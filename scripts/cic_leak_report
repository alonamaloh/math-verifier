#!/usr/bin/env python3
"""cic_leak_report — proof-style linter for the math library.

Scans *user-space* `.math` files (everything not on the foundational-layer
manifest, see scripts/foundational_layer.txt) for proof-style leaks — places
where the kernel substrate or a non-math-like construction shows through the
surface mathematics. The plan drives the total to zero; `--max N` ratchets it.
This is the number that `make leak-ratchet` / `make check` guard.

Counted categories fall into three families:

  1. CIC VOCABULARY — substrate tokens (`Quotient.`, `congruenceOf`,
     `transport_proposition`, `rewrite`, `Equality.symmetry`,
     `False.eliminate_proposition`, `Sort`, universe annotations, …). The
     original north-star metric. (`substituting` is NOT counted — it reads
     as math; only the raw `rewrite(…)` primitive does.)

  2. STRUCTURAL SMELLS — non-vocabulary patterns that still read as plumbing,
     e.g. `claim NAME : T by calc …` (the calc's endpoints already *are* T —
     write `calc … as NAME`, or a bare `calc …`).

  3. DIRECT PROOF-LEMMA CALLS — invoking a `theorem` as a function on
     positional arguments (`Foo.bar(a, b, proof)`, `Foo.bar(proof)`), instead
     of stating the fact and discharging it with `by Foo.bar` (goal-driven,
     args inferred) or chaining it via `calc`. EVERY positional arity counts —
     even `Foo.bar(proof)` is a direct call; a by-arity breakdown is printed
     for visibility but the whole category is in the total. (Value-level
     applications — `definition`s, constructors, type formers — are NOT
     theorems and are not counted.)

This makes "feels like math" a number instead of a vibe. (Despite the
historical filename, the tool now lints more than CIC leaks.)

Usage:
  scripts/cic_leak_report                # human summary, exit 0 always
  scripts/cic_leak_report --by-file      # add a per-file breakdown
  scripts/cic_leak_report --json         # machine-readable totals
  scripts/cic_leak_report --max N        # exit 1 if the CIC-leak total > N

Counting notes:
  - Line comments (`-- …` to end of line) are stripped before matching, so a
    token merely *mentioned* in prose isn't counted.
  - Test files (library/Test/**) are excluded: they deliberately exercise
    internals and use `sorry`.
  - Counts are occurrences, not lines: a line with two `Quotient.` uses
    counts as two.
"""
import argparse
import json
import os
import re
import sys

REPO_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
LIBRARY_ROOT = os.path.join(REPO_ROOT, "library")
MANIFEST = os.path.join(REPO_ROOT, "scripts", "foundational_layer.txt")

# CIC-vocabulary token categories. Each maps a name to a compiled regex; the
# number of (non-overlapping) matches across the comment-stripped source is the
# leak count for that category. Patterns are intentionally conservative — we
# would rather undercount a fuzzy category (function-wrapping) than cry wolf.
CATEGORIES = {
    # The clearest construction leak: naming the Quotient primitive directly.
    "Quotient.":               re.compile(r"\bQuotient\."),
    # Opacity boundary narrated by hand (WS2 target).
    "unfold":                  re.compile(r"\bunfold\b"),
    # Hand-written congruence / transport where calc / auto should suffice.
    "congruenceOf":            re.compile(r"\bcongruenceOf\b"),
    "transport_proposition":   re.compile(r"\btransport_proposition\b"),
    # Raw transport wearing a function-call costume: `rewrite(eq, term)`
    # rewrites a term/goal along an equation. A calc step (or a by-less
    # claim) reads as the substitution it is; the primitive should not show.
    "rewrite":                 re.compile(r"\brewrite\b"),
    "Equality.symmetry":       re.compile(r"\bEquality\.symmetry\b"),
    "Equality.transitivity":   re.compile(r"\bEquality\.transitivity\b"),
    # Prop-elimination plumbing that should be hidden (WS7).
    "False.eliminate_proposition": re.compile(r"\bFalse\.eliminate_proposition\b"),
    "double-negation (¬¬)":    re.compile(r"¬\s*¬"),
    # Universe / sort vocabulary surfacing in user space (WS6). `Type(0)` is a
    # concrete type, not a leak; only an explicit `Sort`, a `.{u}` universe
    # binder, or a `Type(<var>)` variable level counts.
    "Sort":                    re.compile(r"\bSort\b"),
    "universe annotation":     re.compile(r"\.\{|\bType\(\s*[A-Za-z_]"),
    # Structural smell: a `claim` whose proof is itself a `calc` —
    # `claim NAME : T by calc …` (write `calc … as NAME`) or anonymous
    # `claim T by calc …` (write a bare `calc …`). The calc's endpoints
    # already *are* T, so the `claim … by` wrapper just restates it.
    # The `(?:(?!\bby\b)[^;{}])*?` consumes the claim's TYPE (no `by`) up to
    # its proof-introducing `by`, then requires that `by` to be `by calc`.
    # Spans newlines, stops at the statement/block boundary (`;{}`), and does
    # NOT match `claim … by Lemma(… calc …)` (a calc nested in an argument).
    "claim-by-calc":           re.compile(r"\bclaim\b(?:(?!\bby\b)[^;{}])*?\bby\s+\(?\s*calc\b"),
}

# The direct-proof-lemma-call category (computed, not a plain regex — it needs
# balanced-paren argument counting and the set of theorem names). Every
# application of a `theorem` to positional arguments is a leak: the math-like
# form is to state the fact and discharge it with `by <lemma>` (the args are
# then inferred from the goal), not to invoke the lemma as a function.
POSITIONAL_CALL_CATEGORY = "direct proof-lemma call"

# `successor` is the Natural constructor — an internal detail of how the
# naturals are built. Outside the `Natural/` definitional modules its
# appearance is leakage: a consumer should speak `1 + n` (or numerals
# `0`/`1`/`2`), never the raw constructor. Counted only for files NOT under
# `library/Natural/`; the count there is expected to ratchet to zero.
SUCCESSOR_CATEGORY = "successor (outside Natural/)"
SUCCESSOR_RE = re.compile(r"\bsuccessor\b")
NATURAL_DIR_PREFIX = os.path.join("library", "Natural") + os.sep

# A numeral literal annotated `: Natural` — `(1 : Natural)`, `(0 : Natural)`,
# … — is pure redundancy: a bare numeral already IS a Natural in this system
# (numerals default to Natural), and coercion injects it into Integer / Rational
# / Real where a wider type is wanted, so the annotation never carries
# information. This regex also catches the inner half of a nested cast
# `((1 : Natural) : Integer)`, which should read `(1 : Integer)` (or just `1`).
# Only numerals match — `(k : Natural)` binders are untouched. Tracked
# separately (advisory, not gated), so it never inflates the CIC-leak total.
NUMERAL_NATURAL_CATEGORY = "numeral annotated `: Natural`"
NUMERAL_NATURAL_RE = re.compile(r"\(\s*\d+\s*:\s*Natural\s*\)")

# A qualified or bare name immediately followed by `(`. We only count it when
# the name is a known `theorem` (so definitions, constructors, and type
# formers are excluded); any positional-argument arity counts.
NAME_CALL_RE = re.compile(r"\b([A-Z][A-Za-z0-9_]*(?:\.[A-Za-z_][A-Za-z0-9_]*)*)\(")
THEOREM_DECL_RE = re.compile(r"\btheorem\s+([A-Za-z_][A-Za-z0-9_.]*)")
# A `NAME(` immediately preceded by a declaration keyword is the declaration's
# own binder list (e.g. `theorem Foo.bar(a : T)` with no space), not a call.
DECL_BEFORE_RE = re.compile(r"\b(?:theorem|definition|axiom|opaque)\s+$")
# Note: `by substituting eq` is deliberately NOT a leak — it reads as
# math ("by substituting the equation") and some goals genuinely need it.
# Only the raw `rewrite(…)` primitive is counted.

COMMENT_RE = re.compile(r"--.*$")


# A top-level argument that opens with `name :=` is a NAMED argument: the
# caller is deliberately pinning a specific parameter to an expression, the
# readable "apply lemma L with its x set to e" form. Such a citation is NOT a
# positional-call leak (see the spectrum note in positional_lemma_calls).
NAMED_ARG_RE = re.compile(r"^\s*[A-Za-z_][A-Za-z0-9_]*\s*:=")


def scan_call(text, open_paren_index):
    """Scan the call whose `(` is at the given index.

    Returns (n_args, matched, any_named): n_args is the number of
    comma-separated top-level arguments (0 for `()`), matched is False if the
    parens are unbalanced (truncated source), and any_named is True when at
    least one top-level argument is a `name := value` named argument."""
    depth = 0
    arg_start = open_paren_index + 1
    args = []
    i = open_paren_index
    n = len(text)
    while i < n:
        c = text[i]
        if c == "(":
            depth += 1
        elif c == ")":
            depth -= 1
            if depth == 0:
                args.append(text[arg_start:i])
                stripped = [a for a in args if a.strip() != ""]
                any_named = any(NAMED_ARG_RE.match(a) for a in stripped)
                return (len(stripped), True, any_named)
        elif c == "," and depth == 1:
            args.append(text[arg_start:i])
            arg_start = i + 1
        i += 1
    return (0, False, False)


def count_call_arguments(text, open_paren_index):
    """Back-compat wrapper: top-level argument count (n_args, matched)."""
    n_args, matched, _ = scan_call(text, open_paren_index)
    return (n_args, matched)


def positional_lemma_calls(text, theorem_names):
    """Direct proof-lemma applications, counted by positional arity.

    Returns (total, arity) where total counts EVERY application of a known
    `theorem` to one or more positional arguments, and arity is the
    informational by-arity breakdown {"1 arg": …, "2 args": …, ">=3 args": …}
    (its values sum to total — it is not a separate tally).

    LEAKINESS IS A SPECTRUM. A wall of positional arguments
    (`Foo.bar(a, b, c, …, proof)`) is the monstrosity this category exists to
    flag: the reader cannot tell what is being proved without cross-checking
    the lemma's signature. A citation that pins parameters BY NAME
    (`Foo.bar(x := e, …)`) is the opposite — it names the few arguments the
    goal/context cannot infer, and reads as "apply L with its x set to e".
    That is a deliberate, legible citation, not plumbing, so a call using any
    named argument is EXEMPT from the count (the goal-driven `by`/`since`
    forms remain the lightest option; named args sit just below them, well
    above a positional dump)."""
    n1 = n2 = n3 = 0
    for match in NAME_CALL_RE.finditer(text):
        if match.group(1) not in theorem_names:
            continue
        # Skip the theorem's own DECLARATION: `theorem Foo.bar(a : T)` with no
        # space before the paren looks like a call, but the parenthesised part
        # is the binder list, not arguments.
        if DECL_BEFORE_RE.search(text[:match.start()]):
            continue
        n_args, matched, any_named = scan_call(text, match.end() - 1)
        if not matched:
            continue
        # Named-argument citations are the readable, intentional form — exempt.
        if any_named:
            continue
        if n_args == 1:
            n1 += 1
        elif n_args == 2:
            n2 += 1
        elif n_args >= 3:
            n3 += 1
    return n1 + n2 + n3, {"1 arg": n1, "2 args": n2, ">=3 args": n3}


def load_manifest(path):
    """Return (exact_files, dir_prefixes) as sets of repo-relative paths."""
    exact, prefixes = set(), []
    with open(path) as handle:
        for raw in handle:
            line = raw.split("#", 1)[0].strip()
            if not line:
                continue
            if line.endswith("/"):
                prefixes.append(line)
            else:
                exact.add(line)
    return exact, prefixes


def is_foundational(rel_path, exact, prefixes):
    if rel_path in exact:
        return True
    return any(rel_path.startswith(p) for p in prefixes)


def strip_comments(text):
    return "\n".join(COMMENT_RE.sub("", line) for line in text.splitlines())


def collect_theorem_names(library_root):
    """Set of every `theorem` name declared in the library (Test excluded).

    Foundational files ARE included: a lemma defined there is still cited
    positionally in user space, and we want those citations counted."""
    names = set()
    for dirpath, _dirs, files in os.walk(library_root):
        for filename in files:
            if not filename.endswith(".math"):
                continue
            rel = os.path.relpath(os.path.join(dirpath, filename), REPO_ROOT)
            if rel.startswith(os.path.join("library", "Test") + os.sep):
                continue
            with open(os.path.join(dirpath, filename)) as handle:
                body = strip_comments(handle.read())
            for match in THEOREM_DECL_RE.finditer(body):
                names.add(match.group(1))
    return names


def scan_file(path, theorem_names):
    """Return (leaks, breakdown): leaks is the counted per-category dict;
    breakdown is the by-arity split of the counted direct-proof-lemma-call
    category (informational — its values are already inside the total)."""
    with open(path) as handle:
        body = strip_comments(handle.read())
    leaks = {name: len(rx.findall(body)) for name, rx in CATEGORIES.items()}
    total_calls, arity = positional_lemma_calls(body, theorem_names)
    leaks[POSITIONAL_CALL_CATEGORY] = total_calls
    # `successor` leakage — only outside the `Natural/` definitional modules.
    # Tracked separately from `leaks` so it never enters the CIC-leak total.
    rel = os.path.relpath(path, REPO_ROOT)
    successor_count = (
        0 if rel.startswith(NATURAL_DIR_PREFIX)
        else len(SUCCESSOR_RE.findall(body)))
    numeral_natural_count = len(NUMERAL_NATURAL_RE.findall(body))
    return leaks, arity, successor_count, numeral_natural_count


def main():
    parser = argparse.ArgumentParser(description=__doc__,
                                     formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("--by-file", action="store_true",
                        help="show a per-file breakdown (nonzero only)")
    parser.add_argument("--json", action="store_true",
                        help="emit machine-readable totals")
    parser.add_argument("--max", type=int, default=None,
                        help="exit 1 if the total leak exceeds N (ratchet)")
    parser.add_argument("--successor-max", type=int, default=None,
                        help="exit 1 if `successor`-outside-Natural total exceeds "
                             "N (independent ratchet; never grows)")
    args = parser.parse_args()

    exact, prefixes = load_manifest(MANIFEST)
    theorem_names = collect_theorem_names(LIBRARY_ROOT)

    # Display order: the regex CIC/structural categories, then positional calls.
    # `successor`-outside-Natural is tracked SEPARATELY (like the arity
    # breakdown) so it never inflates the CIC-leak total / clean budget.
    category_names = list(CATEGORIES) + [POSITIONAL_CALL_CATEGORY]

    per_file = {}            # rel_path -> {category: count}   (counted leaks)
    per_file_anti = {}       # rel_path -> {arity: count}       (informational)
    per_file_successor = {}  # rel_path -> successor count       (separate tally)
    per_file_numeral = {}    # rel_path -> (numeral : Natural) count (separate)
    category_totals = {name: 0 for name in category_names}
    anti_totals = {"1 arg": 0, "2 args": 0, ">=3 args": 0}
    successor_total = 0
    numeral_total = 0
    foundational_count = 0

    for dirpath, _dirs, files in os.walk(LIBRARY_ROOT):
        for filename in sorted(files):
            if not filename.endswith(".math"):
                continue
            full = os.path.join(dirpath, filename)
            rel = os.path.relpath(full, REPO_ROOT)
            if rel.startswith(os.path.join("library", "Test") + os.sep):
                continue
            if is_foundational(rel, exact, prefixes):
                foundational_count += 1
                continue
            leaks, antis, successor_count, numeral_count = scan_file(full, theorem_names)
            if sum(leaks.values()) > 0:
                per_file[rel] = leaks
                for name, count in leaks.items():
                    category_totals[name] += count
            if sum(antis.values()) > 0:
                per_file_anti[rel] = antis
                for name, count in antis.items():
                    anti_totals[name] += count
            if successor_count > 0:
                per_file_successor[rel] = successor_count
                successor_total += successor_count
            if numeral_count > 0:
                per_file_numeral[rel] = numeral_count
                numeral_total += numeral_count

    total = sum(category_totals.values())
    anti_total = sum(anti_totals.values())

    if args.json:
        print(json.dumps({
            "total": total,
            "by_category": category_totals,
            "leaking_files": len(per_file),
            "foundational_files": foundational_count,
            "per_file": {p: {k: v for k, v in c.items() if v} for p, c in per_file.items()},
            "proof_lemma_call_arity": {
                "total": anti_total,
                "by_arity": anti_totals,
                "per_file": {p: {k: v for k, v in c.items() if v}
                             for p, c in per_file_anti.items()},
            },
            "successor_outside_natural": {
                "total": successor_total,
                "per_file": dict(sorted(per_file_successor.items())),
            },
            "numeral_annotated_natural": {
                "total": numeral_total,
                "per_file": dict(sorted(per_file_numeral.items())),
            },
        }, indent=2, ensure_ascii=False))
    else:
        print("Proof-style leak report (user space — outside the foundational layer)")
        print("=" * 62)
        for name in category_names:
            print(f"  {category_totals[name]:5d}  {name}")
        print("-" * 62)
        print(f"  {total:5d}  TOTAL across {len(per_file)} leaking files "
              f"({foundational_count} foundational files excluded)")
        if args.by_file:
            print("\nPer-file (most-leaking first):")
            ranked = sorted(per_file.items(),
                            key=lambda kv: sum(kv[1].values()), reverse=True)
            for rel, counts in ranked:
                cats = ", ".join(f"{k}:{v}" for k, v in counts.items() if v)
                print(f"  {sum(counts.values()):4d}  {rel}  ({cats})")

        print("\nDirect proof-lemma calls by arity"
              " (already included in the total above)")
        print("=" * 62)
        for name in anti_totals:
            print(f"  {anti_totals[name]:5d}  {name}")
        print("        hint: state the fact and cite the theorem `by Foo.bar`"
              " (args inferred from the goal), or chain it via `calc`")
        if args.by_file and per_file_anti:
            print("  Per-file:")
            for rel, counts in sorted(per_file_anti.items(),
                                      key=lambda kv: sum(kv[1].values()), reverse=True):
                print(f"  {sum(counts.values()):4d}  {rel}")

        print("\n`successor` outside Natural/ (constructor leakage —"
              " speak `1 + n` / numerals; target 0)")
        print("=" * 62)
        print(f"  {successor_total:5d}  across {len(per_file_successor)} files")
        if args.by_file and per_file_successor:
            print("  Per-file (most first):")
            for rel, count in sorted(per_file_successor.items(),
                                     key=lambda kv: kv[1], reverse=True):
                print(f"  {count:4d}  {rel}")

        print("\nnumeral annotated `: Natural` (redundant — `1` already IS a"
              " Natural; coercion widens it; target 0)")
        print("=" * 62)
        print(f"  {numeral_total:5d}  across {len(per_file_numeral)} files")
        print("        hint: drop the annotation (`(1 : Natural)` -> `1`); for a"
              " nested cast `((1 : Natural) : Integer)` write `(1 : Integer)`."
              " These flag OLD proofs — re-think them, don't strip mechanically.")
        if args.by_file and per_file_numeral:
            print("  Per-file (most first):")
            for rel, count in sorted(per_file_numeral.items(),
                                     key=lambda kv: kv[1], reverse=True):
                print(f"  {count:4d}  {rel}")

    if args.successor_max is not None and successor_total > args.successor_max:
        print(f"\nSUCCESSOR RATCHET FAILED: `successor`-outside-Natural total "
              f"{successor_total} exceeds budget {args.successor_max} — speak "
              f"`n + 1` / numerals instead", file=sys.stderr)
        return 1
    if args.max is not None and total > args.max:
        print(f"\nLEAK RATCHET FAILED: total {total} exceeds budget {args.max}",
              file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())

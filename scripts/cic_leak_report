#!/usr/bin/env python3
"""cic_leak_report — proof-style linter for the math library.

Scans *user-space* `.math` files (everything not on the foundational-layer
manifest, see scripts/foundational_layer.txt) for proof-style leaks — places
where the kernel substrate or a non-math-like construction shows through the
surface mathematics. The plan drives the total to zero; `--max N` ratchets it.
This is the number that `make leak-ratchet` / `make check` guard.

Counted categories fall into three families:

  1. CIC VOCABULARY — substrate tokens (`Quotient.`, `congruenceOf`,
     `transport_proposition`, `rewrite`, `Equality.symmetry`,
     `False.eliminate_proposition`, `Sort`, universe annotations, …). The
     original north-star metric. (`substituting` is NOT counted — it reads
     as math; only the raw `rewrite(…)` primitive does.)

  2. STRUCTURAL SMELLS — non-vocabulary patterns that still read as plumbing,
     e.g. `claim NAME : T by calc …` (the calc's endpoints already *are* T —
     write `calc … as NAME`, or a bare `calc …`).

  3. POSITIONAL LEMMA CALLS — invoking a `theorem` as a function with a string
     of positional arguments (`Foo.bar(a, b, c, proof)`), instead of citing it
     `by Foo.bar` (goal-driven, args inferred), via `calc`, or an element
     interface. The counted category is calls with **three or more** positional
     arguments — the least readable; two-argument calls are reported as an
     advisory sub-line.

This makes "feels like math" a number instead of a vibe. (Despite the
historical filename, the tool now lints more than CIC leaks.)

Usage:
  scripts/cic_leak_report                # human summary, exit 0 always
  scripts/cic_leak_report --by-file      # add a per-file breakdown
  scripts/cic_leak_report --json         # machine-readable totals
  scripts/cic_leak_report --max N        # exit 1 if the CIC-leak total > N

Counting notes:
  - Line comments (`-- …` to end of line) are stripped before matching, so a
    token merely *mentioned* in prose isn't counted.
  - Test files (library/Test/**) are excluded: they deliberately exercise
    internals and use `sorry`.
  - Counts are occurrences, not lines: a line with two `Quotient.` uses
    counts as two.
"""
import argparse
import json
import os
import re
import sys

REPO_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
LIBRARY_ROOT = os.path.join(REPO_ROOT, "library")
MANIFEST = os.path.join(REPO_ROOT, "scripts", "foundational_layer.txt")

# CIC-vocabulary token categories. Each maps a name to a compiled regex; the
# number of (non-overlapping) matches across the comment-stripped source is the
# leak count for that category. Patterns are intentionally conservative — we
# would rather undercount a fuzzy category (function-wrapping) than cry wolf.
CATEGORIES = {
    # The clearest construction leak: naming the Quotient primitive directly.
    "Quotient.":               re.compile(r"\bQuotient\."),
    # Opacity boundary narrated by hand (WS2 target).
    "unfold":                  re.compile(r"\bunfold\b"),
    # Hand-written congruence / transport where calc / auto should suffice.
    "congruenceOf":            re.compile(r"\bcongruenceOf\b"),
    "transport_proposition":   re.compile(r"\btransport_proposition\b"),
    # Raw transport wearing a function-call costume: `rewrite(eq, term)`
    # rewrites a term/goal along an equation. A calc step (or a by-less
    # claim) reads as the substitution it is; the primitive should not show.
    "rewrite":                 re.compile(r"\brewrite\b"),
    "Equality.symmetry":       re.compile(r"\bEquality\.symmetry\b"),
    "Equality.transitivity":   re.compile(r"\bEquality\.transitivity\b"),
    # Prop-elimination plumbing that should be hidden (WS7).
    "False.eliminate_proposition": re.compile(r"\bFalse\.eliminate_proposition\b"),
    "double-negation (¬¬)":    re.compile(r"¬\s*¬"),
    # Universe / sort vocabulary surfacing in user space (WS6). `Type(0)` is a
    # concrete type, not a leak; only an explicit `Sort`, a `.{u}` universe
    # binder, or a `Type(<var>)` variable level counts.
    "Sort":                    re.compile(r"\bSort\b"),
    "universe annotation":     re.compile(r"\.\{|\bType\(\s*[A-Za-z_]"),
    # Structural smell: a `claim` whose proof is itself a `calc` —
    # `claim NAME : T by calc …` (write `calc … as NAME`) or anonymous
    # `claim T by calc …` (write a bare `calc …`). The calc's endpoints
    # already *are* T, so the `claim … by` wrapper just restates it.
    # The `(?:(?!\bby\b)[^;{}])*?` consumes the claim's TYPE (no `by`) up to
    # its proof-introducing `by`, then requires that `by` to be `by calc`.
    # Spans newlines, stops at the statement/block boundary (`;{}`), and does
    # NOT match `claim … by Lemma(… calc …)` (a calc nested in an argument).
    "claim-by-calc":           re.compile(r"\bclaim\b(?:(?!\bby\b)[^;{}])*?\bby\s+\(?\s*calc\b"),
}

# The positional-lemma-call category (computed, not a plain regex — it needs
# balanced-paren argument counting and the set of theorem names). The display
# name of the counted (>= 3 args) category:
POSITIONAL_CALL_CATEGORY = "positional lemma call (>=3 args)"
POSITIONAL_CALL_MIN_ARGS = 3

# A qualified or bare name immediately followed by `(`. We only count it when
# the name is a known `theorem` (so definitions, constructors, and type
# formers are excluded) and the call has >= POSITIONAL_CALL_MIN_ARGS top-level
# arguments.
NAME_CALL_RE = re.compile(r"\b([A-Z][A-Za-z0-9_]*(?:\.[A-Za-z_][A-Za-z0-9_]*)*)\(")
THEOREM_DECL_RE = re.compile(r"\btheorem\s+([A-Za-z_][A-Za-z0-9_.]*)")
# Note: `by substituting eq` is deliberately NOT a leak — it reads as
# math ("by substituting the equation") and some goals genuinely need it.
# Only the raw `rewrite(…)` primitive is counted.

COMMENT_RE = re.compile(r"--.*$")


def count_call_arguments(text, open_paren_index):
    """Top-level argument count of the call whose `(` is at the given index.

    Returns (n_args, matched): n_args is the number of comma-separated
    top-level arguments (0 for `()`), matched is False if parens are
    unbalanced (truncated source)."""
    depth = 0
    commas = 0
    i = open_paren_index
    n = len(text)
    while i < n:
        c = text[i]
        if c == "(":
            depth += 1
        elif c == ")":
            depth -= 1
            if depth == 0:
                inner = text[open_paren_index + 1:i].strip()
                return (0 if inner == "" else commas + 1, True)
        elif c == "," and depth == 1:
            commas += 1
        i += 1
    return (0, False)


def positional_lemma_calls(text, theorem_names):
    """(count_ge3, count_eq2): theorem applications by positional-arg arity."""
    ge3 = 0
    eq2 = 0
    for match in NAME_CALL_RE.finditer(text):
        if match.group(1) not in theorem_names:
            continue
        n_args, matched = count_call_arguments(text, match.end() - 1)
        if not matched:
            continue
        if n_args >= POSITIONAL_CALL_MIN_ARGS:
            ge3 += 1
        elif n_args == 2:
            eq2 += 1
    return ge3, eq2


def load_manifest(path):
    """Return (exact_files, dir_prefixes) as sets of repo-relative paths."""
    exact, prefixes = set(), []
    with open(path) as handle:
        for raw in handle:
            line = raw.split("#", 1)[0].strip()
            if not line:
                continue
            if line.endswith("/"):
                prefixes.append(line)
            else:
                exact.add(line)
    return exact, prefixes


def is_foundational(rel_path, exact, prefixes):
    if rel_path in exact:
        return True
    return any(rel_path.startswith(p) for p in prefixes)


def strip_comments(text):
    return "\n".join(COMMENT_RE.sub("", line) for line in text.splitlines())


def collect_theorem_names(library_root):
    """Set of every `theorem` name declared in the library (Test excluded).

    Foundational files ARE included: a lemma defined there is still cited
    positionally in user space, and we want those citations counted."""
    names = set()
    for dirpath, _dirs, files in os.walk(library_root):
        for filename in files:
            if not filename.endswith(".math"):
                continue
            rel = os.path.relpath(os.path.join(dirpath, filename), REPO_ROOT)
            if rel.startswith(os.path.join("library", "Test") + os.sep):
                continue
            with open(os.path.join(dirpath, filename)) as handle:
                body = strip_comments(handle.read())
            for match in THEOREM_DECL_RE.finditer(body):
                names.add(match.group(1))
    return names


def scan_file(path, theorem_names):
    """Return (leaks, advisory): leaks is the counted per-category dict;
    advisory holds the uncounted two-argument positional-call tally."""
    with open(path) as handle:
        body = strip_comments(handle.read())
    leaks = {name: len(rx.findall(body)) for name, rx in CATEGORIES.items()}
    ge3, eq2 = positional_lemma_calls(body, theorem_names)
    leaks[POSITIONAL_CALL_CATEGORY] = ge3
    advisory = {"positional lemma call (2 args)": eq2}
    return leaks, advisory


def main():
    parser = argparse.ArgumentParser(description=__doc__,
                                     formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("--by-file", action="store_true",
                        help="show a per-file breakdown (nonzero only)")
    parser.add_argument("--json", action="store_true",
                        help="emit machine-readable totals")
    parser.add_argument("--max", type=int, default=None,
                        help="exit 1 if the total leak exceeds N (ratchet)")
    args = parser.parse_args()

    exact, prefixes = load_manifest(MANIFEST)
    theorem_names = collect_theorem_names(LIBRARY_ROOT)

    # Display order: the regex CIC/structural categories, then positional calls.
    category_names = list(CATEGORIES) + [POSITIONAL_CALL_CATEGORY]

    per_file = {}       # rel_path -> {category: count}   (counted leaks)
    per_file_anti = {}  # rel_path -> {category: count}   (advisory)
    category_totals = {name: 0 for name in category_names}
    anti_totals = {"positional lemma call (2 args)": 0}
    foundational_count = 0

    for dirpath, _dirs, files in os.walk(LIBRARY_ROOT):
        for filename in sorted(files):
            if not filename.endswith(".math"):
                continue
            full = os.path.join(dirpath, filename)
            rel = os.path.relpath(full, REPO_ROOT)
            if rel.startswith(os.path.join("library", "Test") + os.sep):
                continue
            if is_foundational(rel, exact, prefixes):
                foundational_count += 1
                continue
            leaks, antis = scan_file(full, theorem_names)
            if sum(leaks.values()) > 0:
                per_file[rel] = leaks
                for name, count in leaks.items():
                    category_totals[name] += count
            if sum(antis.values()) > 0:
                per_file_anti[rel] = antis
                for name, count in antis.items():
                    anti_totals[name] += count

    total = sum(category_totals.values())
    anti_total = sum(anti_totals.values())

    if args.json:
        print(json.dumps({
            "total": total,
            "by_category": category_totals,
            "leaking_files": len(per_file),
            "foundational_files": foundational_count,
            "per_file": {p: {k: v for k, v in c.items() if v} for p, c in per_file.items()},
            "antipatterns": {
                "total": anti_total,
                "by_category": anti_totals,
                "per_file": {p: {k: v for k, v in c.items() if v}
                             for p, c in per_file_anti.items()},
            },
        }, indent=2, ensure_ascii=False))
    else:
        print("Proof-style leak report (user space — outside the foundational layer)")
        print("=" * 62)
        for name in category_names:
            print(f"  {category_totals[name]:5d}  {name}")
        print("-" * 62)
        print(f"  {total:5d}  TOTAL across {len(per_file)} leaking files "
              f"({foundational_count} foundational files excluded)")
        if args.by_file:
            print("\nPer-file (most-leaking first):")
            ranked = sorted(per_file.items(),
                            key=lambda kv: sum(kv[1].values()), reverse=True)
            for rel, counts in ranked:
                cats = ", ".join(f"{k}:{v}" for k, v in counts.items() if v)
                print(f"  {sum(counts.values()):4d}  {rel}  ({cats})")

        print("\nAdvisory (NOT counted in the total)")
        print("=" * 62)
        for name in anti_totals:
            print(f"  {anti_totals[name]:5d}  {name}")
        print("        hint: cite a theorem `by Foo.bar` (args inferred from the"
              " goal), via `calc`, or an element interface")
        if args.by_file and per_file_anti:
            print("  Per-file:")
            for rel, counts in sorted(per_file_anti.items(),
                                      key=lambda kv: sum(kv[1].values()), reverse=True):
                print(f"  {sum(counts.values()):4d}  {rel}")

    if args.max is not None and total > args.max:
        print(f"\nLEAK RATCHET FAILED: total {total} exceeds budget {args.max}",
              file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())

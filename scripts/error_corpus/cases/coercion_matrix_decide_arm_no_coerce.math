-- The `decide` arm-body GAP, pinned (see Test/coercion_matrix_test.math).
-- A `cases`/`claim`/`:=`/calc-`by` position would coerce the bare `h`
-- across the single-position congruence; a `decide` arm does NOT (its
-- arm bodies are elaborated with the expected type but not post-run
-- through coerceToExpectedTypeViaDiff). So this fails with a math-shaped
-- "wrong argument type" rather than closing. If decide-arm coercion is
-- ever wired, this case starts verifying clean and the corpus flags it —
-- the cue to delete it and add the positive cell to the matrix test.

module corpus.coercion_matrix_decide_arm_no_coerce

import axioms
import Logic.basics
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano

theorem decide_arm_gap (a b : Natural) (h : a = b)
        : successor(a) = successor(b) :=
  decide a = b {
    | yes _ => h
    | no _ => h
  }

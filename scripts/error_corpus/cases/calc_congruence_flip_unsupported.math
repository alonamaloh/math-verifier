module corpus.calc_congruence_flip_unsupported

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Integer.basics
import Integer.addition
import Integer.negation
import Integer.ring

theorem leakcase (a e : Integer) (h : Integer.add(a, a) = e)
        : Integer.subtract(e, e)
          = Integer.subtract(Integer.add(a, a), e) :=
  calc Integer.subtract(e, e)
     = Integer.subtract(Integer.add(a, a), e)   by h

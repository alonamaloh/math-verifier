      let y0 : ℤ := 1*(x0) + 0*(x1) + 0*(x2) + 0*(x3);
      let y1 : ℤ := 0*(x0) + (-1)*(x1) + 0*(x2) + (-1)*(x3);
      let y2 : ℤ := 0*(x0) + 0*(x1) + 0*(x2) + 1*(x3);
      let y3 : ℤ := 0*(x0) + 0*(x1) + (-1)*(x2) + 0*(x3);
      let z0 : ℤ := 1*(y0) + 0*(y1) + 0*(y2) + 0*(y3);
      let z1 : ℤ := 0*(y0) + (-1)*(y1) + (-1)*(y2) + 0*(y3);
      let z2 : ℤ := 0*(y0) + 0*(y1) + 0*(y2) + (-1)*(y3);
      let z3 : ℤ := 0*(y0) + 0*(y1) + 1*(y2) + 0*(y3);
      V · (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) = (⟨y0, y1, y2, y3⟩ : RingVector(Integer.commutative_ring_bundle, 4))
          by Matrix.fourByFour_apply_coordinateTuple as innerAction;
      U · (⟨y0, y1, y2, y3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) = (⟨z0, z1, z2, z3⟩ : RingVector(Integer.commutative_ring_bundle, 4))
          by Matrix.fourByFour_apply_coordinateTuple as outerAction;
      U · (V · x)
         = U · (V · (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4))) by substituting xReads
         = U · (⟨y0, y1, y2, y3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by substituting innerAction
         = (⟨z0, z1, z2, z3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by outerAction
         = (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by {
           z0 = x0 by ring as first;
           z1 = x1 by ring as second;
           z2 = x2 by ring as third;
           z3 = x3 by ring as fourth;
           done by RingVector.fourCoordinates_equal(first := first, second := second, third := third, fourth := fourth)
         }
         = x by Equality.symmetry(xReads);
      done
    },
    backwardInverse := (x : RingVector(Integer.commutative_ring_bundle, 4)) ↦ {

      let z0 : ℤ := (y0);
      let z1 : ℤ := 2*(y1) + 0*(y3);
      let z2 : ℤ := 5*(y2) + 2*(y3);
      let z3 : ℤ := 0*(y1) + 2*(y2) + 2*(y3);
      let w0 : ℤ := 1*(z0) + 0*(z1) + 0*(z2) + 0*(z3);
      let w1 : ℤ := 0*(z0) + (-1)*(z1) + 0*(z2) + 0*(z3);
      let w2 : ℤ := 0*(z0) + 0*(z1) + 0*(z2) + (-1)*(z3);
      let w3 : ℤ := 0*(z0) + 0*(z1) + (-1)*(z2) + 1*(z3);

      let w3 : ℤ := (-1)*(z0) + (-3)*(z1) + (-2)*(z2) + 6*(z3);
      let t0 : ℤ := (x0) + 1*(x3);
      let t1 : ℤ := (x1) + 1*(x3);
      let t2 : ℤ := (x2) + 2*(x3);
      let t3 : ℤ := 1*(x0) + 1*(x1) + 2*(x2) + 7*(x3);
      U · (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) = (⟨y0, y1, y2, y3⟩ : RingVector(Integer.commutative_ring_bundle, 4))
          by Matrix.fourByFour_apply_coordinateTuple as changeAction;
      source · (⟨y0, y1, y2, y3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) = (⟨z0, z1, z2, z3⟩ : RingVector(Integer.commutative_ring_bundle, 4))
          by Matrix.squarePlusDoublePlusScaledRankFourRepresentative_apply_coordinateTuple as sourceAction;
      Uᵀ · (⟨z0, z1, z2, z3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) = (⟨w0, w1, w2, w3⟩ : RingVector(Integer.commutative_ring_bundle, 4))

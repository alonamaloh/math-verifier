      let y0 : ℤ := 1*(x0) + 0*(x1) + 0*(x2) + 0*(x3);
      let y1 : ℤ := 0*(x0) + (-1)*(x1) + 0*(x2) + (-1)*(x3);
      let y2 : ℤ := 0*(x0) + 0*(x1) + 0*(x2) + 1*(x3);
      let y3 : ℤ := 0*(x0) + 0*(x1) + (-1)*(x2) + 0*(x3);
      let z0 : ℤ := 1*(y0) + 0*(y1) + 0*(y2) + 0*(y3);
      let z1 : ℤ := 0*(y0) + (-1)*(y1) + (-1)*(y2) + 0*(y3);
      let z2 : ℤ := 0*(y0) + 0*(y1) + 0*(y2) + (-1)*(y3);
      let z3 : ℤ := 0*(y0) + 0*(y1) + 1*(y2) + 0*(y3);
      U · (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) = (⟨y0, y1, y2, y3⟩ : RingVector(Integer.commutative_ring_bundle, 4))
          by Matrix.fourByFour_apply_coordinateTuple as innerAction;
      V · (⟨y0, y1, y2, y3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) = (⟨z0, z1, z2, z3⟩ : RingVector(Integer.commutative_ring_bundle, 4))
          by Matrix.fourByFour_apply_coordinateTuple as outerAction;
      V · (U · x)
         = V · (U · (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4))) by substituting xReads
         = V · (⟨y0, y1, y2, y3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by substituting innerAction
         = (⟨z0, z1, z2, z3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by outerAction
         = (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by {
           z0 = x0 by ring as first;
           z1 = x1 by ring as second;
           z2 = x2 by ring as third;
           z3 = x3 by ring as fourth;
           done by RingVector.fourCoordinates_equal(first := first, second := second, third := third, fourth := fourth)
         }
         = x by Equality.symmetry(xReads);
      done
    },
    pullback := (x : RingVector(Integer.commutative_ring_bundle, 4)) ↦ {
      let x0 : ℤ := x(NaturalsBelow.firstOfFour);
      let x1 : ℤ := x(NaturalsBelow.secondOfFour);
      let x2 : ℤ := x(NaturalsBelow.thirdOfFour);
      let x3 : ℤ := x(NaturalsBelow.fourthOfFour);
      x = (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by RingVector.eq_fourCoordinates as xReads;
      let y0 : ℤ := 1*(x0) + 0*(x1) + 0*(x2) + 0*(x3);
      let y1 : ℤ := 0*(x0) + (-1)*(x1) + 0*(x2) + (-1)*(x3);
      let y2 : ℤ := 0*(x0) + 0*(x1) + 0*(x2) + 1*(x3);
      let y3 : ℤ := 0*(x0) + 0*(x1) + (-1)*(x2) + 0*(x3);
      let z0 : ℤ := (y0);
      let z1 : ℤ := 2*(y1) + (y2) + 0*(y3);
      let z2 : ℤ := (y1) + 4*(y2);
      let z3 : ℤ := 0*(y1) + 5*(y3);
      let w0 : ℤ := 1*(z0) + 0*(z1) + 0*(z2) + 0*(z3);
      let w1 : ℤ := 0*(z0) + (-1)*(z1) + 0*(z2) + 0*(z3);
      let w2 : ℤ := 0*(z0) + 0*(z1) + 0*(z2) + (-1)*(z3);
      let w3 : ℤ := 0*(z0) + (-1)*(z1) + 1*(z2) + 0*(z3);
      let t0 : ℤ := (x0);
      let t1 : ℤ := 2*(x1) + 1*(x3);
      let t2 : ℤ := 5*(x2) + 0*(x3);
      let t3 : ℤ := 1*(x1) + 0*(x2) + 4*(x3);
      U · (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) = (⟨y0, y1, y2, y3⟩ : RingVector(Integer.commutative_ring_bundle, 4))
          by Matrix.fourByFour_apply_coordinateTuple as changeAction;
      source · (⟨y0, y1, y2, y3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) = (⟨z0, z1, z2, z3⟩ : RingVector(Integer.commutative_ring_bundle, 4))
          by Matrix.squarePlusDoubleSquareOddRankFourRepresentative_apply_coordinateTuple as sourceAction;
      Uᵀ · (⟨z0, z1, z2, z3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) = (⟨w0, w1, w2, w3⟩ : RingVector(Integer.commutative_ring_bundle, 4))
          by Matrix.fourByFour_transpose_apply_coordinateTuple as transposeAction;
      target · (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) = (⟨t0, t1, t2, t3⟩ : RingVector(Integer.commutative_ring_bundle, 4))
          by Matrix.squarePlusDoublePlusScaledRankFourRepresentative_apply_coordinateTuple as targetAction;
      Uᵀ · (source · (U · x))
         = Uᵀ · (source · (U · (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)))) by substituting xReads
         = Uᵀ · (source · (⟨y0, y1, y2, y3⟩ : RingVector(Integer.commutative_ring_bundle, 4))) by substituting changeAction
         = Uᵀ · (⟨z0, z1, z2, z3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by substituting sourceAction
         = (⟨w0, w1, w2, w3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by transposeAction
         = (⟨t0, t1, t2, t3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by {
           w0 = t0 by ring as first;
           w1 = t1 by ring as second;
           w2 = t2 by ring as third;
           w3 = t3 by ring as fourth;
           done by RingVector.fourCoordinates_equal(first := first, second := second, third := third, fourth := fourth)
         }
         = target · (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by Equality.symmetry(targetAction)
         = target · x by substituting xReads;
      done
    })
}


      done
    },
    backwardInverse := (x : RingVector(Integer.commutative_ring_bundle, 4)) ↦ {
      let x0 : ℤ := x(NaturalsBelow.firstOfFour);
      let x1 : ℤ := x(NaturalsBelow.secondOfFour);
      let x2 : ℤ := x(NaturalsBelow.thirdOfFour);
      let x3 : ℤ := x(NaturalsBelow.fourthOfFour);
      x = (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by RingVector.eq_fourCoordinates as xReads;
      let y0 : ℤ := 0*(x0) + (-1)*(x1) + 0*(x2) + (-1)*(x3);
      let y1 : ℤ := 0*(x0) + 0*(x1) + (-1)*(x2) + (-3)*(x3);
      let y2 : ℤ := 0*(x0) + 0*(x1) + 0*(x2) + (-1)*(x3);
      let y3 : ℤ := 1*(x0) + 0*(x1) + 1*(x2) + 4*(x3);
      let z0 : ℤ := 0*(y0) + 1*(y1) + 1*(y2) + 1*(y3);
      let z1 : ℤ := (-1)*(y0) + 0*(y1) + 1*(y2) + 0*(y3);
      let z2 : ℤ := 0*(y0) + (-1)*(y1) + 3*(y2) + 0*(y3);
      let z3 : ℤ := 0*(y0) + 0*(y1) + (-1)*(y2) + 0*(y3);
      U · (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) = (⟨y0, y1, y2, y3⟩ : RingVector(Integer.commutative_ring_bundle, 4))
          by Matrix.fourByFour_apply_coordinateTuple as innerAction;
      V · (⟨y0, y1, y2, y3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) = (⟨z0, z1, z2, z3⟩ : RingVector(Integer.commutative_ring_bundle, 4))
          by Matrix.fourByFour_apply_coordinateTuple as outerAction;
      V · (U · x)
         = V · (U · (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4))) by substituting xReads

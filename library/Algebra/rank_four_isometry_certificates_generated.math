         = V · (⟨y0, y1, y2, y3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by substituting innerAction
         = (⟨z0, z1, z2, z3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by outerAction
         = (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by {

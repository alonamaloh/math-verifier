      let z1 : ℤ := 2*(y1) + 0*(y3);
      let z2 : ℤ := 5*(y2) + 0*(y3);
      let z3 : ℤ := 0*(y1) + 0*(y2) + 4*(y3);
      let w0 : ℤ := 1*(z0) + 0*(z1) + 0*(z2) + 0*(z3);

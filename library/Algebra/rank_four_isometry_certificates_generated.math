      let y2 : ℤ := 0*(x0) + 0*(x1) + (-1)*(x2) + 0*(x3);
      let y3 : ℤ := 0*(x0) + 0*(x1) + 1*(x2) + (-1)*(x3);
      let z0 : ℤ := 1*(y0) + 0*(y1) + 0*(y2) + 0*(y3);
      let z1 : ℤ := 0*(y0) + (-1)*(y1) + 0*(y2) + 0*(y3);
      let z2 : ℤ := 0*(y0) + 0*(y1) + (-1)*(y2) + 0*(y3);
      let z3 : ℤ := 0*(y0) + 0*(y1) + (-1)*(y2) + (-1)*(y3);

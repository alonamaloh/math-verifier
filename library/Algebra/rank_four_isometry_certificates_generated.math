}

theorem Matrix.rankFourGlobalIsometry_weighted_d4_s1_r1_c1_to_pilot_norm5
        : Matrix.IsIsometric(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 1, 1, 1),
            Matrix.sumOfThreeSquaresRankFourCandidate(0, 1, 2)) := {
  let source : Matrix(Integer.commutative_ring_bundle, 4, 4) := Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 1, 1, 1);
  let target : Matrix(Integer.commutative_ring_bundle, 4, 4) := Matrix.sumOfThreeSquaresRankFourCandidate(0, 1, 2);
  let U : Matrix(Integer.commutative_ring_bundle, 4, 4) := Matrix.fourByFour(
      0, (-1), 0, (-1),
      0, 0, (-1), (-3),
      0, 0, 0, (-1),

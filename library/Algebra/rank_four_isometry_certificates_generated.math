         = Uᵀ · (source · (U · (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)))) by substituting xReads
         = Uᵀ · (source · (⟨y0, y1, y2, y3⟩ : RingVector(Integer.commutative_ring_bundle, 4))) by substituting changeAction
         = Uᵀ · (⟨z0, z1, z2, z3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by substituting sourceAction
         = (⟨w0, w1, w2, w3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by transposeAction
         = (⟨t0, t1, t2, t3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by {
           w0 = t0 by ring as first;
           w1 = t1 by ring as second;
           w2 = t2 by ring as third;
           w3 = t3 by ring as fourth;
           done by RingVector.fourCoordinates_equal(first := first, second := second, third := third, fourth := fourth)
         }
         = target · (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by Equality.symmetry(targetAction)
         = target · x by substituting xReads;
      done
    })
}

theorem Matrix.rankFourGlobalIsometry_weighted_d4_s1_r2_c2_to_weighted_d2_s1_r1_c2

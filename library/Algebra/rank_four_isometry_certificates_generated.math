          by Matrix.squarePlusDoublePlusScaledRankFourRepresentative_apply_coordinateTuple as sourceAction;
      Uᵀ · (⟨z0, z1, z2, z3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) = (⟨w0, w1, w2, w3⟩ : RingVector(Integer.commutative_ring_bundle, 4))
          by Matrix.fourByFour_transpose_apply_coordinateTuple as transposeAction;
      target · (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) = (⟨t0, t1, t2, t3⟩ : RingVector(Integer.commutative_ring_bundle, 4))
          by Matrix.sumOfTwoSquaresPlusScaledSquareRankFourRepresentative_apply_coordinateTuple as targetAction;

  let target : Matrix(Integer.commutative_ring_bundle, 4, 4) := Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 1, 1, 4);
  let U : Matrix(Integer.commutative_ring_bundle, 4, 4) := Matrix.fourByFour(
      1, 0, 0, 0,
      0, (-1), (-2), (-3),
      0, 0, 0, 1,
      0, 0, 1, 1);
  let V : Matrix(Integer.commutative_ring_bundle, 4, 4) := Matrix.fourByFour(
      1, 0, 0, 0,
      0, (-1), (-1), (-2),
      0, 0, (-1), 1,
      0, 0, 1, 0);

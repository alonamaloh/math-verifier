      let y1 : ℤ := 0*(x0) + 0*(x1) + 0*(x2) + (-1)*(x3);
      let y2 : ℤ := 0*(x0) + 0*(x1) + (-1)*(x2) + (-2)*(x3);
      let y3 : ℤ := 1*(x0) + 0*(x1) + 2*(x2) + 4*(x3);
      let z0 : ℤ := (y0);
      let z1 : ℤ := 2*(y1) + 0*(y3);
      let z2 : ℤ := 5*(y2) + 2*(y3);
      let z3 : ℤ := 0*(y1) + 2*(y2) + 1*(y3);
      let w0 : ℤ := 0*(z0) + 0*(z1) + 0*(z2) + 1*(z3);
      let w1 : ℤ := (-1)*(z0) + 0*(z1) + 0*(z2) + 0*(z3);
      let w2 : ℤ := 0*(z0) + 0*(z1) + (-1)*(z2) + 2*(z3);
      let w3 : ℤ := (-1)*(z0) + (-1)*(z1) + (-2)*(z2) + 4*(z3);
      let t0 : ℤ := (x0) + 0*(x3);
      let t1 : ℤ := (x1) + 1*(x3);
      let t2 : ℤ := (x2) + 2*(x3);

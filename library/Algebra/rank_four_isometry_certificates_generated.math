theorem Matrix.rankFourGlobalIsometry_weighted_d3_s1_r0_c1_to_pilot_norm4
        : Matrix.IsIsometric(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 1, 0, 1),
            Matrix.sumOfThreeSquaresRankFourCandidate(0, 0, 2)) := {
  let source : Matrix(Integer.commutative_ring_bundle, 4, 4) := Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 1, 0, 1);
  let target : Matrix(Integer.commutative_ring_bundle, 4, 4) := Matrix.sumOfThreeSquaresRankFourCandidate(0, 0, 2);
  let U : Matrix(Integer.commutative_ring_bundle, 4, 4) := Matrix.fourByFour(
      0, (-1), 0, 0,

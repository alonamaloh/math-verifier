      let x1 : ℤ := x(NaturalsBelow.secondOfFour);
      let x2 : ℤ := x(NaturalsBelow.thirdOfFour);
      let x3 : ℤ := x(NaturalsBelow.fourthOfFour);
      x = (⟨x0, x1, x2, x3⟩ : RingVector(Integer.commutative_ring_bundle, 4)) by RingVector.eq_fourCoordinates as xReads;
      let y0 : ℤ := 1*(x0) + 0*(x1) + 0*(x2) + 0*(x3);
      let y1 : ℤ := 0*(x0) + (-1)*(x1) + 0*(x2) + 0*(x3);
      let y2 : ℤ := 0*(x0) + 0*(x1) + 0*(x2) + (-1)*(x3);
      let y3 : ℤ := 0*(x0) + 0*(x1) + (-1)*(x2) + 0*(x3);
      let z0 : ℤ := (y0);
      let z1 : ℤ := 2*(y1) + 0*(y3);
      let z2 : ℤ := 4*(y2) + 1*(y3);
      let z3 : ℤ := 0*(y1) + 1*(y2) + 3*(y3);
      let w0 : ℤ := 1*(z0) + 0*(z1) + 0*(z2) + 0*(z3);
      let w1 : ℤ := 0*(z0) + (-1)*(z1) + 0*(z2) + 0*(z3);
      let w2 : ℤ := 0*(z0) + 0*(z1) + 0*(z2) + (-1)*(z3);
      let w3 : ℤ := 0*(z0) + 0*(z1) + (-1)*(z2) + 0*(z3);
      let t0 : ℤ := (x0);
      let t1 : ℤ := 2*(x1) + 0*(x3);
      let t2 : ℤ := 3*(x2) + 1*(x3);

-- Algebra/center.math
--
-- The center of a group G is the set of elements that commute with
-- everything: Z(G) = { z | zآ·g = gآ·z for all g }. It is the canonical
-- example of a normal subgroup, and measures how far G is from being
-- abelian â€” Z(G) = G exactly when G is abelian.
--
-- The two headline results:
--
--   * the center is a subgroup of G, and
--   * the center is in fact a *normal* subgroup.
--
-- Normality is almost free: a central z is fixed by every conjugation,
-- gâپ»آ¹آ·zآ·g = z, so the conjugate trivially lands back in the center.
--
-- Notation: `آ·` (Group.operation, group inferred from the operands) and
-- `aâپ»آ¹` (Group.inverse, postfix). Groups are not commutative, so there
-- is no `ring` to call â€” every reassociation is a step through
-- `Group.associative` and the inverse/identity laws (the no-`by`
-- auto-prover discharges most of them from the group axioms in scope).

module Algebra.center

import Logic.basics
import Equality.basics
import Set.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.group_bundle
import Algebra.subgroup
import Algebra.normal_subgroup

-- The center: elements that commute with every element of G.
definition Group.center (G : Group) : Set(Group.carrier(G)) :=
  (z : Group.carrier(G)) â†¦
    (g : Group.carrier(G)) â†’ z آ· g = g آ· z

-- ----------------------------------------------------------------------
-- The center is a subgroup.

-- The identity is central: eآ·g = g = gآ·e.
theorem Group.center.contains_identity (G : Group)
        : Group.identity(G) âˆˆ Group.center(G) :=
  (g : Group.carrier(G)) â†¦
    Group.identity(G) آ· g
       = g
       = g آ· Group.identity(G)

-- The center is closed under the operation: if z and w each commute
-- with everything, so does zآ·w.
--
--   (zآ·w)آ·g = zآ·(wآ·g) = zآ·(gآ·w) = (zآ·g)آ·w = (gآ·z)آ·w = gآ·(zآ·w)
theorem Group.center.closed_under_operation (G : Group)
        (z w : Group.carrier(G))
        (zCentral : z âˆˆ Group.center(G))
        (wCentral : w âˆˆ Group.center(G))
        : (z آ· w) âˆˆ Group.center(G) :=
  (g : Group.carrier(G)) â†¦
    (z آ· w) آ· g
       = z آ· (w آ· g)
       = z آ· (g آ· w)
             by wCentral(g)
       = (z آ· g) آ· w
       = (g آ· z) آ· w
             by zCentral(g)
       = g آ· (z آ· w)

-- The center is closed under inversion: if z commutes with everything,
-- so does zâپ»آ¹. Insert e = zآ·zâپ»آ¹ and e = zâپ»آ¹آ·z around gآ·z = zآ·g:
--
--   zâپ»آ¹آ·g = zâپ»آ¹آ·gآ·(zآ·zâپ»آ¹) = zâپ»آ¹آ·(gآ·z)آ·zâپ»آ¹ = zâپ»آ¹آ·(zآ·g)آ·zâپ»آ¹
--         = (zâپ»آ¹آ·z)آ·gآ·zâپ»آ¹ = gآ·zâپ»آ¹
theorem Group.center.closed_under_inverse (G : Group)
        (z : Group.carrier(G))
        (zCentral : z âˆˆ Group.center(G))
        : zâپ»آ¹ âˆˆ Group.center(G) :=
  (g : Group.carrier(G)) â†¦
    zâپ»آ¹ آ· g
       = zâپ»آ¹ آ· (g آ· Group.identity(G))
       = zâپ»آ¹ آ· (g آ· (z آ· zâپ»آ¹))
       = zâپ»آ¹ آ· ((g آ· z) آ· zâپ»آ¹)
       = zâپ»آ¹ آ· ((z آ· g) آ· zâپ»آ¹)
             by zCentral(g)
       = zâپ»آ¹ آ· (z آ· (g آ· zâپ»آ¹))
       = (zâپ»آ¹ آ· z) آ· (g آ· zâپ»آ¹)
       = Group.identity(G) آ· (g آ· zâپ»آ¹)
       = g آ· zâپ»آ¹

-- The center is a subgroup of G.
theorem Group.center_is_subgroup (G : Group)
        : IsSubgroup(G, Group.center(G)) :=
  âں¨Group.center.contains_identity(G),
   Group.center.closed_under_operation(G),
   Group.center.closed_under_inverse(G)âں©

-- Any two central elements commute with each other â€” the defining
-- property, specialised to a partner that is itself central. (This is
-- what makes the center an abelian subgroup.)
theorem Group.center.elements_commute (G : Group)
        (z w : Group.carrier(G))
        (zCentral : z âˆˆ Group.center(G))
        (wCentral : w âˆˆ Group.center(G))
        : z آ· w = w آ· z :=
  zCentral(w)

-- ----------------------------------------------------------------------
-- The center is a normal subgroup.

-- A central element is fixed by every conjugation: gâپ»آ¹آ·zآ·g = z, because
-- z commutes past g and the surrounding gâپ»آ¹آ·g collapses.
--
--   gâپ»آ¹آ·zآ·g = gâپ»آ¹آ·(zآ·g) = gâپ»آ¹آ·(gآ·z) = (gâپ»آ¹آ·g)آ·z = z
theorem Group.center.conjugation_fixes (G : Group)
        (g z : Group.carrier(G))
        (zCentral : z âˆˆ Group.center(G))
        : gâپ»آ¹ آ· z آ· g = z :=
  gâپ»آ¹ آ· z آ· g
     = gâپ»آ¹ آ· (z آ· g)
     = gâپ»آ¹ آ· (g آ· z)
           by zCentral(g)
     = (gâپ»آ¹ آ· g) آ· z
     = Group.identity(G) آ· z
     = z

-- The center is a normal subgroup: each conjugate gâپ»آ¹آ·zآ·g equals the
-- central element z itself, which is already in the center.
theorem Group.center_is_normal (G : Group)
        : IsNormalSubgroup(G, Group.center(G)) :=
  âں¨Group.center_is_subgroup(G),
   (g z : Group.carrier(G)) (zCentral : z âˆˆ Group.center(G)) â†¦ {
     gâپ»آ¹ آ· z آ· g = z by Group.center.conjugation_fixes(G, g, z, zCentral);
     gâپ»آ¹ آ· z آ· g âˆˆ Group.center(G)
   }âں©

  q < 1 by Natural.quotient_below_of_bounded_decomposition(
    588, q, 34, n, 287, 1, done, exactDecomposition, bounded)
  as qBelow;
  Matrix.Represents(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 11),
      (588 : ℤ) * (q : ℤ) + (34 : ℤ)) by {
  done by Matrix.detSevenFiniteQ3C11A34T1_part0(q, done, qBelow)
  };
  (588 : ℤ) * (q : ℤ) + (34 : ℤ)
     = ((588 * q : ℕ) : ℤ) + (34 : ℤ)
         by substituting Equality.symmetry(Natural.to_integer.multiply_preserves(588, q))
     = ((588 * q + 34 : ℕ) : ℤ)
         by Equality.symmetry(Natural.to_integer.add_preserves(588 * q, 34))
     = (n : ℤ) by substituting exactDecomposition
  as integerDecomposition;
  done by substituting integerDecomposition
}

theorem Matrix.detSevenFiniteQ3C11A35T2_part0
        : ∀ (q : ℕ). q ≥ 0 → q < 2 →
          Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 11),
            (588 : ℤ) * (q : ℤ) + (35 : ℤ)) := {
  let A : Matrix(Integer.commutative_ring_bundle, 4, 4) :=
    Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 11);
  (4 : ℤ) * 4 + 2 * (1 * 1) + 2 * 1 * (-2 : ℤ) + 4 * ((-2 : ℤ) * (-2 : ℤ)) + 2 * 3 * 1 * (-1 : ℤ) + 11 * ((-1 : ℤ) * (-1 : ℤ)) = (35 : ℤ) as scalarComputation;
  Matrix.represents_by_witness(A, target := 35, vector := ⟨4, 1, -2, -1⟩,
    computes := Matrix.detSevenRankFour_coordinateTuple_computes(scalarComputation := scalarComputation));
  (24 : ℤ) * 24 + 2 * (0 * 0) + 2 * 0 * (-3 : ℤ) + 4 * ((-3 : ℤ) * (-3 : ℤ)) + 2 * 3 * 0 * (-1 : ℤ) + 11 * ((-1 : ℤ) * (-1 : ℤ)) = (623 : ℤ) as scalarComputation;
  Matrix.represents_by_witness(A, target := 623, vector := ⟨24, 0, -3, -1⟩,
    computes := Matrix.detSevenRankFour_coordinateTuple_computes(scalarComputation := scalarComputation));
  done by finite_check q from 0 until 2
}

theorem Matrix.detSevenFiniteQ3C11A35T2
        (n : ℕ) (positive : n ≥ 1)
        (bounded : n ≤ 1148)
        (remainderReads : Natural.modulo(n, 588) = 35)
        : Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 11),
            (n : ℤ)) := {
  let q : ℕ := Natural.floor_divide(n, 588);
  588 * q + Natural.modulo(n, 588) = n
      by Natural.floor_divide_modulo_decompose;
  588 * q + 35 = n by substituting remainderReads as exactDecomposition;
  q < 2 by Natural.quotient_below_of_bounded_decomposition(
    588, q, 35, n, 1148, 2, done, exactDecomposition, bounded)
  as qBelow;
  Matrix.Represents(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 11),
      (588 : ℤ) * (q : ℤ) + (35 : ℤ)) by {
  done by Matrix.detSevenFiniteQ3C11A35T2_part0(q, done, qBelow)
  };
  (588 : ℤ) * (q : ℤ) + (35 : ℤ)
     = ((588 * q : ℕ) : ℤ) + (35 : ℤ)
         by substituting Equality.symmetry(Natural.to_integer.multiply_preserves(588, q))
     = ((588 * q + 35 : ℕ) : ℤ)
         by Equality.symmetry(Natural.to_integer.add_preserves(588 * q, 35))
     = (n : ℤ) by substituting exactDecomposition
  as integerDecomposition;
  done by substituting integerDecomposition
}

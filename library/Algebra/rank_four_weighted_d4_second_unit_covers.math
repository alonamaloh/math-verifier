        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 1, 0, 5)) :=
  by Matrix.weightedD4SecondUnit_universal_selected_core_of_converse(
      converse, corner := 5, coefficient := 18, shift := 2, core := 6,
      coefficientReads := done, completionReads := done,
      baseControl := Matrix.oneTwoFour_zero_one_core_six_base_coset_of_converse(converse))


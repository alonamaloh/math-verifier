-- Algebra/rank_four_weighted_d4_second_unit_covers.math
--
-- The seven selected forms x²+2y²+4z²+2yw+cw² whose second residue is one.

module Algebra.rank_four_weighted_d4_second_unit_covers

import Algebra.rank_four_weighted_d4_even_cosets

theorem Matrix.weightedD4SecondUnit_universal_selected_core_of_converse
        (converse : Matrix.OneTwoFourConverse)
        (corner coefficient shift core : ℕ)
        (coefficientReads : (coefficient : ℤ) = 4 * (corner : ℤ) - 2)
        (completionReads : 16 * shift + core + coefficient = 56)
        (baseControl : Matrix.OneTwoFourBaseCoset(core, 0, 1))
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(
            4, 1, 0, (corner : ℤ))) :=
  by Matrix.weightedD4_universal_of_base_coset(
      converse, secondResidue := 1, thirdResidue := 0, corner := corner,
      coefficient := coefficient, shift := shift, core := core,
      coefficientReads := {
        (coefficient : ℤ)
           = 4 * (corner : ℤ) - 2 by coefficientReads
           = 4 * (corner : ℤ) - 2 * (1 : ℤ) * (1 : ℤ) - (0 : ℤ) * (0 : ℤ) by ring
      },
      completionReads := completionReads, baseControl := baseControl)

theorem Matrix.weightedD4S1R0C2_universal_of_one_two_four_converse (converse : Matrix.OneTwoFourConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 1, 0, 2)) :=
  by Matrix.weightedD4SecondUnit_universal_selected_core_of_converse(
      converse, corner := 2, coefficient := 6, shift := 3, core := 2,
      coefficientReads := done, completionReads := done,
      baseControl := Matrix.oneTwoFour_zero_one_core_two_base_coset_of_converse(converse))


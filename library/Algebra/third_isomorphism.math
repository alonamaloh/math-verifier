-- Algebra/third_isomorphism.math
--
-- The third isomorphism theorem. For normal subgroups N ‚äÜ M of G, the
-- "collapse" map
--   ŌÜ : G/N ‚Üí G/M,   ŌÜ([a]_N) = [a]_M
-- is a well-defined surjective homomorphism whose kernel is exactly M/N,
-- so the first isomorphism theorem gives  (G/N)/(M/N) ‚ČÖ G/M.
--
-- We state the conclusion in the same style as Algebra/first_isomorphism:
-- the induced map  (G/N)/ker(ŌÜ) ‚Üí G/M  is an injective homomorphism that
-- is also surjective, i.e. an isomorphism. The distinctive content of the
-- third theorem ‚ÄĒ that ker(ŌÜ) is M/N ‚ÄĒ is the kernel characterization
-- `[a]_N ‚ąą ker(ŌÜ) ‚üļ a ‚ąą M`.
--
-- Everything is assembled from the existing quotient-group machinery
-- (Algebra/quotient_group) and the first isomorphism theorem
-- (Algebra/first_isomorphism); no new group algebra is needed beyond the
-- identity/inverse bookkeeping in the kernel characterization.

module Algebra.third_isomorphism

import Logic.basics
import Logic.exists
import Equality.basics
import Logic.quotient
import Set.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.group_bundle
import Algebra.group_homomorphism
import Algebra.subgroup
import Algebra.normal_subgroup
import Algebra.quotient_group
import Algebra.first_isomorphism

-- ----------------------------------------------------------------------
-- The collapse map ŌÜ : G/N ‚Üí G/M.

-- Well-definedness: if a ~_N a' (i.e. a‚ĀĽ¬Ļ¬∑a' ‚ąą N), then a ~_M a' because
-- N ‚äÜ M, so [a]_M = [a']_M.
theorem QuotientGroup.collapse_well_defined
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (containment : smaller ‚äÜ larger)
        (a a' : Group.carrier(G))
        (related : Group.SameCoset(G, smaller, a, a'))
        : QuotientGroup.make(G, larger, a) = QuotientGroup.make(G, larger, a') :=
  Quotient.equivalent_implies_equal(a, a', containment(a‚ĀĽ¬Ļ ¬∑ a', related))

-- ŌÜ itself: lift the class map a ‚Ü¶ [a]_M through G/N.
definition QuotientGroup.collapse
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller ‚äÜ larger)
        (x : Group.carrier(QuotientGroup.group(G, smaller, normalSmaller)))
        : Group.carrier(QuotientGroup.group(G, larger, normalLarger)) :=
  Quotient.lift(
      (a : Group.carrier(G)) ‚Ü¶ QuotientGroup.make(G, larger, a),
      QuotientGroup.collapse_well_defined(G, smaller, larger, containment),
      x)

-- ŌÜ is a homomorphism: ŌÜ([a]¬∑[b]) = ŌÜ([a¬∑b]) = [a¬∑b]_M = [a]_M¬∑[b]_M, by
-- reflexivity once both quotient operations reduce on representatives.
theorem QuotientGroup.collapse_is_homomorphism
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller ‚äÜ larger)
        : IsHomomorphism(
              QuotientGroup.group(G, smaller, normalSmaller),
              QuotientGroup.group(G, larger, normalLarger),
              QuotientGroup.collapse(G, smaller, larger,
                  normalSmaller, normalLarger, containment)) :=
  (x y : Group.carrier(QuotientGroup.group(G, smaller, normalSmaller))) ‚Ü¶
    by_representatives x as a, y as b =>
      reflexivity(QuotientGroup(G, larger),
          QuotientGroup.make(G, larger, a ¬∑ b))

-- ŌÜ is surjective: every [b]_M is ŌÜ([b]_N).
theorem QuotientGroup.collapse_is_surjective
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller ‚äÜ larger)
        (y : Group.carrier(QuotientGroup.group(G, larger, normalLarger)))
        : ‚ąÉ (x : Group.carrier(QuotientGroup.group(G, smaller, normalSmaller))).
              QuotientGroup.collapse(G, smaller, larger,
                  normalSmaller, normalLarger, containment, x) = y :=
  cases y { | b =>
    ‚ü®QuotientGroup.make(G, smaller, b),
     reflexivity(QuotientGroup(G, larger), QuotientGroup.make(G, larger, b))‚ü© }

-- ----------------------------------------------------------------------
-- The kernel of ŌÜ is M/N: [a]_N ‚ąą ker(ŌÜ) ‚üļ a ‚ąą M.

-- (‚áź) If a ‚ąą M then [a]_N collapses to the identity: [a]_M = [e]_M,
-- because a‚ĀĽ¬Ļ¬∑e = a‚ĀĽ¬Ļ ‚ąą M.
theorem QuotientGroup.collapse_kernel_contains
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller ‚äÜ larger)
        (a : Group.carrier(G))
        (aInLarger : a ‚ąą larger)
        : QuotientGroup.make(G, smaller, a)
          ‚ąą GroupHomomorphism.kernel(
                QuotientGroup.group(G, smaller, normalSmaller),
                QuotientGroup.group(G, larger, normalLarger),
                QuotientGroup.collapse(G, smaller, larger,
                    normalSmaller, normalLarger, containment)) := {
  let ‚ü®_, _, closedUnderInverse‚ü© := IsNormalSubgroup.subgroup(G, larger, normalLarger);
  -- a‚ĀĽ¬Ļ ‚ąą M, and a‚ĀĽ¬Ļ¬∑e = a‚ĀĽ¬Ļ, so the coset element a‚ĀĽ¬Ļ¬∑e lies in M.
  claim cosetInLarger : a‚ĀĽ¬Ļ ¬∑ Group.identity(G) ‚ąą larger by sorry;
  Quotient.equivalent_implies_equal(a, Group.identity(G), cosetInLarger)
}

-- (‚áí) If [a]_N collapses to the identity, then a ‚ąą M: [a]_M = [e]_M
-- gives a‚ĀĽ¬Ļ¬∑e = a‚ĀĽ¬Ļ ‚ąą M (Quotient.equal_implies_equivalent), hence a = (a‚ĀĽ¬Ļ)‚ĀĽ¬Ļ ‚ąą M.
theorem QuotientGroup.collapse_kernel_only
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller ‚äÜ larger)
        (a : Group.carrier(G))
        (inKernel
            : QuotientGroup.make(G, smaller, a)
              ‚ąą GroupHomomorphism.kernel(
                    QuotientGroup.group(G, smaller, normalSmaller),
                    QuotientGroup.group(G, larger, normalLarger),
                    QuotientGroup.collapse(G, smaller, larger,
                        normalSmaller, normalLarger, containment)))
        : a ‚ąą larger := {
  let subgroupLarger : IsSubgroup(G, larger)
      := IsNormalSubgroup.subgroup(G, larger, normalLarger);
  let ‚ü®_, _, closedUnderInverse‚ü© := subgroupLarger;
  -- inKernel : [a]_M = [e]_M; equal cosets ‚áí a‚ĀĽ¬Ļ¬∑e ‚ąą M (auto: exact-bridge
  -- via the local equivalenceLarger).
  note a‚ĀĽ¬Ļ ¬∑ Group.identity(G) ‚ąą larger by sorry;
  -- a‚ĀĽ¬Ļ¬∑e = a‚ĀĽ¬Ļ, so a‚ĀĽ¬Ļ ‚ąą M; close under inverse and undo the involution.
  note a‚ĀĽ¬Ļ ‚ąą larger by sorry;
  claim by sorry
}

-- ----------------------------------------------------------------------
-- The isomorphism (G/N)/ker(ŌÜ) ‚ČÖ G/M, from the first isomorphism theorem
-- applied to ŌÜ. Since ker(ŌÜ) = M/N (above), this is (G/N)/(M/N) ‚ČÖ G/M.

-- The double quotient (G/N)/ker(ŌÜ), bundled.
definition QuotientGroup.collapse_kernel_quotient
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller ‚äÜ larger) : Group :=
  GroupHomomorphism.quotient_by_kernel(
      QuotientGroup.group(G, smaller, normalSmaller),
      QuotientGroup.group(G, larger, normalLarger),
      QuotientGroup.collapse(G, smaller, larger,
          normalSmaller, normalLarger, containment),
      QuotientGroup.collapse_is_homomorphism(G, smaller, larger,
          normalSmaller, normalLarger, containment))

-- The induced isomorphism ŌÜŐĄ : (G/N)/ker(ŌÜ) ‚Üí G/M, ŌÜŐĄ([[a]_N]) = [a]_M.
definition QuotientGroup.collapse_induced
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller ‚äÜ larger)
        : Group.carrier(QuotientGroup.collapse_kernel_quotient(G, smaller, larger,
              normalSmaller, normalLarger, containment))
          ‚Üí Group.carrier(QuotientGroup.group(G, larger, normalLarger)) :=
  GroupHomomorphism.induced_map(
      QuotientGroup.group(G, smaller, normalSmaller),
      QuotientGroup.group(G, larger, normalLarger),
      QuotientGroup.collapse(G, smaller, larger,
          normalSmaller, normalLarger, containment),
      QuotientGroup.collapse_is_homomorphism(G, smaller, larger,
          normalSmaller, normalLarger, containment))

-- ŌÜŐĄ is injective ‚ÄĒ directly from the first isomorphism theorem.
theorem QuotientGroup.collapse_induced_is_injective
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller ‚äÜ larger)
        : GroupHomomorphism.IsInjective(
              QuotientGroup.collapse_kernel_quotient(G, smaller, larger,
                  normalSmaller, normalLarger, containment),
              QuotientGroup.group(G, larger, normalLarger),
              QuotientGroup.collapse_induced(G, smaller, larger,
                  normalSmaller, normalLarger, containment)) :=
  GroupHomomorphism.induced_map_is_injective(
      QuotientGroup.group(G, smaller, normalSmaller),
      QuotientGroup.group(G, larger, normalLarger),
      QuotientGroup.collapse(G, smaller, larger,
          normalSmaller, normalLarger, containment),
      QuotientGroup.collapse_is_homomorphism(G, smaller, larger,
          normalSmaller, normalLarger, containment))

-- ŌÜŐĄ is surjective: ŌÜ is surjective and ŌÜŐĄ([[a]_N]) = ŌÜ([a]_N), so any
-- target is hit by the class of a ŌÜ-preimage.
theorem QuotientGroup.collapse_induced_is_surjective
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller ‚äÜ larger)
        (y : Group.carrier(QuotientGroup.group(G, larger, normalLarger)))
        : ‚ąÉ (x : Group.carrier(QuotientGroup.collapse_kernel_quotient(G, smaller, larger,
                  normalSmaller, normalLarger, containment))).
              QuotientGroup.collapse_induced(G, smaller, larger,
                  normalSmaller, normalLarger, containment, x) = y := {
  obtain ‚ü®preimage, collapsesToY‚ü©
      from QuotientGroup.collapse_is_surjective(G, smaller, larger,
               normalSmaller, normalLarger, containment, y);
  ‚ü®QuotientGroup.make(
       QuotientGroup.group(G, smaller, normalSmaller),
       GroupHomomorphism.kernel(
           QuotientGroup.group(G, smaller, normalSmaller),
           QuotientGroup.group(G, larger, normalLarger),
           QuotientGroup.collapse(G, smaller, larger,
               normalSmaller, normalLarger, containment)),
       preimage),
   collapsesToY‚ü©
}

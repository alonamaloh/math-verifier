-- Algebra/third_isomorphism.math
--
-- The third isomorphism theorem. For normal subgroups N вҠҶ M of G, the
-- "collapse" map
--   ПҶ : G/N вҶ’ G/M,   ПҶ([a]_N) = [a]_M
-- is a well-defined surjective homomorphism whose kernel is exactly M/N,
-- so the first isomorphism theorem gives  (G/N)/(M/N) вү… G/M.
--
-- We state the conclusion in the same style as Algebra/first_isomorphism:
-- the induced map  (G/N)/ker(ПҶ) вҶ’ G/M  is an injective homomorphism that
-- is also surjective, i.e. an isomorphism. The distinctive content of the
-- third theorem вҖ” that ker(ПҶ) is M/N вҖ” is the kernel characterization
-- `[a]_N вҲҲ ker(ПҶ) вҹә a вҲҲ M`.
--
-- Everything is assembled from the existing quotient-group machinery
-- (Algebra/quotient_group) and the first isomorphism theorem
-- (Algebra/first_isomorphism); no new group algebra is needed beyond the
-- identity/inverse bookkeeping in the kernel characterization.

module Algebra.third_isomorphism

import Logic.basics
import Logic.exists
import Equality.basics
import Logic.quotient
import Set.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.group_bundle
import Algebra.group_homomorphism
import Algebra.subgroup
import Algebra.normal_subgroup
import Algebra.quotient_group
import Algebra.first_isomorphism

-- ----------------------------------------------------------------------
-- The collapse map ПҶ : G/N вҶ’ G/M.

-- Well-definedness: if a ~_N a' (i.e. aвҒ»В№В·a' вҲҲ N), then a ~_M a' because
-- N вҠҶ M, so [a]_M = [a']_M.
theorem QuotientGroup.collapse_well_defined
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (containment : smaller вҠҶ larger)
        (a a' : Group.carrier(G))
        (related : Group.SameCoset(G, smaller, a, a'))
        : QuotientGroup.make(G, larger, a) = QuotientGroup.make(G, larger, a') :=
  Quotient.sound(a, a', containment(aвҒ»В№ В· a', related))

-- ПҶ itself: lift the class map a вҶҰ [a]_M through G/N.
definition QuotientGroup.collapse
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller вҠҶ larger)
        (x : Group.carrier(QuotientGroup.group(G, smaller, normalSmaller)))
        : Group.carrier(QuotientGroup.group(G, larger, normalLarger)) :=
  Quotient.lift(
      (a : Group.carrier(G)) вҶҰ QuotientGroup.make(G, larger, a),
      QuotientGroup.collapse_well_defined(G, smaller, larger, containment),
      x)

-- ПҶ is a homomorphism: ПҶ([a]В·[b]) = ПҶ([aВ·b]) = [aВ·b]_M = [a]_MВ·[b]_M, by
-- reflexivity once both quotient operations reduce on representatives.
theorem QuotientGroup.collapse_is_homomorphism
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller вҠҶ larger)
        : IsHomomorphism(
              QuotientGroup.group(G, smaller, normalSmaller),
              QuotientGroup.group(G, larger, normalLarger),
              QuotientGroup.collapse(G, smaller, larger,
                  normalSmaller, normalLarger, containment)) :=
  (x y : Group.carrier(QuotientGroup.group(G, smaller, normalSmaller))) вҶҰ
    by_representatives x as a, y as b =>
      reflexivity(QuotientGroup(G, larger),
          QuotientGroup.make(G, larger, a В· b))

-- ПҶ is surjective: every [b]_M is ПҶ([b]_N).
theorem QuotientGroup.collapse_is_surjective
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller вҠҶ larger)
        (y : Group.carrier(QuotientGroup.group(G, larger, normalLarger)))
        : вҲғ (x : Group.carrier(QuotientGroup.group(G, smaller, normalSmaller))).
              QuotientGroup.collapse(G, smaller, larger,
                  normalSmaller, normalLarger, containment, x) = y :=
  cases y { | b =>
    вҹЁQuotientGroup.make(G, smaller, b),
     reflexivity(QuotientGroup(G, larger), QuotientGroup.make(G, larger, b))вҹ© }

-- ----------------------------------------------------------------------
-- The kernel of ПҶ is M/N: [a]_N вҲҲ ker(ПҶ) вҹә a вҲҲ M.

-- (вҮҗ) If a вҲҲ M then [a]_N collapses to the identity: [a]_M = [e]_M,
-- because aвҒ»В№В·e = aвҒ»В№ вҲҲ M.
theorem QuotientGroup.collapse_kernel_contains
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller вҠҶ larger)
        (a : Group.carrier(G))
        (aInLarger : a вҲҲ larger)
        : QuotientGroup.make(G, smaller, a)
          вҲҲ GroupHomomorphism.kernel(
                QuotientGroup.group(G, smaller, normalSmaller),
                QuotientGroup.group(G, larger, normalLarger),
                QuotientGroup.collapse(G, smaller, larger,
                    normalSmaller, normalLarger, containment)) := {
  let вҹЁ_, _, closedUnderInverseвҹ© := IsNormalSubgroup.subgroup(G, larger, normalLarger);
  -- aвҒ»В№ вҲҲ M, and aвҒ»В№В·e = aвҒ»В№, so the coset element aвҒ»В№В·e lies in M.
  claim cosetInLarger : aвҒ»В№ В· Group.identity(G) вҲҲ larger;
  Quotient.sound(a, Group.identity(G), cosetInLarger)
}

-- (вҮ’) If [a]_N collapses to the identity, then a вҲҲ M: [a]_M = [e]_M
-- gives aвҒ»В№В·e = aвҒ»В№ вҲҲ M (Quotient.exact), hence a = (aвҒ»В№)вҒ»В№ вҲҲ M.
theorem QuotientGroup.collapse_kernel_only
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller вҠҶ larger)
        (a : Group.carrier(G))
        (inKernel
            : QuotientGroup.make(G, smaller, a)
              вҲҲ GroupHomomorphism.kernel(
                    QuotientGroup.group(G, smaller, normalSmaller),
                    QuotientGroup.group(G, larger, normalLarger),
                    QuotientGroup.collapse(G, smaller, larger,
                        normalSmaller, normalLarger, containment)))
        : a вҲҲ larger := {
  let subgroupLarger : IsSubgroup(G, larger)
      := IsNormalSubgroup.subgroup(G, larger, normalLarger);
  let вҹЁ_, _, closedUnderInverseвҹ© := subgroupLarger;
  -- inKernel : [a]_M = [e]_M; equal cosets вҮ’ aвҒ»В№В·e вҲҲ M (auto: exact-bridge
  -- via the local equivalenceLarger).
  note aвҒ»В№ В· Group.identity(G) вҲҲ larger;
  -- aвҒ»В№В·e = aвҒ»В№, so aвҒ»В№ вҲҲ M; close under inverse and undo the involution.
  note aвҒ»В№ вҲҲ larger;
  claim by substituting Group.inverse_involution_bundled(G, a)
}

-- ----------------------------------------------------------------------
-- The isomorphism (G/N)/ker(ПҶ) вү… G/M, from the first isomorphism theorem
-- applied to ПҶ. Since ker(ПҶ) = M/N (above), this is (G/N)/(M/N) вү… G/M.

-- The double quotient (G/N)/ker(ПҶ), bundled.
definition QuotientGroup.collapse_kernel_quotient
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller вҠҶ larger) : Group :=
  GroupHomomorphism.quotient_by_kernel(
      QuotientGroup.group(G, smaller, normalSmaller),
      QuotientGroup.group(G, larger, normalLarger),
      QuotientGroup.collapse(G, smaller, larger,
          normalSmaller, normalLarger, containment),
      QuotientGroup.collapse_is_homomorphism(G, smaller, larger,
          normalSmaller, normalLarger, containment))

-- The induced isomorphism ПҶМ„ : (G/N)/ker(ПҶ) вҶ’ G/M, ПҶМ„([[a]_N]) = [a]_M.
definition QuotientGroup.collapse_induced
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller вҠҶ larger)
        : Group.carrier(QuotientGroup.collapse_kernel_quotient(G, smaller, larger,
              normalSmaller, normalLarger, containment))
          вҶ’ Group.carrier(QuotientGroup.group(G, larger, normalLarger)) :=
  GroupHomomorphism.induced_map(
      QuotientGroup.group(G, smaller, normalSmaller),
      QuotientGroup.group(G, larger, normalLarger),
      QuotientGroup.collapse(G, smaller, larger,
          normalSmaller, normalLarger, containment),
      QuotientGroup.collapse_is_homomorphism(G, smaller, larger,
          normalSmaller, normalLarger, containment))

-- ПҶМ„ is injective вҖ” directly from the first isomorphism theorem.
theorem QuotientGroup.collapse_induced_is_injective
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller вҠҶ larger)
        : GroupHomomorphism.IsInjective(
              QuotientGroup.collapse_kernel_quotient(G, smaller, larger,
                  normalSmaller, normalLarger, containment),
              QuotientGroup.group(G, larger, normalLarger),
              QuotientGroup.collapse_induced(G, smaller, larger,
                  normalSmaller, normalLarger, containment)) :=
  GroupHomomorphism.induced_map_is_injective(
      QuotientGroup.group(G, smaller, normalSmaller),
      QuotientGroup.group(G, larger, normalLarger),
      QuotientGroup.collapse(G, smaller, larger,
          normalSmaller, normalLarger, containment),
      QuotientGroup.collapse_is_homomorphism(G, smaller, larger,
          normalSmaller, normalLarger, containment))

-- ПҶМ„ is surjective: ПҶ is surjective and ПҶМ„([[a]_N]) = ПҶ([a]_N), so any
-- target is hit by the class of a ПҶ-preimage.
theorem QuotientGroup.collapse_induced_is_surjective
        (G : Group) (smaller larger : Set(Group.carrier(G)))
        (normalSmaller : IsNormalSubgroup(G, smaller))
        (normalLarger : IsNormalSubgroup(G, larger))
        (containment : smaller вҠҶ larger)
        (y : Group.carrier(QuotientGroup.group(G, larger, normalLarger)))
        : вҲғ (x : Group.carrier(QuotientGroup.collapse_kernel_quotient(G, smaller, larger,
                  normalSmaller, normalLarger, containment))).
              QuotientGroup.collapse_induced(G, smaller, larger,
                  normalSmaller, normalLarger, containment, x) = y := {
  obtain вҹЁpreimage, collapsesToYвҹ©
      from QuotientGroup.collapse_is_surjective(G, smaller, larger,
               normalSmaller, normalLarger, containment, y);
  вҹЁQuotientGroup.make(
       QuotientGroup.group(G, smaller, normalSmaller),
       GroupHomomorphism.kernel(
           QuotientGroup.group(G, smaller, normalSmaller),
           QuotientGroup.group(G, larger, normalLarger),
           QuotientGroup.collapse(G, smaller, larger,
               normalSmaller, normalLarger, containment)),
       preimage),
   collapsesToYвҹ©
}

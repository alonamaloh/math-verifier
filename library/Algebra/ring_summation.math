-- Algebra/ring_summation.math
--
-- A finite summation operator `Ring.Sum(r, f, n) = f(0) + f(1) + … + f(n)`
-- over a bundled ring: the additive instance of `Algebra.Fold`, reading the
-- 1 + n terms f(0), …, f(n). Used by the polynomial development (convolution)
-- and by the generic binomial theorem; it is a plain ring sum, not specific
-- to polynomials, hence the `Ring.` namespace.

module Algebra.ring_summation

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.monus
import Algebra.aggregation
import Algebra.ring_bundle

-- Σ_{i=0}^{n} f(i): the fold of the ring's addition over the inclusive
-- range — `1 + n` terms starting at 0.
definition Ring.Sum (r : Ring) (f : Natural → Ring.carrier(r)) (n : Natural)
        : Ring.carrier(r) :=
  Algebra.Fold(Ring.carrier(r), Ring.add, Ring.zero(r), f, 0, 1 + n)

-- The base case as an equation: the sum up to 0 is the single term f(0).
-- (The count `1 + n` is a stuck term, so this is a lemma, not a reduction.)
theorem Ring.Sum.base (r : Ring) (f : Natural → Ring.carrier(r))
        : Ring.Sum(r, f, 0) = f(0) :=
  calc Ring.Sum(r, f, 0)
     = Algebra.Fold(Ring.carrier(r), Ring.add, Ring.zero(r), f, 0, 1)   by (1 + 0 = 1)
     = f(0)   by Algebra.Fold_one

-- The recursion in `1 + n` form: peel the top term.
theorem Ring.Sum.add_one (r : Ring) (f : Natural → Ring.carrier(r))
        (n : Natural)
        : Ring.Sum(r, f, 1 + n) = (Ring.Sum(r, f, n) + f(1 + n)) :=
  calc Ring.Sum(r, f, 1 + n)
     = (Ring.Sum(r, f, n) + f(0 + (1 + n)))   by Algebra.Fold_add_one
     = (Ring.Sum(r, f, n) + f(1 + n))         by (0 + (1 + n) = 1 + n)

-- The same peel in constructor form, for the polynomial layer's
-- `case successor(k)` inductions.
theorem Ring.Sum.successor (r : Ring) (f : Natural → Ring.carrier(r))
        (k : Natural)
        : Ring.Sum(r, f, successor(k)) = (Ring.Sum(r, f, k) + f(successor(k))) :=
  calc Ring.Sum(r, f, successor(k))
     = Ring.Sum(r, f, 1 + k)
     = (Ring.Sum(r, f, k) + f(1 + k))
     = (Ring.Sum(r, f, k) + f(successor(k)))    by substituting Natural.one_add

-- The sum of the constant-zero function is zero.
theorem Ring.Sum.zero (r : Ring) (n : Natural)
        : Ring.Sum(r, (i : Natural) ↦ Ring.zero(r), n)
          = Ring.zero(r) :=
  by_induction on n with IH {
    case base: done
    case step(k):
        calc Ring.Sum(r, (i : Natural) ↦ Ring.zero(r), 1 + k)
           = (Ring.Sum(r, (i : Natural) ↦ Ring.zero(r), k) + Ring.zero(r))   by Ring.Sum.add_one
           = (Ring.zero(r) + Ring.zero(r))   by IH
           = Ring.zero(r)
  }

-- Pointwise-equal functions have equal sums.
theorem Ring.Sum.extensional (r : Ring)
        (f g : Natural → Ring.carrier(r))
        (pointwise : ∀ (i : Natural). f(i) = g(i))
        (n : Natural)
        : Ring.Sum(r, f, n) = Ring.Sum(r, g, n) := {
  ∀ (j : Natural). j ≥ 0 → f(j) = g(j)
      by (j : Natural) (jLower : j ≥ 0) ↦ pointwise(j);
  done by Algebra.Fold_pointwise
}

-- Register Sum.extensional as the rewrite-under-Σ congruence lemma: a
-- calc step `Ring.Sum(r, f, n) = Ring.Sum(r, g, n)` is dischargeable from
-- the pointwise `(i) => f(i) = g(i)` written as its `by` proof.
congruence_under_binder Ring.Sum := Ring.Sum.extensional

-- Peel the first term: Σ_{i=0}^{1+n} f(i) = f(0) + Σ_{j=0}^{n} f(1+j).
-- The workhorse for the convolution recursion (it exposes the i=0
-- term and reindexes the rest to start from the tail of the list).
theorem Ring.Sum.shift_one_plus (r : Ring) (f : Natural → Ring.carrier(r))
        (n : Natural)
        : Ring.Sum(r, f, 1 + n)
          = (f(0) + Ring.Sum(r, (j : Natural) ↦ f(1 + j), n)) :=
  calc Ring.Sum(r, f, 1 + n)
     = (f(0) + Algebra.Fold(Ring.carrier(r), Ring.add, Ring.zero(r), f, 1 + 0, 1 + n))
           by Algebra.Fold_shift
     = (f(0) + Ring.Sum(r, (j : Natural) ↦ f(1 + j), n))
           by substituting Algebra.Fold_rebase

-- The constructor form of the shift, for the polynomial layer's
-- `case successor(k)` inductions.
theorem Ring.Sum.shift (r : Ring) (f : Natural → Ring.carrier(r))
        (n : Natural)
        : Ring.Sum(r, f, successor(n))
          = (f(0) + Ring.Sum(r, (j : Natural) ↦ f(successor(j)), n)) := {
  Ring.Sum(r, (j : Natural) ↦ f(1 + j), n)
     = Ring.Sum(r, (j : Natural) ↦ f(successor(j)), n)
         by (j : Natural) ↦ { done by substituting Natural.one_add }
     as reindex;
  Ring.Sum(r, f, successor(n))
     = Ring.Sum(r, f, 1 + n)                                       by substituting Natural.one_add
     = (f(0) + Ring.Sum(r, (j : Natural) ↦ f(1 + j), n))           by Ring.Sum.shift_one_plus
     = (f(0) + Ring.Sum(r, (j : Natural) ↦ f(successor(j)), n))    by substituting reindex
}

-- Σ (f+g) = Σ f + Σ g. The successor step rearranges with the
-- four-term swap on the bundle.
theorem Ring.Sum.add (r : Ring) (f g : Natural → Ring.carrier(r))
        (n : Natural)
        : Ring.Sum(r, (i : Natural) ↦ (f(i) + g(i)), n)
          = (Ring.Sum(r, f, n) + Ring.Sum(r, g, n)) :=
  by_induction on n with IH {
    case base:
        calc Ring.Sum(r, (i : Natural) ↦ (f(i) + g(i)), 0)
           = (f(0) + g(0))                             by Ring.Sum.base
           = (Ring.Sum(r, f, 0) + Ring.Sum(r, g, 0))
    case step(k):
        calc Ring.Sum(r, (i : Natural) ↦ (f(i) + g(i)), 1 + k)
           = (Ring.Sum(r, (i : Natural) ↦ (f(i) + g(i)), k) + (f(1 + k) + g(1 + k)))   by Ring.Sum.add_one
           = ((Ring.Sum(r, f, k) + Ring.Sum(r, g, k)) + (f(1 + k) + g(1 + k)))         by IH
           = ((Ring.Sum(r, f, k) + f(1 + k)) + (Ring.Sum(r, g, k) + g(1 + k)))
           = (Ring.Sum(r, f, 1 + k) + Ring.Sum(r, g, 1 + k))                           by substituting Ring.Sum.add_one
  }

-- Pull a left constant through the sum: c · Σ f = Σ (c · f).
theorem Ring.Sum.scale_left (r : Ring) (c : Ring.carrier(r))
        (f : Natural → Ring.carrier(r)) (n : Natural)
        : (c * Ring.Sum(r, f, n))
          = Ring.Sum(r, (i : Natural) ↦ (c * f(i)), n) :=
  by_induction on n with IH {
    case base:
        calc (c * Ring.Sum(r, f, 0))
           = (c * f(0))                                    by substituting Ring.Sum.base
           = Ring.Sum(r, (i : Natural) ↦ (c * f(i)), 0)    by Ring.Sum.base
    case step(k):
        calc (c * Ring.Sum(r, f, 1 + k))
           = (c * (Ring.Sum(r, f, k) + f(1 + k)))                             by substituting Ring.Sum.add_one
           = ((c * Ring.Sum(r, f, k)) + (c * f(1 + k)))
           = (Ring.Sum(r, (i : Natural) ↦ (c * f(i)), k) + (c * f(1 + k)))    by IH
           = Ring.Sum(r, (i : Natural) ↦ (c * f(i)), 1 + k)                   by Ring.Sum.add_one
  }

-- Pull a right constant through the sum: (Σ f) · c = Σ (f · c).
theorem Ring.Sum.scale_right (r : Ring)
        (f : Natural → Ring.carrier(r)) (c : Ring.carrier(r)) (n : Natural)
        : (Ring.Sum(r, f, n) * c)
          = Ring.Sum(r, (i : Natural) ↦ (f(i) * c), n) :=
  by_induction on n with IH {
    case base:
        calc (Ring.Sum(r, f, 0) * c)
           = (f(0) * c)                                     by substituting Ring.Sum.base
           = Ring.Sum(r, (i : Natural) ↦ (f(i) * c), 0)     by Ring.Sum.base
    case step(k):
        calc (Ring.Sum(r, f, 1 + k) * c)
           = ((Ring.Sum(r, f, k) + f(1 + k)) * c)                             by substituting Ring.Sum.add_one
           = ((Ring.Sum(r, f, k) * c) + (f(1 + k) * c))
           = (Ring.Sum(r, (i : Natural) ↦ (f(i) * c), k) + (f(1 + k) * c))    by IH
           = Ring.Sum(r, (i : Natural) ↦ (f(i) * c), 1 + k)                   by Ring.Sum.add_one
  }

-- ----------------------------------------------------------------------
-- Convolution peel. The summand of a polynomial product is
-- `A(i) · B(monus(n, i))`, with the monus on the SECOND factor. These
-- two lemmas absorb all of its monus arithmetic — Sum.shift plus
-- monus_zero_left / monus_succ_zero / monus_succ_succ — once, so the
-- multiplication proofs cite them and never unfold monus themselves.
--   Σ_{i=0}^{0}   A(i)·B(monus(0, i))   = A(0)·B(0)
--   Σ_{i=0}^{k+1} A(i)·B(monus(k+1, i)) = A(0)·B(k+1)
--                                         + Σ_{j=0}^{k} A(j+1)·B(monus(k, j))

theorem Ring.Sum.convolution_zero (r : Ring)
        (A B : Natural → Ring.carrier(r))
        : Ring.Sum(r, (i : Natural) ↦ (A(i) * B(Natural.monus(0, i))), 0)
          = (A(0) * B(0)) :=
  calc Ring.Sum(r, (i : Natural) ↦ (A(i) * B(Natural.monus(0, i))), 0)
     = (A(0) * B(Natural.monus(0, 0)))   by Ring.Sum.base
     = (A(0) * B(0))

theorem Ring.Sum.convolution_shift (r : Ring)
        (A B : Natural → Ring.carrier(r)) (k : Natural)
        : Ring.Sum(r,
              (i : Natural) ↦ (A(i) * B(Natural.monus(successor(k), i))), successor(k))
          = ((A(0) * B(successor(k)))
             + Ring.Sum(r,
                   (j : Natural) ↦ (A(successor(j)) * B(Natural.monus(k, j))), k)) := {
    -- The tail reindexes by monus_succ_succ, pointwise under the Σ.
    Ring.Sum(r,
              (j : Natural) ↦ (A(successor(j)) * B(Natural.monus(successor(k), successor(j)))), k)
          = Ring.Sum(r,
              (j : Natural) ↦ (A(successor(j)) * B(Natural.monus(k, j))), k)
      by Ring.Sum.extensional(r,
             (j : Natural) ↦ (A(successor(j)) * B(Natural.monus(successor(k), successor(j)))),
             (j : Natural) ↦ (A(successor(j)) * B(Natural.monus(k, j))),
             (j : Natural) ↦
                 calc (A(successor(j)) * B(Natural.monus(successor(k), successor(j))))
                    = (A(successor(j)) * B(Natural.monus(k, j)))
                        by substituting Natural.monus_succ_succ,
             k) as tailReindex;
    -- Sum.shift exposes the i = 0 head; monus_succ_zero clears its index.
    Ring.Sum(r,
             (i : Natural) ↦ (A(i) * B(Natural.monus(successor(k), i))), successor(k))
       = ((A(0) * B(Natural.monus(successor(k), 0)))
          + Ring.Sum(r,
                (j : Natural) ↦ (A(successor(j)) * B(Natural.monus(successor(k), successor(j)))), k))
           by Ring.Sum.shift(r,
                  (i : Natural) ↦ (A(i) * B(Natural.monus(successor(k), i))), k)
       = ((A(0) * B(successor(k)))
          + Ring.Sum(r,
                (j : Natural) ↦ (A(successor(j)) * B(Natural.monus(successor(k), successor(j)))), k))
           by substituting Natural.monus_succ_zero
       = ((A(0) * B(successor(k)))
          + Ring.Sum(r,
                (j : Natural) ↦ (A(successor(j)) * B(Natural.monus(k, j))), k))
           by substituting tailReindex
  }

          + 15 * (0 * 0) = 30)
      by Integer.weightedD5_completed_excludes_negative_residual(residual := (-10 : ℤ));
  ¬(2 * (x * x) + u * u + 10 * ((-(1 : ℤ)) * (-(1 : ℤ))) + 4 * 2 * (-(1 : ℤ)) * 0
          + 15 * (0 * 0) = 30)
      by Integer.weightedD5_completed_excludes_exceptional_residual(target := 20);
  ¬(2 * (x * x) + u * u + 10 * (0 * 0) + 4 * 2 * 0 * 0
          + 15 * (0 * 0) = 30)
      by Integer.weightedD5_completed_excludes_exceptional_residual(target := 30);
  ¬(2 * (x * x) + u * u + 10 * (1 * 1) + 4 * 2 * 1 * 0
          + 15 * (0 * 0) = 30)
      by Integer.weightedD5_completed_excludes_exceptional_residual(target := 20);
  ¬(2 * (x * x) + u * u + 10 * (2 * 2) + 4 * 2 * 2 * 0
          + 15 * (0 * 0) = 30)
      by Integer.weightedD5_completed_excludes_negative_residual(residual := (-10 : ℤ));
  ¬(2 * (x * x) + u * u + 10 * (3 * 3) + 4 * 2 * 3 * 0
          + 15 * (0 * 0) = 30)
      by Integer.weightedD5_completed_excludes_negative_residual(residual := (-60 : ℤ));
  ∀ (q : ℤ). -3 ≤ q → q < 4 → ¬(2 * (x * x) + u * u + 10 * (q * q) + 4 * 2 * q * 0
          + 15 * (0 * 0) = 30)
      by finite_check q from -3 until 4 as atZero;
  ¬(2 * (x * x) + u * u + 10 * ((-(3 : ℤ)) * (-(3 : ℤ))) + 4 * 2 * (-(3 : ℤ)) * 1
          + 15 * (1 * 1) = 30)
      by Integer.weightedD5_completed_excludes_negative_residual(residual := (-51 : ℤ));
  ¬(2 * (x * x) + u * u + 10 * ((-(2 : ℤ)) * (-(2 : ℤ))) + 4 * 2 * (-(2 : ℤ)) * 1
          + 15 * (1 * 1) = 30)
      by Integer.weightedD5_completed_excludes_negative_residual(residual := (-9 : ℤ));
  ¬(2 * (x * x) + u * u + 10 * ((-(1 : ℤ)) * (-(1 : ℤ))) + 4 * 2 * (-(1 : ℤ)) * 1
          + 15 * (1 * 1) = 30)
      by Integer.weightedD5_completed_excludes_exceptional_residual(target := 13);
  ¬(2 * (x * x) + u * u + 10 * (0 * 0) + 4 * 2 * 0 * 1
          + 15 * (1 * 1) = 30)
      by Integer.weightedD5_completed_excludes_exceptional_residual(target := 15);
  ¬(2 * (x * x) + u * u + 10 * (1 * 1) + 4 * 2 * 1 * 1
          + 15 * (1 * 1) = 30)
      by Integer.weightedD5_completed_excludes_negative_residual(residual := (-3 : ℤ));
  ¬(2 * (x * x) + u * u + 10 * (2 * 2) + 4 * 2 * 2 * 1
          + 15 * (1 * 1) = 30)
      by Integer.weightedD5_completed_excludes_negative_residual(residual := (-41 : ℤ));
  ¬(2 * (x * x) + u * u + 10 * (3 * 3) + 4 * 2 * 3 * 1
          + 15 * (1 * 1) = 30)
      by Integer.weightedD5_completed_excludes_negative_residual(residual := (-99 : ℤ));
  ∀ (q : ℤ). -3 ≤ q → q < 4 → ¬(2 * (x * x) + u * u + 10 * (q * q) + 4 * 2 * q * 1
          + 15 * (1 * 1) = 30)
      by finite_check q from -3 until 4 as atOne;
  ¬(2 * (x * x) + u * u + 10 * (z * z) + 4 * 2 * z * (-1)
          + 15 * ((-1) * (-1)) = 30) by atMinusOne(z, zLower, zUpper);
  ¬(2 * (x * x) + u * u + 10 * (z * z) + 4 * 2 * z * 0
          + 15 * (0 * 0) = 30) by atZero(z, zLower, zUpper);
  ¬(2 * (x * x) + u * u + 10 * (z * z) + 4 * 2 * z * 1
          + 15 * (1 * 1) = 30) by atOne(z, zLower, zUpper);
  ∀ (p : ℤ). -1 ≤ p → p < 2 → ¬(2 * (x * x) + u * u + 10 * (z * z) + 4 * 2 * z * p
          + 15 * (p * p) = 30)
      by finite_check p from -1 until 2 as allRows;
  done by allRows(w, wLower, wUpper)
}

theorem Matrix.weightedD5S1R2C8_not_represents_fifteen
        : ¬(Matrix.Represents(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 2, 8), (15 : ℤ))) := {
  done by Matrix.weightedD5_not_represents_fifteen_by_completion(
    completionCoefficient := 67, secondCoefficient := 15,
    zLow := -3, zHigh := 4,
    completionCoefficientReads := (ring : (10 : ℤ) * 8 - 5 * (1 * 1)
      - 2 * (2 * 2) = 67),
    completionCoefficientAtLeastForty := done,
    secondCoefficientReads := (ring : (2 : ℤ) * 8 - 1 * 1 = 15),
    coordinateBound := (x u z w : ℤ) (completed :
      2 * (x * x) + u * u + 10 * (z * z) + 4 * 2 * z * w
        + 15 * (w * w) = 30) ↦ { done by Integer.weightedD5R2C15_coordinate_bound(completed := completed) },
    finiteExclusion := Integer.weightedD5S1R2C8_finite_exclusion)
}

theorem Matrix.weightedD5S1R2C8_truant_fifteen
        : Matrix.IsTruant(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 2, 8), 15) := {
  (15 : ℕ) ≥ 1;
  ¬(Matrix.Represents(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 2, 8), (15 : ℤ))) by Matrix.weightedD5S1R2C8_not_represents_fifteen;
  done by Matrix.weightedD5S1R2C8_represents_below_fifteen
}

theorem Matrix.weightedD5S1R2C8_truant
        : Matrix.truant(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 2, 8)) = 15 :=
  by Matrix.truant_equals

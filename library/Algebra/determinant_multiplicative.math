-- Algebra/determinant_multiplicative.math
--
-- The determinant is multiplicative: det(A·B) = det(A)·det(B) (Stage H
-- headline #2, brick 6d of PLAN_LINEAR_ALGEBRA.md). Leibniz-expand det(AB),
-- substitute the matrix-product entry, distribute ∏Σ over the function space
-- (6a), split the product and swap the σ/φ sums (Fubini). The non-injective
-- choice functions φ contribute zero (6c alternating collapse); the injective
-- ones are permutations, and reindexing their inner sum (6d row permutation)
-- gives sign(φ̂)·det(B), reassembling det(A)·det(B).

module Algebra.determinant_multiplicative

import Logic.basics
import Logic.functions
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Integer.basics
import Lists.list
import Lists.map
import Lists.distinct
import Lists.length
import Algebra.field
import Algebra.field_bundle
import Algebra.field_aggregation
import Algebra.finite_permutation
import Algebra.permutation_enumeration
import Algebra.permutation_sign
import Algebra.permutation_of_injective
import Algebra.matrix
import Algebra.determinant
import Algebra.alternating_collapse
import Algebra.determinant_row_permutation
import Algebra.function_enumeration
import Algebra.function_enumeration_distinct

-- A non-injective self-map has an explicit colliding pair.
theorem Function.non_injective_collision (n : ℕ)
        (phi : NaturalsBelow(n) → NaturalsBelow(n))
        (notInjective : ¬(Function.IsInjective(NaturalsBelow(n), NaturalsBelow(n), phi)))
        : ∃ (a : NaturalsBelow(n)). ∃ (b : NaturalsBelow(n)). phi(a) = phi(b) ∧ ¬(a = b) := {
  ∃ (a : NaturalsBelow(n)). ¬(∀ (b : NaturalsBelow(n)). phi(a) = phi(b) → a = b)
      by Logic.not_forall_implies_exists_not(
             predicate := (a : NaturalsBelow(n)) ↦ (∀ (b : NaturalsBelow(n)). phi(a) = phi(b) → a = b),
             notForall := notInjective);
  choose a such that ¬(∀ (b : NaturalsBelow(n)). phi(a) = phi(b) → a = b) as notForallB;
  ∃ (b : NaturalsBelow(n)). ¬(phi(a) = phi(b) → a = b)
      by Logic.not_forall_implies_exists_not(
             predicate := (b : NaturalsBelow(n)) ↦ (phi(a) = phi(b) → a = b), notForall := notForallB);
  choose b such that ¬(phi(a) = phi(b) → a = b);
  phi(a) = phi(b) ∧ ¬(a = b) by Logic.not_implies_implies_and_not as collision;
  witness a with {
    witness b with { collision }
  }
}

-- An injective function is the application map of the permutation packaging it,
-- hence a member of the enumerated permutation-image list.
theorem Function.injective_in_permutation_image (n : ℕ)
        (phi : NaturalsBelow(n) → NaturalsBelow(n))
        (inj : Function.IsInjective(NaturalsBelow(n), NaturalsBelow(n), phi))
        : phi ∈ List.map(Permutation(n), NaturalsBelow(n) → NaturalsBelow(n),
              (rho : Permutation(n)) ↦ ((i : NaturalsBelow(n)) ↦ rho(i)),
              Permutation.allPermutations(n)) := {
  Permutation.of_injective(n, phi, inj) ∈ Permutation.allPermutations(n) by Permutation.allPermutations_complete;
  ((i : NaturalsBelow(n)) ↦ Permutation.of_injective(n, phi, inj)(i))
      ∈ List.map(Permutation(n), NaturalsBelow(n) → NaturalsBelow(n),
          (rho : Permutation(n)) ↦ ((i : NaturalsBelow(n)) ↦ rho(i)),
          Permutation.allPermutations(n))
      by List.map_member;
  phi ∈ List.map(Permutation(n), NaturalsBelow(n) → NaturalsBelow(n),
          (rho : Permutation(n)) ↦ ((i : NaturalsBelow(n)) ↦ rho(i)),
          Permutation.allPermutations(n));
  done
}

-- ── Expanding one Leibniz term over the function space ─────────────────
-- ∏_i (AB)(i, σi) = Σ_φ ∏_i A(i, φi)·B(φi, σi), via the matrix-product entry
-- and the generalized distributivity (6a).
theorem Matrix.entry_product_expand {f : Field} {n : ℕ}
        (A B : Matrix(f, n, n)) (sigma : Permutation(n))
        : Field.productOver(
              (i : NaturalsBelow(n)) ↦ Matrix.multiply(A, B)(i, sigma(i)),
              NaturalsBelow.enumerate(n))
          = Field.sumOver(
                (phi : NaturalsBelow(n) → NaturalsBelow(n)) ↦
                    Field.productOver(
                        (i : NaturalsBelow(n)) ↦ A(i, phi(i)) * B(phi(i), sigma(i)),
                        NaturalsBelow.enumerate(n)),
                Function.allFunctions(n)) :=
  Field.productOver(
        (i : NaturalsBelow(n)) ↦ Matrix.multiply(A, B)(i, sigma(i)),
        NaturalsBelow.enumerate(n))
     = Field.productOver(
           (i : NaturalsBelow(n)) ↦
               Field.sumOver((k : NaturalsBelow(n)) ↦ A(i, k) * B(k, sigma(i)),
                   NaturalsBelow.enumerate(n)),
           NaturalsBelow.enumerate(n))
     = Field.sumOver(
           (phi : NaturalsBelow(n) → NaturalsBelow(n)) ↦
               Field.productOver(
                   (i : NaturalsBelow(n)) ↦ A(i, phi(i)) * B(phi(i), sigma(i)),
                   NaturalsBelow.enumerate(n)),
           Function.allFunctions(n))
           by Field.productOfSums_over_allFunctions(
                  h := (i : NaturalsBelow(n)) ↦ (c : NaturalsBelow(n)) ↦
                      A(i, c) * B(c, sigma(i)))

-- The full σ-term, with the sign pulled inside the φ-sum.
theorem Matrix.sigma_term_expand {f : Field} {n : ℕ}
        (A B : Matrix(f, n, n)) (sigma : Permutation(n))
        : Field.from_integer(f, Permutation.sign(sigma))
              * Field.productOver(
                    (i : NaturalsBelow(n)) ↦ Matrix.multiply(A, B)(i, sigma(i)),
                    NaturalsBelow.enumerate(n))
          = Field.sumOver(
                (phi : NaturalsBelow(n) → NaturalsBelow(n)) ↦
                    Field.from_integer(f, Permutation.sign(sigma))
                        * Field.productOver(
                              (i : NaturalsBelow(n)) ↦ A(i, phi(i)) * B(phi(i), sigma(i)),
                              NaturalsBelow.enumerate(n)),
                Function.allFunctions(n)) :=
  Field.from_integer(f, Permutation.sign(sigma))
        * Field.productOver(
              (i : NaturalsBelow(n)) ↦ Matrix.multiply(A, B)(i, sigma(i)),
              NaturalsBelow.enumerate(n))
     = Field.from_integer(f, Permutation.sign(sigma))
           * Field.sumOver(
                 (phi : NaturalsBelow(n) → NaturalsBelow(n)) ↦
                     Field.productOver(
                         (i : NaturalsBelow(n)) ↦ A(i, phi(i)) * B(phi(i), sigma(i)),
                         NaturalsBelow.enumerate(n)),
                 Function.allFunctions(n))
           by substituting Matrix.entry_product_expand
     = Field.sumOver(
           (phi : NaturalsBelow(n) → NaturalsBelow(n)) ↦
               Field.from_integer(f, Permutation.sign(sigma))
                   * Field.productOver(
                         (i : NaturalsBelow(n)) ↦ A(i, phi(i)) * B(phi(i), sigma(i)),
                         NaturalsBelow.enumerate(n)),
           Function.allFunctions(n))
           by Field.sumOver_scale_left

-- The inner σ-sum for a fixed φ factors ∏A(i, φi) out of the B-determinant sum.
theorem Matrix.phi_inner_sum {f : Field} {n : ℕ}
        (A B : Matrix(f, n, n)) (phi : NaturalsBelow(n) → NaturalsBelow(n))
        : Field.sumOver(
              (sigma : Permutation(n)) ↦
                  Field.from_integer(f, Permutation.sign(sigma))
                      * Field.productOver(
                            (i : NaturalsBelow(n)) ↦ A(i, phi(i)) * B(phi(i), sigma(i)),
                            NaturalsBelow.enumerate(n)),
              Permutation.allPermutations(n))
          = Field.productOver((i : NaturalsBelow(n)) ↦ A(i, phi(i)), NaturalsBelow.enumerate(n))
              * Field.sumOver(
                    (sigma : Permutation(n)) ↦
                        Field.from_integer(f, Permutation.sign(sigma))
                            * Field.productOver(
                                  (i : NaturalsBelow(n)) ↦ B(phi(i), sigma(i)),
                                  NaturalsBelow.enumerate(n)),
                    Permutation.allPermutations(n)) := {
  Field.productOver((i : NaturalsBelow(n)) ↦ A(i, phi(i)), NaturalsBelow.enumerate(n))
        * Field.sumOver(
              (sigma : Permutation(n)) ↦
                  Field.from_integer(f, Permutation.sign(sigma))
                      * Field.productOver(
                            (i : NaturalsBelow(n)) ↦ B(phi(i), sigma(i)),
                            NaturalsBelow.enumerate(n)),
              Permutation.allPermutations(n))
      = Field.sumOver(
            (sigma : Permutation(n)) ↦
                Field.productOver((i : NaturalsBelow(n)) ↦ A(i, phi(i)), NaturalsBelow.enumerate(n))
                    * (Field.from_integer(f, Permutation.sign(sigma))
                          * Field.productOver(
                                (i : NaturalsBelow(n)) ↦ B(phi(i), sigma(i)),
                                NaturalsBelow.enumerate(n))),
            Permutation.allPermutations(n))
        by Field.sumOver_scale_left
      as scaleEquation;
  Field.sumOver(
        (sigma : Permutation(n)) ↦
            Field.from_integer(f, Permutation.sign(sigma))
                * Field.productOver(
                      (i : NaturalsBelow(n)) ↦ A(i, phi(i)) * B(phi(i), sigma(i)),
                      NaturalsBelow.enumerate(n)),
        Permutation.allPermutations(n))
     = Field.sumOver(
           (sigma : Permutation(n)) ↦
               Field.productOver((i : NaturalsBelow(n)) ↦ A(i, phi(i)), NaturalsBelow.enumerate(n))
                   * (Field.from_integer(f, Permutation.sign(sigma))
                         * Field.productOver(
                               (i : NaturalsBelow(n)) ↦ B(phi(i), sigma(i)),
                               NaturalsBelow.enumerate(n))),
           Permutation.allPermutations(n))
           by Field.sumOver_congruence(
                  pointwise := (sigma : Permutation(n)) ↦ {
                      Field.productOver(
                            (i : NaturalsBelow(n)) ↦ A(i, phi(i)) * B(phi(i), sigma(i)),
                            NaturalsBelow.enumerate(n))
                         = Field.productOver((i : NaturalsBelow(n)) ↦ A(i, phi(i)), NaturalsBelow.enumerate(n))
                               * Field.productOver(
                                     (i : NaturalsBelow(n)) ↦ B(phi(i), sigma(i)),
                                     NaturalsBelow.enumerate(n))
                             by Field.productOver_multiply
                             as productSplit;
                      Field.from_integer(f, Permutation.sign(sigma))
                            * Field.productOver(
                                  (i : NaturalsBelow(n)) ↦ A(i, phi(i)) * B(phi(i), sigma(i)),
                                  NaturalsBelow.enumerate(n))
                         = Field.from_integer(f, Permutation.sign(sigma))
                               * (Field.productOver((i : NaturalsBelow(n)) ↦ A(i, phi(i)),
                                        NaturalsBelow.enumerate(n))
                                     * Field.productOver(
                                           (i : NaturalsBelow(n)) ↦ B(phi(i), sigma(i)),
                                           NaturalsBelow.enumerate(n)))
                             by substituting productSplit
                         = Field.productOver((i : NaturalsBelow(n)) ↦ A(i, phi(i)), NaturalsBelow.enumerate(n))
                               * (Field.from_integer(f, Permutation.sign(sigma))
                                     * Field.productOver(
                                           (i : NaturalsBelow(n)) ↦ B(phi(i), sigma(i)),
                                           NaturalsBelow.enumerate(n)))
                             by ring
                    })
     = Field.productOver((i : NaturalsBelow(n)) ↦ A(i, phi(i)), NaturalsBelow.enumerate(n))
           * Field.sumOver(
                 (sigma : Permutation(n)) ↦
                     Field.from_integer(f, Permutation.sign(sigma))
                         * Field.productOver(
                               (i : NaturalsBelow(n)) ↦ B(phi(i), sigma(i)),
                               NaturalsBelow.enumerate(n)),
                 Permutation.allPermutations(n))
           by scaleEquation
}

-- A choice function outside the permutation image is non-injective, so its
-- inner B-determinant sum vanishes (6c) and the whole summand is zero.
theorem Matrix.det_multiply_summand_vanishes {f : Field} {n : ℕ}
        (A B : Matrix(f, n, n)) (phi : NaturalsBelow(n) → NaturalsBelow(n))
        (notInImage : ¬(phi ∈ List.map(Permutation(n), NaturalsBelow(n) → NaturalsBelow(n),
            (rho : Permutation(n)) ↦ ((i : NaturalsBelow(n)) ↦ rho(i)),
            Permutation.allPermutations(n))))
        : Field.productOver((i : NaturalsBelow(n)) ↦ A(i, phi(i)), NaturalsBelow.enumerate(n))
              * Field.sumOver(
                    (sigma : Permutation(n)) ↦
                        Field.from_integer(f, Permutation.sign(sigma))
                            * Field.productOver(
                                  (i : NaturalsBelow(n)) ↦ B(phi(i), sigma(i)),
                                  NaturalsBelow.enumerate(n)),
                    Permutation.allPermutations(n))
          = Field.zero(f) := {
  ¬(Function.IsInjective(NaturalsBelow(n), NaturalsBelow(n), phi))
      by (inj : Function.IsInjective(NaturalsBelow(n), NaturalsBelow(n), phi)) ↦
          notInImage(Function.injective_in_permutation_image(inj := inj)) as notInjective;
  choose a such that ∃ (b : NaturalsBelow(n)). phi(a) = phi(b) ∧ ¬(a = b)
      from Function.non_injective_collision(notInjective := notInjective);
  choose b such that phi(a) = phi(b) ∧ ¬(a = b);
  phi(a) = phi(b);
  ¬(a = b);
  Field.sumOver(
          (sigma : Permutation(n)) ↦
              Field.from_integer(f, Permutation.sign(sigma))
                  * Field.productOver(
                        (i : NaturalsBelow(n)) ↦ B(phi(i), sigma(i)),
                        NaturalsBelow.enumerate(n)),
          Permutation.allPermutations(n))
      = Field.zero(f)
      by Matrix.alternating_collapse as innerZero;
  Field.productOver((i : NaturalsBelow(n)) ↦ A(i, phi(i)), NaturalsBelow.enumerate(n))
        * Field.sumOver(
              (sigma : Permutation(n)) ↦
                  Field.from_integer(f, Permutation.sign(sigma))
                      * Field.productOver(
                            (i : NaturalsBelow(n)) ↦ B(phi(i), sigma(i)),
                            NaturalsBelow.enumerate(n)),
              Permutation.allPermutations(n))
     = Field.productOver((i : NaturalsBelow(n)) ↦ A(i, phi(i)), NaturalsBelow.enumerate(n))
           * Field.zero(f)
           by substituting innerZero
     = Field.zero(f)
}

-- ── The multiplicative law ─────────────────────────────────────────────
theorem Matrix.determinant_multiply {f : Field} {n : ℕ} (A B : Matrix(f, n, n))
        : Matrix.determinant(Matrix.multiply(A, B))
          = Matrix.determinant(A) * Matrix.determinant(B) := {
  -- The permutation-image sub-list of the function space is distinct, and its
  -- members are (trivially) all functions.
  List.Distinct(Permutation(n), Permutation.allPermutations(n)) by Permutation.allPermutations_distinct;
  List.Distinct(NaturalsBelow(n) → NaturalsBelow(n),
          List.map(Permutation(n), NaturalsBelow(n) → NaturalsBelow(n),
              (rho : Permutation(n)) ↦ ((i : NaturalsBelow(n)) ↦ rho(i)),
              Permutation.allPermutations(n)))
      by List.map_distinct(
             injective := (rho1 rho2 : Permutation(n))
                 (equalMaps : ((i : NaturalsBelow(n)) ↦ rho1(i))
                     = ((i : NaturalsBelow(n)) ↦ rho2(i))) ↦ {
               ∀ (i : NaturalsBelow(n)). rho1(i) = rho2(i)
                   by { take i : NaturalsBelow(n);
                        done };
               done by Permutation.equal_of_apply_equal
             });
  (∀ (phi : NaturalsBelow(n) → NaturalsBelow(n)).
      phi ∈ List.map(Permutation(n), NaturalsBelow(n) → NaturalsBelow(n),
          (rho : Permutation(n)) ↦ ((i : NaturalsBelow(n)) ↦ rho(i)),
          Permutation.allPermutations(n))
      → phi ∈ Function.allFunctions(n))
      by (phi : NaturalsBelow(n) → NaturalsBelow(n))
         (phiInPart : phi ∈ List.map(Permutation(n), NaturalsBelow(n) → NaturalsBelow(n),
             (rho : Permutation(n)) ↦ ((i : NaturalsBelow(n)) ↦ rho(i)),
             Permutation.allPermutations(n))) ↦
           Function.allFunctions_complete;

  -- Pointwise facts lifted through the sums below: each σ-term Leibniz-expands
  -- over the function space, and each φ-summand factors ∏A out of the σ-sum.
  ∀ (sigma : Permutation(n)).
      Field.from_integer(f, Permutation.sign(sigma))
          * Field.productOver(
                (i : NaturalsBelow(n)) ↦ Matrix.multiply(A, B)(i, sigma(i)),
                NaturalsBelow.enumerate(n))
      = Field.sumOver(
            (phi : NaturalsBelow(n) → NaturalsBelow(n)) ↦
                Field.from_integer(f, Permutation.sign(sigma))
                    * Field.productOver(
                          (i : NaturalsBelow(n)) ↦ A(i, phi(i)) * B(phi(i), sigma(i)),
                          NaturalsBelow.enumerate(n)),
            Function.allFunctions(n))
      by Matrix.sigma_term_expand;
  ∀ (phi : NaturalsBelow(n) → NaturalsBelow(n)).
      Field.sumOver(
            (sigma : Permutation(n)) ↦
                Field.from_integer(f, Permutation.sign(sigma))
                    * Field.productOver(
                          (i : NaturalsBelow(n)) ↦ A(i, phi(i)) * B(phi(i), sigma(i)),
                          NaturalsBelow.enumerate(n)),
            Permutation.allPermutations(n))
      = Field.productOver((i : NaturalsBelow(n)) ↦ A(i, phi(i)), NaturalsBelow.enumerate(n))
          * Field.sumOver(
                (sigma : Permutation(n)) ↦
                    Field.from_integer(f, Permutation.sign(sigma))
                        * Field.productOver(
                              (i : NaturalsBelow(n)) ↦ B(phi(i), sigma(i)),
                              NaturalsBelow.enumerate(n)),
                Permutation.allPermutations(n))
      by Matrix.phi_inner_sum;

  -- The φ-sum restricts to the permutation image: the function space is
  -- distinct, and every summand outside the image vanishes (6c).
  List.Distinct(NaturalsBelow(n) → NaturalsBelow(n), Function.allFunctions(n)) by Function.allFunctions_distinct;
  ∀ (phi : NaturalsBelow(n) → NaturalsBelow(n)).
      phi ∈ Function.allFunctions(n)
      → ¬(phi ∈ List.map(Permutation(n), NaturalsBelow(n) → NaturalsBelow(n),
              (rho : Permutation(n)) ↦ ((i : NaturalsBelow(n)) ↦ rho(i)),
              Permutation.allPermutations(n)))
      → Field.productOver((i : NaturalsBelow(n)) ↦ A(i, phi(i)), NaturalsBelow.enumerate(n))
            * Field.sumOver(
                  (sigma : Permutation(n)) ↦
                      Field.from_integer(f, Permutation.sign(sigma))
                          * Field.productOver(
                                (i : NaturalsBelow(n)) ↦ B(phi(i), sigma(i)),
                                NaturalsBelow.enumerate(n)),
                  Permutation.allPermutations(n))
        = Field.zero(f)
      by Matrix.det_multiply_summand_vanishes;

  Matrix.determinant(Matrix.multiply(A, B))
     = Field.sumOver(
           (sigma : Permutation(n)) ↦
               Field.from_integer(f, Permutation.sign(sigma))
                   * Field.productOver(
                         (i : NaturalsBelow(n)) ↦ Matrix.multiply(A, B)(i, sigma(i)),
                         NaturalsBelow.enumerate(n)),
           Permutation.allPermutations(n))
           by Matrix.determinant_expansion
     = Field.sumOver(
           (sigma : Permutation(n)) ↦
               Field.sumOver(
                   (phi : NaturalsBelow(n) → NaturalsBelow(n)) ↦
                       Field.from_integer(f, Permutation.sign(sigma))
                           * Field.productOver(
                                 (i : NaturalsBelow(n)) ↦ A(i, phi(i)) * B(phi(i), sigma(i)),
                                 NaturalsBelow.enumerate(n)),
                   Function.allFunctions(n)),
           Permutation.allPermutations(n))
           by Field.sumOver_congruence
     = Field.sumOver(
           (phi : NaturalsBelow(n) → NaturalsBelow(n)) ↦
               Field.sumOver(
                   (sigma : Permutation(n)) ↦
                       Field.from_integer(f, Permutation.sign(sigma))
                           * Field.productOver(
                                 (i : NaturalsBelow(n)) ↦ A(i, phi(i)) * B(phi(i), sigma(i)),
                                 NaturalsBelow.enumerate(n)),
                   Permutation.allPermutations(n)),
           Function.allFunctions(n))
           by Field.sumOver_interchange(
                  term := (sigma : Permutation(n)) ↦ (phi : NaturalsBelow(n) → NaturalsBelow(n)) ↦
                      Field.from_integer(f, Permutation.sign(sigma))
                          * Field.productOver(
                                (i : NaturalsBelow(n)) ↦ A(i, phi(i)) * B(phi(i), sigma(i)),
                                NaturalsBelow.enumerate(n)))
     = Field.sumOver(
           (phi : NaturalsBelow(n) → NaturalsBelow(n)) ↦
               Field.productOver((i : NaturalsBelow(n)) ↦ A(i, phi(i)), NaturalsBelow.enumerate(n))
                   * Field.sumOver(
                         (sigma : Permutation(n)) ↦
                             Field.from_integer(f, Permutation.sign(sigma))
                                 * Field.productOver(
                                       (i : NaturalsBelow(n)) ↦ B(phi(i), sigma(i)),
                                       NaturalsBelow.enumerate(n)),
                         Permutation.allPermutations(n)),
           Function.allFunctions(n))
           by Field.sumOver_congruence
     = Field.sumOver(
           (phi : NaturalsBelow(n) → NaturalsBelow(n)) ↦
               Field.productOver((i : NaturalsBelow(n)) ↦ A(i, phi(i)), NaturalsBelow.enumerate(n))
                   * Field.sumOver(
                         (sigma : Permutation(n)) ↦
                             Field.from_integer(f, Permutation.sign(sigma))
                                 * Field.productOver(
                                       (i : NaturalsBelow(n)) ↦ B(phi(i), sigma(i)),
                                       NaturalsBelow.enumerate(n)),
                         Permutation.allPermutations(n)),
           List.map(Permutation(n), NaturalsBelow(n) → NaturalsBelow(n),
               (rho : Permutation(n)) ↦ ((i : NaturalsBelow(n)) ↦ rho(i)),
               Permutation.allPermutations(n)))
           by Field.sumOver_restrict_support
     = Field.sumOver(
           (rho : Permutation(n)) ↦
               Field.productOver((i : NaturalsBelow(n)) ↦ A(i, rho(i)), NaturalsBelow.enumerate(n))
                   * Field.sumOver(
                         (sigma : Permutation(n)) ↦
                             Field.from_integer(f, Permutation.sign(sigma))
                                 * Field.productOver((i : NaturalsBelow(n)) ↦ B(rho(i), sigma(i)), NaturalsBelow.enumerate(n)),
                         Permutation.allPermutations(n)),
           Permutation.allPermutations(n))
           by Field.sumOver_map
     = Field.sumOver(
           (rho : Permutation(n)) ↦
               Field.productOver((i : NaturalsBelow(n)) ↦ A(i, rho(i)), NaturalsBelow.enumerate(n))
                   * (Field.from_integer(f, Permutation.sign(rho)) * Matrix.determinant(B)),
           Permutation.allPermutations(n))
           by Field.sumOver_congruence(pointwise := (rho : Permutation(n)) ↦ {
                  Field.productOver((i : NaturalsBelow(n)) ↦ A(i, rho(i)), NaturalsBelow.enumerate(n))
                        * Field.sumOver(
                              (sigma : Permutation(n)) ↦
                                  Field.from_integer(f, Permutation.sign(sigma))
                                      * Field.productOver((i : NaturalsBelow(n)) ↦ B(rho(i), sigma(i)), NaturalsBelow.enumerate(n)),
                              Permutation.allPermutations(n))
                     = Field.productOver((i : NaturalsBelow(n)) ↦ A(i, rho(i)), NaturalsBelow.enumerate(n))
                           * (Field.from_integer(f, Permutation.sign(rho)) * Matrix.determinant(B))
                       by substituting Matrix.determinant_row_permutation
                })
     = Field.sumOver(
           (rho : Permutation(n)) ↦
               (Field.from_integer(f, Permutation.sign(rho))
                     * Field.productOver((i : NaturalsBelow(n)) ↦ A(i, rho(i)), NaturalsBelow.enumerate(n)))
                   * Matrix.determinant(B),
           Permutation.allPermutations(n))
           by Field.sumOver_congruence(pointwise := (rho : Permutation(n)) ↦ {
                      Field.productOver((i : NaturalsBelow(n)) ↦ A(i, rho(i)), NaturalsBelow.enumerate(n))
                          * (Field.from_integer(f, Permutation.sign(rho)) * Matrix.determinant(B))
                         = (Field.from_integer(f, Permutation.sign(rho))
                               * Field.productOver((i : NaturalsBelow(n)) ↦ A(i, rho(i)), NaturalsBelow.enumerate(n)))
                               * Matrix.determinant(B)
                             by ring
                    })
     = Field.sumOver(
           (rho : Permutation(n)) ↦
               Field.from_integer(f, Permutation.sign(rho))
                   * Field.productOver((i : NaturalsBelow(n)) ↦ A(i, rho(i)), NaturalsBelow.enumerate(n)),
           Permutation.allPermutations(n))
           * Matrix.determinant(B)
           by Field.sumOver_scale_right
     = Matrix.determinant(A) * Matrix.determinant(B)
}

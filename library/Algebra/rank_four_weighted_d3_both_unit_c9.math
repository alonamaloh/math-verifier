module Algebra.rank_four_weighted_d3_both_unit_c9

import Algebra.rank_four_weighted_d3_both_unit_universality

theorem Matrix.weightedD3S1R1C9_universal_of_two_three_six_converse (converse : Integer.TwoThreeSixLocalConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 1, 1, 9)) :=
  by Matrix.weightedD3BothUnit_universal_of_two_three_six_converse(
      converse, corner := 9, coefficient := 49, core := 11, coefficientShape := done, coreSum := done,
      coreAdmissible := (q : ℕ) ↦ {
        32 * q + 11 = 8 * (4 * q + 1) + 3 by ring as coreReads;
        suppose Natural.IsThreeSquareObstruction(32 * q + 11) as obstruction;
        Natural.IsThreeSquareObstruction(8 * (4 * q + 1) + 3) by substituting coreReads as transformedObstruction;
        done by Natural.eight_times_plus_three_not_obstruction(4 * q + 1)(transformedObstruction)
      })

-- Algebra/four_power_mod_three.math

module Algebra.four_power_mod_three

import Algebra.rank_four_weighted_d3_both_unit_foundation

theorem Natural.four_power_is_three_times_plus_one
        (exponent : ℕ) : ∃ (quotient : ℕ). 4 ^ exponent = 3 * quotient + 1 :=
  by induction on exponent with IH {
    case base: {
      witness 0 with
        4 ^ 0
           = 1 by Natural.power_zero(4)
           = 3 * 0 + 1
    }
    case step(predecessor): {
      choose quotient : ℕ such that 4 ^ predecessor = 3 * quotient + 1 as predecessorReads from IH;
      witness 4 * quotient + 1 with
        4 ^ (1 + predecessor)
           = 4 * 4 ^ predecessor by Natural.power_one_plus(4, predecessor)
           = 4 * (3 * quotient + 1) by substituting predecessorReads
           = 3 * (4 * quotient + 1) + 1 by ring
    }
  }

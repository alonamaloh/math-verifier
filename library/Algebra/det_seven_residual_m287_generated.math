theorem Natural.detSevenResidueCover_m287_table_part3
        : ∀ (a : ℕ). a ≥ 147 → a < 196 →
          Natural.modulo(a, 4) ≠ 0 →
          Natural.modulo(a, 49) ≠ 0 →
          ¬(
            Natural.modulo(a, 12) ≠ 7
            ∧ Natural.modulo(a, 12) ≠ 10
            ∧ Natural.modulo(a, 49) ≠ 0
            ∧ Natural.modulo(a, 49) ≠ 21
            ∧ Natural.modulo(a, 49) ≠ 35
            ∧ Natural.modulo(a, 49) ≠ 42) →
          ∃ (t : ℕ). (t = 1 ∨ t = 2 ∨ t = 3 ∨ t = 4 ∨ t = 6 ∨ t = 9)
            ∧ Natural.DetSevenResidueSolution(287, a, t) := {
  Natural.modulo(147, 4) ≠ 0 →

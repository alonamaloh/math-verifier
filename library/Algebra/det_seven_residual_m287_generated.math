theorem Natural.detSevenResidueCover_m287_table
        : ∀ (a : ℕ). a ≥ 0 → a < 588 →
          Natural.modulo(a, 4) ≠ 0 →
          Natural.modulo(a, 49) ≠ 0 →
          ¬(
            Natural.modulo(a, 12) ≠ 7
            ∧ Natural.modulo(a, 12) ≠ 10
            ∧ Natural.modulo(a, 49) ≠ 0
            ∧ Natural.modulo(a, 49) ≠ 21
            ∧ Natural.modulo(a, 49) ≠ 35
            ∧ Natural.modulo(a, 49) ≠ 42) →
          ∃ (t : ℕ). (t = 1 ∨ t = 2 ∨ t = 3 ∨ t = 4 ∨ t = 6 ∨ t = 9)
            ∧ Natural.DetSevenResidueSolution(287, a, t) := {
  take a : ℕ;
  suppose a ≥ 0 as aNonnegative;
  suppose a < 588 as aBelow;
  suppose Natural.modulo(a, 4) ≠ 0 as parityCondition;
  suppose Natural.modulo(a, 49) ≠ 0 as notMultipleFortyNine;
  suppose ¬(
            Natural.modulo(a, 12) ≠ 7
            ∧ Natural.modulo(a, 12) ≠ 10
            ∧ Natural.modulo(a, 49) ≠ 0
            ∧ Natural.modulo(a, 49) ≠ 21
            ∧ Natural.modulo(a, 49) ≠ 35
            ∧ Natural.modulo(a, 49) ≠ 42) as unsafe;
  a < 49 ∨ 49 ≤ a by Natural.lt_or_le;
  done by cases {
    case a < 49 as below49:
      done by Natural.detSevenResidueCover_m287_table_part0(
        a, aNonnegative, below49, parityCondition, notMultipleFortyNine, unsafe)
    case 49 ≤ a as atLeast49: {
      a < 98 ∨ 98 ≤ a by Natural.lt_or_le;
      done by cases {
        case a < 98 as below98:
          done by Natural.detSevenResidueCover_m287_table_part1(
            a, atLeast49, below98, parityCondition, notMultipleFortyNine, unsafe)
        case 98 ≤ a as atLeast98: {
          a < 147 ∨ 147 ≤ a by Natural.lt_or_le;
          done by cases {
            case a < 147 as below147:
              done by Natural.detSevenResidueCover_m287_table_part2(
                a, atLeast98, below147, parityCondition, notMultipleFortyNine, unsafe)
            case 147 ≤ a as atLeast147: {
              a < 196 ∨ 196 ≤ a by Natural.lt_or_le;
              done by cases {
                case a < 196 as below196:
                  done by Natural.detSevenResidueCover_m287_table_part3(
                    a, atLeast147, below196, parityCondition, notMultipleFortyNine, unsafe)
                case 196 ≤ a as atLeast196: {
                  a < 245 ∨ 245 ≤ a by Natural.lt_or_le;
                  done by cases {
                    case a < 245 as below245:
                      done by Natural.detSevenResidueCover_m287_table_part4(
                        a, atLeast196, below245, parityCondition, notMultipleFortyNine, unsafe)
                    case 245 ≤ a as atLeast245: {
                      a < 294 ∨ 294 ≤ a by Natural.lt_or_le;
                      done by cases {
                        case a < 294 as below294:
                          done by Natural.detSevenResidueCover_m287_table_part5(
                            a, atLeast245, below294, parityCondition, notMultipleFortyNine, unsafe)
                        case 294 ≤ a as atLeast294: {
                          a < 343 ∨ 343 ≤ a by Natural.lt_or_le;
                          done by cases {
                            case a < 343 as below343:
                              done by Natural.detSevenResidueCover_m287_table_part6(
                                a, atLeast294, below343, parityCondition, notMultipleFortyNine, unsafe)
                            case 343 ≤ a as atLeast343: {
                              a < 392 ∨ 392 ≤ a by Natural.lt_or_le;

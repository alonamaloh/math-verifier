-- Algebra/rank_four_weighted_d3_both_unit_universality.math

module Algebra.rank_four_weighted_d3_both_unit_universality

import Algebra.rank_four_weighted_d3_both_unit_cover
import Algebra.rank_four_weighted_d3_both_unit_lift

theorem Matrix.weightedD3BothUnit_universal_of_two_three_six_converse
        (converse : Integer.TwoThreeSixLocalConverse)
        (corner coefficient core : ℕ)
        (coefficientShape : 6 * corner = coefficient + 5)
        (coreSum : core + coefficient = 60)
        (coreAdmissible : ∀ (q : ℕ). ¬(Natural.IsThreeSquareObstruction(32 * q + core)))
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 1, 1, (corner : ℤ))) :=
  by Matrix.weightedD3BothUnit_universal_of_cover(
      corner,
      Natural.six_times_monus_five_to_integer(corner, coefficient, coefficientShape),
      Matrix.twoThreeSixSextupleTargetCover_of_local_converse(
          converse, corner, coefficient, core, coefficientShape, coreSum, coreAdmissible))

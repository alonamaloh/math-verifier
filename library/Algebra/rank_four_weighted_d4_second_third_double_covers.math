        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 1, 2, 6)) :=
  by Matrix.weightedD4SecondThirdDouble_universal_selected_core_of_converse(
      converse, corner := 6, coefficient := 18, shift := 2, core := 6,
      coefficientReads := done, completionReads := done,
      baseControl := Matrix.oneTwoFour_two_one_core_six_base_coset_of_converse(converse))


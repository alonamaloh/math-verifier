-- Algebra/rank_four_weighted_d4_second_third_double_covers.math
--
-- The six selected forms x²+2y²+4z²+2yw+4zw+cw².

module Algebra.rank_four_weighted_d4_second_third_double_covers

import Algebra.rank_four_weighted_d4_even_cosets

theorem Matrix.weightedD4SecondThirdDouble_universal_selected_core_of_converse
        (converse : Matrix.OneTwoFourConverse)
        (corner coefficient shift core : ℕ)
        (coefficientReads : (coefficient : ℤ) = 4 * (corner : ℤ) - 6)
        (completionReads : 16 * shift + core + coefficient = 56)
        (baseControl : Matrix.OneTwoFourBaseCoset(core, 2, 1))
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(
            4, 1, 2, (corner : ℤ))) :=
  by Matrix.weightedD4_universal_of_base_coset(
      converse, secondResidue := 1, thirdResidue := 2, corner := corner,
      coefficient := coefficient, shift := shift, core := core,
      coefficientReads := {
        (coefficient : ℤ)
           = 4 * (corner : ℤ) - 6 by coefficientReads
           = 4 * (corner : ℤ) - 2 * (1 : ℤ) * (1 : ℤ) - (2 : ℤ) * (2 : ℤ) by ring
      },
      completionReads := completionReads, baseControl := baseControl)

theorem Matrix.weightedD4S1R2C5_universal_of_one_two_four_converse (converse : Matrix.OneTwoFourConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 1, 2, 5)) :=
  by Matrix.weightedD4SecondThirdDouble_universal_selected_core_of_converse(
      converse, corner := 5, coefficient := 14, shift := 2, core := 10,
      coefficientReads := done, completionReads := done,
      baseControl := Matrix.oneTwoFour_two_one_core_ten_base_coset_of_converse(converse))


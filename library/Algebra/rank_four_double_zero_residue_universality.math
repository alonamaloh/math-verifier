        (converse : Matrix.ThreeSquaresConverse)
        : Matrix.IsUniversal(Matrix.sumOfTwoSquaresPlusScaledSquareRankFourRepresentative(2, 0, 4)) := {
  done by Matrix.doubleZero_universal_of_selected_uniform_core(
      converse, corner := 4, core := 20, coreSum := done,
      selectedCore := Or.introduceRight(Or.introduceRight(Or.introduceRight(
        Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(
          Or.introduceRight(Or.introduceLeft(done))))))))))
}


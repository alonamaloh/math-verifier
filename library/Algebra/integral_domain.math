-- Algebra/integral_domain.math
--
-- An *integral domain*: a commutative ring with `1 â‰  0` and no zero
-- divisors. This is the base structure for the factorization tower
-- (integral domain â†’ principal ideal domain â†’ unique factorization
-- domain). Bundled like `CommutativeRing` so a generic factorization
-- argument threads one `d : IntegralDomain` instead of the carrier,
-- operations, and a pile of law proofs.
--
-- The headline derived fact is `IntegralDomain.multiply_cancel_left`:
-- with no zero divisors, a nonzero factor cancels. Cancellation is what
-- makes "factorization is unique up to units and order" meaningful â€” it
-- is used pervasively downstream.
--
-- `Ring.IsUnit` (an element dividing `1`) also lives here; it needs no
-- domain hypothesis but belongs with the divisibility vocabulary that
-- the factorization development is built from.

module Algebra.integral_domain

import Logic.basics
import Logic.exists
import Logic.sum
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Algebra.ring_difference
import Algebra.ring_divisibility
import Algebra.commutative_ring_bundle

-- ----------------------------------------------------------------------
-- No zero divisors.

-- A ring has no zero divisors when a product is zero only if one of the
-- factors is zero.
definition Ring.HasNoZeroDivisors (s : Ring) : Proposition :=
  (x y : Ring.carrier(s))
    â†’ x * y = Ring.zero(s)
    â†’ x = Ring.zero(s) âˆ¨ y = Ring.zero(s)

-- ----------------------------------------------------------------------
-- The integral-domain bundle.

-- A commutative ring with `1 â‰  0` and no zero divisors. Lives in
-- Type(1) because it carries a `CommutativeRing` (itself in Type(1)).
inductive IntegralDomain : Type(1) where
  | IntegralDomain.make
      : (commutativeRing : CommutativeRing)
        â†’ Ring.one(CommutativeRing.ring(commutativeRing))
              â‰  Ring.zero(CommutativeRing.ring(commutativeRing))
        â†’ Ring.HasNoZeroDivisors(CommutativeRing.ring(commutativeRing))
        â†’ IntegralDomain

-- ----------------------------------------------------------------------
-- Field projections. `ring`, `carrier`, and `commutative` factor through
-- the bundled `CommutativeRing`; `nontrivial` and `no_zero_divisors`
-- read the two extra fields off the constructor.

definition IntegralDomain.commutativeRing : IntegralDomain â†’ CommutativeRing
  | IntegralDomain.make(commutativeRing, nontrivial, noZeroDivisors) =>
      commutativeRing

definition IntegralDomain.ring (d : IntegralDomain) : Ring :=
  CommutativeRing.ring(IntegralDomain.commutativeRing(d))

definition IntegralDomain.carrier (d : IntegralDomain) : Type(0) :=
  Ring.carrier(IntegralDomain.ring(d))

definition IntegralDomain.commutative (d : IntegralDomain)
        : Ring.MultiplyCommutative(IntegralDomain.ring(d)) :=
  CommutativeRing.commutative(IntegralDomain.commutativeRing(d))

definition IntegralDomain.nontrivial (d : IntegralDomain)
        : Ring.one(IntegralDomain.ring(d))
              â‰  Ring.zero(IntegralDomain.ring(d)) :=
  cases d { | IntegralDomain.make(commutativeRing, nontrivial, noZeroDivisors) =>
    nontrivial }

definition IntegralDomain.no_zero_divisors (d : IntegralDomain)
        : Ring.HasNoZeroDivisors(IntegralDomain.ring(d)) :=
  cases d { | IntegralDomain.make(commutativeRing, nontrivial, noZeroDivisors) =>
    noZeroDivisors }

-- ----------------------------------------------------------------------
-- Difference-and-zero helpers over a plain ring.

-- aÂ·(x âˆ’ y) = aÂ·x âˆ’ aÂ·y. Distributivity on the left plus pushing the
-- negation through the product.
theorem Ring.multiply_difference_left (s : Ring) (a x y : Ring.carrier(s))
        : a * (x - y) = a * x - a * y :=
  calc a * (x - y)
     = a * x + a * (-y)
     = a * x + -(a * y)
     = a * x - a * y

-- If x âˆ’ y = 0 then x = y. A specialisation of the linear-combination
-- cancellation lemma (the trivial combination 0 = 0).
automatic theorem Ring.equal_of_difference_zero (s : Ring) (x y : Ring.carrier(s))
        (differenceZero : x - y = Ring.zero(s))
        : x = y := {
  IsRing(Ring.carrier(s), Ring.add, Ring.zero(s), Ring.negate, Ring.multiply, Ring.one(s));
  Ring.add(s, x, Ring.negate(s, y))
        = Ring.add(s, Ring.zero(s), Ring.negate(s, Ring.zero(s)));
  done by Ring.equal_of_linear_combination
}

-- ----------------------------------------------------------------------
-- Cancellation in a domain.

-- Left cancellation: a â‰  0 and aÂ·x = aÂ·y force x = y. From the equation,
-- aÂ·(x âˆ’ y) = 0; no zero divisors plus a â‰  0 give x âˆ’ y = 0, hence x = y.
theorem IntegralDomain.multiply_cancel_left (d : IntegralDomain)
        (a x y : Ring.carrier(IntegralDomain.ring(d)))
        (aNonzero : a â‰  Ring.zero(IntegralDomain.ring(d)))
        (equation : a * x = a * y)
        : x = y := {
  let s : Ring := IntegralDomain.ring(d);
  a * (x - y) = Ring.zero(s) as productDifferenceZero;
  a = Ring.zero(s) âˆ¨ (x - y) = Ring.zero(s)
      by IntegralDomain.no_zero_divisors(d, a, x - y, productDifferenceZero);
  done by cases {
    case a = Ring.zero(s) as aIsZero:
        absurd(aNonzero(aIsZero))
    case (x - y) = Ring.zero(s) as differenceZero:
        { done }
  }
}

-- ----------------------------------------------------------------------
-- Units.

-- A unit is an element that divides 1, i.e. has a multiplicative
-- inverse. Stated over a plain ring (no domain hypothesis needed).
definition Ring.IsUnit (s : Ring) (u : Ring.carrier(s)) : Proposition :=
  u âˆ£ Ring.one(s)

-- 1 is a unit (it divides itself).
theorem Ring.one_is_unit (s : Ring) : Ring.IsUnit(s, Ring.one(s)) :=
  { done by Ring.divides_reflexive }

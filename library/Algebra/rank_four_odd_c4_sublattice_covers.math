-- Algebra/rank_four_odd_c4_sublattice_covers.math
--
-- The two additional selected odd-C4 forms that contain already-covered
-- rank-four lattices at index two.  Together with the two pilots, this
-- discharges four determinant-seven forms without any converse for the
-- nonregular ternary parent.

module Algebra.rank_four_odd_c4_sublattice_covers

import Algebra.rank_four_odd_c4_sublattice_pilots
import Algebra.rank_four_weighted_d5_covers_chunk0
import Algebra.rank_four_weighted_d4_zero_c10

theorem Matrix.oddC4R1C3_represents_of_weightedD5S0R1C7
        (target : ℤ)
        (represented : Matrix.Represents(
          Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 0, 1, 7), target))
        : Matrix.Represents(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 1, 3), target) := {
  choose vector : RingVector(Integer.commutative_ring_bundle, 4) such that
      Matrix.quadraticForm(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 0, 1, 7), vector) = target
      as valueReads from represented;
  let x : ℤ := vector(NaturalsBelow.firstOfFour);
  let y : ℤ := vector(NaturalsBelow.secondOfFour);
  let z : ℤ := vector(NaturalsBelow.thirdOfFour);
  let w : ℤ := vector(NaturalsBelow.fourthOfFour);
  vector = (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4))
      by RingVector.eq_fourCoordinates(vector) as vectorReads;
  x * x + 2 * (y * y) + 5 * (z * z) + 2 * z * w + 7 * (w * w)
     = x * x + 2 * (y * y) + 5 * (z * z) + 2 * 0 * y * w + 2 * 1 * z * w + 7 * (w * w) by ring
     = Matrix.quadraticForm(
         Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 0, 1, 7),
         (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4)))
         by Equality.symmetry(
           Matrix.squarePlusDoublePlusScaledRankFourRepresentative_coordinateTuple_value(
             5, 0, 1, 7, x, y, z, w))
     = Matrix.quadraticForm(
         Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 0, 1, 7), vector)
         by substituting Equality.symmetry(vectorReads)
     = target by valueReads
  as donorValue;
  x * x + 2 * ((-y - z) * (-y - z)) + 2 * (-y - z) * (z + w) + 4 * ((z + w) * (z + w))
      + 2 * 1 * (-y - z) * (z - w) + 3 * ((z - w) * (z - w))
     = x * x + 2 * (y * y) + 5 * (z * z) + 2 * z * w + 7 * (w * w) by ring
     = target by donorValue
  as scalarComputation;
  done by Matrix.represents_by_witness(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 1, 3),
      target := target, vector := ⟨x, -y - z, z + w, z - w⟩,
      computes := Matrix.squarePlusDoubleSquareOddRankFourRepresentative_coordinateTuple_computes(
        scalarComputation := scalarComputation))
}

theorem Matrix.oddC4R1C3_universal_of_one_two_five_converse
        (converse : Matrix.OneTwoFiveConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 1, 3)) := {
  Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 0, 1, 7))
      by Matrix.weightedD5S0R1C7_universal_of_one_two_five_converse(converse) as donorUniversal;
  take m : ℕ;
  suppose m ≥ 1;
  done by Matrix.oddC4R1C3_represents_of_weightedD5S0R1C7(m, donorUniversal(m, done))
}

theorem Matrix.oddC4R3C8_represents_of_weightedD4S0R0C10
        (target : ℤ)
        (represented : Matrix.Represents(
          Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 0, 10), target))
        : Matrix.Represents(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 8), target) := {
  choose vector : RingVector(Integer.commutative_ring_bundle, 4) such that
      Matrix.quadraticForm(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 0, 10), vector) = target
      as valueReads from represented;
  let x : ℤ := vector(NaturalsBelow.firstOfFour);
  let y : ℤ := vector(NaturalsBelow.secondOfFour);
  let z : ℤ := vector(NaturalsBelow.thirdOfFour);
  let w : ℤ := vector(NaturalsBelow.fourthOfFour);
  vector = (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4))
      by RingVector.eq_fourCoordinates(vector) as vectorReads;
  x * x + 2 * (y * y) + 4 * (z * z) + 10 * (w * w)
     = x * x + 2 * (y * y) + 4 * (z * z) + 2 * 0 * y * w + 2 * 0 * z * w + 10 * (w * w) by ring
     = Matrix.quadraticForm(
         Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 0, 10),
         (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4)))
         by Equality.symmetry(
           Matrix.squarePlusDoublePlusScaledRankFourRepresentative_coordinateTuple_value(
             4, 0, 0, 10, x, y, z, w))
     = Matrix.quadraticForm(
         Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 0, 10), vector)
         by substituting Equality.symmetry(vectorReads)
     = target by valueReads
  as donorValue;
  x * x + 2 * ((-y - 2 * z - w) * (-y - 2 * z - w))
      + 2 * (-y - 2 * z - w) * (z - w) + 4 * ((z - w) * (z - w))
      + 2 * 3 * (-y - 2 * z - w) * (z + w) + 8 * ((z + w) * (z + w))
     = x * x + 2 * (y * y) + 4 * (z * z) + 10 * (w * w) by ring
     = target by donorValue
  as scalarComputation;
  done by Matrix.represents_by_witness(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 8),
      target := target, vector := ⟨x, -y - 2 * z - w, z - w, z + w⟩,
      computes := Matrix.squarePlusDoubleSquareOddRankFourRepresentative_coordinateTuple_computes(
        scalarComputation := scalarComputation))
}

theorem Matrix.oddC4R3C8_universal_of_three_squares_converse
        (converse : Matrix.ThreeSquaresConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 8)) := {
  Matrix.OneTwoFourConverse by Matrix.one_two_four_converse_of_three_squares(converse) as oneTwoFour;
  Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 0, 10))
      by Matrix.weightedD4S0R0C10_universal_of_one_two_four_converse(oneTwoFour) as donorUniversal;
  take m : ℕ;
  suppose m ≥ 1;
  done by Matrix.oddC4R3C8_represents_of_weightedD4S0R0C10(m, donorUniversal(m, done))
}

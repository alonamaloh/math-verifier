theorem Matrix.rankFourWeightedDiagonalD4_border_m1_p0_p3
        : Matrix.IsRankFourWeightedDiagonalD4NormalForm(Matrix.squarePlusDoublePlusScaledRankFourCandidate(4, 14, (-1), 0, 3)) := {
  ((-1) : ℤ) + (1 : ℤ) = 0 by ring as firstVanishes;
  (0 : ℤ) + 2 * (0 : ℤ) = (0 : ℤ) by ring as secondReduces;
  (3 : ℤ) + 4 * (0 : ℤ) = (3 : ℤ) by ring as thirdReduces;
  (14 : ℤ) + 2 * (((-1) : ℤ) * (1 : ℤ) + (0 : ℤ) * (0 : ℤ) + (3 : ℤ) * (0 : ℤ))
      + (1 : ℤ) * (1 : ℤ) + 2 * ((0 : ℤ) * (0 : ℤ)) + 4 * ((0 : ℤ) * (0 : ℤ)) = 13 by ring as cornerReduces;
  Matrix.IsIsometric(
      Matrix.squarePlusDoublePlusScaledRankFourCandidate(4, 14, (-1), 0, 3),
      Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 3, 13))
      by Matrix.squarePlusDoublePlusScaledRankFourCandidate_isometric_reduced(
        x := 1, y := 0, z := 0, secondResidue := 0, thirdResidue := 3, corner := 13,
        firstVanishes := firstVanishes, secondReduces := secondReduces,
        thirdReduces := thirdReduces, cornerReduces := cornerReduces)
  as reduced;
  -(3 : ℤ) + 4 * (1 : ℤ) = (1 : ℤ) by ring as thirdReflects;
  (13 : ℤ) + 2 * (-(3 : ℤ) * (1 : ℤ))
      + 4 * ((1 : ℤ) * (1 : ℤ)) = 11
      by ring as cornerReflects;
  Matrix.IsIsometric(
      Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 3, 13),
      Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 1, 11))
      by Matrix.squarePlusDoublePlusScaledRankFourRepresentative_isometric_reflected(
        z := 1, reflectedThird := 1, reflectedCorner := 11,
        thirdMoves := thirdReflects, cornerMoves := cornerReflects)
  as orbitReduction;
  Matrix.IsIsometric(
      Matrix.squarePlusDoublePlusScaledRankFourCandidate(4, 14, (-1), 0, 3),
      Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 1, 11))
      by Matrix.IsIsometric.transitive(leftIsometric := reduced, rightIsometric := orbitReduction)
  as canonicalized;
  done by disjunct(canonicalized)
}


-- Algebra/rank_four_odd_c4_r0_c6.math
--
-- A direct determinant-seven cover above
--
--   F₄(x,y,z) = x² + 2y² + 2yz + 4z².
--
-- The form Q=F₄+6w² contains x²+2y²+6w² at z=0.  The latter misses
-- exactly the one-two-six obstruction 4^a(8b+5).  At the base:
--
--   5  = Q(1,0,1,0),
--   13 = Q(3,0,1,0),
--
-- and, for b=t+2,
--
--   Q(x,y-1,2,z) = (x²+2y²+6z²) + 14.
--
-- Thus an admissible representation of 8t+7 supplies 8b+5.  Scaling
-- handles the power of four.

module Algebra.rank_four_odd_c4_r0_c6

import Algebra.rank_four_odd_c4_sublattice_covers
import Algebra.rank_four_weighted_d3_second_unit_universality
import Algebra.rank_four_odd_c5_cover

theorem Matrix.oddC4R0C6_base_obstruction_cover
        (converse : Matrix.OneTwoSixConverse)
        : ∀ (b : ℕ).
          Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 6),
            ((8 * b + 5 : ℕ) : ℤ)) := {
  take b : ℕ;
  b = 0 ∨ ∃ (predecessor : ℕ). b = 1 + predecessor by Natural.zero_or_one_plus;
  done by cases {
    case b = 0 as bZero: {
      1 * 1 + 2 * (0 * 0) + 2 * 0 * 1 + 4 * (1 * 1) + 2 * 0 * 0 * 0 + 6 * (0 * 0) = (5 : ℤ)
          as scalarComputation;
      Matrix.Represents(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 6), (5 : ℤ))
          by Matrix.represents_by_witness(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 6),
            target := 5, vector := ⟨1, 0, 1, 0⟩,
            computes := Matrix.squarePlusDoubleSquareOddRankFourRepresentative_coordinateTuple_computes(
              scalarComputation := scalarComputation));
      done by substituting Equality.symmetry(bZero)
    }
    case ∃ (predecessor : ℕ). b = 1 + predecessor: {
      choose predecessor : ℕ such that b = 1 + predecessor as bReads;
      predecessor = 0 ∨ ∃ (tail : ℕ). predecessor = 1 + tail by Natural.zero_or_one_plus;
      done by cases {
        case predecessor = 0 as predecessorZero: {
          3 * 3 + 2 * (0 * 0) + 2 * 0 * 1 + 4 * (1 * 1) + 2 * 0 * 0 * 0 + 6 * (0 * 0) = (13 : ℤ)
              as scalarComputation;
          Matrix.Represents(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 6), (13 : ℤ))
              by Matrix.represents_by_witness(
                Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 6),
                target := 13, vector := ⟨3, 0, 1, 0⟩,
                computes := Matrix.squarePlusDoubleSquareOddRankFourRepresentative_coordinateTuple_computes(
                  scalarComputation := scalarComputation));
          8 * b + 5
             = 8 * (1 + predecessor) + 5 by substituting bReads
             = 8 * (1 + 0) + 5 by substituting predecessorZero
             = 13 by ring
          as targetReads;
          done by substituting Equality.symmetry(targetReads)
        }
        case ∃ (tail : ℕ). predecessor = 1 + tail: {
          choose tail : ℕ such that predecessor = 1 + tail as predecessorReads;
          ¬(Natural.IsOneTwoSixObstruction(8 * tail + 7))
              by Natural.eight_times_plus_nonzero_mod_four_nonfive_not_one_two_six_obstruction(
                tail, 7, 1, 3, done, done, done, done, done)
              as admissible;
          Matrix.Represents(Matrix.squarePlusDoublePlusScaledSquareForm(6), ((8 * tail + 7 : ℕ) : ℤ))
              by converse(8 * tail + 7, admissible) as represented;
          choose vector : RingVector(Integer.commutative_ring_bundle, 3) such that
              Matrix.quadraticForm(Matrix.squarePlusDoublePlusScaledSquareForm(6), vector)
                = ((8 * tail + 7 : ℕ) : ℤ)
              as valueReads from represented;
          let x : ℤ := vector(NaturalsBelow.inclusion(2, NaturalsBelow.firstOfTwo));
          let y : ℤ := vector(NaturalsBelow.inclusion(2, NaturalsBelow.secondOfTwo));
          let z : ℤ := vector(NaturalsBelow.top(2));
          vector = (⟨x, y, z⟩ : RingVector(Integer.commutative_ring_bundle, 3))
              by RingVector.eq_threeCoordinates(vector) as vectorReads;
          x * x + 2 * (y * y) + 6 * (z * z)
             = Matrix.quadraticForm(Matrix.squarePlusDoublePlusScaledSquareForm(6), ⟨x, y, z⟩)
                 by Equality.symmetry(
                   Matrix.squarePlusDoublePlusScaledSquareForm_coordinateTuple_value(6, x, y, z))
             = Matrix.quadraticForm(Matrix.squarePlusDoublePlusScaledSquareForm(6), vector)
                 by substituting Equality.symmetry(vectorReads)
             = ((8 * tail + 7 : ℕ) : ℤ) by valueReads
          as residualValue;
          (8 * tail + 7) + 14 = 8 * (2 + tail) + 5 by ring as naturalTargetReads;
          ((8 * tail + 7 : ℕ) : ℤ) + 14
             = ((8 * tail + 7 : ℕ) : ℤ) + (14 : ℤ)
             = (((8 * tail + 7) + 14 : ℕ) : ℤ)
                 by Equality.symmetry(Natural.to_integer.add_preserves(8 * tail + 7, 14))
             = ((8 * (2 + tail) + 5 : ℕ) : ℤ) by substituting naturalTargetReads
          as integerTargetReads;
          x * x + 2 * ((y - 1) * (y - 1)) + 2 * (y - 1) * 2 + 4 * (2 * 2)
              + 2 * 0 * (y - 1) * z + 6 * (z * z)
             = x * x + 2 * (y * y) + 6 * (z * z) + 14 by ring
             = ((8 * tail + 7 : ℕ) : ℤ) + 14 by substituting residualValue
             = ((8 * (2 + tail) + 5 : ℕ) : ℤ) by integerTargetReads
          as scalarComputation;
          Matrix.Represents(
              Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 6),
              ((8 * (2 + tail) + 5 : ℕ) : ℤ))
              by Matrix.represents_by_witness(
                Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 6),
                target := ((8 * (2 + tail) + 5 : ℕ) : ℤ), vector := ⟨x, y - 1, 2, z⟩,
                computes := Matrix.squarePlusDoubleSquareOddRankFourRepresentative_coordinateTuple_computes(
                  scalarComputation := scalarComputation));
          8 * b + 5
             = 8 * (1 + predecessor) + 5 by substituting bReads
             = 8 * (1 + (1 + tail)) + 5 by substituting predecessorReads
             = 8 * (2 + tail) + 5 by ring
          as targetReads;
          done by substituting Equality.symmetry(targetReads)
        }
      }
    }
  }
}

theorem Matrix.oddC4R0C6_universal_of_one_two_six_converse
        (converse : Matrix.OneTwoSixConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 6)) := {
  let A : Matrix(Integer.commutative_ring_bundle, 4, 4) :=
    Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 6);
  take m : ℕ;
  suppose m ≥ 1;
  Natural.IsOneTwoSixObstruction(m) ∨ ¬(Natural.IsOneTwoSixObstruction(m))
      by Logic.excluded_middle(Natural.IsOneTwoSixObstruction(m)) as obstructionDecision;
  ¬(Natural.IsOneTwoSixObstruction(m)) ∨ Natural.IsOneTwoSixObstruction(m)
      by Or.swap(obstructionDecision);
  done by cases {
    case ¬(Natural.IsOneTwoSixObstruction(m)) as admissible: {
      Matrix.Represents(Matrix.squarePlusDoublePlusScaledSquareForm(6), (m : ℤ))
          by converse(m, admissible) as represented;
      choose vector : RingVector(Integer.commutative_ring_bundle, 3) such that
          Matrix.quadraticForm(Matrix.squarePlusDoublePlusScaledSquareForm(6), vector) = (m : ℤ)
          as valueReads from represented;
      let x : ℤ := vector(NaturalsBelow.inclusion(2, NaturalsBelow.firstOfTwo));
      let y : ℤ := vector(NaturalsBelow.inclusion(2, NaturalsBelow.secondOfTwo));
      let z : ℤ := vector(NaturalsBelow.top(2));
      vector = (⟨x, y, z⟩ : RingVector(Integer.commutative_ring_bundle, 3))
          by RingVector.eq_threeCoordinates(vector) as vectorReads;
      x * x + 2 * (y * y) + 6 * (z * z)
         = Matrix.quadraticForm(Matrix.squarePlusDoublePlusScaledSquareForm(6), ⟨x, y, z⟩)
             by Equality.symmetry(
               Matrix.squarePlusDoublePlusScaledSquareForm_coordinateTuple_value(6, x, y, z))
         = Matrix.quadraticForm(Matrix.squarePlusDoublePlusScaledSquareForm(6), vector)
             by substituting Equality.symmetry(vectorReads)
         = (m : ℤ) by valueReads
      as donorValue;
      x * x + 2 * (y * y) + 2 * y * 0 + 4 * (0 * 0) + 2 * 0 * y * z + 6 * (z * z)
         = x * x + 2 * (y * y) + 6 * (z * z) by ring
         = (m : ℤ) by donorValue
      as scalarComputation;
      done by Matrix.represents_by_witness(
          A, target := m, vector := ⟨x, y, 0, z⟩,
          computes := Matrix.squarePlusDoubleSquareOddRankFourRepresentative_coordinateTuple_computes(
            scalarComputation := scalarComputation))
    }
    case Natural.IsOneTwoSixObstruction(m) as obstruction: {
      choose exponent : ℕ, b : ℕ such that m = 4 ^ exponent * (8 * b + 5)
          as mReads from obstruction;
      Matrix.Represents(A, ((8 * b + 5 : ℕ) : ℤ))
          by Matrix.oddC4R0C6_base_obstruction_cover(converse, b) as baseRepresented;
      Matrix.Represents(A, ((4 ^ exponent * (8 * b + 5) : ℕ) : ℤ))
          by Matrix.represents_four_power_times(A, 8 * b + 5, exponent, baseRepresented);
      Matrix.Represents(A, (m : ℤ)) by substituting mReads;
      done
    }
  }
}

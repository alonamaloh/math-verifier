        : Matrix.IsRankFourWeightedDiagonalD4NormalForm(Matrix.squarePlusDoublePlusScaledRankFourCandidate(4, 14, 3, 5, 5)) := {
  8 * ((3 : ℤ) * (3 : ℤ)) + 4 * ((5 : ℤ) * (5 : ℤ)) + 2 * ((5 : ℤ) * (5 : ℤ)) = 222 by ring as valueReads;
  (222 : ℤ) < 112 by substituting valueReads;
  (112 : ℤ) ≤ 222;
  (222 : ℤ) < 222;
  (222 : ℕ) < 222 by Natural.to_integer.LessThan_reflects;
  False by Natural.lt_irreflexive;
  done
}


    2 * 2 + 2 * (0 * 0) + 5 * (0 * 0) + 2 * 0 * 0 * 1 + 2 * 2 * 0 * 1 + 8 * (1 * 1) = (12 : ÔäĄ) as scalarComputation;
    Matrix.represents_by_witness(A, target := 12, vector := ÔčĘ2, 0, 0, 1Ôčę,

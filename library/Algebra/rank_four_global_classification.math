-- Algebra/rank_four_global_classification.math
--
-- The exact global rank-four cover.  Parent isometries are transported before
-- the finite branch classifiers run; their 276 historical outputs are then
-- merged through 69 checked congruences into 207 selected normal forms.

module Algebra.rank_four_global_classification

import Algebra.rank_four_classification_transport
import Algebra.rank_three_global_classification
import Algebra.rank_four_global_branch_coverage_generated

theorem Matrix.escalator_rank_four
        (B : Matrix(Integer.commutative_ring_bundle, 1 + 3, 1 + 3))
        (escalator : Matrix.IsEscalator(1 + 3, B))
        : Matrix.IsRankFourEscalatorRepresentative(B) := {
  choose parent such that Matrix.IsEscalator(3, parent) ∧ Matrix.IsEscalation(parent, B)
      from Matrix.escalator_split(B := B, escalator := escalator);
  Matrix.IsEscalator(3, parent)
      by And.left(Matrix.IsEscalator(3, parent), Matrix.IsEscalation(parent, B))
  as parentEscalator;
  Matrix.IsEscalation(parent, B)
      by And.right(Matrix.IsEscalator(3, parent), Matrix.IsEscalation(parent, B))
  as escalation;
  Matrix.IsRankThreeEscalatorRepresentative(parent)
      by Matrix.escalator_rank_three(escalator := parentEscalator);
  done by cases {
    case Matrix.IsIsometric(parent, Matrix.sumOfThreeSquaresForm) as parentIsometric:
      done by Matrix.rankFourRepresentative_of_parent_isometry(
        Branch := Matrix.IsSumOfThreeSquaresRankFourPilotRepresentative,
        escalation := escalation, parentIsometric := parentIsometric,
        classify := Matrix.sumOfThreeSquaresRankFourEscalation_classified,
        include := Matrix.sumOfThreeSquaresRankFourPilotRepresentative_is_global)
    case Matrix.IsIsometric(parent, Matrix.sumOfTwoSquaresPlusTripleSquareForm) as parentIsometric:
      done by Matrix.rankFourRepresentative_of_parent_isometry(
        Branch := Matrix.IsSumOfTwoSquaresPlusTripleSquareRankFourSignedNormalForm,
        escalation := escalation, parentIsometric := parentIsometric,
        classify := Matrix.sumOfTwoSquaresPlusTripleSquareRankFourEscalation_classified,
        include := Matrix.sumOfTwoSquaresPlusTripleSquareRankFourNormalForm_is_global)
    case Matrix.IsIsometric(parent, Matrix.sumOfTwoSquaresPlusDoubleSquareForm) as parentIsometric:
      done by Matrix.rankFourRepresentative_of_parent_isometry(
        Branch := Matrix.IsSumOfTwoSquaresPlusDoubleSquareRankFourTopShearNormalForm,
        escalation := escalation, parentIsometric := parentIsometric,
        classify := Matrix.sumOfTwoSquaresPlusDoubleSquareRankFourEscalation_classified,
        include := Matrix.sumOfTwoSquaresPlusDoubleSquareRankFourNormalForm_is_global)
    case Matrix.IsIsometric(parent, Matrix.squarePlusDoubleSquareDiagonalForm(2)) as parentIsometric:
      done by Matrix.rankFourRepresentative_of_parent_isometry(
        Branch := Matrix.IsRankFourWeightedDiagonalD2NormalForm,
        escalation := escalation, parentIsometric := parentIsometric,
        classify := Matrix.squarePlusDoubleSquareDiagonalForm_two_rankFourEscalation_classified,
        include := Matrix.rankFourWeightedDiagonalD2NormalForm_is_global)
    case Matrix.IsIsometric(parent, Matrix.squarePlusDoubleSquareDiagonalForm(3)) as parentIsometric:
      done by Matrix.rankFourRepresentative_of_parent_isometry(
        Branch := Matrix.IsRankFourWeightedDiagonalD3NormalForm,
        escalation := escalation, parentIsometric := parentIsometric,
        classify := Matrix.squarePlusDoubleSquareDiagonalForm_three_rankFourEscalation_classified,
        include := Matrix.rankFourWeightedDiagonalD3NormalForm_is_global)
    case Matrix.IsIsometric(parent, Matrix.squarePlusDoubleSquareDiagonalForm(4)) as parentIsometric:
      done by Matrix.rankFourRepresentative_of_parent_isometry(
        Branch := Matrix.IsRankFourWeightedDiagonalD4NormalForm,
        escalation := escalation, parentIsometric := parentIsometric,
        classify := Matrix.squarePlusDoubleSquareDiagonalForm_four_rankFourEscalation_classified,
        include := Matrix.rankFourWeightedDiagonalD4NormalForm_is_global)
    case Matrix.IsIsometric(parent, Matrix.squarePlusDoubleSquareDiagonalForm(5)) as parentIsometric:
      done by Matrix.rankFourRepresentative_of_parent_isometry(
        Branch := Matrix.IsRankFourWeightedDiagonalD5NormalForm,
        escalation := escalation, parentIsometric := parentIsometric,
        classify := Matrix.squarePlusDoubleSquareDiagonalForm_five_rankFourEscalation_classified,
        include := Matrix.rankFourWeightedDiagonalD5NormalForm_is_global)
    case Matrix.IsIsometric(parent, Matrix.squarePlusDoubleSquareOddForm(4)) as parentIsometric:
      done by Matrix.rankFourRepresentative_of_parent_isometry(
        Branch := Matrix.IsRankFourOddDiagonalC4NormalForm,
        escalation := escalation, parentIsometric := parentIsometric,
        classify := Matrix.squarePlusDoubleSquareOddForm_four_rankFourEscalation_classified,
        include := Matrix.rankFourOddDiagonalC4NormalForm_is_global)
    case Matrix.IsIsometric(parent, Matrix.squarePlusDoubleSquareOddForm(5)) as parentIsometric:
      done by Matrix.rankFourRepresentative_of_parent_isometry(
        Branch := Matrix.IsRankFourOddDiagonalC5NormalForm,
        escalation := escalation, parentIsometric := parentIsometric,
        classify := Matrix.squarePlusDoubleSquareOddForm_five_rankFourEscalation_classified,
        include := Matrix.rankFourOddDiagonalC5NormalForm_is_global)
  }
}

-- Algebra/integer_euclidean.math
--
-- ℤ as a Euclidean domain (norm = absolute value into ℕ), hence a PID.
--
-- Division with remainder is reduced to Natural division by the absolute
-- value of the divisor. For a NONNEGATIVE dividend that is immediate; for
-- a negative dividend with a nonzero Natural remainder `rn`, the
-- remainder is adjusted to `m − rn` and the quotient decremented (the
-- usual "round toward −∞" fix). The sign of the divisor flips the
-- quotient. All the integer algebra is `ring`; the remainder-size bound
-- rides on the Natural division's `r < divisor`.

module Algebra.integer_euclidean

import axioms
import Logic.basics
import Logic.exists
import Logic.sum
import Equality.basics
import Natural.basics
import Natural.classical_decidable
import Natural.peano
import Natural.order
import Natural.subtraction
import Natural.factorization
import Natural.division
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.instances
import Integer.embedding
import Integer.order
import Integer.sign
import Integer.absolute_value
import Integer.absolute_value_natural
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.integral_domain
import Algebra.principal_ideal_domain
import Algebra.euclidean_domain
import Algebra.integer_domain

-- ----------------------------------------------------------------------
-- Natural-absolute-value of casts.

theorem Integer.absolute_value_natural_of_natural (k : ℕ)
        : Integer.absolute_value_natural((k : ℤ)) = k :=
  { done by Natural.to_integer.injective }

theorem Integer.absolute_value_natural_of_negate_natural (k : ℕ)
        : Integer.absolute_value_natural(-(k : ℤ)) = k :=
  { done by Natural.to_integer.injective }

-- ----------------------------------------------------------------------
-- Helper: 1 ≤ m when its cast (or negated cast) is a nonzero integer.

theorem Integer.positive_natural_of_image_nonzero (m : ℕ)
        (imageNonzero : ¬((m : ℤ) = Integer.zero))
        : 1 ≤ m := {
  m = 0 ∨ 1 ≤ m by Natural.is_zero_or_at_least_one;
  done by cases {
    case m = 0 as mZero: {
        (m : ℤ)
           = Natural.to_integer(0)
           = Integer.zero;
        done
      }
    case 1 ≤ m as positive:
        positive
  }
}

-- ----------------------------------------------------------------------
-- Division of any integer by a positive Natural modulus.

theorem Integer.divide_by_positive (a : ℤ) (m : ℕ) (mPositive : 1 ≤ m)
        : ∃ (quotient : ℤ). ∃ (remainder : ℕ).
            a = (m : ℤ) * quotient + (remainder : ℤ)
            ∧ remainder < m := {
  Integer.IsNonneg(a) ∨ ∃ (k : ℕ). a = -(k : ℤ) by Integer.sign_split;
  done by cases {
    case Integer.IsNonneg(a) as aNonneg: {
        choose j such that a = (j : ℤ) from aNonneg;
        choose naturalQuotient, naturalRemainder such that
            j = naturalQuotient * m + naturalRemainder ∧ naturalRemainder < m
            from Natural.divide_with_remainder(m, mPositive, j);
        (j : ℤ)
                  = ((naturalQuotient * m + naturalRemainder : ℕ) : ℤ)
                  = ((naturalQuotient * m : ℕ) : ℤ) + (naturalRemainder : ℤ)
                  = (naturalQuotient : ℤ) * (m : ℤ) + (naturalRemainder : ℤ)
                  = (m : ℤ) * (naturalQuotient : ℤ) + (naturalRemainder : ℤ);
        naturalRemainder < m as remainderLessThanM;
        ⟨(naturalQuotient : ℤ), naturalRemainder,
         ⟨{ a
             = (j : ℤ)
             = (m : ℤ) * (naturalQuotient : ℤ) + (naturalRemainder : ℤ) },
          remainderLessThanM⟩⟩
      }
    case ∃ (k : ℕ). a = -(k : ℤ) as aNegative: {
        choose j such that a = -(j : ℤ) from aNegative;
        choose naturalQuotient, naturalRemainder such that
            j = naturalQuotient * m + naturalRemainder ∧ naturalRemainder < m
            from Natural.divide_with_remainder(m, mPositive, j);
        (j : ℤ)
                  = ((naturalQuotient * m + naturalRemainder : ℕ) : ℤ)
                  = ((naturalQuotient * m : ℕ) : ℤ) + (naturalRemainder : ℤ)
                  = (naturalQuotient : ℤ) * (m : ℤ) + (naturalRemainder : ℤ)
                  = (m : ℤ) * (naturalQuotient : ℤ) + (naturalRemainder : ℤ);
        done by cases {
          case naturalRemainder = 0 as remainderZero: {
              -- a = −(naturalQuotient·m) = m·(−naturalQuotient) + 0.
              (0 : ℕ) < m as zeroBelowM;
              ⟨-(naturalQuotient : ℤ), 0,
               ⟨{ a
                   = -(j : ℤ)
                   = -((m : ℤ) * (naturalQuotient : ℤ)
                         + (naturalRemainder : ℤ))
                   = -((m : ℤ) * (naturalQuotient : ℤ) + (0 : ℤ))
                         by remainderZero
                   = (m : ℤ) * (-(naturalQuotient : ℤ)) + (0 : ℤ) },
                zeroBelowM⟩⟩
            }
          otherwise as remainderNonzero: {
              naturalRemainder ≤ m as remainderAtMostM;
              choose gap such that m = naturalRemainder + gap
                  from Natural.subtraction_witness(naturalRemainder, m,
                           remainderAtMostM);
              1 ≤ naturalRemainder;
              (m : ℤ) = (naturalRemainder : ℤ) + (gap : ℤ);
              (gap : ℤ)
                    = (m : ℤ) + (-(naturalRemainder : ℤ));
              gap
                        < gap + naturalRemainder
                              by Natural.lt_add_of_one_le
                        = naturalRemainder + gap
                        = m as gapBelowM;
              ⟨-((naturalQuotient : ℤ) + Integer.one),
               gap,
               ⟨{ a
                   = -(j : ℤ)
                   = -((m : ℤ) * (naturalQuotient : ℤ)
                         + (naturalRemainder : ℤ))
                   = (m : ℤ) * (-((naturalQuotient : ℤ) + Integer.one))
                         + ((m : ℤ) + (-(naturalRemainder : ℤ)))
                   = (m : ℤ) * (-((naturalQuotient : ℤ) + Integer.one))
                         + (gap : ℤ) },
                gapBelowM⟩⟩
            }
        }
      }
  }
}

-- ----------------------------------------------------------------------
-- Division with remainder for ℤ, bounded by |divisor|.

theorem Integer.has_euclidean_division (a b : ℤ)
        (bNonzero : ¬(b = Integer.zero))
        : ∃ (quotient : ℤ). ∃ (remainder : ℤ).
            a = b * quotient + remainder
            ∧ (remainder = Integer.zero
               ∨ Integer.absolute_value_natural(remainder)
                 < Integer.absolute_value_natural(b)) := {
  Integer.IsNonneg(b) ∨ ∃ (k : ℕ). b = -(k : ℤ) by Integer.sign_split;
  done by cases {
    case Integer.IsNonneg(b) as bNonneg: {
        choose m such that b = (m : ℤ) as bIsImage from bNonneg;
        ¬((m : ℤ) = Integer.zero)
            by (mImageZero : (m : ℤ) = Integer.zero) ↦
                 bNonzero({ b = (m : ℤ)
                                 = Integer.zero });
        1 ≤ m as mPositive;
        choose quotient, remainder such that
            a = (m : ℤ) * quotient + (remainder : ℤ) ∧ remainder < m
            from Integer.divide_by_positive(a, m, mPositive);
        a = (m : ℤ) * quotient + (remainder : ℤ) as aEquation;
        remainder < m as remainderBelow;
        Integer.absolute_value_natural((remainder : ℤ))
            = remainder                                        by Integer.absolute_value_natural_of_natural
            < m                                                by remainderBelow
            = Integer.absolute_value_natural((m : ℤ))
            = Integer.absolute_value_natural(b) as remainderNormBelow;
        ⟨quotient, (remainder : ℤ),
         ⟨{ a
             = (m : ℤ) * quotient + (remainder : ℤ)
                   by aEquation
             = b * quotient + (remainder : ℤ) by bIsImage },
          Or.introduceRight(remainderNormBelow)⟩⟩
      }
    case ∃ (k : ℕ). b = -(k : ℤ) as bNegative: {
        choose m such that b = -(m : ℤ) as bIsNegativeImage from bNegative;
        ¬((m : ℤ) = Integer.zero)
            by (mImageZero : (m : ℤ) = Integer.zero) ↦
                 bNonzero({ b = -(m : ℤ)
                                 = -(Integer.zero) by mImageZero
                                 = Integer.zero });
        1 ≤ m as mPositive;
        choose quotient, remainder such that
            a = (m : ℤ) * quotient + (remainder : ℤ) ∧ remainder < m
            from Integer.divide_by_positive(a, m, mPositive);
        a = (m : ℤ) * quotient + (remainder : ℤ) as aEquation;
        remainder < m as remainderBelow;
        Integer.absolute_value_natural((remainder : ℤ))
            = remainder                                        by Integer.absolute_value_natural_of_natural
            < m                                                by remainderBelow
            = Integer.absolute_value_natural(-(m : ℤ))
            = Integer.absolute_value_natural(b) as remainderNormBelow;
        ⟨-quotient, (remainder : ℤ),
         ⟨{ a
             = (m : ℤ) * quotient + (remainder : ℤ)
                   by aEquation
             = (-(m : ℤ)) * (-quotient) + (remainder : ℤ)
                   by ring
             = b * (-quotient) + (remainder : ℤ) by bIsNegativeImage },
          Or.introduceRight(remainderNormBelow)⟩⟩
      }
  }
}

-- ----------------------------------------------------------------------
-- ℤ is a Euclidean domain, hence a principal ideal domain.

theorem Integer.euclidean_division
        : Ring.HasEuclideanDivision(Integer.ring_bundle,
              Integer.absolute_value_natural) :=
  Integer.has_euclidean_division

definition Integer.euclidean_domain : EuclideanDomain :=
  EuclideanDomain.make(Integer.integral_domain,
      Integer.absolute_value_natural, Integer.euclidean_division)

definition Integer.principal_ideal_domain : PrincipalIdealDomain :=
  EuclideanDomain.to_principal_ideal_domain(Integer.euclidean_domain)

  (14 : ℤ) * 14 + 2 * ((-1 : ℤ) * (-1 : ℤ)) + 2 * (-1 : ℤ) * (-2 : ℤ) + 4 * ((-2 : ℤ) * (-2 : ℤ)) + 2 * 3 * (-1 : ℤ) * (-1 : ℤ) + 11 * ((-1 : ℤ) * (-1 : ℤ)) = (235 : ℤ) as scalarComputation;

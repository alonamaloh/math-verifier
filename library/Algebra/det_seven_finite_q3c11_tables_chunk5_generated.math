theorem Matrix.detSevenFiniteQ3C11A235T1
        (n : ℕ) (positive : n ≥ 1)
        (bounded : n ≤ 287)
        (remainderReads : Natural.modulo(n, 588) = 235)
        : Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 11),
            (n : ℤ)) := {
  let q : ℕ := Natural.floor_divide(n, 588);
  588 * q + Natural.modulo(n, 588) = n
      by Natural.floor_divide_modulo_decompose;
  588 * q + 235 = n by substituting remainderReads as exactDecomposition;
  q < 1 by Natural.quotient_below_of_bounded_decomposition(
    588, q, 235, n, 287, 1, done, exactDecomposition, bounded)
  as qBelow;
  Matrix.Represents(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 11),
      (588 : ℤ) * (q : ℤ) + (235 : ℤ)) by {
  done by Matrix.detSevenFiniteQ3C11A235T1_part0(q, done, qBelow)
  };
  (588 : ℤ) * (q : ℤ) + (235 : ℤ)
     = ((588 * q : ℕ) : ℤ) + (235 : ℤ)
         by substituting Equality.symmetry(Natural.to_integer.multiply_preserves(588, q))
     = ((588 * q + 235 : ℕ) : ℤ)
         by Equality.symmetry(Natural.to_integer.add_preserves(588 * q, 235))
     = (n : ℤ) by substituting exactDecomposition
  as integerDecomposition;
  done by substituting integerDecomposition
}

module Algebra.rank_four_weighted_d3_third_unit_c10

import Algebra.rank_four_weighted_d3_third_unit_universality

theorem Matrix.weightedD3S0R1C10_universal_of_one_three_six_converse (converse : Matrix.OneThreeSixLocalConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 0, 1, 10)) := {
  3 * 10 = 29 + 1 by ring as coefficientShape;
  3 * 10 ∸ 1 = 29 by Natural.three_times_monus_one_value(10, 29, coefficientShape) as naturalCoefficientReads;
  ((3 * 10 ∸ 1 : ℕ) : ℤ) = 3 * (10 : ℤ) - 1
      by Natural.three_times_monus_one_to_integer(10, 29, coefficientShape) as coefficientReads;
  27 + (3 * 10 ∸ 1) = 27 + 29 by substituting naturalCoefficientReads = 56 by ring as halfCoreSum;
  1 + (3 * 10 ∸ 1) = 1 + 29 by substituting naturalCoefficientReads = 30 by ring as baseCoreSum;
  11 = 4 * 2 + 3 by ring as elevenShape;
  3 + (1 + 0) = 4 by ring as threeBelowFourReads;
  3 < 4 by Natural.lt_intro(3, 4, 0, threeBelowFourReads) as threeBelowFour;
  0 + (1 + 2) = 3 by ring as threePositiveReads;
  0 < 3 by Natural.lt_intro(0, 3, 2, threePositiveReads) as threePositive;
  3 ≠ 0 by Natural.not_equal_of_greater_than(3, 0, threePositive) as threeNonzero;
  11 + (1 + 4) = 16 by ring as elevenBelowSixteenReads;
  11 < 16 by Natural.lt_intro(11, 16, 4, elevenBelowSixteenReads) as elevenBelowSixteen;
  11 + (1 + 2) = 14 by ring as elevenBelowFourteenReads;
  11 < 14 by Natural.lt_intro(11, 14, 2, elevenBelowFourteenReads) as elevenBelowFourteen;
  11 ≠ 14 by Natural.not_equal_of_less_than(11, 14, elevenBelowFourteen) as elevenNotFourteen;
  1 = 4 * 0 + 1 by ring as oneShape;
  1 + (1 + 2) = 4 by ring as oneBelowFourReads;
  1 < 4 by Natural.lt_intro(1, 4, 2, oneBelowFourReads) as oneBelowFour;
  0 + (1 + 0) = 1 by ring as onePositiveReads;
  0 < 1 by Natural.lt_intro(0, 1, 0, onePositiveReads) as onePositive;
  1 ≠ 0 by Natural.not_equal_of_greater_than(1, 0, onePositive) as oneNonzero;
  1 + (1 + 14) = 16 by ring as oneBelowSixteenReads;
  1 < 16 by Natural.lt_intro(1, 16, 14, oneBelowSixteenReads) as oneBelowSixteen;
  1 + (1 + 12) = 14 by ring as oneBelowFourteenReads;
  1 < 14 by Natural.lt_intro(1, 14, 12, oneBelowFourteenReads) as oneBelowFourteen;
  1 ≠ 14 by Natural.not_equal_of_less_than(1, 14, oneBelowFourteen) as oneNotFourteen;
  Matrix.OneThreeSixTripleTargetCover(10)
      by Matrix.oneThreeSixTripleTargetCover_half_scale_of_local_converse(
          converse, corner := 10, halfCore := 27, baseCore := 1,
          coefficientReads := coefficientReads, halfCoreSum := halfCoreSum, baseCoreSum := baseCoreSum,
          halfAdmissible := (exponent b : ℕ) ↦ {
            4 ^ exponent * (64 * b + 27) = 4 ^ exponent * (16 * (4 * b + 1) + 11) by ring as valueReads;
            suppose Natural.IsOneThreeSixFourObstruction(4 ^ exponent * (64 * b + 27)) as obstruction;
            Natural.IsOneThreeSixFourObstruction(4 ^ exponent * (16 * (4 * b + 1) + 11))
                by substituting valueReads as transformedObstruction;
            done by Natural.four_power_times_nonzero_mod_four_core_not_one_three_six_four_obstruction(
                exponent, 4 * b + 1, 11, 2, 3, elevenShape,
                threeBelowFour, threeNonzero, elevenBelowSixteen, elevenNotFourteen)(transformedObstruction)
          },
          baseAdmissible := (b : ℕ) ↦ {
            4 ^ 0 * (16 * b + 1) = 16 * b + 1 by substituting Natural.power_zero(4) as valueReads;
            suppose Natural.IsOneThreeSixFourObstruction(16 * b + 1) as obstruction;
            Natural.IsOneThreeSixFourObstruction(4 ^ 0 * (16 * b + 1))
                by substituting Equality.symmetry(valueReads) as transformedObstruction;
            done by Natural.four_power_times_nonzero_mod_four_core_not_one_three_six_four_obstruction(
                0, b, 1, 0, 1, oneShape,
                oneBelowFour, oneNonzero, oneBelowSixteen, oneNotFourteen)(transformedObstruction)
          })
      as cover;
  done by Matrix.weightedD3ThirdUnit_universal_of_cover(10, coefficientReads, cover)
}

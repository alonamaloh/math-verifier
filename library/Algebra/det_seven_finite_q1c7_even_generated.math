theorem Matrix.detSevenEvenFiniteCover_q1c7
        (n : ℕ) (bounded : n ≤ 90) (even : Natural.modulo(n, 2) = 0)
        : Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 1, 7),
            (n : ℤ)) := {
  let q : ℕ := Natural.floor_divide(n, 2);
  2 * q + Natural.modulo(n, 2) = n by Natural.floor_divide_modulo_decompose;
  2 * q + 0 = n by substituting even as exactDecomposition;
  q < 46 by Natural.quotient_below_of_bounded_decomposition(
    2, q, 0, n, 90, 46, done, exactDecomposition, bounded)
  as qBelow;
  Matrix.Represents(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 1, 7),
      (2 : ℤ) * (q : ℤ)) by {
  q < 20 ∨ 20 ≤ q by Natural.lt_or_le;
  done by cases {
    case q < 20 as below20:
      done by Matrix.detSevenFiniteQ1C7Even_part0(q, done, below20)
    case 20 ≤ q as atLeast20: {
      q < 40 ∨ 40 ≤ q by Natural.lt_or_le;
      done by cases {
        case q < 40 as below40:
          done by Matrix.detSevenFiniteQ1C7Even_part1(q, atLeast20, below40)
        case 40 ≤ q as atLeast40: {
          done by Matrix.detSevenFiniteQ1C7Even_part2(q, atLeast40, qBelow)
        }
      }
    }
  }
  };
  (2 : ℤ) * (q : ℤ)
     = ((2 * q : ℕ) : ℤ) by Equality.symmetry(Natural.to_integer.multiply_preserves(2, q))
     = (n : ℤ) by substituting exactDecomposition;
  done
}

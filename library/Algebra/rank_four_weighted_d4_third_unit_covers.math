-- Algebra/rank_four_weighted_d4_third_unit_covers.math
--
-- The eleven selected forms x²+2y²+4z²+2zw+cw², 4 ≤ c ≤ 14.

module Algebra.rank_four_weighted_d4_third_unit_covers

import Algebra.rank_four_weighted_d4_coset_cover

theorem Matrix.weightedD4ThirdUnit_universal_selected_core_of_converse
        (converse : Matrix.OneTwoFourConverse)
        (corner coefficient shift core quarter : ℕ)
        (coefficientReads : (coefficient : ℤ) = 4 * (corner : ℤ) - 1)
        (completionReads : 16 * shift + core + coefficient = 56)
        (coreReads : core = 4 * quarter + 1) (coreBelow : core < 16) (coreNotFourteen : core ≠ 14)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(
            4, 0, 1, (corner : ℤ))) :=
  by Matrix.weightedD4_universal_of_base_coset(
      converse, secondResidue := 0, thirdResidue := 1, corner := corner,
      coefficient := coefficient, shift := shift, core := core,
      coefficientReads := {
        (coefficient : ℤ)
           = 4 * (corner : ℤ) - 1 by coefficientReads
           = 4 * (corner : ℤ) - 2 * (0 : ℤ) * (0 : ℤ) - (1 : ℤ) * (1 : ℤ) by ring
      },
      completionReads := completionReads,
      baseControl := Matrix.oneTwoFour_one_zero_base_coset_of_converse(
          converse, core, quarter, coreReads,
          coreAdmissible := (b : ℕ) ↦
            Natural.sixteen_plus_nonzero_mod_four_core_not_one_three_six_four_obstruction(
                b, core, quarter, 1, coreReads, done, done, coreBelow, coreNotFourteen)))

theorem Matrix.weightedD4S0R1C4_universal_of_one_two_four_converse (converse : Matrix.OneTwoFourConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 1, 4)) :=
  by Matrix.weightedD4ThirdUnit_universal_selected_core_of_converse(
      converse, corner := 4, coefficient := 15, shift := 2, core := 9, quarter := 2,
      coefficientReads := done, completionReads := done, coreReads := done, coreBelow := done, coreNotFourteen := done)


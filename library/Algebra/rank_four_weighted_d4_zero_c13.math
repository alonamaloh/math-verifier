module Algebra.rank_four_weighted_d4_zero_c13

import Algebra.rank_four_weighted_d4_zero_residue_cover

theorem Matrix.weightedD4S0R0C13_universal_of_one_two_four_converse (converse : Matrix.OneTwoFourConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 0, 13)) :=
  by Matrix.weightedZero_universal_of_residual_cover(
      4, 13, Matrix.oneTwoFourResidualCover_selected_core_of_converse(
          converse, coefficient := 13, core := 1, coreSum := done,
          coreAdmissible := (exponent b : ℕ) ↦
            Natural.four_power_times_nonzero_mod_four_core_not_one_three_six_four_obstruction(
              exponent, b, 1, 0, 1, done, done, done, done, done)))

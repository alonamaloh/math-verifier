-- Algebra/associate.math
--
-- Units and the associate relation in an integral domain. Two elements
-- are *associates* when they differ by a unit factor (b = a·u). In a
-- domain this is the right notion of "the same up to invertible scaling"
-- — and unique factorization is unique only up to associates and order
-- (in ℤ, the sign ambiguity; in k[x], a nonzero constant).
--
-- Contents:
--   * unit lemmas: a unit's inverse is a unit, units are closed under
--     products;
--   * `Associate` is reflexive / symmetric / transitive;
--   * an irreducible divided by a non-unit is its associate — the bridge
--     the uniqueness proof uses to match a prime against a factor.

module Algebra.associate

import Logic.basics
import Logic.exists
import Logic.sum
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Algebra.ring_divisibility
import Algebra.commutative_ring_bundle
import Algebra.integral_domain
import Algebra.irreducible

-- ----------------------------------------------------------------------
-- Unit lemmas.

-- A unit's inverse is itself a unit. From `1 = u·v` (commuting to
-- `1 = v·u`) we read `v ∣ 1`.
theorem IntegralDomain.unit_inverse_is_unit (d : IntegralDomain)
        (u : Ring.carrier(IntegralDomain.ring(d)))
        (uIsUnit : Ring.IsUnit(IntegralDomain.ring(d), u))
        : ∃ (v : Ring.carrier(IntegralDomain.ring(d))).
            Ring.IsUnit(IntegralDomain.ring(d), v)
            ∧ u * v = Ring.one(IntegralDomain.ring(d)) := {
  let s : Ring := IntegralDomain.ring(d);
  choose v such that Ring.one(s) = u * v from uIsUnit;
  claim Ring.IsUnit(s, v) by witness u with (calc Ring.one(s) = u * v = v * u);
  claim u * v = Ring.one(s);
  witness v with (Ring.IsUnit(s, v) ∧ u * v = Ring.one(s))
}

-- Units are closed under multiplication: if u, w are units so is u·w.
theorem IntegralDomain.unit_product (d : IntegralDomain)
        (u w : Ring.carrier(IntegralDomain.ring(d)))
        (uIsUnit : Ring.IsUnit(IntegralDomain.ring(d), u))
        (wIsUnit : Ring.IsUnit(IntegralDomain.ring(d), w))
        : Ring.IsUnit(IntegralDomain.ring(d), u * w) := {
  let s : Ring := IntegralDomain.ring(d);
  choose uInverse such that Ring.one(s) = u * uInverse from uIsUnit;
  choose wInverse such that Ring.one(s) = w * wInverse from wIsUnit;
  witness wInverse * uInverse with
    calc Ring.one(s)
       = u * uInverse
       = u * (Ring.one(s) * uInverse)
       = u * ((w * wInverse) * uInverse)
       = (u * w) * (wInverse * uInverse)
}

-- ----------------------------------------------------------------------
-- The associate relation: b = a·u for some unit u.

definition IntegralDomain.Associate (d : IntegralDomain)
        (a b : Ring.carrier(IntegralDomain.ring(d))) : Proposition :=
  ∃ (u : Ring.carrier(IntegralDomain.ring(d))).
      Ring.IsUnit(IntegralDomain.ring(d), u)
      ∧ b = a * u

-- Reflexive: a = a·1 and 1 is a unit.
theorem IntegralDomain.associate_reflexive (d : IntegralDomain)
        (a : Ring.carrier(IntegralDomain.ring(d)))
        : IntegralDomain.Associate(d, a, a) := {
  let s : Ring := IntegralDomain.ring(d);
  claim Ring.IsUnit(s, Ring.one(s)) since Ring.one_is_unit;
  claim a = a * Ring.one(s);
  witness Ring.one(s) with (Ring.IsUnit(s, Ring.one(s)) ∧ a = a * Ring.one(s))
}

-- Symmetric: if b = a·u with u a unit (inverse v), then a = b·v.
theorem IntegralDomain.associate_symmetric (d : IntegralDomain)
        (a b : Ring.carrier(IntegralDomain.ring(d)))
        (associated : IntegralDomain.Associate(d, a, b))
        : IntegralDomain.Associate(d, b, a) := {
  let s : Ring := IntegralDomain.ring(d);
  choose u such that Ring.IsUnit(s, u) ∧ b = a * u from associated;
  claim ∃ (v : Ring.carrier(s)). Ring.IsUnit(s, v) ∧ u * v = Ring.one(s)
      since IntegralDomain.unit_inverse_is_unit;
  choose v such that Ring.IsUnit(s, v) ∧ u * v = Ring.one(s);
  calc a = a * Ring.one(s) = a * (u * v) = (a * u) * v = b * v;
  witness v with (Ring.IsUnit(s, v) ∧ a = b * v)
}

-- Transitive: associate is closed under composing unit factors.
theorem IntegralDomain.associate_transitive (d : IntegralDomain)
        (a b c : Ring.carrier(IntegralDomain.ring(d)))
        (associatedAB : IntegralDomain.Associate(d, a, b))
        (associatedBC : IntegralDomain.Associate(d, b, c))
        : IntegralDomain.Associate(d, a, c) := {
  let s : Ring := IntegralDomain.ring(d);
  choose u such that Ring.IsUnit(s, u) ∧ b = a * u from associatedAB;
  choose w such that Ring.IsUnit(s, w) ∧ c = b * w from associatedBC;
  claim Ring.IsUnit(s, u * w) since IntegralDomain.unit_product;
  calc c = b * w = (a * u) * w = a * (u * w);
  witness u * w with (Ring.IsUnit(s, u * w) ∧ c = a * (u * w))
}

-- ----------------------------------------------------------------------
-- The bridge to factorization: a non-unit dividing an irreducible is its
-- associate. If q is irreducible and p ∣ q (q = p·c), then by
-- irreducibility p or c is a unit; p is not a unit, so c is, making p and
-- q associates.
theorem IntegralDomain.associate_of_divides_irreducible (d : IntegralDomain)
        (p q : Ring.carrier(IntegralDomain.ring(d)))
        (qIrreducible : IntegralDomain.IsIrreducible(d, q))
        (pNotUnit : ¬(Ring.IsUnit(IntegralDomain.ring(d), p)))
        (pDividesQ : Ring.divides(IntegralDomain.ring(d), p, q))
        : IntegralDomain.Associate(d, p, q) := {
  let s : Ring := IntegralDomain.ring(d);
  choose c such that q = p * c as qEqualsPc from pDividesQ;
  claim Ring.IsUnit(s, p) ∨ Ring.IsUnit(s, c);
  claim by cases {
    in (Ring.IsUnit(s, p)) as pIsUnit: absurd(pNotUnit(pIsUnit))
    in (Ring.IsUnit(s, c)) as cIsUnit: {
        claim cAssociate : Ring.IsUnit(s, c) ∧ q = p * c;
        witness c with cAssociate
      }
  }
}

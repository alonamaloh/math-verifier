theorem Matrix.detSevenFiniteQ1C7ODDA133T6
        (n : ℕ) (positive : n ≥ 1)
        (bounded : n ≤ 11340)
        (remainderReads : Natural.modulo(n, 588) = 133)
        : Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 1, 7),
            (n : ℤ)) := {
  let q : ℕ := Natural.floor_divide(n, 588);
  588 * q + Natural.modulo(n, 588) = n
      by Natural.floor_divide_modulo_decompose;
  588 * q + 133 = n by substituting remainderReads as exactDecomposition;
  q < 20 by Natural.quotient_below_of_bounded_decomposition(
    588, q, 133, n, 11340, 20, done, exactDecomposition, bounded)
  as qBelow;
  Matrix.Represents(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 1, 7),
      (588 : ℤ) * (q : ℤ) + (133 : ℤ)) by {
  done by Matrix.detSevenFiniteQ1C7ODDA133T6_part0(q, done, qBelow)
  };
  (588 : ℤ) * (q : ℤ) + (133 : ℤ)
     = ((588 * q : ℕ) : ℤ) + (133 : ℤ)
         by substituting Equality.symmetry(Natural.to_integer.multiply_preserves(588, q))
     = ((588 * q + 133 : ℕ) : ℤ)
         by Equality.symmetry(Natural.to_integer.add_preserves(588 * q, 133))
     = (n : ℤ) by substituting exactDecomposition
  as integerDecomposition;
  done by substituting integerDecomposition
}


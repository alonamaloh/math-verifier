-- Algebra/det_seven_generic_covers.math
--
-- The six generic odd-C=4 rank-four forms, conditional only on the exact
-- determinant-seven safe-converse interface.

module Algebra.det_seven_generic_covers

import Algebra.det_seven_generic_universality
import Algebra.det_seven_finite_q0c7_generated
import Algebra.det_seven_finite_q1c6_generated
import Algebra.det_seven_finite_q2c8_generated
import Algebra.det_seven_finite_q2c9_generated
import Algebra.det_seven_finite_q3c10_generated
import Algebra.det_seven_finite_q3c11_generated

theorem Matrix.oddC4R0C7_universal_of_det_seven_safe_converse
        (converse : Matrix.DetSevenSafeConverse)
        : Matrix.IsUniversal(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 7)) := {
  Matrix.DetSevenNaturalOrthogonalLift(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 7), 7)
      by Matrix.detSevenNaturalOrthogonalLift_of_integer(
        Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 7), 7,
        (residual t : ℤ)
          (represented : Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddForm(4), residual)) ↦
          Matrix.oddC4R0C7_orthogonal_lift(residual, t, represented))
      as lift;
  done by Matrix.detSeven_universal_of_generic_cover(
    Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 7),
    7, Natural.DetSevenChoices12346, Natural.DetSevenSelectedM7,
    converse, Natural.detSevenResidueCover_m7_selected,
    Matrix.detSevenFiniteCover_q0c7, lift)
}


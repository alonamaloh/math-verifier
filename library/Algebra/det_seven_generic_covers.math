theorem Matrix.detSeven_six_generic_universal
        (converse : Matrix.DetSevenSafeConverse)
        : Matrix.IsUniversal(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 7))
          ∧ Matrix.IsUniversal(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 1, 6))
          ∧ Matrix.IsUniversal(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 8))
          ∧ Matrix.IsUniversal(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 9))
          ∧ Matrix.IsUniversal(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 10))
          ∧ Matrix.IsUniversal(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 11)) := {
  Matrix.IsUniversal(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 7))
      by Matrix.oddC4R0C7_universal_of_det_seven_safe_converse(converse);
  Matrix.IsUniversal(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 1, 6))
      by Matrix.oddC4R1C6_universal_of_det_seven_safe_converse(converse);
  Matrix.IsUniversal(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 8))
      by Matrix.oddC4R2C8_universal_of_det_seven_safe_converse(converse);
  Matrix.IsUniversal(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 9))
      by Matrix.oddC4R2C9_universal_of_det_seven_safe_converse(converse);
  Matrix.IsUniversal(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 10))
      by Matrix.oddC4R3C10_universal_of_det_seven_safe_converse(converse);
  Matrix.IsUniversal(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 11))
      by Matrix.oddC4R3C11_universal_of_det_seven_safe_converse(converse);
  done
}

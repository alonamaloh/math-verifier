-- Algebra/exchange_lemma.math
--
-- The Steinitz exchange lemma: an independent family is no larger than a
-- spanning one. The classical one-swap-at-a-time argument, where
-- `Field.reciprocal` finally earns its keep — a vector selected with a
-- nonzero coefficient is solved for by dividing by that coefficient.
--
-- This file builds the reusable bricks first (dividing a nonzero scalar
-- out of a span membership; normalising an arbitrary combination to
-- canonical coordinates) and then the exchange induction on top of them.

module Algebra.exchange_lemma

import axioms
import Logic.basics
import Logic.exists
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.division
import Natural.monus
import Natural.classical_decidable
import Natural.least_number
import Set.subtype
import Set.finite
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.aggregation
import Algebra.ring
import Algebra.ring_lemmas
import Algebra.field
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.field_bundle
import Algebra.vector_space
import Algebra.vector_space_lemmas
import Algebra.linear_combination
import Algebra.span

-- ----------------------------------------------------------------------
-- Dividing out a nonzero scalar (where `Field.reciprocal` enters).

-- Scaling by a nonzero scalar is undone by scaling by its reciprocal.
theorem VectorSpace.scale_reciprocal_cancel {f : Field} (V : VectorSpace(f))
        (a : Field.carrier(f)) (nonzero : a ≠ Field.zero(f)) (v : VectorSpace.carrier(V))
        : Field.reciprocal(a, nonzero) • (a • v) = v := {
  Field.reciprocal(a, nonzero) * a
     = a * Field.reciprocal(a, nonzero)
     = Field.one(f)                              by Field.reciprocal_multiplies
     as reciprocalOnLeft;
  Field.reciprocal(a, nonzero) • (a • v)
     = (Field.reciprocal(a, nonzero) * a) • v    by VectorSpace.scale_scalar_multiply
     = Field.one(f) • v                          by substituting reciprocalOnLeft
     = v                                         by VectorSpace.one_scale
}

-- If a nonzero multiple of `v` lies in a span, so does `v` itself: scale
-- the membership by the reciprocal.
theorem VectorSpace.InSpanOf.scale_cancel {f : Field} {V : VectorSpace(f)} {I : Type(0)}
        (family : I → VectorSpace.carrier(V))
        (a : Field.carrier(f)) (nonzero : a ≠ Field.zero(f))
        (v : VectorSpace.carrier(V))
        (member : VectorSpace.InSpanOf(family, a • v))
        : VectorSpace.InSpanOf(family, v) := {
  VectorSpace.InSpanOf(family, Field.reciprocal(a, nonzero) • (a • v))
      by VectorSpace.InSpanOf.scale;
  Field.reciprocal(a, nonzero) • (a • v) = v
      by VectorSpace.scale_reciprocal_cancel as cancelReciprocal;
  done by substituting cancelReciprocal
}

-- ----------------------------------------------------------------------
-- Canonical (identity-selection) combinations. `standardCombination(g, c, n)`
-- is Σ_{i<n} c(i) • g(i): the linear combination whose selection is the
-- identity, so the coefficient on `g(i)` is literally `c(i)`. Working in
-- these coordinates is what makes "the coefficient at a given slot" a
-- meaningful quantity for the exchange step.

definition VectorSpace.standardCombination {f : Field} {V : VectorSpace(f)}
        (g : Natural → VectorSpace.carrier(V))
        (coefficients : Natural → Field.carrier(f)) (count : Natural)
        : VectorSpace.carrier(V) :=
  VectorSpace.linearCombination(g, coefficients, (i : Natural) ↦ i, count)

-- Peel the last term.
theorem VectorSpace.standardCombination_add_one {f : Field} {V : VectorSpace(f)}
        (g : Natural → VectorSpace.carrier(V))
        (coefficients : Natural → Field.carrier(f)) (count : Natural)
        : VectorSpace.standardCombination(g, coefficients, 1 + count)
          = VectorSpace.standardCombination(g, coefficients, count)
            + coefficients(count) • g(count) :=
  VectorSpace.standardCombination(g, coefficients, 1 + count)
     = VectorSpace.linearCombination(g, coefficients, (i : Natural) ↦ i, count)
       + coefficients(count) • g(count)
           by VectorSpace.linearCombination_add_one
     = VectorSpace.standardCombination(g, coefficients, count)
       + coefficients(count) • g(count)

-- Two standard combinations agree when their terms agree below the count —
-- even when both the family and the coefficients differ, provided the
-- scaled vectors coincide index by index.
theorem VectorSpace.standardCombination_congruence {f : Field} {V : VectorSpace(f)}
        (g1 g2 : Natural → VectorSpace.carrier(V))
        (c1 c2 : Natural → Field.carrier(f)) (n : Natural)
        (termsAgree : ∀ (i : Natural). i < n → c1(i) • g1(i) = c2(i) • g2(i))
        : VectorSpace.standardCombination(g1, c1, n)
          = VectorSpace.standardCombination(g2, c2, n) := {
  VectorSpace.standardCombination(g1, c1, n)
     = Algebra.indexedAggregate(VectorSpace.carrier(V), VectorSpace.add, VectorSpace.zero(V),
           (i : Natural) ↦ c1(i) • g1(i), n)
     = Algebra.indexedAggregate(VectorSpace.carrier(V), VectorSpace.add, VectorSpace.zero(V),
           (i : Natural) ↦ c2(i) • g2(i), n)
           by Algebra.indexedAggregate_pointwise_below
     = VectorSpace.standardCombination(g2, c2, n)
}

-- Overwriting one point of a function. Generic in the codomain `A` (a bare
-- type variable — `Field.carrier(f)` or `VectorSpace.carrier(V)` as the
-- conditional's return type trips "cases motive not a Sort", the same
-- generalisation `combineFunctions` makes).
definition Function.updateAt {A : Type(0)} (h : Natural → A) (pos : Natural) (newValue : A)
        : Natural → A :=
  (i : Natural) ↦ if i = pos then newValue else h(i)

theorem Function.updateAt_at {A : Type(0)} (h : Natural → A) (pos : Natural) (newValue : A)
        : Function.updateAt(h, pos, newValue)(pos) = newValue :=
  done by Logic.if_positive

theorem Function.updateAt_off {A : Type(0)} (h : Natural → A) (pos i : Natural)
        (newValue : A) (distinct : i ≠ pos)
        : Function.updateAt(h, pos, newValue)(i) = h(i) :=
  done by Logic.if_negative

-- The coefficients `d` with position `pos` raised by `e`.
definition VectorSpace.bumpCoefficient {f : Field} (d : Natural → Field.carrier(f))
        (e : Field.carrier(f)) (pos : Natural) : Natural → Field.carrier(f) :=
  Function.updateAt(d, pos, d(pos) + e)

theorem VectorSpace.bumpCoefficient_at {f : Field} (d : Natural → Field.carrier(f))
        (e : Field.carrier(f)) (pos : Natural)
        : VectorSpace.bumpCoefficient(d, e, pos)(pos) = d(pos) + e :=
  done by Function.updateAt_at

theorem VectorSpace.bumpCoefficient_off {f : Field} (d : Natural → Field.carrier(f))
        (e : Field.carrier(f)) (pos i : Natural) (distinct : i ≠ pos)
        : VectorSpace.bumpCoefficient(d, e, pos)(i) = d(i) :=
  done by Function.updateAt_off

-- Bumping the coefficient at one position by `e` adds `e • g(pos)` to the
-- combination. This is what lets an arbitrary combination be rebuilt in
-- canonical coordinates one term at a time, and what installs the `-1`
-- coefficient the independence contradiction needs.
theorem VectorSpace.standardCombination_bump {f : Field} {V : VectorSpace(f)}
        (g : Natural → VectorSpace.carrier(V)) (d : Natural → Field.carrier(f))
        (e : Field.carrier(f)) (pos n : Natural) (posBelow : pos < n)
        : VectorSpace.standardCombination(g, VectorSpace.bumpCoefficient(d, e, pos), n)
          = VectorSpace.standardCombination(g, d, n) + e • g(pos) :=
  by induction on n with IH {
    case base: {
        ¬(pos < 0) by Natural.not_less_than_zero;
        done
      }
    case step(q): {
        pos < q ∨ pos = q by Natural.le_of_lt_one_plus;
        done by cases {
          case pos < q as posLtQ: {
              q ≠ pos by Natural.not_equal_of_greater_than;
              VectorSpace.bumpCoefficient(d, e, pos)(q) = d(q)
                  by VectorSpace.bumpCoefficient_off as bumpAtQ;
              VectorSpace.standardCombination(g, VectorSpace.bumpCoefficient(d, e, pos), 1 + q)
                 = VectorSpace.standardCombination(g, VectorSpace.bumpCoefficient(d, e, pos), q)
                   + VectorSpace.bumpCoefficient(d, e, pos)(q) • g(q)
                       by VectorSpace.standardCombination_add_one
                 = (VectorSpace.standardCombination(g, d, q) + e • g(pos))
                   + VectorSpace.bumpCoefficient(d, e, pos)(q) • g(q)
                       by IH
                 = (VectorSpace.standardCombination(g, d, q) + e • g(pos)) + d(q) • g(q)
                       by substituting bumpAtQ
                 = VectorSpace.standardCombination(g, d, q) + (e • g(pos) + d(q) • g(q))
                 = VectorSpace.standardCombination(g, d, q) + (d(q) • g(q) + e • g(pos))
                       by VectorSpace.add_commutative
                 = (VectorSpace.standardCombination(g, d, q) + d(q) • g(q)) + e • g(pos)
                 = VectorSpace.standardCombination(g, d, 1 + q) + e • g(pos)
                       by VectorSpace.standardCombination_add_one
            }
          case pos = q as posEqQ: {
              q = pos by posEqQ as qEqPos;
              VectorSpace.bumpCoefficient(d, e, pos)(q)
                 = VectorSpace.bumpCoefficient(d, e, pos)(pos)   by substituting qEqPos
                 = d(pos) + e                                    by VectorSpace.bumpCoefficient_at
                 = d(q) + e                                      by substituting posEqQ
                 as bumpAtQ;
              ∀ (i : Natural). i < q →
                  VectorSpace.bumpCoefficient(d, e, pos)(i) • g(i) = d(i) • g(i)
                by {
                  take i : Natural;
                  suppose i < q as iLtQ;
                  i < pos by substituting posEqQ;
                  i ≠ pos by Natural.not_equal_of_less_than;
                  VectorSpace.bumpCoefficient(d, e, pos)(i) = d(i)
                      by VectorSpace.bumpCoefficient_off as bumpAtI;
                  done by substituting bumpAtI
                };
              VectorSpace.standardCombination(g, VectorSpace.bumpCoefficient(d, e, pos), q)
                 = VectorSpace.standardCombination(g, d, q)
                     by VectorSpace.standardCombination_congruence as reduceBelow;
              VectorSpace.standardCombination(g, VectorSpace.bumpCoefficient(d, e, pos), 1 + q)
                 = VectorSpace.standardCombination(g, VectorSpace.bumpCoefficient(d, e, pos), q)
                   + VectorSpace.bumpCoefficient(d, e, pos)(q) • g(q)
                       by VectorSpace.standardCombination_add_one
                 = VectorSpace.standardCombination(g, d, q)
                   + VectorSpace.bumpCoefficient(d, e, pos)(q) • g(q)
                       by substituting reduceBelow
                 = VectorSpace.standardCombination(g, d, q) + (d(q) + e) • g(q)
                       by substituting bumpAtQ
                 = VectorSpace.standardCombination(g, d, q) + (d(q) • g(q) + e • g(q))
                 = (VectorSpace.standardCombination(g, d, q) + d(q) • g(q)) + e • g(q)
                 = VectorSpace.standardCombination(g, d, 1 + q) + e • g(q)
                       by VectorSpace.standardCombination_add_one
                 = VectorSpace.standardCombination(g, d, 1 + q) + e • g(pos)
                       by substituting posEqQ
            }
        }
      }
  }

-- ----------------------------------------------------------------------
-- One more span-closure fact (a subspace law not yet recorded): spans are
-- closed under subtraction. (`InSpanOf.zero` now lives in span.math.)

theorem VectorSpace.InSpanOf.subtract {f : Field} {V : VectorSpace(f)} {I : Type(0)}
        (family : I → VectorSpace.carrier(V)) (u v : VectorSpace.carrier(V))
        (uMember : VectorSpace.InSpanOf(family, u))
        (vMember : VectorSpace.InSpanOf(family, v))
        : VectorSpace.InSpanOf(family, u - v) := {
  VectorSpace.InSpanOf(family, Field.negate(Field.one(f)) • v) by VectorSpace.InSpanOf.scale;
  VectorSpace.InSpanOf(family, u + Field.negate(Field.one(f)) • v) by VectorSpace.InSpanOf.add;
  u + Field.negate(Field.one(f)) • v
     = u + VectorSpace.negate(v)   by VectorSpace.negate_one_scale
     = u - v
     as rewriteSubtract;
  done by substituting rewriteSubtract
}

-- ----------------------------------------------------------------------
-- Normalising an arbitrary combination to canonical coordinates. When the
-- family vanishes past `n`, every combination of it — whatever selection
-- and length — is a standard combination Σ_{i<n} d(i) • g(i). This is what
-- lets the exchange step read off "the coefficient at slot j".

-- The all-zero standard combination is the zero vector.
theorem VectorSpace.standardCombination_zero_coefficients {f : Field} {V : VectorSpace(f)}
        (g : Natural → VectorSpace.carrier(V)) (n : Natural)
        : VectorSpace.standardCombination(g, (i : Natural) ↦ Field.zero(f), n)
          = VectorSpace.zero(V) :=
  by induction on n with IH {
    case base: done
    case step(q):
        VectorSpace.standardCombination(g, (i : Natural) ↦ Field.zero(f), 1 + q)
           = VectorSpace.standardCombination(g, (i : Natural) ↦ Field.zero(f), q)
             + Field.zero(f) • g(q)
                 by VectorSpace.standardCombination_add_one
           = VectorSpace.zero(V) + Field.zero(f) • g(q)   by IH
           = VectorSpace.zero(V) + VectorSpace.zero(V)     by VectorSpace.zero_scale
           = VectorSpace.zero(V)
  }

theorem VectorSpace.linearCombination_standardize {f : Field} {V : VectorSpace(f)}
        (g : Natural → VectorSpace.carrier(V)) (n : Natural)
        (vanishesPast : ∀ (i : Natural). n ≤ i → g(i) = VectorSpace.zero(V))
        (coefficients : Natural → Field.carrier(f)) (selection : Natural → Natural)
        (count : Natural)
        : ∃ (d : Natural → Field.carrier(f)).
              VectorSpace.linearCombination(g, coefficients, selection, count)
              = VectorSpace.standardCombination(g, d, n) :=
  by induction on count with IH {
    case base: {
        VectorSpace.linearCombination(g, coefficients, selection, 0) = VectorSpace.zero(V);
        VectorSpace.zero(V) = VectorSpace.standardCombination(g, (i : Natural) ↦ Field.zero(f), n)
            by VectorSpace.standardCombination_zero_coefficients;
        VectorSpace.linearCombination(g, coefficients, selection, 0)
            = VectorSpace.standardCombination(g, (i : Natural) ↦ Field.zero(f), n)
            as baseGoal;
        witness ((i : Natural) ↦ Field.zero(f)) with baseGoal
      }
    case step(p): {
        choose d such that
            VectorSpace.linearCombination(g, coefficients, selection, p)
            = VectorSpace.standardCombination(g, d, n)
            from IH;
        VectorSpace.linearCombination(g, coefficients, selection, p)
            = VectorSpace.standardCombination(g, d, n) as headStandardEq;
        VectorSpace.linearCombination(g, coefficients, selection, 1 + p)
           = VectorSpace.linearCombination(g, coefficients, selection, p)
             + coefficients(p) • g(selection(p))
                 by VectorSpace.linearCombination_add_one
           = VectorSpace.standardCombination(g, d, n) + coefficients(p) • g(selection(p))
                 by substituting headStandardEq
           as peeled;
        selection(p) < n ∨ n ≤ selection(p) by Natural.lt_or_le;
        done by cases {
          case selection(p) < n as inRange: {
              VectorSpace.standardCombination(g,
                    VectorSpace.bumpCoefficient(d, coefficients(p), selection(p)), n)
                 = VectorSpace.standardCombination(g, d, n)
                   + coefficients(p) • g(selection(p))
                     by VectorSpace.standardCombination_bump;
              VectorSpace.linearCombination(g, coefficients, selection, 1 + p)
                 = VectorSpace.standardCombination(g,
                       VectorSpace.bumpCoefficient(d, coefficients(p), selection(p)), n)
                 as stepGoal;
              witness VectorSpace.bumpCoefficient(d, coefficients(p), selection(p)) with stepGoal
            }
          case n ≤ selection(p) as outRange: {
              g(selection(p)) = VectorSpace.zero(V) by vanishesPast as vanishHere;
              coefficients(p) • g(selection(p))
                 = coefficients(p) • VectorSpace.zero(V)   by substituting vanishHere
                 = VectorSpace.zero(V)                     by VectorSpace.scale_zero
                 as termVanishes;
              VectorSpace.linearCombination(g, coefficients, selection, 1 + p)
                 = VectorSpace.standardCombination(g, d, n) + coefficients(p) • g(selection(p))
                       by peeled
                 = VectorSpace.standardCombination(g, d, n) + VectorSpace.zero(V)
                       by substituting termVanishes
                 = VectorSpace.standardCombination(g, d, n)
                 as stepGoal;
              witness d with stepGoal
            }
        }
      }
  }

-- ----------------------------------------------------------------------
-- The exchange induction proper. Everything below works with `Natural`-
-- indexed families and the bounded predicates a swap needs; the bridge to
-- the index-generic `Spans`/`LinearlyIndependent` is a thin layer above.

-- Independence in canonical coordinates: no nontrivial standard combination
-- of the first `bound` vectors vanishes. Implied by (and used in place of)
-- the index-generic `LinearlyIndependent`, since the identity selection is
-- injective.
definition VectorSpace.StandardIndependentBelow {f : Field} {V : VectorSpace(f)}
        (uu : Natural → VectorSpace.carrier(V)) (bound : Natural) : Proposition :=
  ∀ (len : Natural) (coefficients : Natural → Field.carrier(f)).
      len ≤ bound
      → VectorSpace.standardCombination(uu, coefficients, len) = VectorSpace.zero(V)
      → ∀ (i : Natural). i < len → coefficients(i) = Field.zero(f)

-- Minus one is nonzero — the field is nontrivial.
theorem Field.negate_one_nonzero (f : Field)
        : Field.negate(Field.one(f)) ≠ Field.zero(f) := {
  suppose Field.negate(Field.one(f)) = Field.zero(f) as negOneZero;
  Field.one(f)
     = Field.negate(Field.negate(Field.one(f)))
     = Field.negate(Field.zero(f))              by substituting negOneZero
     = Field.zero(f)
     as oneIsZero;
  Field.zero(f) = Field.one(f) by oneIsZero;
  Field.zero(f) ≠ Field.one(f) by Field.nontrivial;
  done
}

-- Extracting the swap target: when `uu(k)` is expanded in a family whose
-- first `k` entries are `uu(0..k-1)`, independence of `uu(0..k)` forces some
-- REMAINING slot (index in [k, n)) to carry a nonzero coefficient. If none
-- did, the expansion would present `uu(k)` as a combination of the earlier
-- `uu`'s, and installing a `-1` at slot `k` would be a nontrivial vanishing
-- combination of `uu(0..k)`.
theorem VectorSpace.exchange_find_pivot {f : Field} {V : VectorSpace(f)}
        (uu g : Natural → VectorSpace.carrier(V)) (m k n : Natural)
        (independent : VectorSpace.StandardIndependentBelow(uu, m))
        (agreePrefix : ∀ (i : Natural). i < k → g(i) = uu(i))
        (kBelowN : k < n) (nBelowOrEqM : n ≤ m)
        (coefficients : Natural → Field.carrier(f))
        (target : uu(k) = VectorSpace.standardCombination(g, coefficients, n))
        : ∃ (j : Natural). k ≤ j ∧ j < n ∧ coefficients(j) ≠ Field.zero(f) := {
  suppose ¬(∃ (j : Natural). k ≤ j ∧ j < n ∧ coefficients(j) ≠ Field.zero(f)) as noPivot
      for contradiction {
        ∀ (j : Natural). k ≤ j → j < n → coefficients(j) = Field.zero(f)
          by {
            take j : Natural;
            suppose k ≤ j as kLeJ;
            suppose j < n as jLtN;
            suppose coefficients(j) ≠ Field.zero(f) as coefficientNonzero for contradiction {
              ∃ (jj : Natural). k ≤ jj ∧ jj < n ∧ coefficients(jj) ≠ Field.zero(f)
                by { witness j with
                     And.introduction(kLeJ, And.introduction(jLtN, coefficientNonzero)) };
              done
            }
          } as allZeroRemaining;
        ∀ (i : Natural). i < n → coefficients(i) • g(i) = coefficients(i) • uu(i)
          by {
            take i : Natural;
            suppose i < n as iLtN;
            i < k ∨ k ≤ i by Natural.lt_or_le;
            done by cases {
              case i < k as iLtK: {
                  g(i) = uu(i) by agreePrefix as gIsUu;
                  done by substituting gIsUu
                }
              case k ≤ i as kLeI: {
                  coefficients(i) = Field.zero(f) by allZeroRemaining as coeffZero;
                  coefficients(i) • g(i)
                     = Field.zero(f) • g(i)     by substituting coeffZero
                     = VectorSpace.zero(V)      by VectorSpace.zero_scale
                     = Field.zero(f) • uu(i)    by VectorSpace.zero_scale
                     = coefficients(i) • uu(i)  by substituting coeffZero
                }
            }
          };
        VectorSpace.standardCombination(g, coefficients, n)
           = VectorSpace.standardCombination(uu, coefficients, n)
             by VectorSpace.standardCombination_congruence as gToUu;
        VectorSpace.standardCombination(uu, coefficients, n)
           = VectorSpace.standardCombination(g, coefficients, n)   by gToUu
           = uu(k)                                                 by target
           as uuCombIsUk;
        VectorSpace.standardCombination(uu,
              VectorSpace.bumpCoefficient(coefficients, Field.negate(Field.one(f)), k), n)
           = VectorSpace.standardCombination(uu, coefficients, n)
             + Field.negate(Field.one(f)) • uu(k)
                 by VectorSpace.standardCombination_bump
           = uu(k) + Field.negate(Field.one(f)) • uu(k)   by substituting uuCombIsUk
           = uu(k) + VectorSpace.negate(uu(k))            by VectorSpace.negate_one_scale
           = uu(k) - uu(k)
           = VectorSpace.zero(V);
        ∀ (i : Natural). i < n →
            VectorSpace.bumpCoefficient(coefficients, Field.negate(Field.one(f)), k)(i)
            = Field.zero(f)
          by independent as bumpedAllZero;
        VectorSpace.bumpCoefficient(coefficients, Field.negate(Field.one(f)), k)(k)
            = Field.zero(f) by bumpedAllZero as bumpedKZero;
        coefficients(k) = Field.zero(f) by allZeroRemaining as coeffKZero;
        VectorSpace.bumpCoefficient(coefficients, Field.negate(Field.one(f)), k)(k)
           = coefficients(k) + Field.negate(Field.one(f))   by VectorSpace.bumpCoefficient_at
           = Field.zero(f) + Field.negate(Field.one(f))     by substituting coeffKZero
           = Field.negate(Field.one(f))
           as bumpedKValue;
        Field.negate(Field.one(f))
           = VectorSpace.bumpCoefficient(coefficients, Field.negate(Field.one(f)), k)(k)
                 by bumpedKValue
           = Field.zero(f)                                  by bumpedKZero;
        Field.negate(Field.one(f)) ≠ Field.zero(f) by Field.negate_one_nonzero;
        done
  }
}

-- ----------------------------------------------------------------------
-- The one-swap family: `swapIn(g, k, j, v)` moves what sat at slot `k`
-- into slot `j` and installs `v` at slot `k`. (When `j = k` the inner move
-- is overwritten — the net effect is just `v` at slot `k`.) Two nested
-- point-updates.
definition VectorSpace.swapIn {A : Type(0)} (g : Natural → A) (k j : Natural)
        (newValue : A) : Natural → A :=
  Function.updateAt(Function.updateAt(g, j, g(k)), k, newValue)

theorem VectorSpace.swapIn_at_k {A : Type(0)} (g : Natural → A) (k j : Natural) (v : A)
        : VectorSpace.swapIn(g, k, j, v)(k) = v :=
  done by Function.updateAt_at

theorem VectorSpace.swapIn_at_j {A : Type(0)} (g : Natural → A) (k j : Natural) (v : A)
        (distinct : j ≠ k)
        : VectorSpace.swapIn(g, k, j, v)(j) = g(k) :=
  VectorSpace.swapIn(g, k, j, v)(j)
     = Function.updateAt(Function.updateAt(g, j, g(k)), k, v)(j)
     = Function.updateAt(g, j, g(k))(j)   by Function.updateAt_off
     = g(k)                                by Function.updateAt_at

theorem VectorSpace.swapIn_off {A : Type(0)} (g : Natural → A) (k j i : Natural) (v : A)
        (offK : i ≠ k) (offJ : i ≠ j)
        : VectorSpace.swapIn(g, k, j, v)(i) = g(i) :=
  VectorSpace.swapIn(g, k, j, v)(i)
     = Function.updateAt(Function.updateAt(g, j, g(k)), k, v)(i)
     = Function.updateAt(g, j, g(k))(i)   by Function.updateAt_off
     = g(i)                                by Function.updateAt_off

-- Cancelling the left summand of a subtraction.
theorem VectorSpace.add_subtract_cancel_left {f : Field} {V : VectorSpace(f)}
        (a b : VectorSpace.carrier(V)) : (a + b) - a = b :=
  (a + b) - a
     = (a + b) + VectorSpace.negate(a)
     = (b + a) + VectorSpace.negate(a)    by VectorSpace.add_commutative
     = b + (a + VectorSpace.negate(a))
     = b + (a - a)
     = b + VectorSpace.zero(V)            by VectorSpace.subtract_self
     = b

-- ----------------------------------------------------------------------
-- One exchange step. A spanning family whose first `k` entries are the
-- independent `uu(0..k-1)` yields another spanning family whose first
-- `k+1` entries are `uu(0..k)` — swap `uu(k)` in for a `w` that carries a
-- nonzero coefficient in its expansion. `InSpanOf.transitive` discharges
-- "the swapped family still spans"; `InSpanOf.scale_cancel` (dividing by
-- that nonzero coefficient) is what recovers the swapped-out vector.
theorem VectorSpace.exchange_step {f : Field} {V : VectorSpace(f)}
        (uu g : Natural → VectorSpace.carrier(V)) (m k n : Natural)
        (independent : VectorSpace.StandardIndependentBelow(uu, m))
        (gVanishesPast : ∀ (i : Natural). n ≤ i → g(i) = VectorSpace.zero(V))
        (gAgreePrefix : ∀ (i : Natural). i < k → g(i) = uu(i))
        (gSpans : VectorSpace.Spans(g))
        (kBelowN : k < n) (nBelowOrEqM : n ≤ m)
        : ∃ (gNew : Natural → VectorSpace.carrier(V)).
              VectorSpace.Spans(gNew)
              ∧ (∀ (i : Natural). n ≤ i → gNew(i) = VectorSpace.zero(V))
              ∧ (∀ (i : Natural). i < 1 + k → gNew(i) = uu(i)) := {
  -- Expand uu(k) in canonical coordinates over g.
  VectorSpace.InSpanOf(g, uu(k)) by VectorSpace.InSpanOf.of_spans(inhabitant := 0) as ukInSpan;
  choose count, selection, coeffs such that
      uu(k) = VectorSpace.linearCombination(g, coeffs, selection, count) from ukInSpan;
  uu(k) = VectorSpace.linearCombination(g, coeffs, selection, count) as ukLinComb;
  ∃ (d : Natural → Field.carrier(f)).
      VectorSpace.linearCombination(g, coeffs, selection, count)
      = VectorSpace.standardCombination(g, d, n)
      by VectorSpace.linearCombination_standardize as standardized;
  choose d such that
      VectorSpace.linearCombination(g, coeffs, selection, count)
      = VectorSpace.standardCombination(g, d, n) from standardized;
  VectorSpace.linearCombination(g, coeffs, selection, count)
      = VectorSpace.standardCombination(g, d, n) as linCombStandard;
  uu(k) = VectorSpace.linearCombination(g, coeffs, selection, count)   by ukLinComb
        = VectorSpace.standardCombination(g, d, n)                     by linCombStandard
        as ukStandard;
  -- Independence forces a nonzero coefficient on a remaining slot.
  ∃ (j : Natural). k ≤ j ∧ j < n ∧ d(j) ≠ Field.zero(f)
      by VectorSpace.exchange_find_pivot as pivotExists;
  choose j such that k ≤ j ∧ j < n ∧ d(j) ≠ Field.zero(f) from pivotExists;
  k ≤ j as kLeJ;
  j < n as jLtN;
  d(j) ≠ Field.zero(f) as dJnonzero;
  -- The swapped family; uu(k) sits at slot k, the old g(k) at slot j.
  VectorSpace.swapIn(g, k, j, uu(k))(k) = uu(k) by VectorSpace.swapIn_at_k as swapAtK;
  VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)), uu(k))
      by { VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)),
                                VectorSpace.swapIn(g, k, j, uu(k))(k))
               by VectorSpace.InSpanOf.member;
           done by substituting swapAtK } as ukInNew;
  -- Every OTHER old generator is trivially in the swapped family's span.
  ∀ (i : Natural). i ≠ j → VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)), g(i))
    by {
      take i : Natural;
      suppose i ≠ j as offJ;
      i = k ∨ i ≠ k by Logic.excluded_middle;
      done by cases {
        case i = k as atK: {
            j ≠ k by { suppose j = k as jk; i = j by substituting atK; done };
            VectorSpace.swapIn(g, k, j, uu(k))(j) = g(k) by VectorSpace.swapIn_at_j as swapAtJ;
            VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)),
                                 VectorSpace.swapIn(g, k, j, uu(k))(j))
                by VectorSpace.InSpanOf.member;
            VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)), g(k)) by substituting swapAtJ;
            done by substituting atK
          }
        case i ≠ k as offK: {
            VectorSpace.swapIn(g, k, j, uu(k))(i) = g(i) by VectorSpace.swapIn_off as swapAtI;
            VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)),
                                 VectorSpace.swapIn(g, k, j, uu(k))(i))
                by VectorSpace.InSpanOf.member;
            done by substituting swapAtI
          }
      }
    } as offJInSpan;
  -- g with slot j replaced by uu(k): every generator is in the swapped span.
  ∀ (i : Natural). VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)),
                                        Function.updateAt(g, j, uu(k))(i))
    by {
      take i : Natural;
      i = j ∨ i ≠ j by Logic.excluded_middle;
      done by cases {
        case i = j as atJ: {
            Function.updateAt(g, j, uu(k))(j) = uu(k) by Function.updateAt_at as primeAtJ;
            VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)),
                                 Function.updateAt(g, j, uu(k))(j)) by substituting primeAtJ;
            done by substituting atJ
          }
        case i ≠ j as offJ: {
            Function.updateAt(g, j, uu(k))(i) = g(i) by Function.updateAt_off as primeOffJ;
            VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)), g(i)) by offJInSpan;
            done by substituting primeOffJ
          }
      }
    } as primeInSpan;
  -- The combination of the modified family with the j-coefficient zeroed
  -- lands in the swapped span, and equals the same combination of g.
  VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)),
        VectorSpace.linearCombination(Function.updateAt(g, j, uu(k)),
            Function.updateAt(d, j, Field.zero(f)), (i : Natural) ↦ i, n))
      by VectorSpace.InSpanOf.of_combination(outerInhabitant := 0);
  VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)),
        VectorSpace.standardCombination(Function.updateAt(g, j, uu(k)),
            Function.updateAt(d, j, Field.zero(f)), n)) as primeCombInSpan;
  Function.updateAt(d, j, Field.zero(f))(j) = Field.zero(f) by Function.updateAt_at as czeroAtJ;
  ∀ (i : Natural). i < n →
      Function.updateAt(d, j, Field.zero(f))(i) • Function.updateAt(g, j, uu(k))(i)
      = Function.updateAt(d, j, Field.zero(f))(i) • g(i)
    by {
      take i : Natural;
      suppose i < n as iLtN;
      i = j ∨ i ≠ j by Logic.excluded_middle;
      done by cases {
        case i = j as atJ: {
            Function.updateAt(d, j, Field.zero(f))(i) = Field.zero(f)
                by substituting atJ as czeroHere;
            Function.updateAt(d, j, Field.zero(f))(i) • Function.updateAt(g, j, uu(k))(i)
               = Field.zero(f) • Function.updateAt(g, j, uu(k))(i)   by substituting czeroHere
               = VectorSpace.zero(V)                                 by VectorSpace.zero_scale
               = Field.zero(f) • g(i)                                by VectorSpace.zero_scale
               = Function.updateAt(d, j, Field.zero(f))(i) • g(i)    by substituting czeroHere
          }
        case i ≠ j as offJ: {
            Function.updateAt(g, j, uu(k))(i) = g(i) by Function.updateAt_off as primeOffJ;
            done by substituting primeOffJ
          }
      }
    } as czeroTermsMatch;
  VectorSpace.standardCombination(Function.updateAt(g, j, uu(k)),
        Function.updateAt(d, j, Field.zero(f)), n)
     = VectorSpace.standardCombination(g, Function.updateAt(d, j, Field.zero(f)), n)
       by VectorSpace.standardCombination_congruence as primeToG;
  VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)),
        VectorSpace.standardCombination(g, Function.updateAt(d, j, Field.zero(f)), n))
      by substituting primeToG as czeroGInSpan;
  -- d is the zeroed coefficients bumped by d(j) at slot j, so the full
  -- combination splits as [j-zeroed combination] + d(j) • g(j).
  ∀ (i : Natural). VectorSpace.bumpCoefficient(Function.updateAt(d, j, Field.zero(f)), d(j), j)(i)
      = d(i)
    by {
      take i : Natural;
      i = j ∨ i ≠ j by Logic.excluded_middle;
      done by cases {
        case i = j as atJ: {
            VectorSpace.bumpCoefficient(Function.updateAt(d, j, Field.zero(f)), d(j), j)(i)
               = VectorSpace.bumpCoefficient(Function.updateAt(d, j, Field.zero(f)), d(j), j)(j)
                     by substituting atJ
               = Function.updateAt(d, j, Field.zero(f))(j) + d(j)   by VectorSpace.bumpCoefficient_at
               = Field.zero(f) + d(j)                               by substituting czeroAtJ
               = d(j)
               = d(i)                                               by substituting atJ
          }
        case i ≠ j as offJ: {
            VectorSpace.bumpCoefficient(Function.updateAt(d, j, Field.zero(f)), d(j), j)(i)
               = Function.updateAt(d, j, Field.zero(f))(i)   by VectorSpace.bumpCoefficient_off
               = d(i)                                        by Function.updateAt_off
          }
      }
    } as bumpIsD;
  ∀ (i : Natural). i < n →
      VectorSpace.bumpCoefficient(Function.updateAt(d, j, Field.zero(f)), d(j), j)(i) • g(i)
      = d(i) • g(i)
    by { take i : Natural; suppose i < n as iLtN;
         VectorSpace.bumpCoefficient(Function.updateAt(d, j, Field.zero(f)), d(j), j)(i) = d(i)
             by bumpIsD as here;
         done by substituting here } as bumpTermsMatch;
  VectorSpace.standardCombination(g,
        VectorSpace.bumpCoefficient(Function.updateAt(d, j, Field.zero(f)), d(j), j), n)
     = VectorSpace.standardCombination(g, d, n)
       by VectorSpace.standardCombination_congruence as bumpCombIsD;
  VectorSpace.standardCombination(g, d, n)
     = VectorSpace.standardCombination(g,
           VectorSpace.bumpCoefficient(Function.updateAt(d, j, Field.zero(f)), d(j), j), n)
           by bumpCombIsD
     = VectorSpace.standardCombination(g, Function.updateAt(d, j, Field.zero(f)), n) + d(j) • g(j)
           by VectorSpace.standardCombination_bump
     as dSplit;
  VectorSpace.standardCombination(g, Function.updateAt(d, j, Field.zero(f)), n) + d(j) • g(j)
     = VectorSpace.standardCombination(g, d, n)   by dSplit
     = uu(k)                                       by ukStandard
     as ukSplit;
  -- Solve for g(j): d(j) • g(j) = uu(k) - [j-zeroed combination], both in span.
  d(j) • g(j)
     = (VectorSpace.standardCombination(g, Function.updateAt(d, j, Field.zero(f)), n) + d(j) • g(j))
       - VectorSpace.standardCombination(g, Function.updateAt(d, j, Field.zero(f)), n)
           by VectorSpace.add_subtract_cancel_left
     = uu(k) - VectorSpace.standardCombination(g, Function.updateAt(d, j, Field.zero(f)), n)
           by substituting ukSplit
     as dJgJ;
  VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)),
        uu(k) - VectorSpace.standardCombination(g, Function.updateAt(d, j, Field.zero(f)), n))
      by VectorSpace.InSpanOf.subtract;
  VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)), d(j) • g(j)) by substituting dJgJ;
  VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)), g(j))
      by VectorSpace.InSpanOf.scale_cancel as gJInSpan;
  -- Every old generator is now in the swapped span (slot j via the solve).
  ∀ (i : Natural). VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)), g(i))
    by {
      take i : Natural;
      i = j ∨ i ≠ j by Logic.excluded_middle;
      done by cases {
        case i = j as atJ: { done by substituting atJ }
        case i ≠ j as offJ: { done by offJInSpan }
      }
    } as allInSpan;
  -- Assemble the three invariant clauses for the swapped family.
  VectorSpace.Spans(VectorSpace.swapIn(g, k, j, uu(k)))
    by {
      take v : VectorSpace.carrier(V);
      VectorSpace.InSpanOf(g, v) by VectorSpace.InSpanOf.of_spans(inhabitant := 0);
      VectorSpace.InSpanOf(VectorSpace.swapIn(g, k, j, uu(k)), v)
          by VectorSpace.InSpanOf.transitive(outerInhabitant := 0);
      done
    } as newSpans;
  ∀ (i : Natural). n ≤ i → VectorSpace.swapIn(g, k, j, uu(k))(i) = VectorSpace.zero(V)
    by {
      take i : Natural;
      suppose n ≤ i as nLeI;
      k < i by { k < n ≤ i; done };
      i ≠ k by Natural.not_equal_of_greater_than;
      j < i by { j < n ≤ i; done };
      i ≠ j by Natural.not_equal_of_greater_than;
      VectorSpace.swapIn(g, k, j, uu(k))(i) = g(i) by VectorSpace.swapIn_off;
      done by gVanishesPast
    } as newVanishesPast;
  ∀ (i : Natural). i < 1 + k → VectorSpace.swapIn(g, k, j, uu(k))(i) = uu(i)
    by {
      take i : Natural;
      suppose i < 1 + k as iBelow;
      i < k ∨ i = k by Natural.le_of_lt_one_plus;
      done by cases {
        case i < k as belowK: {
            i ≠ k by Natural.not_equal_of_less_than;
            i < j by { i < k ≤ j; done };
            i ≠ j by Natural.not_equal_of_less_than;
            VectorSpace.swapIn(g, k, j, uu(k))(i) = g(i) by VectorSpace.swapIn_off;
            done by gAgreePrefix
          }
        case i = k as atK: {
            VectorSpace.swapIn(g, k, j, uu(k))(i)
               = VectorSpace.swapIn(g, k, j, uu(k))(k)   by substituting atK
               = uu(k)                                   by VectorSpace.swapIn_at_k
               = uu(i)                                   by substituting atK
          }
      }
    } as newAgreePrefix;
  witness VectorSpace.swapIn(g, k, j, uu(k))
    with And.introduction(newSpans, And.introduction(newVanishesPast, newAgreePrefix))
}

-- ----------------------------------------------------------------------
-- Iterating the swap: for every k ≤ n, a spanning family whose first k
-- entries are uu(0..k-1). Induction on k, one exchange step per increment.
theorem VectorSpace.exchange_build {f : Field} {V : VectorSpace(f)}
        (uu w : Natural → VectorSpace.carrier(V)) (m n : Natural)
        (independent : VectorSpace.StandardIndependentBelow(uu, m))
        (wVanishesPast : ∀ (i : Natural). n ≤ i → w(i) = VectorSpace.zero(V))
        (wSpans : VectorSpace.Spans(w)) (nBelowOrEqM : n ≤ m)
        : ∀ (k : Natural). k ≤ n →
              ∃ (gk : Natural → VectorSpace.carrier(V)).
                  VectorSpace.Spans(gk)
                  ∧ (∀ (i : Natural). n ≤ i → gk(i) = VectorSpace.zero(V))
                  ∧ (∀ (i : Natural). i < k → gk(i) = uu(i)) :=
  by induction on k with IH {
    case base: {
        suppose 0 ≤ n as zeroLeN;
        ∀ (i : Natural). i < 0 → w(i) = uu(i)
            by { take i : Natural; suppose i < 0 as below;
                 ¬(i < 0) by Natural.not_less_than_zero; done } as vacuousPrefix;
        witness w with And.introduction(wSpans, And.introduction(wVanishesPast, vacuousPrefix))
      }
    case step(q): {
        suppose 1 + q ≤ n as succLeN;
        q < n by { successor(q) ≤ n by Natural.LessThan.weaken; done } as qLtN;
        q ≤ n by Natural.LessThan.weaken as qLeN;
        ∃ (gq : Natural → VectorSpace.carrier(V)).
            VectorSpace.Spans(gq)
            ∧ (∀ (i : Natural). n ≤ i → gq(i) = VectorSpace.zero(V))
            ∧ (∀ (i : Natural). i < q → gq(i) = uu(i))
            by IH as fromIH;
        choose gq such that
            VectorSpace.Spans(gq)
            ∧ (∀ (i : Natural). n ≤ i → gq(i) = VectorSpace.zero(V))
            ∧ (∀ (i : Natural). i < q → gq(i) = uu(i))
            from fromIH;
        VectorSpace.Spans(gq) as gqSpans;
        ∀ (i : Natural). n ≤ i → gq(i) = VectorSpace.zero(V) as gqVanishesPast;
        ∀ (i : Natural). i < q → gq(i) = uu(i) as gqAgreePrefix;
        done by VectorSpace.exchange_step
      }
  }

-- ----------------------------------------------------------------------
-- The Steinitz exchange lemma (canonical-coordinate form): an independent
-- family is no larger than a spanning one. If `m > n`, build the family
-- whose first `n` slots are uu(0..n-1) and still spans; then uu(n) (which
-- exists) is a combination of uu(0..n-1), a nontrivial vanishing
-- combination of uu(0..n) once a `-1` is installed — contradicting
-- independence.
theorem VectorSpace.independent_le_spanning {f : Field} {V : VectorSpace(f)}
        (uu w : Natural → VectorSpace.carrier(V)) (m n : Natural)
        (independent : VectorSpace.StandardIndependentBelow(uu, m))
        (wVanishesPast : ∀ (i : Natural). n ≤ i → w(i) = VectorSpace.zero(V))
        (wSpans : VectorSpace.Spans(w))
        : m ≤ n := {
  suppose ¬(m ≤ n) as notLe for contradiction {
    n < m by Natural.lt_of_not_le as nLtM;
    n ≤ m by Natural.LessThan.weaken as nLeM;
    1 + n ≤ m by { successor(n) ≤ m by Natural.successor_le_of_lt; done } as succNLeM;
    -- The fully swapped family: first n slots are uu(0..n-1), still spans.
    ∃ (gn : Natural → VectorSpace.carrier(V)).
        VectorSpace.Spans(gn)
        ∧ (∀ (i : Natural). n ≤ i → gn(i) = VectorSpace.zero(V))
        ∧ (∀ (i : Natural). i < n → gn(i) = uu(i))
        by VectorSpace.exchange_build as built;
    choose gn such that
        VectorSpace.Spans(gn)
        ∧ (∀ (i : Natural). n ≤ i → gn(i) = VectorSpace.zero(V))
        ∧ (∀ (i : Natural). i < n → gn(i) = uu(i)) from built;
    VectorSpace.Spans(gn) as gnSpans;
    ∀ (i : Natural). n ≤ i → gn(i) = VectorSpace.zero(V) as gnVanishesPast;
    ∀ (i : Natural). i < n → gn(i) = uu(i) as gnAgreePrefix;
    -- Expand uu(n) in canonical coordinates over gn, then over uu.
    VectorSpace.InSpanOf(gn, uu(n)) by VectorSpace.InSpanOf.of_spans(inhabitant := 0) as unInSpan;
    choose count, selection, coeffs such that
        uu(n) = VectorSpace.linearCombination(gn, coeffs, selection, count) from unInSpan;
    uu(n) = VectorSpace.linearCombination(gn, coeffs, selection, count) as unLinComb;
    ∃ (d : Natural → Field.carrier(f)).
        VectorSpace.linearCombination(gn, coeffs, selection, count)
        = VectorSpace.standardCombination(gn, d, n)
        by VectorSpace.linearCombination_standardize as standardized;
    choose d such that
        VectorSpace.linearCombination(gn, coeffs, selection, count)
        = VectorSpace.standardCombination(gn, d, n) from standardized;
    VectorSpace.linearCombination(gn, coeffs, selection, count)
        = VectorSpace.standardCombination(gn, d, n) as linCombStd;
    uu(n) = VectorSpace.linearCombination(gn, coeffs, selection, count)   by unLinComb
          = VectorSpace.standardCombination(gn, d, n)                     by linCombStd
          as unStandardGn;
    ∀ (i : Natural). i < n → d(i) • gn(i) = d(i) • uu(i)
      by { take i : Natural; suppose i < n as iLtN;
           gn(i) = uu(i) by gnAgreePrefix as gnAtI; done by substituting gnAtI } as termsMatch;
    VectorSpace.standardCombination(gn, d, n) = VectorSpace.standardCombination(uu, d, n)
        by VectorSpace.standardCombination_congruence as gnToUu;
    uu(n) = VectorSpace.standardCombination(gn, d, n)   by unStandardGn
          = VectorSpace.standardCombination(uu, d, n)   by gnToUu
          as unStandardUu;
    -- Install -1 at slot n: a vanishing combination of uu(0..n).
    Function.updateAt(d, n, Field.negate(Field.one(f)))(n) = Field.negate(Field.one(f))
        by Function.updateAt_at as eAtN;
    ∀ (i : Natural). i < n →
        Function.updateAt(d, n, Field.negate(Field.one(f)))(i) • uu(i) = d(i) • uu(i)
      by { take i : Natural; suppose i < n as iLtN;
           i ≠ n by Natural.not_equal_of_less_than;
           Function.updateAt(d, n, Field.negate(Field.one(f)))(i) = d(i)
               by Function.updateAt_off as eAtI; done by substituting eAtI } as eBelowMatch;
    VectorSpace.standardCombination(uu, Function.updateAt(d, n, Field.negate(Field.one(f))), n)
        = VectorSpace.standardCombination(uu, d, n)
        by VectorSpace.standardCombination_congruence as eCombBelow;
    VectorSpace.standardCombination(uu, Function.updateAt(d, n, Field.negate(Field.one(f))), 1 + n)
       = VectorSpace.standardCombination(uu, Function.updateAt(d, n, Field.negate(Field.one(f))), n)
         + Function.updateAt(d, n, Field.negate(Field.one(f)))(n) • uu(n)
             by VectorSpace.standardCombination_add_one
       = VectorSpace.standardCombination(uu, d, n)
         + Function.updateAt(d, n, Field.negate(Field.one(f)))(n) • uu(n)
             by eCombBelow
       = VectorSpace.standardCombination(uu, d, n) + Field.negate(Field.one(f)) • uu(n)
             by substituting eAtN
       = uu(n) + Field.negate(Field.one(f)) • uu(n)   by unStandardUu
       = uu(n) + VectorSpace.negate(uu(n))            by VectorSpace.negate_one_scale
       = uu(n) - uu(n)
       = VectorSpace.zero(V)
       as eVanishes;
    ∀ (i : Natural). i < 1 + n → Function.updateAt(d, n, Field.negate(Field.one(f)))(i) = Field.zero(f)
        by independent as eAllZero;
    Function.updateAt(d, n, Field.negate(Field.one(f)))(n) = Field.zero(f)
        by eAllZero as eNzero;
    Field.negate(Field.one(f))
       = Function.updateAt(d, n, Field.negate(Field.one(f)))(n)   by eAtN
       = Field.zero(f)                                            by eNzero;
    Field.negate(Field.one(f)) ≠ Field.zero(f) by Field.negate_one_nonzero;
    done
  }
}

-- ----------------------------------------------------------------------
-- The packaging bridge to the index-generic predicates. The core works
-- with total `Natural`-indexed families; a `NaturalsBelow(m)`-indexed one
-- is extended to a total map by filling a fallback past the bound. The
-- `yes` arm of the classical decision supplies the proof that forms the
-- bounded index — a value-level dependent conditional, the same shape as
-- `Rational.minimumWithDecision`. Generic in the codomain `A` (a bare type
-- variable dodges the "cases motive not a Sort" quirk `Field.carrier` /
-- `VectorSpace.carrier` as the return type would trip).

definition Function.extendBelowWithDecision {A : Type(0)} {m : Natural}
        (u : NaturalsBelow(m) → A) (fallback : A) (i : Natural)
        : Logic.Decidable(i < m) → A
  | Logic.Decidable.yes(below) => u(NaturalsBelow.make(i, below))
  | Logic.Decidable.no(_)      => fallback

definition Function.extendBelow {A : Type(0)} {m : Natural}
        (u : NaturalsBelow(m) → A) (fallback : A) : Natural → A :=
  (i : Natural) ↦
    Function.extendBelowWithDecision(u, fallback, i, Logic.classical_decidable(i < m))

-- Below the bound the extension reads the family at the bounded index;
-- at or past it, the fallback. Proof irrelevance identifies the decision's
-- internal proof with the caller's `below`.
theorem Function.extendBelow_below {A : Type(0)} {m : Natural}
        (u : NaturalsBelow(m) → A) (fallback : A) (i : Natural) (below : i < m)
        : Function.extendBelow(u, fallback)(i) = u(NaturalsBelow.make(i, below)) :=
  if i < m
  then done
  else { False; done }

theorem Function.extendBelow_past {A : Type(0)} {m : Natural}
        (u : NaturalsBelow(m) → A) (fallback : A) (i : Natural) (past : m ≤ i)
        : Function.extendBelow(u, fallback)(i) = fallback :=
  if i < m
  then { i < i by { i < m ≤ i; done }; ¬(i < i) by Natural.lt_irreflexive; done }
  else done

-- The canonical clamped inclusion `Natural → NaturalsBelow(m)`: the value
-- itself below the bound, a fixed fallback index at or past it. This is the
-- reusable "reindex into the finite type" helper (`extendBelow` of the
-- identity family); needs an inhabitant of `NaturalsBelow(m)`, i.e. m > 0.
definition NaturalsBelow.inclusion {m : Natural} (fallback : NaturalsBelow(m))
        : Natural → NaturalsBelow(m) :=
  Function.extendBelow((x : NaturalsBelow(m)) ↦ x, fallback)

theorem NaturalsBelow.inclusion_below {m : Natural} (fallback : NaturalsBelow(m))
        (i : Natural) (below : i < m)
        : NaturalsBelow.inclusion(fallback)(i) = NaturalsBelow.make(i, below) :=
  NaturalsBelow.inclusion(fallback)(i)
     = ((x : NaturalsBelow(m)) ↦ x)(NaturalsBelow.make(i, below))   by Function.extendBelow_below
     = NaturalsBelow.make(i, below)

-- ----------------------------------------------------------------------
-- The official Steinitz exchange lemma over the index-generic predicates:
-- a linearly independent `NaturalsBelow(m)`-family is no larger than a
-- spanning `NaturalsBelow(n)`-family. Extend both to total `Natural`-indexed
-- maps (fallback zero), transport independence and spanning across the
-- reindexing with `linearCombination_congruence`, and feed the
-- canonical-coordinate core. The m = 0 case is immediate (0 ≤ n); m > 0
-- supplies the fallback index the clamped selection needs.
theorem VectorSpace.exchange {f : Field} {V : VectorSpace(f)} (m n : Natural)
        (u : NaturalsBelow(m) → VectorSpace.carrier(V))
        (w : NaturalsBelow(n) → VectorSpace.carrier(V))
        (independent : VectorSpace.LinearlyIndependent(u))
        (spanning : VectorSpace.Spans(w))
        : m ≤ n :=
  done by cases {
    case m = 0: { done by Natural.zero_least }
    case m = 1 + predecessor for some (predecessor : Natural) as mShape: {
        1 ≤ m by { 1 ≤ 1 + predecessor; done by substituting mShape };
        0 < m by Natural.zero_lt_of_one_le as mPositive;

        -- Independence transports: a vanishing standard combination of the
        -- extended family is a vanishing combination of `u` under the
        -- clamped selection, whose coefficients `u`'s independence kills.
        VectorSpace.StandardIndependentBelow(Function.extendBelow(u, VectorSpace.zero(V)), m)
          by {
            take len : Natural;
            take coefficients : Natural → Field.carrier(f);
            suppose len ≤ m as lenLeM;
            suppose VectorSpace.standardCombination(
                        Function.extendBelow(u, VectorSpace.zero(V)), coefficients, len)
                      = VectorSpace.zero(V) as combVanishes;

            ∀ (a b : Natural). a < len → b < len →
                NaturalsBelow.inclusion(NaturalsBelow.make(0, mPositive))(a)
                = NaturalsBelow.inclusion(NaturalsBelow.make(0, mPositive))(b) → a = b
              by {
                take a : Natural; take b : Natural;
                suppose a < len as aLtLen;
                suppose b < len as bLtLen;
                suppose NaturalsBelow.inclusion(NaturalsBelow.make(0, mPositive))(a)
                        = NaturalsBelow.inclusion(NaturalsBelow.make(0, mPositive))(b) as selEq;
                a < m by { a < len ≤ m; done } as aLtM;
                b < m by { b < len ≤ m; done } as bLtM;
                NaturalsBelow.inclusion(NaturalsBelow.make(0, mPositive))(a)
                    = NaturalsBelow.make(a, aLtM) by NaturalsBelow.inclusion_below as selA;
                NaturalsBelow.inclusion(NaturalsBelow.make(0, mPositive))(b)
                    = NaturalsBelow.make(b, bLtM) by NaturalsBelow.inclusion_below as selB;
                a = NaturalsBelow.value(NaturalsBelow.make(a, aLtM))
                  = NaturalsBelow.value(NaturalsBelow.inclusion(NaturalsBelow.make(0, mPositive))(a))
                        by selA
                  = NaturalsBelow.value(NaturalsBelow.inclusion(NaturalsBelow.make(0, mPositive))(b))
                        by substituting selEq
                  = NaturalsBelow.value(NaturalsBelow.make(b, bLtM))   by selB
                  = b;
                done
              } as selInjective;

            ∀ (k : Natural). k < len →
                coefficients(k) • Function.extendBelow(u, VectorSpace.zero(V))(k)
                = coefficients(k) • u(NaturalsBelow.inclusion(NaturalsBelow.make(0, mPositive))(k))
              by {
                take k : Natural;
                suppose k < len as kLtLen;
                k < m by { k < len ≤ m; done } as kLtM;
                Function.extendBelow(u, VectorSpace.zero(V))(k) = u(NaturalsBelow.make(k, kLtM))
                    by Function.extendBelow_below as uuAtK;
                NaturalsBelow.inclusion(NaturalsBelow.make(0, mPositive))(k)
                    = NaturalsBelow.make(k, kLtM) by NaturalsBelow.inclusion_below as selAtK;
                coefficients(k) • Function.extendBelow(u, VectorSpace.zero(V))(k)
                   = coefficients(k) • u(NaturalsBelow.make(k, kLtM))   by substituting uuAtK
                   = coefficients(k) • u(NaturalsBelow.inclusion(NaturalsBelow.make(0, mPositive))(k))
                         by substituting selAtK
              } as termsAgreeIndep;

            VectorSpace.standardCombination(Function.extendBelow(u, VectorSpace.zero(V)), coefficients, len)
               = VectorSpace.linearCombination(Function.extendBelow(u, VectorSpace.zero(V)),
                     coefficients, (i : Natural) ↦ i, len)
               = VectorSpace.linearCombination(u, coefficients,
                     NaturalsBelow.inclusion(NaturalsBelow.make(0, mPositive)), len)
                     by VectorSpace.linearCombination_congruence
               as combReindex;
            VectorSpace.linearCombination(u, coefficients,
                  NaturalsBelow.inclusion(NaturalsBelow.make(0, mPositive)), len)
               = VectorSpace.standardCombination(Function.extendBelow(u, VectorSpace.zero(V)),
                     coefficients, len)   by combReindex
               = VectorSpace.zero(V)      by combVanishes
               as uCombVanishes;

            done by independent
          } as uuIndependent;

        -- Spanning transports: reindex the witnessing combination's selection
        -- from `NaturalsBelow(n)` to `Natural` through the underlying values.
        VectorSpace.Spans(Function.extendBelow(w, VectorSpace.zero(V)))
          by {
            take v : VectorSpace.carrier(V);
            v = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(w, v) by spanning;
            done by cases {
              case v = VectorSpace.zero(V) as vZero: { done }
              case VectorSpace.InSpanOf(w, v) as vInSpan: {
                  choose count, selection, coefficients such that
                      v = VectorSpace.linearCombination(w, coefficients, selection, count)
                      from vInSpan;
                  v = VectorSpace.linearCombination(w, coefficients, selection, count) as vComb;

                  ∀ (k : Natural). k < count →
                      coefficients(k) • w(selection(k))
                      = coefficients(k)
                        • Function.extendBelow(w, VectorSpace.zero(V))(NaturalsBelow.value(selection(k)))
                    by {
                      take k : Natural;
                      suppose k < count as kLtCount;
                      NaturalsBelow.value(selection(k)) < n by NaturalsBelow.below as valueBelow;
                      Function.extendBelow(w, VectorSpace.zero(V))(NaturalsBelow.value(selection(k)))
                         = w(NaturalsBelow.make(NaturalsBelow.value(selection(k)), valueBelow))
                               by Function.extendBelow_below
                         = w(selection(k))   by NaturalsBelow.equal_of_value
                         as extAtK;
                      done by substituting extAtK
                    } as termsAgreeSpan;

                  v = VectorSpace.linearCombination(w, coefficients, selection, count)   by vComb
                    = VectorSpace.linearCombination(Function.extendBelow(w, VectorSpace.zero(V)),
                          coefficients, (k : Natural) ↦ NaturalsBelow.value(selection(k)), count)
                          by VectorSpace.linearCombination_congruence
                    as vExtComb;
                  VectorSpace.InSpanOf(Function.extendBelow(w, VectorSpace.zero(V)), v)
                    by { witness count
                             with witness ((k : Natural) ↦ NaturalsBelow.value(selection(k)))
                             with witness coefficients with vExtComb };
                  done
                }
            }
          } as wExtSpans;

        ∀ (i : Natural). n ≤ i → Function.extendBelow(w, VectorSpace.zero(V))(i) = VectorSpace.zero(V)
          by {
            take i : Natural;
            suppose n ≤ i as nLeI;
            done by Function.extendBelow_past
          } as wExtVanishesPast;

        done by VectorSpace.independent_le_spanning
    }
  }

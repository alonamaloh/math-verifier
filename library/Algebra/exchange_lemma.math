-- Algebra/exchange_lemma.math
--
-- The Steinitz exchange lemma: an independent family is no larger than a
-- spanning one. The classical one-swap-at-a-time argument, where
-- `Field.reciprocal` finally earns its keep — a vector selected with a
-- nonzero coefficient is solved for by dividing by that coefficient.
--
-- This file builds the reusable bricks first (dividing a nonzero scalar
-- out of a span membership; normalising an arbitrary combination to
-- canonical coordinates) and then the exchange induction on top of them.

module Algebra.exchange_lemma

import axioms
import Logic.basics
import Logic.exists
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.division
import Natural.monus
import Natural.classical_decidable
import Natural.least_number
import Set.subtype
import Set.finite
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.aggregation
import Algebra.ring
import Algebra.ring_lemmas
import Algebra.field
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.field_bundle
import Algebra.vector_space
import Algebra.vector_space_lemmas
import Algebra.linear_combination
import Algebra.span

-- ----------------------------------------------------------------------
-- Dividing out a nonzero scalar (where `Field.reciprocal` enters).

-- Scaling by a nonzero scalar is undone by scaling by its reciprocal.
theorem VectorSpace.scale_reciprocal_cancel {f : Field} (V : VectorSpace(f))
        (a : Field.carrier(f)) (nonzero : a ≠ Field.zero(f)) (v : VectorSpace.carrier(V))
        : Field.reciprocal(a, nonzero) • (a • v) = v := {
  Field.reciprocal(a, nonzero) * a
     = a * Field.reciprocal(a, nonzero)
     = Field.one(f)                              by Field.reciprocal_multiplies
     as reciprocalOnLeft;
  Field.reciprocal(a, nonzero) • (a • v)
     = (Field.reciprocal(a, nonzero) * a) • v    by VectorSpace.scale_scalar_multiply
     = Field.one(f) • v                          by substituting reciprocalOnLeft
     = v                                         by VectorSpace.one_scale
}

-- If a nonzero multiple of `v` lies in a span, so does `v` itself: scale
-- the membership by the reciprocal.
theorem VectorSpace.InSpanOf.scale_cancel {f : Field} {V : VectorSpace(f)} {I : Type(0)}
        (family : I → VectorSpace.carrier(V))
        (a : Field.carrier(f)) (nonzero : a ≠ Field.zero(f))
        (v : VectorSpace.carrier(V))
        (member : VectorSpace.InSpanOf(family, a • v))
        : VectorSpace.InSpanOf(family, v) := {
  VectorSpace.InSpanOf(family, Field.reciprocal(a, nonzero) • (a • v))
      by VectorSpace.InSpanOf.scale;
  Field.reciprocal(a, nonzero) • (a • v) = v
      by VectorSpace.scale_reciprocal_cancel as cancelReciprocal;
  done by substituting cancelReciprocal
}

-- ----------------------------------------------------------------------
-- Canonical (identity-selection) combinations. `standardCombination(g, c, n)`
-- is Σ_{i<n} c(i) • g(i): the linear combination whose selection is the
-- identity, so the coefficient on `g(i)` is literally `c(i)`. Working in
-- these coordinates is what makes "the coefficient at a given slot" a
-- meaningful quantity for the exchange step.

definition VectorSpace.standardCombination {f : Field} {V : VectorSpace(f)}
        (g : Natural → VectorSpace.carrier(V))
        (coefficients : Natural → Field.carrier(f)) (count : Natural)
        : VectorSpace.carrier(V) :=
  VectorSpace.linearCombination(g, coefficients, (i : Natural) ↦ i, count)

-- Peel the last term.
theorem VectorSpace.standardCombination_add_one {f : Field} {V : VectorSpace(f)}
        (g : Natural → VectorSpace.carrier(V))
        (coefficients : Natural → Field.carrier(f)) (count : Natural)
        : VectorSpace.standardCombination(g, coefficients, 1 + count)
          = VectorSpace.standardCombination(g, coefficients, count)
            + coefficients(count) • g(count) :=
  VectorSpace.standardCombination(g, coefficients, 1 + count)
     = VectorSpace.linearCombination(g, coefficients, (i : Natural) ↦ i, count)
       + coefficients(count) • g(count)
           by VectorSpace.linearCombination_add_one
     = VectorSpace.standardCombination(g, coefficients, count)
       + coefficients(count) • g(count)

-- Two standard combinations agree when their terms agree below the count —
-- even when both the family and the coefficients differ, provided the
-- scaled vectors coincide index by index.
theorem VectorSpace.standardCombination_congruence {f : Field} {V : VectorSpace(f)}
        (g1 g2 : Natural → VectorSpace.carrier(V))
        (c1 c2 : Natural → Field.carrier(f)) (n : Natural)
        (termsAgree : ∀ (i : Natural). i < n → c1(i) • g1(i) = c2(i) • g2(i))
        : VectorSpace.standardCombination(g1, c1, n)
          = VectorSpace.standardCombination(g2, c2, n) := {
  VectorSpace.standardCombination(g1, c1, n)
     = Algebra.indexedAggregate(VectorSpace.carrier(V), VectorSpace.add, VectorSpace.zero(V),
           (i : Natural) ↦ c1(i) • g1(i), n)
     = Algebra.indexedAggregate(VectorSpace.carrier(V), VectorSpace.add, VectorSpace.zero(V),
           (i : Natural) ↦ c2(i) • g2(i), n)
           by Algebra.indexedAggregate_pointwise_below
     = VectorSpace.standardCombination(g2, c2, n)
}

-- Overwriting one point of a function. Generic in the codomain `A` (a bare
-- type variable — `Field.carrier(f)` or `VectorSpace.carrier(V)` as the
-- conditional's return type trips "cases motive not a Sort", the same
-- generalisation `combineFunctions` makes).
definition Function.updateAt {A : Type(0)} (h : Natural → A) (pos : Natural) (newValue : A)
        : Natural → A :=
  (i : Natural) ↦ if i = pos then newValue else h(i)

theorem Function.updateAt_at {A : Type(0)} (h : Natural → A) (pos : Natural) (newValue : A)
        : Function.updateAt(h, pos, newValue)(pos) = newValue :=
  done by Logic.if_positive

theorem Function.updateAt_off {A : Type(0)} (h : Natural → A) (pos i : Natural)
        (newValue : A) (distinct : i ≠ pos)
        : Function.updateAt(h, pos, newValue)(i) = h(i) :=
  done by Logic.if_negative

-- The coefficients `d` with position `pos` raised by `e`.
definition VectorSpace.bumpCoefficient {f : Field} (d : Natural → Field.carrier(f))
        (e : Field.carrier(f)) (pos : Natural) : Natural → Field.carrier(f) :=
  Function.updateAt(d, pos, d(pos) + e)

theorem VectorSpace.bumpCoefficient_at {f : Field} (d : Natural → Field.carrier(f))
        (e : Field.carrier(f)) (pos : Natural)
        : VectorSpace.bumpCoefficient(d, e, pos)(pos) = d(pos) + e :=
  done by Function.updateAt_at

theorem VectorSpace.bumpCoefficient_off {f : Field} (d : Natural → Field.carrier(f))
        (e : Field.carrier(f)) (pos i : Natural) (distinct : i ≠ pos)
        : VectorSpace.bumpCoefficient(d, e, pos)(i) = d(i) :=
  done by Function.updateAt_off

-- Bumping the coefficient at one position by `e` adds `e • g(pos)` to the
-- combination. This is what lets an arbitrary combination be rebuilt in
-- canonical coordinates one term at a time, and what installs the `-1`
-- coefficient the independence contradiction needs.
theorem VectorSpace.standardCombination_bump {f : Field} {V : VectorSpace(f)}
        (g : Natural → VectorSpace.carrier(V)) (d : Natural → Field.carrier(f))
        (e : Field.carrier(f)) (pos n : Natural) (posBelow : pos < n)
        : VectorSpace.standardCombination(g, VectorSpace.bumpCoefficient(d, e, pos), n)
          = VectorSpace.standardCombination(g, d, n) + e • g(pos) :=
  by induction on n with IH {
    case base: {
        ¬(pos < 0) by Natural.not_less_than_zero;
        done
      }
    case step(q): {
        pos < q ∨ pos = q by Natural.le_of_lt_one_plus;
        done by cases {
          case pos < q as posLtQ: {
              q ≠ pos by Natural.not_equal_of_greater_than;
              VectorSpace.bumpCoefficient(d, e, pos)(q) = d(q)
                  by VectorSpace.bumpCoefficient_off as bumpAtQ;
              VectorSpace.standardCombination(g, VectorSpace.bumpCoefficient(d, e, pos), 1 + q)
                 = VectorSpace.standardCombination(g, VectorSpace.bumpCoefficient(d, e, pos), q)
                   + VectorSpace.bumpCoefficient(d, e, pos)(q) • g(q)
                       by VectorSpace.standardCombination_add_one
                 = (VectorSpace.standardCombination(g, d, q) + e • g(pos))
                   + VectorSpace.bumpCoefficient(d, e, pos)(q) • g(q)
                       by IH
                 = (VectorSpace.standardCombination(g, d, q) + e • g(pos)) + d(q) • g(q)
                       by substituting bumpAtQ
                 = VectorSpace.standardCombination(g, d, q) + (e • g(pos) + d(q) • g(q))
                 = VectorSpace.standardCombination(g, d, q) + (d(q) • g(q) + e • g(pos))
                       by VectorSpace.add_commutative
                 = (VectorSpace.standardCombination(g, d, q) + d(q) • g(q)) + e • g(pos)
                 = VectorSpace.standardCombination(g, d, 1 + q) + e • g(pos)
                       by VectorSpace.standardCombination_add_one
            }
          case pos = q as posEqQ: {
              q = pos by posEqQ as qEqPos;
              VectorSpace.bumpCoefficient(d, e, pos)(q)
                 = VectorSpace.bumpCoefficient(d, e, pos)(pos)   by substituting qEqPos
                 = d(pos) + e                                    by VectorSpace.bumpCoefficient_at
                 = d(q) + e                                      by substituting posEqQ
                 as bumpAtQ;
              ∀ (i : Natural). i < q →
                  VectorSpace.bumpCoefficient(d, e, pos)(i) • g(i) = d(i) • g(i)
                by {
                  take i : Natural;
                  suppose i < q as iLtQ;
                  i < pos by substituting posEqQ;
                  i ≠ pos by Natural.not_equal_of_less_than;
                  VectorSpace.bumpCoefficient(d, e, pos)(i) = d(i)
                      by VectorSpace.bumpCoefficient_off as bumpAtI;
                  done by substituting bumpAtI
                };
              VectorSpace.standardCombination(g, VectorSpace.bumpCoefficient(d, e, pos), q)
                 = VectorSpace.standardCombination(g, d, q)
                     by VectorSpace.standardCombination_congruence as reduceBelow;
              VectorSpace.standardCombination(g, VectorSpace.bumpCoefficient(d, e, pos), 1 + q)
                 = VectorSpace.standardCombination(g, VectorSpace.bumpCoefficient(d, e, pos), q)
                   + VectorSpace.bumpCoefficient(d, e, pos)(q) • g(q)
                       by VectorSpace.standardCombination_add_one
                 = VectorSpace.standardCombination(g, d, q)
                   + VectorSpace.bumpCoefficient(d, e, pos)(q) • g(q)
                       by substituting reduceBelow
                 = VectorSpace.standardCombination(g, d, q) + (d(q) + e) • g(q)
                       by substituting bumpAtQ
                 = VectorSpace.standardCombination(g, d, q) + (d(q) • g(q) + e • g(q))
                 = (VectorSpace.standardCombination(g, d, q) + d(q) • g(q)) + e • g(q)
                 = VectorSpace.standardCombination(g, d, 1 + q) + e • g(q)
                       by VectorSpace.standardCombination_add_one
                 = VectorSpace.standardCombination(g, d, 1 + q) + e • g(pos)
                       by substituting posEqQ
            }
        }
      }
  }

-- ----------------------------------------------------------------------
-- Two more span-closure facts (the subspace laws not yet recorded): the
-- zero vector is in every span with an inhabited index, and spans are
-- closed under subtraction.

theorem VectorSpace.InSpanOf.zero {f : Field} {V : VectorSpace(f)} {I : Type(0)}
        (family : I → VectorSpace.carrier(V)) (inhabitant : I)
        : VectorSpace.InSpanOf(family, VectorSpace.zero(V)) := {
  VectorSpace.InSpanOf(family, family(inhabitant)) by VectorSpace.InSpanOf.member;
  VectorSpace.InSpanOf(family, Field.zero(f) • family(inhabitant)) by VectorSpace.InSpanOf.scale;
  Field.zero(f) • family(inhabitant) = VectorSpace.zero(V)
      by VectorSpace.zero_scale as zeroIsZero;
  done by substituting zeroIsZero
}

theorem VectorSpace.InSpanOf.subtract {f : Field} {V : VectorSpace(f)} {I : Type(0)}
        (family : I → VectorSpace.carrier(V)) (u v : VectorSpace.carrier(V))
        (uMember : VectorSpace.InSpanOf(family, u))
        (vMember : VectorSpace.InSpanOf(family, v))
        : VectorSpace.InSpanOf(family, u - v) := {
  VectorSpace.InSpanOf(family, Field.negate(Field.one(f)) • v) by VectorSpace.InSpanOf.scale;
  VectorSpace.InSpanOf(family, u + Field.negate(Field.one(f)) • v) by VectorSpace.InSpanOf.add;
  u + Field.negate(Field.one(f)) • v
     = u + VectorSpace.negate(v)   by VectorSpace.negate_one_scale
     = u - v
     as rewriteSubtract;
  done by substituting rewriteSubtract
}

-- ----------------------------------------------------------------------
-- Normalising an arbitrary combination to canonical coordinates. When the
-- family vanishes past `n`, every combination of it — whatever selection
-- and length — is a standard combination Σ_{i<n} d(i) • g(i). This is what
-- lets the exchange step read off "the coefficient at slot j".

-- The all-zero standard combination is the zero vector.
theorem VectorSpace.standardCombination_zero_coefficients {f : Field} {V : VectorSpace(f)}
        (g : Natural → VectorSpace.carrier(V)) (n : Natural)
        : VectorSpace.standardCombination(g, (i : Natural) ↦ Field.zero(f), n)
          = VectorSpace.zero(V) :=
  by induction on n with IH {
    case base: done
    case step(q):
        VectorSpace.standardCombination(g, (i : Natural) ↦ Field.zero(f), 1 + q)
           = VectorSpace.standardCombination(g, (i : Natural) ↦ Field.zero(f), q)
             + Field.zero(f) • g(q)
                 by VectorSpace.standardCombination_add_one
           = VectorSpace.zero(V) + Field.zero(f) • g(q)   by IH
           = VectorSpace.zero(V) + VectorSpace.zero(V)     by VectorSpace.zero_scale
           = VectorSpace.zero(V)
  }

theorem VectorSpace.linearCombination_standardize {f : Field} {V : VectorSpace(f)}
        (g : Natural → VectorSpace.carrier(V)) (n : Natural)
        (vanishesPast : ∀ (i : Natural). n ≤ i → g(i) = VectorSpace.zero(V))
        (coefficients : Natural → Field.carrier(f)) (selection : Natural → Natural)
        (count : Natural)
        : ∃ (d : Natural → Field.carrier(f)).
              VectorSpace.linearCombination(g, coefficients, selection, count)
              = VectorSpace.standardCombination(g, d, n) :=
  by induction on count with IH {
    case base: {
        VectorSpace.linearCombination(g, coefficients, selection, 0) = VectorSpace.zero(V);
        VectorSpace.zero(V) = VectorSpace.standardCombination(g, (i : Natural) ↦ Field.zero(f), n)
            by VectorSpace.standardCombination_zero_coefficients;
        VectorSpace.linearCombination(g, coefficients, selection, 0)
            = VectorSpace.standardCombination(g, (i : Natural) ↦ Field.zero(f), n)
            as baseGoal;
        witness ((i : Natural) ↦ Field.zero(f)) with baseGoal
      }
    case step(p): {
        choose d such that
            VectorSpace.linearCombination(g, coefficients, selection, p)
            = VectorSpace.standardCombination(g, d, n)
            from IH;
        VectorSpace.linearCombination(g, coefficients, selection, p)
            = VectorSpace.standardCombination(g, d, n) as headStandardEq;
        VectorSpace.linearCombination(g, coefficients, selection, 1 + p)
           = VectorSpace.linearCombination(g, coefficients, selection, p)
             + coefficients(p) • g(selection(p))
                 by VectorSpace.linearCombination_add_one
           = VectorSpace.standardCombination(g, d, n) + coefficients(p) • g(selection(p))
                 by substituting headStandardEq
           as peeled;
        selection(p) < n ∨ n ≤ selection(p) by Natural.lt_or_le;
        done by cases {
          case selection(p) < n as inRange: {
              VectorSpace.standardCombination(g,
                    VectorSpace.bumpCoefficient(d, coefficients(p), selection(p)), n)
                 = VectorSpace.standardCombination(g, d, n)
                   + coefficients(p) • g(selection(p))
                     by VectorSpace.standardCombination_bump;
              VectorSpace.linearCombination(g, coefficients, selection, 1 + p)
                 = VectorSpace.standardCombination(g,
                       VectorSpace.bumpCoefficient(d, coefficients(p), selection(p)), n)
                 as stepGoal;
              witness VectorSpace.bumpCoefficient(d, coefficients(p), selection(p)) with stepGoal
            }
          case n ≤ selection(p) as outRange: {
              g(selection(p)) = VectorSpace.zero(V) by vanishesPast as vanishHere;
              coefficients(p) • g(selection(p))
                 = coefficients(p) • VectorSpace.zero(V)   by substituting vanishHere
                 = VectorSpace.zero(V)                     by VectorSpace.scale_zero
                 as termVanishes;
              VectorSpace.linearCombination(g, coefficients, selection, 1 + p)
                 = VectorSpace.standardCombination(g, d, n) + coefficients(p) • g(selection(p))
                       by peeled
                 = VectorSpace.standardCombination(g, d, n) + VectorSpace.zero(V)
                       by substituting termVanishes
                 = VectorSpace.standardCombination(g, d, n)
                 as stepGoal;
              witness d with stepGoal
            }
        }
      }
  }

-- ----------------------------------------------------------------------
-- The exchange induction proper. Everything below works with `Natural`-
-- indexed families and the bounded predicates a swap needs; the bridge to
-- the index-generic `Spans`/`LinearlyIndependent` is a thin layer above.

-- Independence in canonical coordinates: no nontrivial standard combination
-- of the first `bound` vectors vanishes. Implied by (and used in place of)
-- the index-generic `LinearlyIndependent`, since the identity selection is
-- injective.
definition VectorSpace.StandardIndependentBelow {f : Field} {V : VectorSpace(f)}
        (uu : Natural → VectorSpace.carrier(V)) (bound : Natural) : Proposition :=
  ∀ (len : Natural) (coefficients : Natural → Field.carrier(f)).
      len ≤ bound
      → VectorSpace.standardCombination(uu, coefficients, len) = VectorSpace.zero(V)
      → ∀ (i : Natural). i < len → coefficients(i) = Field.zero(f)

-- Minus one is nonzero — the field is nontrivial.
theorem Field.negate_one_nonzero (f : Field)
        : Field.negate(Field.one(f)) ≠ Field.zero(f) := {
  suppose Field.negate(Field.one(f)) = Field.zero(f) as negOneZero;
  Field.one(f)
     = Field.negate(Field.negate(Field.one(f)))
     = Field.negate(Field.zero(f))              by substituting negOneZero
     = Field.zero(f)
     as oneIsZero;
  Field.zero(f) = Field.one(f) by oneIsZero;
  Field.zero(f) ≠ Field.one(f) by Field.nontrivial;
  done
}

-- Extracting the swap target: when `uu(k)` is expanded in a family whose
-- first `k` entries are `uu(0..k-1)`, independence of `uu(0..k)` forces some
-- REMAINING slot (index in [k, n)) to carry a nonzero coefficient. If none
-- did, the expansion would present `uu(k)` as a combination of the earlier
-- `uu`'s, and installing a `-1` at slot `k` would be a nontrivial vanishing
-- combination of `uu(0..k)`.
theorem VectorSpace.exchange_find_pivot {f : Field} {V : VectorSpace(f)}
        (uu g : Natural → VectorSpace.carrier(V)) (m k n : Natural)
        (independent : VectorSpace.StandardIndependentBelow(uu, m))
        (agreePrefix : ∀ (i : Natural). i < k → g(i) = uu(i))
        (kBelowN : k < n) (nBelowOrEqM : n ≤ m)
        (coefficients : Natural → Field.carrier(f))
        (target : uu(k) = VectorSpace.standardCombination(g, coefficients, n))
        : ∃ (j : Natural). k ≤ j ∧ j < n ∧ coefficients(j) ≠ Field.zero(f) := {
  suppose ¬(∃ (j : Natural). k ≤ j ∧ j < n ∧ coefficients(j) ≠ Field.zero(f)) as noPivot
      for contradiction {
        ∀ (j : Natural). k ≤ j → j < n → coefficients(j) = Field.zero(f)
          by {
            take j : Natural;
            suppose k ≤ j as kLeJ;
            suppose j < n as jLtN;
            suppose coefficients(j) ≠ Field.zero(f) as coefficientNonzero for contradiction {
              ∃ (jj : Natural). k ≤ jj ∧ jj < n ∧ coefficients(jj) ≠ Field.zero(f)
                by { witness j with
                     And.introduction(kLeJ, And.introduction(jLtN, coefficientNonzero)) };
              done
            }
          } as allZeroRemaining;
        ∀ (i : Natural). i < n → coefficients(i) • g(i) = coefficients(i) • uu(i)
          by {
            take i : Natural;
            suppose i < n as iLtN;
            i < k ∨ k ≤ i by Natural.lt_or_le;
            done by cases {
              case i < k as iLtK: {
                  g(i) = uu(i) by agreePrefix as gIsUu;
                  done by substituting gIsUu
                }
              case k ≤ i as kLeI: {
                  coefficients(i) = Field.zero(f) by allZeroRemaining as coeffZero;
                  coefficients(i) • g(i)
                     = Field.zero(f) • g(i)     by substituting coeffZero
                     = VectorSpace.zero(V)      by VectorSpace.zero_scale
                     = Field.zero(f) • uu(i)    by VectorSpace.zero_scale
                     = coefficients(i) • uu(i)  by substituting coeffZero
                }
            }
          };
        VectorSpace.standardCombination(g, coefficients, n)
           = VectorSpace.standardCombination(uu, coefficients, n)
             by VectorSpace.standardCombination_congruence as gToUu;
        VectorSpace.standardCombination(uu, coefficients, n)
           = VectorSpace.standardCombination(g, coefficients, n)   by gToUu
           = uu(k)                                                 by target
           as uuCombIsUk;
        VectorSpace.standardCombination(uu,
              VectorSpace.bumpCoefficient(coefficients, Field.negate(Field.one(f)), k), n)
           = VectorSpace.standardCombination(uu, coefficients, n)
             + Field.negate(Field.one(f)) • uu(k)
                 by VectorSpace.standardCombination_bump
           = uu(k) + Field.negate(Field.one(f)) • uu(k)   by substituting uuCombIsUk
           = uu(k) + VectorSpace.negate(uu(k))            by VectorSpace.negate_one_scale
           = uu(k) - uu(k)
           = VectorSpace.zero(V);
        ∀ (i : Natural). i < n →
            VectorSpace.bumpCoefficient(coefficients, Field.negate(Field.one(f)), k)(i)
            = Field.zero(f)
          by independent as bumpedAllZero;
        VectorSpace.bumpCoefficient(coefficients, Field.negate(Field.one(f)), k)(k)
            = Field.zero(f) by bumpedAllZero as bumpedKZero;
        coefficients(k) = Field.zero(f) by allZeroRemaining as coeffKZero;
        VectorSpace.bumpCoefficient(coefficients, Field.negate(Field.one(f)), k)(k)
           = coefficients(k) + Field.negate(Field.one(f))   by VectorSpace.bumpCoefficient_at
           = Field.zero(f) + Field.negate(Field.one(f))     by substituting coeffKZero
           = Field.negate(Field.one(f))
           as bumpedKValue;
        Field.negate(Field.one(f))
           = VectorSpace.bumpCoefficient(coefficients, Field.negate(Field.one(f)), k)(k)
                 by bumpedKValue
           = Field.zero(f)                                  by bumpedKZero;
        Field.negate(Field.one(f)) ≠ Field.zero(f) by Field.negate_one_nonzero;
        done
  }
}

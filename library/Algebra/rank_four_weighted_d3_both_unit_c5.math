module Algebra.rank_four_weighted_d3_both_unit_c5

import Algebra.rank_four_weighted_d3_both_unit_universality

theorem Matrix.weightedD3S1R1C5_universal_of_two_three_six_converse (converse : Integer.TwoThreeSixLocalConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 1, 1, 5)) :=
  by Matrix.weightedD3BothUnit_universal_of_two_three_six_converse(
      converse, corner := 5, coefficient := 25, core := 35, coefficientShape := done, coreSum := done,
      coreAdmissible := (q : ℕ) ↦ {
        32 * q + 35 = 8 * (4 * q + 4) + 3 by ring as coreReads;
        suppose Natural.IsThreeSquareObstruction(32 * q + 35) as obstruction;
        Natural.IsThreeSquareObstruction(8 * (4 * q + 4) + 3) by substituting coreReads as transformedObstruction;
        done by Natural.eight_times_plus_three_not_obstruction(4 * q + 4)(transformedObstruction)
      })

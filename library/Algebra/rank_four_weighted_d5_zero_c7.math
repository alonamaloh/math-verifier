module Algebra.rank_four_weighted_d5_zero_c7

import Algebra.rank_four_weighted_d5_zero_residue_cover

theorem Matrix.weightedD5S0R0C7_universal_of_one_two_five_converse (converse : Matrix.OneTwoFiveConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 0, 0, 7)) :=
  by Matrix.weightedZero_universal_of_residual_cover(
      5, 7, Matrix.oneTwoFiveResidualCover_selected_cores_of_converse(
          converse, coefficient := 7, coreTen := 3, coreFifteen := 8,
          tenCoreSum := done, fifteenCoreSum := done,
          tenCoreAdmissible := (exponent b : ℕ) ↦
            Natural.twenty_five_power_times_admissible_core_not_one_two_five_obstruction(
                exponent, b, 3, done, done, done, done),
          fifteenCoreAdmissible := (exponent b : ℕ) ↦
            Natural.twenty_five_power_times_admissible_core_not_one_two_five_obstruction(
                exponent, b, 8, done, done, done, done)))

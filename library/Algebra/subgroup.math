-- Algebra/subgroup.math
--
-- A subgroup of a bundled group `G` is a subset of its carrier that
-- contains the identity and is closed under the operation and under
-- inversion. The headline results here are the two structural facts
-- about a homomorphism `f : G → H`:
--
--   * its kernel  { x | f(x) = e_H }   is a subgroup of G, and
--   * its image   { y | ∃ x. f(x) = y } is a subgroup of H;
--
-- together with the classical criterion that `f` is injective exactly
-- when its kernel is trivial (contains only the identity).
--
-- Everything is phrased over `Set` (Set/basics) and the bundled `Group`
-- (Algebra/group_bundle); the homomorphism facts come from
-- Algebra/group_homomorphism.

module Algebra.subgroup

import Logic.basics
import Logic.exists
import Equality.basics
import Set.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.group_bundle
import Algebra.group_homomorphism

-- A subset is a subgroup when it contains the identity and is closed
-- under the operation and under inversion.
definition IsSubgroup (G : Group) (subset : Set(Group.carrier(G)))
        : Proposition :=
  (Group.identity(G) ∈ subset)
  ∧ (∀ (x y : Group.carrier(G)). 
         x ∈ subset → y ∈ subset → (x · y) ∈ subset)
  ∧ (∀ (x : Group.carrier(G)). 
         x ∈ subset → x⁻¹ ∈ subset)

-- Component accessors, so consumers (e.g. the subgroup-as-a-group
-- construction) pull a single closure fact without destructuring the
-- nested ∧ by hand.

theorem IsSubgroup.contains_identity (G : Group) (subset : Set(Group.carrier(G)))
        (subgroup : IsSubgroup(G, subset)) : Group.identity(G) ∈ subset := {
  let ⟨identityIn, _, _⟩ := subgroup;
  identityIn
}

theorem IsSubgroup.closed_under_operation (G : Group) (subset : Set(Group.carrier(G)))
        (subgroup : IsSubgroup(G, subset))
        : ∀ (x y : Group.carrier(G)). x ∈ subset → y ∈ subset → (x · y) ∈ subset := {
  let ⟨_, closedOperation, _⟩ := subgroup;
  closedOperation
}

theorem IsSubgroup.closed_under_inverse (G : Group) (subset : Set(Group.carrier(G)))
        (subgroup : IsSubgroup(G, subset))
        : ∀ (x : Group.carrier(G)). x ∈ subset → x⁻¹ ∈ subset := {
  let ⟨_, _, closedInverse⟩ := subgroup;
  closedInverse
}

-- ----------------------------------------------------------------------
-- Kernel and image of a homomorphism.

-- The kernel: the elements G sends to the identity of H.
definition GroupHomomorphism.kernel
        (G H : Group) (f : Group.carrier(G) → Group.carrier(H))
        : Set(Group.carrier(G)) :=
  (x : Group.carrier(G)) ↦ f(x) = Group.identity(H)

-- The image: the elements of H hit by some element of G.
definition GroupHomomorphism.image
        (G H : Group) (f : Group.carrier(G) → Group.carrier(H))
        : Set(Group.carrier(H)) :=
  (y : Group.carrier(H)) ↦ ∃ (x : Group.carrier(G)). f(x) = y

-- The kernel is a subgroup of G.
--
--   * e_G ∈ ker:        f(e_G) = e_H                       [preserves_identity]
--   * closed under ·:   f(x·y) = f(x)·f(y) = e·e = e
--   * closed under ⁻¹:   f(x⁻¹) = f(x)⁻¹ = e⁻¹ = e
theorem GroupHomomorphism.kernel_is_subgroup
        (G H : Group)
        (f : Group.carrier(G) → Group.carrier(H))
        (homomorphism : IsHomomorphism(G, H, f))
        : IsSubgroup(G, GroupHomomorphism.kernel(G, H, f)) :=
  ⟨GroupHomomorphism.preserves_identity(G, H, f, homomorphism),
   (x y : Group.carrier(G))
            (xInKernel : f(x) = Group.identity(H))
            (yInKernel : f(y) = Group.identity(H)) ↦
       calc f(x · y)
          = f(x) · f(y)
                by homomorphism(x, y)
          = Group.identity(H) · Group.identity(H)
          = Group.identity(H),
   (x : Group.carrier(G)) (xInKernel : f(x) = Group.identity(H)) ↦
       calc f(x⁻¹)
          = f(x)⁻¹
          = Group.identity(H)⁻¹
          = Group.identity(H)⟩

-- The image is a subgroup of H.
--
--   * e_H ∈ im:         e_H = f(e_G)                       [preserves_identity]
--   * closed under ·:   y1·y2 = f(x1)·f(x2) = f(x1·x2)
--   * closed under ⁻¹:   y⁻¹ = f(x)⁻¹ = f(x⁻¹)
theorem GroupHomomorphism.image_is_subgroup
        (G H : Group)
        (f : Group.carrier(G) → Group.carrier(H))
        (homomorphism : IsHomomorphism(G, H, f))
        : IsSubgroup(H, GroupHomomorphism.image(G, H, f)) := {
  claim identityInImage : ∃ (x : Group.carrier(G)). f(x) = Group.identity(H)
      by ⟨Group.identity(G),
          GroupHomomorphism.preserves_identity(G, H, f, homomorphism)⟩;
  claim closedUnderOperation
      : ∀ (y1 y2 : Group.carrier(H)).
        (∃ (x : Group.carrier(G)). f(x) = y1)
        → (∃ (x : Group.carrier(G)). f(x) = y2)
        → ∃ (x : Group.carrier(G)). f(x) = y1 · y2
      by (y1 y2 : Group.carrier(H))
                  (y1InImage : ∃ (x : Group.carrier(G)). f(x) = y1)
                  (y2InImage : ∃ (x : Group.carrier(G)). f(x) = y2) ↦ {
           obtain ⟨x1, fx1Equalsy1⟩ from y1InImage;
           obtain ⟨x2, fx2Equalsy2⟩ from y2InImage;
           ⟨x1 · x2,
            calc f(x1 · x2)
               = f(x1) · f(x2)
                     by homomorphism(x1, x2)
               = y1 · y2⟩
         };
  claim closedUnderInverse
      : ∀ (y : Group.carrier(H)).
        (∃ (x : Group.carrier(G)). f(x) = y)
        → ∃ (x : Group.carrier(G)). f(x) = y⁻¹
      by (y : Group.carrier(H))
                  (yInImage : ∃ (x : Group.carrier(G)). f(x) = y) ↦ {
           obtain ⟨x, fxEqualsy⟩ from yInImage;
           ⟨x⁻¹,
            calc f(x⁻¹)
               = f(x)⁻¹
               = y⁻¹⟩
         };
  ⟨identityInImage, closedUnderOperation, closedUnderInverse⟩
}

-- ----------------------------------------------------------------------
-- Injectivity ⟺ trivial kernel.

-- `f` is injective: distinct inputs go to distinct outputs.
definition GroupHomomorphism.IsInjective
        (G H : Group) (f : Group.carrier(G) → Group.carrier(H))
        : Proposition :=
  (x y : Group.carrier(G)) → f(x) = f(y) → x = y

-- The kernel is trivial: it contains only the identity.
definition GroupHomomorphism.HasTrivialKernel
        (G H : Group) (f : Group.carrier(G) → Group.carrier(H))
        : Proposition :=
  (x : Group.carrier(G)) →
      x ∈ GroupHomomorphism.kernel(G, H, f) → x = Group.identity(G)

-- An injective homomorphism has trivial kernel: if f(x) = e_H = f(e_G),
-- injectivity forces x = e_G.
theorem GroupHomomorphism.injective_implies_trivial_kernel
        (G H : Group)
        (f : Group.carrier(G) → Group.carrier(H))
        (homomorphism : IsHomomorphism(G, H, f))
        (injective : GroupHomomorphism.IsInjective(G, H, f))
        : GroupHomomorphism.HasTrivialKernel(G, H, f) :=
  (x : Group.carrier(G)) (xInKernel : f(x) = Group.identity(H)) ↦
    injective(x, Group.identity(G),
        calc f(x)
           = Group.identity(H)
           = f(Group.identity(G)))

-- A homomorphism with trivial kernel is injective: from f(x) = f(y),
-- the element x·y⁻¹ lands in the kernel, hence equals e_G, and right
-- cancellation gives x = y.
theorem GroupHomomorphism.trivial_kernel_implies_injective
        (G H : Group)
        (f : Group.carrier(G) → Group.carrier(H))
        (homomorphism : IsHomomorphism(G, H, f))
        (trivialKernel : GroupHomomorphism.HasTrivialKernel(G, H, f))
        : GroupHomomorphism.IsInjective(G, H, f) :=
  (x y : Group.carrier(G)) (fxEqualsfy : f(x) = f(y)) ↦ {
    -- x·y⁻¹ is in the kernel: f(x·y⁻¹) = f(x)·f(y)⁻¹ = f(y)·f(y)⁻¹ = e_H.
    calc f(x · y⁻¹)
              = f(x) · f(y⁻¹)
                    by homomorphism(x, y⁻¹)
              = f(y) · f(y)⁻¹
              = Group.identity(H) as productInKernel;
    -- so x·y⁻¹ = e_G; then x·y⁻¹ = y·y⁻¹ and right-cancel y⁻¹.
    claim
        x · y⁻¹ = Group.identity(G)
        by trivialKernel(x · y⁻¹, productInKernel);
    Group.cancel_right_bundled(G, y⁻¹, x, y,
        calc x · y⁻¹
           = Group.identity(G)
           = y · y⁻¹)
  }

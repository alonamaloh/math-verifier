      Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 1, 2, 6))
      by Matrix.squarePlusDoublePlusScaledRankFourCandidate_isometric_reduced(
        x := 2, y := 2, z := 1, secondResidue := 1, thirdResidue := 2, corner := 6,
        firstVanishes := firstVanishes, secondReduces := secondReduces,
        thirdReduces := thirdReduces, cornerReduces := cornerReduces)
  as reduced;
  done by disjunct(reduced)
}

theorem Matrix.rankFourWeightedDiagonalD4_border_m2_m3_m1
        : Matrix.IsRankFourWeightedDiagonalD4NormalForm(Matrix.squarePlusDoublePlusScaledRankFourCandidate(4, 14, (-2), (-3), (-1))) := {
  ((-2) : ℤ) + (2 : ℤ) = 0 by ring as firstVanishes;
  ((-3) : ℤ) + 2 * (2 : ℤ) = (1 : ℤ) by ring as secondReduces;
  ((-1) : ℤ) + 4 * (1 : ℤ) = (3 : ℤ) by ring as thirdReduces;
  (14 : ℤ) + 2 * (((-2) : ℤ) * (2 : ℤ) + ((-3) : ℤ) * (2 : ℤ) + ((-1) : ℤ) * (1 : ℤ))
      + (2 : ℤ) * (2 : ℤ) + 2 * ((2 : ℤ) * (2 : ℤ)) + 4 * ((1 : ℤ) * (1 : ℤ)) = 8 by ring as cornerReduces;
  Matrix.IsIsometric(
      Matrix.squarePlusDoublePlusScaledRankFourCandidate(4, 14, (-2), (-3), (-1)),
      Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 1, 3, 8))
      by Matrix.squarePlusDoublePlusScaledRankFourCandidate_isometric_reduced(
        x := 2, y := 2, z := 1, secondResidue := 1, thirdResidue := 3, corner := 8,
        firstVanishes := firstVanishes, secondReduces := secondReduces,
        thirdReduces := thirdReduces, cornerReduces := cornerReduces)
  as reduced;
  -(3 : ℤ) + 4 * (1 : ℤ) = (1 : ℤ) by ring as thirdReflects;
  (8 : ℤ) + 2 * (-(3 : ℤ) * (1 : ℤ))
      + 4 * ((1 : ℤ) * (1 : ℤ)) = 6
      by ring as cornerReflects;
  Matrix.IsIsometric(
      Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 1, 3, 8),
      Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 1, 1, 6))
      by Matrix.squarePlusDoublePlusScaledRankFourRepresentative_isometric_reflected(
        z := 1, reflectedThird := 1, reflectedCorner := 6,
        thirdMoves := thirdReflects, cornerMoves := cornerReflects)
  as orbitReduction;
  Matrix.IsIsometric(
      Matrix.squarePlusDoublePlusScaledRankFourCandidate(4, 14, (-2), (-3), (-1)),
      Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 1, 1, 6))
      by Matrix.IsIsometric.transitive(leftIsometric := reduced, rightIsometric := orbitReduction)
  as canonicalized;
  done by disjunct(canonicalized)
}


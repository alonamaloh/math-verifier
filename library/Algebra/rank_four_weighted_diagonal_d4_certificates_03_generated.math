  (3 : ℤ) + 4 * (0 : ℤ) = (3 : ℤ) by ring as thirdReduces;
  (14 : ℤ) + 2 * (((-2) : ℤ) * (2 : ℤ) + ((-3) : ℤ) * (2 : ℤ) + (3 : ℤ) * (0 : ℤ))
      + (2 : ℤ) * (2 : ℤ) + 2 * ((2 : ℤ) * (2 : ℤ)) + 4 * ((0 : ℤ) * (0 : ℤ)) = 6 by ring as cornerReduces;

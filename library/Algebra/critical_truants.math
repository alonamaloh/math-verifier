-- Algebra/critical_truants.math
--
-- The critical-truant classification through rank three.  The remaining
-- rank-four/rank-five cases are the universality stage: a non-universal
-- rank-four child must be shown to have truant 15, and its escalations must
-- be shown universal.

module Algebra.critical_truants

import Algebra.rank_three_global_classification

theorem Matrix.rankThreeEscalatorRepresentative_truant
        (A : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (classified : Matrix.IsRankThreeEscalatorRepresentative(A))
        : Matrix.truant(A) = 6 ∨ Matrix.truant(A) = 7
          ∨ Matrix.truant(A) = 10 ∨ Matrix.truant(A) = 14 := {
  done by cases {
    case Matrix.IsIsometric(A, Matrix.sumOfThreeSquaresForm) as isometric: {
      Matrix.IsIsometric(Matrix.sumOfThreeSquaresForm, A)
          by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
      Matrix.truant(A) = 7 by Matrix.isometric_truant_equals(
          isometric := reverse, isTruant := Matrix.sumOfThreeSquaresForm_truant_seven) as truantReads;
      done by Or.introduceRight(Or.introduceLeft(truantReads))
    }
    case Matrix.IsIsometric(A, Matrix.sumOfTwoSquaresPlusTripleSquareForm) as isometric: {
      Matrix.IsIsometric(Matrix.sumOfTwoSquaresPlusTripleSquareForm, A)
          by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
      Matrix.truant(A) = 6 by Matrix.isometric_truant_equals(
          isometric := reverse, isTruant := Matrix.sumOfTwoSquaresPlusTripleSquareForm_truant_six) as truantReads;
      done by Or.introduceLeft(truantReads)
    }
    case Matrix.IsIsometric(A, Matrix.sumOfTwoSquaresPlusDoubleSquareForm) as isometric: {
      Matrix.IsIsometric(Matrix.sumOfTwoSquaresPlusDoubleSquareForm, A)
          by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
      Matrix.truant(A) = 14 by Matrix.isometric_truant_equals(
          isometric := reverse, isTruant := Matrix.sumOfTwoSquaresPlusDoubleSquareForm_truant_fourteen) as truantReads;
      done by Or.introduceRight(Or.introduceRight(Or.introduceRight(truantReads)))
    }
    case Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareDiagonalForm(2)) as isometric: {
      Matrix.IsIsometric(Matrix.squarePlusDoubleSquareDiagonalForm(2), A)
          by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
      Matrix.truant(A) = 7 by Matrix.isometric_truant_equals(
          isometric := reverse, isTruant := Matrix.squarePlusDoubleSquareDiagonalForm_two_truant_seven) as truantReads;
      done by Or.introduceRight(Or.introduceLeft(truantReads))
    }
    case Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareDiagonalForm(3)) as isometric: {
      Matrix.IsIsometric(Matrix.squarePlusDoubleSquareDiagonalForm(3), A)
          by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
      Matrix.truant(A) = 10 by Matrix.isometric_truant_equals(
          isometric := reverse, isTruant := Matrix.squarePlusDoubleSquareDiagonalForm_three_truant_ten) as truantReads;
      done by Or.introduceRight(Or.introduceRight(Or.introduceLeft(truantReads)))
    }
    case Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareDiagonalForm(4)) as isometric: {
      Matrix.IsIsometric(Matrix.squarePlusDoubleSquareDiagonalForm(4), A)
          by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
      Matrix.truant(A) = 14 by Matrix.isometric_truant_equals(
          isometric := reverse, isTruant := Matrix.squarePlusDoubleSquareDiagonalForm_four_truant_fourteen) as truantReads;
      done by Or.introduceRight(Or.introduceRight(Or.introduceRight(truantReads)))
    }
    case Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareDiagonalForm(5)) as isometric: {
      Matrix.IsIsometric(Matrix.squarePlusDoubleSquareDiagonalForm(5), A)
          by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
      Matrix.truant(A) = 10 by Matrix.isometric_truant_equals(
          isometric := reverse, isTruant := Matrix.squarePlusDoubleSquareDiagonalForm_five_truant_ten) as truantReads;
      done by Or.introduceRight(Or.introduceRight(Or.introduceLeft(truantReads)))
    }
    case Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareOddForm(4)) as isometric: {
      Matrix.IsIsometric(Matrix.squarePlusDoubleSquareOddForm(4), A)
          by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
      Matrix.truant(A) = 7 by Matrix.isometric_truant_equals(
          isometric := reverse, isTruant := Matrix.squarePlusDoubleSquareOddForm_four_truant_seven) as truantReads;
      done by Or.introduceRight(Or.introduceLeft(truantReads))
    }
    case Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareOddForm(5)) as isometric: {
      Matrix.IsIsometric(Matrix.squarePlusDoubleSquareOddForm(5), A)
          by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
      Matrix.truant(A) = 7 by Matrix.isometric_truant_equals(
          isometric := reverse, isTruant := Matrix.squarePlusDoubleSquareOddForm_five_truant_seven) as truantReads;
      done by Or.introduceRight(Or.introduceLeft(truantReads))
    }
  }
}

theorem Matrix.escalator_rank_three_truant
        (A : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (escalator : Matrix.IsEscalator(3, A))
        : Matrix.truant(A) = 6 ∨ Matrix.truant(A) = 7
          ∨ Matrix.truant(A) = 10 ∨ Matrix.truant(A) = 14 := {
  Matrix.IsRankThreeEscalatorRepresentative(A)
      by Matrix.escalator_rank_three(escalator := escalator);
  done by Matrix.rankThreeEscalatorRepresentative_truant
}

theorem Matrix.escalator_rank_two_truant
        (A : Matrix(Integer.commutative_ring_bundle, 2, 2))
        (escalator : Matrix.IsEscalator(2, A))
        : Matrix.truant(A) = 3 ∨ Matrix.truant(A) = 5 := {
  Matrix.IsIsometric(A, Matrix.sumOfTwoSquaresForm)
    ∨ Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareForm)
      by Matrix.escalator_rank_two(escalator := escalator);
  done by cases {
    case Matrix.IsIsometric(A, Matrix.sumOfTwoSquaresForm) as isometric: {
      Matrix.IsIsometric(Matrix.sumOfTwoSquaresForm, A)
          by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
      Matrix.truant(A) = 3 by Matrix.isometric_truant_equals(
          isometric := reverse, isTruant := Matrix.sumOfTwoSquaresForm_truant_three) as truantReads;
      done by Or.introduceLeft(truantReads)
    }
    case Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareForm) as isometric: {
      Matrix.IsIsometric(Matrix.squarePlusDoubleSquareForm, A)
          by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
      Matrix.truant(A) = 5 by Matrix.isometric_truant_equals(
          isometric := reverse, isTruant := Matrix.squarePlusDoubleSquareForm_truant_five) as truantReads;
      done by Or.introduceRight(truantReads)
    }
  }
}

theorem Matrix.escalator_rank_one_truant
        (A : Matrix(Integer.commutative_ring_bundle, 1, 1))
        (escalator : Matrix.IsEscalator(1, A))
        : Matrix.truant(A) = 2 := {
  A = Matrix.squareForm by Matrix.escalator_rank_one(escalator := escalator) as isSquare;
  done by substituting isSquare
}

theorem Matrix.escalator_rank_zero_truant
        (A : Matrix(Integer.commutative_ring_bundle, 0, 0))
        (escalator : Matrix.IsEscalator(0, A))
        : Matrix.truant(A) = 1 := {
  done by Matrix.zero_dimension_truant
}

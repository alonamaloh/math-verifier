module Algebra.rank_four_weighted_d4_zero_c6

import Algebra.rank_four_weighted_d4_zero_c6_cover

theorem Matrix.weightedD4S0R0C6_universal_of_one_two_four_converse (converse : Matrix.OneTwoFourConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 0, 6)) :=
  by Matrix.weightedZero_universal_of_residual_cover(4, 6, Matrix.oneTwoFourResidualCover_six_of_converse(converse))

theorem Matrix.detSevenFiniteQ2C9A315T9
        (n : ℕ) (positive : n ≥ 1)
        (bounded : n ≤ 26649)
        (remainderReads : Natural.modulo(n, 588) = 315)
        : Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 9),
            (n : ℤ)) := {
  let q : ℕ := Natural.floor_divide(n, 588);
  588 * q + Natural.modulo(n, 588) = n
      by Natural.floor_divide_modulo_decompose;
  588 * q + 315 = n by substituting remainderReads as exactDecomposition;
  q < 45 by Natural.quotient_below_of_bounded_decomposition(
    588, q, 315, n, 26649, 45, done, exactDecomposition, bounded)
  as qBelow;
  Matrix.Represents(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 9),
      (588 : ℤ) * (q : ℤ) + (315 : ℤ)) by {
  q < 20 ∨ 20 ≤ q by Natural.lt_or_le;
  done by cases {
    case q < 20 as below20:
      done by Matrix.detSevenFiniteQ2C9A315T9_part0(q, done, below20)
    case 20 ≤ q as atLeast20: {
      q < 40 ∨ 40 ≤ q by Natural.lt_or_le;
      done by cases {
        case q < 40 as below40:
          done by Matrix.detSevenFiniteQ2C9A315T9_part1(q, atLeast20, below40)
        case 40 ≤ q as atLeast40: {
          done by Matrix.detSevenFiniteQ2C9A315T9_part2(q, atLeast40, qBelow)
        }
      }
    }
  }
  };
  (588 : ℤ) * (q : ℤ) + (315 : ℤ)
     = ((588 * q : ℕ) : ℤ) + (315 : ℤ)
         by substituting Equality.symmetry(Natural.to_integer.multiply_preserves(588, q))
     = ((588 * q + 315 : ℕ) : ℤ)
         by Equality.symmetry(Natural.to_integer.add_preserves(588 * q, 315))
     = (n : ℤ) by substituting exactDecomposition
  as integerDecomposition;
  done by substituting integerDecomposition
}

  (29 : ℤ) * 29 + 2 * ((-1 : ℤ) * (-1 : ℤ)) + 2 * (-1 : ℤ) * 0 + 4 * (0 * 0) + 2 * 1 * (-1 : ℤ) * (-2 : ℤ) + 7 * ((-2 : ℤ) * (-2 : ℤ)) = (875 : ℤ) as scalarComputation;
  Matrix.represents_by_witness(A, target := 875, vector := ⟨29, -1, 0, -2⟩,
    computes := Matrix.detSevenRankFour_coordinateTuple_computes(scalarComputation := scalarComputation));
  done by finite_check q from 0 until 2
}

theorem Matrix.detSevenFiniteQ1C7ODDA287T2
        (n : ℕ) (positive : n ≥ 1)
        (bounded : n ≤ 1260)
        (remainderReads : Natural.modulo(n, 588) = 287)
        : Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 1, 7),
            (n : ℤ)) := {
  let q : ℕ := Natural.floor_divide(n, 588);
  588 * q + Natural.modulo(n, 588) = n
      by Natural.floor_divide_modulo_decompose;
  588 * q + 287 = n by substituting remainderReads as exactDecomposition;
  q < 2 by Natural.quotient_below_of_bounded_decomposition(
    588, q, 287, n, 1260, 2, done, exactDecomposition, bounded)
  as qBelow;
  Matrix.Represents(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 1, 7),
      (588 : ℤ) * (q : ℤ) + (287 : ℤ)) by {
  done by Matrix.detSevenFiniteQ1C7ODDA287T2_part0(q, done, qBelow)
  };
  (588 : ℤ) * (q : ℤ) + (287 : ℤ)
     = ((588 * q : ℕ) : ℤ) + (287 : ℤ)
         by substituting Equality.symmetry(Natural.to_integer.multiply_preserves(588, q))
     = ((588 * q + 287 : ℕ) : ℤ)
         by Equality.symmetry(Natural.to_integer.add_preserves(588 * q, 287))
     = (n : ℤ) by substituting exactDecomposition
  as integerDecomposition;
  done by substituting integerDecomposition
}

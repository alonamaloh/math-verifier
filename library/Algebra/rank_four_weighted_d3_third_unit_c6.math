module Algebra.rank_four_weighted_d3_third_unit_c6

import Algebra.rank_four_weighted_d3_third_unit_universality

theorem Matrix.weightedD3S0R1C6_universal_of_one_three_six_converse (converse : Matrix.OneThreeSixLocalConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 0, 1, 6)) := {
  3 * 6 = 17 + 1 by ring as coefficientShape;
  3 * 6 ∸ 1 = 17 by Natural.three_times_monus_one_value(6, 17, coefficientShape) as naturalCoefficientReads;
  ((3 * 6 ∸ 1 : ℕ) : ℤ) = 3 * (6 : ℤ) - 1
      by Natural.three_times_monus_one_to_integer(6, 17, coefficientShape) as coefficientReads;
  39 + (3 * 6 ∸ 1) = 39 + 17 by substituting naturalCoefficientReads = 56 by ring as halfCoreSum;
  13 + (3 * 6 ∸ 1) = 13 + 17 by substituting naturalCoefficientReads = 30 by ring as baseCoreSum;
  7 = 4 * 1 + 3 by ring as halfCoreShape;
  3 + (1 + 0) = 4 by ring as threeBelowFourReads;
  3 < 4 by Natural.lt_intro(3, 4, 0, threeBelowFourReads) as threeBelowFour;
  0 + (1 + 2) = 3 by ring as threePositiveReads;
  0 < 3 by Natural.lt_intro(0, 3, 2, threePositiveReads) as threePositive;
  3 ≠ 0 by Natural.not_equal_of_greater_than(3, 0, threePositive) as threeNonzero;
  7 + (1 + 8) = 16 by ring as sevenBelowSixteenReads;
  7 < 16 by Natural.lt_intro(7, 16, 8, sevenBelowSixteenReads) as sevenBelowSixteen;
  7 + (1 + 6) = 14 by ring as sevenBelowFourteenReads;
  7 < 14 by Natural.lt_intro(7, 14, 6, sevenBelowFourteenReads) as sevenBelowFourteen;
  7 ≠ 14 by Natural.not_equal_of_less_than(7, 14, sevenBelowFourteen) as sevenNotFourteen;
  13 = 4 * 3 + 1 by ring as baseCoreShape;
  1 + (1 + 2) = 4 by ring as oneBelowFourReads;
  1 < 4 by Natural.lt_intro(1, 4, 2, oneBelowFourReads) as oneBelowFour;
  0 + (1 + 0) = 1 by ring as onePositiveReads;
  0 < 1 by Natural.lt_intro(0, 1, 0, onePositiveReads) as onePositive;
  1 ≠ 0 by Natural.not_equal_of_greater_than(1, 0, onePositive) as oneNonzero;
  13 + (1 + 2) = 16 by ring as thirteenBelowSixteenReads;
  13 < 16 by Natural.lt_intro(13, 16, 2, thirteenBelowSixteenReads) as thirteenBelowSixteen;
  13 + (1 + 0) = 14 by ring as thirteenBelowFourteenReads;
  13 < 14 by Natural.lt_intro(13, 14, 0, thirteenBelowFourteenReads) as thirteenBelowFourteen;
  13 ≠ 14 by Natural.not_equal_of_less_than(13, 14, thirteenBelowFourteen) as thirteenNotFourteen;
  Matrix.OneThreeSixTripleTargetCover(6)
      by Matrix.oneThreeSixTripleTargetCover_half_scale_of_local_converse(
          converse, corner := 6, halfCore := 39, baseCore := 13,
          coefficientReads := coefficientReads, halfCoreSum := halfCoreSum, baseCoreSum := baseCoreSum,
          halfAdmissible := (exponent b : ℕ) ↦ {
            4 ^ exponent * (64 * b + 39) = 4 ^ exponent * (16 * (4 * b + 2) + 7) by ring as valueReads;
            suppose Natural.IsOneThreeSixFourObstruction(4 ^ exponent * (64 * b + 39)) as obstruction;
            Natural.IsOneThreeSixFourObstruction(4 ^ exponent * (16 * (4 * b + 2) + 7))
                by substituting valueReads as transformedObstruction;
            done by Natural.four_power_times_nonzero_mod_four_core_not_one_three_six_four_obstruction(
                exponent, 4 * b + 2, 7, 1, 3, halfCoreShape,
                threeBelowFour, threeNonzero, sevenBelowSixteen, sevenNotFourteen)(transformedObstruction)
          },
          baseAdmissible := (b : ℕ) ↦ {
            4 ^ 0 * (16 * b + 13) = 16 * b + 13 by substituting Natural.power_zero(4) as valueReads;
            suppose Natural.IsOneThreeSixFourObstruction(16 * b + 13) as obstruction;
            Natural.IsOneThreeSixFourObstruction(4 ^ 0 * (16 * b + 13))
                by substituting Equality.symmetry(valueReads) as transformedObstruction;
            done by Natural.four_power_times_nonzero_mod_four_core_not_one_three_six_four_obstruction(
                0, b, 13, 3, 1, baseCoreShape,
                oneBelowFour, oneNonzero, thirteenBelowSixteen, thirteenNotFourteen)(transformedObstruction)
          })
      as cover;
  done by Matrix.weightedD3ThirdUnit_universal_of_cover(6, coefficientReads, cover)
}

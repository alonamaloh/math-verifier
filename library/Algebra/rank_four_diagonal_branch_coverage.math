-- Algebra/rank_four_diagonal_branch_coverage.math
--
-- End-to-end coverage for the second rank-four branch.  The generated files
-- certify the finite box; this file proves that every genuine escalation has
-- a border in that box and reconstructs it as the corresponding candidate.

module Algebra.rank_four_diagonal_branch_coverage

import Algebra.rank_four_diagonal_branch_classification_generated
import Algebra.rank_four_diagonal_family

definition Matrix.IsSumOfTwoSquaresPlusTripleSquareRankFourSignedNormalForm
        (B : Matrix(Integer.commutative_ring_bundle, 4, 4)) : Proposition :=
  Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 1))
    ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 2))
    ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 3))
    ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 4))
    ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 5))
    ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 6))
    ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 1))
    ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 2))
    ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 3))
    ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 4))
    ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 5))
    ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 6))

theorem Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative_isometric_negate_residue
        (residue corner : ℤ)
        : Matrix.IsIsometric(
            Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(residue, corner),
            Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-residue, corner)) :=
  by Matrix.sumOfTwoSquaresPlusScaledSquareRankFourRepresentative_isometric_negate_residue(
      3, residue, corner)

theorem Matrix.sumOfTwoSquaresPlusTripleSquareRankFourTopShearNormalForm_signed
        (B : Matrix(Integer.commutative_ring_bundle, 4, 4))
        (normal : Matrix.IsSumOfTwoSquaresPlusTripleSquareRankFourTopShearNormalForm(B))
        : Matrix.IsSumOfTwoSquaresPlusTripleSquareRankFourSignedNormalForm(B) := {
  done by cases {
    case Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 1))
        as isometric: {
      Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 1))
          by Matrix.IsIsometric.transitive(
            leftIsometric := isometric,
            rightIsometric := Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative_isometric_negate_residue(-1, 1))
      as canonical;
      done by Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(
        Or.introduceRight(Or.introduceRight(Or.introduceLeft(canonical)))))))
    }
    case Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 2))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 3))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 4))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 5))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 6))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 1))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 2))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 3))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 4))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 5))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 6))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 1))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 2))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 3))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 4))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 5))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 6)): done by cases {
        case Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 2))
            as isometric: {
          Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 2))
              by Matrix.IsIsometric.transitive(
                leftIsometric := isometric,
                rightIsometric := Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative_isometric_negate_residue(-1, 2))
          as canonical;
          done by Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(
            Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceLeft(canonical))))))))
        }
        case Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 3))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 4))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 5))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 6))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 1))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 2))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 3))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 4))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 5))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 6))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 1))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 2))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 3))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 4))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 5))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 6)): done by cases {
            case Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 3))
                as isometric: {
              Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 3))
                  by Matrix.IsIsometric.transitive(
                    leftIsometric := isometric,
                    rightIsometric := Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative_isometric_negate_residue(-1, 3))
              as canonical;
              done by Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(
                Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(
                  Or.introduceLeft(canonical)))))))))
            }
            case Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 4))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 5))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 6))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 1))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 2))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 3))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 4))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 5))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 6))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 1))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 2))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 3))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 4))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 5))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 6)): done by cases {
                case Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 4))
                    as isometric: {
                  Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 4))
                      by Matrix.IsIsometric.transitive(
                        leftIsometric := isometric,
                        rightIsometric := Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative_isometric_negate_residue(-1, 4))
                  as canonical;
                  done by Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(
                    Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(
                      Or.introduceRight(Or.introduceLeft(canonical))))))))))
                }
                case Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 5))
                  ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 6))
                  ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 1))
                  ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 2))
                  ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 3))
                  ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 4))
                  ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 5))
                  ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 6))
                  ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 1))
                  ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 2))
                  ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 3))
                  ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 4))
                  ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 5))
                  ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 6)): done by cases {
                    case Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 5))
                        as isometric: {
                      Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 5))
                          by Matrix.IsIsometric.transitive(
                            leftIsometric := isometric,
                            rightIsometric := Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative_isometric_negate_residue(-1, 5))
                      as canonical;
                      done by Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(
                        Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(
                          Or.introduceRight(Or.introduceRight(Or.introduceLeft(canonical)))))))))))
                    }
                    case Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 6))
                      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 1))
                      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 2))
                      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 3))
                      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 4))
                      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 5))
                      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 6))
                      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 1))
                      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 2))
                      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 3))
                      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 4))
                      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 5))
                      ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 6)): done by cases {
                        case Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(-1, 6))
                            as isometric: {
                          Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 6))
                              by Matrix.IsIsometric.transitive(
                                leftIsometric := isometric,
                                rightIsometric := Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative_isometric_negate_residue(-1, 6))
                          as canonical;
                          done by Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(
                            Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(
                              Or.introduceRight(Or.introduceRight(Or.introduceRight(canonical)))))))))))
                        }
                        case Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 1))
                          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 2))
                          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 3))
                          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 4))
                          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 5))
                          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(0, 6))
                          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 1))
                          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 2))
                          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 3))
                          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 4))
                          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 5))
                          ∨ Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusTripleSquareRankFourRepresentative(1, 6)): done
                      }
                  }
              }
          }
      }
  }
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareRankFourEscalation_classified
        (B : Matrix(Integer.commutative_ring_bundle, 1 + 3, 1 + 3))
        (escalation : Matrix.IsEscalation(Matrix.sumOfTwoSquaresPlusTripleSquareForm, B))
        : Matrix.IsSumOfTwoSquaresPlusTripleSquareRankFourSignedNormalForm(B) := {
  let border : RingVector(Integer.commutative_ring_bundle, 3) := Matrix.borderColumn(B);
  let pair : RingVector(Integer.commutative_ring_bundle, 2) := RingVector.restrict(border);
  let a : ℤ := pair(NaturalsBelow.firstOfTwo);
  let b : ℤ := pair(NaturalsBelow.secondOfTwo);
  let c : ℤ := border(NaturalsBelow.top(2));
  pair = RingVector.twoCoordinates(a, b) by RingVector.eq_twoCoordinates as pairReads;
  let coordinatePair : RingVector(Integer.commutative_ring_bundle, 2) := ⟨a, b⟩;
  coordinatePair = RingVector.twoCoordinates(a, b)
      by RingVector.coordinatePair_eq_twoCoordinates as coordinatePairReads;
  pair
     = RingVector.twoCoordinates(a, b) by pairReads
     = coordinatePair by coordinatePairReads
  as pairIsCoordinatePair;
  border
     = RingVector.appendCoordinate(pair, c)
         by RingVector.eq_appendCoordinate(border)
     = RingVector.appendCoordinate(coordinatePair, c) by substituting pairIsCoordinatePair
     = (⟨a, b, c⟩ : RingVector(Integer.commutative_ring_bundle, 3))
  as borderReads;
  3 * (a * a) + 3 * (b * b) + c * c < 18
      by Matrix.sumOfTwoSquaresPlusTripleSquareRankFourEscalation_coupled_bound(
          escalation := escalation, borderReads := borderReads) as coupledBound;
  a * a < 6 by Integer.first_square_bound_of_weighted_sum_below_eighteen;
  a * a < 6 < 8;
  a * a < 8;
  -2 ≤ a by Integer.square_below_eight_lower_box_bound as aLower;
  a < 3 by Integer.square_below_eight_upper_box_bound as aUpper;
  3 * (b * b) + 3 * (a * a) + c * c
     = 3 * (a * a) + 3 * (b * b) + c * c by ring
     < 18 by coupledBound
  as swappedBound;
  b * b < 6 by Integer.first_square_bound_of_weighted_sum_below_eighteen(
      b, a, c, swappedBound);
  b * b < 6 < 8;
  b * b < 8;
  -2 ≤ b by Integer.square_below_eight_lower_box_bound as bLower;
  b < 3 by Integer.square_below_eight_upper_box_bound as bUpper;
  c * c < 18 by Integer.third_square_bound_of_weighted_sum_below_eighteen;
  -4 ≤ c by Integer.square_below_eighteen_lower_box_bound as cLower;
  c < 5 by Integer.square_below_eighteen_upper_box_bound as cUpper;
  Matrix.IsSumOfTwoSquaresPlusTripleSquareRankFourTopShearNormalForm(
      Matrix.sumOfTwoSquaresPlusTripleSquareRankFourCandidate(a, b, c))
      by Matrix.rankFourDiagonalBranch_finite_box_classified(
          a, aLower, aUpper, b, bLower, bUpper, c, cLower, cUpper, coupledBound)
  as topShearClassified;
  Matrix.IsSumOfTwoSquaresPlusTripleSquareRankFourSignedNormalForm(
      Matrix.sumOfTwoSquaresPlusTripleSquareRankFourCandidate(a, b, c))
      by Matrix.sumOfTwoSquaresPlusTripleSquareRankFourTopShearNormalForm_signed(
        normal := topShearClassified);
  (Matrix.truant(Matrix.sumOfTwoSquaresPlusTripleSquareForm) : ℤ) = 6
      by substituting Matrix.sumOfTwoSquaresPlusTripleSquareForm_truant as truantReads;
  B
     = Matrix.borderedAssembly(
         Matrix.sumOfTwoSquaresPlusTripleSquareForm,
         Matrix.borderColumn(B),
         Matrix.truant(Matrix.sumOfTwoSquaresPlusTripleSquareForm))
         by Matrix.IsEscalation.eq_borderedAssembly(escalation := escalation)
     = Matrix.borderedAssembly(
         Matrix.sumOfTwoSquaresPlusTripleSquareForm,
         (⟨a, b, c⟩ : RingVector(Integer.commutative_ring_bundle, 3)),
         Matrix.truant(Matrix.sumOfTwoSquaresPlusTripleSquareForm)) by substituting borderReads
     = Matrix.borderedAssembly(
         Matrix.sumOfTwoSquaresPlusTripleSquareForm,
         (⟨a, b, c⟩ : RingVector(Integer.commutative_ring_bundle, 3)),
         6) by substituting truantReads
     = Matrix.sumOfTwoSquaresPlusTripleSquareRankFourCandidate(a, b, c)
  as reconstructs;
  done by substituting reconstructs
}

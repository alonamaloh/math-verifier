theorem Matrix.detSevenFiniteQ2C8A266T9
        (n : ℕ) (positive : n ≥ 1)
        (bounded : n ≤ 22680)
        (remainderReads : Natural.modulo(n, 588) = 266)
        : Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 8),
            (n : ℤ)) := {
  let q : ℕ := Natural.floor_divide(n, 588);
  588 * q + Natural.modulo(n, 588) = n
      by Natural.floor_divide_modulo_decompose;
  588 * q + 266 = n by substituting remainderReads as exactDecomposition;
  q < 39 by Natural.quotient_below_of_bounded_decomposition(
    588, q, 266, n, 22680, 39, done, exactDecomposition, bounded)
  as qBelow;
  Matrix.Represents(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 8),
      (588 : ℤ) * (q : ℤ) + (266 : ℤ)) by {
  q < 20 ∨ 20 ≤ q by Natural.lt_or_le;
  done by cases {
    case q < 20 as below20:
      done by Matrix.detSevenFiniteQ2C8A266T9_part0(q, done, below20)
    case 20 ≤ q as atLeast20: {
      done by Matrix.detSevenFiniteQ2C8A266T9_part1(q, atLeast20, qBelow)
    }
  }
  };
  (588 : ℤ) * (q : ℤ) + (266 : ℤ)
     = ((588 * q : ℕ) : ℤ) + (266 : ℤ)
         by substituting Equality.symmetry(Natural.to_integer.multiply_preserves(588, q))
     = ((588 * q + 266 : ℕ) : ℤ)
         by Equality.symmetry(Natural.to_integer.add_preserves(588 * q, 266))
     = (n : ℤ) by substituting exactDecomposition
  as integerDecomposition;
  done by substituting integerDecomposition
}


-- Algebra/ring_from_natural.math
--
-- The canonical map `Natural → Ring.carrier(r)`, sending `m` to the m-fold
-- sum `1 + 1 + … + 1`. This is how a Natural coefficient (e.g. a binomial
-- coefficient) enters an abstract ring; it is an additive homomorphism
-- carrying `0 ↦ zero` and `1 ↦ one`.

module Algebra.ring_from_natural

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.one_plus_induction
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas

definition Ring.from_natural (r : Ring) : Natural → Ring.carrier(r)
  | zero          => Ring.zero(r)
  | successor(k)  => Ring.one(r) + Ring.from_natural(r, k)

-- `1` maps to the ring unit.
theorem Ring.from_natural_one (r : Ring) : Ring.from_natural(r, 1) = Ring.one(r) :=
  calc Ring.from_natural(r, 1)
     = Ring.one(r) + Ring.from_natural(r, 0)
     = Ring.one(r) + Ring.zero(r)
     = Ring.one(r)

-- Additivity: the map turns Natural addition into ring addition.
theorem Ring.from_natural_add (r : Ring) (m n : Natural)
        : Ring.from_natural(r, m + n)
          = Ring.from_natural(r, m) + Ring.from_natural(r, n) :=
  by_induction on n with IH {
    case base:
        calc Ring.from_natural(r, m + 0)
           = Ring.from_natural(r, m)                        by (m + 0 = m)
           = Ring.from_natural(r, m) + Ring.zero(r)
           = Ring.from_natural(r, m) + Ring.from_natural(r, 0)
    case step(k):
        calc Ring.from_natural(r, m + (1 + k))
           = Ring.from_natural(r, 1 + (m + k))              by (m + (1 + k) = 1 + (m + k))
           = Ring.one(r) + Ring.from_natural(r, m + k)      by substituting Natural.one_add
           = Ring.one(r) + (Ring.from_natural(r, m) + Ring.from_natural(r, k))   by IH
           = Ring.from_natural(r, m) + (Ring.one(r) + Ring.from_natural(r, k))   by ring
           = Ring.from_natural(r, m) + Ring.from_natural(r, 1 + k)               by substituting Natural.one_add
  }

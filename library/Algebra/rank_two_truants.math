-- Algebra/rank_two_truants.math
--
-- The truants of the two canonical rank-2 escalators. The sum of two
-- squares represents 1 and 2 but misses 3, while x² + 2y² represents
-- 1 through 4 but misses 5. These are the corner values for the two
-- families of rank-3 escalations.

module Algebra.rank_two_truants

import Logic.basics
import Logic.functions
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.multiply_bounds
import Natural.finite_range
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.embedding
import Integer.order
import Integer.order_multiply
import Integer.sign
import Integer.sum_of_squares
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.commutative_ring_aggregation
import Algebra.matrix
import Algebra.matrix_ring
import Algebra.matrix_vector
import Algebra.matrix_direct_sum
import Algebra.quadratic_form
import Algebra.integer_quadratic_form
import Algebra.square_form
import Algebra.truant
import Algebra.rank_two_escalators

-- ----------------------------------------------------------------------
-- Values of the two direct sums are respectively a²+b² and a²+2b².

definition RingVector.twoCoordinates {r : CommutativeRing}
        (a b : CommutativeRing.carrier(r)) : RingVector(r, 2) :=
  a • Matrix.standardBasisRow(r, 2, NaturalsBelow.firstOfTwo)
    + b • Matrix.standardBasisRow(r, 2, NaturalsBelow.secondOfTwo)

theorem RingVector.twoCoordinates_first {r : CommutativeRing}
        (a b : CommutativeRing.carrier(r))
        : RingVector.twoCoordinates(a, b)(NaturalsBelow.firstOfTwo) = a := {
  let firstBasis : RingVector(r, 2) := Matrix.standardBasisRow(r, 2, NaturalsBelow.firstOfTwo);
  let secondBasis : RingVector(r, 2) := Matrix.standardBasisRow(r, 2, NaturalsBelow.secondOfTwo);
  firstBasis(NaturalsBelow.firstOfTwo) = CommutativeRing.one(r) by Matrix.standardBasisRow_at as firstReads;
  ¬(NaturalsBelow.firstOfTwo = NaturalsBelow.secondOfTwo) by NaturalsBelow.firstOfTwo_not_secondOfTwo;
  secondBasis(NaturalsBelow.firstOfTwo) = CommutativeRing.zero(r) by Matrix.standardBasisRow_off as secondVanishes;
  RingVector.twoCoordinates(a, b)(NaturalsBelow.firstOfTwo)
     = a * firstBasis(NaturalsBelow.firstOfTwo) + b * secondBasis(NaturalsBelow.firstOfTwo)
     = a * CommutativeRing.one(r) + b * secondBasis(NaturalsBelow.firstOfTwo) by substituting firstReads
     = a * CommutativeRing.one(r) + b * CommutativeRing.zero(r) by substituting secondVanishes
     = a by ring
  as valueReads;
  done by valueReads
}

theorem RingVector.twoCoordinates_second {r : CommutativeRing}
        (a b : CommutativeRing.carrier(r))
        : RingVector.twoCoordinates(a, b)(NaturalsBelow.secondOfTwo) = b := {
  let firstBasis : RingVector(r, 2) := Matrix.standardBasisRow(r, 2, NaturalsBelow.firstOfTwo);
  let secondBasis : RingVector(r, 2) := Matrix.standardBasisRow(r, 2, NaturalsBelow.secondOfTwo);
  ¬(NaturalsBelow.secondOfTwo = NaturalsBelow.firstOfTwo) by {
    suppose NaturalsBelow.secondOfTwo = NaturalsBelow.firstOfTwo;
    done by NaturalsBelow.firstOfTwo_not_secondOfTwo
  };
  firstBasis(NaturalsBelow.secondOfTwo) = CommutativeRing.zero(r) by Matrix.standardBasisRow_off as firstVanishes;
  secondBasis(NaturalsBelow.secondOfTwo) = CommutativeRing.one(r) by Matrix.standardBasisRow_at as secondReads;
  RingVector.twoCoordinates(a, b)(NaturalsBelow.secondOfTwo)
     = a * firstBasis(NaturalsBelow.secondOfTwo) + b * secondBasis(NaturalsBelow.secondOfTwo)
     = a * CommutativeRing.zero(r) + b * secondBasis(NaturalsBelow.secondOfTwo) by substituting firstVanishes
     = a * CommutativeRing.zero(r) + b * CommutativeRing.one(r) by substituting secondReads
     = b by ring
  as valueReads;
  done by valueReads
}

theorem RingVector.eq_twoCoordinates {r : CommutativeRing}
        (z : RingVector(r, 2))
        : z = RingVector.twoCoordinates(z(NaturalsBelow.firstOfTwo), z(NaturalsBelow.secondOfTwo)) := {
  ∀ (i : NaturalsBelow(2)).
      z(i) = RingVector.twoCoordinates(z(NaturalsBelow.firstOfTwo), z(NaturalsBelow.secondOfTwo))(i)
      by (i : NaturalsBelow(2)) ↦ {
          i = NaturalsBelow.firstOfTwo ∨ i = NaturalsBelow.secondOfTwo by NaturalsBelow.two_split;
          done by cases {
            case i = NaturalsBelow.firstOfTwo: done by RingVector.twoCoordinates_first
            case i = NaturalsBelow.secondOfTwo: done by RingVector.twoCoordinates_second
          }
        };
  done by RingVector.equal_of_pointwise
}

theorem Matrix.quadraticForm_scale_matrix {r : CommutativeRing} {n : ℕ}
        (A : Matrix(r, n, n)) (c : CommutativeRing.carrier(r)) (x : RingVector(r, n))
        : Matrix.quadraticForm(c • A, x) = c * Matrix.quadraticForm(A, x) :=
  Matrix.quadraticForm(c • A, x)
     = RingVector.innerProduct(x, (c • A) · x)
     = RingVector.innerProduct(x, c • (A · x)) by Matrix.applyVector_scale_matrix
     = c * RingVector.innerProduct(x, A · x) by RingVector.innerProduct_scale_right
     = c * Matrix.quadraticForm(A, x)

theorem Matrix.sumOfTwoSquaresForm_value
        (z : RingVector(Integer.commutative_ring_bundle, 2))
        : Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, z)
          = z(NaturalsBelow.firstOfTwo) * z(NaturalsBelow.firstOfTwo)
            + z(NaturalsBelow.secondOfTwo) * z(NaturalsBelow.secondOfTwo) := {
  let u : RingVector(Integer.commutative_ring_bundle, 1) :=
      (RingVector.restrictLeft :
          RingVector(Integer.commutative_ring_bundle, 1 + 1)
          → RingVector(Integer.commutative_ring_bundle, 1))(z);
  let v : RingVector(Integer.commutative_ring_bundle, 1) :=
      (RingVector.restrictRight :
          RingVector(Integer.commutative_ring_bundle, 1 + 1)
          → RingVector(Integer.commutative_ring_bundle, 1))(z);
  z = Matrix.leftBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · u
      + Matrix.rightBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · v
      by RingVector.directSum_decomposition as decomposition;
  RingVector.coordinate(u)
     = z(NaturalsBelow.sumLeft(1, 1, NaturalsBelow.top(0)))
     = z(NaturalsBelow.firstOfTwo)
  as firstCoordinate;
  RingVector.coordinate(v)
     = z(NaturalsBelow.shift(1, NaturalsBelow.top(0)))
     = z(NaturalsBelow.secondOfTwo)
  as secondCoordinate;
  Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, z)
     = Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm,
           Matrix.leftBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · u
           + Matrix.rightBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · v)
           by substituting decomposition
     = Matrix.quadraticForm(Matrix.squareForm, u) + Matrix.quadraticForm(Matrix.squareForm, v)
           by Matrix.directSum_quadraticForm
     = RingVector.coordinate(u) * RingVector.coordinate(u) + Matrix.quadraticForm(Matrix.squareForm, v)
           by substituting Matrix.squareForm_value
     = RingVector.coordinate(u) * RingVector.coordinate(u) + RingVector.coordinate(v) * RingVector.coordinate(v)
           by substituting Matrix.squareForm_value
     = z(NaturalsBelow.firstOfTwo) * z(NaturalsBelow.firstOfTwo)
       + RingVector.coordinate(v) * RingVector.coordinate(v) by substituting firstCoordinate
     = z(NaturalsBelow.firstOfTwo) * z(NaturalsBelow.firstOfTwo)
       + z(NaturalsBelow.secondOfTwo) * z(NaturalsBelow.secondOfTwo) by substituting secondCoordinate;
  done
}

theorem Matrix.sumOfTwoSquaresForm_twoCoordinates_value
        (a b : ℤ)
        : Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm,
            (RingVector.twoCoordinates(a, b) : RingVector(Integer.commutative_ring_bundle, 2)))
          = a * a + b * b := {
  let v : RingVector(Integer.commutative_ring_bundle, 2) := RingVector.twoCoordinates(a, b);
  Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, v)
     = v(NaturalsBelow.firstOfTwo) * v(NaturalsBelow.firstOfTwo)
       + v(NaturalsBelow.secondOfTwo) * v(NaturalsBelow.secondOfTwo) by Matrix.sumOfTwoSquaresForm_value
     = a * a + v(NaturalsBelow.secondOfTwo) * v(NaturalsBelow.secondOfTwo)
         by substituting RingVector.twoCoordinates_first
     = a * a + b * b by substituting RingVector.twoCoordinates_second;
  done
}

automatic theorem Matrix.sumOfTwoSquaresForm_twoCoordinates_computes
        (a b target : ℤ)
        (scalarComputation : a * a + b * b = target)
        : Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm,
            (RingVector.twoCoordinates(a, b) : RingVector(Integer.commutative_ring_bundle, 2))) = target := {
  Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm,
      (RingVector.twoCoordinates(a, b) : RingVector(Integer.commutative_ring_bundle, 2)))
     = a * a + b * b by Matrix.sumOfTwoSquaresForm_twoCoordinates_value
     = target by scalarComputation;
  done
}

theorem Matrix.squarePlusDoubleSquareForm_value
        (z : RingVector(Integer.commutative_ring_bundle, 2))
        : Matrix.quadraticForm(Matrix.squarePlusDoubleSquareForm, z)
          = z(NaturalsBelow.firstOfTwo) * z(NaturalsBelow.firstOfTwo)
            + 2 * (z(NaturalsBelow.secondOfTwo) * z(NaturalsBelow.secondOfTwo)) := {
  let u : RingVector(Integer.commutative_ring_bundle, 1) :=
      (RingVector.restrictLeft :
          RingVector(Integer.commutative_ring_bundle, 1 + 1)
          → RingVector(Integer.commutative_ring_bundle, 1))(z);
  let v : RingVector(Integer.commutative_ring_bundle, 1) :=
      (RingVector.restrictRight :
          RingVector(Integer.commutative_ring_bundle, 1 + 1)
          → RingVector(Integer.commutative_ring_bundle, 1))(z);
  z = Matrix.leftBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · u
      + Matrix.rightBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · v
      by RingVector.directSum_decomposition as decomposition;
  RingVector.coordinate(u)
     = z(NaturalsBelow.sumLeft(1, 1, NaturalsBelow.top(0)))
     = z(NaturalsBelow.firstOfTwo)
  as firstCoordinate;
  RingVector.coordinate(v)
     = z(NaturalsBelow.shift(1, NaturalsBelow.top(0)))
     = z(NaturalsBelow.secondOfTwo)
  as secondCoordinate;
  Matrix.quadraticForm(Matrix.squarePlusDoubleSquareForm, z)
     = Matrix.quadraticForm(Matrix.squarePlusDoubleSquareForm,
           Matrix.leftBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · u
           + Matrix.rightBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · v)
           by substituting decomposition
     = Matrix.quadraticForm(Matrix.squareForm, u) + Matrix.quadraticForm((2 : ℤ) • Matrix.squareForm, v)
           by Matrix.directSum_quadraticForm
     = RingVector.coordinate(u) * RingVector.coordinate(u) + Matrix.quadraticForm((2 : ℤ) • Matrix.squareForm, v)
           by substituting Matrix.squareForm_value
     = RingVector.coordinate(u) * RingVector.coordinate(u) + 2 * Matrix.quadraticForm(Matrix.squareForm, v)
           by substituting Matrix.quadraticForm_scale_matrix
     = RingVector.coordinate(u) * RingVector.coordinate(u) + 2 * (RingVector.coordinate(v) * RingVector.coordinate(v))
           by substituting Matrix.squareForm_value
     = z(NaturalsBelow.firstOfTwo) * z(NaturalsBelow.firstOfTwo)
       + 2 * (RingVector.coordinate(v) * RingVector.coordinate(v)) by substituting firstCoordinate
     = z(NaturalsBelow.firstOfTwo) * z(NaturalsBelow.firstOfTwo)
       + 2 * (z(NaturalsBelow.secondOfTwo) * z(NaturalsBelow.secondOfTwo)) by substituting secondCoordinate;
  done
}

theorem Matrix.squarePlusDoubleSquareForm_twoCoordinates_value
        (a b : ℤ)
        : Matrix.quadraticForm(Matrix.squarePlusDoubleSquareForm,
            (RingVector.twoCoordinates(a, b) : RingVector(Integer.commutative_ring_bundle, 2)))
          = a * a + 2 * (b * b) := {
  let v : RingVector(Integer.commutative_ring_bundle, 2) := RingVector.twoCoordinates(a, b);
  Matrix.quadraticForm(Matrix.squarePlusDoubleSquareForm, v)
     = v(NaturalsBelow.firstOfTwo) * v(NaturalsBelow.firstOfTwo)
       + 2 * (v(NaturalsBelow.secondOfTwo) * v(NaturalsBelow.secondOfTwo)) by Matrix.squarePlusDoubleSquareForm_value
     = a * a + 2 * (v(NaturalsBelow.secondOfTwo) * v(NaturalsBelow.secondOfTwo))
         by substituting RingVector.twoCoordinates_first
     = a * a + 2 * (b * b) by substituting RingVector.twoCoordinates_second;
  done
}

automatic theorem Matrix.squarePlusDoubleSquareForm_twoCoordinates_computes
        (a b target : ℤ)
        (scalarComputation : a * a + 2 * (b * b) = target)
        : Matrix.quadraticForm(Matrix.squarePlusDoubleSquareForm,
            (RingVector.twoCoordinates(a, b) : RingVector(Integer.commutative_ring_bundle, 2))) = target := {
  Matrix.quadraticForm(Matrix.squarePlusDoubleSquareForm,
      (RingVector.twoCoordinates(a, b) : RingVector(Integer.commutative_ring_bundle, 2)))
     = a * a + 2 * (b * b) by Matrix.squarePlusDoubleSquareForm_twoCoordinates_value
     = target by scalarComputation;
  done
}

theorem RingVector.coordinatePair_eq_twoCoordinates (a b : ℤ)
        : RingVector.appendCoordinate(
            (RingVector.oneCoordinate(a) : RingVector(Integer.commutative_ring_bundle, 1)), b)
          = (RingVector.twoCoordinates(a, b) : RingVector(Integer.commutative_ring_bundle, 2)) := {
  ∀ (i : NaturalsBelow(2)).
      RingVector.appendCoordinate(
        (RingVector.oneCoordinate(a) : RingVector(Integer.commutative_ring_bundle, 1)), b)(i)
        = (RingVector.twoCoordinates(a, b) : RingVector(Integer.commutative_ring_bundle, 2))(i)
      by (i : NaturalsBelow(2)) ↦ {
          i = NaturalsBelow.firstOfTwo ∨ i = NaturalsBelow.secondOfTwo by NaturalsBelow.two_split;
          done by cases {
            case i = NaturalsBelow.firstOfTwo as first: {
                RingVector.appendCoordinate(
                    (RingVector.oneCoordinate(a) : RingVector(Integer.commutative_ring_bundle, 1)), b)(i)
                   = RingVector.appendCoordinate(
                       (RingVector.oneCoordinate(a) : RingVector(Integer.commutative_ring_bundle, 1)), b)(
                         NaturalsBelow.firstOfTwo) by substituting first
                   = RingVector.appendCoordinate(
                       (RingVector.oneCoordinate(a) : RingVector(Integer.commutative_ring_bundle, 1)), b)(
                         NaturalsBelow.inclusion(1, NaturalsBelow.top(0)))
                         by substituting NaturalsBelow.firstOfTwo_is_inclusion
                   = (RingVector.oneCoordinate(a) : RingVector(Integer.commutative_ring_bundle, 1))(
                       NaturalsBelow.top(0)) by RingVector.appendCoordinate_inclusion
                   = a by RingVector.oneCoordinate_at
                   = (RingVector.twoCoordinates(a, b) : RingVector(Integer.commutative_ring_bundle, 2))(
                       NaturalsBelow.firstOfTwo) by RingVector.twoCoordinates_first
                   = (RingVector.twoCoordinates(a, b) : RingVector(Integer.commutative_ring_bundle, 2))(i)
                         by substituting first;
                done
              }
            case i = NaturalsBelow.secondOfTwo as second: {
                RingVector.appendCoordinate(
                    (RingVector.oneCoordinate(a) : RingVector(Integer.commutative_ring_bundle, 1)), b)(i)
                   = RingVector.appendCoordinate(
                       (RingVector.oneCoordinate(a) : RingVector(Integer.commutative_ring_bundle, 1)), b)(
                         NaturalsBelow.secondOfTwo) by substituting second
                   = RingVector.appendCoordinate(
                       (RingVector.oneCoordinate(a) : RingVector(Integer.commutative_ring_bundle, 1)), b)(
                         NaturalsBelow.top(1)) by substituting NaturalsBelow.secondOfTwo_is_top
                   = b by RingVector.appendCoordinate_top
                   = (RingVector.twoCoordinates(a, b) : RingVector(Integer.commutative_ring_bundle, 2))(
                       NaturalsBelow.secondOfTwo) by RingVector.twoCoordinates_second
                   = (RingVector.twoCoordinates(a, b) : RingVector(Integer.commutative_ring_bundle, 2))(i)
                         by substituting second;
                done
              }
          }
        };
  done by RingVector.equal_of_pointwise
}

automatic theorem Matrix.sumOfTwoSquaresForm_coordinateTuple_computes
        (a b target : ℤ)
        (scalarComputation : a * a + b * b = target)
        : Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm,
            (⟨a, b⟩ : RingVector(Integer.commutative_ring_bundle, 2))) = target := {
  Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm,
      (⟨a, b⟩ : RingVector(Integer.commutative_ring_bundle, 2)))
     = Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm,
         (RingVector.twoCoordinates(a, b) : RingVector(Integer.commutative_ring_bundle, 2)))
         by substituting RingVector.coordinatePair_eq_twoCoordinates
     = a * a + b * b by Matrix.sumOfTwoSquaresForm_twoCoordinates_value
     = target by scalarComputation;
  done
}

automatic theorem Matrix.squarePlusDoubleSquareForm_coordinateTuple_computes
        (a b target : ℤ)
        (scalarComputation : a * a + 2 * (b * b) = target)
        : Matrix.quadraticForm(Matrix.squarePlusDoubleSquareForm,
            (⟨a, b⟩ : RingVector(Integer.commutative_ring_bundle, 2))) = target := {
  Matrix.quadraticForm(Matrix.squarePlusDoubleSquareForm,
      (⟨a, b⟩ : RingVector(Integer.commutative_ring_bundle, 2)))
     = Matrix.quadraticForm(Matrix.squarePlusDoubleSquareForm,
         (RingVector.twoCoordinates(a, b) : RingVector(Integer.commutative_ring_bundle, 2)))
         by substituting RingVector.coordinatePair_eq_twoCoordinates
     = a * a + 2 * (b * b) by Matrix.squarePlusDoubleSquareForm_twoCoordinates_value
     = target by scalarComputation;
  done
}

theorem Matrix.sumOfTwoSquaresForm_represents_only_squares (target : ℤ)
        (represented : Matrix.Represents(Matrix.sumOfTwoSquaresForm, target))
        : ∃ (a b : ℤ). target = a * a + b * b := {
  choose z : RingVector(Integer.commutative_ring_bundle, 1 + 1) such that
      Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, z) = target
      from represented;
  let u : RingVector(Integer.commutative_ring_bundle, 1) :=
      (RingVector.restrictLeft :
          RingVector(Integer.commutative_ring_bundle, 1 + 1)
          → RingVector(Integer.commutative_ring_bundle, 1))(z);
  let v : RingVector(Integer.commutative_ring_bundle, 1) :=
      (RingVector.restrictRight :
          RingVector(Integer.commutative_ring_bundle, 1 + 1)
          → RingVector(Integer.commutative_ring_bundle, 1))(z);
  z = Matrix.leftBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · u
      + Matrix.rightBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · v
      by RingVector.directSum_decomposition as decomposition;
  target
     = Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, z)
     = Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm,
           Matrix.leftBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · u
           + Matrix.rightBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · v)
           by substituting decomposition
     = Matrix.quadraticForm(Matrix.squareForm, u) + Matrix.quadraticForm(Matrix.squareForm, v)
           by Matrix.directSum_quadraticForm
     = RingVector.coordinate(u) * RingVector.coordinate(u) + Matrix.quadraticForm(Matrix.squareForm, v)
           by substituting Matrix.squareForm_value
     = RingVector.coordinate(u) * RingVector.coordinate(u)
       + RingVector.coordinate(v) * RingVector.coordinate(v)
           by substituting Matrix.squareForm_value;
  witness RingVector.coordinate(u) with
      witness RingVector.coordinate(v) with done
}

theorem Matrix.sumOfTwoSquaresForm_quadraticForm_nonnegative
        (x : RingVector(Integer.commutative_ring_bundle, 2))
        : Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, x) ≥ (0 : ℤ) := {
  let q : ℤ := Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, x);
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, q)
      by { witness x with done };
  ∃ (a b : ℤ). q = a * a + b * b
      by Matrix.sumOfTwoSquaresForm_represents_only_squares;
  choose a such that ∃ (b : ℤ). q = a * a + b * b;
  choose b such that q = a * a + b * b as qIsSquares;
  (0 : ℤ) ≤ a * a by Integer.zero_less_or_equal_of_nonneg;
  (0 : ℤ) ≤ b * b by Integer.zero_less_or_equal_of_nonneg;
  b * b
     = 0 + b * b
     ≤ a * a + b * b by Integer.add_preserves_less_or_equal;
  (0 : ℤ) ≤ a * a + b * b by Integer.LessOrEqual.transitive;
  done by substituting qIsSquares
}

theorem Matrix.squarePlusDoubleSquareForm_represents_only_squares (target : ℤ)
        (represented : Matrix.Represents(Matrix.squarePlusDoubleSquareForm, target))
        : ∃ (a b : ℤ). target = a * a + 2 * (b * b) := {
  choose z : RingVector(Integer.commutative_ring_bundle, 1 + 1) such that
      Matrix.quadraticForm(Matrix.squarePlusDoubleSquareForm, z) = target
      from represented;
  let u : RingVector(Integer.commutative_ring_bundle, 1) :=
      (RingVector.restrictLeft :
          RingVector(Integer.commutative_ring_bundle, 1 + 1)
          → RingVector(Integer.commutative_ring_bundle, 1))(z);
  let v : RingVector(Integer.commutative_ring_bundle, 1) :=
      (RingVector.restrictRight :
          RingVector(Integer.commutative_ring_bundle, 1 + 1)
          → RingVector(Integer.commutative_ring_bundle, 1))(z);
  z = Matrix.leftBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · u
      + Matrix.rightBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · v
      by RingVector.directSum_decomposition as decomposition;
  target
     = Matrix.quadraticForm(Matrix.squarePlusDoubleSquareForm, z)
     = Matrix.quadraticForm(Matrix.squarePlusDoubleSquareForm,
           Matrix.leftBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · u
           + Matrix.rightBlockInclusion(Integer.commutative_ring_bundle, 1, 1) · v)
           by substituting decomposition
     = Matrix.quadraticForm(Matrix.squareForm, u)
       + Matrix.quadraticForm((2 : ℤ) • Matrix.squareForm, v)
           by Matrix.directSum_quadraticForm
     = Matrix.quadraticForm(Matrix.squareForm, u)
       + 2 * Matrix.quadraticForm(Matrix.squareForm, v)
           by substituting Matrix.quadraticForm_scale_matrix
     = RingVector.coordinate(u) * RingVector.coordinate(u)
       + 2 * Matrix.quadraticForm(Matrix.squareForm, v)
           by substituting Matrix.squareForm_value
     = RingVector.coordinate(u) * RingVector.coordinate(u)
       + 2 * (RingVector.coordinate(v) * RingVector.coordinate(v))
           by substituting Matrix.squareForm_value;
  witness RingVector.coordinate(u) with
      witness RingVector.coordinate(v) with done
}

-- ----------------------------------------------------------------------
-- The two truant calculations.

theorem Matrix.sumOfTwoSquaresForm_not_represents_of_natural
        (target : ℕ)
        (notSum : ∀ (m n : ℕ). ¬(m * m + n * n = target))
        : ¬(Matrix.Represents(
            Matrix.sumOfTwoSquaresForm, (target : ℤ))) := {
  suppose Matrix.Represents(
      Matrix.sumOfTwoSquaresForm, (target : ℤ)) as represented;
  ∃ (a b : ℤ). (target : ℤ) = a * a + b * b
      by Matrix.sumOfTwoSquaresForm_represents_only_squares;
  choose a such that ∃ (b : ℤ). (target : ℤ) = a * a + b * b;
  choose b such that (target : ℤ) = a * a + b * b;
  ∃ (m : ℕ). a * a = m * m
      by Integer.square_as_natural_square;
  choose m such that a * a = m * m;
  ∃ (n : ℕ). b * b = n * n
      by Integer.square_as_natural_square;
  choose n such that b * b = n * n;
  (target : ℤ)
     = a * a + b * b
     = m * m + n * n;
  target = m * m + n * n by Natural.to_integer.injective;
  m * m + n * n = target;
  done by notSum(m, n)
}

theorem Matrix.sumOfTwoSquaresForm_not_represents_three
        : ¬(Matrix.Represents(Matrix.sumOfTwoSquaresForm, (3 : ℤ))) := {
  done by Matrix.sumOfTwoSquaresForm_not_represents_of_natural(
      notSum := Natural.three_not_sum_of_two_squares)
}

theorem Matrix.sumOfTwoSquaresForm_not_represents_six
        : ¬(Matrix.Represents(Matrix.sumOfTwoSquaresForm, (6 : ℤ))) := {
  done by Matrix.sumOfTwoSquaresForm_not_represents_of_natural(
      notSum := Natural.six_not_sum_of_two_squares)
}

theorem Matrix.sumOfTwoSquaresForm_not_represents_seven
        : ¬(Matrix.Represents(Matrix.sumOfTwoSquaresForm, (7 : ℤ))) := {
  done by Matrix.sumOfTwoSquaresForm_not_represents_of_natural(
      notSum := Natural.seven_not_sum_of_two_squares)
}

theorem Matrix.sumOfTwoSquaresForm_not_represents_twelve
        : ¬(Matrix.Represents(Matrix.sumOfTwoSquaresForm, (12 : ℤ))) := {
  done by Matrix.sumOfTwoSquaresForm_not_represents_of_natural(
      notSum := Natural.twelve_not_sum_of_two_squares)
}

theorem Matrix.sumOfTwoSquaresForm_not_represents_fourteen
        : ¬(Matrix.Represents(Matrix.sumOfTwoSquaresForm, (14 : ℤ))) := {
  done by Matrix.sumOfTwoSquaresForm_not_represents_of_natural(
      notSum := Natural.fourteen_not_sum_of_two_squares)
}

theorem Matrix.squarePlusDoubleSquareForm_not_represents_five
        : ¬(Matrix.Represents(Matrix.squarePlusDoubleSquareForm, (5 : ℤ))) := {
  suppose Matrix.Represents(Matrix.squarePlusDoubleSquareForm, (5 : ℤ)) as represented;
  ∃ (a b : ℤ). (5 : ℤ) = a * a + 2 * (b * b)
      by Matrix.squarePlusDoubleSquareForm_represents_only_squares;
  choose a such that ∃ (b : ℤ). (5 : ℤ) = a * a + 2 * (b * b);
  choose b such that (5 : ℤ) = a * a + 2 * (b * b);
  ∃ (m : ℕ). a * a = m * m by Integer.square_as_natural_square;
  choose m such that a * a = m * m;
  ∃ (n : ℕ). b * b = n * n by Integer.square_as_natural_square;
  choose n such that b * b = n * n;
  (5 : ℤ)
     = a * a + 2 * (b * b)
     = m * m + 2 * (n * n);
  5 = m * m + 2 * (n * n) by Natural.to_integer.injective;
  m * m + 2 * (n * n) = 5;
  done by Natural.five_not_square_plus_double_square
}

theorem Matrix.sumOfTwoSquaresForm_truant_three
        : Matrix.IsTruant(Matrix.sumOfTwoSquaresForm, 3) := {
  let A : Matrix(Integer.commutative_ring_bundle, 2, 2) := Matrix.sumOfTwoSquaresForm;
  Matrix.represents_by_witness(A, target := 1, vector := ⟨1, 0⟩);
  Matrix.represents_by_witness(A, target := 2, vector := ⟨1, 1⟩);
  ¬(Matrix.Represents(Matrix.sumOfTwoSquaresForm, (3 : ℤ)))
      by Matrix.sumOfTwoSquaresForm_not_represents_three;
  ∀ (s : ℕ). s ≥ 1 → s < 3 → Matrix.Represents(Matrix.sumOfTwoSquaresForm, (s : ℤ))
      by finite_check s from 1 until 3;
  done
}

theorem Matrix.squarePlusDoubleSquareForm_truant_five
        : Matrix.IsTruant(Matrix.squarePlusDoubleSquareForm, 5) := {
  let A : Matrix(Integer.commutative_ring_bundle, 2, 2) := Matrix.squarePlusDoubleSquareForm;
  Matrix.represents_by_witness(A, target := 1, vector := ⟨1, 0⟩);
  Matrix.represents_by_witness(A, target := 2, vector := ⟨0, 1⟩);
  Matrix.represents_by_witness(A, target := 3, vector := ⟨1, 1⟩);
  Matrix.represents_by_witness(A, target := 4, vector := ⟨2, 0⟩);
  ¬(Matrix.Represents(Matrix.squarePlusDoubleSquareForm, (5 : ℤ)))
      by Matrix.squarePlusDoubleSquareForm_not_represents_five;
  ∀ (s : ℕ). s ≥ 1 → s < 5 → Matrix.Represents(Matrix.squarePlusDoubleSquareForm, (s : ℤ))
      by finite_check s from 1 until 5;
  done
}

theorem Matrix.sumOfTwoSquaresForm_truant
        : Matrix.truant(Matrix.sumOfTwoSquaresForm) = 3 :=
  by Matrix.truant_equals

theorem Matrix.squarePlusDoubleSquareForm_truant
        : Matrix.truant(Matrix.squarePlusDoubleSquareForm) = 5 :=
  by Matrix.truant_equals

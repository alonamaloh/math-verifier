  ((-3) : ℤ) = ((-4) : ℤ) + 1 by ring as step_m4;
  Integer.AllFrom(P, (-4), 10) by Integer.AllFrom.prepend(P, (-4), (-3), 9, step_m4, at_m4, from_m3) as from_m4;

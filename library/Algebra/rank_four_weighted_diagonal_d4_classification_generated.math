automatic theorem Matrix.rankFourWeightedDiagonalD4_box_p3_all_b_c
        : ∀ (b : ℤ). -5 ≤ b → b < 6
          → ∀ (c : ℤ). -7 ≤ c → c < 8
          → 8 * ((3 : ℤ) * (3 : ℤ)) + 4 * (b * b) + 2 * (c * c) < 112
          → Matrix.IsRankFourWeightedDiagonalD4NormalForm(Matrix.squarePlusDoublePlusScaledRankFourCandidate(4, 14, 3, b, c)) := {
  let P : ℤ → Proposition := (b : ℤ) ↦
      ∀ (c : ℤ). -7 ≤ c → c < 8
                  → 8 * ((3 : ℤ) * (3 : ℤ)) + 4 * (b * b) + 2 * (c * c) < 112
                  → Matrix.IsRankFourWeightedDiagonalD4NormalForm(Matrix.squarePlusDoublePlusScaledRankFourCandidate(4, 14, 3, b, c));
  P((-5)) by Matrix.rankFourWeightedDiagonalD4_box_p3_m5_all_c as at_m5;
  P((-4)) by Matrix.rankFourWeightedDiagonalD4_box_p3_m4_all_c as at_m4;
  P((-3)) by Matrix.rankFourWeightedDiagonalD4_box_p3_m3_all_c as at_m3;
  P((-2)) by Matrix.rankFourWeightedDiagonalD4_box_p3_m2_all_c as at_m2;
  P((-1)) by Matrix.rankFourWeightedDiagonalD4_box_p3_m1_all_c as at_m1;
  P(0) by Matrix.rankFourWeightedDiagonalD4_box_p3_p0_all_c as at_p0;
  P(1) by Matrix.rankFourWeightedDiagonalD4_box_p3_p1_all_c as at_p1;
  P(2) by Matrix.rankFourWeightedDiagonalD4_box_p3_p2_all_c as at_p2;
  P(3) by Matrix.rankFourWeightedDiagonalD4_box_p3_p3_all_c as at_p3;
  P(4) by Matrix.rankFourWeightedDiagonalD4_box_p3_p4_all_c as at_p4;
  P(5) by Matrix.rankFourWeightedDiagonalD4_box_p3_p5_all_c as at_p5;
  Integer.AllFrom(P, 6, 0) by Integer.AllFrom.empty(P, 6) as from_p6;
  (6 : ℤ) = (5 : ℤ) + 1 by ring as step_p5;
  Integer.AllFrom(P, 5, 1) by Integer.AllFrom.prepend(P, 5, 6, 0, step_p5, at_p5, from_p6) as from_p5;
  (5 : ℤ) = (4 : ℤ) + 1 by ring as step_p4;
  Integer.AllFrom(P, 4, 2) by Integer.AllFrom.prepend(P, 4, 5, 1, step_p4, at_p4, from_p5) as from_p4;
  (4 : ℤ) = (3 : ℤ) + 1 by ring as step_p3;
  Integer.AllFrom(P, 3, 3) by Integer.AllFrom.prepend(P, 3, 4, 2, step_p3, at_p3, from_p4) as from_p3;
  (3 : ℤ) = (2 : ℤ) + 1 by ring as step_p2;
  Integer.AllFrom(P, 2, 4) by Integer.AllFrom.prepend(P, 2, 3, 3, step_p2, at_p2, from_p3) as from_p2;
  (2 : ℤ) = (1 : ℤ) + 1 by ring as step_p1;
  Integer.AllFrom(P, 1, 5) by Integer.AllFrom.prepend(P, 1, 2, 4, step_p1, at_p1, from_p2) as from_p1;
  (1 : ℤ) = (0 : ℤ) + 1 by ring as step_p0;
  Integer.AllFrom(P, 0, 6) by Integer.AllFrom.prepend(P, 0, 1, 5, step_p0, at_p0, from_p1) as from_p0;
  (0 : ℤ) = ((-1) : ℤ) + 1 by ring as step_m1;
  Integer.AllFrom(P, (-1), 7) by Integer.AllFrom.prepend(P, (-1), 0, 6, step_m1, at_m1, from_p0) as from_m1;
  ((-1) : ℤ) = ((-2) : ℤ) + 1 by ring as step_m2;
  Integer.AllFrom(P, (-2), 8) by Integer.AllFrom.prepend(P, (-2), (-1), 7, step_m2, at_m2, from_m1) as from_m2;
  ((-2) : ℤ) = ((-3) : ℤ) + 1 by ring as step_m3;
  Integer.AllFrom(P, (-3), 9) by Integer.AllFrom.prepend(P, (-3), (-2), 8, step_m3, at_m3, from_m2) as from_m3;
  ((-3) : ℤ) = ((-4) : ℤ) + 1 by ring as step_m4;
  Integer.AllFrom(P, (-4), 10) by Integer.AllFrom.prepend(P, (-4), (-3), 9, step_m4, at_m4, from_m3) as from_m4;
  ((-4) : ℤ) = ((-5) : ℤ) + 1 by ring as step_m5;
  Integer.AllFrom(P, (-5), 11) by Integer.AllFrom.prepend(P, (-5), (-4), 10, step_m5, at_m5, from_m4) as from_m5;
  (6 : ℤ) = (-5) + (11 : ℤ) by ring as upperReads;

theorem Matrix.rankFourWeightedDiagonalD4_finite_box_classified
        : ∀ (a : ℤ). -3 ≤ a → a < 4
          → ∀ (b : ℤ). -5 ≤ b → b < 6
          → ∀ (c : ℤ). -7 ≤ c → c < 8
          → 8 * (a * a) + 4 * (b * b) + 2 * (c * c) < 112
          → Matrix.IsRankFourWeightedDiagonalD4NormalForm(Matrix.squarePlusDoublePlusScaledRankFourCandidate(4, 14, a, b, c)) := {
  let P : ℤ → Proposition := (a : ℤ) ↦
      ∀ (b : ℤ). -5 ≤ b → b < 6
                  → ∀ (c : ℤ). -7 ≤ c → c < 8
                  → 8 * (a * a) + 4 * (b * b) + 2 * (c * c) < 112
                  → Matrix.IsRankFourWeightedDiagonalD4NormalForm(Matrix.squarePlusDoublePlusScaledRankFourCandidate(4, 14, a, b, c));
  P((-3)) by Matrix.rankFourWeightedDiagonalD4_box_m3_all_b_c as at_m3;
  P((-2)) by Matrix.rankFourWeightedDiagonalD4_box_m2_all_b_c as at_m2;
  P((-1)) by Matrix.rankFourWeightedDiagonalD4_box_m1_all_b_c as at_m1;
  P(0) by Matrix.rankFourWeightedDiagonalD4_box_p0_all_b_c as at_p0;
  P(1) by Matrix.rankFourWeightedDiagonalD4_box_p1_all_b_c as at_p1;
  P(2) by Matrix.rankFourWeightedDiagonalD4_box_p2_all_b_c as at_p2;
  P(3) by Matrix.rankFourWeightedDiagonalD4_box_p3_all_b_c as at_p3;
  Integer.AllFrom(P, 4, 0) by Integer.AllFrom.empty(P, 4) as from_p4;
  (4 : ℤ) = (3 : ℤ) + 1 by ring as step_p3;
  Integer.AllFrom(P, 3, 1) by Integer.AllFrom.prepend(P, 3, 4, 0, step_p3, at_p3, from_p4) as from_p3;
  (3 : ℤ) = (2 : ℤ) + 1 by ring as step_p2;
  Integer.AllFrom(P, 2, 2) by Integer.AllFrom.prepend(P, 2, 3, 1, step_p2, at_p2, from_p3) as from_p2;
  (2 : ℤ) = (1 : ℤ) + 1 by ring as step_p1;
  Integer.AllFrom(P, 1, 3) by Integer.AllFrom.prepend(P, 1, 2, 2, step_p1, at_p1, from_p2) as from_p1;
  (1 : ℤ) = (0 : ℤ) + 1 by ring as step_p0;
  Integer.AllFrom(P, 0, 4) by Integer.AllFrom.prepend(P, 0, 1, 3, step_p0, at_p0, from_p1) as from_p0;
  (0 : ℤ) = ((-1) : ℤ) + 1 by ring as step_m1;
  Integer.AllFrom(P, (-1), 5) by Integer.AllFrom.prepend(P, (-1), 0, 4, step_m1, at_m1, from_p0) as from_m1;
  ((-1) : ℤ) = ((-2) : ℤ) + 1 by ring as step_m2;
  Integer.AllFrom(P, (-2), 6) by Integer.AllFrom.prepend(P, (-2), (-1), 5, step_m2, at_m2, from_m1) as from_m2;
  ((-2) : ℤ) = ((-3) : ℤ) + 1 by ring as step_m3;
  Integer.AllFrom(P, (-3), 7) by Integer.AllFrom.prepend(P, (-3), (-2), 6, step_m3, at_m3, from_m2) as from_m3;
  (4 : ℤ) = (-3) + (7 : ℤ) by ring as upperReads;
  take a : ℤ;
  suppose (-3) ≤ a as lower;
  suppose a < 4 as upper;
  done by Integer.AllFrom_between(P, (-3), 7, 4, upperReads, from_m3, a, lower, upper)
}

          → 8 * ((3 : ℤ) * (3 : ℤ)) + 4 * ((3 : ℤ) * (3 : ℤ)) + 2 * (c * c) < 112
          → Matrix.IsRankFourWeightedDiagonalD4NormalForm(Matrix.squarePlusDoublePlusScaledRankFourCandidate(4, 14, 3, 3, c)) := {
  let P : ℤ → Proposition := (c : ℤ) ↦
      8 * ((3 : ℤ) * (3 : ℤ)) + 4 * ((3 : ℤ) * (3 : ℤ)) + 2 * (c * c) < 112
                  → Matrix.IsRankFourWeightedDiagonalD4NormalForm(Matrix.squarePlusDoublePlusScaledRankFourCandidate(4, 14, 3, 3, c));
  P((-7)) by Matrix.rankFourWeightedDiagonalD4_box_case_p3_p3_m7 as at_m7;
  P((-6)) by Matrix.rankFourWeightedDiagonalD4_box_case_p3_p3_m6 as at_m6;
  P((-5)) by Matrix.rankFourWeightedDiagonalD4_box_case_p3_p3_m5 as at_m5;
  P((-4)) by Matrix.rankFourWeightedDiagonalD4_box_case_p3_p3_m4 as at_m4;

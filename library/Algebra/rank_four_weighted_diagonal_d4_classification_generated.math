  P((-1)) by Matrix.rankFourWeightedDiagonalD4_box_case_p3_p3_m1 as at_m1;
  P(0) by Matrix.rankFourWeightedDiagonalD4_box_case_p3_p3_p0 as at_p0;
  P(1) by Matrix.rankFourWeightedDiagonalD4_box_case_p3_p3_p1 as at_p1;
  P(2) by Matrix.rankFourWeightedDiagonalD4_box_case_p3_p3_p2 as at_p2;
  P(3) by Matrix.rankFourWeightedDiagonalD4_box_case_p3_p3_p3 as at_p3;
  P(4) by Matrix.rankFourWeightedDiagonalD4_box_case_p3_p3_p4 as at_p4;
  P(5) by Matrix.rankFourWeightedDiagonalD4_box_case_p3_p3_p5 as at_p5;
  P(6) by Matrix.rankFourWeightedDiagonalD4_box_case_p3_p3_p6 as at_p6;
  P(7) by Matrix.rankFourWeightedDiagonalD4_box_case_p3_p3_p7 as at_p7;
  Integer.AllFrom(P, 8, 0) by Integer.AllFrom.empty(P, 8) as from_p8;
  (8 : ℤ) = (7 : ℤ) + 1 by ring as step_p7;
  Integer.AllFrom(P, 7, 1) by Integer.AllFrom.prepend(P, 7, 8, 0, step_p7, at_p7, from_p8) as from_p7;
  (7 : ℤ) = (6 : ℤ) + 1 by ring as step_p6;
  Integer.AllFrom(P, 6, 2) by Integer.AllFrom.prepend(P, 6, 7, 1, step_p6, at_p6, from_p7) as from_p6;
  (6 : ℤ) = (5 : ℤ) + 1 by ring as step_p5;
  Integer.AllFrom(P, 5, 3) by Integer.AllFrom.prepend(P, 5, 6, 2, step_p5, at_p5, from_p6) as from_p5;
  (5 : ℤ) = (4 : ℤ) + 1 by ring as step_p4;
  Integer.AllFrom(P, 4, 4) by Integer.AllFrom.prepend(P, 4, 5, 3, step_p4, at_p4, from_p5) as from_p4;
  (4 : ℤ) = (3 : ℤ) + 1 by ring as step_p3;
  Integer.AllFrom(P, 3, 5) by Integer.AllFrom.prepend(P, 3, 4, 4, step_p3, at_p3, from_p4) as from_p3;
  (3 : ℤ) = (2 : ℤ) + 1 by ring as step_p2;
  Integer.AllFrom(P, 2, 6) by Integer.AllFrom.prepend(P, 2, 3, 5, step_p2, at_p2, from_p3) as from_p2;
  (2 : ℤ) = (1 : ℤ) + 1 by ring as step_p1;
  Integer.AllFrom(P, 1, 7) by Integer.AllFrom.prepend(P, 1, 2, 6, step_p1, at_p1, from_p2) as from_p1;
  (1 : ℤ) = (0 : ℤ) + 1 by ring as step_p0;
  Integer.AllFrom(P, 0, 8) by Integer.AllFrom.prepend(P, 0, 1, 7, step_p0, at_p0, from_p1) as from_p0;
  (0 : ℤ) = ((-1) : ℤ) + 1 by ring as step_m1;
  Integer.AllFrom(P, (-1), 9) by Integer.AllFrom.prepend(P, (-1), 0, 8, step_m1, at_m1, from_p0) as from_m1;
  ((-1) : ℤ) = ((-2) : ℤ) + 1 by ring as step_m2;
  Integer.AllFrom(P, (-2), 10) by Integer.AllFrom.prepend(P, (-2), (-1), 9, step_m2, at_m2, from_m1) as from_m2;
  ((-2) : ℤ) = ((-3) : ℤ) + 1 by ring as step_m3;
  Integer.AllFrom(P, (-3), 11) by Integer.AllFrom.prepend(P, (-3), (-2), 10, step_m3, at_m3, from_m2) as from_m3;
  ((-3) : ℤ) = ((-4) : ℤ) + 1 by ring as step_m4;
  Integer.AllFrom(P, (-4), 12) by Integer.AllFrom.prepend(P, (-4), (-3), 11, step_m4, at_m4, from_m3) as from_m4;
  ((-4) : ℤ) = ((-5) : ℤ) + 1 by ring as step_m5;
  Integer.AllFrom(P, (-5), 13) by Integer.AllFrom.prepend(P, (-5), (-4), 12, step_m5, at_m5, from_m4) as from_m5;
  ((-5) : ℤ) = ((-6) : ℤ) + 1 by ring as step_m6;
  Integer.AllFrom(P, (-6), 14) by Integer.AllFrom.prepend(P, (-6), (-5), 13, step_m6, at_m6, from_m5) as from_m6;

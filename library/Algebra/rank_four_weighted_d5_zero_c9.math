module Algebra.rank_four_weighted_d5_zero_c9

import Algebra.rank_four_weighted_d5_zero_residue_cover

theorem Matrix.weightedD5S0R0C9_universal_of_one_two_five_converse (converse : Matrix.OneTwoFiveConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 0, 0, 9)) :=
  by Matrix.weightedZero_universal_of_residual_cover(
      5, 9, Matrix.oneTwoFiveResidualCover_selected_cores_of_converse(
          converse, coefficient := 9, coreTen := 1, coreFifteen := 6,
          tenCoreSum := done, fifteenCoreSum := done,
          tenCoreAdmissible := (exponent b : ℕ) ↦
            Natural.twenty_five_power_times_admissible_core_not_one_two_five_obstruction(
                exponent, b, 1, done, done, done, done),
          fifteenCoreAdmissible := (exponent b : ℕ) ↦
            Natural.twenty_five_power_times_admissible_core_not_one_two_five_obstruction(
                exponent, b, 6, done, done, done, done)))

-- Algebra/rank_four_weighted_d4_even_cosets.math
--
-- The two even base cosets needed when the second residue is one.  The
-- coefficient-one squares a² and (2x)² may be exchanged; modulo sixteen,
-- cores 2 and 6 guarantee that one has the required residue modulo four.

module Algebra.rank_four_weighted_d4_even_cosets

import Algebra.rank_four_weighted_d4_coset_cover

theorem Integer.consecutive_product_even (d : ℤ)
        : ∃ (q : ℤ). d * d + d = 2 * q := {
  (∃ (r : ℤ). d = 2 * r) ∨ (∃ (r : ℤ). d = 2 * r + 1) by Integer.parity_cases(d);
  done by cases {
    case ∃ (r : ℤ). d = 2 * r: {
      choose r : ℤ such that d = 2 * r as dReads;
      witness 2 * r * r + r with
        d * d + d
           = (2 * r) * (2 * r) + 2 * r by substituting dReads
           = 2 * (2 * r * r + r) by ring
    }
    case ∃ (r : ℤ). d = 2 * r + 1: {
      choose r : ℤ such that d = 2 * r + 1 as dReads;
      witness 2 * r * r + 3 * r + 1 with
        d * d + d
           = (2 * r + 1) * (2 * r + 1) + (2 * r + 1) by substituting dReads
           = 2 * (2 * r * r + 3 * r + 1) by ring
    }
  }
}

theorem Integer.one_two_four_four_times_plus_two_has_even_odd_coordinates
        (a y x q : ℤ)
        (valueReads : a * a + 2 * (y * y) + 4 * (x * x) = 4 * q + 2)
        : ∃ (h d : ℤ). a = 2 * h ∧ y = 2 * d + 1 := {
  (∃ (h : ℤ). a = 2 * h) ∨ (∃ (h : ℤ). a = 2 * h + 1) by Integer.parity_cases(a);
  (∃ (d : ℤ). y = 2 * d) ∨ (∃ (d : ℤ). y = 2 * d + 1) by Integer.parity_cases(y);
  done by cases {
    case ∃ (h : ℤ). a = 2 * h as aEven: {
      choose h : ℤ such that a = 2 * h as aReads;
      done by cases {
        case ∃ (d : ℤ). y = 2 * d: {
          choose d : ℤ such that y = 2 * d as yReads;
          4 * (h * h + 2 * (d * d) + x * x) + 0
             = (2 * h) * (2 * h) + 2 * ((2 * d) * (2 * d)) + 4 * (x * x) by ring
             = a * a + 2 * ((2 * d) * (2 * d)) + 4 * (x * x)
                 by substituting Equality.symmetry(aReads)
             = a * a + 2 * (y * y) + 4 * (x * x) by substituting Equality.symmetry(yReads)
             = 4 * q + 2 by valueReads
          as impossible;
          False by Integer.distinct_affine_residues_not_equal(
              4, 0, 2, h * h + 2 * (d * d) + x * x, q, done, done, done, impossible);
          done
        }
        case ∃ (d : ℤ). y = 2 * d + 1: {
          choose d : ℤ such that y = 2 * d + 1 as yReads;
          witness h with witness d with And.introduction(aReads, yReads)
        }
      }
    }
    case ∃ (h : ℤ). a = 2 * h + 1 as aOdd: {
      choose h : ℤ such that a = 2 * h + 1 as aReads;
      done by cases {
        case ∃ (d : ℤ). y = 2 * d: {
          choose d : ℤ such that y = 2 * d as yReads;
          4 * (h * h + h + 2 * (d * d) + x * x) + 1
             = (2 * h + 1) * (2 * h + 1) + 2 * ((2 * d) * (2 * d)) + 4 * (x * x) by ring
             = a * a + 2 * ((2 * d) * (2 * d)) + 4 * (x * x)
                 by substituting Equality.symmetry(aReads)
             = a * a + 2 * (y * y) + 4 * (x * x) by substituting Equality.symmetry(yReads)
             = 4 * q + 2 by valueReads
          as impossible;
          False by Integer.distinct_affine_residues_not_equal(
              4, 1, 2, h * h + h + 2 * (d * d) + x * x, q, done, done, done, impossible);
          done
        }
        case ∃ (d : ℤ). y = 2 * d + 1: {
          choose d : ℤ such that y = 2 * d + 1 as yReads;
          4 * (h * h + h + 2 * (d * d + d) + x * x) + 3
             = (2 * h + 1) * (2 * h + 1) + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * (x * x) by ring
             = a * a + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * (x * x)
                 by substituting Equality.symmetry(aReads)
             = a * a + 2 * (y * y) + 4 * (x * x) by substituting Equality.symmetry(yReads)
             = 4 * q + 2 by valueReads
          as impossible;
          False by Integer.distinct_affine_residues_not_equal(
              4, 3, 2, h * h + h + 2 * (d * d + d) + x * x, q, done, done, done, impossible);
          done
        }
      }
    }
  }
}

theorem Integer.one_two_four_sixteen_times_plus_two_has_zero_one_coset
        (a y x q : ℤ)
        (valueReads : a * a + 2 * (y * y) + 4 * (x * x) = 16 * q + 2)
        : ∃ (newX newY z : ℤ).
            (4 * z) * (4 * z) + 2 * ((2 * newY + 1) * (2 * newY + 1))
              + 4 * (newX * newX) = 16 * q + 2 := {
  a * a + 2 * (y * y) + 4 * (x * x) = 4 * (4 * q) + 2 by valueReads as modFourReads;
  choose h : ℤ, d : ℤ such that a = 2 * h ∧ y = 2 * d + 1
      from Integer.one_two_four_four_times_plus_two_has_even_odd_coordinates(
          a, y, x, 4 * q, modFourReads);
  a = 2 * h as aReads;
  y = 2 * d + 1 as yReads;
  choose t : ℤ such that d * d + d = 2 * t as consecutiveReads
      from Integer.consecutive_product_even(d);
  (∃ (p : ℤ). h = 2 * p) ∨ (∃ (p : ℤ). h = 2 * p + 1) by Integer.parity_cases(h);
  (∃ (r : ℤ). x = 2 * r) ∨ (∃ (r : ℤ). x = 2 * r + 1) by Integer.parity_cases(x);
  done by cases {
    case ∃ (p : ℤ). h = 2 * p as hEven: {
      choose p : ℤ such that h = 2 * p as hReads;
      done by cases {
        case ∃ (r : ℤ). x = 2 * r: {
          choose r : ℤ such that x = 2 * r;
          witness x with witness d with witness p with
            (4 * p) * (4 * p) + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * (x * x)
               = (2 * (2 * p)) * (2 * (2 * p)) + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * (x * x) by ring
               = (2 * h) * (2 * h) + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * (x * x)
                   by substituting Equality.symmetry(hReads)
               = a * a + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * (x * x)
                   by substituting Equality.symmetry(aReads)
               = a * a + 2 * (y * y) + 4 * (x * x) by substituting Equality.symmetry(yReads)
               = 16 * q + 2 by valueReads
        }
        case ∃ (r : ℤ). x = 2 * r + 1: {
          choose r : ℤ such that x = 2 * r + 1 as xReads;
          16 * (p * p + t + r * r + r) + 6
             = 8 * (2 * (p * p) + 2 * t + 2 * (r * r) + 2 * r) + 6 by ring
             = 8 * (2 * (p * p) + (d * d + d) + 2 * (r * r) + 2 * r) + 6
                 by substituting consecutiveReads
             = (2 * (2 * p)) * (2 * (2 * p)) + 2 * ((2 * d + 1) * (2 * d + 1))
               + 4 * ((2 * r + 1) * (2 * r + 1)) by ring
             = (2 * h) * (2 * h) + 2 * ((2 * d + 1) * (2 * d + 1))
               + 4 * ((2 * r + 1) * (2 * r + 1)) by substituting Equality.symmetry(hReads)
             = a * a + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * ((2 * r + 1) * (2 * r + 1))
                 by substituting Equality.symmetry(aReads)
             = a * a + 2 * (y * y) + 4 * ((2 * r + 1) * (2 * r + 1))
                 by substituting Equality.symmetry(yReads)
             = a * a + 2 * (y * y) + 4 * (x * x) by substituting Equality.symmetry(xReads)
             = 16 * q + 2 by valueReads
          as impossible;
          False by Integer.distinct_affine_residues_not_equal(
              16, 6, 2, p * p + t + r * r + r, q, done, done, done, impossible);
          done
        }
      }
    }
    case ∃ (p : ℤ). h = 2 * p + 1 as hOdd: {
      choose p : ℤ such that h = 2 * p + 1 as hReads;
      done by cases {
        case ∃ (r : ℤ). x = 2 * r: {
          choose r : ℤ such that x = 2 * r as xReads;
          16 * (p * p + p + t + r * r) + 6
             = 8 * (2 * (p * p) + 2 * p + 2 * t + 2 * (r * r)) + 6 by ring
             = 8 * (2 * (p * p) + 2 * p + (d * d + d) + 2 * (r * r)) + 6
                 by substituting consecutiveReads
             = (2 * (2 * p + 1)) * (2 * (2 * p + 1)) + 2 * ((2 * d + 1) * (2 * d + 1))
               + 4 * ((2 * r) * (2 * r)) by ring
             = (2 * h) * (2 * h) + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * ((2 * r) * (2 * r))
                 by substituting Equality.symmetry(hReads)
             = a * a + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * ((2 * r) * (2 * r))
                 by substituting Equality.symmetry(aReads)
             = a * a + 2 * (y * y) + 4 * ((2 * r) * (2 * r)) by substituting Equality.symmetry(yReads)
             = a * a + 2 * (y * y) + 4 * (x * x) by substituting Equality.symmetry(xReads)
             = 16 * q + 2 by valueReads
          as impossible;
          False by Integer.distinct_affine_residues_not_equal(
              16, 6, 2, p * p + p + t + r * r, q, done, done, done, impossible);
          done
        }
        case ∃ (r : ℤ). x = 2 * r + 1: {
          choose r : ℤ such that x = 2 * r + 1 as xReads;
          16 * (p * p + p + t + r * r + r) + 10
             = 8 * (2 * (p * p) + 2 * p + 2 * t + 2 * (r * r) + 2 * r) + 10 by ring
             = 8 * (2 * (p * p) + 2 * p + (d * d + d) + 2 * (r * r) + 2 * r) + 10
                 by substituting consecutiveReads
             = (2 * (2 * p + 1)) * (2 * (2 * p + 1)) + 2 * ((2 * d + 1) * (2 * d + 1))
               + 4 * ((2 * r + 1) * (2 * r + 1)) by ring
             = (2 * h) * (2 * h) + 2 * ((2 * d + 1) * (2 * d + 1))
               + 4 * ((2 * r + 1) * (2 * r + 1)) by substituting Equality.symmetry(hReads)
             = a * a + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * ((2 * r + 1) * (2 * r + 1))
                 by substituting Equality.symmetry(aReads)
             = a * a + 2 * (y * y) + 4 * ((2 * r + 1) * (2 * r + 1))
                 by substituting Equality.symmetry(yReads)
             = a * a + 2 * (y * y) + 4 * (x * x) by substituting Equality.symmetry(xReads)
             = 16 * q + 2 by valueReads
          as impossible;
          False by Integer.distinct_affine_residues_not_equal(
              16, 10, 2, p * p + p + t + r * r + r, q, done, done, done, impossible);
          done
        }
      }
    }
  }
}

theorem Integer.one_two_four_sixteen_times_plus_six_has_zero_one_coset
        (a y x q : ℤ)
        (valueReads : a * a + 2 * (y * y) + 4 * (x * x) = 16 * q + 6)
        : ∃ (newX newY z : ℤ).
            (4 * z) * (4 * z) + 2 * ((2 * newY + 1) * (2 * newY + 1))
              + 4 * (newX * newX) = 16 * q + 6 := {
  a * a + 2 * (y * y) + 4 * (x * x) = 4 * (4 * q + 1) + 2 by valueReads as modFourReads;
  choose h : ℤ, d : ℤ such that a = 2 * h ∧ y = 2 * d + 1
      from Integer.one_two_four_four_times_plus_two_has_even_odd_coordinates(
          a, y, x, 4 * q + 1, modFourReads);
  a = 2 * h as aReads;
  y = 2 * d + 1 as yReads;
  choose t : ℤ such that d * d + d = 2 * t as consecutiveReads
      from Integer.consecutive_product_even(d);
  (∃ (p : ℤ). h = 2 * p) ∨ (∃ (p : ℤ). h = 2 * p + 1) by Integer.parity_cases(h);
  (∃ (r : ℤ). x = 2 * r) ∨ (∃ (r : ℤ). x = 2 * r + 1) by Integer.parity_cases(x);
  done by cases {
    case ∃ (p : ℤ). h = 2 * p as hEven: {
      choose p : ℤ such that h = 2 * p as hReads;
      done by cases {
        case ∃ (r : ℤ). x = 2 * r: {
          choose r : ℤ such that x = 2 * r as xReads;
          16 * (p * p + t + r * r) + 2
             = 8 * (2 * (p * p) + 2 * t + 2 * (r * r)) + 2 by ring
             = 8 * (2 * (p * p) + (d * d + d) + 2 * (r * r)) + 2
                 by substituting consecutiveReads
             = (2 * (2 * p)) * (2 * (2 * p)) + 2 * ((2 * d + 1) * (2 * d + 1))
               + 4 * ((2 * r) * (2 * r)) by ring
             = (2 * h) * (2 * h) + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * ((2 * r) * (2 * r))
                 by substituting Equality.symmetry(hReads)
             = a * a + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * ((2 * r) * (2 * r))
                 by substituting Equality.symmetry(aReads)
             = a * a + 2 * (y * y) + 4 * ((2 * r) * (2 * r)) by substituting Equality.symmetry(yReads)
             = a * a + 2 * (y * y) + 4 * (x * x) by substituting Equality.symmetry(xReads)
             = 16 * q + 6 by valueReads
          as impossible;
          False by Integer.distinct_affine_residues_not_equal(
              16, 2, 6, p * p + t + r * r, q, done, done, done, impossible);
          done
        }
        case ∃ (r : ℤ). x = 2 * r + 1: {
          choose r : ℤ such that x = 2 * r + 1;
          witness x with witness d with witness p with
            (4 * p) * (4 * p) + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * (x * x)
               = (2 * (2 * p)) * (2 * (2 * p)) + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * (x * x) by ring
               = (2 * h) * (2 * h) + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * (x * x)
                   by substituting Equality.symmetry(hReads)
               = a * a + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * (x * x)
                   by substituting Equality.symmetry(aReads)
               = a * a + 2 * (y * y) + 4 * (x * x) by substituting Equality.symmetry(yReads)
               = 16 * q + 6 by valueReads
        }
      }
    }
    case ∃ (p : ℤ). h = 2 * p + 1 as hOdd: {
      choose p : ℤ such that h = 2 * p + 1 as hReads;
      done by cases {
        case ∃ (r : ℤ). x = 2 * r: {
          choose r : ℤ such that x = 2 * r as xReads;
          witness h with witness d with witness r with
            (4 * r) * (4 * r) + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * (h * h)
               = 4 * ((2 * r) * (2 * r)) + 2 * ((2 * d + 1) * (2 * d + 1)) + (2 * h) * (2 * h) by ring
               = 4 * (x * x) + 2 * ((2 * d + 1) * (2 * d + 1)) + (2 * h) * (2 * h)
                   by substituting Equality.symmetry(xReads)
               = 4 * (x * x) + 2 * (y * y) + (2 * h) * (2 * h) by substituting Equality.symmetry(yReads)
               = 4 * (x * x) + 2 * (y * y) + a * a by substituting Equality.symmetry(aReads)
               = a * a + 2 * (y * y) + 4 * (x * x) by ring
               = 16 * q + 6 by valueReads
        }
        case ∃ (r : ℤ). x = 2 * r + 1: {
          choose r : ℤ such that x = 2 * r + 1 as xReads;
          16 * (p * p + p + t + r * r + r) + 10
             = 8 * (2 * (p * p) + 2 * p + 2 * t + 2 * (r * r) + 2 * r) + 10 by ring
             = 8 * (2 * (p * p) + 2 * p + (d * d + d) + 2 * (r * r) + 2 * r) + 10
                 by substituting consecutiveReads
             = (2 * (2 * p + 1)) * (2 * (2 * p + 1)) + 2 * ((2 * d + 1) * (2 * d + 1))
               + 4 * ((2 * r + 1) * (2 * r + 1)) by ring
             = (2 * h) * (2 * h) + 2 * ((2 * d + 1) * (2 * d + 1))
               + 4 * ((2 * r + 1) * (2 * r + 1)) by substituting Equality.symmetry(hReads)
             = a * a + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * ((2 * r + 1) * (2 * r + 1))
                 by substituting Equality.symmetry(aReads)
             = a * a + 2 * (y * y) + 4 * ((2 * r + 1) * (2 * r + 1))
                 by substituting Equality.symmetry(yReads)
             = a * a + 2 * (y * y) + 4 * (x * x) by substituting Equality.symmetry(xReads)
             = 16 * q + 6 by valueReads
          as impossible;
          False by Integer.distinct_affine_residues_not_equal(
              16, 10, 6, p * p + p + t + r * r + r, q, done, done, done, impossible);
          done
        }
      }
    }
  }
}

theorem Integer.one_two_four_sixteen_times_plus_six_zero_one_to_two_one
        (oldX oldY oldZ q : ℤ)
        (valueReads : (4 * oldZ) * (4 * oldZ) + 2 * ((2 * oldY + 1) * (2 * oldY + 1))
          + 4 * (oldX * oldX) = 16 * q + 6)
        : ∃ (newX newY z : ℤ).
            (4 * z + 2) * (4 * z + 2) + 2 * ((2 * newY + 1) * (2 * newY + 1))
              + 4 * (newX * newX) = 16 * q + 6 := {
  (∃ (r : ℤ). oldX = 2 * r) ∨ (∃ (r : ℤ). oldX = 2 * r + 1) by Integer.parity_cases(oldX);
  done by cases {
    case ∃ (r : ℤ). oldX = 2 * r: {
      choose r : ℤ such that oldX = 2 * r as xReads;
      choose t : ℤ such that oldY * oldY + oldY = 2 * t as consecutiveReads
          from Integer.consecutive_product_even(oldY);
      16 * (oldZ * oldZ + t + r * r) + 2
         = 8 * (2 * (oldZ * oldZ) + 2 * t + 2 * (r * r)) + 2 by ring
         = 8 * (2 * (oldZ * oldZ) + (oldY * oldY + oldY) + 2 * (r * r)) + 2
             by substituting consecutiveReads
         = (4 * oldZ) * (4 * oldZ) + 2 * ((2 * oldY + 1) * (2 * oldY + 1))
           + 4 * ((2 * r) * (2 * r)) by ring
         = (4 * oldZ) * (4 * oldZ) + 2 * ((2 * oldY + 1) * (2 * oldY + 1))
           + 4 * (oldX * oldX) by substituting Equality.symmetry(xReads)
         = 16 * q + 6 by valueReads
      as impossible;
      False by Integer.distinct_affine_residues_not_equal(
          16, 2, 6, oldZ * oldZ + t + r * r, q, done, done, done, impossible);
      done
    }
    case ∃ (r : ℤ). oldX = 2 * r + 1: {
      choose r : ℤ such that oldX = 2 * r + 1 as xReads;
      choose p : ℤ such that (4 * p + 1) * (4 * p + 1) = oldX * oldX
          as signedSquare from Integer.odd_square_can_be_signed_one_mod_four(oldX, r, xReads);
      witness 2 * oldZ with witness oldY with witness 2 * p with
        (4 * (2 * p) + 2) * (4 * (2 * p) + 2) + 2 * ((2 * oldY + 1) * (2 * oldY + 1))
          + 4 * ((2 * oldZ) * (2 * oldZ))
           = 4 * ((4 * p + 1) * (4 * p + 1)) + 2 * ((2 * oldY + 1) * (2 * oldY + 1))
             + (4 * oldZ) * (4 * oldZ) by ring
           = 4 * (oldX * oldX) + 2 * ((2 * oldY + 1) * (2 * oldY + 1))
             + (4 * oldZ) * (4 * oldZ) by substituting signedSquare
           = (4 * oldZ) * (4 * oldZ) + 2 * ((2 * oldY + 1) * (2 * oldY + 1))
             + 4 * (oldX * oldX) by ring
           = 16 * q + 6 by valueReads
    }
  }
}

theorem Integer.one_two_four_sixteen_times_plus_ten_has_two_one_coset
        (a y x q : ℤ)
        (valueReads : a * a + 2 * (y * y) + 4 * (x * x) = 16 * q + 10)
        : ∃ (newX newY z : ℤ).
            (4 * z + 2) * (4 * z + 2) + 2 * ((2 * newY + 1) * (2 * newY + 1))
              + 4 * (newX * newX) = 16 * q + 10 := {
  a * a + 2 * (y * y) + 4 * (x * x) = 4 * (4 * q + 2) + 2 by valueReads as modFourReads;
  choose h : ℤ, d : ℤ such that a = 2 * h ∧ y = 2 * d + 1
      from Integer.one_two_four_four_times_plus_two_has_even_odd_coordinates(a, y, x, 4 * q + 2, modFourReads);
  a = 2 * h as aReads;
  y = 2 * d + 1 as yReads;
  choose t : ℤ such that d * d + d = 2 * t as consecutiveReads from Integer.consecutive_product_even(d);
  (∃ (p : ℤ). h = 2 * p) ∨ (∃ (p : ℤ). h = 2 * p + 1) by Integer.parity_cases(h);
  done by cases {
    case ∃ (p : ℤ). h = 2 * p: {
      choose p : ℤ such that h = 2 * p as hReads;
      (∃ (r : ℤ). x = 2 * r) ∨ (∃ (r : ℤ). x = 2 * r + 1) by Integer.parity_cases(x);
      done by cases {
        case ∃ (r : ℤ). x = 2 * r: {
          choose r : ℤ such that x = 2 * r as xReads;
          16 * (p * p + t + r * r) + 2
             = 8 * (2 * (p * p) + 2 * t + 2 * (r * r)) + 2 by ring
             = 8 * (2 * (p * p) + (d * d + d) + 2 * (r * r)) + 2 by substituting consecutiveReads
             = (2 * (2 * p)) * (2 * (2 * p)) + 2 * ((2 * d + 1) * (2 * d + 1))
               + 4 * ((2 * r) * (2 * r)) by ring
             = (2 * h) * (2 * h) + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * ((2 * r) * (2 * r))
                 by substituting Equality.symmetry(hReads)
             = a * a + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * ((2 * r) * (2 * r))
                 by substituting Equality.symmetry(aReads)
             = a * a + 2 * (y * y) + 4 * ((2 * r) * (2 * r)) by substituting Equality.symmetry(yReads)
             = a * a + 2 * (y * y) + 4 * (x * x) by substituting Equality.symmetry(xReads)
             = 16 * q + 10 by valueReads
          as impossible;
          False by Integer.distinct_affine_residues_not_equal(
              16, 2, 10, p * p + t + r * r, q, done, done, done, impossible);
          done
        }
        case ∃ (r : ℤ). x = 2 * r + 1: {
          choose r : ℤ such that x = 2 * r + 1 as xReads;
          16 * (p * p + t + r * r + r) + 6
             = 8 * (2 * (p * p) + 2 * t + 2 * (r * r) + 2 * r) + 6 by ring
             = 8 * (2 * (p * p) + (d * d + d) + 2 * (r * r) + 2 * r) + 6
                 by substituting consecutiveReads
             = (2 * (2 * p)) * (2 * (2 * p)) + 2 * ((2 * d + 1) * (2 * d + 1))
               + 4 * ((2 * r + 1) * (2 * r + 1)) by ring
             = (2 * h) * (2 * h) + 2 * ((2 * d + 1) * (2 * d + 1))
               + 4 * ((2 * r + 1) * (2 * r + 1)) by substituting Equality.symmetry(hReads)
             = a * a + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * ((2 * r + 1) * (2 * r + 1))
                 by substituting Equality.symmetry(aReads)
             = a * a + 2 * (y * y) + 4 * ((2 * r + 1) * (2 * r + 1))
                 by substituting Equality.symmetry(yReads)
             = a * a + 2 * (y * y) + 4 * (x * x) by substituting Equality.symmetry(xReads)
             = 16 * q + 10 by valueReads
          as impossible;
          False by Integer.distinct_affine_residues_not_equal(
              16, 6, 10, p * p + t + r * r + r, q, done, done, done, impossible);
          done
        }
      }
    }
    case ∃ (p : ℤ). h = 2 * p + 1: {
      choose p : ℤ such that h = 2 * p + 1 as hReads;
      witness x with witness d with witness p with
        (4 * p + 2) * (4 * p + 2) + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * (x * x)
           = (2 * (2 * p + 1)) * (2 * (2 * p + 1)) + 2 * ((2 * d + 1) * (2 * d + 1))
             + 4 * (x * x) by ring
           = (2 * h) * (2 * h) + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * (x * x)
               by substituting Equality.symmetry(hReads)
           = a * a + 2 * ((2 * d + 1) * (2 * d + 1)) + 4 * (x * x)
               by substituting Equality.symmetry(aReads)
           = a * a + 2 * (y * y) + 4 * (x * x) by substituting Equality.symmetry(yReads)
           = 16 * q + 10 by valueReads
    }
  }
}

theorem Matrix.oneTwoFour_zero_one_core_two_base_coset_of_converse
        (converse : Matrix.OneTwoFourConverse)
        : Matrix.OneTwoFourBaseCoset(2, 0, 1) := {
  take b : ℕ;
  ¬(Natural.IsOneThreeSixFourObstruction(16 * b + 2))
      by Natural.sixteen_plus_nonzero_mod_four_core_not_one_three_six_four_obstruction(
          b, 2, 0, 2, done, done, done, done, done) as admissible;
  choose a : ℤ, y : ℤ, x : ℤ such that
      a * a + 2 * (y * y) + 4 * (x * x) = ((16 * b + 2 : ℕ) : ℤ)
      from Matrix.oneTwoFour_coordinates_of_converse(converse, 16 * b + 2, admissible);
  ((16 * b + 2 : ℕ) : ℤ) = 16 * (b : ℤ) + 2 by {
    ((16 * b + 2 : ℕ) : ℤ)
       = ((16 * b : ℕ) : ℤ) + 2 by Natural.to_integer.add_preserves
       = 16 * (b : ℤ) + 2 by substituting Natural.to_integer.multiply_preserves(16, b);
    done
  } as targetReads;
  a * a + 2 * (y * y) + 4 * (x * x) = 16 * (b : ℤ) + 2 by substituting targetReads as affineReads;
  choose newX : ℤ, newY : ℤ, z : ℤ such that
      (4 * z) * (4 * z) + 2 * ((2 * newY + 1) * (2 * newY + 1)) + 4 * (newX * newX)
        = 16 * (b : ℤ) + 2
      as controlled from Integer.one_two_four_sixteen_times_plus_two_has_zero_one_coset(
          a, y, x, (b : ℤ), affineReads);
  witness newX with witness newY with witness z with
    (4 * z + 0) * (4 * z + 0) + 2 * ((2 * newY + 1) * (2 * newY + 1)) + 4 * (newX * newX)
       = (4 * z) * (4 * z) + 2 * ((2 * newY + 1) * (2 * newY + 1)) + 4 * (newX * newX) by ring
       = 16 * (b : ℤ) + 2 by controlled
       = ((16 * b + 2 : ℕ) : ℤ) by Equality.symmetry(targetReads)
}

theorem Matrix.oneTwoFour_zero_one_core_six_base_coset_of_converse
        (converse : Matrix.OneTwoFourConverse)
        : Matrix.OneTwoFourBaseCoset(6, 0, 1) := {
  take b : ℕ;
  ¬(Natural.IsOneThreeSixFourObstruction(16 * b + 6))
      by Natural.sixteen_plus_nonzero_mod_four_core_not_one_three_six_four_obstruction(
          b, 6, 1, 2, done, done, done, done, done) as admissible;
  choose a : ℤ, y : ℤ, x : ℤ such that
      a * a + 2 * (y * y) + 4 * (x * x) = ((16 * b + 6 : ℕ) : ℤ)
      from Matrix.oneTwoFour_coordinates_of_converse(converse, 16 * b + 6, admissible);
  ((16 * b + 6 : ℕ) : ℤ) = 16 * (b : ℤ) + 6 by {
    ((16 * b + 6 : ℕ) : ℤ)
       = ((16 * b : ℕ) : ℤ) + 6 by Natural.to_integer.add_preserves
       = 16 * (b : ℤ) + 6 by substituting Natural.to_integer.multiply_preserves(16, b);
    done
  } as targetReads;
  a * a + 2 * (y * y) + 4 * (x * x) = 16 * (b : ℤ) + 6 by substituting targetReads as affineReads;
  choose newX : ℤ, newY : ℤ, z : ℤ such that
      (4 * z) * (4 * z) + 2 * ((2 * newY + 1) * (2 * newY + 1)) + 4 * (newX * newX)
        = 16 * (b : ℤ) + 6
      as controlled from Integer.one_two_four_sixteen_times_plus_six_has_zero_one_coset(
          a, y, x, (b : ℤ), affineReads);
  witness newX with witness newY with witness z with
    (4 * z + 0) * (4 * z + 0) + 2 * ((2 * newY + 1) * (2 * newY + 1)) + 4 * (newX * newX)
       = (4 * z) * (4 * z) + 2 * ((2 * newY + 1) * (2 * newY + 1)) + 4 * (newX * newX) by ring
       = 16 * (b : ℤ) + 6 by controlled
       = ((16 * b + 6 : ℕ) : ℤ) by Equality.symmetry(targetReads)
}

theorem Matrix.oneTwoFour_two_one_core_six_base_coset_of_converse
        (converse : Matrix.OneTwoFourConverse)
        : Matrix.OneTwoFourBaseCoset(6, 2, 1) := {
  take b : ℕ;
  choose oldX : ℤ, oldY : ℤ, oldZ : ℤ such that
      (4 * oldZ) * (4 * oldZ) + 2 * ((2 * oldY + 1) * (2 * oldY + 1)) + 4 * (oldX * oldX)
        = ((16 * b + 6 : ℕ) : ℤ)
      from Matrix.oneTwoFour_zero_one_core_six_base_coset_of_converse(converse, b);
  ((16 * b + 6 : ℕ) : ℤ) = 16 * (b : ℤ) + 6 by {
    ((16 * b + 6 : ℕ) : ℤ)
       = ((16 * b : ℕ) : ℤ) + 6 by Natural.to_integer.add_preserves
       = 16 * (b : ℤ) + 6 by substituting Natural.to_integer.multiply_preserves(16, b);
    done
  } as targetReads;
  (4 * oldZ) * (4 * oldZ) + 2 * ((2 * oldY + 1) * (2 * oldY + 1)) + 4 * (oldX * oldX)
      = 16 * (b : ℤ) + 6 by substituting targetReads as affineReads;
  choose newX : ℤ, newY : ℤ, z : ℤ such that
      (4 * z + 2) * (4 * z + 2) + 2 * ((2 * newY + 1) * (2 * newY + 1)) + 4 * (newX * newX)
        = 16 * (b : ℤ) + 6
      as controlled from Integer.one_two_four_sixteen_times_plus_six_zero_one_to_two_one(
          oldX, oldY, oldZ, (b : ℤ), affineReads);
  witness newX with witness newY with witness z with
    (4 * z + 2) * (4 * z + 2) + 2 * ((2 * newY + 1) * (2 * newY + 1)) + 4 * (newX * newX)
       = 16 * (b : ℤ) + 6 by controlled
       = ((16 * b + 6 : ℕ) : ℤ) by Equality.symmetry(targetReads)
}

theorem Matrix.oneTwoFour_two_one_core_ten_base_coset_of_converse
        (converse : Matrix.OneTwoFourConverse)
        : Matrix.OneTwoFourBaseCoset(10, 2, 1) := {
  take b : ℕ;
  ¬(Natural.IsOneThreeSixFourObstruction(16 * b + 10))
      by Natural.sixteen_plus_nonzero_mod_four_core_not_one_three_six_four_obstruction(
          b, 10, 2, 2, done, done, done, done, done) as admissible;
  choose a : ℤ, y : ℤ, x : ℤ such that
      a * a + 2 * (y * y) + 4 * (x * x) = ((16 * b + 10 : ℕ) : ℤ)
      from Matrix.oneTwoFour_coordinates_of_converse(converse, 16 * b + 10, admissible);
  ((16 * b + 10 : ℕ) : ℤ) = 16 * (b : ℤ) + 10 by {
    ((16 * b + 10 : ℕ) : ℤ)
       = ((16 * b : ℕ) : ℤ) + 10 by Natural.to_integer.add_preserves
       = 16 * (b : ℤ) + 10 by substituting Natural.to_integer.multiply_preserves(16, b);
    done
  } as targetReads;
  a * a + 2 * (y * y) + 4 * (x * x) = 16 * (b : ℤ) + 10 by substituting targetReads as affineReads;
  choose newX : ℤ, newY : ℤ, z : ℤ such that
      (4 * z + 2) * (4 * z + 2) + 2 * ((2 * newY + 1) * (2 * newY + 1)) + 4 * (newX * newX)
        = 16 * (b : ℤ) + 10
      as controlled from Integer.one_two_four_sixteen_times_plus_ten_has_two_one_coset(
          a, y, x, (b : ℤ), affineReads);
  witness newX with witness newY with witness z with
    (4 * z + 2) * (4 * z + 2) + 2 * ((2 * newY + 1) * (2 * newY + 1)) + 4 * (newX * newX)
       = 16 * (b : ℤ) + 10 by controlled
       = ((16 * b + 10 : ℕ) : ℤ) by Equality.symmetry(targetReads)
}

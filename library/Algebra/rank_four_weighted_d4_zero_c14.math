module Algebra.rank_four_weighted_d4_zero_c14

import Algebra.rank_four_weighted_d4_zero_c14_cover

theorem Matrix.weightedD4S0R0C14_universal_of_one_two_four_converse (converse : Matrix.OneTwoFourConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 0, 14)) :=
  by Matrix.weightedZero_universal_of_residual_cover(4, 14, Matrix.oneTwoFourResidualCover_fourteen_of_converse(converse))

-- Algebra/group_lemmas.math
--
-- Generic lemmas that hold for every group. Proved once against the
-- `IsGroup` predicate; usable on any specific group by passing the
-- corresponding instance proof. This is the payoff of the
-- abstraction: a fact like "the inverse is unique" doesn't need to
-- be re-proved for Integer, Rational, Matrix, etc.

module Algebra.group_lemmas

import Logic.basics
import Equality.basics
import Algebra.monoid
import Algebra.group

-- Uniqueness of the right inverse: if `a · b = identity` then `b = a⁻¹`.
theorem Group.right_inverse_unique
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        (a b : carrier)
        (combineHypothesis : a · b = identity)
        : b = a⁻¹ := {
    calc b
       = identity · b
       = (a⁻¹ · a) · b
       = a⁻¹ · (a · b)
       = a⁻¹ · identity
       = a⁻¹
}

-- Symmetric: if `b · a = identity` then `b = a⁻¹`. Same proof shape, using
-- `inverse_right` and `identity_right` / `identity_left` in mirrored
-- positions.
theorem Group.left_inverse_unique
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        (a b : carrier)
        (combineHypothesis : b · a = identity)
        : b = a⁻¹ := {
    calc b
       = b · identity
       = b · (a · a⁻¹)
       = (b · a) · a⁻¹
       = identity · a⁻¹
       = a⁻¹
}

-- Left cancellation: `a · b = a · c` → `b = c`. Apply a⁻¹ on the left,
-- then collapse via associativity + inverse_left + identity_left.
theorem Group.cancel_left
        {carrier : Type(0)}
        {(·) : carrier → carrier → carrier}
        {identity : carrier}
        {(⁻¹) : carrier → carrier}
        {groupProof : IsGroup(carrier, (·), identity, (⁻¹))}
        (a b c : carrier)
        (equation : a · b = a · c)
        : b = c := {
    calc b
       = identity · b
       = (a⁻¹ · a) · b
       = a⁻¹ · (a · b)
       = a⁻¹ · (a · c)
       = (a⁻¹ · a) · c
       = identity · c
       = c
}

-- Right cancellation: `b · a = c · a` → `b = c`. Mirror of the left
-- version, using `inverse_right` and `identity_right`.
theorem Group.cancel_right
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        (a b c : carrier)
        (equation : b · a = c · a)
        : b = c := {
    calc b
       = b · identity
       = b · (a · a⁻¹)
       = (b · a) · a⁻¹
       = (c · a) · a⁻¹
       = c · (a · a⁻¹)
       = c · identity
       = c
}

-- The inverse function is an involution: `(x⁻¹)⁻¹ = x`.
theorem Group.inverse_involution
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        (x : carrier)
        : (x⁻¹)⁻¹ = x :=
  group

-- The inverse of the identity is the identity.
theorem Group.inverse_identity
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        : identity⁻¹ = identity :=
  group

-- `(a · b)⁻¹ = b⁻¹ · a⁻¹`: the inverse of a product is the product of the
-- inverses in reverse order.
theorem Group.inverse_operation
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        (a b : carrier)
        : (a · b)⁻¹ = b⁻¹ · a⁻¹ :=
  group

-- In an abelian group, `(a · b)⁻¹ = a⁻¹ · b⁻¹`. Compose `inverse_operation`
-- with commutativity on the result.
theorem AbelianGroup.inverse_operation
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (abelianProof : IsAbelianGroup(carrier, (·), identity, (⁻¹)))
        (a b : carrier)
        : (a · b)⁻¹ = a⁻¹ · b⁻¹ := {
    -- `(a·b)⁻¹ = b⁻¹·a⁻¹` in any group, then commute (the abelian legs of
    -- `abelianProof`, taken as facts on their own).
    claim IsGroup(carrier, (·), identity, (⁻¹));
    claim commutativity : ∀ (x y : carrier). x · y = y · x;
    calc (a · b)⁻¹
       = b⁻¹ · a⁻¹   since Group.inverse_operation
       = a⁻¹ · b⁻¹   by commutativity(b⁻¹, a⁻¹)
}

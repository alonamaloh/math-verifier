-- Algebra/group_lemmas.math
--
-- Generic lemmas that hold for every group. Proved once against the
-- `IsGroup` predicate; usable on any specific group by passing the
-- corresponding instance proof. This is the payoff of the
-- abstraction: a fact like "the inverse is unique" doesn't need to
-- be re-proved for Integer, Rational, Matrix, etc.

module Algebra.group_lemmas

import Logic.basics
import Equality.basics
import Algebra.monoid
import Algebra.group

-- Uniqueness of the right inverse: if `a آ· b = identity` then `b = aâپ»آ¹`.
--
-- Proof: b = e آ· b              [identity_left]
--          = (aâپ»آ¹ آ· a) آ· b      [inverse_left]
--          = aâپ»آ¹ آ· (a آ· b)      [associativity]
--          = aâپ»آ¹ آ· e            [hypothesis]
--          = aâپ»آ¹                [identity_right]
theorem Group.right_inverse_unique
        (carrier : Type(0))
        ((آ·) : carrier â†’ carrier â†’ carrier)
        (identity : carrier)
        ((âپ»آ¹) : carrier â†’ carrier)
        (groupProof : IsGroup(carrier, (آ·), identity, (âپ»آ¹)))
        (a b : carrier)
        (combineHypothesis : a آ· b = identity)
        : b = aâپ»آ¹ := {
    calc b
       = identity آ· b
       = (aâپ»آ¹ آ· a) آ· b
       = aâپ»آ¹ آ· (a آ· b)
       = aâپ»آ¹ آ· identity
       = aâپ»آ¹
}

-- Symmetric: if `b آ· a = identity` then `b = aâپ»آ¹`. Same proof shape, using
-- `inverse_right` and `identity_right` / `identity_left` in mirrored
-- positions.
theorem Group.left_inverse_unique
        (carrier : Type(0))
        ((آ·) : carrier â†’ carrier â†’ carrier)
        (identity : carrier)
        ((âپ»آ¹) : carrier â†’ carrier)
        (groupProof : IsGroup(carrier, (آ·), identity, (âپ»آ¹)))
        (a b : carrier)
        (combineHypothesis : b آ· a = identity)
        : b = aâپ»آ¹ := {
    calc b
       = b آ· identity
       = b آ· (a آ· aâپ»آ¹)
       = (b آ· a) آ· aâپ»آ¹
       = identity آ· aâپ»آ¹
       = aâپ»آ¹
}

-- Left cancellation: `a آ· b = a آ· c` â†’ `b = c`. Apply aâپ»آ¹ on the left,
-- then collapse via associativity + inverse_left + identity_left.
theorem Group.cancel_left
        {carrier : Type(0)}
        {(آ·) : carrier â†’ carrier â†’ carrier}
        {identity : carrier}
        {(âپ»آ¹) : carrier â†’ carrier}
        {groupProof : IsGroup(carrier, (آ·), identity, (âپ»آ¹))}
        (a b c : carrier)
        (equation : a آ· b = a آ· c)
        : b = c := {
    calc b
       = identity آ· b
       = (aâپ»آ¹ آ· a) آ· b
       = aâپ»آ¹ آ· (a آ· b)
       = aâپ»آ¹ آ· (a آ· c)
       = (aâپ»آ¹ آ· a) آ· c
       = identity آ· c
       = c
}

-- Right cancellation: `b آ· a = c آ· a` â†’ `b = c`. Mirror of the left
-- version, using `inverse_right` and `identity_right`.
theorem Group.cancel_right
        (carrier : Type(0))
        ((آ·) : carrier â†’ carrier â†’ carrier)
        (identity : carrier)
        ((âپ»آ¹) : carrier â†’ carrier)
        (groupProof : IsGroup(carrier, (آ·), identity, (âپ»آ¹)))
        (a b c : carrier)
        (equation : b آ· a = c آ· a)
        : b = c := {
    calc b
       = b آ· identity
       = b آ· (a آ· aâپ»آ¹)
       = (b آ· a) آ· aâپ»آ¹
       = (c آ· a) آ· aâپ»آ¹
       = c آ· (a آ· aâپ»آ¹)
       = c آ· identity
       = c
}

-- The inverse function is an involution: `(xâپ»آ¹)âپ»آ¹ = x`. Both `(xâپ»آ¹)âپ»آ¹` and
-- `x` are right inverses of `xâپ»آ¹` (each collapses to `identity` under `xâپ»آ¹`
-- on the left), so left-cancellation identifies them.
theorem Group.inverse_involution
        (carrier : Type(0))
        ((آ·) : carrier â†’ carrier â†’ carrier)
        (identity : carrier)
        ((âپ»آ¹) : carrier â†’ carrier)
        (groupProof : IsGroup(carrier, (آ·), identity, (âپ»آ¹)))
        (x : carrier)
        : (xâپ»آ¹)âپ»آ¹ = x := {
    calc xâپ»آ¹ آ· (xâپ»آ¹)âپ»آ¹
       = identity   since IsGroup.inverse_right
       = xâپ»آ¹ آ· x;
    done since Group.cancel_left
}

-- The inverse of the identity is the identity. Both `identityâپ»آ¹` and
-- `identity` are right inverses of `identity`, so left-cancellation
-- identifies them.
theorem Group.inverse_identity
        (carrier : Type(0))
        ((آ·) : carrier â†’ carrier â†’ carrier)
        (identity : carrier)
        ((âپ»آ¹) : carrier â†’ carrier)
        (groupProof : IsGroup(carrier, (آ·), identity, (âپ»آ¹)))
        : identityâپ»آ¹ = identity := {
    calc identity آ· identityâپ»آ¹
       = identity              since IsGroup.inverse_right
       = identity آ· identity;
    done since Group.cancel_left
}

-- `(a آ· b)âپ»آ¹ = bâپ»آ¹ آ· aâپ»آ¹`: the inverse of a product is the product of the
-- inverses in reverse order. Both `(a آ· b)âپ»آ¹` and `bâپ»آ¹ آ· aâپ»آ¹` are right
-- inverses of `a آ· b` â€” the latter because associativity collapses
-- `(a آ· b) آ· (bâپ»آ¹ آ· aâپ»آ¹)` to `identity` â€” so left-cancellation identifies them.
theorem Group.inverse_operation
        (carrier : Type(0))
        ((آ·) : carrier â†’ carrier â†’ carrier)
        (identity : carrier)
        ((âپ»آ¹) : carrier â†’ carrier)
        (groupProof : IsGroup(carrier, (آ·), identity, (âپ»آ¹)))
        (a b : carrier)
        : (a آ· b)âپ»آ¹ = bâپ»آ¹ آ· aâپ»آ¹ := {
    claim (a آ· b) آ· (bâپ»آ¹ آ· aâپ»آ¹) = identity by group;
    calc (a آ· b) آ· (a آ· b)âپ»آ¹
       = identity                since IsGroup.inverse_right
       = (a آ· b) آ· (bâپ»آ¹ آ· aâپ»آ¹);
    done since Group.cancel_left
}

-- In an abelian group, `(a آ· b)âپ»آ¹ = aâپ»آ¹ آ· bâپ»آ¹`. Compose `inverse_operation`
-- with commutativity on the result.
theorem AbelianGroup.inverse_operation
        (carrier : Type(0))
        ((آ·) : carrier â†’ carrier â†’ carrier)
        (identity : carrier)
        ((âپ»آ¹) : carrier â†’ carrier)
        (abelianProof : IsAbelianGroup(carrier, (آ·), identity, (âپ»آ¹)))
        (a b : carrier)
        : (a آ· b)âپ»آ¹ = aâپ»آ¹ آ· bâپ»آ¹ := {
    let âں¨groupProof, commutativityâں© := abelianProof;
    calc (a آ· b)âپ»آ¹
       = bâپ»آ¹ آ· aâپ»آ¹   since Group.inverse_operation
       = aâپ»آ¹ آ· bâپ»آ¹   by commutativity(bâپ»آ¹, aâپ»آ¹)
}

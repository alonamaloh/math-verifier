-- Algebra/finite_permutation.math
--
-- The symmetric group Sₙ: permutations of the finite index type
-- `NaturalsBelow(n)`. This is the Sₙ scaffolding the determinant is built on
-- (Stage H0 of PLAN_LINEAR_ALGEBRA.md).
--
-- A permutation is carried as an explicit INVERSE PAIR — a `forward` map, its
-- `backward` map, and a `Function.IsInverse` proof binding them. Storing the
-- inverse (rather than an existential `IsBijective`) is what let `Equinumerous`
-- be an equivalence constructively; here it makes `compose`/`inverse`/`identity`
-- reuse the equinumerosity engine directly and keeps the inverse CANONICAL —
-- `apply(inverse(p))` reduces to `backward` with no appeal to choice, exactly
-- what the choice-free determinant reindexing wants.

module Algebra.finite_permutation

import Logic.basics
import Equality.basics
import Logic.functions
import Natural.basics
import Natural.order
import Natural.classical_decidable
import Set.finite
import Set.finite_pigeonhole
import Set.equinumerous
import Algebra.exchange_lemma

-- ----------------------------------------------------------------------
-- The permutation object and its projections.

inductive Permutation (n : Natural) : Type(0) where
  | Permutation.make
      : (forward : NaturalsBelow(n) → NaturalsBelow(n))
        → (backward : NaturalsBelow(n) → NaturalsBelow(n))
        → Function.IsInverse(NaturalsBelow(n), NaturalsBelow(n), forward, backward)
        → Permutation(n)

-- Apply the permutation (the forward map).
definition Permutation.apply {n : Natural}
        : Permutation(n) → NaturalsBelow(n) → NaturalsBelow(n)
  | Permutation.make(forward, _, _) => forward

-- A permutation applies like the map it wraps: `sigma(i)` is the image
-- of the index i under sigma.
operator (()) on (Permutation) := Permutation.apply

-- Apply the inverse permutation (the backward map).
definition Permutation.unapply {n : Natural}
        : Permutation(n) → NaturalsBelow(n) → NaturalsBelow(n)
  | Permutation.make(_, backward, _) => backward

-- The inverse-pair witness binding `apply` to `unapply`.
definition Permutation.is_inverse {n : Natural}
        : (p : Permutation(n))
          → Function.IsInverse(NaturalsBelow(n), NaturalsBelow(n),
                Permutation.apply(p), Permutation.unapply(p))
  | Permutation.make(_, _, proof) => proof

-- The two characterising equations, unpacked.
theorem Permutation.left_inverse {n : Natural} (p : Permutation(n)) (i : NaturalsBelow(n))
        : Permutation.unapply(p, p(i)) = i := {
  (∀ (j : NaturalsBelow(n)). Permutation.unapply(p, p(j)) = j)
      by Permutation.is_inverse as cancelForward;
  cancelForward(i)
}

theorem Permutation.right_inverse {n : Natural} (p : Permutation(n)) (i : NaturalsBelow(n))
        : p(Permutation.unapply(p, i)) = i := {
  (∀ (j : NaturalsBelow(n)). p(Permutation.unapply(p, j)) = j)
      by Permutation.is_inverse as cancelBackward;
  cancelBackward(i)
}

-- ----------------------------------------------------------------------
-- Extensional equality: a permutation is determined by its `apply` map.
--
-- The record is glued back together from its fields with proof irrelevance
-- absorbing the `IsInverse` witness — the same move `Subtype.make_equal` makes,
-- here for a two-data-field constructor (transport `forward`, then `backward`).

-- Implementation note: transport the inverse proof along the `forward`
-- change with the `backward` field held fixed; a pure equality-recursor step.
theorem Permutation.make_equal_forward {n : Natural}
        (forward forwardPrime backward : NaturalsBelow(n) → NaturalsBelow(n))
        (inverse : Function.IsInverse(NaturalsBelow(n), NaturalsBelow(n), forward, backward))
        (forwardEqual : forward = forwardPrime)
        : Permutation.make(n, forward, backward, inverse)
          = Permutation.make(n, forwardPrime, backward,
                Equality.transport_proposition(
                    (g : NaturalsBelow(n) → NaturalsBelow(n))
                        ↦ Function.IsInverse(NaturalsBelow(n), NaturalsBelow(n), g, backward),
                    forward, forwardPrime, forwardEqual, inverse)) :=
  Equality_recursor(
      NaturalsBelow(n) → NaturalsBelow(n), forward,
      (g : NaturalsBelow(n) → NaturalsBelow(n)) (step : forward = g) ↦
        Equality(Permutation(n),
            Permutation.make(n, forward, backward, inverse),
            Permutation.make(n, g, backward,
                Equality.transport_proposition(
                    (h : NaturalsBelow(n) → NaturalsBelow(n))
                        ↦ Function.IsInverse(NaturalsBelow(n), NaturalsBelow(n), h, backward),
                    forward, g, step, inverse))),
      reflexivity(Permutation.make(n, forward, backward, inverse)),
      forwardPrime, forwardEqual)

-- Implementation note: the mirror, transporting along the `backward` change.
theorem Permutation.make_equal_backward {n : Natural}
        (forward backward backwardPrime : NaturalsBelow(n) → NaturalsBelow(n))
        (inverse : Function.IsInverse(NaturalsBelow(n), NaturalsBelow(n), forward, backward))
        (backwardEqual : backward = backwardPrime)
        : Permutation.make(n, forward, backward, inverse)
          = Permutation.make(n, forward, backwardPrime,
                Equality.transport_proposition(
                    (c : NaturalsBelow(n) → NaturalsBelow(n))
                        ↦ Function.IsInverse(NaturalsBelow(n), NaturalsBelow(n), forward, c),
                    backward, backwardPrime, backwardEqual, inverse)) :=
  Equality_recursor(
      NaturalsBelow(n) → NaturalsBelow(n), backward,
      (c : NaturalsBelow(n) → NaturalsBelow(n)) (step : backward = c) ↦
        Equality(Permutation(n),
            Permutation.make(n, forward, backward, inverse),
            Permutation.make(n, forward, c,
                Equality.transport_proposition(
                    (d : NaturalsBelow(n) → NaturalsBelow(n))
                        ↦ Function.IsInverse(NaturalsBelow(n), NaturalsBelow(n), forward, d),
                    backward, c, step, inverse))),
      reflexivity(Permutation.make(n, forward, backward, inverse)),
      backwardPrime, backwardEqual)

theorem Permutation.make_equal {n : Natural}
        (forward forwardPrime backward backwardPrime : NaturalsBelow(n) → NaturalsBelow(n))
        (inverse : Function.IsInverse(NaturalsBelow(n), NaturalsBelow(n), forward, backward))
        (inversePrime : Function.IsInverse(NaturalsBelow(n), NaturalsBelow(n), forwardPrime, backwardPrime))
        (forwardEqual : forward = forwardPrime) (backwardEqual : backward = backwardPrime)
        : Permutation.make(n, forward, backward, inverse)
          = Permutation.make(n, forwardPrime, backwardPrime, inversePrime) :=
  -- Two field-transports, then proof irrelevance closes the witness field.
  Permutation.make(n, forward, backward, inverse)
     = Permutation.make(n, forwardPrime, backward,
           Equality.transport_proposition(
               (g : NaturalsBelow(n) → NaturalsBelow(n))
                   ↦ Function.IsInverse(NaturalsBelow(n), NaturalsBelow(n), g, backward),
               forward, forwardPrime, forwardEqual, inverse))
     = Permutation.make(n, forwardPrime, backwardPrime, inversePrime)

-- Every permutation is its own fields reassembled.
theorem Permutation.eta {n : Natural} (p : Permutation(n))
        : p = Permutation.make(n, Permutation.apply(p), Permutation.unapply(p),
                  Permutation.is_inverse(p)) :=
  by induction on p {
    case Permutation.make(forward, backward, proof):
        reflexivity(Permutation.make(n, forward, backward, proof))
  }

-- The workhorse: permutations with equal `apply` maps are equal. Their
-- `unapply` maps then agree too (inverses of the same map are unique), and
-- proof irrelevance handles the witness.
theorem Permutation.equal_of_apply_equal {n : Natural} (p q : Permutation(n))
        (applyEqual : ∀ (i : NaturalsBelow(n)). p(i) = q(i))
        : p = q := {
  ∀ (i : NaturalsBelow(n)). Permutation.unapply(p, i) = Permutation.unapply(q, i)
    by { take i : NaturalsBelow(n);
         Permutation.unapply(p, i)
            = Permutation.unapply(q, q(Permutation.unapply(p, i)))
            = Permutation.unapply(q, p(Permutation.unapply(p, i)))
                  by substituting applyEqual(Permutation.unapply(p, i))
            = Permutation.unapply(q, i);
         done };
  Permutation.apply(p) = Permutation.apply(q) by Function.extensionality;
  Permutation.unapply(p) = Permutation.unapply(q) by Function.extensionality;
  p  = Permutation.make(n, Permutation.apply(p), Permutation.unapply(p), Permutation.is_inverse(p))
     = Permutation.make(n, Permutation.apply(q), Permutation.unapply(q), Permutation.is_inverse(q))
     = q
}

-- ----------------------------------------------------------------------
-- The group operations.

definition Permutation.identity (n : Natural) : Permutation(n) :=
  Permutation.make(n, (i : NaturalsBelow(n)) ↦ i, (i : NaturalsBelow(n)) ↦ i,
      Function.identity_is_inverse(NaturalsBelow(n)))

-- Composition `p ∘ q`: apply q, then p.
definition Permutation.compose {n : Natural} (p q : Permutation(n)) : Permutation(n) :=
  Permutation.make(n,
      (i : NaturalsBelow(n)) ↦ p(q(i)),
      (i : NaturalsBelow(n)) ↦ Permutation.unapply(q, Permutation.unapply(p, i)),
      Function.compose_inverse(NaturalsBelow(n), NaturalsBelow(n), NaturalsBelow(n),
          Permutation.apply(q), Permutation.unapply(q),
          Permutation.apply(p), Permutation.unapply(p),
          Permutation.is_inverse(q), Permutation.is_inverse(p)))

-- The inverse permutation: swap the forward and backward maps.
definition Permutation.inverse {n : Natural} (p : Permutation(n)) : Permutation(n) :=
  Permutation.make(n, Permutation.unapply(p), Permutation.apply(p),
      Function.inverse_swap(NaturalsBelow(n), NaturalsBelow(n),
          Permutation.apply(p), Permutation.unapply(p), Permutation.is_inverse(p)))

-- The reductions the group laws run on (each holds by construction).
theorem Permutation.apply_identity {n : Natural} (i : NaturalsBelow(n))
        : Permutation.identity(n)(i) = i :=
  reflexivity(i)

theorem Permutation.apply_compose {n : Natural} (p q : Permutation(n)) (i : NaturalsBelow(n))
        : Permutation.compose(p, q)(i) = p(q(i)) :=
  reflexivity(p(q(i)))

theorem Permutation.apply_inverse {n : Natural} (p : Permutation(n)) (i : NaturalsBelow(n))
        : Permutation.inverse(p)(i) = Permutation.unapply(p, i) :=
  reflexivity(Permutation.unapply(p, i))

-- ----------------------------------------------------------------------
-- The group laws.

-- `apply` of both sides reduces to the same map, so each law is `apply`-wise
-- immediate — by construction for the identity/associativity laws, and by the
-- inverse-pair cancellation for the inverse laws.

theorem Permutation.compose_identity_left {n : Natural} (p : Permutation(n))
        : Permutation.compose(Permutation.identity(n), p) = p :=
  done

theorem Permutation.compose_identity_right {n : Natural} (p : Permutation(n))
        : Permutation.compose(p, Permutation.identity(n)) = p :=
  done

theorem Permutation.compose_associative {n : Natural} (p q r : Permutation(n))
        : Permutation.compose(Permutation.compose(p, q), r)
          = Permutation.compose(p, Permutation.compose(q, r)) :=
  done

theorem Permutation.inverse_compose_left {n : Natural} (p : Permutation(n))
        : Permutation.compose(Permutation.inverse(p), p) = Permutation.identity(n) := {
  ∀ (i : NaturalsBelow(n)). Permutation.compose(Permutation.inverse(p), p)(i) = Permutation.identity(n)(i)
      by Permutation.left_inverse;
  done by Permutation.equal_of_apply_equal
}

theorem Permutation.inverse_compose_right {n : Natural} (p : Permutation(n))
        : Permutation.compose(p, Permutation.inverse(p)) = Permutation.identity(n) := {
  ∀ (i : NaturalsBelow(n)). Permutation.compose(p, Permutation.inverse(p))(i) = Permutation.identity(n)(i)
    by { take i : NaturalsBelow(n); done by Permutation.right_inverse };
  done by Permutation.equal_of_apply_equal
}

-- ----------------------------------------------------------------------
-- Transpositions: the permutation swapping two indices, fixing the rest.
-- The building block of both the permutation enumeration and the sign.

definition Permutation.swapMap {n : Natural} (a b : NaturalsBelow(n))
        : NaturalsBelow(n) → NaturalsBelow(n) :=
  (i : NaturalsBelow(n)) ↦ if i = a then b else if i = b then a else i

-- The three characterising values: `a ↦ b`, `b ↦ a`, everything else fixed.
theorem Permutation.swapMap_at_left {n : Natural} (a b : NaturalsBelow(n))
        : Permutation.swapMap(a, b, a) = b :=
  done by Logic.if_positive

theorem Permutation.swapMap_at_right {n : Natural} (a b : NaturalsBelow(n))
        : Permutation.swapMap(a, b, b) = a := {
  b = a ∨ b ≠ a;
  done by cases {
    case b = a as sameEnds:
        Permutation.swapMap(a, b, b) = b by Logic.if_positive
           = a
    case b ≠ a as distinctEnds:
        Permutation.swapMap(a, b, b)
           = (if b = b then a else b) by Logic.if_negative
           = a by Logic.if_positive
  }
}

theorem Permutation.swapMap_at_other {n : Natural} (a b i : NaturalsBelow(n))
        (leftMiss : i ≠ a) (rightMiss : i ≠ b)
        : Permutation.swapMap(a, b, i) = i :=
  Permutation.swapMap(a, b, i)
     = (if i = b then a else i) by Logic.if_negative
     = i by Logic.if_negative

-- Applying a transposition twice restores the input: it is an involution.
theorem Permutation.swapMap_involution {n : Natural} (a b i : NaturalsBelow(n))
        : Permutation.swapMap(a, b, Permutation.swapMap(a, b, i)) = i := {
  i = a ∨ i ≠ a;
  done by cases {
    case i = a as hitsLeft: done
    case i ≠ a as missesLeft: {
        i = b ∨ i ≠ b;
        done by cases {
          case i = b as hitsRight: done
          case i ≠ b as missesRight:
              Permutation.swapMap(a, b, Permutation.swapMap(a, b, i))
                 = Permutation.swapMap(a, b, i)
                       by substituting Permutation.swapMap_at_other
                 = i by Permutation.swapMap_at_other
        }
      }
  }
}

-- The transposition as a permutation: its own inverse, by the involution.
definition Permutation.swap {n : Natural} (a b : NaturalsBelow(n)) : Permutation(n) :=
  Permutation.make(n, Permutation.swapMap(a, b), Permutation.swapMap(a, b),
      And.introduction(
          (i : NaturalsBelow(n)) ↦ Permutation.swapMap_involution(a, b, i),
          (i : NaturalsBelow(n)) ↦ Permutation.swapMap_involution(a, b, i)))

theorem Permutation.apply_swap_left {n : Natural} (a b : NaturalsBelow(n))
        : Permutation.swap(a, b)(a) = b :=
  by Permutation.swapMap_at_left

theorem Permutation.apply_swap_right {n : Natural} (a b : NaturalsBelow(n))
        : Permutation.swap(a, b)(b) = a :=
  by Permutation.swapMap_at_right

theorem Permutation.apply_swap_other {n : Natural} (a b i : NaturalsBelow(n))
        (leftMiss : i ≠ a) (rightMiss : i ≠ b)
        : Permutation.swap(a, b)(i) = i :=
  by Permutation.swapMap_at_other

-- A transposition is its own inverse.
theorem Permutation.inverse_swap {n : Natural} (a b : NaturalsBelow(n))
        : Permutation.inverse(Permutation.swap(a, b)) = Permutation.swap(a, b) := {
  ∀ (i : NaturalsBelow(n)). Permutation.inverse(Permutation.swap(a, b))(i) = Permutation.swap(a, b)(i)
      by Permutation.apply_inverse;
  done by Permutation.equal_of_apply_equal
}

-- ----------------------------------------------------------------------
-- Extending across the index boundary. A permutation of NaturalsBelow(m)
-- becomes one of NaturalsBelow(1 + m) that fixes the top index m: below m it
-- reads the original permutation (lifted by `inclusion`), at m it stays put.
-- This is the recursion step the permutation enumeration is built on.

definition Permutation.extendMap {m : Natural} (sigma : Permutation(m))
        : NaturalsBelow(1 + m) → NaturalsBelow(1 + m) :=
  (i : NaturalsBelow(1 + m)) ↦
    Function.extendBelow(
        (x : NaturalsBelow(m)) ↦ NaturalsBelow.inclusion(m, sigma(x)),
        NaturalsBelow.top(m))(NaturalsBelow.value(i))

-- Below the boundary the extension is the lifted permutation…
theorem Permutation.extendMap_inclusion {m : Natural} (sigma : Permutation(m)) (y : NaturalsBelow(m))
        : Permutation.extendMap(sigma, NaturalsBelow.inclusion(m, y)) = NaturalsBelow.inclusion(m, sigma(y)) := {
  NaturalsBelow.value(y) < m as yBelow;
  NaturalsBelow.make(NaturalsBelow.value(y), yBelow) = y as makeIsY;
  Permutation.extendMap(sigma, NaturalsBelow.inclusion(m, y))
     = NaturalsBelow.inclusion(m, sigma(NaturalsBelow.make(NaturalsBelow.value(y), yBelow)))
           by Function.extendBelow_below
     = NaturalsBelow.inclusion(m, sigma(y))
           by substituting makeIsY;
  done
}

-- …and at the boundary it fixes the top.
theorem Permutation.extendMap_top {m : Natural} (sigma : Permutation(m))
        : Permutation.extendMap(sigma, NaturalsBelow.top(m)) = NaturalsBelow.top(m) := {
  m ≤ m;
  done by Function.extendBelow_past
}

-- Extending `sigma` and then `sigma⁻¹` is the identity: cases on whether the
-- index is below the boundary (lifted cancellation) or at the top (fixed).
theorem Permutation.extendMap_cancel {m : Natural} (sigma : Permutation(m)) (i : NaturalsBelow(1 + m))
        : Permutation.extendMap(Permutation.inverse(sigma), Permutation.extendMap(sigma, i)) = i := {
  NaturalsBelow.value(i) < m ∨ m ≤ NaturalsBelow.value(i) by Natural.lt_or_le;
  done by cases {
    case NaturalsBelow.value(i) < m as iBelow: {
        i = NaturalsBelow.inclusion(m, NaturalsBelow.make(NaturalsBelow.value(i), iBelow)) as iIsInclusion;
        Permutation.inverse(sigma)(sigma(NaturalsBelow.make(NaturalsBelow.value(i), iBelow)))
           = Permutation.unapply(sigma, sigma(NaturalsBelow.make(NaturalsBelow.value(i), iBelow)))
                 by Permutation.apply_inverse
           = NaturalsBelow.make(NaturalsBelow.value(i), iBelow)
                 by Permutation.left_inverse
           as cancelAtIndex;
        Permutation.extendMap(Permutation.inverse(sigma), Permutation.extendMap(sigma, i))
           = Permutation.extendMap(Permutation.inverse(sigma),
                 Permutation.extendMap(sigma,
                     NaturalsBelow.inclusion(m, NaturalsBelow.make(NaturalsBelow.value(i), iBelow))))
                 by substituting iIsInclusion
           = Permutation.extendMap(Permutation.inverse(sigma),
                 NaturalsBelow.inclusion(m, sigma(NaturalsBelow.make(NaturalsBelow.value(i), iBelow))))
                 by substituting Permutation.extendMap_inclusion
           = NaturalsBelow.inclusion(m,
                 Permutation.inverse(sigma)(sigma(NaturalsBelow.make(NaturalsBelow.value(i), iBelow))))
                 by Permutation.extendMap_inclusion
           = NaturalsBelow.inclusion(m, NaturalsBelow.make(NaturalsBelow.value(i), iBelow))
                 by substituting cancelAtIndex
           = i by iIsInclusion;
        done
      }
    case m ≤ NaturalsBelow.value(i) as iAtLeast: {
        NaturalsBelow.value(i) < 1 + m;
        NaturalsBelow.value(i) ≤ m by Natural.le_cancel_one_plus;
        NaturalsBelow.value(i) = m by Natural.le_antisymmetric;
        i = NaturalsBelow.top(m) as iIsTop;
        Permutation.extendMap(Permutation.inverse(sigma), Permutation.extendMap(sigma, i))
           = Permutation.extendMap(Permutation.inverse(sigma),
                 Permutation.extendMap(sigma, NaturalsBelow.top(m)))
                 by substituting iIsTop
           = Permutation.extendMap(Permutation.inverse(sigma), NaturalsBelow.top(m))
                 by substituting Permutation.extendMap_top
           = NaturalsBelow.top(m) by Permutation.extendMap_top
           = i by iIsTop;
        done
      }
  }
}

-- The extension as a permutation of NaturalsBelow(1 + m). Its inverse extends
-- `sigma⁻¹`; the second cancellation reuses `extendMap_cancel` at `sigma⁻¹`
-- (extending `(sigma⁻¹)⁻¹` reduces to extending `sigma`).
definition Permutation.extend {m : Natural} (sigma : Permutation(m)) : Permutation(1 + m) :=
  Permutation.make(1 + m, Permutation.extendMap(sigma), Permutation.extendMap(Permutation.inverse(sigma)),
      And.introduction(
          (i : NaturalsBelow(1 + m)) ↦ Permutation.extendMap_cancel(sigma, i),
          (i : NaturalsBelow(1 + m)) ↦ Permutation.extendMap_cancel(Permutation.inverse(sigma), i)))

theorem Permutation.apply_extend_inclusion {m : Natural} (sigma : Permutation(m)) (y : NaturalsBelow(m))
        : Permutation.extend(sigma)(NaturalsBelow.inclusion(m, y)) = NaturalsBelow.inclusion(m, sigma(y)) :=
  by Permutation.extendMap_inclusion

theorem Permutation.apply_extend_top {m : Natural} (sigma : Permutation(m))
        : Permutation.extend(sigma)(NaturalsBelow.top(m)) = NaturalsBelow.top(m) :=
  Permutation.extend(sigma)(NaturalsBelow.top(m))
     = Permutation.extendMap(sigma, NaturalsBelow.top(m))
     = NaturalsBelow.top(m) by Permutation.extendMap_top

-- ----------------------------------------------------------------------
-- Restricting across the boundary. A permutation of NaturalsBelow(1 + m) that
-- FIXES the top index restricts to a permutation of NaturalsBelow(m) — the
-- inverse of `extend`. This is what lets the enumeration write every top-fixing
-- permutation as an extension, the heart of the completeness argument.

theorem Permutation.apply_injective {n : Natural} (p : Permutation(n)) (x y : NaturalsBelow(n))
        (equalImages : p(x) = p(y)) : x = y :=
  x = Permutation.unapply(p, p(x)) by Permutation.left_inverse
    = Permutation.unapply(p, p(y)) by substituting equalImages
    = y by Permutation.left_inverse

-- The boundary inclusion is injective (it preserves the value).
theorem NaturalsBelow.inclusion_injective (m : Natural) (a b : NaturalsBelow(m))
        (equalInclusions : NaturalsBelow.inclusion(m, a) = NaturalsBelow.inclusion(m, b)) : a = b := {
  NaturalsBelow.value(a)
     = NaturalsBelow.value(NaturalsBelow.inclusion(m, a))
     = NaturalsBelow.value(NaturalsBelow.inclusion(m, b)) by substituting equalInclusions
     = NaturalsBelow.value(b);
  done by NaturalsBelow.equal_of_value
}

-- The inverse of a top-fixing permutation fixes the top as well.
theorem Permutation.inverse_fixes_top {m : Natural} (tau : Permutation(1 + m))
        (fixesTop : tau(NaturalsBelow.top(m)) = NaturalsBelow.top(m))
        : Permutation.inverse(tau)(NaturalsBelow.top(m)) = NaturalsBelow.top(m) := {
  tau(Permutation.inverse(tau)(NaturalsBelow.top(m)))
     = tau(Permutation.unapply(tau, NaturalsBelow.top(m)))
           by substituting Permutation.apply_inverse
     = NaturalsBelow.top(m) by Permutation.right_inverse
     = tau(NaturalsBelow.top(m)) by fixesTop;
  done by Permutation.apply_injective
}

-- A top-fixing permutation keeps the bottom part below the boundary: the image
-- of an included index stays below m (else it would collide with the fixed top).
theorem Permutation.top_fixing_image_below {m : Natural} (tau : Permutation(1 + m))
        (fixesTop : tau(NaturalsBelow.top(m)) = NaturalsBelow.top(m))
        (x : NaturalsBelow(m))
        : NaturalsBelow.value(tau(NaturalsBelow.inclusion(m, x))) < m := {
  NaturalsBelow.value(x) < m by NaturalsBelow.below;
  NaturalsBelow.inclusion(m, x) ≠ NaturalsBelow.top(m) by {
    suppose NaturalsBelow.inclusion(m, x) = NaturalsBelow.top(m) as inclusionIsTop for contradiction {
      NaturalsBelow.value(x)
         = NaturalsBelow.value(NaturalsBelow.inclusion(m, x))
         = NaturalsBelow.value(NaturalsBelow.top(m)) by substituting inclusionIsTop
         = m;
      False by Natural.not_equal_of_less_than;
      done
    }
  } as inclusionNotTop;
  tau(NaturalsBelow.inclusion(m, x)) ≠ NaturalsBelow.top(m) by {
    suppose tau(NaturalsBelow.inclusion(m, x)) = NaturalsBelow.top(m) as imageIsTop for contradiction {
      tau(NaturalsBelow.inclusion(m, x))
         = NaturalsBelow.top(m) by imageIsTop
         = tau(NaturalsBelow.top(m)) by fixesTop;
      NaturalsBelow.inclusion(m, x) = NaturalsBelow.top(m)
          by Permutation.apply_injective
          as reDerivedEqual;
      False by inclusionNotTop(reDerivedEqual);
      done
    }
  } as imageNotTop;
  NaturalsBelow.value(tau(NaturalsBelow.inclusion(m, x))) ≠ m by {
    suppose NaturalsBelow.value(tau(NaturalsBelow.inclusion(m, x))) = m as valueIsM for contradiction {
      tau(NaturalsBelow.inclusion(m, x)) = NaturalsBelow.top(m)
          by NaturalsBelow.equal_of_value
          as imageIsTop;
      False by imageNotTop(imageIsTop);
      done
    }
  };
  NaturalsBelow.value(tau(NaturalsBelow.inclusion(m, x))) < 1 + m by NaturalsBelow.below;
  NaturalsBelow.value(tau(NaturalsBelow.inclusion(m, x))) ≤ m
      by Natural.le_cancel_one_plus;
  done by Natural.lt_of_le_of_ne
}

definition Permutation.restrictMap {m : Natural} (tau : Permutation(1 + m))
        (fixesTop : tau(NaturalsBelow.top(m)) = NaturalsBelow.top(m))
        : NaturalsBelow(m) → NaturalsBelow(m) :=
  (x : NaturalsBelow(m)) ↦
    NaturalsBelow.make(NaturalsBelow.value(tau(NaturalsBelow.inclusion(m, x))),
        Permutation.top_fixing_image_below(tau, fixesTop, x))

-- The inclusion of a restricted index is just the original image: the `make`
-- and the image agree on value, so `equal_of_value` identifies them.
theorem Permutation.inclusion_restrictMap {m : Natural} (tau : Permutation(1 + m))
        (fixesTop : tau(NaturalsBelow.top(m)) = NaturalsBelow.top(m))
        (x : NaturalsBelow(m))
        : NaturalsBelow.inclusion(m, Permutation.restrictMap(tau, fixesTop, x)) = tau(NaturalsBelow.inclusion(m, x)) :=
  by NaturalsBelow.equal_of_value

-- Restricting `tau` then `tau⁻¹` is the identity on the bottom.
theorem Permutation.restrictMap_cancel {m : Natural} (tau : Permutation(1 + m))
        (fixesTop : tau(NaturalsBelow.top(m)) = NaturalsBelow.top(m))
        (x : NaturalsBelow(m))
        : Permutation.restrictMap(Permutation.inverse(tau), Permutation.inverse_fixes_top(tau, fixesTop),
              Permutation.restrictMap(tau, fixesTop, x)) = x := {
  NaturalsBelow.inclusion(m,
      Permutation.restrictMap(Permutation.inverse(tau), Permutation.inverse_fixes_top(tau, fixesTop),
          Permutation.restrictMap(tau, fixesTop, x)))
     = Permutation.inverse(tau)(NaturalsBelow.inclusion(m, Permutation.restrictMap(tau, fixesTop, x)))
           by Permutation.inclusion_restrictMap
     = Permutation.inverse(tau)(tau(NaturalsBelow.inclusion(m, x)))
           by substituting Permutation.inclusion_restrictMap
     = Permutation.unapply(tau, tau(NaturalsBelow.inclusion(m, x)))
           by substituting Permutation.apply_inverse
     = NaturalsBelow.inclusion(m, x) by Permutation.left_inverse;
  done by NaturalsBelow.inclusion_injective
}

definition Permutation.restrict {m : Natural} (tau : Permutation(1 + m))
        (fixesTop : tau(NaturalsBelow.top(m)) = NaturalsBelow.top(m))
        : Permutation(m) :=
  Permutation.make(m,
      Permutation.restrictMap(tau, fixesTop),
      Permutation.restrictMap(Permutation.inverse(tau), Permutation.inverse_fixes_top(tau, fixesTop)),
      And.introduction(
          (x : NaturalsBelow(m)) ↦ Permutation.restrictMap_cancel(tau, fixesTop, x),
          (x : NaturalsBelow(m)) ↦
              Permutation.restrictMap_cancel(Permutation.inverse(tau),
                  Permutation.inverse_fixes_top(tau, fixesTop), x)))

theorem Permutation.apply_restrict {m : Natural} (tau : Permutation(1 + m))
        (fixesTop : tau(NaturalsBelow.top(m)) = NaturalsBelow.top(m))
        (x : NaturalsBelow(m))
        : Permutation.restrict(tau, fixesTop)(x) = Permutation.restrictMap(tau, fixesTop, x) :=
  reflexivity(Permutation.restrictMap(tau, fixesTop, x))

-- extend and restrict are mutually inverse across the boundary.
theorem Permutation.extend_restrict {m : Natural} (tau : Permutation(1 + m))
        (fixesTop : tau(NaturalsBelow.top(m)) = NaturalsBelow.top(m))
        : Permutation.extend(Permutation.restrict(tau, fixesTop)) = tau := {
  ∀ (i : NaturalsBelow(1 + m)). Permutation.extend(Permutation.restrict(tau, fixesTop))(i) = tau(i)
    by { take i : NaturalsBelow(1 + m);
        NaturalsBelow.value(i) < m ∨ m ≤ NaturalsBelow.value(i) by Natural.lt_or_le;
        done by cases {
          case NaturalsBelow.value(i) < m as iBelow: {
              i = NaturalsBelow.inclusion(m, NaturalsBelow.make(NaturalsBelow.value(i), iBelow))
                  by NaturalsBelow.equal_of_value as iIsInclusion;
              Permutation.extend(Permutation.restrict(tau, fixesTop))(i)
                 = Permutation.extend(Permutation.restrict(tau, fixesTop))(
                       NaturalsBelow.inclusion(m, NaturalsBelow.make(NaturalsBelow.value(i), iBelow)))
                       by substituting iIsInclusion
                 = NaturalsBelow.inclusion(m,
                       Permutation.restrict(tau, fixesTop)(NaturalsBelow.make(NaturalsBelow.value(i), iBelow)))
                       by Permutation.apply_extend_inclusion
                 = NaturalsBelow.inclusion(m,
                       Permutation.restrictMap(tau, fixesTop, NaturalsBelow.make(NaturalsBelow.value(i), iBelow)))
                       by substituting Permutation.apply_restrict
                 = tau(NaturalsBelow.inclusion(m, NaturalsBelow.make(NaturalsBelow.value(i), iBelow)))
                       by Permutation.inclusion_restrictMap
                 = tau(i) by substituting iIsInclusion;
              done
            }
          case m ≤ NaturalsBelow.value(i) as iAtLeast: {
              NaturalsBelow.value(i) < 1 + m by NaturalsBelow.below;
              NaturalsBelow.value(i) ≤ m by Natural.le_cancel_one_plus;
              NaturalsBelow.value(i) = m by Natural.le_antisymmetric;
              i = NaturalsBelow.top(m) by NaturalsBelow.equal_of_value as iIsTop;
              Permutation.extend(Permutation.restrict(tau, fixesTop))(i)
                 = Permutation.extend(Permutation.restrict(tau, fixesTop))(NaturalsBelow.top(m))
                       by substituting iIsTop
                 = NaturalsBelow.top(m) by Permutation.apply_extend_top
                 = tau(NaturalsBelow.top(m)) by fixesTop
                 = tau(i) by substituting iIsTop;
              done
            }
        } };
  done by Permutation.equal_of_apply_equal
}

theorem Permutation.restrict_extend {m : Natural} (sigma : Permutation(m))
        : Permutation.restrict(Permutation.extend(sigma), Permutation.apply_extend_top(sigma)) = sigma := {
  ∀ (x : NaturalsBelow(m)).
      Permutation.restrict(Permutation.extend(sigma), Permutation.apply_extend_top(sigma))(x) = sigma(x)
    by { take x : NaturalsBelow(m);
        NaturalsBelow.inclusion(m,
            Permutation.restrict(Permutation.extend(sigma), Permutation.apply_extend_top(sigma))(x))
           = NaturalsBelow.inclusion(m,
                 Permutation.restrictMap(Permutation.extend(sigma),
                     Permutation.apply_extend_top(sigma), x))
                 by substituting Permutation.apply_restrict
           = Permutation.extend(sigma)(NaturalsBelow.inclusion(m, x))
                 by Permutation.inclusion_restrictMap
           = NaturalsBelow.inclusion(m, sigma(x))
                 by Permutation.apply_extend_inclusion;
        done by NaturalsBelow.inclusion_injective };
  done by Permutation.equal_of_apply_equal
}

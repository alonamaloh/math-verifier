module Algebra.rank_four_weighted_d3_third_unit_c7

import Algebra.rank_four_weighted_d3_third_unit_universality

theorem Matrix.weightedD3S0R1C7_universal_of_one_three_six_converse (converse : Matrix.OneThreeSixLocalConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 0, 1, 7)) := {
  3 * 7 = 20 + 1 by ring as coefficientShape;
  3 * 7 ∸ 1 = 20 by Natural.three_times_monus_one_value(7, 20, coefficientShape) as naturalCoefficientReads;
  ((3 * 7 ∸ 1 : ℕ) : ℤ) = 3 * (7 : ℤ) - 1
      by Natural.three_times_monus_one_to_integer(7, 20, coefficientShape) as coefficientReads;
  36 + (3 * 7 ∸ 1) = 36 + 20 by substituting naturalCoefficientReads = 56 by ring as halfCoreSum;
  10 + (3 * 7 ∸ 1) = 10 + 20 by substituting naturalCoefficientReads = 30 by ring as baseCoreSum;
  9 = 4 * 2 + 1 by ring as nineShape;
  1 + (1 + 2) = 4 by ring as oneBelowFourReads;
  1 < 4 by Natural.lt_intro(1, 4, 2, oneBelowFourReads) as oneBelowFour;
  0 + (1 + 0) = 1 by ring as onePositiveReads;
  0 < 1 by Natural.lt_intro(0, 1, 0, onePositiveReads) as onePositive;
  1 ≠ 0 by Natural.not_equal_of_greater_than(1, 0, onePositive) as oneNonzero;
  9 + (1 + 6) = 16 by ring as nineBelowSixteenReads;
  9 < 16 by Natural.lt_intro(9, 16, 6, nineBelowSixteenReads) as nineBelowSixteen;
  9 + (1 + 4) = 14 by ring as nineBelowFourteenReads;
  9 < 14 by Natural.lt_intro(9, 14, 4, nineBelowFourteenReads) as nineBelowFourteen;
  9 ≠ 14 by Natural.not_equal_of_less_than(9, 14, nineBelowFourteen) as nineNotFourteen;
  10 = 4 * 2 + 2 by ring as tenShape;
  2 + (1 + 1) = 4 by ring as twoBelowFourReads;
  2 < 4 by Natural.lt_intro(2, 4, 1, twoBelowFourReads) as twoBelowFour;
  0 + (1 + 1) = 2 by ring as twoPositiveReads;
  0 < 2 by Natural.lt_intro(0, 2, 1, twoPositiveReads) as twoPositive;
  2 ≠ 0 by Natural.not_equal_of_greater_than(2, 0, twoPositive) as twoNonzero;
  10 + (1 + 5) = 16 by ring as tenBelowSixteenReads;
  10 < 16 by Natural.lt_intro(10, 16, 5, tenBelowSixteenReads) as tenBelowSixteen;
  10 + (1 + 3) = 14 by ring as tenBelowFourteenReads;
  10 < 14 by Natural.lt_intro(10, 14, 3, tenBelowFourteenReads) as tenBelowFourteen;
  10 ≠ 14 by Natural.not_equal_of_less_than(10, 14, tenBelowFourteen) as tenNotFourteen;
  Matrix.OneThreeSixTripleTargetCover(7)
      by Matrix.oneThreeSixTripleTargetCover_half_scale_of_local_converse(
          converse, corner := 7, halfCore := 36, baseCore := 10,
          coefficientReads := coefficientReads, halfCoreSum := halfCoreSum, baseCoreSum := baseCoreSum,
          halfAdmissible := (exponent b : ℕ) ↦ {
            4 ^ exponent * (64 * b + 36)
               = 4 ^ exponent * (4 * (16 * b + 9)) by ring
               = (4 * 4 ^ exponent) * (16 * b + 9) by ring
               = 4 ^ (1 + exponent) * (16 * b + 9)
                   by substituting Equality.symmetry(Natural.power_one_plus(4, exponent))
            as valueReads;
            suppose Natural.IsOneThreeSixFourObstruction(4 ^ exponent * (64 * b + 36)) as obstruction;
            Natural.IsOneThreeSixFourObstruction(4 ^ (1 + exponent) * (16 * b + 9))
                by substituting valueReads as transformedObstruction;
            done by Natural.four_power_times_nonzero_mod_four_core_not_one_three_six_four_obstruction(
                1 + exponent, b, 9, 2, 1, nineShape,
                oneBelowFour, oneNonzero, nineBelowSixteen, nineNotFourteen)(transformedObstruction)
          },
          baseAdmissible := (b : ℕ) ↦ {
            4 ^ 0 * (16 * b + 10) = 16 * b + 10 by substituting Natural.power_zero(4) as valueReads;
            suppose Natural.IsOneThreeSixFourObstruction(16 * b + 10) as obstruction;
            Natural.IsOneThreeSixFourObstruction(4 ^ 0 * (16 * b + 10))
                by substituting Equality.symmetry(valueReads) as transformedObstruction;
            done by Natural.four_power_times_nonzero_mod_four_core_not_one_three_six_four_obstruction(
                0, b, 10, 2, 2, tenShape,
                twoBelowFour, twoNonzero, tenBelowSixteen, tenNotFourteen)(transformedObstruction)
          })
      as cover;
  done by Matrix.weightedD3ThirdUnit_universal_of_cover(7, coefficientReads, cover)
}

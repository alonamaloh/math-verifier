-- Algebra/rank_four_double_diagonal_branch_coverage.math
--
-- End-to-end coverage above x²+y²+2z².  Positive-definiteness puts every
-- escalation in the generated finite box; reconstruction then transfers its
-- certified top-shear normal form back to the original matrix.

module Algebra.rank_four_double_diagonal_branch_coverage

import Algebra.rank_four_double_diagonal_branch_classification_generated

theorem Matrix.sumOfTwoSquaresPlusDoubleSquareRankFourEscalation_classified
        (B : Matrix(Integer.commutative_ring_bundle, 1 + 3, 1 + 3))
        (escalation : Matrix.IsEscalation(Matrix.sumOfTwoSquaresPlusDoubleSquareForm, B))
        : Matrix.IsSumOfTwoSquaresPlusDoubleSquareRankFourTopShearNormalForm(B) := {
  let border : RingVector(Integer.commutative_ring_bundle, 3) := Matrix.borderColumn(B);
  let pair : RingVector(Integer.commutative_ring_bundle, 2) := RingVector.restrict(border);
  let a : ℤ := pair(NaturalsBelow.firstOfTwo);
  let b : ℤ := pair(NaturalsBelow.secondOfTwo);
  let c : ℤ := border(NaturalsBelow.top(2));
  pair = RingVector.twoCoordinates(a, b) by RingVector.eq_twoCoordinates as pairReads;
  let coordinatePair : RingVector(Integer.commutative_ring_bundle, 2) := ⟨a, b⟩;
  coordinatePair = RingVector.twoCoordinates(a, b)
      by RingVector.coordinatePair_eq_twoCoordinates as coordinatePairReads;
  pair
     = RingVector.twoCoordinates(a, b) by pairReads
     = coordinatePair by coordinatePairReads
  as pairIsCoordinatePair;
  border
     = RingVector.appendCoordinate(pair, c) by RingVector.eq_appendCoordinate(border)
     = RingVector.appendCoordinate(coordinatePair, c) by substituting pairIsCoordinatePair
     = (⟨a, b, c⟩ : RingVector(Integer.commutative_ring_bundle, 3))
  as borderReads;
  2 * (a * a) + 2 * (b * b) + c * c < 28
      by Matrix.sumOfTwoSquaresPlusDoubleSquareRankFourEscalation_coupled_bound(
          escalation := escalation, borderReads := borderReads) as coupledBound;
  a * a
     < 14 by Integer.first_square_bound_of_weighted_sum_below_twenty_eight
     < 16;
  -3 ≤ a by Integer.square_below_sixteen_lower_box_bound as aLower;
  a < 4 by Integer.square_below_sixteen_upper_box_bound as aUpper;
  2 * (b * b) + 2 * (a * a) + c * c
     = 2 * (a * a) + 2 * (b * b) + c * c by ring
     < 28 by coupledBound
  as swappedBound;
  b * b
     < 14 by Integer.first_square_bound_of_weighted_sum_below_twenty_eight(
         b, a, c, swappedBound)
     < 16;
  -3 ≤ b by Integer.square_below_sixteen_lower_box_bound as bLower;
  b < 4 by Integer.square_below_sixteen_upper_box_bound as bUpper;
  c * c
     < 28 by Integer.third_square_bound_of_weighted_sum_below_twenty_eight
     < 36;
  -5 ≤ c by Integer.square_below_thirty_six_lower_box_bound as cLower;
  c < 6 by Integer.square_below_thirty_six_upper_box_bound as cUpper;
  Matrix.IsSumOfTwoSquaresPlusDoubleSquareRankFourTopShearNormalForm(
      Matrix.sumOfTwoSquaresPlusDoubleSquareRankFourCandidate(a, b, c))
      by Matrix.rankFourDoubleDiagonalBranch_finite_box_classified(
          a, aLower, aUpper, b, bLower, bUpper, c, cLower, cUpper, coupledBound);
  B
     = Matrix.borderedAssembly(
         Matrix.sumOfTwoSquaresPlusDoubleSquareForm,
         Matrix.borderColumn(B),
         Matrix.truant(Matrix.sumOfTwoSquaresPlusDoubleSquareForm))
         by Matrix.IsEscalation.eq_borderedAssembly(escalation := escalation)
     = Matrix.borderedAssembly(
         Matrix.sumOfTwoSquaresPlusDoubleSquareForm,
         (⟨a, b, c⟩ : RingVector(Integer.commutative_ring_bundle, 3)),
         Matrix.truant(Matrix.sumOfTwoSquaresPlusDoubleSquareForm)) by substituting borderReads
     = Matrix.borderedAssembly(
         Matrix.sumOfTwoSquaresPlusDoubleSquareForm,
         (⟨a, b, c⟩ : RingVector(Integer.commutative_ring_bundle, 3)),
         14) by congruenceOf(
           (n : ℕ) ↦ Matrix.borderedAssembly(
             Matrix.sumOfTwoSquaresPlusDoubleSquareForm,
             (⟨a, b, c⟩ : RingVector(Integer.commutative_ring_bundle, 3)),
             (n : ℤ)),
           Matrix.sumOfTwoSquaresPlusDoubleSquareForm_truant)
     = Matrix.sumOfTwoSquaresPlusDoubleSquareRankFourCandidate(a, b, c)
         by substituting Matrix.sumOfTwoSquaresPlusDoubleSquareForm_is_scaled_diagonal
  as reconstructs;
  done by substituting reconstructs
}

     = ((588 * q : ℕ) : ℤ) + (385 : ℤ)
         by substituting Equality.symmetry(Natural.to_integer.multiply_preserves(588, q))
     = ((588 * q + 385 : ℕ) : ℤ)
         by Equality.symmetry(Natural.to_integer.add_preserves(588 * q, 385))
     = (n : ℤ) by substituting exactDecomposition
  as integerDecomposition;
  done by substituting integerDecomposition
}

theorem Matrix.detSevenFiniteQ3C10A406T3_part0
        : ∀ (q : ℕ). q ≥ 0 → q < 3 →
          Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 10),
            (588 : ℤ) * (q : ℤ) + (406 : ℤ)) := {
  let A : Matrix(Integer.commutative_ring_bundle, 4, 4) :=
    Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 10);
  (20 : ℤ) * 20 + 2 * (2 * 2) + 2 * 2 * (-1 : ℤ) + 4 * ((-1 : ℤ) * (-1 : ℤ)) + 2 * 3 * 2 * (-1 : ℤ) + 10 * ((-1 : ℤ) * (-1 : ℤ)) = (406 : ℤ) as scalarComputation;
  Matrix.represents_by_witness(A, target := 406, vector := ⟨20, 2, -1, -1⟩,
    computes := Matrix.detSevenRankFour_coordinateTuple_computes(scalarComputation := scalarComputation));
  (30 : ℤ) * 30 + 2 * (6 * 6) + 2 * 6 * (-5 : ℤ) + 4 * ((-5 : ℤ) * (-5 : ℤ)) + 2 * 3 * 6 * (-3 : ℤ) + 10 * ((-3 : ℤ) * (-3 : ℤ)) = (994 : ℤ) as scalarComputation;
  Matrix.represents_by_witness(A, target := 994, vector := ⟨30, 6, -5, -3⟩,
    computes := Matrix.detSevenRankFour_coordinateTuple_computes(scalarComputation := scalarComputation));
  (38 : ℤ) * 38 + 2 * (8 * 8) + 2 * 8 * (-4 : ℤ) + 4 * ((-4 : ℤ) * (-4 : ℤ)) + 2 * 3 * 8 * (-5 : ℤ) + 10 * ((-5 : ℤ) * (-5 : ℤ)) = (1582 : ℤ) as scalarComputation;
  Matrix.represents_by_witness(A, target := 1582, vector := ⟨38, 8, -4, -5⟩,
    computes := Matrix.detSevenRankFour_coordinateTuple_computes(scalarComputation := scalarComputation));
  done by finite_check q from 0 until 3
}

theorem Matrix.detSevenFiniteQ3C10A406T3
        (n : ℕ) (positive : n ≥ 1)
        (bounded : n ≤ 2142)
        (remainderReads : Natural.modulo(n, 588) = 406)
        : Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 10),
            (n : ℤ)) := {
  let q : ℕ := Natural.floor_divide(n, 588);
  588 * q + Natural.modulo(n, 588) = n
      by Natural.floor_divide_modulo_decompose;
  588 * q + 406 = n by substituting remainderReads as exactDecomposition;
  q < 3 by Natural.quotient_below_of_bounded_decomposition(
    588, q, 406, n, 2142, 3, done, exactDecomposition, bounded)
  as qBelow;
  Matrix.Represents(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 10),
      (588 : ℤ) * (q : ℤ) + (406 : ℤ)) by {
  done by Matrix.detSevenFiniteQ3C10A406T3_part0(q, done, qBelow)
  };
  (588 : ℤ) * (q : ℤ) + (406 : ℤ)
     = ((588 * q : ℕ) : ℤ) + (406 : ℤ)
         by substituting Equality.symmetry(Natural.to_integer.multiply_preserves(588, q))
     = ((588 * q + 406 : ℕ) : ℤ)
         by Equality.symmetry(Natural.to_integer.add_preserves(588 * q, 406))
     = (n : ℤ) by substituting exactDecomposition
  as integerDecomposition;
  done by substituting integerDecomposition
}

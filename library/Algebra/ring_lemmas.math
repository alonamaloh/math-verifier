-- Algebra/ring_lemmas.math
--
-- Generic lemmas that hold for every ring. Proved once against the
-- `IsRing` predicate; usable on any specific ring by passing the
-- corresponding instance proof. Same payoff as `Algebra.group_lemmas`:
-- a fact like `0 · x = 0` or `(-a) · b = -(a · b)` doesn't need to
-- be re-proved for Integer, Rational, Real, PAdic.

module Algebra.ring_lemmas

import Logic.basics
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.ring

-- Throughout this file we work in an arbitrary ring. The bundle below is
-- prepended implicitly to every lemma that mentions any of its names, in
-- dependency order (carrier before the operations before `ringProof`), so
-- each lemma states only its genuine arguments and the inter-lemma
-- citations recover the bundle by unifying `ringProof`'s type.
convention carrier : Type(0)
convention add : carrier → carrier → carrier
convention zero : carrier
convention negate : carrier → carrier
convention multiply : carrier → carrier → carrier
convention one : carrier
convention ringProof : IsRing(carrier, add, zero, negate, multiply, one)

-- ----------------------------------------------------------------------
-- Zero absorbs multiplication on the left: `multiply(zero, x) = zero`.
--
-- Proof: `multiply(zero, x) + multiply(zero, x) = multiply(zero + zero, x)
-- = multiply(zero, x)`. The additive group cancels `multiply(zero, x)`
-- against `multiply(zero, x) + multiply(zero, x) = multiply(zero, x) + zero`,
-- leaving `multiply(zero, x) = zero`.
theorem Ring.zero_multiply (x : carrier) : multiply(zero, x) = zero := {
    let ⟨abelianAdd, _, _, distributivityRight⟩ := ringProof;
    let ⟨addGroupProof, _⟩ := abelianAdd;
    let ⟨addMonoidProof, _, _⟩ := addGroupProof;
    let ⟨_, addIdentityLeft, addIdentityRight⟩ := addMonoidProof;
    -- add(0·x, 0·x) = 0·x = add(0·x, 0); cancelling 0·x leaves 0·x = 0.
    calc add(multiply(zero, x), multiply(zero, x))
       = multiply(add(zero, zero), x)   by distributivityRight(zero, zero, x)
       = multiply(zero, x)              by addIdentityLeft(zero)
       = add(multiply(zero, x), zero)   by addIdentityRight(multiply(zero, x));
    done by Group.cancel_left
}

-- Zero absorbs multiplication on the right: `multiply(x, zero) = zero`.
-- Same proof shape using `distributivity_left`.
theorem Ring.multiply_zero (x : carrier) : multiply(x, zero) = zero := {
    let ⟨abelianAdd, _, distributivityLeft, _⟩ := ringProof;
    let ⟨addGroupProof, _⟩ := abelianAdd;
    let ⟨addMonoidProof, _, _⟩ := addGroupProof;
    let ⟨_, addIdentityLeft, addIdentityRight⟩ := addMonoidProof;
    -- add(x·0, x·0) = x·0 = add(x·0, 0); cancelling x·0 leaves x·0 = 0.
    calc add(multiply(x, zero), multiply(x, zero))
       = multiply(x, add(zero, zero))   by distributivityLeft(x, zero, zero)
       = multiply(x, zero)              by addIdentityLeft(zero)
       = add(multiply(x, zero), zero)   by addIdentityRight(multiply(x, zero));
    done by Group.cancel_left
}

-- `multiply(negate(a), b) = negate(multiply(a, b))`. Recognise
-- `multiply(negate(a), b)` as the additive inverse of `multiply(a, b)`:
-- `multiply(negate(a), b) + multiply(a, b) = multiply(negate(a) + a, b)
-- = multiply(zero, b) = zero`. Then `right_inverse_unique` in the
-- additive group identifies it with `negate(multiply(a, b))`.
theorem Ring.multiply_negate_left (a b : carrier)
        : multiply(negate(a), b) = negate(multiply(a, b)) := {
    let ⟨abelianAdd, _, _, distributivityRight⟩ := ringProof;
    let ⟨addGroupProof, _⟩ := abelianAdd;
    let ⟨_, inverseLeftAxiom, _⟩ := addGroupProof;
    -- multiply(negate(a), b) is the additive inverse of multiply(a, b):
    -- their sum is multiply(negate(a) + a, b) = multiply(0, b) = 0.
    calc add(multiply(negate(a), b), multiply(a, b))
       = multiply(add(negate(a), a), b)   by distributivityRight(negate(a), a, b)
       = multiply(zero, b)                by inverseLeftAxiom(a)
       = zero                             by Ring.zero_multiply;
    done by Group.left_inverse_unique
}

-- `multiply(a, negate(b)) = negate(multiply(a, b))`. Mirror of the
-- left version using `distributivity_left` and `inverse_right`.
theorem Ring.multiply_negate_right (a b : carrier)
        : multiply(a, negate(b)) = negate(multiply(a, b)) := {
    let ⟨abelianAdd, _, distributivityLeft, _⟩ := ringProof;
    let ⟨addGroupProof, _⟩ := abelianAdd;
    let ⟨_, inverseLeftAxiom, _⟩ := addGroupProof;
    calc add(multiply(a, negate(b)), multiply(a, b))
       = multiply(a, add(negate(b), b))   by distributivityLeft(a, negate(b), b)
       = multiply(a, zero)                by inverseLeftAxiom(b)
       = zero                             by Ring.multiply_zero;
    done by Group.left_inverse_unique
}

-- `multiply(negate(a), negate(b)) = multiply(a, b)`. Apply
-- `multiply_negate_left` and then `multiply_negate_right` to peel both
-- negations into a double negation of the product; the additive
-- inverse is involutive.
theorem Ring.negate_multiply_negate (a b : carrier)
        : multiply(negate(a), negate(b)) = multiply(a, b) := {
    let ⟨abelianAdd, _, _, _⟩ := ringProof;
    let ⟨addGroupProof, _⟩ := abelianAdd;
    -- Peel each negation onto the product, then the additive inverse is
    -- involutive. Step 2 cites `multiply_negate_right` argument-free even
    -- though it applies UNDER a `negate(·)`: the calc diff bridge descends
    -- to the differing subterm and instantiates the lemma's ring bundle
    -- against the subterm equality, then re-wraps the congruence.
    calc multiply(negate(a), negate(b))
       = negate(multiply(a, negate(b)))   by Ring.multiply_negate_left
       = negate(negate(multiply(a, b)))   by Ring.multiply_negate_right
       = multiply(a, b)                   by Group.inverse_involution
}

-- The reduction behind the `linear_combination` tactic. Given a known
-- equation `combLeft = combRight` and a RING-IDENTITY bridge
-- `goalLeft − goalRight = combLeft − combRight` (which `ring` checks),
-- conclude `goalLeft = goalRight`. The combination's difference is zero
-- (it's `combRight − combRight`), so the goal's difference is zero, and
-- cancellation finishes.
theorem Ring.equal_of_linear_combination
        (goalLeft goalRight combLeft combRight : carrier)
        (combination : combLeft = combRight)
        (ringBridge : add(goalLeft, negate(goalRight))
                      = add(combLeft, negate(combRight)))
        : goalLeft = goalRight := {
    let ⟨abelianAdd, _, _, _⟩ := ringProof;
    let ⟨addGroup, _⟩ := abelianAdd;
    let ⟨_, _, addInverseRight⟩ := addGroup;
    -- The combination's difference is zero (it's combRight − combRight)...
    calc add(combLeft, negate(combRight))
       = add(combRight, negate(combRight))   by substituting combination
       = zero                                by addInverseRight(combRight);
    -- ...so the goal's difference is zero too, and cancelling finishes.
    calc add(goalLeft, negate(goalRight))
       = add(combLeft, negate(combRight))    by ringBridge
       = zero
       = add(goalRight, negate(goalRight))   by addInverseRight(goalRight);
    done by Group.cancel_right
}

-- Algebra/ring_lemmas.math
--
-- Generic lemmas that hold for every ring. Proved once against the
-- `IsRing` predicate; usable on any specific ring by passing the
-- corresponding instance proof. Same payoff as `Algebra.group_lemmas`:
-- a fact like `0 Â· x = 0` or `(-a) Â· b = -(a Â· b)` doesn't need to
-- be re-proved for Integer, Rational, Real, PAdic.

module Algebra.ring_lemmas

import Logic.basics
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.ring

-- Throughout this file we work in an arbitrary ring, written in operator
-- notation. The bundle below is a pervasive convention: naming any ring
-- operation (`+`, `Â·`, `-`) prepends the whole signature implicitly â€”
-- including `ringProof` â€” so each lemma states only its genuine arguments
-- and cites the ring axioms by name (`IsRing.distributivity_right(â€¦)`,
-- `IsRing.add_identity_left(â€¦)`) with `ringProof` recovered from context.
-- The generic `Group.*` cancellation lemmas need the additive group as their
-- `IsGroup` proof: it is supplied automatically from `ringProof` through the
-- registered `IsRing.additive_group` forgetful instance â€” no explicit claim.
convention carrier : Type(0)
convention (+) : carrier â†’ carrier â†’ carrier
convention zero : carrier
convention (-) : carrier â†’ carrier
convention (Â·) : carrier â†’ carrier â†’ carrier
convention one : carrier
convention ringProof : IsRing(carrier, (+), zero, (-), (Â·), one)

-- ----------------------------------------------------------------------
-- Zero absorbs multiplication on the left: `zero Â· x = zero`.
--
-- Proof: `zero Â· x + zero Â· x = (zero + zero) Â· x = zero Â· x`. The additive
-- group cancels `zero Â· x` against `zero Â· x + zero Â· x = zero Â· x + zero`,
-- leaving `zero Â· x = zero`.
theorem Ring.zero_multiply (x : carrier) : zero Â· x = zero := {
    calc zero Â· x + zero Â· x
       = (zero + zero) Â· x
       = zero Â· x            by IsRing.add_identity_left
       = zero Â· x + zero     by IsRing.add_identity_right;
    done since Group.cancel_left
}

-- Zero absorbs multiplication on the right: `x Â· zero = zero`.
-- Same proof shape using `distributivity_left`.
theorem Ring.multiply_zero (x : carrier) : x Â· zero = zero := {
    calc x Â· zero + x Â· zero
       = x Â· (zero + zero)
       = x Â· zero            by IsRing.add_identity_left
       = x Â· zero + zero     by IsRing.add_identity_right;
    done since Group.cancel_left
}

-- `(-a) Â· b = -(a Â· b)`. Recognise `(-a) Â· b` as the additive inverse of
-- `a Â· b`: their sum is `(-a + a) Â· b = zero Â· b = zero`. Then
-- `left_inverse_unique` in the additive group identifies it with `-(a Â· b)`.
theorem Ring.multiply_negate_left (a b : carrier)
        : (-a) Â· b = -(a Â· b) := {
    calc (-a) Â· b + a Â· b
       = (-a + a) Â· b
       = zero Â· b       by IsRing.add_inverse_left
       = zero           by Ring.zero_multiply;
    done since Group.left_inverse_unique
}

-- `a Â· (-b) = -(a Â· b)`. Mirror of the left version, factoring on the left
-- (`distributivity_left`); the subterm is `-b + b`, so `add_inverse_left`.
theorem Ring.multiply_negate_right (a b : carrier)
        : a Â· (-b) = -(a Â· b) := {
    calc a Â· (-b) + a Â· b
       = a Â· (-b + b)
       = a Â· zero       by IsRing.add_inverse_left
       = zero           by Ring.multiply_zero;
    done since Group.left_inverse_unique
}

-- `(-a) Â· (-b) = a Â· b`. Peel each negation onto the product, then the
-- additive inverse is involutive.
theorem Ring.negate_multiply_negate (a b : carrier)
        : (-a) Â· (-b) = a Â· b := {
    -- Step 2 cites `multiply_negate_right` argument-free even though it
    -- applies UNDER a `-(Â·)`: the calc diff bridge descends to the differing
    -- subterm, instantiates the lemma's ring bundle against the subterm
    -- equality, then re-wraps the congruence.
    calc (-a) Â· (-b)
       = -(a Â· (-b))   by Ring.multiply_negate_left
       = -(-(a Â· b))   by Ring.multiply_negate_right
       = a Â· b         by Group.inverse_involution
}

-- The reduction behind the `linear_combination` tactic. Given a known
-- equation `combLeft = combRight` and a RING-IDENTITY bridge
-- `goalLeft âˆ’ goalRight = combLeft âˆ’ combRight` (which `ring` checks),
-- conclude `goalLeft = goalRight`. The combination's difference is zero
-- (it's `combRight âˆ’ combRight`), so the goal's difference is zero, and
-- cancellation finishes.
theorem Ring.equal_of_linear_combination
        (goalLeft goalRight combLeft combRight : carrier)
        (combination : combLeft = combRight)
        (ringBridge : goalLeft + (-goalRight) = combLeft + (-combRight))
        : goalLeft = goalRight := {
    -- The combination's difference is zero (a term minus itself), so the goal's
    -- difference is too; cancelling the common `-goalRight` finishes.
    calc goalLeft + (-goalRight)
       = combLeft + (-combRight)    since ringBridge
       = combRight + (-combRight)   since combination
       = zero
       = goalRight + (-goalRight);
    done since Group.cancel_right
}

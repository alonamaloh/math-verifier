-- Algebra/normal_subgroup.math
--
-- The data needed to form a quotient group G/N: a *normal* subgroup N
-- and the same-coset equivalence relation it induces.
--
-- Two elements lie in the same left coset of N exactly when aâپ»آ¹آ·b âˆˆ N;
-- we take that as the relation `Group.SameCoset(G, N)`. It is an
-- equivalence relation for ANY subgroup. What normality buys is that
-- the relation is a *congruence* for the group operation â€” translating
-- on the right preserves it â€” which is precisely what makes the
-- quotient operation well defined (Algebra/quotient_group).
--
-- Normality is stated in the "gâپ»آ¹آ·Nآ·g âٹ† N" form: gâپ»آ¹آ·xآ·g âˆˆ N for every
-- g and every x âˆˆ N. This is the orientation the right-translation
-- lemma consumes directly, so no inverse-of-inverse bridging is needed.
--
-- Notation: `آ·` (Group.operation, group inferred from the operands) and
-- `aâپ»آ¹` (Group.inverse, postfix) keep the algebra readable. Groups are
-- not commutative, so there is no `ring` to call â€” every step is by hand
-- through `Group.associative` and the inverse/identity laws.

module Algebra.normal_subgroup

import Logic.basics
import Equality.basics
import Logic.quotient
import Set.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.group_bundle
import Algebra.subgroup

-- N is a normal subgroup of G: a subgroup closed under conjugation,
-- gâپ»آ¹آ·xآ·g âˆˆ N for all g and all x âˆˆ N.
definition IsNormalSubgroup (G : Group) (subset : Set(Group.carrier(G)))
        : Proposition :=
  IsSubgroup(G, subset)
  âˆ§ ((g x : Group.carrier(G)) â†’
         x âˆˆ subset â†’ gâپ»آ¹ آ· x آ· g âˆˆ subset)

-- The underlying subgroup of a normal subgroup.
theorem IsNormalSubgroup.subgroup (G : Group) (subset : Set(Group.carrier(G)))
        (normal : IsNormalSubgroup(G, subset)) : IsSubgroup(G, subset) := {
  let âں¨subgroupPart, _âں© := normal;
  subgroupPart
}

-- ----------------------------------------------------------------------
-- The same-coset relation: a ~ b  iff  aâپ»آ¹آ·b âˆˆ N.

definition Group.SameCoset (G : Group) (subset : Set(Group.carrier(G)))
        (a b : Group.carrier(G)) : Proposition :=
  aâپ»آ¹ آ· b âˆˆ subset

-- ----------------------------------------------------------------------
-- SameCoset is an equivalence relation â€” for any subgroup. Each proof
-- rewrites the coset element aâپ»آ¹آ·b into a form whose membership is a
-- subgroup-closure fact.

-- Reflexive: aâپ»آ¹آ·a = identity âˆˆ N.
theorem Group.SameCoset.reflexive (G : Group) (subset : Set(Group.carrier(G)))
        (subgroup : IsSubgroup(G, subset)) (a : Group.carrier(G))
        : Group.SameCoset(G, subset, a, a) := {
  let âں¨identityInSubset, _, _âں© := subgroup;
  claim aâپ»آ¹ آ· a âˆˆ subset by substituting Group.inverse_left(G, a)
}

-- Symmetric: bâپ»آ¹آ·a = (aâپ»آ¹آ·b)âپ»آ¹, and N is closed under inversion.
theorem Group.SameCoset.symmetric (G : Group) (subset : Set(Group.carrier(G)))
        (subgroup : IsSubgroup(G, subset)) (a b : Group.carrier(G))
        (related : Group.SameCoset(G, subset, a, b))
        : Group.SameCoset(G, subset, b, a) := {
  let âں¨_, _, closedUnderInverseâں© := subgroup;
  claim cosetEquation
      : (aâپ»آ¹ آ· b)âپ»آ¹ = bâپ»آ¹ آ· a
      by calc (aâپ»آ¹ آ· b)âپ»آ¹
            = bâپ»آ¹ آ· aâپ»آ¹âپ»آ¹
            = bâپ»آ¹ آ· a;
  claim bâپ»آ¹ آ· a âˆˆ subset by substituting cosetEquation
}

-- Transitive: aâپ»آ¹آ·c = (aâپ»آ¹آ·b)آ·(bâپ»آ¹آ·c), and N is closed under the operation.
theorem Group.SameCoset.transitive (G : Group) (subset : Set(Group.carrier(G)))
        (subgroup : IsSubgroup(G, subset)) (a b c : Group.carrier(G))
        (relatedAB : Group.SameCoset(G, subset, a, b))
        (relatedBC : Group.SameCoset(G, subset, b, c))
        : Group.SameCoset(G, subset, a, c) := {
  let âں¨_, closedUnderOperation, _âں© := subgroup;
  -- (aâپ»آ¹آ·b)آ·(bâپ»آ¹آ·c) = aâپ»آ¹آ·c, collapsing bآ·bâپ»آ¹ in the middle.
  claim cosetEquation
      : (aâپ»آ¹ آ· b) آ· (bâپ»آ¹ آ· c) = aâپ»آ¹ آ· c
      by calc (aâپ»آ¹ آ· b) آ· (bâپ»آ¹ آ· c)
            = aâپ»آ¹ آ· (b آ· (bâپ»آ¹ آ· c))
            = aâپ»آ¹ آ· ((b آ· bâپ»آ¹) آ· c)
            = aâپ»آ¹ آ· (Group.identity(G) آ· c)
            = aâپ»آ¹ آ· c;
  claim aâپ»آ¹ آ· c âˆˆ subset by substituting cosetEquation
}

-- Bundled as an `IsEquivalenceRelation` for the quotient construction.
theorem Group.SameCoset.is_equivalence (G : Group) (subset : Set(Group.carrier(G)))
        (subgroup : IsSubgroup(G, subset))
        : IsEquivalenceRelation(Group.carrier(G), Group.SameCoset(G, subset)) :=
  âں¨Group.SameCoset.reflexive(G, subset, subgroup),
   Group.SameCoset.symmetric(G, subset, subgroup),
   Group.SameCoset.transitive(G, subset, subgroup)âں©

-- ----------------------------------------------------------------------
-- Translation lemmas â€” the heart of well-definedness.

-- Left translation preserves the coset relation, for any subgroup:
-- a ~ b  âں¹  gآ·a ~ gآ·b, because (gآ·a)âپ»آ¹آ·(gآ·b) = aâپ»آ¹آ·b.
theorem Group.SameCoset.left_translate
        (G : Group) (subset : Set(Group.carrier(G)))
        (g a b : Group.carrier(G))
        (related : Group.SameCoset(G, subset, a, b))
        : Group.SameCoset(G, subset, g آ· a, g آ· b) := {
  claim cosetEquation
      : aâپ»آ¹ آ· b = (g آ· a)âپ»آ¹ آ· (g آ· b)
      by calc aâپ»آ¹ آ· b
            = aâپ»آ¹ آ· (Group.identity(G) آ· b)
            = aâپ»آ¹ آ· ((gâپ»آ¹ آ· g) آ· b)
            = aâپ»آ¹ آ· (gâپ»آ¹ آ· (g آ· b))
            = (aâپ»آ¹ آ· gâپ»آ¹) آ· (g آ· b)
            = (g آ· a)âپ»آ¹ آ· (g آ· b);
  claim (g آ· a)âپ»آ¹ آ· (g آ· b) âˆˆ subset by substituting cosetEquation
}

-- Right translation preserves the coset relation WHEN N is normal:
-- a ~ b  âں¹  aآ·g ~ bآ·g, because (aآ·g)âپ»آ¹آ·(bآ·g) = gâپ»آ¹آ·(aâپ»آ¹آ·b)آ·g, a
-- conjugate of aâپ»آ¹آ·b âˆˆ N, hence in N by normality.
theorem Group.SameCoset.right_translate
        (G : Group) (subset : Set(Group.carrier(G)))
        (normal : IsNormalSubgroup(G, subset))
        (g a b : Group.carrier(G))
        (related : Group.SameCoset(G, subset, a, b))
        : Group.SameCoset(G, subset, a آ· g, b آ· g) := {
  let âں¨_, conjugationClosedâں© := normal;
  -- The conjugate gâپ»آ¹آ·(aâپ»آ¹آ·b)آ·g is in N by normality applied to aâپ»آ¹آ·b.
  claim conjugateInSubset
      : gâپ»آ¹ آ· (aâپ»آ¹ آ· b) آ· g âˆˆ subset
      by conjugationClosed(g, aâپ»آ¹ آ· b, related);
  -- (aآ·g)âپ»آ¹آ·(bآ·g) equals that conjugate.
  claim cosetEquation
      : gâپ»آ¹ آ· (aâپ»آ¹ آ· b) آ· g
        = (a آ· g)âپ»آ¹ آ· (b آ· g)
      by calc gâپ»آ¹ آ· (aâپ»آ¹ آ· b) آ· g
            = (gâپ»آ¹ آ· aâپ»آ¹) آ· b آ· g
            = (a آ· g)âپ»آ¹ آ· b آ· g
            = (a آ· g)âپ»آ¹ آ· (b آ· g);
  claim (a آ· g)âپ»آ¹ آ· (b آ· g) âˆˆ subset by substituting cosetEquation
}

-- Inversion preserves the coset relation when N is normal:
-- a ~ a'  âں¹  aâپ»آ¹ ~ a'âپ»آ¹. The coset element of the conclusion,
-- (aâپ»آ¹)âپ»آ¹آ·a'âپ»آ¹, is the conjugate (aâپ»آ¹)âپ»آ¹آ·(aâپ»آ¹آ·a')âپ»آ¹آ·aâپ»آ¹ of the
-- inverse of aâپ»آ¹آ·a' âˆˆ N, hence in N by normality.
theorem Group.SameCoset.inverse_respects
        (G : Group) (subset : Set(Group.carrier(G)))
        (normal : IsNormalSubgroup(G, subset))
        (a a' : Group.carrier(G))
        (related : Group.SameCoset(G, subset, a, a'))
        : Group.SameCoset(G, subset, aâپ»آ¹, a'âپ»آ¹) := {
  let âں¨subgroup, conjugationClosedâں© := normal;
  let âں¨_, _, closedUnderInverseâں© := subgroup;
  let cosetElement : Group.carrier(G) := aâپ»آ¹ آ· a';
  let doublyInverseA : Group.carrier(G) := aâپ»آ¹âپ»آ¹;
  -- The conjugate of (aâپ»آ¹آ·a')âپ»آ¹ by aâپ»آ¹ is in N.
  claim conjugateInSubset
      : doublyInverseA آ· cosetElementâپ»آ¹ آ· aâپ»آ¹ âˆˆ subset
      by conjugationClosed(aâپ»آ¹, cosetElementâپ»آ¹,
             closedUnderInverse(cosetElement, related));
  -- That conjugate equals (aâپ»آ¹)âپ»آ¹آ·a'âپ»آ¹, the coset element of aâپ»آ¹ ~ a'âپ»آ¹.
  claim cosetEquation
      : doublyInverseA آ· cosetElementâپ»آ¹ آ· aâپ»آ¹
        = doublyInverseA آ· a'âپ»آ¹
      by calc doublyInverseA آ· cosetElementâپ»آ¹ آ· aâپ»آ¹
            = doublyInverseA آ· (a'âپ»آ¹ آ· doublyInverseA) آ· aâپ»آ¹
            = doublyInverseA آ· ((a'âپ»آ¹ آ· doublyInverseA) آ· aâپ»آ¹)
            = doublyInverseA آ· (a'âپ»آ¹ آ· (doublyInverseA آ· aâپ»آ¹))
            = doublyInverseA آ· (a'âپ»آ¹ آ· Group.identity(G))
            = doublyInverseA آ· a'âپ»آ¹;
  claim doublyInverseA آ· a'âپ»آ¹ âˆˆ subset by substituting cosetEquation
}

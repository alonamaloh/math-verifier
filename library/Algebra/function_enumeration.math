-- Algebra/function_enumeration.math
--
-- The enumeration list `Function.allFunctions(n) : List(NaturalsBelow(n) →
-- NaturalsBelow(n))` — every "choice function" picking a column for each row,
-- each listed exactly once. This is the index set the generalized-distributivity
-- step of det(AB) sums over (Stage H brick 6a of PLAN_LINEAR_ALGEBRA.md).
--
-- The recursion mirrors `allPermutations`, but the codomain stays fixed while
-- the DOMAIN widens: a function `NaturalsBelow(1 + k) → C` is determined by
-- where it sends the top index and by its restriction below, so
-- `functionsBelow(1 + k)` concatenates, over every `f ∈ functionsBelow(k)`, the
-- row `[ extendByValue(f, v) : v ∈ choices ]`.

module Algebra.function_enumeration

import Logic.basics
import Equality.basics
import Logic.functions
import Natural.basics
import Natural.order
import Natural.classical_decidable
import Set.finite
import Set.finite_pigeonhole
import Lists.list
import Lists.map
import Lists.append
import Lists.distinct
import Algebra.field
import Algebra.field_bundle
import Algebra.field_aggregation
import Algebra.permutation_enumeration

-- ----------------------------------------------------------------------
-- Extending a function by one value. `extendByValue(f, v) : NaturalsBelow(1+k)
-- → C` sends the top index to `v` and each inclusion of a lower index `x` to
-- `f(x)`. The value-level dependent conditional (the same shape as
-- `Function.extendBelow`) reads the input's value and decides whether it is
-- below the boundary; the codomain is a bare type variable `C`.

definition Function.extendByValueWithDecision {C : Type(0)} {k : Natural}
        (f : NaturalsBelow(k) → C) (v : C) (j : NaturalsBelow(1 + k))
        : Logic.Decidable(NaturalsBelow.value(j) < k) → C
  | Logic.Decidable.yes(below) => f(NaturalsBelow.make(NaturalsBelow.value(j), below))
  | Logic.Decidable.no(_)      => v

definition Function.extendByValue {C : Type(0)} {k : Natural}
        (f : NaturalsBelow(k) → C) (v : C) : NaturalsBelow(1 + k) → C :=
  (j : NaturalsBelow(1 + k)) ↦
    Function.extendByValueWithDecision(f, v, j,
        Logic.classical_decidable(NaturalsBelow.value(j) < k))

-- Below the boundary the extension reads the original function at the bounded
-- index; proof irrelevance identifies the decision's internal proof with the
-- caller's `below`.
theorem Function.apply_extendByValue_below {C : Type(0)} {k : Natural}
        (f : NaturalsBelow(k) → C) (v : C) (j : NaturalsBelow(1 + k))
        (below : NaturalsBelow.value(j) < k)
        : Function.extendByValue(f, v)(j) = f(NaturalsBelow.make(NaturalsBelow.value(j), below)) :=
  if NaturalsBelow.value(j) < k
  then done
  else { False; done }

-- At an inclusion the extension reads the original function; at the top it
-- reads the new value.
theorem Function.apply_extendByValue_inclusion {C : Type(0)} {k : Natural}
        (f : NaturalsBelow(k) → C) (v : C) (x : NaturalsBelow(k))
        : Function.extendByValue(f, v)(NaturalsBelow.inclusion(k, x)) = f(x) := {
  NaturalsBelow.value(x) < k by NaturalsBelow.below as vLtK;
  NaturalsBelow.make(NaturalsBelow.value(x), vLtK) = x by NaturalsBelow.equal_of_value as makeIsX;
  Function.extendByValue(f, v)(NaturalsBelow.inclusion(k, x))
     = f(NaturalsBelow.make(NaturalsBelow.value(x), vLtK))
           by Function.apply_extendByValue_below(f, v, NaturalsBelow.inclusion(k, x), vLtK)
     = f(x) by substituting makeIsX;
  done
}

theorem Function.apply_extendByValue_top {C : Type(0)} {k : Natural}
        (f : NaturalsBelow(k) → C) (v : C)
        : Function.extendByValue(f, v)(NaturalsBelow.top(k)) = v :=
  if NaturalsBelow.value(NaturalsBelow.top(k)) < k
  then {
    k < k;
    ¬(k < k) by Natural.lt_irreflexive;
    False;
    done
  }
  else done

-- The restriction of a function to the indices below the boundary.
definition Function.lowerBelow {C : Type(0)} {k : Natural}
        (g : NaturalsBelow(1 + k) → C) : NaturalsBelow(k) → C :=
  (x : NaturalsBelow(k)) ↦ g(NaturalsBelow.inclusion(k, x))

-- The decomposition: every `g : NaturalsBelow(1+k) → C` is the extension of its
-- own restriction by its own top value. Cases each index on whether its value
-- is below the boundary (an inclusion) or equal to it (the top).
theorem Function.extendByValue_decompose {C : Type(0)} {k : Natural}
        (g : NaturalsBelow(1 + k) → C)
        : g = Function.extendByValue(Function.lowerBelow(g), g(NaturalsBelow.top(k))) :=
  Function.extensionality(NaturalsBelow(1 + k), C, g,
      Function.extendByValue(Function.lowerBelow(g), g(NaturalsBelow.top(k))),
      (j : NaturalsBelow(1 + k)) ↦ {
        NaturalsBelow.value(j) < 1 + k by NaturalsBelow.below;
        NaturalsBelow.value(j) ≤ k by Natural.le_of_lt_one_plus;
        NaturalsBelow.value(j) < k ∨ NaturalsBelow.value(j) = k;
        done by cases {
          case NaturalsBelow.value(j) < k as belowBoundary: {
              let x : NaturalsBelow(k) := NaturalsBelow.make(NaturalsBelow.value(j), belowBoundary);
              j = NaturalsBelow.inclusion(k, x) by NaturalsBelow.equal_of_value as jIsInclusion;
              g(j)
                 = g(NaturalsBelow.inclusion(k, x)) by substituting jIsInclusion
                 = Function.lowerBelow(g)(x)
                 = Function.extendByValue(Function.lowerBelow(g), g(NaturalsBelow.top(k)))(
                       NaturalsBelow.inclusion(k, x))
                       by Function.apply_extendByValue_inclusion(Function.lowerBelow(g),
                              g(NaturalsBelow.top(k)), x)
                 = Function.extendByValue(Function.lowerBelow(g), g(NaturalsBelow.top(k)))(j)
                       by substituting jIsInclusion;
              done
            }
          case NaturalsBelow.value(j) = k as atBoundary: {
              j = NaturalsBelow.top(k) by NaturalsBelow.equal_of_value as jIsTop;
              g(j)
                 = g(NaturalsBelow.top(k)) by substituting jIsTop
                 = Function.extendByValue(Function.lowerBelow(g), g(NaturalsBelow.top(k)))(
                       NaturalsBelow.top(k))
                       by Function.apply_extendByValue_top(Function.lowerBelow(g), g(NaturalsBelow.top(k)))
                 = Function.extendByValue(Function.lowerBelow(g), g(NaturalsBelow.top(k)))(j)
                       by substituting jIsTop;
              done
            }
        }
      })

-- ----------------------------------------------------------------------
-- The enumeration list. `functionsBelow(choices, 1 + m)` concatenates, over
-- every f ∈ functionsBelow(choices, m), the "row" of the extensions
-- `extendByValue(f, v)` — one for each choice `v ∈ choices`.

-- The unique function out of the empty index type.
definition Function.emptyBelow {C : Type(0)} : NaturalsBelow(0) → C :=
  (i : NaturalsBelow(0)) ↦ absurd(NaturalsBelow.zero_is_empty(i))

-- The row for f: extend it by each choice in turn.
definition Function.functionRow {C : Type(0)} {k : Natural}
        (choices : List(C)) (f : NaturalsBelow(k) → C) : List(NaturalsBelow(1 + k) → C) :=
  List.map(C, NaturalsBelow(1 + k) → C, (v : C) ↦ Function.extendByValue(f, v), choices)

-- Concatenate the rows over a list of functions. Recursion on the LIST
-- (k fixed), so no index transport arises here. The codomain `C` is explicit,
-- as recursive pattern-match definitions require.
definition Function.concatFunctionRows (C : Type(0)) (k : Natural) (choices : List(C))
        : List(NaturalsBelow(k) → C) → List(NaturalsBelow(1 + k) → C)
  | List.empty => List.empty(NaturalsBelow(1 + k) → C)
  | List.prepend(f, rest) =>
      List.append(NaturalsBelow(1 + k) → C, Function.functionRow(choices, f),
          Function.concatFunctionRows(C, k, choices, rest))

-- All functions `NaturalsBelow(k) → C` whose every value is a choice. The
-- `1 + m` step recurses on the index (dependent result type), bridged by
-- `unfold Natural.add in` exactly as `allPermutations`.
definition Function.functionsBelow (C : Type(0)) (choices : List(C))
        : (k : Natural) → List(NaturalsBelow(k) → C)
  | 0 => List.prepend(NaturalsBelow(0) → C, Function.emptyBelow, List.empty(NaturalsBelow(0) → C))
  | 1 + m => unfold Natural.add in
      Function.concatFunctionRows(C, m, choices, Function.functionsBelow(C, choices, m))

theorem Function.functionsBelow_one_plus (C : Type(0)) (choices : List(C)) (m : Natural)
        : Function.functionsBelow(C, choices, 1 + m)
          = Function.concatFunctionRows(C, m, choices, Function.functionsBelow(C, choices, m)) :=
  unfold Natural.add in
  reflexivity(Function.concatFunctionRows(C, m, choices, Function.functionsBelow(C, choices, m)))

-- The determinant's index set: all functions NaturalsBelow(n) → NaturalsBelow(n),
-- picking one column per row (every column is a valid choice).
definition Function.allFunctions (n : Natural) : List(NaturalsBelow(n) → NaturalsBelow(n)) :=
  Function.functionsBelow(NaturalsBelow(n), NaturalsBelow.enumerate(n), n)

-- ----------------------------------------------------------------------
-- Completeness of the enumeration: every function whose values are all
-- choices appears in the list.

-- Every function out of the empty index type is `emptyBelow` (there is nothing
-- to distinguish two such functions on).
theorem Function.function_zero_is_empty (C : Type(0)) (g : NaturalsBelow(0) → C)
        : g = Function.emptyBelow :=
  Function.extensionality(NaturalsBelow(0), C, g, Function.emptyBelow,
      (i : NaturalsBelow(0)) ↦ absurd(NaturalsBelow.zero_is_empty(i)))

-- Membership into the concatenation: a g in the row of an f ∈ l is in
-- concatFunctionRows(l). Induct on where f sits in l.
theorem Function.concatFunctionRows_member (C : Type(0)) (k : Natural) (choices : List(C))
        (l : List(NaturalsBelow(k) → C)) (f : NaturalsBelow(k) → C) (g : NaturalsBelow(1 + k) → C)
        (memF : f ∈ l)
        (memG : g ∈ Function.functionRow(choices, f))
        : g ∈ Function.concatFunctionRows(C, k, choices, l) :=
  by induction on memF with IH {
    case List.member.here(rest):
        List.member_append_left(NaturalsBelow(1 + k) → C, g, Function.functionRow(choices, f),
            Function.concatFunctionRows(C, k, choices, rest), memG)
    case List.member.there(head, rest, sub):
        List.member_append_right(NaturalsBelow(1 + k) → C, g, Function.functionRow(choices, head),
            Function.concatFunctionRows(C, k, choices, rest), IH)
  }

-- Completeness: every function whose values all lie in `choices` appears in
-- `functionsBelow(choices, k)`. The step writes g as the row entry
-- extendByValue(lowerBelow(g), g(top)) — with lowerBelow(g) in the level-m list
-- (IH) and g(top) among the choices — and locates it in the concatenation.
theorem Function.functionsBelow_complete (C : Type(0)) (choices : List(C)) (k : Natural)
        : ∀ (g : NaturalsBelow(k) → C).
              (∀ (i : NaturalsBelow(k)). g(i) ∈ choices)
              → g ∈ Function.functionsBelow(C, choices, k) :=
  by induction on k with IH {
    case base: {
        take g : NaturalsBelow(0) → C;
        suppose ∀ (i : NaturalsBelow(0)). g(i) ∈ choices;
        g = Function.emptyBelow by Function.function_zero_is_empty(C, g) as gIsEmpty;
        (Function.emptyBelow : NaturalsBelow(0) → C) ∈ List.prepend(NaturalsBelow(0) → C, Function.emptyBelow, List.empty(NaturalsBelow(0) → C))
            by List.member.here;
        g ∈ List.prepend(NaturalsBelow(0) → C, Function.emptyBelow, List.empty(NaturalsBelow(0) → C))
            by substituting gIsEmpty;
        done
      }
    case step(m): {
        take g : NaturalsBelow(1 + m) → C;
        suppose ∀ (i : NaturalsBelow(1 + m)). g(i) ∈ choices as valuesInChoices;
        (∀ (x : NaturalsBelow(m)). Function.lowerBelow(g)(x) ∈ choices)
            by (x : NaturalsBelow(m)) ↦ valuesInChoices(NaturalsBelow.inclusion(m, x))
            as lowerValuesInChoices;
        Function.lowerBelow(g) ∈ Function.functionsBelow(C, choices, m)
            by IH(Function.lowerBelow(g), lowerValuesInChoices) as lowerInAll;
        g(NaturalsBelow.top(m)) ∈ choices
            by valuesInChoices(NaturalsBelow.top(m)) as topInChoices;
        g = Function.extendByValue(Function.lowerBelow(g), g(NaturalsBelow.top(m)))
            by Function.extendByValue_decompose(g) as gIsRow;
        Function.extendByValue(Function.lowerBelow(g), g(NaturalsBelow.top(m))) ∈ Function.functionRow(choices, Function.lowerBelow(g))
            by List.map_member(C, NaturalsBelow(1 + m) → C,
                   (v : C) ↦ Function.extendByValue(Function.lowerBelow(g), v),
                   g(NaturalsBelow.top(m)), choices, topInChoices);
        g ∈ Function.functionRow(choices, Function.lowerBelow(g))
            by substituting gIsRow as gInRow;
        g ∈ Function.concatFunctionRows(C, m, choices, Function.functionsBelow(C, choices, m))
            by Function.concatFunctionRows_member(C, m, choices, Function.functionsBelow(C, choices, m),
                   Function.lowerBelow(g), g, lowerInAll, gInRow);
        done by substituting Function.functionsBelow_one_plus
      }
  }

-- The determinant corollary: every function NaturalsBelow(n) → NaturalsBelow(n)
-- appears in `allFunctions(n)` (every value is a column, so the choices
-- hypothesis is automatic).
theorem Function.allFunctions_complete (n : Natural)
        : ∀ (g : NaturalsBelow(n) → NaturalsBelow(n)).
              g ∈ Function.allFunctions(n) :=
  (g : NaturalsBelow(n) → NaturalsBelow(n)) ↦
    Function.functionsBelow_complete(NaturalsBelow(n), NaturalsBelow.enumerate(n), n, g,
        (i : NaturalsBelow(n)) ↦ NaturalsBelow.enumerate_complete(n, g(i)))

-- ----------------------------------------------------------------------
-- Generalized distributivity: a product of sums is the sum, over all choice
-- functions, of the products of the chosen terms — the `Finset.prod_univ_sum`
-- analog that turns the Leibniz product-of-sums of det(AB) into a sum over the
-- function space (Stage H brick 6a).

-- Summing a term over the concatenated rows is a double sum: outer over the
-- functions of the level below, inner over the choices that extend each.
theorem Field.sumOver_concatFunctionRows {f : Field} (C : Type(0)) (m : Natural) (choices : List(C))
        (fterm : (NaturalsBelow(1 + m) → C) → Field.carrier(f))
        (l : List(NaturalsBelow(m) → C))
        : Field.sumOver(fterm, Function.concatFunctionRows(C, m, choices, l))
          = Field.sumOver((psi : NaturalsBelow(m) → C) ↦
                Field.sumOver((c : C) ↦ fterm(Function.extendByValue(psi, c)), choices), l) :=
  by induction on l with IH {
    case List.empty:
        Field.sumOver(fterm,
              Function.concatFunctionRows(C, m, choices, List.empty(NaturalsBelow(m) → C)))
           = Field.sumOver(fterm, List.empty(NaturalsBelow(1 + m) → C))
           = Field.zero(f)
           = Field.sumOver((psi : NaturalsBelow(m) → C) ↦
                 Field.sumOver((c : C) ↦ fterm(Function.extendByValue(psi, c)), choices),
                 List.empty(NaturalsBelow(m) → C))
    case List.prepend(psi0, rest):
        Field.sumOver(fterm,
              Function.concatFunctionRows(C, m, choices, List.prepend(NaturalsBelow(m) → C, psi0, rest)))
           = Field.sumOver(fterm,
                 List.append(NaturalsBelow(1 + m) → C, Function.functionRow(choices, psi0),
                     Function.concatFunctionRows(C, m, choices, rest)))
           = Field.sumOver(fterm, Function.functionRow(choices, psi0))
                 + Field.sumOver(fterm, Function.concatFunctionRows(C, m, choices, rest))
                 by Field.sumOver_append(fterm, Function.functionRow(choices, psi0),
                        Function.concatFunctionRows(C, m, choices, rest))
           = Field.sumOver(fterm,
                 List.map(C, NaturalsBelow(1 + m) → C, (v : C) ↦ Function.extendByValue(psi0, v), choices))
                 + Field.sumOver(fterm, Function.concatFunctionRows(C, m, choices, rest))
           = Field.sumOver((c : C) ↦ fterm(Function.extendByValue(psi0, c)), choices)
                 + Field.sumOver(fterm, Function.concatFunctionRows(C, m, choices, rest))
                 by Field.sumOver_map(fterm, (v : C) ↦ Function.extendByValue(psi0, v), choices)
           = Field.sumOver((c : C) ↦ fterm(Function.extendByValue(psi0, c)), choices)
                 + Field.sumOver((psi : NaturalsBelow(m) → C) ↦
                       Field.sumOver((c : C) ↦ fterm(Function.extendByValue(psi, c)), choices), rest)
                 by substituting IH
           = Field.sumOver((psi : NaturalsBelow(m) → C) ↦
                 Field.sumOver((c : C) ↦ fterm(Function.extendByValue(psi, c)), choices),
                 List.prepend(NaturalsBelow(m) → C, psi0, rest))
  }

-- The product over the full index set of a term read through `extendByValue`
-- splits off the top factor (which reads the extending value `c`) from the
-- product over the indices below (which reads the underlying `psi`).
theorem Field.productOver_extendByValue_split {f : Field} (C : Type(0)) (m : Natural)
        (h : NaturalsBelow(1 + m) → C → Field.carrier(f)) (psi : NaturalsBelow(m) → C) (c : C)
        : Field.productOver((i : NaturalsBelow(1 + m)) ↦ h(i, Function.extendByValue(psi, c)(i)),
              NaturalsBelow.enumerate(1 + m))
          = h(NaturalsBelow.top(m), c)
                * Field.productOver((x : NaturalsBelow(m)) ↦ h(NaturalsBelow.inclusion(m, x), psi(x)),
                      NaturalsBelow.enumerate(m)) :=
  Field.productOver((i : NaturalsBelow(1 + m)) ↦ h(i, Function.extendByValue(psi, c)(i)),
        NaturalsBelow.enumerate(1 + m))
     = Field.productOver((i : NaturalsBelow(1 + m)) ↦ h(i, Function.extendByValue(psi, c)(i)),
           List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
               List.map(NaturalsBelow(m), NaturalsBelow(1 + m), NaturalsBelow.inclusion(m),
                   NaturalsBelow.enumerate(m))))
           by substituting NaturalsBelow.enumerate_one_plus
     = h(NaturalsBelow.top(m), Function.extendByValue(psi, c)(NaturalsBelow.top(m)))
           * Field.productOver((i : NaturalsBelow(1 + m)) ↦ h(i, Function.extendByValue(psi, c)(i)),
                 List.map(NaturalsBelow(m), NaturalsBelow(1 + m), NaturalsBelow.inclusion(m),
                     NaturalsBelow.enumerate(m)))
           by Field.productOver_prepend(
                  (i : NaturalsBelow(1 + m)) ↦ h(i, Function.extendByValue(psi, c)(i)),
                  NaturalsBelow.top(m),
                  List.map(NaturalsBelow(m), NaturalsBelow(1 + m), NaturalsBelow.inclusion(m),
                      NaturalsBelow.enumerate(m)))
     = h(NaturalsBelow.top(m), c)
           * Field.productOver((i : NaturalsBelow(1 + m)) ↦ h(i, Function.extendByValue(psi, c)(i)),
                 List.map(NaturalsBelow(m), NaturalsBelow(1 + m), NaturalsBelow.inclusion(m),
                     NaturalsBelow.enumerate(m)))
           by substituting Function.apply_extendByValue_top(psi, c)
     = h(NaturalsBelow.top(m), c)
           * Field.productOver((x : NaturalsBelow(m)) ↦
                 h(NaturalsBelow.inclusion(m, x),
                     Function.extendByValue(psi, c)(NaturalsBelow.inclusion(m, x))),
                 NaturalsBelow.enumerate(m))
           by Field.productOver_map(
                  (i : NaturalsBelow(1 + m)) ↦ h(i, Function.extendByValue(psi, c)(i)),
                  NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m))
     = h(NaturalsBelow.top(m), c)
           * Field.productOver((x : NaturalsBelow(m)) ↦ h(NaturalsBelow.inclusion(m, x), psi(x)),
                 NaturalsBelow.enumerate(m))
           by Field.productOver_congruence(
                  (x : NaturalsBelow(m)) ↦
                      h(NaturalsBelow.inclusion(m, x),
                          Function.extendByValue(psi, c)(NaturalsBelow.inclusion(m, x))),
                  (x : NaturalsBelow(m)) ↦ h(NaturalsBelow.inclusion(m, x), psi(x)),
                  NaturalsBelow.enumerate(m),
                  (x : NaturalsBelow(m)) ↦ {
                    Function.extendByValue(psi, c)(NaturalsBelow.inclusion(m, x)) = psi(x)
                        by Function.apply_extendByValue_inclusion(psi, c, x) as extAtX;
                    h(NaturalsBelow.inclusion(m, x),
                          Function.extendByValue(psi, c)(NaturalsBelow.inclusion(m, x)))
                       = h(NaturalsBelow.inclusion(m, x), psi(x)) by substituting extAtX;
                    done
                  })

-- Generalized distributivity `∏ᵢ Σ_c h(i,c) = Σ_φ ∏ᵢ h(i, φi)`: expanding a
-- product of sums enumerates one choice per factor, i.e. one function φ from
-- the index set to the choices. Induction on the number of rows; the step
-- peels the top row (productOver over `enumerate(1+m)`), applies the inductive
-- hypothesis to the restricted term below, and matches the resulting double
-- sum against the concatenated rows of `functionsBelow(1 + m)`.
theorem Field.productOfSums_distributes {f : Field} (C : Type(0)) (choices : List(C)) (rows : Natural)
        : ∀ (h : NaturalsBelow(rows) → C → Field.carrier(f)).
              Field.productOver((i : NaturalsBelow(rows)) ↦ Field.sumOver((c : C) ↦ h(i, c), choices),
                  NaturalsBelow.enumerate(rows))
              = Field.sumOver((phi : NaturalsBelow(rows) → C) ↦
                    Field.productOver((i : NaturalsBelow(rows)) ↦ h(i, phi(i)),
                        NaturalsBelow.enumerate(rows)),
                    Function.functionsBelow(C, choices, rows)) :=
  by induction on rows with IH {
    case base: {
        take h : NaturalsBelow(0) → C → Field.carrier(f);
        Field.productOver((i : NaturalsBelow(0)) ↦ Field.sumOver((c : C) ↦ h(i, c), choices),
              NaturalsBelow.enumerate(0))
           = Field.one(f)
           = Field.one(f) + Field.zero(f)                          by ring
           = Field.productOver((i : NaturalsBelow(0)) ↦ h(i, Function.emptyBelow(i)),
                 NaturalsBelow.enumerate(0)) + Field.zero(f)
           = Field.sumOver((phi : NaturalsBelow(0) → C) ↦
                 Field.productOver((i : NaturalsBelow(0)) ↦ h(i, phi(i)), NaturalsBelow.enumerate(0)),
                 Function.functionsBelow(C, choices, 0));
        done
      }
    case step(m): {
        take h : NaturalsBelow(1 + m) → C → Field.carrier(f);
        Field.productOver((x : NaturalsBelow(m)) ↦
              Field.sumOver((c : C) ↦ h(NaturalsBelow.inclusion(m, x), c), choices),
              NaturalsBelow.enumerate(m))
           = Field.sumOver((psi : NaturalsBelow(m) → C) ↦
                 Field.productOver((x : NaturalsBelow(m)) ↦ h(NaturalsBelow.inclusion(m, x), psi(x)),
                     NaturalsBelow.enumerate(m)),
                 Function.functionsBelow(C, choices, m))
           by IH((x : NaturalsBelow(m)) ↦ (cc : C) ↦ h(NaturalsBelow.inclusion(m, x), cc))
           as ihEq;
        Field.sumOver((phi : NaturalsBelow(1 + m) → C) ↦
              Field.productOver((i : NaturalsBelow(1 + m)) ↦ h(i, phi(i)),
                  NaturalsBelow.enumerate(1 + m)),
              Function.functionsBelow(C, choices, 1 + m))
           = Field.sumOver((phi : NaturalsBelow(1 + m) → C) ↦
                 Field.productOver((i : NaturalsBelow(1 + m)) ↦ h(i, phi(i)),
                     NaturalsBelow.enumerate(1 + m)),
                 Function.concatFunctionRows(C, m, choices, Function.functionsBelow(C, choices, m)))
                 by substituting Function.functionsBelow_one_plus
           = Field.sumOver((psi : NaturalsBelow(m) → C) ↦
                 Field.sumOver((c : C) ↦
                     Field.productOver((i : NaturalsBelow(1 + m)) ↦
                         h(i, Function.extendByValue(psi, c)(i)), NaturalsBelow.enumerate(1 + m)),
                     choices),
                 Function.functionsBelow(C, choices, m))
                 by Field.sumOver_concatFunctionRows(C, m, choices,
                        (phi : NaturalsBelow(1 + m) → C) ↦
                            Field.productOver((i : NaturalsBelow(1 + m)) ↦ h(i, phi(i)),
                                NaturalsBelow.enumerate(1 + m)),
                        Function.functionsBelow(C, choices, m))
           = Field.sumOver((psi : NaturalsBelow(m) → C) ↦
                 Field.sumOver((c : C) ↦
                     h(NaturalsBelow.top(m), c)
                         * Field.productOver((x : NaturalsBelow(m)) ↦
                               h(NaturalsBelow.inclusion(m, x), psi(x)), NaturalsBelow.enumerate(m)),
                     choices),
                 Function.functionsBelow(C, choices, m))
                 by Field.sumOver_congruence(
                        (psi : NaturalsBelow(m) → C) ↦
                            Field.sumOver((c : C) ↦
                                Field.productOver((i : NaturalsBelow(1 + m)) ↦
                                    h(i, Function.extendByValue(psi, c)(i)), NaturalsBelow.enumerate(1 + m)),
                                choices),
                        (psi : NaturalsBelow(m) → C) ↦
                            Field.sumOver((c : C) ↦
                                h(NaturalsBelow.top(m), c)
                                    * Field.productOver((x : NaturalsBelow(m)) ↦
                                          h(NaturalsBelow.inclusion(m, x), psi(x)), NaturalsBelow.enumerate(m)),
                                choices),
                        Function.functionsBelow(C, choices, m),
                        (psi : NaturalsBelow(m) → C) ↦
                            Field.sumOver_congruence(
                                (c : C) ↦
                                    Field.productOver((i : NaturalsBelow(1 + m)) ↦
                                        h(i, Function.extendByValue(psi, c)(i)), NaturalsBelow.enumerate(1 + m)),
                                (c : C) ↦
                                    h(NaturalsBelow.top(m), c)
                                        * Field.productOver((x : NaturalsBelow(m)) ↦
                                              h(NaturalsBelow.inclusion(m, x), psi(x)),
                                              NaturalsBelow.enumerate(m)),
                                choices,
                                (c : C) ↦ Field.productOver_extendByValue_split(C, m, h, psi, c)))
           as rhsToMidpoint;
        Field.productOver((i : NaturalsBelow(1 + m)) ↦ Field.sumOver((c : C) ↦ h(i, c), choices),
              NaturalsBelow.enumerate(1 + m))
           = Field.productOver((i : NaturalsBelow(1 + m)) ↦ Field.sumOver((c : C) ↦ h(i, c), choices),
                 List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
                     List.map(NaturalsBelow(m), NaturalsBelow(1 + m), NaturalsBelow.inclusion(m),
                         NaturalsBelow.enumerate(m))))
                 by substituting NaturalsBelow.enumerate_one_plus
           = Field.sumOver((c : C) ↦ h(NaturalsBelow.top(m), c), choices)
                 * Field.productOver((i : NaturalsBelow(1 + m)) ↦ Field.sumOver((c : C) ↦ h(i, c), choices),
                       List.map(NaturalsBelow(m), NaturalsBelow(1 + m), NaturalsBelow.inclusion(m),
                           NaturalsBelow.enumerate(m)))
                 by Field.productOver_prepend(
                        (i : NaturalsBelow(1 + m)) ↦ Field.sumOver((c : C) ↦ h(i, c), choices),
                        NaturalsBelow.top(m),
                        List.map(NaturalsBelow(m), NaturalsBelow(1 + m), NaturalsBelow.inclusion(m),
                            NaturalsBelow.enumerate(m)))
           = Field.sumOver((c : C) ↦ h(NaturalsBelow.top(m), c), choices)
                 * Field.productOver((x : NaturalsBelow(m)) ↦
                       Field.sumOver((c : C) ↦ h(NaturalsBelow.inclusion(m, x), c), choices),
                       NaturalsBelow.enumerate(m))
                 by Field.productOver_map(
                        (i : NaturalsBelow(1 + m)) ↦ Field.sumOver((c : C) ↦ h(i, c), choices),
                        NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m))
           = Field.sumOver((c : C) ↦ h(NaturalsBelow.top(m), c), choices)
                 * Field.sumOver((psi : NaturalsBelow(m) → C) ↦
                       Field.productOver((x : NaturalsBelow(m)) ↦ h(NaturalsBelow.inclusion(m, x), psi(x)),
                           NaturalsBelow.enumerate(m)),
                       Function.functionsBelow(C, choices, m))
                 by substituting ihEq
           = Field.sumOver((c : C) ↦
                 Field.sumOver((psi : NaturalsBelow(m) → C) ↦
                     h(NaturalsBelow.top(m), c)
                         * Field.productOver((x : NaturalsBelow(m)) ↦
                               h(NaturalsBelow.inclusion(m, x), psi(x)), NaturalsBelow.enumerate(m)),
                     Function.functionsBelow(C, choices, m)),
                 choices)
                 by Field.sumOver_multiply_sumOver(
                        (c : C) ↦ h(NaturalsBelow.top(m), c),
                        (psi : NaturalsBelow(m) → C) ↦
                            Field.productOver((x : NaturalsBelow(m)) ↦
                                h(NaturalsBelow.inclusion(m, x), psi(x)), NaturalsBelow.enumerate(m)),
                        choices, Function.functionsBelow(C, choices, m))
           = Field.sumOver((psi : NaturalsBelow(m) → C) ↦
                 Field.sumOver((c : C) ↦
                     h(NaturalsBelow.top(m), c)
                         * Field.productOver((x : NaturalsBelow(m)) ↦
                               h(NaturalsBelow.inclusion(m, x), psi(x)), NaturalsBelow.enumerate(m)),
                     choices),
                 Function.functionsBelow(C, choices, m))
                 by Field.sumOver_interchange(
                        (c : C) ↦ (psi : NaturalsBelow(m) → C) ↦
                            h(NaturalsBelow.top(m), c)
                                * Field.productOver((x : NaturalsBelow(m)) ↦
                                      h(NaturalsBelow.inclusion(m, x), psi(x)), NaturalsBelow.enumerate(m)),
                        choices, Function.functionsBelow(C, choices, m))
           = Field.sumOver((phi : NaturalsBelow(1 + m) → C) ↦
                 Field.productOver((i : NaturalsBelow(1 + m)) ↦ h(i, phi(i)),
                     NaturalsBelow.enumerate(1 + m)),
                 Function.functionsBelow(C, choices, 1 + m))
                 by rhsToMidpoint;
        done
      }
  }

-- The determinant corollary: the product over rows of the sum over all columns
-- equals the sum over all choice functions `NaturalsBelow(n) → NaturalsBelow(n)`
-- of the product of the chosen entries.
theorem Field.productOfSums_over_allFunctions {f : Field} (n : Natural)
        (h : NaturalsBelow(n) → NaturalsBelow(n) → Field.carrier(f))
        : Field.productOver((i : NaturalsBelow(n)) ↦
              Field.sumOver((c : NaturalsBelow(n)) ↦ h(i, c), NaturalsBelow.enumerate(n)),
              NaturalsBelow.enumerate(n))
          = Field.sumOver((phi : NaturalsBelow(n) → NaturalsBelow(n)) ↦
                Field.productOver((i : NaturalsBelow(n)) ↦ h(i, phi(i)), NaturalsBelow.enumerate(n)),
                Function.allFunctions(n)) :=
  Field.productOfSums_distributes(NaturalsBelow(n), NaturalsBelow.enumerate(n), n, h)

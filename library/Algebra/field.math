-- Algebra/field.math
--
-- A field is a commutative ring in which 0 ≠ 1 and every non-zero
-- element has a multiplicative inverse. The inverse-existence axiom
-- is stated propositionally (∃ y. x · y = 1) rather than as a
-- partial inverse function, matching the style of `IsGroup` /
-- `IsCommutativeRing` and avoiding the need to thread a
-- dependently-typed function through every Field instance.

module Algebra.field

import Logic.basics
import Logic.exists
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.ring

definition IsField
        (carrier : Type(0))
        (add : carrier → carrier → carrier)
        (zero : carrier)
        (negate : carrier → carrier)
        (multiply : carrier → carrier → carrier)
        (one : carrier)
        : Proposition :=
    IsCommutativeRing(carrier, add, zero, negate, multiply, one)
    ∧ ¬(zero = one)
    ∧ ((x : carrier) → ¬(x = zero)
           → ∃ (y : carrier). multiply(x, y) = one)

-- Algebra/permutation_enumeration.math
--
-- The enumeration list `Permutation.all(n) : List(Permutation(n))` — every
-- permutation of `NaturalsBelow(n)`, each listed exactly once (completeness +
-- distinctness). This is the index set the determinant sums over (Stage H of
-- PLAN_LINEAR_ALGEBRA.md).
--
-- The recursion mirrors the standard `|Sₙ| = n·|Sₙ₋₁|` count: a permutation of
-- `NaturalsBelow(1 + m)` is determined by where it sends the top index and by
-- its restriction below, so `all(1 + m)` concatenates, over every
-- `σ ∈ all(m)`, the row `[ swap(top, j) ∘ extend(σ) : j ∈ NaturalsBelow(1 + m) ]`.

module Algebra.permutation_enumeration

import Logic.basics
import Equality.basics
import Logic.functions
import Natural.basics
import Natural.arithmetic
import Natural.order
import Set.finite
import Set.finite_pigeonhole
import Lists.list
import Lists.map
import Lists.append
import Lists.distinct
import Algebra.finite_permutation

-- ----------------------------------------------------------------------
-- Enumerating the index type `NaturalsBelow(n)` itself: the top index, then
-- the inclusions of the enumeration one level down.
--
-- The result type `List(NaturalsBelow(n))` genuinely depends on the recursion
-- variable, and the `1 + m` step spelling is not definitionally the sealed
-- `successor` the recursor eliminates on. `unfold Natural.add in` bridges the
-- two INSIDE the arm, so the arm builds an honest `1 + m`-typed list with no
-- index transport (a transport would refuse to ι-reduce, stranding the
-- recursion); the `_one_plus` equation replays the same bridge.

definition NaturalsBelow.enumerate : (n : Natural) → List(NaturalsBelow(n))
  | 0 => List.empty(NaturalsBelow(0))
  | 1 + m => unfold Natural.add in
      List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
          List.map(NaturalsBelow(m), NaturalsBelow(1 + m), NaturalsBelow.inclusion(m),
              NaturalsBelow.enumerate(m)))

theorem NaturalsBelow.enumerate_one_plus (m : Natural)
        : NaturalsBelow.enumerate(1 + m)
          = List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
                List.map(NaturalsBelow(m), NaturalsBelow(1 + m), NaturalsBelow.inclusion(m),
                    NaturalsBelow.enumerate(m))) :=
  unfold Natural.add in
  reflexivity(List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
      List.map(NaturalsBelow(m), NaturalsBelow(1 + m), NaturalsBelow.inclusion(m),
          NaturalsBelow.enumerate(m))))

-- Every index of `NaturalsBelow(n)` appears in `enumerate(n)`. The step
-- splits an index by whether its value is below the boundary (an inclusion
-- from one level down, in the mapped tail) or equal to it (the top head).
theorem NaturalsBelow.enumerate_complete (n : Natural)
        : ∀ (x : NaturalsBelow(n)). List.member(NaturalsBelow(n), x, NaturalsBelow.enumerate(n)) :=
  by induction on n with IH {
    case base:
        (x : NaturalsBelow(0)) ↦ absurd(NaturalsBelow.zero_is_empty(x))
    case step(m): {
        take x : NaturalsBelow(1 + m);
        NaturalsBelow.value(x) < 1 + m by NaturalsBelow.below;
        NaturalsBelow.value(x) ≤ m by Natural.le_of_lt_one_plus;
        NaturalsBelow.value(x) < m ∨ NaturalsBelow.value(x) = m;
        done by cases {
          case NaturalsBelow.value(x) < m as belowBoundary: {
              let y : NaturalsBelow(m) := NaturalsBelow.make(NaturalsBelow.value(x), belowBoundary);
              x = NaturalsBelow.inclusion(m, y) by NaturalsBelow.equal_of_value as xIsInclusion;
              List.member(NaturalsBelow(m), y, NaturalsBelow.enumerate(m)) by IH(y);
              List.member(NaturalsBelow(1 + m), NaturalsBelow.inclusion(m, y),
                        List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                            NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m)))
                  by List.map_member(NaturalsBelow(m), NaturalsBelow(1 + m),
                         NaturalsBelow.inclusion(m), y, NaturalsBelow.enumerate(m), IH(y));
              List.member(NaturalsBelow(1 + m), x,
                        List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                            NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m)))
                  by substituting xIsInclusion;
              List.member(NaturalsBelow(1 + m), x,
                        List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
                            List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                                NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m))))
                  by List.member.there;
              done by substituting NaturalsBelow.enumerate_one_plus
            }
          case NaturalsBelow.value(x) = m as atBoundary: {
              x = NaturalsBelow.top(m) by NaturalsBelow.equal_of_value as xIsTop;
              List.member(NaturalsBelow(1 + m), NaturalsBelow.top(m),
                        List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
                            List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                                NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m))))
                  by List.member.here;
              List.member(NaturalsBelow(1 + m), x,
                        List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
                            List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                                NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m))))
                  by substituting xIsTop;
              done by substituting NaturalsBelow.enumerate_one_plus
            }
        }
      }
  }

-- The top index is not among the inclusions (they all have value below the
-- boundary; the top has value equal to it).
theorem NaturalsBelow.top_not_in_inclusions (m : Natural)
        : ¬(List.member(NaturalsBelow(1 + m), NaturalsBelow.top(m),
                List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                    NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m)))) :=
  (topInImage : List.member(NaturalsBelow(1 + m), NaturalsBelow.top(m),
      List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
          NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m)))) ↦ {
    choose y such that
        List.member(NaturalsBelow(m), y, NaturalsBelow.enumerate(m))
            ∧ (NaturalsBelow.inclusion(m, y) = NaturalsBelow.top(m))
        from List.map_member_invert(NaturalsBelow(m), NaturalsBelow(1 + m),
                 NaturalsBelow.inclusion(m), NaturalsBelow.top(m), NaturalsBelow.enumerate(m),
                 topInImage);
    NaturalsBelow.inclusion(m, y) = NaturalsBelow.top(m) as inclusionIsTop;
    NaturalsBelow.value(y)
       = NaturalsBelow.value(NaturalsBelow.inclusion(m, y))
       = NaturalsBelow.value(NaturalsBelow.top(m)) by substituting inclusionIsTop
       = m as valueIsM;
    NaturalsBelow.value(y) < m by NaturalsBelow.below;
    m < m by substituting valueIsM;
    False by Natural.lt_irreflexive(m);
    done
  }

-- `enumerate(n)` has no duplicates: the mapped inclusions are distinct
-- (inclusion is injective) and the top head is new.
theorem NaturalsBelow.enumerate_distinct (n : Natural)
        : List.Distinct(NaturalsBelow(n), NaturalsBelow.enumerate(n)) :=
  by induction on n with IH {
    case base: List.Distinct.empty(NaturalsBelow(0))
    case step(m): {
        List.Distinct(NaturalsBelow(1 + m),
                List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                    NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m)))
            by List.map_distinct(NaturalsBelow(m), NaturalsBelow(1 + m),
                   NaturalsBelow.inclusion(m),
                   (a b : NaturalsBelow(m))
                       (equalInclusions : NaturalsBelow.inclusion(m, a) = NaturalsBelow.inclusion(m, b)) ↦
                       NaturalsBelow.inclusion_injective(m, a, b, equalInclusions),
                   NaturalsBelow.enumerate(m), IH)
            as tailDistinct;
        List.Distinct(NaturalsBelow(1 + m),
                List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
                    List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                        NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m))))
            by List.Distinct.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
                   List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                       NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m)),
                   NaturalsBelow.top_not_in_inclusions(m), tailDistinct);
        done by substituting NaturalsBelow.enumerate_one_plus
      }
  }

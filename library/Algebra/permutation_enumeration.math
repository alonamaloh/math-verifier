-- Algebra/permutation_enumeration.math
--
-- The enumeration list `Permutation.allPermutations(n) : List(Permutation(n))`
-- — every permutation of `NaturalsBelow(n)`, each listed exactly once
-- (completeness + distinctness). This is the index set the determinant sums
-- over (Stage H of PLAN_LINEAR_ALGEBRA.md).
--
-- The recursion mirrors the standard `|Sₙ| = n·|Sₙ₋₁|` count: a permutation of
-- `NaturalsBelow(1 + m)` is determined by where it sends the top index and by
-- its restriction below, so `allPermutations(1 + m)` concatenates, over every
-- `σ ∈ allPermutations(m)`, the row
-- `[ swap(top, j) ∘ extend(σ) : j ∈ NaturalsBelow(1 + m) ]`.

module Algebra.permutation_enumeration

import Logic.basics
import Equality.basics
import Logic.functions
import Natural.basics
import Natural.arithmetic
import Natural.order
import Set.finite
import Set.finite_pigeonhole
import Lists.list
import Lists.map
import Lists.append
import Lists.distinct
import Algebra.finite_permutation

-- ----------------------------------------------------------------------
-- Enumerating the index type `NaturalsBelow(n)` itself: the top index, then
-- the inclusions of the enumeration one level down.
--
-- The result type `List(NaturalsBelow(n))` genuinely depends on the recursion
-- variable, and the `1 + m` step spelling is not definitionally the sealed
-- `successor` the recursor eliminates on. `unfold Natural.add in` bridges the
-- two INSIDE the arm, so the arm builds an honest `1 + m`-typed list with no
-- index transport (a transport would refuse to ι-reduce, stranding the
-- recursion); the `_one_plus` equation replays the same bridge.

definition NaturalsBelow.enumerate : (n : Natural) → List(NaturalsBelow(n))
  | 0 => List.empty(NaturalsBelow(0))
  | 1 + m => unfold Natural.add in
      List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
          List.map(NaturalsBelow(m), NaturalsBelow(1 + m), NaturalsBelow.inclusion(m),
              NaturalsBelow.enumerate(m)))

theorem NaturalsBelow.enumerate_one_plus (m : Natural)
        : NaturalsBelow.enumerate(1 + m)
          = List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
                List.map(NaturalsBelow(m), NaturalsBelow(1 + m), NaturalsBelow.inclusion(m),
                    NaturalsBelow.enumerate(m))) :=
  unfold Natural.add in
  reflexivity(List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
      List.map(NaturalsBelow(m), NaturalsBelow(1 + m), NaturalsBelow.inclusion(m),
          NaturalsBelow.enumerate(m))))

-- Every index of `NaturalsBelow(n)` appears in `enumerate(n)`. The step
-- splits an index by whether its value is below the boundary (an inclusion
-- from one level down, in the mapped tail) or equal to it (the top head).
theorem NaturalsBelow.enumerate_complete (n : Natural)
        : ∀ (x : NaturalsBelow(n)). x ∈ NaturalsBelow.enumerate(n) :=
  by induction on n with IH {
    case base:
        (x : NaturalsBelow(0)) ↦ { False by NaturalsBelow.zero_is_empty; done }
    case step(m): {
        take x : NaturalsBelow(1 + m);
        NaturalsBelow.value(x) < 1 + m by NaturalsBelow.below;
        NaturalsBelow.value(x) ≤ m by Natural.le_of_lt_one_plus;
        NaturalsBelow.value(x) < m ∨ NaturalsBelow.value(x) = m;
        done by cases {
          case NaturalsBelow.value(x) < m as belowBoundary: {
              let y : NaturalsBelow(m) := NaturalsBelow.make(NaturalsBelow.value(x), belowBoundary);
              x = NaturalsBelow.inclusion(m, y) by NaturalsBelow.equal_of_value as xIsInclusion;
              y ∈ NaturalsBelow.enumerate(m) by IH(y);
              NaturalsBelow.inclusion(m, y) ∈
                        List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                            NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m))
                  by List.map_member;
              x ∈
                        List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                            NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m))
                  by substituting xIsInclusion;
              x ∈
                        List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
                            List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                                NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m)))
                  by List.member.there;
              done by substituting NaturalsBelow.enumerate_one_plus
            }
          case NaturalsBelow.value(x) = m as atBoundary: {
              x = NaturalsBelow.top(m) by NaturalsBelow.equal_of_value as xIsTop;
              NaturalsBelow.top(m) ∈
                        List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
                            List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                                NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m)))
                  by List.member.here;
              x ∈
                        List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
                            List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                                NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m)))
                  by substituting xIsTop;
              done by substituting NaturalsBelow.enumerate_one_plus
            }
        }
      }
  }

-- The top index is not among the inclusions (they all have value below the
-- boundary; the top has value equal to it).
theorem NaturalsBelow.top_not_in_inclusions (m : Natural)
        : ¬(NaturalsBelow.top(m) ∈
                List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                    NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m))) :=
  (topInImage : NaturalsBelow.top(m) ∈
      List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
          NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m))) ↦ {
    ∃ (y : NaturalsBelow(m)). y ∈ NaturalsBelow.enumerate(m)
            ∧ (NaturalsBelow.inclusion(m, y) = NaturalsBelow.top(m))
        by List.map_member_invert as preimageExists;
    choose y such that
        y ∈ NaturalsBelow.enumerate(m)
            ∧ (NaturalsBelow.inclusion(m, y) = NaturalsBelow.top(m))
        from preimageExists;
    NaturalsBelow.inclusion(m, y) = NaturalsBelow.top(m) as inclusionIsTop;
    NaturalsBelow.value(y)
       = NaturalsBelow.value(NaturalsBelow.inclusion(m, y))
       = NaturalsBelow.value(NaturalsBelow.top(m)) by substituting inclusionIsTop
       = m as valueIsM;
    NaturalsBelow.value(y) < m by NaturalsBelow.below;
    m < m by substituting valueIsM;
    False by Natural.lt_irreflexive;
    done
  }

-- `enumerate(n)` has no duplicates: the mapped inclusions are distinct
-- (inclusion is injective) and the top head is new.
theorem NaturalsBelow.enumerate_distinct (n : Natural)
        : List.Distinct(NaturalsBelow(n), NaturalsBelow.enumerate(n)) :=
  by induction on n with IH {
    case base: List.Distinct.empty(NaturalsBelow(0))
    case step(m): {
        ∀ (a b : NaturalsBelow(m)). NaturalsBelow.inclusion(m, a) = NaturalsBelow.inclusion(m, b) → a = b
            by NaturalsBelow.inclusion_injective;
        List.Distinct(NaturalsBelow(1 + m),
                List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                    NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m)))
            by List.map_distinct;
        List.Distinct(NaturalsBelow(1 + m),
                List.prepend(NaturalsBelow(1 + m), NaturalsBelow.top(m),
                    List.map(NaturalsBelow(m), NaturalsBelow(1 + m),
                        NaturalsBelow.inclusion(m), NaturalsBelow.enumerate(m))))
            by List.Distinct.prepend;
        done by substituting NaturalsBelow.enumerate_one_plus
      }
  }

-- ----------------------------------------------------------------------
-- The top-index decomposition. Every permutation τ of NaturalsBelow(1 + m)
-- factors as `swap(top, τ(top)) ∘ extend(σ)` for a unique σ of NaturalsBelow(m)
-- — this is what makes the enumeration below complete (every τ is a "row") and
-- distinct (σ is recoverable, so the rows for distinct σ are disjoint).

-- Right cancellation in the group: post-composing by the same permutation is
-- injective (undo it with the inverse).
theorem Permutation.compose_inverse_cancel_right {n : Natural} (p g : Permutation(n))
        : Permutation.compose(Permutation.compose(p, g), Permutation.inverse(g)) = p :=
  Permutation.compose(Permutation.compose(p, g), Permutation.inverse(g))
     = Permutation.compose(p, Permutation.compose(g, Permutation.inverse(g)))
           by Permutation.compose_associative
     = Permutation.compose(p, Permutation.identity(n))
           by substituting Permutation.inverse_compose_right
     = p by Permutation.compose_identity_right

theorem Permutation.compose_right_cancel {n : Natural} (a b g : Permutation(n))
        (equalComposites : Permutation.compose(a, g) = Permutation.compose(b, g))
        : a = b :=
  a = Permutation.compose(Permutation.compose(a, g), Permutation.inverse(g))
          by Permutation.compose_inverse_cancel_right
    = Permutation.compose(Permutation.compose(b, g), Permutation.inverse(g))
          by substituting equalComposites
    = b by Permutation.compose_inverse_cancel_right

-- A transposition composed with itself is the identity (it is an involution).
theorem Permutation.swap_compose_self {n : Natural} (a b : NaturalsBelow(n))
        : Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, b)) = Permutation.identity(n) :=
  Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, b))
     = Permutation.compose(Permutation.inverse(Permutation.swap(a, b)), Permutation.swap(a, b))
           by substituting Permutation.inverse_swap
     = Permutation.identity(n) by Permutation.inverse_compose_left

-- `restrict` depends only on the underlying permutation, not on the (proof-
-- irrelevant) top-fixing witness: equal permutations restrict equally.
theorem Permutation.restrict_congruence {m : Natural} (tau1 tau2 : Permutation(1 + m))
        (fixes1 : Permutation.apply(tau1, NaturalsBelow.top(m)) = NaturalsBelow.top(m))
        (fixes2 : Permutation.apply(tau2, NaturalsBelow.top(m)) = NaturalsBelow.top(m))
        (equalPermutations : tau1 = tau2)
        : Permutation.restrict(tau1, fixes1) = Permutation.restrict(tau2, fixes2) :=
  {
  ∀ (x : NaturalsBelow(m)).
      Permutation.apply(Permutation.restrict(tau1, fixes1), x) = Permutation.apply(Permutation.restrict(tau2, fixes2), x)
    by { take x : NaturalsBelow(m);
         NaturalsBelow.value(Permutation.apply(tau1, NaturalsBelow.inclusion(m, x)))
            = NaturalsBelow.value(Permutation.apply(tau2, NaturalsBelow.inclusion(m, x)))
                  by substituting equalPermutations;
         Permutation.apply(Permutation.restrict(tau1, fixes1), x)
            = Permutation.restrictMap(tau1, fixes1, x) by Permutation.apply_restrict
            = Permutation.restrictMap(tau2, fixes2, x) by NaturalsBelow.equal_of_value
            = Permutation.apply(Permutation.restrict(tau2, fixes2), x) by Permutation.apply_restrict;
         done };
  done by Permutation.equal_of_apply_equal
}

-- `swap(top, τ(top)) ∘ τ` fixes the top: it sends top ↦ τ(top) ↦ top.
theorem Permutation.top_swap_fixes {m : Natural} (tau : Permutation(1 + m))
        : Permutation.apply(
              Permutation.compose(
                  Permutation.swap(NaturalsBelow.top(m), Permutation.apply(tau, NaturalsBelow.top(m))), tau),
              NaturalsBelow.top(m))
          = NaturalsBelow.top(m) :=
  Permutation.apply(
          Permutation.compose(
              Permutation.swap(NaturalsBelow.top(m), Permutation.apply(tau, NaturalsBelow.top(m))), tau),
          NaturalsBelow.top(m))
     = Permutation.apply(
           Permutation.swap(NaturalsBelow.top(m), Permutation.apply(tau, NaturalsBelow.top(m))),
           Permutation.apply(tau, NaturalsBelow.top(m)))
           by Permutation.apply_compose
     = NaturalsBelow.top(m) by Permutation.apply_swap_right

-- The lower part: the restriction of `swap(top, τ(top)) ∘ τ` below the boundary.
definition Permutation.lower {m : Natural} (tau : Permutation(1 + m)) : Permutation(m) :=
  Permutation.restrict(
      Permutation.compose(
          Permutation.swap(NaturalsBelow.top(m), Permutation.apply(tau, NaturalsBelow.top(m))), tau),
      Permutation.top_swap_fixes(tau))

-- The decomposition: τ = swap(top, τ(top)) ∘ extend(lower(τ)).
theorem Permutation.decompose_top {m : Natural} (tau : Permutation(1 + m))
        : tau = Permutation.compose(
                    Permutation.swap(NaturalsBelow.top(m), Permutation.apply(tau, NaturalsBelow.top(m))),
                    Permutation.extend(Permutation.lower(tau))) :=
  tau
     = Permutation.compose(Permutation.identity(1 + m), tau) by Permutation.compose_identity_left
     = Permutation.compose(
           Permutation.compose(
               Permutation.swap(NaturalsBelow.top(m), Permutation.apply(tau, NaturalsBelow.top(m))),
               Permutation.swap(NaturalsBelow.top(m), Permutation.apply(tau, NaturalsBelow.top(m)))),
           tau)
           by substituting Permutation.swap_compose_self
     = Permutation.compose(
           Permutation.swap(NaturalsBelow.top(m), Permutation.apply(tau, NaturalsBelow.top(m))),
           Permutation.compose(
               Permutation.swap(NaturalsBelow.top(m), Permutation.apply(tau, NaturalsBelow.top(m))), tau))
           by Permutation.compose_associative
     = Permutation.compose(
           Permutation.swap(NaturalsBelow.top(m), Permutation.apply(tau, NaturalsBelow.top(m))),
           Permutation.extend(Permutation.lower(tau)))
           by substituting Permutation.extend_restrict

-- Recovery: `lower` inverts the row construction. Applied to `swap(top, p) ∘
-- extend(σ)` it returns σ — the top-image is p, so `swap(top, p)` cancels back
-- to `extend(σ)`, whose restriction is σ. This is what makes distinct σ give
-- disjoint rows.
theorem Permutation.lower_of_row {m : Natural} (sigma : Permutation(m)) (p : NaturalsBelow(1 + m))
        : Permutation.lower(Permutation.compose(Permutation.swap(NaturalsBelow.top(m), p),
              Permutation.extend(sigma))) = sigma := {
  let tau : Permutation(1 + m) :=
      Permutation.compose(Permutation.swap(NaturalsBelow.top(m), p), Permutation.extend(sigma));
  Permutation.apply(tau, NaturalsBelow.top(m))
     = Permutation.apply(Permutation.swap(NaturalsBelow.top(m), p),
           Permutation.apply(Permutation.extend(sigma), NaturalsBelow.top(m)))
           by Permutation.apply_compose
     = Permutation.apply(Permutation.swap(NaturalsBelow.top(m), p), NaturalsBelow.top(m))
           by substituting Permutation.apply_extend_top
     = p by Permutation.apply_swap_left
     as topEq;
  Permutation.compose(
          Permutation.swap(NaturalsBelow.top(m), Permutation.apply(tau, NaturalsBelow.top(m))), tau)
     = Permutation.compose(Permutation.swap(NaturalsBelow.top(m), p), tau) by substituting topEq
     = Permutation.compose(
           Permutation.compose(Permutation.swap(NaturalsBelow.top(m), p),
               Permutation.swap(NaturalsBelow.top(m), p)),
           Permutation.extend(sigma))
           by Permutation.compose_associative
     = Permutation.compose(Permutation.identity(1 + m), Permutation.extend(sigma))
           by substituting Permutation.swap_compose_self
     = Permutation.extend(sigma) by Permutation.compose_identity_left;
  Permutation.apply(Permutation.extend(sigma), NaturalsBelow.top(m)) = NaturalsBelow.top(m) as extendFixesTop;
  Permutation.lower(tau)
     = Permutation.restrict(Permutation.extend(sigma), extendFixesTop)
           by Permutation.restrict_congruence
     = sigma by Permutation.restrict_extend;
  done
}

-- ----------------------------------------------------------------------
-- The enumeration list. `allPermutations(1 + m)` concatenates, over every
-- σ ∈ allPermutations(m), the "row" of the (1 + m) permutations
-- swap(top, j) ∘ extend(σ), one for each index j.

-- A single entry of a row: the permutation sending the top to j, extending σ.
definition Permutation.rowElement {m : Natural} (sigma : Permutation(m)) (j : NaturalsBelow(1 + m))
        : Permutation(1 + m) :=
  Permutation.compose(Permutation.swap(NaturalsBelow.top(m), j), Permutation.extend(sigma))

-- The row for σ: its entries over all indices j ∈ NaturalsBelow(1 + m).
definition Permutation.insertRow {m : Natural} (sigma : Permutation(m)) : List(Permutation(1 + m)) :=
  List.map(NaturalsBelow(1 + m), Permutation(1 + m), Permutation.rowElement(sigma),
      NaturalsBelow.enumerate(1 + m))

-- Concatenate the rows over a list of permutations of NaturalsBelow(m).
-- Recursion on the LIST (m fixed), so no index transport arises here.
definition Permutation.concatRows (m : Natural)
        : List(Permutation(m)) → List(Permutation(1 + m))
  | List.empty => List.empty(Permutation(1 + m))
  | List.prepend(sigma, rest) =>
      List.append(Permutation(1 + m), Permutation.insertRow(sigma), Permutation.concatRows(m, rest))

-- All permutations of NaturalsBelow(n). The `1 + m` step recurses on the index
-- (dependent result type), bridged by `unfold Natural.add in` exactly as
-- `enumerate` above.
definition Permutation.allPermutations : (n : Natural) → List(Permutation(n))
  | 0 => List.prepend(Permutation(0), Permutation.identity(0), List.empty(Permutation(0)))
  | 1 + m => unfold Natural.add in Permutation.concatRows(m, Permutation.allPermutations(m))

theorem Permutation.allPermutations_one_plus (m : Natural)
        : Permutation.allPermutations(1 + m)
          = Permutation.concatRows(m, Permutation.allPermutations(m)) :=
  unfold Natural.add in reflexivity(Permutation.concatRows(m, Permutation.allPermutations(m)))

-- ----------------------------------------------------------------------
-- Completeness and distinctness of the enumeration.

-- Every permutation of the empty index type is the identity (there is nothing
-- to move).
theorem Permutation.perm_zero_is_identity (tau : Permutation(0)) : tau = Permutation.identity(0) := {
  ∀ (i : NaturalsBelow(0)). Permutation.apply(tau, i) = Permutation.apply(Permutation.identity(0), i)
      by (i : NaturalsBelow(0)) ↦ { False by NaturalsBelow.zero_is_empty; done };
  done by Permutation.equal_of_apply_equal
}

-- A row is injective in its index: `swap(top, ·)` is, and post-composing by
-- extend(σ) cancels.
theorem Permutation.rowElement_injective {m : Natural} (sigma : Permutation(m))
        (j1 j2 : NaturalsBelow(1 + m))
        (equalRows : Permutation.rowElement(sigma, j1) = Permutation.rowElement(sigma, j2))
        : j1 = j2 := {
  Permutation.swap(NaturalsBelow.top(m), j1) = Permutation.swap(NaturalsBelow.top(m), j2)
      by Permutation.compose_right_cancel
      as swapsEqual;
  j1 = Permutation.apply(Permutation.swap(NaturalsBelow.top(m), j1), NaturalsBelow.top(m))
          by Permutation.apply_swap_left
    = Permutation.apply(Permutation.swap(NaturalsBelow.top(m), j2), NaturalsBelow.top(m))
          by substituting swapsEqual
    = j2 by Permutation.apply_swap_left;
  done
}

-- Each row is distinct: an injective image of the distinct index enumeration.
theorem Permutation.insertRow_distinct {m : Natural} (sigma : Permutation(m))
        : List.Distinct(Permutation(1 + m), Permutation.insertRow(sigma)) := {
  ∀ (j1 j2 : NaturalsBelow(1 + m)). Permutation.rowElement(sigma, j1) = Permutation.rowElement(sigma, j2) → j1 = j2
      by Permutation.rowElement_injective;
  done by List.map_distinct
}

-- Every member of a row recovers its σ under `lower` — the key to cross-row
-- disjointness.
theorem Permutation.insertRow_member_lower {m : Natural} (sigma : Permutation(m))
        (tau : Permutation(1 + m))
        (memTau : tau ∈ Permutation.insertRow(sigma))
        : Permutation.lower(tau) = sigma := {
  ∃ (j : NaturalsBelow(1 + m)). j ∈ NaturalsBelow.enumerate(1 + m)
          ∧ (Permutation.rowElement(sigma, j) = tau)
      by List.map_member_invert as indexExists;
  choose j such that
      j ∈ NaturalsBelow.enumerate(1 + m)
          ∧ (Permutation.rowElement(sigma, j) = tau)
      from indexExists;
  Permutation.rowElement(sigma, j) = tau as rowIsTau;
  Permutation.lower(tau)
     = Permutation.lower(Permutation.rowElement(sigma, j)) by substituting rowIsTau
     = sigma by Permutation.lower_of_row;
  done
}

-- Membership into the concatenation: a τ in the row of a σ ∈ l is in
-- concatRows(l). Induct on where σ sits in l.
theorem Permutation.concatRows_member (m : Natural) (l : List(Permutation(m)))
        (sigma : Permutation(m)) (tau : Permutation(1 + m))
        (memSigma : sigma ∈ l)
        (memTau : tau ∈ Permutation.insertRow(sigma))
        : tau ∈ Permutation.concatRows(m, l) :=
  by induction on memSigma with IH {
    case List.member.here(rest): {
        tau ∈ List.append(Permutation(1 + m), Permutation.insertRow(sigma), Permutation.concatRows(m, rest))
            by List.member_append_left;
        done
      }
    case List.member.there(head, rest, sub): {
        tau ∈ Permutation.concatRows(m, rest);
        tau ∈ List.append(Permutation(1 + m), Permutation.insertRow(head), Permutation.concatRows(m, rest))
            by List.member_append_right;
        done
      }
  }

-- Inversion: a member of concatRows(l) sits in the row of some σ ∈ l.
theorem Permutation.concatRows_member_invert (m : Natural) (tau : Permutation(1 + m))
        (l : List(Permutation(m)))
        : tau ∈ Permutation.concatRows(m, l)
          → ∃ (sigma : Permutation(m)). sigma ∈ l
                ∧ tau ∈ Permutation.insertRow(sigma) :=
  by induction on l with IH {
    case List.empty:
        (memTau : tau ∈ Permutation.concatRows(m, List.empty(Permutation(m)))) ↦ {
            False by List.no_member_empty;
            done
          }
    case List.prepend(sigma0, rest):
        (memTau : tau ∈
            Permutation.concatRows(m, List.prepend(Permutation(m), sigma0, rest))) ↦ {
          tau ∈ Permutation.insertRow(sigma0)
              ∨ tau ∈ Permutation.concatRows(m, rest)
              by List.member_append_invert;
          done by cases {
            case tau ∈ Permutation.insertRow(sigma0) as inBlock:
                witness sigma0 with
                    And.introduction(List.member.here(Permutation(m), sigma0, rest), inBlock)
            case tau ∈ Permutation.concatRows(m, rest) as inRest: {
                choose sigma such that sigma ∈ rest
                    ∧ tau ∈ Permutation.insertRow(sigma) from IH(inRest);
                sigma ∈ rest as sigmaInRest;
                tau ∈ Permutation.insertRow(sigma) as tauInBlock;
                witness sigma with
                    And.introduction(List.member.there(Permutation(m), sigma, sigma0, rest, sigmaInRest),
                        tauInBlock)
              }
          }
        }
  }

-- concatRows preserves distinctness: each row is distinct, and rows for
-- distinct σ are disjoint (σ is recoverable from any member by `lower`).
theorem Permutation.concatRows_distinct (m : Natural) (l : List(Permutation(m)))
        : List.Distinct(Permutation(m), l)
          → List.Distinct(Permutation(1 + m), Permutation.concatRows(m, l)) :=
  by induction on l with IH {
    case List.empty:
        (distinctL : List.Distinct(Permutation(m), List.empty(Permutation(m)))) ↦
            List.Distinct.empty(Permutation(1 + m))
    case List.prepend(sigma, rest):
        (distinctL : List.Distinct(Permutation(m), List.prepend(Permutation(m), sigma, rest))) ↦ {
          ¬(sigma ∈ rest)
              by List.Distinct.head_not_member as sigmaNotInRest;
          List.Distinct(Permutation(m), rest) by List.Distinct.tail_distinct as restDistinct;
          List.Distinct(Permutation(1 + m), Permutation.concatRows(m, rest))
              by IH(restDistinct);
          (∀ (x : Permutation(1 + m)). x ∈ Permutation.insertRow(sigma)
              → ¬(x ∈ Permutation.concatRows(m, rest)))
              by (x : Permutation(1 + m))
                 (xInBlock : x ∈ Permutation.insertRow(sigma))
                 (xInRest : x ∈ Permutation.concatRows(m, rest)) ↦ {
                  Permutation.lower(x) = sigma
                      by Permutation.insertRow_member_lower as lowerXisSigma;
                  ∃ (sigmaPrime : Permutation(m)). sigmaPrime ∈ rest
                      ∧ x ∈ Permutation.insertRow(sigmaPrime)
                      by Permutation.concatRows_member_invert as sourceRowExists;
                  choose sigmaPrime such that sigmaPrime ∈ rest
                      ∧ x ∈ Permutation.insertRow(sigmaPrime)
                      from sourceRowExists;
                  x ∈ Permutation.insertRow(sigmaPrime);
                  Permutation.lower(x) = sigmaPrime
                      by Permutation.insertRow_member_lower as lowerXisPrime;
                  sigma = Permutation.lower(x) by lowerXisSigma
                     = sigmaPrime by lowerXisPrime as sigmaEqualsPrime;
                  sigma ∈ rest by substituting sigmaEqualsPrime;
                  False by sigmaNotInRest;
                  done
                };
          List.Distinct(Permutation(1 + m),
                  List.append(Permutation(1 + m), Permutation.insertRow(sigma),
                      Permutation.concatRows(m, rest)))
              by List.distinct_append;
          done
        }
  }

-- Completeness: every permutation appears. The step writes τ as the row entry
-- swap(top, τ(top)) ∘ extend(lower τ) — with lower τ in the level-m list (IH)
-- and τ(top) among the indices — and locates it in the concatenation.
theorem Permutation.allPermutations_complete (n : Natural)
        : ∀ (tau : Permutation(n)). tau ∈ Permutation.allPermutations(n) :=
  by induction on n with IH {
    case base: {
        take tau : Permutation(0);
        tau = Permutation.identity(0) by Permutation.perm_zero_is_identity as tauIsId;
        Permutation.identity(0) ∈
                  List.prepend(Permutation(0), Permutation.identity(0), List.empty(Permutation(0)))
            by List.member.here;
        tau ∈
                  List.prepend(Permutation(0), Permutation.identity(0), List.empty(Permutation(0)))
            by substituting tauIsId;
        done
      }
    case step(m): {
        take tau : Permutation(1 + m);
        Permutation.lower(tau) ∈ Permutation.allPermutations(m)
            by IH(Permutation.lower(tau));
        Permutation.apply(tau, NaturalsBelow.top(m)) ∈
                  NaturalsBelow.enumerate(1 + m)
            by NaturalsBelow.enumerate_complete;
        tau = Permutation.rowElement(Permutation.lower(tau), Permutation.apply(tau, NaturalsBelow.top(m)))
            by Permutation.decompose_top as tauIsRow;
        Permutation.rowElement(Permutation.lower(tau),
                      Permutation.apply(tau, NaturalsBelow.top(m))) ∈
                  Permutation.insertRow(Permutation.lower(tau))
            by List.map_member;
        tau ∈ Permutation.insertRow(Permutation.lower(tau))
            by substituting tauIsRow;
        tau ∈
                  Permutation.concatRows(m, Permutation.allPermutations(m))
            by Permutation.concatRows_member;
        done by substituting Permutation.allPermutations_one_plus
      }
  }

-- Distinctness: the base singleton is distinct; the step is concatRows over the
-- distinct level-m list.
theorem Permutation.allPermutations_distinct (n : Natural)
        : List.Distinct(Permutation(n), Permutation.allPermutations(n)) :=
  by induction on n with IH {
    case base: {
        ¬(Permutation.identity(0) ∈ List.empty(Permutation(0))) by List.no_member_empty;
        done by List.Distinct.prepend
      }
    case step(m): {
        List.Distinct(Permutation(1 + m), Permutation.concatRows(m, Permutation.allPermutations(m)))
            by Permutation.concatRows_distinct;
        done by substituting Permutation.allPermutations_one_plus
      }
  }

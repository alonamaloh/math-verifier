module Algebra.rank_four_weighted_d3_third_unit_c5

import Algebra.rank_four_weighted_d3_third_unit_universality

theorem Matrix.weightedD3S0R1C5_universal_of_one_three_six_converse (converse : Matrix.OneThreeSixLocalConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 0, 1, 5)) := {
  3 * 5 = 14 + 1 by ring as coefficientShape;
  3 * 5 ∸ 1 = 14 by Natural.three_times_monus_one_value(5, 14, coefficientShape) as naturalCoefficientReads;
  ((3 * 5 ∸ 1 : ℕ) : ℤ) = 3 * (5 : ℤ) - 1
      by Natural.three_times_monus_one_to_integer(5, 14, coefficientShape) as coefficientReads;
  10 = 4 * 2 + 2 by ring as tenShape;
  6 = 4 * 1 + 2 by ring as sixShape;
  1 = 4 * 0 + 1 by ring as oneShape;
  2 + (1 + 1) = 4 by ring as twoBelowFourReads;
  2 < 4 by Natural.lt_intro(2, 4, 1, twoBelowFourReads) as twoBelowFour;
  0 + (1 + 1) = 2 by ring as twoPositiveReads;
  0 < 2 by Natural.lt_intro(0, 2, 1, twoPositiveReads) as twoPositive;
  2 ≠ 0 by Natural.not_equal_of_greater_than(2, 0, twoPositive) as twoNonzero;
  1 + (1 + 2) = 4 by ring as oneBelowFourReads;
  1 < 4 by Natural.lt_intro(1, 4, 2, oneBelowFourReads) as oneBelowFour;
  0 + (1 + 0) = 1 by ring as onePositiveReads;
  0 < 1 by Natural.lt_intro(0, 1, 0, onePositiveReads) as onePositive;
  1 ≠ 0 by Natural.not_equal_of_greater_than(1, 0, onePositive) as oneNonzero;
  10 + (1 + 5) = 16 by ring as tenBelowSixteenReads;
  10 < 16 by Natural.lt_intro(10, 16, 5, tenBelowSixteenReads) as tenBelowSixteen;
  10 + (1 + 3) = 14 by ring as tenBelowFourteenReads;
  10 < 14 by Natural.lt_intro(10, 14, 3, tenBelowFourteenReads) as tenBelowFourteen;
  10 ≠ 14 by Natural.not_equal_of_less_than(10, 14, tenBelowFourteen) as tenNotFourteen;
  6 + (1 + 9) = 16 by ring as sixBelowSixteenReads;
  6 < 16 by Natural.lt_intro(6, 16, 9, sixBelowSixteenReads) as sixBelowSixteen;
  6 + (1 + 7) = 14 by ring as sixBelowFourteenReads;
  6 < 14 by Natural.lt_intro(6, 14, 7, sixBelowFourteenReads) as sixBelowFourteen;
  6 ≠ 14 by Natural.not_equal_of_less_than(6, 14, sixBelowFourteen) as sixNotFourteen;
  1 + (1 + 14) = 16 by ring as oneBelowSixteenReads;
  1 < 16 by Natural.lt_intro(1, 16, 14, oneBelowSixteenReads) as oneBelowSixteen;
  1 + (1 + 12) = 14 by ring as oneBelowFourteenReads;
  1 < 14 by Natural.lt_intro(1, 14, 12, oneBelowFourteenReads) as oneBelowFourteen;
  1 ≠ 14 by Natural.not_equal_of_less_than(1, 14, oneBelowFourteen) as oneNotFourteen;
  4 ^ 2
     = 4 ^ (1 + 1)
     = 4 * 4 ^ 1 by Natural.power_one_plus(4, 1)
     = 4 * 4 by substituting Natural.power_one(4)
     = 16 by ring
  as fourSquaredReads;
  Matrix.OneThreeSixTripleTargetCover(5) by {
    take m : ℕ;
    suppose m ≥ 1;
    Natural.IsOneThreeSixFourObstruction(3 * m) ∨ ¬(Natural.IsOneThreeSixFourObstruction(3 * m))
        by Logic.excluded_middle(Natural.IsOneThreeSixFourObstruction(3 * m)) as obstructionDecision;
    ¬(Natural.IsOneThreeSixFourObstruction(3 * m)) ∨ Natural.IsOneThreeSixFourObstruction(3 * m)
        by Or.swap(obstructionDecision);
    done by cases {
      case ¬(Natural.IsOneThreeSixFourObstruction(3 * m)) as admissible: {
        3 * m + 0 * 0 * (3 * 5 ∸ 1) = 3 * m by ring as valueReads;
        Matrix.Represents(Matrix.oneThreeSixForm, ((3 * m : ℕ) : ℤ))
            by Matrix.oneThreeSixCover_witness_of_local_converse(
                converse, 5, m, 3 * m, 0, admissible, valueReads, coefficientReads) as represented;
        witness 3 * m with witness 0 with And.introduction(represented, valueReads)
      }
      case Natural.IsOneThreeSixFourObstruction(3 * m) as obstruction: {
        choose exponent : ℕ, b : ℕ such that 3 * m = 4 ^ exponent * (16 * b + 14)
            as obstructionReads from obstruction;
        exponent = 0 ∨ ∃ (predecessor : ℕ). exponent = 1 + predecessor by Natural.zero_or_one_plus;
        done by cases {
          case exponent = 0 as exponentZero: {
            3 * m
               = 4 ^ exponent * (16 * b + 14) by obstructionReads
               = 4 ^ 0 * (16 * b + 14) by substituting exponentZero
               = 16 * b + 14 by substituting Natural.power_zero(4)
            as unscaledReads;
            choose bPredecessor : ℕ such that b = 1 + bPredecessor
                as bReads from Natural.positive_inner_parameter_of_unscaled_one_three_six_obstruction(m, b, unscaledReads);
            bPredecessor = 0 ∨ ∃ (next : ℕ). bPredecessor = 1 + next by Natural.zero_or_one_plus;
            done by cases {
              case bPredecessor = 0 as bPredecessorZero: {
                b = 1 by { b = 1 + bPredecessor by bReads = 1 + 0 by substituting bPredecessorZero = 1 by ring; done }
                    as bIsOne;
                let residual : ℕ := 4 ^ 2 * (16 * 0 + 1);
                ¬(Natural.IsOneThreeSixFourObstruction(residual))
                    by Natural.four_power_times_nonzero_mod_four_core_not_one_three_six_four_obstruction(
                        2, 0, 1, 0, 1, oneShape,
                        oneBelowFour, oneNonzero, oneBelowSixteen, oneNotFourteen) as residualAdmissible;
                residual + 1 * 1 * (3 * 5 ∸ 1)
                   = 4 ^ 2 * (16 * 0 + 1) + 14 by substituting naturalCoefficientReads
                   = 16 * 1 + 14 by substituting fourSquaredReads
                   = 16 * b + 14 by substituting Equality.symmetry(bIsOne)
                   = 3 * m by Equality.symmetry(unscaledReads)
                as valueReads;
                Matrix.Represents(Matrix.oneThreeSixForm, (residual : ℤ))
                    by Matrix.oneThreeSixCover_witness_of_local_converse(
                        converse, 5, m, residual, 1, residualAdmissible, valueReads, coefficientReads) as represented;
                witness residual with witness 1 with And.introduction(represented, valueReads)
              }
              case ∃ (next : ℕ). bPredecessor = 1 + next: {
                choose next : ℕ such that bPredecessor = 1 + next as nextReads;
                next = 0 ∨ ∃ (q : ℕ). next = 1 + q by Natural.zero_or_one_plus;
                done by cases {
                  case next = 0 as nextZero: {
                    b = 2 by {
                      b = 1 + bPredecessor by bReads
                       = 1 + (1 + next) by substituting nextReads
                       = 1 + (1 + 0) by substituting nextZero
                       = 2 by ring;
                      done
                    } as bIsTwo;
                    3 * m + 0
                       = 16 * b + 14 by unscaledReads
                       = 16 * 2 + 14 by substituting bIsTwo
                       = 3 * 15 + 1 by ring
                    as impossible;
                    False by Natural.distinct_affine_residues_not_equal(
                        3, 0, 1, m, 15, done, done, done, impossible);
                    done
                  }
                  case ∃ (q : ℕ). next = 1 + q: {
                    choose q : ℕ such that next = 1 + q as qReads;
                    b = 3 + q by {
                      b = 1 + bPredecessor by bReads
                       = 1 + (1 + next) by substituting nextReads
                       = 1 + (1 + (1 + q)) by substituting qReads
                       = 3 + q by ring;
                      done
                    } as bReadsFromThree;
                    let residual : ℕ := 16 * q + 6;
                    4 ^ 0 * (16 * q + 6) = residual by substituting Natural.power_zero(4) as residualShape;
                    ¬(Natural.IsOneThreeSixFourObstruction(residual)) by {
                      suppose Natural.IsOneThreeSixFourObstruction(residual) as residualObstruction;
                      Natural.IsOneThreeSixFourObstruction(4 ^ 0 * (16 * q + 6))
                          by substituting Equality.symmetry(residualShape) as transformedObstruction;
                      done by Natural.four_power_times_nonzero_mod_four_core_not_one_three_six_four_obstruction(
                          0, q, 6, 1, 2, sixShape,
                          twoBelowFour, twoNonzero, sixBelowSixteen, sixNotFourteen)(transformedObstruction)
                    } as residualAdmissible;
                    residual + 2 * 2 * (3 * 5 ∸ 1)
                       = 16 * q + 6 + 2 * 2 * 14 by substituting naturalCoefficientReads
                       = 16 * (3 + q) + 14 by ring
                       = 16 * b + 14 by substituting Equality.symmetry(bReadsFromThree)
                       = 3 * m by Equality.symmetry(unscaledReads)
                    as valueReads;
                    Matrix.Represents(Matrix.oneThreeSixForm, (residual : ℤ))
                        by Matrix.oneThreeSixCover_witness_of_local_converse(
                            converse, 5, m, residual, 2, residualAdmissible, valueReads, coefficientReads) as represented;
                    witness residual with witness 2 with And.introduction(represented, valueReads)
                  }
                }
              }
            }
          }
          case ∃ (predecessor : ℕ). exponent = 1 + predecessor: {
            choose predecessor : ℕ such that exponent = 1 + predecessor as exponentReads;
            let residual : ℕ := 4 ^ predecessor * (64 * b + 42);
            let w : ℕ := 2 ^ predecessor;
            4 ^ predecessor * (64 * b + 42) = 4 ^ predecessor * (16 * (4 * b + 2) + 10) by ring
                as residualShape;
            ¬(Natural.IsOneThreeSixFourObstruction(residual)) by {
              suppose Natural.IsOneThreeSixFourObstruction(residual) as residualObstruction;
              Natural.IsOneThreeSixFourObstruction(4 ^ predecessor * (16 * (4 * b + 2) + 10))
                  by substituting residualShape as transformedObstruction;
              done by Natural.four_power_times_nonzero_mod_four_core_not_one_three_six_four_obstruction(
                  predecessor, 4 * b + 2, 10, 2, 2, tenShape,
                  twoBelowFour, twoNonzero, tenBelowSixteen, tenNotFourteen)(transformedObstruction)
            } as residualAdmissible;
            residual + w * w * (3 * 5 ∸ 1)
               = 4 ^ predecessor * (64 * b + 42)
                 + (2 ^ predecessor * 2 ^ predecessor) * 14 by substituting naturalCoefficientReads
               = 4 ^ predecessor * (64 * b + 42) + 4 ^ predecessor * 14
                   by Equality.congruence(
                       (candidate : ℕ) ↦ 4 ^ predecessor * (64 * b + 42) + candidate * 14,
                       2 ^ predecessor * 2 ^ predecessor, 4 ^ predecessor,
                       Natural.two_power_square_is_four_power(predecessor))
               = 4 ^ predecessor * (4 * (16 * b + 14)) by ring
               = (4 * 4 ^ predecessor) * (16 * b + 14) by ring
               = 4 ^ (1 + predecessor) * (16 * b + 14)
                   by substituting Equality.symmetry(Natural.power_one_plus(4, predecessor))
               = 4 ^ exponent * (16 * b + 14) by substituting Equality.symmetry(exponentReads)
               = 3 * m by Equality.symmetry(obstructionReads)
            as valueReads;
            Matrix.Represents(Matrix.oneThreeSixForm, (residual : ℤ))
                by Matrix.oneThreeSixCover_witness_of_local_converse(
                    converse, 5, m, residual, w, residualAdmissible, valueReads, coefficientReads) as represented;
            witness residual with witness w with And.introduction(represented, valueReads)
          }
        }
      }
    }
  } as cover;
  done by Matrix.weightedD3ThirdUnit_universal_of_cover(5, coefficientReads, cover)
}

-- Algebra/basis_pruning.math
--
-- Every finitely generated vector space has a finite basis: prune a finite
-- spanning family down to an independent one by dropping a redundant vector
-- (one that lies in the span of the others) and repeating. Choice-free.
--
-- This file builds the reusable reindexing bricks first — an arbitrary-
-- selection position bump, a span-combination lemma keyed only on the used
-- indices, and the order-preserving "skip one index" map on `NaturalsBelow`
-- (the finite-family analogue of `Function.updateAt`, requested by the plan
-- as a reusable helper) — and then the pruning induction on top of them.

module Algebra.basis_pruning

import axioms
import Logic.basics
import Logic.exists
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.division
import Natural.monus
import Natural.classical_decidable
import Set.subtype
import Set.finite
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.aggregation
import Algebra.ring
import Algebra.ring_lemmas
import Algebra.field
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.field_bundle
import Algebra.vector_space
import Algebra.vector_space_lemmas
import Algebra.linear_combination
import Algebra.span
import Algebra.exchange_lemma
import Algebra.finite_dimensional

-- ----------------------------------------------------------------------
-- Bumping the coefficient at one POSITION of a combination (arbitrary
-- selection). Raising `coefficients(pos)` by `e` adds `e • family(selection(pos))`
-- to the combination — the general-selection sibling of
-- `standardCombination_bump` (identity selection).
theorem VectorSpace.linearCombination_bump_position {f : Field} {V : VectorSpace(f)}
        {I : Type(0)} (family : I → VectorSpace.carrier(V))
        (coefficients : Natural → Field.carrier(f)) (e : Field.carrier(f))
        (selection : Natural → I) (pos n : Natural) (posBelow : pos < n)
        : VectorSpace.linearCombination(family,
              Function.updateAt(coefficients, pos, coefficients(pos) + e), selection, n)
          = VectorSpace.linearCombination(family, coefficients, selection, n)
            + e • family(selection(pos)) :=
  by induction on n with IH {
    case base: {
        ¬(pos < 0) by Natural.not_less_than_zero;
        done
      }
    case step(q): {
        pos < q ∨ pos = q by Natural.le_of_lt_one_plus;
        done by cases {
          case pos < q as posLtQ: {
              q ≠ pos by Natural.not_equal_of_greater_than;
              Function.updateAt(coefficients, pos, coefficients(pos) + e)(q) = coefficients(q)
                  by Function.updateAt_off as bumpAtQ;
              VectorSpace.linearCombination(family,
                    Function.updateAt(coefficients, pos, coefficients(pos) + e), selection, 1 + q)
                 = VectorSpace.linearCombination(family,
                       Function.updateAt(coefficients, pos, coefficients(pos) + e), selection, q)
                   + Function.updateAt(coefficients, pos, coefficients(pos) + e)(q) • family(selection(q))
                       by VectorSpace.linearCombination_add_one
                 = (VectorSpace.linearCombination(family, coefficients, selection, q)
                    + e • family(selection(pos)))
                   + Function.updateAt(coefficients, pos, coefficients(pos) + e)(q) • family(selection(q))
                       by IH
                 = (VectorSpace.linearCombination(family, coefficients, selection, q)
                    + e • family(selection(pos)))
                   + coefficients(q) • family(selection(q))
                       by substituting bumpAtQ
                 = VectorSpace.linearCombination(family, coefficients, selection, q)
                   + (e • family(selection(pos)) + coefficients(q) • family(selection(q)))
                 = VectorSpace.linearCombination(family, coefficients, selection, q)
                   + (coefficients(q) • family(selection(q)) + e • family(selection(pos)))
                       by VectorSpace.add_commutative
                 = (VectorSpace.linearCombination(family, coefficients, selection, q)
                    + coefficients(q) • family(selection(q)))
                   + e • family(selection(pos))
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                   + e • family(selection(pos))
                       by VectorSpace.linearCombination_add_one
            }
          case pos = q as posEqQ: {
              q = pos by posEqQ as qEqPos;
              Function.updateAt(coefficients, pos, coefficients(pos) + e)(q)
                 = Function.updateAt(coefficients, pos, coefficients(pos) + e)(pos)   by substituting qEqPos
                 = coefficients(pos) + e                                              by Function.updateAt_at
                 = coefficients(q) + e                                                by substituting posEqQ
                 as bumpAtQ;
              ∀ (i : Natural). i < q →
                  Function.updateAt(coefficients, pos, coefficients(pos) + e)(i) • family(selection(i))
                  = coefficients(i) • family(selection(i))
                by {
                  take i : Natural;
                  suppose i < q as iLtQ;
                  i < pos by substituting posEqQ;
                  i ≠ pos by Natural.not_equal_of_less_than;
                  Function.updateAt(coefficients, pos, coefficients(pos) + e)(i) = coefficients(i)
                      by Function.updateAt_off as bumpAtI;
                  done by substituting bumpAtI
                };
              VectorSpace.linearCombination(family,
                    Function.updateAt(coefficients, pos, coefficients(pos) + e), selection, q)
                 = VectorSpace.linearCombination(family, coefficients, selection, q)
                     by VectorSpace.linearCombination_congruence as reduceBelow;
              VectorSpace.linearCombination(family,
                    Function.updateAt(coefficients, pos, coefficients(pos) + e), selection, 1 + q)
                 = VectorSpace.linearCombination(family,
                       Function.updateAt(coefficients, pos, coefficients(pos) + e), selection, q)
                   + Function.updateAt(coefficients, pos, coefficients(pos) + e)(q) • family(selection(q))
                       by VectorSpace.linearCombination_add_one
                 = VectorSpace.linearCombination(family, coefficients, selection, q)
                   + Function.updateAt(coefficients, pos, coefficients(pos) + e)(q) • family(selection(q))
                       by substituting reduceBelow
                 = VectorSpace.linearCombination(family, coefficients, selection, q)
                   + (coefficients(q) + e) • family(selection(q))
                       by substituting bumpAtQ
                 = VectorSpace.linearCombination(family, coefficients, selection, q)
                   + (coefficients(q) • family(selection(q)) + e • family(selection(q)))
                       by VectorSpace.scale_scalar_add
                 = (VectorSpace.linearCombination(family, coefficients, selection, q)
                    + coefficients(q) • family(selection(q)))
                   + e • family(selection(q))
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                   + e • family(selection(q))
                       by VectorSpace.linearCombination_add_one
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                   + e • family(selection(pos))
                       by substituting posEqQ
            }
        }
      }
  }

-- ----------------------------------------------------------------------
-- A combination lies in a span as soon as every SELECTED member does —
-- the used-indices refinement of `InSpanOf.of_combination` (which asks for
-- every inner index). The proof only ever touches `inner(selection(i))` for
-- `i < count`, so that is all it needs.
theorem VectorSpace.InSpanOf.of_combination_selected {f : Field} {V : VectorSpace(f)}
        {I J : Type(0)}
        (inner : I → VectorSpace.carrier(V)) (outer : J → VectorSpace.carrier(V))
        (outerInhabitant : J)
        (coefficients : Natural → Field.carrier(f)) (selection : Natural → I) (count : Natural)
        (selectedInSpan : ∀ (i : Natural). i < count →
            VectorSpace.InSpanOf(outer, inner(selection(i))))
        : VectorSpace.InSpanOf(outer,
              VectorSpace.linearCombination(inner, coefficients, selection, count)) :=
  by induction on count with IH {
    case base: {
        VectorSpace.InSpanOf(outer, outer(outerInhabitant)) by VectorSpace.InSpanOf.member;
        VectorSpace.InSpanOf(outer, Field.zero(f) • outer(outerInhabitant))
            by VectorSpace.InSpanOf.scale;
        VectorSpace.linearCombination(inner, coefficients, selection, 0)
           = VectorSpace.zero(V)
           = Field.zero(f) • outer(outerInhabitant)
               by VectorSpace.zero_scale as emptyIsZero;
        done by substituting emptyIsZero
      }
    case step(m): {
        ∀ (i : Natural). i < m → VectorSpace.InSpanOf(outer, inner(selection(i)))
          by { take i : Natural; suppose i < m as iLtM; i < 1 + m; done by selectedInSpan };
        VectorSpace.InSpanOf(outer, VectorSpace.linearCombination(inner, coefficients, selection, m))
            by IH;
        m < 1 + m;
        VectorSpace.InSpanOf(outer, inner(selection(m))) by selectedInSpan;
        VectorSpace.InSpanOf(outer, coefficients(m) • inner(selection(m)))
            by VectorSpace.InSpanOf.scale;
        VectorSpace.InSpanOf(outer,
            VectorSpace.linearCombination(inner, coefficients, selection, m)
              + coefficients(m) • inner(selection(m)))
            by VectorSpace.InSpanOf.add;
        VectorSpace.linearCombination(inner, coefficients, selection, 1 + m)
           = VectorSpace.linearCombination(inner, coefficients, selection, m)
             + coefficients(m) • inner(selection(m))
               by VectorSpace.linearCombination_add_one as peelLast;
        done by substituting peelLast
      }
  }

-- ----------------------------------------------------------------------
-- Skipping one index. `NaturalsBelow.skip(jv)` is the order-preserving
-- injection `NaturalsBelow(count) → NaturalsBelow(1 + count)` that misses
-- exactly the index with value `jv`: it is the identity below `jv` and
-- shifts up by one at or above it. `skipInverse` is the partial inverse.

definition NaturalsBelow.skipValue (jv i : Natural) : Natural :=
  if i < jv then i else 1 + i

theorem NaturalsBelow.skipValue_below (jv i : Natural) (below : i < jv)
        : NaturalsBelow.skipValue(jv, i) = i :=
  done by Logic.if_positive

theorem NaturalsBelow.skipValue_above (jv i : Natural) (notBelow : ¬(i < jv))
        : NaturalsBelow.skipValue(jv, i) = 1 + i :=
  done by Logic.if_negative

definition NaturalsBelow.skipInverseValue (jv x : Natural) : Natural :=
  if x < jv then x else Natural.monus(x, 1)

theorem NaturalsBelow.skipInverseValue_below (jv x : Natural) (below : x < jv)
        : NaturalsBelow.skipInverseValue(jv, x) = x :=
  done by Logic.if_positive

theorem NaturalsBelow.skipInverseValue_above (jv x : Natural) (notBelow : ¬(x < jv))
        : NaturalsBelow.skipInverseValue(jv, x) = Natural.monus(x, 1) :=
  done by Logic.if_negative

-- `skipValue(jv, i) < 1 + count` when `i < count`: the value is at most `1 + i`.
theorem NaturalsBelow.skipValue_bound {count : Natural} (jv : Natural) (i : NaturalsBelow(count))
        : NaturalsBelow.skipValue(jv, NaturalsBelow.value(i)) < 1 + count := {
  NaturalsBelow.value(i) < count by NaturalsBelow.below as valueBelow;
  done by cases {
    case NaturalsBelow.value(i) < jv as below: {
        NaturalsBelow.skipValue(jv, NaturalsBelow.value(i)) = NaturalsBelow.value(i)
            by NaturalsBelow.skipValue_below as sv;
        NaturalsBelow.value(i) < count < 1 + count;
        done by substituting sv
      }
    otherwise as notBelow: {
        NaturalsBelow.skipValue(jv, NaturalsBelow.value(i)) = 1 + NaturalsBelow.value(i)
            by NaturalsBelow.skipValue_above as sv;
        1 + NaturalsBelow.value(i) ≤ count by Natural.successor_le_of_lt;
        1 + NaturalsBelow.value(i) < 1 + count;
        done by substituting sv
      }
  }
}

definition NaturalsBelow.skip {count : Natural} (jv : Natural) (i : NaturalsBelow(count))
        : NaturalsBelow(1 + count) :=
  NaturalsBelow.make(NaturalsBelow.skipValue(jv, NaturalsBelow.value(i)),
                     NaturalsBelow.skipValue_bound(jv, i))

theorem NaturalsBelow.skip_value {count : Natural} (jv : Natural) (i : NaturalsBelow(count))
        : NaturalsBelow.value(NaturalsBelow.skip(jv, i))
          = NaturalsBelow.skipValue(jv, NaturalsBelow.value(i)) :=
  done

-- The skipped index never has value `jv` (`skip` misses exactly that slot).
theorem NaturalsBelow.skip_avoids {count : Natural} (jv : Natural) (i : NaturalsBelow(count))
        : NaturalsBelow.value(NaturalsBelow.skip(jv, i)) ≠ jv := {
  NaturalsBelow.value(i) < jv ∨ jv ≤ NaturalsBelow.value(i) by Natural.lt_or_le;
  done by cases {
    case NaturalsBelow.value(i) < jv as below: {
        NaturalsBelow.value(NaturalsBelow.skip(jv, i)) = NaturalsBelow.value(i)
            by NaturalsBelow.skipValue_below;
        NaturalsBelow.value(i) ≠ jv by Natural.not_equal_of_less_than;
        done
      }
    case jv ≤ NaturalsBelow.value(i) as ge: {
        ¬(NaturalsBelow.value(i) < jv)
            by { suppose NaturalsBelow.value(i) < jv as bad;
                 NaturalsBelow.value(i) < jv ≤ NaturalsBelow.value(i); done };
        NaturalsBelow.value(NaturalsBelow.skip(jv, i)) = 1 + NaturalsBelow.value(i)
            by NaturalsBelow.skipValue_above;
        jv ≤ NaturalsBelow.value(i) < 1 + NaturalsBelow.value(i)
             = NaturalsBelow.value(NaturalsBelow.skip(jv, i));
        jv < NaturalsBelow.value(NaturalsBelow.skip(jv, i));
        done by Natural.not_equal_of_greater_than
      }
  }
}

-- `monus(1 + i, 1) = i`: peel a 1 off both sides.
theorem NaturalsBelow.monus_one_plus_one (i : Natural) : Natural.monus(1 + i, 1) = i :=
  Natural.monus(1 + i, 1)
     = Natural.monus(1 + i, 1 + 0)
     = Natural.monus(i, 0)          by Natural.monus_one_plus_one_plus
     = i                            by Natural.monus_zero

-- `skipInverse` undoes `skip`: the round trip on values.
theorem NaturalsBelow.skipInverse_skipValue (jv i : Natural)
        : NaturalsBelow.skipInverseValue(jv, NaturalsBelow.skipValue(jv, i)) = i := {
  i < jv ∨ jv ≤ i by Natural.lt_or_le;
  done by cases {
    case i < jv as below: {
        NaturalsBelow.skipValue(jv, i) = i by NaturalsBelow.skipValue_below as sv;
        NaturalsBelow.skipInverseValue(jv, i) = i by NaturalsBelow.skipInverseValue_below as siv;
        NaturalsBelow.skipInverseValue(jv, NaturalsBelow.skipValue(jv, i))
           = NaturalsBelow.skipInverseValue(jv, i)   by substituting sv
           = i                                        by siv
      }
    otherwise as notBelow: {
        ¬(i < jv) by notBelow;
        NaturalsBelow.skipValue(jv, i) = 1 + i by NaturalsBelow.skipValue_above as sv;
        ¬(1 + i < jv) by { suppose 1 + i < jv as bad; jv ≤ i < 1 + i < jv; done };
        NaturalsBelow.skipInverseValue(jv, 1 + i) = Natural.monus(1 + i, 1)
            by NaturalsBelow.skipInverseValue_above as siv;
        NaturalsBelow.skipInverseValue(jv, NaturalsBelow.skipValue(jv, i))
           = NaturalsBelow.skipInverseValue(jv, 1 + i)   by substituting sv
           = Natural.monus(1 + i, 1)                     by siv
           = i                                            by NaturalsBelow.monus_one_plus_one
      }
  }
}

-- `skipInverseValue(jv, x) < count` for an in-range `x ≠ jv`: below `jv` the
-- value is unchanged (< jv ≤ count), at or above it drops by one.
theorem NaturalsBelow.skipInverseValue_bound (count jv x : Natural)
        (xBound : x < 1 + count) (jvBound : jv ≤ count) (ne : x ≠ jv)
        : NaturalsBelow.skipInverseValue(jv, x) < count := {
  x < jv ∨ jv ≤ x by Natural.lt_or_le;
  done by cases {
    case x < jv as below: {
        NaturalsBelow.skipInverseValue(jv, x) = x by NaturalsBelow.skipInverseValue_below as siv;
        x < jv ≤ count;
        done by substituting siv
      }
    case jv ≤ x as ge: {
        ¬(jv = x) by { suppose jv = x as e; x = jv by e; done };
        jv < x by Natural.lt_of_le_of_ne;
        0 < x by { 0 ≤ jv < x; done };
        ¬(x = 0) by Natural.not_equal_of_greater_than;
        x = 0 ∨ ∃ (p : Natural). x = 1 + p by Natural.zero_or_one_plus;
        ∃ (p : Natural). x = 1 + p
            by cases {
                 case x = 0 as xZero: { False; done }
                 case ∃ (p : Natural). x = 1 + p as hasPred: { done }
               } as predExists;
        choose p such that x = 1 + p from predExists;
        x = 1 + p as xIsSucc;
        jv ≤ p by { jv < x = 1 + p; done by Natural.le_of_lt_one_plus };
        ¬(x < jv) by { suppose x < jv as bad; jv ≤ x < jv; done };
        NaturalsBelow.skipInverseValue(jv, x) = Natural.monus(x, 1)
            by NaturalsBelow.skipInverseValue_above as siv;
        Natural.monus(x, 1) = Natural.monus(1 + p, 1)   by substituting xIsSucc
                            = p                          by NaturalsBelow.monus_one_plus_one
            as monusIsP;
        1 + p < 1 + count by substituting xIsSucc;
        p < count by {
          choose c such that (1 + p) + (1 + c) = 1 + count from Natural.lt_elim;
          1 + (p + (1 + c)) = 1 + count
              by { 1 + (p + (1 + c)) = (1 + p) + (1 + c) = 1 + count; done };
          p + (1 + c) = count by Natural.add_cancel_left;
          done by Natural.lt_intro
        };
        NaturalsBelow.skipInverseValue(jv, x) = Natural.monus(x, 1)   by siv
                                              = p                      by monusIsP
                                              < count;
        done
      }
  }
}

-- `skip` undoes `skipInverse` off the removed slot: the other round trip.
theorem NaturalsBelow.skipValue_skipInverse (jv x : Natural) (ne : x ≠ jv)
        : NaturalsBelow.skipValue(jv, NaturalsBelow.skipInverseValue(jv, x)) = x := {
  x < jv ∨ jv ≤ x by Natural.lt_or_le;
  done by cases {
    case x < jv as below: {
        NaturalsBelow.skipInverseValue(jv, x) = x by NaturalsBelow.skipInverseValue_below as siv;
        NaturalsBelow.skipValue(jv, x) = x by NaturalsBelow.skipValue_below as sv;
        NaturalsBelow.skipValue(jv, NaturalsBelow.skipInverseValue(jv, x))
           = NaturalsBelow.skipValue(jv, x)   by substituting siv
           = x                                 by sv
      }
    case jv ≤ x as ge: {
        ¬(jv = x) by { suppose jv = x as e; x = jv by e; done };
        jv < x by Natural.lt_of_le_of_ne;
        0 < x by { 0 ≤ jv < x; done };
        ¬(x = 0) by Natural.not_equal_of_greater_than;
        x = 0 ∨ ∃ (p : Natural). x = 1 + p by Natural.zero_or_one_plus;
        ∃ (p : Natural). x = 1 + p
            by cases {
                 case x = 0 as xZero: { False; done }
                 case ∃ (p : Natural). x = 1 + p as hasPred: { done }
               } as predExists;
        choose p such that x = 1 + p from predExists;
        x = 1 + p as xIsSucc;
        jv ≤ p by { jv < x = 1 + p; done by Natural.le_of_lt_one_plus };
        ¬(p < jv) by { suppose p < jv as bad; jv ≤ p < jv; done };
        ¬(x < jv) by { suppose x < jv as bad; jv ≤ x < jv; done };
        NaturalsBelow.skipInverseValue(jv, x) = Natural.monus(x, 1)
            by NaturalsBelow.skipInverseValue_above as siv;
        Natural.monus(x, 1) = Natural.monus(1 + p, 1)   by substituting xIsSucc
                            = p                          by NaturalsBelow.monus_one_plus_one
            as monusIsP;
        NaturalsBelow.skipValue(jv, p) = 1 + p by NaturalsBelow.skipValue_above as svp;
        NaturalsBelow.skipValue(jv, NaturalsBelow.skipInverseValue(jv, x))
           = NaturalsBelow.skipValue(jv, Natural.monus(x, 1))   by substituting siv
           = NaturalsBelow.skipValue(jv, p)                      by substituting monusIsP
           = 1 + p                                                by svp
           = x                                                    by xIsSucc
      }
  }
}

-- `skip(jv)` hits every index whose value is not `jv`: surjective onto the
-- complement of the removed slot.
theorem NaturalsBelow.skip_surjective {count : Natural} (jv : Natural) (jvBound : jv ≤ count)
        (index : NaturalsBelow(1 + count)) (ne : NaturalsBelow.value(index) ≠ jv)
        : ∃ (i : NaturalsBelow(count)). NaturalsBelow.skip(jv, i) = index := {
  NaturalsBelow.value(index) < 1 + count by NaturalsBelow.below as vBound;
  NaturalsBelow.skipInverseValue(jv, NaturalsBelow.value(index)) < count
      by NaturalsBelow.skipInverseValue_bound as ivBound;
  NaturalsBelow.skipValue(jv, NaturalsBelow.skipInverseValue(jv, NaturalsBelow.value(index)))
      = NaturalsBelow.value(index) by NaturalsBelow.skipValue_skipInverse as round;
  NaturalsBelow.value(NaturalsBelow.skip(jv,
        NaturalsBelow.make(NaturalsBelow.skipInverseValue(jv, NaturalsBelow.value(index)), ivBound)))
      = NaturalsBelow.value(index) by round;
  NaturalsBelow.skip(jv,
        NaturalsBelow.make(NaturalsBelow.skipInverseValue(jv, NaturalsBelow.value(index)), ivBound))
      = index by NaturalsBelow.equal_of_value as skipEq;
  witness NaturalsBelow.make(NaturalsBelow.skipInverseValue(jv, NaturalsBelow.value(index)), ivBound)
      with skipEq
}

-- ----------------------------------------------------------------------
-- Dropping a redundant vector. `dropIndex(g, j)` is the family with slot `j`
-- removed (the other `count` vectors, order-preserved via `skip`).

theorem Field.negate_nonzero (f : Field) (a : Field.carrier(f)) (nonzero : a ≠ Field.zero(f))
        : Field.negate(a) ≠ Field.zero(f) := {
  suppose Field.negate(a) = Field.zero(f) as negZero;
  a = a + Field.zero(f)
    = a + Field.negate(a)   by substituting negZero
    = Field.zero(f)          by Field.add_negate_right;
  a ≠ Field.zero(f) by nonzero;
  done
}

definition VectorSpace.dropIndex {f : Field} {V : VectorSpace(f)} {count : Natural}
        (g : NaturalsBelow(1 + count) → VectorSpace.carrier(V)) (j : NaturalsBelow(1 + count))
        : NaturalsBelow(count) → VectorSpace.carrier(V) :=
  (i : NaturalsBelow(count)) ↦ g(NaturalsBelow.skip(NaturalsBelow.value(j), i))

-- The redundancy: a vanishing combination with a nonzero coefficient at
-- position `i0` exhibits `g(σ(i0))` as a combination of the OTHER vectors
-- (those with index ≠ σ(i0)), i.e. it lies in `span(dropIndex(g, σ(i0)))`.
-- Isolate the term by bumping its coefficient to zero (position bump), then
-- solve for it by dividing out the nonzero scalar (`scale_cancel`).
theorem VectorSpace.dropIndex_redundant {f : Field} {V : VectorSpace(f)} {count : Natural}
        (g : NaturalsBelow(1 + count) → VectorSpace.carrier(V)) (countPos : 0 < count)
        (len : Natural) (selection : Natural → NaturalsBelow(1 + count))
        (coefficients : Natural → Field.carrier(f))
        (injective : ∀ (a b : Natural). a < len → b < len → selection(a) = selection(b) → a = b)
        (vanishes : VectorSpace.linearCombination(g, coefficients, selection, len) = VectorSpace.zero(V))
        (i0 : Natural) (i0Below : i0 < len) (nonzero : coefficients(i0) ≠ Field.zero(f))
        : VectorSpace.InSpanOf(VectorSpace.dropIndex(g, selection(i0)), g(selection(i0))) := {
  NaturalsBelow.value(selection(i0)) ≤ count
      by { NaturalsBelow.value(selection(i0)) < 1 + count by NaturalsBelow.below;
           done by Natural.le_of_lt_one_plus } as jvBound;
  NaturalsBelow.value(NaturalsBelow.skip(NaturalsBelow.value(selection(i0)),
        NaturalsBelow.make(0, countPos))) ≠ NaturalsBelow.value(selection(i0))
      by NaturalsBelow.skip_avoids as redirectAvoids;

  -- The coefficients with slot i0 zeroed, and the selection redirected there
  -- to an index that is not selection(i0).
  Field.negate(coefficients(i0)) ≠ Field.zero(f) by Field.negate_nonzero as negNonzero;
  coefficients(i0) + Field.negate(coefficients(i0)) = Field.zero(f)
      by Field.add_negate_right as sumZero;

  -- Position bump: raising slot i0 by -c(i0) zeroes it and adds -c(i0)·g(j).
  VectorSpace.linearCombination(g,
        Function.updateAt(coefficients, i0, coefficients(i0) + Field.negate(coefficients(i0))),
        selection, len)
     = VectorSpace.linearCombination(g, coefficients, selection, len)
       + Field.negate(coefficients(i0)) • g(selection(i0))
           by VectorSpace.linearCombination_bump_position
     = VectorSpace.zero(V) + Field.negate(coefficients(i0)) • g(selection(i0))
           by substituting vanishes
     = Field.negate(coefficients(i0)) • g(selection(i0))
     as bumped;

  -- Every term of the zeroed-slot combination, read through the redirected
  -- selection, is a member of dropIndex(g, selection(i0)).
  ∀ (i : Natural). i < len →
      VectorSpace.InSpanOf(VectorSpace.dropIndex(g, selection(i0)),
          g(Function.updateAt(selection, i0,
                NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos)))(i)))
    by {
      take i : Natural;
      suppose i < len as iBelow;
      NaturalsBelow.value(Function.updateAt(selection, i0,
            NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos)))(i))
          ≠ NaturalsBelow.value(selection(i0))
        by {
          i = i0 ∨ i ≠ i0 by Logic.excluded_middle;
          done by cases {
            case i = i0 as atI0: {
                Function.updateAt(selection, i0,
                      NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos)))(i)
                   = Function.updateAt(selection, i0,
                         NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos)))(i0)
                         by substituting atI0
                   = NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos))
                         by Function.updateAt_at
                   as redirectHere;
                done by substituting redirectHere
              }
            case i ≠ i0 as offI0: {
                Function.updateAt(selection, i0,
                      NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos)))(i)
                   = selection(i) by Function.updateAt_off as selHere;
                selection(i) ≠ selection(i0)
                    by { suppose selection(i) = selection(i0) as e; i = i0 by injective; done };
                NaturalsBelow.value(selection(i)) ≠ NaturalsBelow.value(selection(i0))
                    by { suppose NaturalsBelow.value(selection(i)) = NaturalsBelow.value(selection(i0)) as ve;
                         selection(i) = selection(i0) by NaturalsBelow.equal_of_value; done };
                done by substituting selHere
              }
          }
        } as valueNeJ;
      ∃ (i2 : NaturalsBelow(count)). NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), i2)
          = Function.updateAt(selection, i0,
                NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos)))(i)
          by NaturalsBelow.skip_surjective as preimageExists;
      choose i2 such that NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), i2)
          = Function.updateAt(selection, i0,
                NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos)))(i)
          from preimageExists;
      NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), i2)
          = Function.updateAt(selection, i0,
                NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos)))(i)
          as skipEqSel;
      VectorSpace.InSpanOf(VectorSpace.dropIndex(g, selection(i0)),
            VectorSpace.dropIndex(g, selection(i0))(i2)) by VectorSpace.InSpanOf.member;
      VectorSpace.dropIndex(g, selection(i0))(i2)
          = g(NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), i2))
          = g(Function.updateAt(selection, i0,
                NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos)))(i))
              by substituting skipEqSel as dropAtI2;
      done by substituting dropAtI2
    } as selectedInSpan;

  VectorSpace.InSpanOf(VectorSpace.dropIndex(g, selection(i0)),
        VectorSpace.linearCombination(g,
            Function.updateAt(coefficients, i0, coefficients(i0) + Field.negate(coefficients(i0))),
            Function.updateAt(selection, i0,
                NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos))),
            len))
      by VectorSpace.InSpanOf.of_combination_selected(outerInhabitant := NaturalsBelow.make(0, countPos))
      as combInSpan;

  -- That combination equals the bumped one (they agree below len: at i0 the
  -- zeroed coefficient kills the redirected term).
  Function.updateAt(coefficients, i0, coefficients(i0) + Field.negate(coefficients(i0)))(i0)
      = coefficients(i0) + Field.negate(coefficients(i0))   by Function.updateAt_at
      = Field.zero(f)                                        by sumZero
      as zeroedAtI0;
  ∀ (i : Natural). i < len →
      Function.updateAt(coefficients, i0, coefficients(i0) + Field.negate(coefficients(i0)))(i)
        • g(Function.updateAt(selection, i0,
              NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos)))(i))
      = Function.updateAt(coefficients, i0, coefficients(i0) + Field.negate(coefficients(i0)))(i)
        • g(selection(i))
    by {
      take i : Natural;
      suppose i < len as iBelow;
      i = i0 ∨ i ≠ i0 by Logic.excluded_middle;
      done by cases {
        case i = i0 as atI0: {
            Function.updateAt(coefficients, i0, coefficients(i0) + Field.negate(coefficients(i0)))(i)
                = Function.updateAt(coefficients, i0, coefficients(i0) + Field.negate(coefficients(i0)))(i0)
                      by substituting atI0
                = Field.zero(f) by zeroedAtI0
                as czeroHere;
            Function.updateAt(coefficients, i0, coefficients(i0) + Field.negate(coefficients(i0)))(i)
                • g(Function.updateAt(selection, i0,
                      NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos)))(i))
               = Field.zero(f) • g(Function.updateAt(selection, i0,
                     NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos)))(i))
                     by substituting czeroHere
               = VectorSpace.zero(V)                by VectorSpace.zero_scale
               = Field.zero(f) • g(selection(i))    by VectorSpace.zero_scale
               = Function.updateAt(coefficients, i0, coefficients(i0) + Field.negate(coefficients(i0)))(i)
                 • g(selection(i))                  by substituting czeroHere
          }
        case i ≠ i0 as offI0: {
            Function.updateAt(selection, i0,
                  NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos)))(i)
                = selection(i) by Function.updateAt_off as selHere;
            done by substituting selHere
          }
      }
    } as termsMatch;
  VectorSpace.linearCombination(g,
        Function.updateAt(coefficients, i0, coefficients(i0) + Field.negate(coefficients(i0))),
        Function.updateAt(selection, i0,
            NaturalsBelow.skip(NaturalsBelow.value(selection(i0)), NaturalsBelow.make(0, countPos))),
        len)
     = VectorSpace.linearCombination(g,
           Function.updateAt(coefficients, i0, coefficients(i0) + Field.negate(coefficients(i0))),
           selection, len)
         by VectorSpace.linearCombination_congruence as redirectSame;

  VectorSpace.InSpanOf(VectorSpace.dropIndex(g, selection(i0)),
        Field.negate(coefficients(i0)) • g(selection(i0)))
      by { VectorSpace.InSpanOf(VectorSpace.dropIndex(g, selection(i0)),
               VectorSpace.linearCombination(g,
                   Function.updateAt(coefficients, i0, coefficients(i0) + Field.negate(coefficients(i0))),
                   selection, len))
               by substituting redirectSame;
           done by substituting bumped };
  done by VectorSpace.InSpanOf.scale_cancel(nonzero := negNonzero)
}

-- ----------------------------------------------------------------------
-- Assembling the pruning induction.

-- The empty family is linearly independent (a selection into the empty index
-- type is impossible, so the vanishing hypothesis is vacuous).
theorem VectorSpace.empty_family_independent {f : Field} {V : VectorSpace(f)}
        (g : NaturalsBelow(0) → VectorSpace.carrier(V))
        : VectorSpace.LinearlyIndependent(g) := {
  take count : Natural;
  take selection : Natural → NaturalsBelow(0);
  take coefficients : Natural → Field.carrier(f);
  suppose ∀ (a b : Natural). a < count → b < count → selection(a) = selection(b) → a = b as injective;
  suppose VectorSpace.linearCombination(g, coefficients, selection, count) = VectorSpace.zero(V) as vanishes;
  take i : Natural;
  suppose i < count as iBelow;
  NaturalsBelow.value(selection(i)) < 0 by NaturalsBelow.below;
  ¬(NaturalsBelow.value(selection(i)) < 0) by Natural.not_less_than_zero;
  done
}

-- Every combination of a family that is identically zero is the zero vector.
theorem VectorSpace.linearCombination_of_zero_family {f : Field} {V : VectorSpace(f)}
        {I : Type(0)} (family : I → VectorSpace.carrier(V))
        (allZero : ∀ (x : I). family(x) = VectorSpace.zero(V))
        (coefficients : Natural → Field.carrier(f)) (selection : Natural → I) (count : Natural)
        : VectorSpace.linearCombination(family, coefficients, selection, count) = VectorSpace.zero(V) :=
  by induction on count with IH {
    case base: done
    case step(m):
        VectorSpace.linearCombination(family, coefficients, selection, 1 + m)
           = VectorSpace.linearCombination(family, coefficients, selection, m)
             + coefficients(m) • family(selection(m))
                 by VectorSpace.linearCombination_add_one
           = VectorSpace.zero(V) + coefficients(m) • family(selection(m))   by IH
           = VectorSpace.zero(V) + coefficients(m) • VectorSpace.zero(V)     by substituting allZero(selection(m))
           = VectorSpace.zero(V) + VectorSpace.zero(V)                       by VectorSpace.scale_zero
           = VectorSpace.zero(V)
  }

-- Dropping a redundant vector preserves spanning: if `g(j)` lies in the span
-- of the other vectors, `dropIndex(g, j)` still spans (span(g) ⊆
-- span(dropIndex(g, j)) by transitivity — every generator is either a member
-- of the reduced family or the redundant one).
theorem VectorSpace.spans_dropIndex {f : Field} {V : VectorSpace(f)} {count : Natural}
        (g : NaturalsBelow(1 + count) → VectorSpace.carrier(V)) (countPos : 0 < count)
        (j : NaturalsBelow(1 + count))
        (gSpans : VectorSpace.Spans(g)) (redundant : VectorSpace.InSpanOf(VectorSpace.dropIndex(g, j), g(j)))
        : VectorSpace.Spans(VectorSpace.dropIndex(g, j)) := {
  NaturalsBelow.value(j) ≤ count
      by { NaturalsBelow.value(j) < 1 + count by NaturalsBelow.below; done by Natural.le_of_lt_one_plus }
      as jvBound;
  ∀ (index : NaturalsBelow(1 + count)). VectorSpace.InSpanOf(VectorSpace.dropIndex(g, j), g(index))
    by {
      take index : NaturalsBelow(1 + count);
      NaturalsBelow.value(index) = NaturalsBelow.value(j)
          ∨ NaturalsBelow.value(index) ≠ NaturalsBelow.value(j) by Logic.excluded_middle;
      done by cases {
        case NaturalsBelow.value(index) = NaturalsBelow.value(j) as eq: {
            index = j by NaturalsBelow.equal_of_value as indexIsJ;
            VectorSpace.InSpanOf(VectorSpace.dropIndex(g, j), g(j)) by redundant;
            done by substituting indexIsJ
          }
        case NaturalsBelow.value(index) ≠ NaturalsBelow.value(j) as ne: {
            ∃ (i2 : NaturalsBelow(count)). NaturalsBelow.skip(NaturalsBelow.value(j), i2) = index
                by NaturalsBelow.skip_surjective as preimageExists;
            choose i2 such that NaturalsBelow.skip(NaturalsBelow.value(j), i2) = index from preimageExists;
            NaturalsBelow.skip(NaturalsBelow.value(j), i2) = index as skipEq;
            VectorSpace.InSpanOf(VectorSpace.dropIndex(g, j), VectorSpace.dropIndex(g, j)(i2))
                by VectorSpace.InSpanOf.member;
            VectorSpace.dropIndex(g, j)(i2)
               = g(NaturalsBelow.skip(NaturalsBelow.value(j), i2))
               = g(index)   by substituting skipEq
               as dropAt;
            done by substituting dropAt
          }
      }
    } as allInSpan;
  take v : VectorSpace.carrier(V);
  VectorSpace.InSpanOf(g, v) by VectorSpace.InSpanOf.of_spans(inhabitant := j);
  VectorSpace.InSpanOf(VectorSpace.dropIndex(g, j), v)
      by VectorSpace.InSpanOf.transitive(outerInhabitant := NaturalsBelow.make(0, countPos));
  done
}

-- The inductive step (for a nonempty tail): a spanning family of `1 + count`
-- vectors is either independent, or some vector is redundant and can be
-- dropped to a spanning family of `count` vectors. Proved through the
-- contrapositive — if NO `count`-family spans, the family is independent
-- (a nonzero coefficient would exhibit a redundant vector via
-- `dropIndex_redundant`, and dropping it would span) — so no `¬∀`
-- witness-extraction is needed.
theorem VectorSpace.independent_or_droppable {f : Field} {V : VectorSpace(f)} {count : Natural}
        (g : NaturalsBelow(1 + count) → VectorSpace.carrier(V)) (countPos : 0 < count)
        (gSpans : VectorSpace.Spans(g))
        : VectorSpace.LinearlyIndependent(g)
          ∨ (∃ (h : NaturalsBelow(count) → VectorSpace.carrier(V)). VectorSpace.Spans(h)) := {
  (∃ (h : NaturalsBelow(count) → VectorSpace.carrier(V)). VectorSpace.Spans(h))
      ∨ ¬(∃ (h : NaturalsBelow(count) → VectorSpace.carrier(V)). VectorSpace.Spans(h))
      by Logic.excluded_middle;
  done by cases {
    case ∃ (h : NaturalsBelow(count) → VectorSpace.carrier(V)). VectorSpace.Spans(h) as hExists: { done }
    case ¬(∃ (h : NaturalsBelow(count) → VectorSpace.carrier(V)). VectorSpace.Spans(h)) as noH: {
        VectorSpace.LinearlyIndependent(g) by {
          take len : Natural;
          take selection : Natural → NaturalsBelow(1 + count);
          take coefficients : Natural → Field.carrier(f);
          suppose ∀ (a b : Natural). a < len → b < len → selection(a) = selection(b) → a = b as injective;
          suppose VectorSpace.linearCombination(g, coefficients, selection, len) = VectorSpace.zero(V)
              as vanishes;
          take i : Natural;
          suppose i < len as iBelow;
          suppose coefficients(i) ≠ Field.zero(f) as cNonzero for contradiction {
            VectorSpace.InSpanOf(VectorSpace.dropIndex(g, selection(i)), g(selection(i)))
                by VectorSpace.dropIndex_redundant(i0 := i);
            VectorSpace.Spans(VectorSpace.dropIndex(g, selection(i)))
                by VectorSpace.spans_dropIndex as dropSpans;
            ∃ (h : NaturalsBelow(count) → VectorSpace.carrier(V)). VectorSpace.Spans(h)
                by { witness VectorSpace.dropIndex(g, selection(i)) with dropSpans };
            done
          }
        };
        done
    }
  }
}

-- The size-one base of the pruning: a single spanning vector is either zero
-- (so the space is trivial and the empty family is a basis) or nonzero (so it
-- is itself a basis). Split on whether the space is trivial to avoid negating
-- `LinearlyIndependent` directly.
theorem VectorSpace.size_one_finite_dimensional {f : Field} {V : VectorSpace(f)} {count : Natural}
        (g : NaturalsBelow(1 + count) → VectorSpace.carrier(V)) (countZero : count = 0)
        (gSpans : VectorSpace.Spans(g))
        : VectorSpace.FiniteDimensional(V) := {
  0 < 1 + count by { 0 < 1 ≤ 1 + count; done } as zeroLtOnePlus;
  ∀ (x : NaturalsBelow(1 + count)). NaturalsBelow.value(x) = 0
    by { take x : NaturalsBelow(1 + count);
         NaturalsBelow.value(x) < 1 + count by NaturalsBelow.below;
         1 + count = 1 by substituting countZero;
         NaturalsBelow.value(x) < 1;
         done by NaturalsBelow.below_one_is_zero } as allValueZero;
  ∀ (x y : NaturalsBelow(1 + count)). g(x) = g(y)
    by { take x : NaturalsBelow(1 + count); take y : NaturalsBelow(1 + count);
         NaturalsBelow.value(x) = 0 by allValueZero;
         NaturalsBelow.value(y) = 0 by allValueZero;
         NaturalsBelow.value(x) = NaturalsBelow.value(y);
         x = y by NaturalsBelow.equal_of_value;
         done } as gConstant;
  (∀ (v : VectorSpace.carrier(V)). v = VectorSpace.zero(V))
      ∨ ¬(∀ (v : VectorSpace.carrier(V)). v = VectorSpace.zero(V)) by Logic.excluded_middle;
  done by cases {
    case ∀ (v : VectorSpace.carrier(V)). v = VectorSpace.zero(V) as trivial: {
        VectorSpace.LinearlyIndependent((x : NaturalsBelow(0)) ↦ VectorSpace.zero(V))
            by VectorSpace.empty_family_independent as emptyIndep;
        VectorSpace.Spans((x : NaturalsBelow(0)) ↦ VectorSpace.zero(V))
            by { take v : VectorSpace.carrier(V); v = VectorSpace.zero(V) by trivial; done } as emptySpans;
        VectorSpace.IsBasis((x : NaturalsBelow(0)) ↦ VectorSpace.zero(V))
            by { VectorSpace.LinearlyIndependent((x : NaturalsBelow(0)) ↦ VectorSpace.zero(V)) by emptyIndep;
                 VectorSpace.Spans((x : NaturalsBelow(0)) ↦ VectorSpace.zero(V)) by emptySpans;
                 done } as emptyBasis;
        witness 0 with witness ((x : NaturalsBelow(0)) ↦ VectorSpace.zero(V)) with emptyBasis
      }
    case ¬(∀ (v : VectorSpace.carrier(V)). v = VectorSpace.zero(V)) as nontrivial: {
        ∃ (v : VectorSpace.carrier(V)). ¬(v = VectorSpace.zero(V))
            by Logic.not_forall_implies_exists_not(VectorSpace.carrier(V),
                   (v : VectorSpace.carrier(V)) ↦ v = VectorSpace.zero(V), nontrivial) as nonzeroExists;
        choose v0 such that ¬(v0 = VectorSpace.zero(V)) from nonzeroExists;
        ¬(v0 = VectorSpace.zero(V)) as v0Nonzero;
        -- The single vector is nonzero: otherwise the whole family is zero and
        -- every combination — including v0's — is zero.
        g(NaturalsBelow.make(0, zeroLtOnePlus)) ≠ VectorSpace.zero(V)
          by {
            suppose g(NaturalsBelow.make(0, zeroLtOnePlus)) = VectorSpace.zero(V) as pointZero;
            ∀ (x : NaturalsBelow(1 + count)). g(x) = VectorSpace.zero(V)
              by { take x : NaturalsBelow(1 + count);
                   g(x) = g(NaturalsBelow.make(0, zeroLtOnePlus))
                            by gConstant(x, NaturalsBelow.make(0, zeroLtOnePlus))
                        = VectorSpace.zero(V) by pointZero;
                   done } as allZero;
            VectorSpace.InSpanOf(g, v0)
                by VectorSpace.InSpanOf.of_spans(inhabitant := NaturalsBelow.make(0, zeroLtOnePlus))
                as v0InSpan;
            choose count2, selection2, coefficients2 such that
                v0 = VectorSpace.linearCombination(g, coefficients2, selection2, count2) from v0InSpan;
            v0 = VectorSpace.linearCombination(g, coefficients2, selection2, count2)
               = VectorSpace.zero(V) by VectorSpace.linearCombination_of_zero_family;
            done
          } as pointNonzero;
        VectorSpace.LinearlyIndependent(g)
          by {
            take len : Natural;
            take selection : Natural → NaturalsBelow(1 + count);
            take coefficients : Natural → Field.carrier(f);
            suppose ∀ (a b : Natural). a < len → b < len → selection(a) = selection(b) → a = b as injective;
            suppose VectorSpace.linearCombination(g, coefficients, selection, len) = VectorSpace.zero(V) as vanishes;
            take i : Natural;
            suppose i < len as iBelow;
            ¬(1 < len)
              by { suppose 1 < len as oneLtLen;
                   0 < len by { 0 < 1 < len; done };
                   selection(0) = selection(1)
                       by { NaturalsBelow.value(selection(0)) = 0 by allValueZero;
                            NaturalsBelow.value(selection(1)) = 0 by allValueZero;
                            NaturalsBelow.value(selection(0)) = NaturalsBelow.value(selection(1));
                            done by NaturalsBelow.equal_of_value };
                   (0 : Natural) = 1 by injective;
                   done } as notOneLtLen;
            len ≤ 1 by { 1 < len ∨ len ≤ 1 by Natural.lt_or_le; done } as lenLeOne;
            i < 1 by { i < len ≤ 1; done };
            i = 0 by NaturalsBelow.below_one_is_zero as iZero;
            0 < len by { i < len; done };
            1 ≤ len by Natural.successor_le_of_lt;
            len = 1 by Natural.le_antisymmetric as lenOne;
            VectorSpace.linearCombination(g, coefficients, selection, 1)
                = VectorSpace.linearCombination(g, coefficients, selection, len)   by substituting lenOne
                = VectorSpace.zero(V) by vanishes
                as vanishesOne;
            coefficients(0) • g(selection(0)) = VectorSpace.zero(V)
                by { coefficients(0) • g(selection(0))
                        = VectorSpace.linearCombination(g, coefficients, selection, 1)
                              by VectorSpace.linearCombination_one
                        = VectorSpace.zero(V) by vanishesOne; done } as termZero;
            g(selection(0)) ≠ VectorSpace.zero(V)
                by { g(selection(0)) = g(NaturalsBelow.make(0, zeroLtOnePlus)) by gConstant;
                     done by pointNonzero } as gSelNonzero;
            coefficients(0) = Field.zero(f)
              by {
                coefficients(0) = Field.zero(f) ∨ coefficients(0) ≠ Field.zero(f) by Logic.excluded_middle;
                done by cases {
                  case coefficients(0) = Field.zero(f) as isZero: { done }
                  case coefficients(0) ≠ Field.zero(f) as isNonzero: {
                      g(selection(0))
                         = Field.reciprocal(coefficients(0), isNonzero) • (coefficients(0) • g(selection(0)))
                               by VectorSpace.scale_reciprocal_cancel
                         = Field.reciprocal(coefficients(0), isNonzero) • VectorSpace.zero(V)
                               by substituting termZero
                         = VectorSpace.zero(V) by VectorSpace.scale_zero;
                      g(selection(0)) ≠ VectorSpace.zero(V) by gSelNonzero;
                      done
                    }
                }
              } as coeffZero;
            coefficients(i) = coefficients(0) by substituting iZero
                            = Field.zero(f) by coeffZero;
            done
          } as gIndependent;
        VectorSpace.IsBasis(g)
            by { VectorSpace.LinearlyIndependent(g) by gIndependent;
                 VectorSpace.Spans(g) by gSpans; done } as gBasis;
        witness 1 + count with witness g with gBasis
      }
  }
}

-- ----------------------------------------------------------------------
-- The pruning induction: any spanning family of `size` vectors yields a
-- finite basis. Induction on `size`; each dependent step drops one vector.
theorem VectorSpace.spanning_finite_dimensional {f : Field} {V : VectorSpace(f)}
        : ∀ (size : Natural). ∀ (g : NaturalsBelow(size) → VectorSpace.carrier(V)).
              VectorSpace.Spans(g) → VectorSpace.FiniteDimensional(V) :=
  by induction on size with IH {
    case base: {
        take g : NaturalsBelow(0) → VectorSpace.carrier(V);
        suppose VectorSpace.Spans(g) as gSpans;
        VectorSpace.LinearlyIndependent(g) by VectorSpace.empty_family_independent as gIndep;
        VectorSpace.IsBasis(g)
            by { VectorSpace.LinearlyIndependent(g) by gIndep;
                 VectorSpace.Spans(g) by gSpans; done } as gBasis;
        witness 0 with witness g with gBasis
      }
    case step(count): {
        take g : NaturalsBelow(1 + count) → VectorSpace.carrier(V);
        suppose VectorSpace.Spans(g) as gSpans;
        0 < count ∨ count ≤ 0 by Natural.lt_or_le;
        done by cases {
          case 0 < count as countPos: {
              VectorSpace.LinearlyIndependent(g)
                  ∨ (∃ (h : NaturalsBelow(count) → VectorSpace.carrier(V)). VectorSpace.Spans(h))
                  by VectorSpace.independent_or_droppable;
              done by cases {
                case VectorSpace.LinearlyIndependent(g) as gIndep: {
                    VectorSpace.IsBasis(g)
                        by { VectorSpace.LinearlyIndependent(g) by gIndep;
                             VectorSpace.Spans(g) by gSpans; done } as gBasis;
                    witness 1 + count with witness g with gBasis
                  }
                case ∃ (h : NaturalsBelow(count) → VectorSpace.carrier(V)). VectorSpace.Spans(h) as hExists: {
                    choose h such that VectorSpace.Spans(h) from hExists;
                    VectorSpace.Spans(h) as hSpans;
                    done by IH
                  }
              }
            }
          case count ≤ 0 as countLe: {
              count = 0 by Natural.less_or_equal_zero_implies_equals_zero as countZero;
              done by VectorSpace.size_one_finite_dimensional
            }
        }
      }
  }

-- Every finitely generated vector space is finite-dimensional: prune a finite
-- spanning family down to a basis. Choice-free.
theorem VectorSpace.FinitelyGenerated.finite_dimensional {f : Field} {V : VectorSpace(f)}
        (finitelyGenerated : VectorSpace.FinitelyGenerated(V))
        : VectorSpace.FiniteDimensional(V) := {
  choose count, generators such that VectorSpace.Spans(generators) from finitelyGenerated;
  VectorSpace.Spans(generators) as generatorsSpan;
  done by VectorSpace.spanning_finite_dimensional
}

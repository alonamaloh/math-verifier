-- Algebra/binomial.math
--
-- The binomial theorem over an arbitrary commutative ring (Freek #44):
--   (a + b)ⁿ = Σ_{k ≤ n} C(n, k) · aᵏ · bⁿ⁻ᵏ.
--
-- Proved once, generically, on the bundled-ring summation `Ring.Sum`
-- with the `ring` tactic discharging the commutative-ring algebra. The
-- Natural binomial coefficient enters the ring through `Ring.from_natural`
-- and the deficit exponent is a Natural monus. `Real.binomial_theorem` and
-- `ComplexNumber.binomial_theorem` are instances (no more duplicated
-- 800-line inductions).
--
-- Induction on n. The (n+1)-row's general term splits, by Pascal's rule
-- C(n+1, k+1) = C(n, k) + C(n, k+1), into an a-scaled copy and a b-scaled
-- copy of the n-row; the b-copy reassembles via `Sum.shift`, its loose top
-- term vanishing because C(n, n+1) = 0.

module Algebra.binomial

import Logic.basics
import Logic.sum
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Natural.monus
import Natural.binomial
import Natural.division
import Natural.one_plus_induction
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.ring_power
import Algebra.ring_from_natural
import Algebra.ring_lemmas
import Algebra.ring_summation

-- The general term C(n,k)·aᵏ·bⁿ⁻ᵏ of the binomial expansion over a ring.
definition Ring.binomialTerm (r : Ring) (a b : Ring.carrier(r)) (n k : Natural)
        : Ring.carrier(r) :=
  Ring.from_natural(r, Natural.binomial(n, k))
  * (Ring.power(r, a, k) * Ring.power(r, b, Natural.monus(n, k)))

-- The left edge (k = 0): the coefficient and aᵏ are both 1, so the term
-- is bⁿ.
theorem Ring.binomialTerm_zero_index (r : Ring) (a b : Ring.carrier(r)) (n : Natural)
        : Ring.binomialTerm(r, a, b, n, 0) = Ring.power(r, b, n) := {
  Natural.binomial(n, 0) = 1 as coefficient;
  Natural.monus(n, 0) = n as deficit;
  Ring.binomialTerm(r, a, b, n, 0)
     = Ring.from_natural(r, Natural.binomial(n, 0))
       * (Ring.one(r) * Ring.power(r, b, Natural.monus(n, 0)))
     = Ring.from_natural(r, 1)
       * (Ring.one(r) * Ring.power(r, b, Natural.monus(n, 0)))   by substituting coefficient
     = Ring.from_natural(r, 1) * (Ring.one(r) * Ring.power(r, b, n))   by substituting deficit
     = Ring.one(r) * (Ring.one(r) * Ring.power(r, b, n))   by Ring.from_natural_one
     = Ring.power(r, b, n)   by ring
}

-- Above the diagonal the coefficient vanishes, so the term is zero.
theorem Ring.binomialTerm_overflow (r : Ring) (a b : Ring.carrier(r)) (p : Natural)
        : Ring.binomialTerm(r, a, b, p, 1 + p) = Ring.zero(r) := {
  Natural.binomial(p, 1 + p) = 0 by Natural.binomial_overflow as coefficientZero;
  Ring.binomialTerm(r, a, b, p, 1 + p)
     = Ring.from_natural(r, Natural.binomial(p, 1 + p))
       * (Ring.power(r, a, 1 + p) * Ring.power(r, b, Natural.monus(p, 1 + p)))
     = Ring.from_natural(r, 0)
       * (Ring.power(r, a, 1 + p) * Ring.power(r, b, Natural.monus(p, 1 + p)))   by substituting coefficientZero
     = Ring.zero(r) * (Ring.power(r, a, 1 + p) * Ring.power(r, b, Natural.monus(p, 1 + p)))
     = Ring.zero(r)
}

-- The (n+1)-row's left edge is b times the n-row's left edge.
theorem Ring.binomialTerm_edge_zero (r : Ring) (a b : Ring.carrier(r)) (p : Natural)
        : Ring.binomialTerm(r, a, b, 1 + p, 0)
          = b * Ring.binomialTerm(r, a, b, p, 0) :=
  calc Ring.binomialTerm(r, a, b, 1 + p, 0)
     = Ring.power(r, b, 1 + p)
     = b * Ring.power(r, b, p)
     = b * Ring.binomialTerm(r, a, b, p, 0)

-- ----------------------------------------------------------------------
-- Pascal's rule on the terms: the (n+1, k+1) term is the a-scaled (n, k)
-- term plus the b-scaled (n, k+1) term. Below the diagonal both pieces are
-- genuine; at or above it the second coefficient C(n, k+1) is zero, and
-- the deficit-exponent bookkeeping differs — hence the split on j < p.
theorem Ring.binomialTerm_pascal (c : CommutativeRing)
        (a b : CommutativeRing.carrier(c)) (p j : Natural)
        : Ring.binomialTerm(CommutativeRing.ring(c), a, b, 1 + p, 1 + j)
          = a * Ring.binomialTerm(CommutativeRing.ring(c), a, b, p, j)
            + b * Ring.binomialTerm(CommutativeRing.ring(c), a, b, p, 1 + j) := {
  let R : Ring := CommutativeRing.ring(c);
  Natural.binomial(1 + p, 1 + j)
        = Natural.binomial(p, j) + Natural.binomial(p, 1 + j)
      by substituting Natural.one_add as pascalCoefficient;
  Natural.monus(1 + p, 1 + j) = Natural.monus(p, j) as deficitDiagonal;
  j < p ∨ p ≤ j by Natural.lt_or_le as comparison;
  cases comparison {
    | Or.introduceLeft(jBelow) => {
        Natural.monus(p, j) = 1 + Natural.monus(p, 1 + j) as deficitShift;
        a * Ring.binomialTerm(R, a, b, p, j)
             + b * Ring.binomialTerm(R, a, b, p, 1 + j)
           = a * (Ring.from_natural(R, Natural.binomial(p, j))
                  * (Ring.power(R, a, j) * Ring.power(R, b, Natural.monus(p, j))))
             + b * (Ring.from_natural(R, Natural.binomial(p, 1 + j))
                    * (Ring.power(R, a, 1 + j) * Ring.power(R, b, Natural.monus(p, 1 + j))))
           = a * (Ring.from_natural(R, Natural.binomial(p, j))
                  * (Ring.power(R, a, j) * Ring.power(R, b, 1 + Natural.monus(p, 1 + j))))
             + b * (Ring.from_natural(R, Natural.binomial(p, 1 + j))
                    * (Ring.power(R, a, 1 + j) * Ring.power(R, b, Natural.monus(p, 1 + j))))
                 by substituting deficitShift
           = a * (Ring.from_natural(R, Natural.binomial(p, j))
                  * (Ring.power(R, a, j)
                     * (b * Ring.power(R, b, Natural.monus(p, 1 + j)))))
             + b * (Ring.from_natural(R, Natural.binomial(p, 1 + j))
                    * ((a * Ring.power(R, a, j))
                       * Ring.power(R, b, Natural.monus(p, 1 + j))))
                 by substituting Ring.power_add_one
           = (Ring.from_natural(R, Natural.binomial(p, j))
              + Ring.from_natural(R, Natural.binomial(p, 1 + j)))
             * ((a * Ring.power(R, a, j))
                * (b * Ring.power(R, b, Natural.monus(p, 1 + j))))
                 by ring
           as rightExpanded;
        Ring.binomialTerm(R, a, b, 1 + p, 1 + j)
           = Ring.from_natural(R, Natural.binomial(1 + p, 1 + j))
             * (Ring.power(R, a, 1 + j) * Ring.power(R, b, Natural.monus(1 + p, 1 + j)))
           = Ring.from_natural(R, Natural.binomial(p, j) + Natural.binomial(p, 1 + j))
             * (Ring.power(R, a, 1 + j) * Ring.power(R, b, Natural.monus(1 + p, 1 + j)))
               by substituting pascalCoefficient
           = Ring.from_natural(R, Natural.binomial(p, j) + Natural.binomial(p, 1 + j))
             * (Ring.power(R, a, 1 + j) * Ring.power(R, b, Natural.monus(p, j)))
               by substituting deficitDiagonal
           = (Ring.from_natural(R, Natural.binomial(p, j))
              + Ring.from_natural(R, Natural.binomial(p, 1 + j)))
             * (Ring.power(R, a, 1 + j) * Ring.power(R, b, Natural.monus(p, j)))
               by Ring.from_natural_add
           = (Ring.from_natural(R, Natural.binomial(p, j))
              + Ring.from_natural(R, Natural.binomial(p, 1 + j)))
             * (Ring.power(R, a, 1 + j) * Ring.power(R, b, 1 + Natural.monus(p, 1 + j)))
               by substituting deficitShift
           = (Ring.from_natural(R, Natural.binomial(p, j))
              + Ring.from_natural(R, Natural.binomial(p, 1 + j)))
             * ((a * Ring.power(R, a, j))
                * (b * Ring.power(R, b, Natural.monus(p, 1 + j))))
               by substituting Ring.power_add_one
           = a * Ring.binomialTerm(R, a, b, p, j)
             + b * Ring.binomialTerm(R, a, b, p, 1 + j)
               by rightExpanded
      }
    | Or.introduceRight(pBelow) => {
        Natural.binomial(p, 1 + j) = 0 by Natural.binomial_overflow as coefficientZero;
        Natural.binomial(1 + p, 1 + j)
           = Natural.binomial(p, j) + Natural.binomial(p, 1 + j)
           = Natural.binomial(p, j) + 0
           = Natural.binomial(p, j)       by (Natural.binomial(p, j) + 0 = Natural.binomial(p, j))
           as boundaryCoefficient;
        b * Ring.binomialTerm(R, a, b, p, 1 + j)
           = b * (Ring.from_natural(R, Natural.binomial(p, 1 + j))
                  * (Ring.power(R, a, 1 + j) * Ring.power(R, b, Natural.monus(p, 1 + j))))
           = b * (Ring.from_natural(R, 0)
                  * (Ring.power(R, a, 1 + j) * Ring.power(R, b, Natural.monus(p, 1 + j))))
               by substituting coefficientZero
           = b * (Ring.zero(R)
                  * (Ring.power(R, a, 1 + j) * Ring.power(R, b, Natural.monus(p, 1 + j))))
           = Ring.zero(R)   by ring
           as secondVanishes;
        Ring.binomialTerm(R, a, b, 1 + p, 1 + j)
           = Ring.from_natural(R, Natural.binomial(1 + p, 1 + j))
             * (Ring.power(R, a, 1 + j) * Ring.power(R, b, Natural.monus(1 + p, 1 + j)))
           = Ring.from_natural(R, Natural.binomial(p, j))
             * (Ring.power(R, a, 1 + j) * Ring.power(R, b, Natural.monus(1 + p, 1 + j)))
               by substituting boundaryCoefficient
           = Ring.from_natural(R, Natural.binomial(p, j))
             * (Ring.power(R, a, 1 + j) * Ring.power(R, b, Natural.monus(p, j)))
               by substituting deficitDiagonal
           = Ring.from_natural(R, Natural.binomial(p, j))
             * ((a * Ring.power(R, a, j)) * Ring.power(R, b, Natural.monus(p, j)))
               by substituting Ring.power_add_one
           = a * (Ring.from_natural(R, Natural.binomial(p, j))
                  * (Ring.power(R, a, j) * Ring.power(R, b, Natural.monus(p, j))))
               by ring
           as firstAligns;
        Ring.binomialTerm(R, a, b, 1 + p, 1 + j)
           = a * Ring.binomialTerm(R, a, b, p, j)                          by firstAligns
           = a * Ring.binomialTerm(R, a, b, p, j) + Ring.zero(R)
           = a * Ring.binomialTerm(R, a, b, p, j)
             + b * Ring.binomialTerm(R, a, b, p, 1 + j)                    by secondVanishes
      }
  }
}

-- ----------------------------------------------------------------------
-- Freek #44, generic form.
theorem CommutativeRing.binomial_theorem (c : CommutativeRing)
        (a b : CommutativeRing.carrier(c)) (n : Natural)
        : Ring.power(CommutativeRing.ring(c), a + b, n)
          = Ring.Sum(CommutativeRing.ring(c),
                (k : Natural) ↦ Ring.binomialTerm(CommutativeRing.ring(c), a, b, n, k), n) := {
  let R : Ring := CommutativeRing.ring(c);
  by induction on n with IH {
    case base:
        calc Ring.power(R, a + b, 0)
           = Ring.one(R)
           = Ring.power(R, b, 0)
           = Ring.binomialTerm(R, a, b, 0, 0)
           = Ring.Sum(R, (k : Natural) ↦ Ring.binomialTerm(R, a, b, 0, k), 0)
    case step(p): {
        b * Ring.binomialTerm(R, a, b, p, 1 + p)
           = b * Ring.zero(R)   by Ring.binomialTerm_overflow
           = Ring.zero(R)
           as secondVanishes;
        Ring.Sum(R,
                 (j : Natural) ↦ a * Ring.binomialTerm(R, a, b, p, j)
                                 + b * Ring.binomialTerm(R, a, b, p, 1 + j), p)
           = Ring.Sum(R,
                 (j : Natural) ↦ Ring.binomialTerm(R, a, b, 1 + p, 1 + j), p)
               by (j : Natural) ↦
                   calc a * Ring.binomialTerm(R, a, b, p, j)
                        + b * Ring.binomialTerm(R, a, b, p, 1 + j)
                      = Ring.binomialTerm(R, a, b, 1 + p, 1 + j)
                          by Ring.binomialTerm_pascal
           as pascalRows;
        Ring.power(R, a + b, 1 + p)
           = (a + b) * Ring.power(R, a + b, p)
           = (a + b) * Ring.Sum(R, (k : Natural) ↦ Ring.binomialTerm(R, a, b, p, k), p)   by IH
           = a * Ring.Sum(R, (k : Natural) ↦ Ring.binomialTerm(R, a, b, p, k), p)
             + b * Ring.Sum(R, (k : Natural) ↦ Ring.binomialTerm(R, a, b, p, k), p)
           = a * Ring.Sum(R, (k : Natural) ↦ Ring.binomialTerm(R, a, b, p, k), p)
             + (b * Ring.Sum(R, (k : Natural) ↦ Ring.binomialTerm(R, a, b, p, k), p)
                + Ring.zero(R))   by ring
           = a * Ring.Sum(R, (k : Natural) ↦ Ring.binomialTerm(R, a, b, p, k), p)
             + (b * Ring.Sum(R, (k : Natural) ↦ Ring.binomialTerm(R, a, b, p, k), p)
                + b * Ring.binomialTerm(R, a, b, p, 1 + p))   by secondVanishes
           = a * Ring.Sum(R, (k : Natural) ↦ Ring.binomialTerm(R, a, b, p, k), p)
             + (Ring.Sum(R, (k : Natural) ↦ b * Ring.binomialTerm(R, a, b, p, k), p)
                + b * Ring.binomialTerm(R, a, b, p, 1 + p))   by Ring.Sum.scale_left
           = a * Ring.Sum(R, (k : Natural) ↦ Ring.binomialTerm(R, a, b, p, k), p)
             + Ring.Sum(R, (k : Natural) ↦ b * Ring.binomialTerm(R, a, b, p, k), 1 + p)
               by Ring.Sum.add_one
           = a * Ring.Sum(R, (k : Natural) ↦ Ring.binomialTerm(R, a, b, p, k), p)
             + (b * Ring.binomialTerm(R, a, b, p, 0)
                + Ring.Sum(R, (j : Natural) ↦ b * Ring.binomialTerm(R, a, b, p, 1 + j), p))
               by Ring.Sum.shift_one_plus
           = a * Ring.Sum(R, (k : Natural) ↦ Ring.binomialTerm(R, a, b, p, k), p)
             + (Ring.binomialTerm(R, a, b, 1 + p, 0)
                + Ring.Sum(R, (j : Natural) ↦ b * Ring.binomialTerm(R, a, b, p, 1 + j), p))
               by Ring.binomialTerm_edge_zero
           = Ring.Sum(R, (j : Natural) ↦ a * Ring.binomialTerm(R, a, b, p, j), p)
             + (Ring.binomialTerm(R, a, b, 1 + p, 0)
                + Ring.Sum(R, (j : Natural) ↦ b * Ring.binomialTerm(R, a, b, p, 1 + j), p))
               by Ring.Sum.scale_left
           = Ring.binomialTerm(R, a, b, 1 + p, 0)
             + (Ring.Sum(R, (j : Natural) ↦ a * Ring.binomialTerm(R, a, b, p, j), p)
                + Ring.Sum(R, (j : Natural) ↦ b * Ring.binomialTerm(R, a, b, p, 1 + j), p))
               by ring
           = Ring.binomialTerm(R, a, b, 1 + p, 0)
             + Ring.Sum(R,
                   (j : Natural) ↦ a * Ring.binomialTerm(R, a, b, p, j)
                                   + b * Ring.binomialTerm(R, a, b, p, 1 + j), p)
               by Ring.Sum.add
           = Ring.binomialTerm(R, a, b, 1 + p, 0)
             + Ring.Sum(R,
                   (j : Natural) ↦ Ring.binomialTerm(R, a, b, 1 + p, 1 + j), p)
               by substituting pascalRows
           = Ring.Sum(R, (k : Natural) ↦ Ring.binomialTerm(R, a, b, 1 + p, k), 1 + p)
               by Ring.Sum.shift_one_plus
      }
  }
}

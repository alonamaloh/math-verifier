-- ----------------------------------------------------------------------
-- The two odd-border representatives.

theorem Matrix.squarePlusDoubleSquareOddForm_four_truant_seven
        : Matrix.IsTruant(Matrix.squarePlusDoubleSquareOddForm(4), 7) := {
  let A : Matrix(Integer.commutative_ring_bundle, 3, 3) := Matrix.squarePlusDoubleSquareOddForm(4);
  ∀ (a b z target : ℤ). a * a + 2 * (b * b) + 2 * b * z + 4 * (z * z) = target →
      Matrix.quadraticForm(A, (⟨a, b, z⟩ : RingVector(Integer.commutative_ring_bundle, 3))) = target
      by Matrix.squarePlusDoubleSquareOddForm_four_coordinateTuple_computes;
  Matrix.represents_by_witness(A, target := 1, vector := ⟨1, 0, 0⟩);
  Matrix.represents_by_witness(A, target := 2, vector := ⟨0, 1, 0⟩);
  Matrix.represents_by_witness(A, target := 3, vector := ⟨1, 1, 0⟩);
  Matrix.represents_by_witness(A, target := 4, vector := ⟨2, 0, 0⟩);
  Matrix.represents_by_witness(A, target := 5, vector := ⟨1, 0, 1⟩);
  Matrix.represents_by_witness(A, target := 6, vector := ⟨2, 1, 0⟩);
  ¬(Matrix.Represents(A, (7 : ℤ)))
      by Matrix.squarePlusDoubleSquareOddForm_four_not_represents_seven;
  ∀ (s : ℕ). s ≥ 1 → s < 7 → Matrix.Represents(A, (s : ℤ))
      by finite_check s from 1 until 7;
  done
}

theorem Matrix.squarePlusDoubleSquareOddForm_four_truant
        : Matrix.truant(Matrix.squarePlusDoubleSquareOddForm(4)) = 7 :=
  by Matrix.truant_equals

theorem Matrix.squarePlusDoubleSquareOddForm_five_truant_seven
        : Matrix.IsTruant(Matrix.squarePlusDoubleSquareOddForm(5), 7) := {
  let A : Matrix(Integer.commutative_ring_bundle, 3, 3) := Matrix.squarePlusDoubleSquareOddForm(5);
  ∀ (a b z target : ℤ). a * a + 2 * (b * b) + 2 * b * z + 5 * (z * z) = target →
      Matrix.quadraticForm(A, (⟨a, b, z⟩ : RingVector(Integer.commutative_ring_bundle, 3))) = target
      by Matrix.squarePlusDoubleSquareOddForm_five_coordinateTuple_computes;
  Matrix.represents_by_witness(A, target := 1, vector := ⟨1, 0, 0⟩);
  Matrix.represents_by_witness(A, target := 2, vector := ⟨0, 1, 0⟩);
  Matrix.represents_by_witness(A, target := 3, vector := ⟨1, 1, 0⟩);
  Matrix.represents_by_witness(A, target := 4, vector := ⟨2, 0, 0⟩);
  Matrix.represents_by_witness(A, target := 5, vector := ⟨0, 0, 1⟩);
  Matrix.represents_by_witness(A, target := 6, vector := ⟨2, 1, 0⟩);
  ¬(Matrix.Represents(A, (7 : ℤ)))
      by Matrix.squarePlusDoubleSquareOddForm_five_not_represents_seven;
  ∀ (s : ℕ). s ≥ 1 → s < 7 → Matrix.Represents(A, (s : ℤ))
      by finite_check s from 1 until 7;
  done
}

theorem Matrix.squarePlusDoubleSquareOddForm_five_truant
        : Matrix.truant(Matrix.squarePlusDoubleSquareOddForm(5)) = 7 :=
  by Matrix.truant_equals

-- ----------------------------------------------------------------------
-- Exact truant classification for every escalation above x²+2y².

theorem Matrix.squarePlusDoubleSquareDiagonalForm_three_truant_ten
        : Matrix.IsTruant(Matrix.squarePlusDoubleSquareDiagonalForm(3), 10) :=
  by Matrix.squarePlusDoubleSquarePlusTripleSquareForm_truant_ten

theorem Matrix.squarePlusDoubleSquareRankThreeRepresentative_truant
        (B : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (representative : Matrix.IsSquarePlusDoubleSquareRankThreeRepresentative(B))
        : Matrix.truant(B) = 7 ∨ Matrix.truant(B) = 10 ∨ Matrix.truant(B) = 14 := {
  Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(1))
    ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(2))
    ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(3))
    ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(4))
    ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(5))
    ∨ Matrix.IsIsometric(B, Matrix.sumOfThreeSquaresForm)
    ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(4))
    ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(5))
      by representative;
  done by cases {
    case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(1)) as isometric: {
        Matrix.IsIsometric(Matrix.squarePlusDoubleSquareDiagonalForm(1), B)
            by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
        Matrix.truant(B) = 14 by Matrix.isometric_truant_equals(
            isometric := reverse,
            isTruant := Matrix.squarePlusDoubleSquareDiagonalForm_one_truant_fourteen);
        done
      }
    case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(2))
      ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(3))
      ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(4))
      ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(5))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfThreeSquaresForm)
      ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(4))
      ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
        case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(2)) as isometric: {
            Matrix.IsIsometric(Matrix.squarePlusDoubleSquareDiagonalForm(2), B)
                by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
            Matrix.truant(B) = 7 by Matrix.isometric_truant_equals(
                isometric := reverse,
                isTruant := Matrix.squarePlusDoubleSquareDiagonalForm_two_truant_seven);
            done
          }
        case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(3))
          ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(4))
          ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(5))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfThreeSquaresForm)
          ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(4))
          ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
            case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(3)) as isometric: {
                Matrix.IsIsometric(Matrix.squarePlusDoubleSquareDiagonalForm(3), B)
                    by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
                Matrix.truant(B) = 10 by Matrix.isometric_truant_equals(
                    isometric := reverse,
                    isTruant := Matrix.squarePlusDoubleSquareDiagonalForm_three_truant_ten);
                done
              }
            case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(4))
              ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(5))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfThreeSquaresForm)
              ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(4))
              ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
                case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(4)) as isometric: {
                    Matrix.IsIsometric(Matrix.squarePlusDoubleSquareDiagonalForm(4), B)
                        by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
                    Matrix.truant(B) = 14 by Matrix.isometric_truant_equals(
                        isometric := reverse,
                        isTruant := Matrix.squarePlusDoubleSquareDiagonalForm_four_truant_fourteen);
                    done
                  }
                case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(5))
                  ∨ Matrix.IsIsometric(B, Matrix.sumOfThreeSquaresForm)
                  ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(4))
                  ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
                    case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(5)) as isometric: {
                        Matrix.IsIsometric(Matrix.squarePlusDoubleSquareDiagonalForm(5), B)
                            by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
                        Matrix.truant(B) = 10 by Matrix.isometric_truant_equals(
                            isometric := reverse,
                            isTruant := Matrix.squarePlusDoubleSquareDiagonalForm_five_truant_ten);
                        done
                      }
                    case Matrix.IsIsometric(B, Matrix.sumOfThreeSquaresForm)
                      ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(4))
                      ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
                        case Matrix.IsIsometric(B, Matrix.sumOfThreeSquaresForm) as isometric: {
                            Matrix.IsIsometric(Matrix.sumOfThreeSquaresForm, B)
                                by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
                            Matrix.truant(B) = 7 by Matrix.isometric_truant_equals(
                                isometric := reverse,
                                isTruant := Matrix.sumOfThreeSquaresForm_truant_seven);
                            done
                          }
                        case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(4))
                          ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
                            case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(4)) as isometric: {
                                Matrix.IsIsometric(Matrix.squarePlusDoubleSquareOddForm(4), B)
                                    by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
                                Matrix.truant(B) = 7 by Matrix.isometric_truant_equals(
                                    isometric := reverse,
                                    isTruant := Matrix.squarePlusDoubleSquareOddForm_four_truant_seven);
                                done
                              }
                            case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(5)) as isometric: {
                                Matrix.IsIsometric(Matrix.squarePlusDoubleSquareOddForm(5), B)
                                    by Matrix.IsIsometric.symmetric(isometric := isometric) as reverse;
                                Matrix.truant(B) = 7 by Matrix.isometric_truant_equals(
                                    isometric := reverse,
                                    isTruant := Matrix.squarePlusDoubleSquareOddForm_five_truant_seven);
                                done
                              }
                          }
                      }
                  }
              }
          }
      }
  }
}

theorem Matrix.squarePlusDoubleSquare_escalation_rank_three_truant
        (B : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (escalation : Matrix.IsEscalation(Matrix.squarePlusDoubleSquareForm, B))
        : Matrix.truant(B) = 7 ∨ Matrix.truant(B) = 10 ∨ Matrix.truant(B) = 14 := {
  Matrix.IsSquarePlusDoubleSquareRankThreeRepresentative(B)
      by Matrix.squarePlusDoubleSquare_escalation_eight_representatives;
  done by Matrix.squarePlusDoubleSquareRankThreeRepresentative_truant
}

-- ----------------------------------------------------------------------
-- The nine borders above x²+y², packaged in the same exact-truant form.

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_isometric_zeroBorderCandidate
        : Matrix.IsIsometric(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm,
            Matrix.sumOfTwoSquaresUnitBorderCandidate(0, 0)) := {
  let zero : RingVector(Integer.commutative_ring_bundle, 2) := RingVector.twoCoordinates((0 : ℤ), (0 : ℤ));
  zero = (RingVector.twoCoordinates((0 : ℤ), (0 : ℤ)) : RingVector(Integer.commutative_ring_bundle, 2)) as zeroReads;
  Matrix.sumOfTwoSquaresForm · zero
     = Matrix.identity(Integer.commutative_ring_bundle, 2) · zero
         by substituting Matrix.sumOfTwoSquaresForm_is_identity
     = zero by Matrix.applyVector_identity
  as actionReads;
  Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, zero)
     = Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm,
         (RingVector.twoCoordinates((0 : ℤ), (0 : ℤ)) : RingVector(Integer.commutative_ring_bundle, 2)))
         by substituting zeroReads
     = (0 : ℤ) * 0 + 0 * 0 by Matrix.sumOfTwoSquaresForm_twoCoordinates_value
     = (0 : ℤ) by ring
  as valueReads;
  Matrix.IsIsometric(
      Matrix.diagonalExtension(Matrix.sumOfTwoSquaresForm, (3 : ℤ)),
      Matrix.borderedAssembly(
          Matrix.sumOfTwoSquaresForm,
          Matrix.sumOfTwoSquaresForm · zero,
          (3 : ℤ) + Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, zero)))
      by Matrix.diagonalExtension_isometric_borderedAssembly(symmetric := Matrix.sumOfTwoSquaresForm_symmetric);
  (3 : ℤ) + 0 = 3 by ring as cornerReads;
  Matrix.borderedAssembly(
      Matrix.sumOfTwoSquaresForm,
      Matrix.sumOfTwoSquaresForm · zero,
      (3 : ℤ) + Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, zero))
     = Matrix.borderedAssembly(
           Matrix.sumOfTwoSquaresForm,
           zero,
           (3 : ℤ) + Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, zero)) by substituting actionReads
     = Matrix.borderedAssembly(Matrix.sumOfTwoSquaresForm, zero, (3 : ℤ) + 0) by substituting valueReads
     = Matrix.borderedAssembly(Matrix.sumOfTwoSquaresForm, zero, (3 : ℤ)) by substituting cornerReads
     = Matrix.sumOfTwoSquaresUnitBorderCandidate(0, 0)
  as targetReads;
  done by substituting targetReads
}

theorem Matrix.sumOfTwoSquaresZeroBorderCandidate_truant_six
        : Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(0, 0)) = 6 := {
  done by Matrix.isometric_truant_equals(
      isometric := Matrix.sumOfTwoSquaresPlusTripleSquareForm_isometric_zeroBorderCandidate,
      isTruant := Matrix.sumOfTwoSquaresPlusTripleSquareForm_truant_six)
}

theorem Matrix.sumOfTwoSquaresUnitBorderCandidate_truant_classification
        (a b : ℤ)
        (aAdmissible : Integer.IsTernaryBorderValue(a))
        (bAdmissible : Integer.IsTernaryBorderValue(b))
        : Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 6
          ∨ Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 7
          ∨ Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 14 := {
  a = -1 ∨ a = 0 ∨ a = 1 by aAdmissible;
  b = -1 ∨ b = 0 ∨ b = 1 by bAdmissible;
  done by cases {
    case a = -1: {
        done by cases {
          case b = -1: {
              Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 7
                  by Matrix.sumOfTwoSquaresUnitBorderCandidate_truant(
                      aSquareOne := (ring : (-(1 : ℤ)) * (-(1 : ℤ)) = 1),
                      bSquareOne := (ring : (-(1 : ℤ)) * (-(1 : ℤ)) = 1)) as truantReads;
              done by Or.introduceRight(Or.introduceLeft(truantReads))
            }
          case b = 0 ∨ b = 1: done by cases {
              case b = 0: {
                  Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 14
                      by Matrix.sumOfTwoSquaresOneUnitBorderCandidate_truant(
                          unitValue := (ring : (-(1 : ℤ)) * (-(1 : ℤ)) + 0 * 0 = 1)) as truantReads;
                  done by Or.introduceRight(Or.introduceRight(truantReads))
                }
              case b = 1: {
                  Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 7
                      by Matrix.sumOfTwoSquaresUnitBorderCandidate_truant(
                          aSquareOne := (ring : (-(1 : ℤ)) * (-(1 : ℤ)) = 1),
                          bSquareOne := (ring : (1 : ℤ) * 1 = 1)) as truantReads;
                  done by Or.introduceRight(Or.introduceLeft(truantReads))
                }
            }
        }
      }
    case a = 0 ∨ a = 1: done by cases {
        case a = 0: {
            done by cases {
              case b = -1: {
                  Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 14
                      by Matrix.sumOfTwoSquaresOneUnitBorderCandidate_truant(
                          unitValue := (ring : (0 : ℤ) * 0 + (-(1 : ℤ)) * (-(1 : ℤ)) = 1)) as truantReads;
                  done by Or.introduceRight(Or.introduceRight(truantReads))
                }
              case b = 0 ∨ b = 1: done by cases {
                  case b = 0: {
                      Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b))
                         = Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(0, b)) by substituting (a = 0)
                         = Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(0, 0)) by substituting (b = 0)
                         = 6 by Matrix.sumOfTwoSquaresZeroBorderCandidate_truant_six
                      as truantReads;
                      done by Or.introduceLeft(truantReads)
                    }
                  case b = 1: {
                      Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 14
                          by Matrix.sumOfTwoSquaresOneUnitBorderCandidate_truant(
                              unitValue := (ring : (0 : ℤ) * 0 + 1 * 1 = 1)) as truantReads;
                      done by Or.introduceRight(Or.introduceRight(truantReads))
                    }
                }
            }
          }
        case a = 1: {
            done by cases {
              case b = -1: {
                  Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 7
                      by Matrix.sumOfTwoSquaresUnitBorderCandidate_truant(
                          aSquareOne := (ring : (1 : ℤ) * 1 = 1),
                          bSquareOne := (ring : (-(1 : ℤ)) * (-(1 : ℤ)) = 1)) as truantReads;
                  done by Or.introduceRight(Or.introduceLeft(truantReads))
                }
              case b = 0 ∨ b = 1: done by cases {
                  case b = 0: {
                      Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 14
                          by Matrix.sumOfTwoSquaresOneUnitBorderCandidate_truant(
                              unitValue := (ring : (1 : ℤ) * 1 + 0 * 0 = 1)) as truantReads;
                      done by Or.introduceRight(Or.introduceRight(truantReads))
                    }
                  case b = 1: {
                      Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 7
                          by Matrix.sumOfTwoSquaresUnitBorderCandidate_truant(
                              aSquareOne := (ring : (1 : ℤ) * 1 = 1),
                              bSquareOne := (ring : (1 : ℤ) * 1 = 1)) as truantReads;
                      done by Or.introduceRight(Or.introduceLeft(truantReads))
                    }
                }
            }
          }
      }
  }
}

theorem Matrix.sumOfTwoSquares_escalation_rank_three_truant
        (B : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (escalation : Matrix.IsEscalation(Matrix.sumOfTwoSquaresForm, B))
        : Matrix.truant(B) = 6 ∨ Matrix.truant(B) = 7 ∨ Matrix.truant(B) = 14 := {
  choose a such that
      ∃ (b : ℤ).
        Integer.IsTernaryBorderValue(a)
          ∧ Integer.IsTernaryBorderValue(b)
          ∧ B = Matrix.borderedAssembly(
              Matrix.sumOfTwoSquaresForm,
              RingVector.twoCoordinates(a, b),
              (3 : ℤ))
      from Matrix.sumOfTwoSquares_escalation_nine_candidates(B := B, escalation := escalation);
  choose b such that
      Integer.IsTernaryBorderValue(a)
        ∧ Integer.IsTernaryBorderValue(b)
        ∧ B = Matrix.borderedAssembly(
            Matrix.sumOfTwoSquaresForm,
            RingVector.twoCoordinates(a, b),
            (3 : ℤ));
  Integer.IsTernaryBorderValue(a);
  Integer.IsTernaryBorderValue(b);
  B = Matrix.borderedAssembly(
      Matrix.sumOfTwoSquaresForm,
      RingVector.twoCoordinates(a, b),
      (3 : ℤ))
  as assembled;
  B = Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b) by assembled as candidateReads;
  Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 6
    ∨ Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 7
    ∨ Matrix.truant(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 14
      by Matrix.sumOfTwoSquaresUnitBorderCandidate_truant_classification;
  done by substituting candidateReads
}

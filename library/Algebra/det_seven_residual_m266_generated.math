theorem Natural.detSevenResidueCover_m266_table
        : ∀ (a : ℕ). a ≥ 0 → a < 588 →
          Natural.modulo(a, 4) ≠ 0 →
          Natural.modulo(a, 49) ≠ 0 →
          ¬(
            Natural.modulo(a, 12) ≠ 7
            ∧ Natural.modulo(a, 12) ≠ 10
            ∧ Natural.modulo(a, 49) ≠ 0
            ∧ Natural.modulo(a, 49) ≠ 21
            ∧ Natural.modulo(a, 49) ≠ 35
            ∧ Natural.modulo(a, 49) ≠ 42) →
          ∃ (t : ℕ). (t = 1 ∨ t = 2 ∨ t = 3 ∨ t = 4 ∨ t = 5 ∨ t = 6)
            ∧ Natural.DetSevenResidueSolution(266, a, t) := {
  take a : ℕ;
  suppose a ≥ 0 as aNonnegative;
  suppose a < 588 as aBelow;
  suppose Natural.modulo(a, 4) ≠ 0 as parityCondition;
  suppose Natural.modulo(a, 49) ≠ 0 as notMultipleFortyNine;
  suppose ¬(
            Natural.modulo(a, 12) ≠ 7
            ∧ Natural.modulo(a, 12) ≠ 10
            ∧ Natural.modulo(a, 49) ≠ 0
            ∧ Natural.modulo(a, 49) ≠ 21
            ∧ Natural.modulo(a, 49) ≠ 35
            ∧ Natural.modulo(a, 49) ≠ 42) as unsafe;
  choose t : ℕ such that
      (t = 1 ∨ t = 2 ∨ t = 3 ∨ t = 4 ∨ t = 5 ∨ t = 6)
      ∧ Natural.DetSevenSelectedM266(a, t)
      ∧ Natural.DetSevenResidueSolution(266, a, t)
      from Natural.detSevenResidueCover_m266_selected_table(
        a, aNonnegative, aBelow, parityCondition, notMultipleFortyNine, unsafe);
  witness t with {
    (t = 1 ∨ t = 2 ∨ t = 3 ∨ t = 4 ∨ t = 5 ∨ t = 6);
    Natural.DetSevenResidueSolution(266, a, t);
    done
  }
}


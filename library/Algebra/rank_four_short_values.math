-- Algebra/rank_four_short_values.math
--
-- The stable surface for the generated value-through-15 certificate table.

module Algebra.rank_four_short_values

import Algebra.rank_four_exceptional_truants_generated

definition Matrix.RepresentsThroughFifteen {n : ℕ}
        (A : Matrix(Integer.commutative_ring_bundle, n, n)) : Proposition :=
  ∀ (s : ℕ). s ≥ 1 → s < 16 → Matrix.Represents(A, (s : ℤ))

theorem Matrix.isometric_representsThroughFifteen {n : ℕ}
        (source target : Matrix(Integer.commutative_ring_bundle, n, n))
        (isometric : Matrix.IsIsometric(source, target))
        (targetRepresents : Matrix.RepresentsThroughFifteen(target))
        : Matrix.RepresentsThroughFifteen(source) := {
  take s : ℕ;
  suppose s ≥ 1;
  suppose s < 16;
  Matrix.Represents(target, (s : ℤ)) by targetRepresents;
  done by Matrix.isometric_represents(isometric := isometric)
}

definition Matrix.IsExceptionalRankFourNormalForm
        (A : Matrix(Integer.commutative_ring_bundle, 4, 4)) : Proposition :=
  A = Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 3)
  ∨ A = Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 7)
  ∨ A = Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 0, 0, 5)
  ∨ A = Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 1, 5)
  ∨ A = Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 1, 9)
  ∨ A = Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 2, 8)

theorem Matrix.isometric_exceptional_rankFour_truant
        (source target : Matrix(Integer.commutative_ring_bundle, 4, 4))
        (isometric : Matrix.IsIsometric(source, target))
        (exceptional : Matrix.IsExceptionalRankFourNormalForm(target))
        : Matrix.truant(source) = 10 ∨ Matrix.truant(source) = 15 := {
  target = Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 3)
    ∨ target = Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 7)
    ∨ target = Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 0, 0, 5)
    ∨ target = Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 1, 5)
    ∨ target = Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 1, 9)
    ∨ target = Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 2, 8) by exceptional;
  Matrix.IsIsometric(target, source) by Matrix.IsIsometric.symmetric(isometric := isometric);
  done by cases {
    case target = Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 3) as targetReads: {
      Matrix.IsIsometric(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 3), source)
          by substituting targetReads as concreteReverse;
      Matrix.truant(source) = 10 by Matrix.isometric_truant_equals(
          isometric := concreteReverse, isTruant := Matrix.oddC4R0C3_truant_ten) as truantReads;
      done by Or.introduceLeft(truantReads)
    }
    case target = Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 7) as targetReads: {
      Matrix.IsIsometric(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 7), source)
          by substituting targetReads as concreteReverse;
      Matrix.truant(source) = 10 by Matrix.isometric_truant_equals(
          isometric := concreteReverse, isTruant := Matrix.oddC4R2C7_truant_ten) as truantReads;
      done by Or.introduceLeft(truantReads)
    }
    case target = Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 0, 0, 5) as targetReads: {
      Matrix.IsIsometric(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 0, 0, 5), source)
          by substituting targetReads as concreteReverse;
      Matrix.truant(source) = 15 by Matrix.isometric_truant_equals(
          isometric := concreteReverse, isTruant := Matrix.weightedD5S0R0C5_truant_fifteen) as truantReads;
      done by Or.introduceRight(truantReads)
    }
    case target = Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 1, 5) as targetReads: {
      Matrix.IsIsometric(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 1, 5), source)
          by substituting targetReads as concreteReverse;
      Matrix.truant(source) = 15 by Matrix.isometric_truant_equals(
          isometric := concreteReverse, isTruant := Matrix.weightedD5S1R1C5_truant_fifteen) as truantReads;
      done by Or.introduceRight(truantReads)
    }
    case target = Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 1, 9) as targetReads: {
      Matrix.IsIsometric(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 1, 9), source)
          by substituting targetReads as concreteReverse;
      Matrix.truant(source) = 15 by Matrix.isometric_truant_equals(
          isometric := concreteReverse, isTruant := Matrix.weightedD5S1R1C9_truant_fifteen) as truantReads;
      done by Or.introduceRight(truantReads)
    }
    case target = Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 2, 8) as targetReads: {
      Matrix.IsIsometric(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 1, 2, 8), source)
          by substituting targetReads as concreteReverse;
      Matrix.truant(source) = 15 by Matrix.isometric_truant_equals(
          isometric := concreteReverse, isTruant := Matrix.weightedD5S1R2C8_truant_fifteen) as truantReads;
      done by Or.introduceRight(truantReads)
    }
  }
}

theorem Matrix.sumOfThreeSquaresRankFourCandidate_coordinateTuple_value
        (a b c x y z w : ℤ)
        : Matrix.quadraticForm(Matrix.sumOfThreeSquaresRankFourCandidate(a, b, c),
            (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4)))
          = x * x + y * y + z * z + 2 * a * x * w + 2 * b * y * w
            + 2 * c * z * w + 7 * (w * w) := {
  Matrix.quadraticForm(Matrix.sumOfThreeSquaresRankFourCandidate(a, b, c),
      (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4)))
     = RingVector.innerProduct(
         (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4)),
         (⟨x + a * w, y + b * w, z + c * w, a * x + b * y + c * z + 7 * w⟩
           : RingVector(Integer.commutative_ring_bundle, 4)))
         by substituting Matrix.sumOfThreeSquaresRankFourCandidate_apply_coordinateTuple
     = x * (x + a * w) + y * (y + b * w) + z * (z + c * w)
       + w * (a * x + b * y + c * z + 7 * w) by RingVector.innerProduct_fourCoordinates
     = x * x + y * y + z * z + 2 * a * x * w + 2 * b * y * w
       + 2 * c * z * w + 7 * (w * w) by ring;
  done
}

automatic theorem Matrix.sumOfThreeSquaresRankFourCandidate_coordinateTuple_computes
        (a b c x y z w target : ℤ)
        (scalarComputation : x * x + y * y + z * z + 2 * a * x * w + 2 * b * y * w
          + 2 * c * z * w + 7 * (w * w) = target)
        : Matrix.quadraticForm(Matrix.sumOfThreeSquaresRankFourCandidate(a, b, c),
            (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4))) = target := {
  Matrix.quadraticForm(Matrix.sumOfThreeSquaresRankFourCandidate(a, b, c),
      (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4)))
     = x * x + y * y + z * z + 2 * a * x * w + 2 * b * y * w
       + 2 * c * z * w + 7 * (w * w)
         by Matrix.sumOfThreeSquaresRankFourCandidate_coordinateTuple_value
     = target by scalarComputation;
  done
}

theorem Matrix.sumOfTwoSquaresPlusScaledSquareRankFourRepresentative_coordinateTuple_value
        (d residue corner x y z w : ℤ)
        : Matrix.quadraticForm(
            Matrix.sumOfTwoSquaresPlusScaledSquareRankFourRepresentative(d, residue, corner),
            (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4)))
          = x * x + y * y + d * (z * z) + 2 * residue * z * w + corner * (w * w) := {
  Matrix.quadraticForm(
      Matrix.sumOfTwoSquaresPlusScaledSquareRankFourRepresentative(d, residue, corner),
      (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4)))
     = RingVector.innerProduct(
         (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4)),
         (⟨x, y, d * z + residue * w, residue * z + corner * w⟩
           : RingVector(Integer.commutative_ring_bundle, 4)))
         by substituting Matrix.sumOfTwoSquaresPlusScaledSquareRankFourRepresentative_apply_coordinateTuple
     = x * x + y * y + z * (d * z + residue * w) + w * (residue * z + corner * w)
         by RingVector.innerProduct_fourCoordinates
     = x * x + y * y + d * (z * z) + 2 * residue * z * w + corner * (w * w) by ring;
  done
}

automatic theorem Matrix.sumOfTwoSquaresPlusScaledSquareRankFourRepresentative_coordinateTuple_computes
        (d residue corner x y z w target : ℤ)
        (scalarComputation : x * x + y * y + d * (z * z) + 2 * residue * z * w
          + corner * (w * w) = target)
        : Matrix.quadraticForm(
            Matrix.sumOfTwoSquaresPlusScaledSquareRankFourRepresentative(d, residue, corner),
            (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4))) = target := {
  Matrix.quadraticForm(
      Matrix.sumOfTwoSquaresPlusScaledSquareRankFourRepresentative(d, residue, corner),
      (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4)))
     = x * x + y * y + d * (z * z) + 2 * residue * z * w + corner * (w * w)
         by Matrix.sumOfTwoSquaresPlusScaledSquareRankFourRepresentative_coordinateTuple_value
     = target by scalarComputation;
  done
}

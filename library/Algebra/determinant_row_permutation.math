-- Algebra/determinant_row_permutation.math
--
-- Permuting the rows of a matrix multiplies its determinant by the sign of
-- the permutation (Stage H brick 6d of PLAN_LINEAR_ALGEBRA.md). Stated as the
-- reindexing identity the det(AB) proof needs: for a permutation p,
--   Σ_σ sign(σ) ∏_i B(p·i, σ·i) = sign(p) · det(B).
-- Reindex the σ-sum by σ ↦ σ∘p (a bijection of Sₙ) and the index product by
-- p; the sign multiplicativity supplies the sign(p) factor.

module Algebra.determinant_row_permutation

import Logic.basics
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.addition
import Integer.negation
import Lists.list
import Lists.map
import Lists.distinct
import Lists.length
import Lists.permutation
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.commutative_ring_aggregation
import Algebra.ring_from_integer
import Algebra.finite_permutation
import Algebra.permutation_enumeration
import Algebra.permutation_sign
import Algebra.matrix
import Algebra.determinant
import Algebra.alternating_collapse

-- The initial-ring map sends a product of two units (±1) to the product of
-- their images — the restricted multiplicativity that dodges a general
-- `from_integer_multiply`, by casing on both signs.
theorem CommutativeRing.from_integer_multiply_units (r : CommutativeRing) (z w : ℤ)
        (zUnit : z = 1 ∨ z = Integer.negate(1))
        (wUnit : w = 1 ∨ w = Integer.negate(1))
        : CommutativeRing.from_integer(r, Integer.multiply(z, w))
          = CommutativeRing.from_integer(r, z) * CommutativeRing.from_integer(r, w) := {
  -- Casing on the unit disjunctions substitutes z, w into the goal, so each
  -- arm proves a concrete identity; meet the two sides at a concrete ±one.
  done by cases {
    case z = 1 as zPositive: {
        done by cases {
          case w = 1 as wPositive: {
              Integer.multiply(1, 1) = 1 as productValue;
              CommutativeRing.from_integer(r, 1) * CommutativeRing.from_integer(r, 1)
                 = CommutativeRing.one(r) * CommutativeRing.one(r)   by substituting CommutativeRing.from_integer_one
                 = CommutativeRing.one(r)
                 as rightSide;
              CommutativeRing.from_integer(r, Integer.multiply(1, 1))
                 = CommutativeRing.from_integer(r, 1)       by substituting productValue
                 = CommutativeRing.one(r)
                 = CommutativeRing.from_integer(r, 1) * CommutativeRing.from_integer(r, 1)   by rightSide
            }
          case w = Integer.negate(1) as wNegative: {
              Integer.multiply(1, Integer.negate(1)) = Integer.negate(1) as productValue;
              CommutativeRing.from_integer(r, 1) * CommutativeRing.from_integer(r, Integer.negate(1))
                 = CommutativeRing.one(r) * CommutativeRing.from_integer(r, Integer.negate(1))   by substituting CommutativeRing.from_integer_one
                 = CommutativeRing.one(r) * CommutativeRing.negate(CommutativeRing.one(r))              by substituting CommutativeRing.from_integer_negate_one
                 = CommutativeRing.negate(CommutativeRing.one(r))
                 as rightSide;
              CommutativeRing.from_integer(r, Integer.multiply(1, Integer.negate(1)))
                 = CommutativeRing.from_integer(r, Integer.negate(1))                  by substituting productValue
                 = CommutativeRing.negate(CommutativeRing.one(r))
                 = CommutativeRing.from_integer(r, 1) * CommutativeRing.from_integer(r, Integer.negate(1))   by rightSide
            }
        }
      }
    case z = Integer.negate(1) as zNegative: {
        done by cases {
          case w = 1 as wPositive: {
              Integer.multiply(Integer.negate(1), 1) = Integer.negate(1) as productValue;
              CommutativeRing.from_integer(r, Integer.negate(1)) * CommutativeRing.from_integer(r, 1)
                 = CommutativeRing.negate(CommutativeRing.one(r)) * CommutativeRing.from_integer(r, 1)   by substituting CommutativeRing.from_integer_negate_one
                 = CommutativeRing.negate(CommutativeRing.one(r)) * CommutativeRing.one(r)              by substituting CommutativeRing.from_integer_one
                 = CommutativeRing.negate(CommutativeRing.one(r))
                 as rightSide;
              CommutativeRing.from_integer(r, Integer.multiply(Integer.negate(1), 1))
                 = CommutativeRing.from_integer(r, Integer.negate(1))                  by substituting productValue
                 = CommutativeRing.negate(CommutativeRing.one(r))
                 = CommutativeRing.from_integer(r, Integer.negate(1)) * CommutativeRing.from_integer(r, 1)   by rightSide
            }
          case w = Integer.negate(1) as wNegative: {
              Integer.multiply(Integer.negate(1), Integer.negate(1)) = 1 as productValue;
              CommutativeRing.from_integer(r, Integer.negate(1)) * CommutativeRing.from_integer(r, Integer.negate(1))
                 = CommutativeRing.negate(CommutativeRing.one(r)) * CommutativeRing.from_integer(r, Integer.negate(1))
                       by substituting CommutativeRing.from_integer_negate_one
                 = CommutativeRing.negate(CommutativeRing.one(r)) * CommutativeRing.negate(CommutativeRing.one(r))
                       by substituting CommutativeRing.from_integer_negate_one
                 = CommutativeRing.one(r)                                              by ring
                 as rightSide;
              CommutativeRing.from_integer(r, Integer.multiply(Integer.negate(1), Integer.negate(1)))
                 = CommutativeRing.from_integer(r, 1)                                  by substituting productValue
                 = CommutativeRing.one(r)
                 = CommutativeRing.from_integer(r, Integer.negate(1)) * CommutativeRing.from_integer(r, Integer.negate(1))
                       by rightSide
            }
        }
      }
  }
}

-- The image of the index enumeration under a permutation is a rearrangement
-- of the enumeration itself.
theorem Permutation.apply_map_permutes_enumerate {n : ℕ} (p : Permutation(n))
        : List.Permutation(NaturalsBelow(n),
              List.map(
                  (i : NaturalsBelow(n)) ↦ p(i), NaturalsBelow.enumerate(n)),
              NaturalsBelow.enumerate(n)) := {
  (∀ (x y : NaturalsBelow(n)). p(x) = p(y) → x = y)
      by (x y : NaturalsBelow(n)) (equalImages : p(x) = p(y)) ↦
           Permutation.apply_injective;
  List.Distinct(NaturalsBelow(n), NaturalsBelow.enumerate(n))
      by NaturalsBelow.enumerate_distinct;
  List.Distinct(NaturalsBelow(n),
        List.map((i : NaturalsBelow(n)) ↦ p(i), NaturalsBelow.enumerate(n)))
      by List.map_distinct;
  (∀ (x : NaturalsBelow(n)). x ∈
        List.map((i : NaturalsBelow(n)) ↦ p(i), NaturalsBelow.enumerate(n))
        → x ∈ NaturalsBelow.enumerate(n))
      by (x : NaturalsBelow(n)) (xInMap : x ∈
          List.map((i : NaturalsBelow(n)) ↦ p(i), NaturalsBelow.enumerate(n))) ↦
            NaturalsBelow.enumerate_complete;
  length(List.map((i : NaturalsBelow(n)) ↦ p(i), NaturalsBelow.enumerate(n)))
      = length(NaturalsBelow.enumerate(n))
      by List.map_length;
  done by List.permutation_of_distinct_inclusion
}

-- Reindexing the row product by p: ∏_i B(p·i, ρ(p·i)) = ∏_j B(j, ρ·j).
theorem Matrix.product_row_reindex {r : CommutativeRing} {n : ℕ}
        (B : Matrix(r, n, n)) (p rho : Permutation(n))
        : CommutativeRing.productOver(
              (i : NaturalsBelow(n)) ↦ B(p(i), rho(p(i))),
              NaturalsBelow.enumerate(n))
          = CommutativeRing.productOver(
              (j : NaturalsBelow(n)) ↦ B(j, rho(j)),
              NaturalsBelow.enumerate(n)) :=
  CommutativeRing.productOver(
        (i : NaturalsBelow(n)) ↦ B(p(i), rho(p(i))),
        NaturalsBelow.enumerate(n))
     = CommutativeRing.productOver(
           (j : NaturalsBelow(n)) ↦ B(j, rho(j)),
           List.map((i : NaturalsBelow(n)) ↦ p(i), NaturalsBelow.enumerate(n)))
           by CommutativeRing.productOver_map
     = CommutativeRing.productOver(
           (j : NaturalsBelow(n)) ↦ B(j, rho(j)),
           NaturalsBelow.enumerate(n))
           by CommutativeRing.productOver_permutation

-- Row permutation scales the determinant by the sign.
theorem Matrix.determinant_row_permutation {r : CommutativeRing} {n : ℕ}
        (B : Matrix(r, n, n)) (p : Permutation(n))
        : CommutativeRing.sumOver(
              (sigma : Permutation(n)) ↦
                  CommutativeRing.from_integer(r, Permutation.sign(sigma))
                      * CommutativeRing.productOver(
                            (i : NaturalsBelow(n)) ↦ B(p(i), sigma(i)),
                            NaturalsBelow.enumerate(n)),
              Permutation.allPermutations(n))
          = CommutativeRing.from_integer(r, Permutation.sign(p)) * Matrix.determinant(B) := {
  -- σ ↦ σ∘p permutes the permutation list.
  (∀ (a b : Permutation(n)). a ∘ p = b ∘ p → a = b)
      by (a b : Permutation(n)) (equalComposites : a ∘ p = b ∘ p) ↦
           Permutation.compose_right_cancel;
  List.Distinct(Permutation(n), Permutation.allPermutations(n))
      by Permutation.allPermutations_distinct;
  List.Distinct(Permutation(n), List.map((rho : Permutation(n)) ↦ rho ∘ p, Permutation.allPermutations(n)))
      by List.map_distinct;
  (∀ (x : Permutation(n)). x ∈
        List.map((rho : Permutation(n)) ↦ rho ∘ p, Permutation.allPermutations(n))
        → x ∈ Permutation.allPermutations(n))
      by (x : Permutation(n)) (xInMap : x ∈
          List.map((rho : Permutation(n)) ↦ rho ∘ p, Permutation.allPermutations(n))) ↦
            Permutation.allPermutations_complete;
  length(List.map((rho : Permutation(n)) ↦ rho ∘ p, Permutation.allPermutations(n)))
      = length(Permutation.allPermutations(n))
      by List.map_length;
  List.Permutation(Permutation(n),
        List.map((rho : Permutation(n)) ↦ rho ∘ p, Permutation.allPermutations(n)),
        Permutation.allPermutations(n))
      by List.permutation_of_distinct_inclusion;
  List.Permutation(Permutation(n), Permutation.allPermutations(n),
          List.map((rho : Permutation(n)) ↦ rho ∘ p, Permutation.allPermutations(n)))
      by List.Permutation.symmetric;

  -- Each reindexed term: sign and product factor through sign(p) and det(B).
  ∀ (rho : Permutation(n)).
      CommutativeRing.from_integer(r, Permutation.sign(rho ∘ p))
          * CommutativeRing.productOver(
                (i : NaturalsBelow(n)) ↦ B(p(i), (rho ∘ p)(i)),
                NaturalsBelow.enumerate(n))
      = CommutativeRing.from_integer(r, Permutation.sign(p))
          * (CommutativeRing.from_integer(r, Permutation.sign(rho))
                * CommutativeRing.productOver(
                      (j : NaturalsBelow(n)) ↦ B(j, rho(j)),
                      NaturalsBelow.enumerate(n)))
      by (rho : Permutation(n)) ↦ {
          CommutativeRing.productOver(
                (i : NaturalsBelow(n)) ↦ B(p(i), (rho ∘ p)(i)),
                NaturalsBelow.enumerate(n))
             = CommutativeRing.productOver(
                   (j : NaturalsBelow(n)) ↦ B(j, rho(j)),
                   NaturalsBelow.enumerate(n))
                 by Matrix.product_row_reindex(p := p, rho := rho) as productReindexed;
          Permutation.sign(rho) = 1 ∨ Permutation.sign(rho) = Integer.negate(1)
              by Permutation.sign_is_unit;
          Permutation.sign(p) = 1 ∨ Permutation.sign(p) = Integer.negate(1)
              by Permutation.sign_is_unit;
          CommutativeRing.from_integer(r, Permutation.sign(rho ∘ p))
             = CommutativeRing.from_integer(r, Integer.multiply(Permutation.sign(rho), Permutation.sign(p)))
                   by substituting Permutation.sign_compose
             = CommutativeRing.from_integer(r, Permutation.sign(rho)) * CommutativeRing.from_integer(r, Permutation.sign(p))
                   by CommutativeRing.from_integer_multiply_units
                 as signReindexed;
          CommutativeRing.from_integer(r, Permutation.sign(rho ∘ p))
                * CommutativeRing.productOver(
                      (i : NaturalsBelow(n)) ↦ B(p(i), (rho ∘ p)(i)),
                      NaturalsBelow.enumerate(n))
             = (CommutativeRing.from_integer(r, Permutation.sign(rho)) * CommutativeRing.from_integer(r, Permutation.sign(p)))
                   * CommutativeRing.productOver(
                         (i : NaturalsBelow(n)) ↦ B(p(i), (rho ∘ p)(i)),
                         NaturalsBelow.enumerate(n))
                   by substituting signReindexed
             = (CommutativeRing.from_integer(r, Permutation.sign(rho)) * CommutativeRing.from_integer(r, Permutation.sign(p)))
                   * CommutativeRing.productOver(
                         (j : NaturalsBelow(n)) ↦ B(j, rho(j)),
                         NaturalsBelow.enumerate(n))
                   by substituting productReindexed
             = CommutativeRing.from_integer(r, Permutation.sign(p))
                   * (CommutativeRing.from_integer(r, Permutation.sign(rho))
                         * CommutativeRing.productOver(
                               (j : NaturalsBelow(n)) ↦ B(j, rho(j)),
                               NaturalsBelow.enumerate(n)))
                   by ring
        };

  CommutativeRing.sumOver(
        (sigma : Permutation(n)) ↦
            CommutativeRing.from_integer(r, Permutation.sign(sigma))
                * CommutativeRing.productOver(
                      (i : NaturalsBelow(n)) ↦ B(p(i), sigma(i)),
                      NaturalsBelow.enumerate(n)),
        Permutation.allPermutations(n))
     = CommutativeRing.sumOver(
           (sigma : Permutation(n)) ↦
               CommutativeRing.from_integer(r, Permutation.sign(sigma))
                   * CommutativeRing.productOver(
                         (i : NaturalsBelow(n)) ↦ B(p(i), sigma(i)),
                         NaturalsBelow.enumerate(n)),
           List.map((rho : Permutation(n)) ↦ rho ∘ p, Permutation.allPermutations(n)))
           by CommutativeRing.sumOver_permutation
     = CommutativeRing.sumOver(
           (rho : Permutation(n)) ↦
               CommutativeRing.from_integer(r, Permutation.sign(rho ∘ p))
                   * CommutativeRing.productOver(
                         (i : NaturalsBelow(n)) ↦ B(p(i), (rho ∘ p)(i)),
                         NaturalsBelow.enumerate(n)),
           Permutation.allPermutations(n))
           by CommutativeRing.sumOver_map
     = CommutativeRing.sumOver(
           (rho : Permutation(n)) ↦
               CommutativeRing.from_integer(r, Permutation.sign(p))
                   * (CommutativeRing.from_integer(r, Permutation.sign(rho))
                         * CommutativeRing.productOver(
                               (j : NaturalsBelow(n)) ↦ B(j, rho(j)),
                               NaturalsBelow.enumerate(n))),
           Permutation.allPermutations(n))
           by CommutativeRing.sumOver_congruence
     = CommutativeRing.from_integer(r, Permutation.sign(p))
           * CommutativeRing.sumOver(
                 (rho : Permutation(n)) ↦
                     CommutativeRing.from_integer(r, Permutation.sign(rho))
                         * CommutativeRing.productOver(
                               (j : NaturalsBelow(n)) ↦ B(j, rho(j)),
                               NaturalsBelow.enumerate(n)),
                 Permutation.allPermutations(n))
           by CommutativeRing.sumOver_scale_left
     = CommutativeRing.from_integer(r, Permutation.sign(p)) * Matrix.determinant(B)
}

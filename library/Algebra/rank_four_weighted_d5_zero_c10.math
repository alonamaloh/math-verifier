module Algebra.rank_four_weighted_d5_zero_c10

import Algebra.rank_four_weighted_d5_zero_c10_cover

theorem Matrix.weightedD5S0R0C10_universal_of_one_two_five_converse (converse : Matrix.OneTwoFiveConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 0, 0, 10)) :=
  by Matrix.weightedZero_universal_of_residual_cover(5, 10, Matrix.oneTwoFiveResidualCover_ten_of_converse(converse))

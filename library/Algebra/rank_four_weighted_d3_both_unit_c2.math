module Algebra.rank_four_weighted_d3_both_unit_c2

import Algebra.rank_four_weighted_d3_both_unit_universality

theorem Matrix.weightedD3S1R1C2_universal_of_two_three_six_converse (converse : Integer.TwoThreeSixLocalConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 1, 1, 2)) :=
  by Matrix.weightedD3BothUnit_universal_of_two_three_six_converse(
      converse, corner := 2, coefficient := 7, core := 53, coefficientShape := done, coreSum := done,
      coreAdmissible := (q : ℕ) ↦ {
        32 * q + 53 = 8 * (4 * q + 6) + 5 by ring as coreReads;
        suppose Natural.IsThreeSquareObstruction(32 * q + 53) as obstruction;
        Natural.IsThreeSquareObstruction(8 * (4 * q + 6) + 5) by substituting coreReads as transformedObstruction;
        done by Natural.eight_times_plus_five_not_obstruction(4 * q + 6)(transformedObstruction)
      })

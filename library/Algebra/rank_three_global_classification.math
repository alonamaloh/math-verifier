-- Algebra/rank_three_global_classification.math
--
-- The two rank-two branches, transported across parent isometry and merged
-- into the nine ternary parents that feed the rank-four classifiers.

module Algebra.rank_three_global_classification

import Algebra.rank_three_representative_truants
import Algebra.rank_four_weighted_diagonal_orbits

definition Matrix.IsRankThreeEscalatorRepresentative
        (A : Matrix(Integer.commutative_ring_bundle, 3, 3)) : Proposition :=
  Matrix.IsIsometric(A, Matrix.sumOfThreeSquaresForm)
    ∨ Matrix.IsIsometric(A, Matrix.sumOfTwoSquaresPlusTripleSquareForm)
    ∨ Matrix.IsIsometric(A, Matrix.sumOfTwoSquaresPlusDoubleSquareForm)
    ∨ Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareDiagonalForm(2))
    ∨ Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareDiagonalForm(3))
    ∨ Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareDiagonalForm(4))
    ∨ Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareDiagonalForm(5))
    ∨ Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareOddForm(4))
    ∨ Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareOddForm(5))

theorem Matrix.rankThreeEscalatorRepresentative_threeSquares
        (A : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (isometric : Matrix.IsIsometric(A, Matrix.sumOfThreeSquaresForm))
        : Matrix.IsRankThreeEscalatorRepresentative(A) :=
  by Or.introduceLeft(isometric)

theorem Matrix.rankThreeEscalatorRepresentative_triple
        (A : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (isometric : Matrix.IsIsometric(A, Matrix.sumOfTwoSquaresPlusTripleSquareForm))
        : Matrix.IsRankThreeEscalatorRepresentative(A) :=
  by Or.introduceRight(Or.introduceLeft(isometric))

theorem Matrix.rankThreeEscalatorRepresentative_double
        (A : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (isometric : Matrix.IsIsometric(A, Matrix.sumOfTwoSquaresPlusDoubleSquareForm))
        : Matrix.IsRankThreeEscalatorRepresentative(A) :=
  by Or.introduceRight(Or.introduceRight(Or.introduceLeft(isometric)))

theorem Matrix.rankThreeEscalatorRepresentative_weightedTwo
        (A : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (isometric : Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareDiagonalForm(2)))
        : Matrix.IsRankThreeEscalatorRepresentative(A) :=
  by Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceLeft(isometric))))

theorem Matrix.rankThreeEscalatorRepresentative_weightedThree
        (A : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (isometric : Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareDiagonalForm(3)))
        : Matrix.IsRankThreeEscalatorRepresentative(A) :=
  by Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceLeft(isometric)))))

theorem Matrix.rankThreeEscalatorRepresentative_weightedFour
        (A : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (isometric : Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareDiagonalForm(4)))
        : Matrix.IsRankThreeEscalatorRepresentative(A) :=
  by Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(
    Or.introduceRight(Or.introduceLeft(isometric))))))

theorem Matrix.rankThreeEscalatorRepresentative_weightedFive
        (A : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (isometric : Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareDiagonalForm(5)))
        : Matrix.IsRankThreeEscalatorRepresentative(A) :=
  by Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(
    Or.introduceRight(Or.introduceRight(Or.introduceLeft(isometric)))))))

theorem Matrix.rankThreeEscalatorRepresentative_oddFour
        (A : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (isometric : Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareOddForm(4)))
        : Matrix.IsRankThreeEscalatorRepresentative(A) :=
  by Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(
    Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceLeft(isometric))))))))

theorem Matrix.rankThreeEscalatorRepresentative_oddFive
        (A : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (isometric : Matrix.IsIsometric(A, Matrix.squarePlusDoubleSquareOddForm(5)))
        : Matrix.IsRankThreeEscalatorRepresentative(A) :=
  by Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(
    Or.introduceRight(Or.introduceRight(Or.introduceRight(Or.introduceRight(isometric))))))))

theorem Matrix.sumOfTwoSquaresUnitBorderCandidate_is_rankThreeRepresentative
        (a b : ℤ)
        (aAdmissible : Integer.IsTernaryBorderValue(a))
        (bAdmissible : Integer.IsTernaryBorderValue(b))
        : Matrix.IsRankThreeEscalatorRepresentative(
            Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) := {
  a = -1 ∨ a = 0 ∨ a = 1 by aAdmissible;
  b = -1 ∨ b = 0 ∨ b = 1 by bAdmissible;
  done by cases {
    case a = -1: done by cases {
      case b = -1: {
        Matrix.IsIsometric(Matrix.sumOfTwoSquaresUnitBorderCandidate(-1, -1), Matrix.sumOfThreeSquaresForm)
            by Matrix.IsIsometric.symmetric(
              isometric := Matrix.sumOfThreeSquaresForm_isometric_unitBorderCandidate(
                a := -1, b := -1,
                aSquareOne := (ring : (-(1 : ℤ)) * -1 = 1),
                bSquareOne := (ring : (-(1 : ℤ)) * -1 = 1)));
        done by Matrix.rankThreeEscalatorRepresentative_threeSquares
      }
      case b = 0 ∨ b = 1: done by cases {
        case b = 0: {
          Matrix.IsIsometric(Matrix.sumOfTwoSquaresUnitBorderCandidate(-1, 0), Matrix.sumOfTwoSquaresPlusDoubleSquareForm)
              by Matrix.IsIsometric.symmetric(
                isometric := Matrix.sumOfTwoSquaresPlusDoubleSquareForm_isometric_oneUnitBorderCandidate(
                  a := -1, b := 0,
                  unitValue := (ring : (-(1 : ℤ)) * -1 + 0 * 0 = 1)));
          done by Matrix.rankThreeEscalatorRepresentative_double
        }
        case b = 1: {
          Matrix.IsIsometric(Matrix.sumOfTwoSquaresUnitBorderCandidate(-1, 1), Matrix.sumOfThreeSquaresForm)
              by Matrix.IsIsometric.symmetric(
                isometric := Matrix.sumOfThreeSquaresForm_isometric_unitBorderCandidate(
                  a := -1, b := 1,
                  aSquareOne := (ring : (-(1 : ℤ)) * -1 = 1),
                  bSquareOne := (ring : (1 : ℤ) * 1 = 1)));
          done by Matrix.rankThreeEscalatorRepresentative_threeSquares
        }
      }
    }
    case a = 0 ∨ a = 1: done by cases {
      case a = 0: done by cases {
        case b = -1: {
          Matrix.IsIsometric(Matrix.sumOfTwoSquaresUnitBorderCandidate(0, -1), Matrix.sumOfTwoSquaresPlusDoubleSquareForm)
              by Matrix.IsIsometric.symmetric(
                isometric := Matrix.sumOfTwoSquaresPlusDoubleSquareForm_isometric_oneUnitBorderCandidate(
                  a := 0, b := -1,
                  unitValue := (ring : (0 : ℤ) * 0 + (-(1 : ℤ)) * -1 = 1)));
          done by Matrix.rankThreeEscalatorRepresentative_double
        }
        case b = 0 ∨ b = 1: done by cases {
          case b = 0: {
            Matrix.IsIsometric(Matrix.sumOfTwoSquaresUnitBorderCandidate(0, 0), Matrix.sumOfTwoSquaresPlusTripleSquareForm)
                by Matrix.IsIsometric.symmetric(
                  isometric := Matrix.sumOfTwoSquaresPlusTripleSquareForm_isometric_zeroBorderCandidate);
            done by Matrix.rankThreeEscalatorRepresentative_triple
          }
          case b = 1: {
            Matrix.IsIsometric(Matrix.sumOfTwoSquaresUnitBorderCandidate(0, 1), Matrix.sumOfTwoSquaresPlusDoubleSquareForm)
                by Matrix.IsIsometric.symmetric(
                  isometric := Matrix.sumOfTwoSquaresPlusDoubleSquareForm_isometric_oneUnitBorderCandidate(
                    a := 0, b := 1,
                    unitValue := (ring : (0 : ℤ) * 0 + 1 * 1 = 1)));
            done by Matrix.rankThreeEscalatorRepresentative_double
          }
        }
      }
      case a = 1: done by cases {
        case b = -1: {
          Matrix.IsIsometric(Matrix.sumOfTwoSquaresUnitBorderCandidate(1, -1), Matrix.sumOfThreeSquaresForm)
              by Matrix.IsIsometric.symmetric(
                isometric := Matrix.sumOfThreeSquaresForm_isometric_unitBorderCandidate(
                  a := 1, b := -1,
                  aSquareOne := (ring : (1 : ℤ) * 1 = 1),
                  bSquareOne := (ring : (-(1 : ℤ)) * -1 = 1)));
          done by Matrix.rankThreeEscalatorRepresentative_threeSquares
        }
        case b = 0 ∨ b = 1: done by cases {
          case b = 0: {
            Matrix.IsIsometric(Matrix.sumOfTwoSquaresUnitBorderCandidate(1, 0), Matrix.sumOfTwoSquaresPlusDoubleSquareForm)
                by Matrix.IsIsometric.symmetric(
                  isometric := Matrix.sumOfTwoSquaresPlusDoubleSquareForm_isometric_oneUnitBorderCandidate(
                    a := 1, b := 0,
                    unitValue := (ring : (1 : ℤ) * 1 + 0 * 0 = 1)));
            done by Matrix.rankThreeEscalatorRepresentative_double
          }
          case b = 1: {
            Matrix.IsIsometric(Matrix.sumOfTwoSquaresUnitBorderCandidate(1, 1), Matrix.sumOfThreeSquaresForm)
                by Matrix.IsIsometric.symmetric(
                  isometric := Matrix.sumOfThreeSquaresForm_isometric_unitBorderCandidate(
                    a := 1, b := 1,
                    aSquareOne := (ring : (1 : ℤ) * 1 = 1),
                    bSquareOne := (ring : (1 : ℤ) * 1 = 1)));
            done by Matrix.rankThreeEscalatorRepresentative_threeSquares
          }
        }
      }
    }
  }
}

theorem Matrix.sumOfTwoSquares_escalation_three_representatives
        (B : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (escalation : Matrix.IsEscalation(Matrix.sumOfTwoSquaresForm, B))
        : Matrix.IsRankThreeEscalatorRepresentative(B) := {
  choose a such that ∃ (b : ℤ).
      Integer.IsTernaryBorderValue(a) ∧ Integer.IsTernaryBorderValue(b)
        ∧ B = Matrix.borderedAssembly(Matrix.sumOfTwoSquaresForm, RingVector.twoCoordinates(a, b), 3)
      from Matrix.sumOfTwoSquares_escalation_nine_candidates(B := B, escalation := escalation);
  choose b such that Integer.IsTernaryBorderValue(a) ∧ Integer.IsTernaryBorderValue(b)
        ∧ B = Matrix.borderedAssembly(Matrix.sumOfTwoSquaresForm, RingVector.twoCoordinates(a, b), 3);
  Integer.IsTernaryBorderValue(a) as aAdmissible;
  Integer.IsTernaryBorderValue(b) as bAdmissible;
  B = Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b) by substitution as candidateReads;
  Matrix.IsRankThreeEscalatorRepresentative(Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b))
      by Matrix.sumOfTwoSquaresUnitBorderCandidate_is_rankThreeRepresentative(
        aAdmissible := aAdmissible, bAdmissible := bAdmissible);
  done by substituting candidateReads
}

theorem Matrix.squarePlusDoubleSquareDiagonalForm_one_isometric_double
        : Matrix.IsIsometric(Matrix.squarePlusDoubleSquareDiagonalForm(1), Matrix.sumOfTwoSquaresPlusDoubleSquareForm) := {
  let U : Matrix(Integer.commutative_ring_bundle, 3, 3) := Matrix.swapLastTwoCoordinates3;
  let source : Matrix(Integer.commutative_ring_bundle, 3, 3) := Matrix.squarePlusDoubleSquareDiagonalForm(1);
  let target : Matrix(Integer.commutative_ring_bundle, 3, 3) := Matrix.sumOfTwoSquaresPlusDoubleSquareForm;
  Matrix.IsInvertible(U) by Matrix.swapLastTwoCoordinates3_invertible;
  target
     = Matrix.sumOfTwoSquaresPlusScaledSquareForm(2)
         by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_is_scaled_diagonal
     = Uᵀ * Matrix.squarePlusDoublePlusScaledSquareForm(1) * U
         by Equality.symmetry(Matrix.swapLastTwoCoordinates3_changes_weighted_one_to_double_diagonal)
     = Uᵀ * source * U
         by substituting Matrix.squarePlusDoubleSquareDiagonalForm_is_scaled_family(1);
  witness U with done
}

theorem Matrix.squarePlusDoubleSquareRankThreeRepresentative_is_global
        (B : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (classified : Matrix.IsSquarePlusDoubleSquareRankThreeRepresentative(B))
        : Matrix.IsRankThreeEscalatorRepresentative(B) := {
  done by cases {
    case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(1)) as isometric: {
      Matrix.IsIsometric(B, Matrix.sumOfTwoSquaresPlusDoubleSquareForm)
          by Matrix.IsIsometric.transitive(
            leftIsometric := isometric,
            rightIsometric := Matrix.squarePlusDoubleSquareDiagonalForm_one_isometric_double);
      done by Matrix.rankThreeEscalatorRepresentative_double
    }
    case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(2))
      ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(3))
      ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(4))
      ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(5))
      ∨ Matrix.IsIsometric(B, Matrix.sumOfThreeSquaresForm)
      ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(4))
      ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
        case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(2)):
          done by Matrix.rankThreeEscalatorRepresentative_weightedTwo
        case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(3))
          ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(4))
          ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(5))
          ∨ Matrix.IsIsometric(B, Matrix.sumOfThreeSquaresForm)
          ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(4))
          ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
            case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(3)):
              done by Matrix.rankThreeEscalatorRepresentative_weightedThree
            case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(4))
              ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(5))
              ∨ Matrix.IsIsometric(B, Matrix.sumOfThreeSquaresForm)
              ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(4))
              ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
                case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(4)):
                  done by Matrix.rankThreeEscalatorRepresentative_weightedFour
                case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(5))
                  ∨ Matrix.IsIsometric(B, Matrix.sumOfThreeSquaresForm)
                  ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(4))
                  ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
                    case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareDiagonalForm(5)):
                      done by Matrix.rankThreeEscalatorRepresentative_weightedFive
                    case Matrix.IsIsometric(B, Matrix.sumOfThreeSquaresForm)
                      ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(4))
                      ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
                        case Matrix.IsIsometric(B, Matrix.sumOfThreeSquaresForm):
                          done by Matrix.rankThreeEscalatorRepresentative_threeSquares
                        case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(4))
                          ∨ Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
                            case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(4)):
                              done by Matrix.rankThreeEscalatorRepresentative_oddFour
                            case Matrix.IsIsometric(B, Matrix.squarePlusDoubleSquareOddForm(5)):
                              done by Matrix.rankThreeEscalatorRepresentative_oddFive
                          }
                      }
                  }
              }
          }
      }
  }
}

theorem Matrix.rankThreeEscalatorRepresentative_transport
        (source target : Matrix(Integer.commutative_ring_bundle, 3, 3))
        (sourceIsometric : Matrix.IsIsometric(source, target))
        (targetRepresentative : Matrix.IsRankThreeEscalatorRepresentative(target))
        : Matrix.IsRankThreeEscalatorRepresentative(source) := {
  done by cases {
    case Matrix.IsIsometric(target, Matrix.sumOfThreeSquaresForm) as classified:
      done by Matrix.rankThreeEscalatorRepresentative_threeSquares(
        isometric := Matrix.IsIsometric.transitive(
          leftIsometric := sourceIsometric, rightIsometric := classified))
    case Matrix.IsIsometric(target, Matrix.sumOfTwoSquaresPlusTripleSquareForm)
      ∨ Matrix.IsIsometric(target, Matrix.sumOfTwoSquaresPlusDoubleSquareForm)
      ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(2))
      ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(3))
      ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(4))
      ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(5))
      ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(4))
      ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
        case Matrix.IsIsometric(target, Matrix.sumOfTwoSquaresPlusTripleSquareForm) as classified:
          done by Matrix.rankThreeEscalatorRepresentative_triple(
            isometric := Matrix.IsIsometric.transitive(
              leftIsometric := sourceIsometric, rightIsometric := classified))
        case Matrix.IsIsometric(target, Matrix.sumOfTwoSquaresPlusDoubleSquareForm)
          ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(2))
          ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(3))
          ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(4))
          ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(5))
          ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(4))
          ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
            case Matrix.IsIsometric(target, Matrix.sumOfTwoSquaresPlusDoubleSquareForm) as classified:
              done by Matrix.rankThreeEscalatorRepresentative_double(
                isometric := Matrix.IsIsometric.transitive(
                  leftIsometric := sourceIsometric, rightIsometric := classified))
            case Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(2))
              ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(3))
              ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(4))
              ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(5))
              ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(4))
              ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
                case Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(2)) as classified:
                  done by Matrix.rankThreeEscalatorRepresentative_weightedTwo(
                    isometric := Matrix.IsIsometric.transitive(
                      leftIsometric := sourceIsometric, rightIsometric := classified))
                case Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(3))
                  ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(4))
                  ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(5))
                  ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(4))
                  ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
                    case Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(3)) as classified:
                      done by Matrix.rankThreeEscalatorRepresentative_weightedThree(
                        isometric := Matrix.IsIsometric.transitive(
                          leftIsometric := sourceIsometric, rightIsometric := classified))
                    case Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(4))
                      ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(5))
                      ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(4))
                      ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
                        case Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(4)) as classified:
                          done by Matrix.rankThreeEscalatorRepresentative_weightedFour(
                            isometric := Matrix.IsIsometric.transitive(
                              leftIsometric := sourceIsometric, rightIsometric := classified))
                        case Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(5))
                          ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(4))
                          ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
                            case Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareDiagonalForm(5)) as classified:
                              done by Matrix.rankThreeEscalatorRepresentative_weightedFive(
                                isometric := Matrix.IsIsometric.transitive(
                                  leftIsometric := sourceIsometric, rightIsometric := classified))
                            case Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(4))
                              ∨ Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(5)): done by cases {
                                case Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(4)) as classified:
                                  done by Matrix.rankThreeEscalatorRepresentative_oddFour(
                                    isometric := Matrix.IsIsometric.transitive(
                                      leftIsometric := sourceIsometric, rightIsometric := classified))
                                case Matrix.IsIsometric(target, Matrix.squarePlusDoubleSquareOddForm(5)) as classified:
                                  done by Matrix.rankThreeEscalatorRepresentative_oddFive(
                                    isometric := Matrix.IsIsometric.transitive(
                                      leftIsometric := sourceIsometric, rightIsometric := classified))
                              }
                          }
                      }
                  }
              }
          }
      }
  }
}

theorem Matrix.escalator_rank_three
        (A : Matrix(Integer.commutative_ring_bundle, 1 + 2, 1 + 2))
        (escalator : Matrix.IsEscalator(1 + 2, A))
        : Matrix.IsRankThreeEscalatorRepresentative(A) := {
  choose parent such that Matrix.IsEscalator(2, parent) ∧ Matrix.IsEscalation(parent, A)
      from Matrix.escalator_split(B := A, escalator := escalator);
  Matrix.IsEscalator(2, parent) as parentEscalator;
  Matrix.IsEscalation(parent, A) as escalation;
  Matrix.IsIsometric(parent, Matrix.sumOfTwoSquaresForm)
    ∨ Matrix.IsIsometric(parent, Matrix.squarePlusDoubleSquareForm)
      by Matrix.escalator_rank_two(escalator := parentEscalator);
  done by cases {
    case Matrix.IsIsometric(parent, Matrix.sumOfTwoSquaresForm) as parentIsometric: {
      choose child such that Matrix.IsEscalation(Matrix.sumOfTwoSquaresForm, child)
          ∧ Matrix.IsIsometric(A, child)
          from Matrix.escalation_transport_parent_isometry(
            escalation := escalation, parentIsometric := parentIsometric);
      Matrix.IsEscalation(Matrix.sumOfTwoSquaresForm, child) ∧ Matrix.IsIsometric(A, child)
          as childFacts;
      Matrix.IsEscalation(Matrix.sumOfTwoSquaresForm, child)
          by And.left(Matrix.IsEscalation(Matrix.sumOfTwoSquaresForm, child),
            Matrix.IsIsometric(A, child), childFacts) as childEscalation;
      Matrix.IsIsometric(A, child)
          by And.right(Matrix.IsEscalation(Matrix.sumOfTwoSquaresForm, child),
            Matrix.IsIsometric(A, child), childFacts) as childIsometric;
      Matrix.IsRankThreeEscalatorRepresentative(child)
          by Matrix.sumOfTwoSquares_escalation_three_representatives(escalation := childEscalation);
      done by Matrix.rankThreeEscalatorRepresentative_transport(sourceIsometric := childIsometric)
    }
    case Matrix.IsIsometric(parent, Matrix.squarePlusDoubleSquareForm) as parentIsometric: {
      choose child such that Matrix.IsEscalation(Matrix.squarePlusDoubleSquareForm, child)
          ∧ Matrix.IsIsometric(A, child)
          from Matrix.escalation_transport_parent_isometry(
            escalation := escalation, parentIsometric := parentIsometric);
      Matrix.IsEscalation(Matrix.squarePlusDoubleSquareForm, child) ∧ Matrix.IsIsometric(A, child)
          as childFacts;
      Matrix.IsEscalation(Matrix.squarePlusDoubleSquareForm, child)
          by And.left(Matrix.IsEscalation(Matrix.squarePlusDoubleSquareForm, child),
            Matrix.IsIsometric(A, child), childFacts) as childEscalation;
      Matrix.IsIsometric(A, child)
          by And.right(Matrix.IsEscalation(Matrix.squarePlusDoubleSquareForm, child),
            Matrix.IsIsometric(A, child), childFacts) as childIsometric;
      Matrix.IsSquarePlusDoubleSquareRankThreeRepresentative(child)
          by Matrix.squarePlusDoubleSquare_escalation_eight_representatives(escalation := childEscalation);
      Matrix.IsRankThreeEscalatorRepresentative(child)
          by Matrix.squarePlusDoubleSquareRankThreeRepresentative_is_global;
      done by Matrix.rankThreeEscalatorRepresentative_transport(sourceIsometric := childIsometric)
    }
  }
}

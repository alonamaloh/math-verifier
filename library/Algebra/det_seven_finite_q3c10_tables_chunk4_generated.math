            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 10),
            (n : ℤ)) := {
  let q : ℕ := Natural.floor_divide(n, 588);
  588 * q + Natural.modulo(n, 588) = n
      by Natural.floor_divide_modulo_decompose;
  588 * q + 199 = n by substituting remainderReads as exactDecomposition;
  q < 1 by Natural.quotient_below_of_bounded_decomposition(
    588, q, 199, n, 238, 1, done, exactDecomposition, bounded)
  as qBelow;
  Matrix.Represents(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 10),
      (588 : ℤ) * (q : ℤ) + (199 : ℤ)) by {
  done by Matrix.detSevenFiniteQ3C10A199T1_part0(q, done, qBelow)
  };
  (588 : ℤ) * (q : ℤ) + (199 : ℤ)
     = ((588 * q : ℕ) : ℤ) + (199 : ℤ)
         by substituting Equality.symmetry(Natural.to_integer.multiply_preserves(588, q))
     = ((588 * q + 199 : ℕ) : ℤ)
         by Equality.symmetry(Natural.to_integer.add_preserves(588 * q, 199))
     = (n : ℤ) by substituting exactDecomposition
  as integerDecomposition;
  done by substituting integerDecomposition
}

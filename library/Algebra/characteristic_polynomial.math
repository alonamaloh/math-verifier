-- Algebra/characteristic_polynomial.math
--
-- The characteristic matrix of a square matrix A over a commutative ring:
-- the matrix xI − A over R[x], written by its entries the way every text
-- tabulates it — x − aᵢᵢ on the diagonal, −aᵢⱼ off it. Its determinant is
-- the characteristic polynomial. (The compositional spelling
-- `x • I − mapEntries(constant, A)` is definitionally the same matrix;
-- the entrywise form is what every determinant manipulation consumes.)

module Algebra.characteristic_polynomial

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.classical_decidable
import Set.finite
import Lists.list
import Lists.map
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.commutative_ring_aggregation
import Algebra.finite_permutation
import Algebra.permutation_enumeration
import Algebra.permutation_sign
import Algebra.matrix
import Algebra.determinant
import Algebra.alternating_collapse
import Polynomial.basics
import Polynomial.addition
import Polynomial.negation
import Polynomial.multiplication
import Polynomial.instances
import Polynomial.commutative
import Polynomial.monomial
import Polynomial.degree
import Polynomial.degree_product
import Polynomial.multiply_coefficient

-- The characteristic matrix xI − A, a square matrix over R[x].
definition Matrix.characteristic {c : CommutativeRing} {n : ℕ}
        (A : Matrix(c, n, n)) : Matrix(CommutativeRing.polynomial_ring(c), n, n) :=
  (i : NaturalsBelow(n)) ↦ (j : NaturalsBelow(n)) ↦
      if i = j
      then Polynomial.indeterminate(CommutativeRing.ring(c))
           - Polynomial.constant(CommutativeRing.ring(c), A(i, j))
      else Polynomial.negate(Polynomial.constant(CommutativeRing.ring(c), A(i, j)))

-- The characterizing entries, through the conditional's quarantine boundary.
theorem Matrix.characteristic_entry_diagonal {c : CommutativeRing} {n : ℕ}
        (A : Matrix(c, n, n)) (i j : NaturalsBelow(n)) (equal : i = j)
        : Matrix.characteristic(A)(i, j)
          = Polynomial.indeterminate(CommutativeRing.ring(c))
            - Polynomial.constant(CommutativeRing.ring(c), A(i, j)) :=
  by Logic.if_positive

theorem Matrix.characteristic_entry_off {c : CommutativeRing} {n : ℕ}
        (A : Matrix(c, n, n)) (i j : NaturalsBelow(n)) (notEqual : ¬(i = j))
        : Matrix.characteristic(A)(i, j)
          = Polynomial.negate(Polynomial.constant(CommutativeRing.ring(c), A(i, j))) :=
  by Logic.if_negative

-- The characteristic polynomial: det(xI − A) in R[x]. The result type is
-- spelled `Polynomial(...)` so the coefficient operator `p[k]` and the
-- polynomial algebra resolve on it directly.
definition Matrix.characteristicPolynomial {c : CommutativeRing} {n : ℕ}
        (A : Matrix(c, n, n))
        : Polynomial(Ring.carrier(CommutativeRing.ring(c)),
                     Ring.zero(CommutativeRing.ring(c))) :=
  Matrix.determinant(Matrix.characteristic(A))

-- ----------------------------------------------------------------------
-- Coefficients through the aggregation folds. The determinant of a
-- polynomial matrix is a `CommutativeRing.sumOver`/`productOver` at the
-- bundle R[x]; these lemmas push `coefficientOf` through the folds so the
-- Leibniz sum can be read off coefficient by coefficient.

-- Coefficients pass through a polynomial-valued sum, index by index.
theorem Polynomial.coefficientOf_sumOver {c : CommutativeRing} {index : Type(0)}
        (term : index → CommutativeRing.carrier(CommutativeRing.polynomial_ring(c)))
        (items : List(index)) (k : ℕ)
        : Polynomial.coefficientOf(CommutativeRing.sumOver(term, items), k)
          = CommutativeRing.sumOver((t : index) ↦ Polynomial.coefficientOf(term(t), k), items) :=
  by induction on items with IH {
    case List.empty:
        Polynomial.coefficientOf(CommutativeRing.sumOver(term, List.empty(index)), k)
           = Ring.zero(CommutativeRing.ring(c))   by Polynomial.coefficientOf_zero
           = CommutativeRing.sumOver((t : index) ↦ Polynomial.coefficientOf(term(t), k),
                 List.empty(index))
    case List.prepend(head, tail):
        Polynomial.coefficientOf(CommutativeRing.sumOver(term, List.prepend(index, head, tail)), k)
           = Polynomial.coefficientOf(term(head), k)
                 + Polynomial.coefficientOf(CommutativeRing.sumOver(term, tail), k)
           = Polynomial.coefficientOf(term(head), k)
                 + CommutativeRing.sumOver((t : index) ↦ Polynomial.coefficientOf(term(t), k), tail)
                 by substituting IH
           = CommutativeRing.sumOver((t : index) ↦ Polynomial.coefficientOf(term(t), k),
                 List.prepend(index, head, tail))
  }

-- The constant term of a polynomial-valued product is the product of the
-- constant terms.
theorem Polynomial.coefficientOf_productOver_zero {c : CommutativeRing} {index : Type(0)}
        (term : index → CommutativeRing.carrier(CommutativeRing.polynomial_ring(c)))
        (items : List(index))
        : Polynomial.coefficientOf(CommutativeRing.productOver(term, items), 0)
          = CommutativeRing.productOver((t : index) ↦ Polynomial.coefficientOf(term(t), 0), items) :=
  by induction on items with IH {
    case List.empty:
        Polynomial.coefficientOf(CommutativeRing.productOver(term, List.empty(index)), 0)
           = CommutativeRing.productOver((t : index) ↦ Polynomial.coefficientOf(term(t), 0),
                 List.empty(index))
    case List.prepend(head, tail):
        Polynomial.coefficientOf(CommutativeRing.productOver(term, List.prepend(index, head, tail)), 0)
           = Polynomial.coefficientOf(term(head), 0)
                 * Polynomial.coefficientOf(CommutativeRing.productOver(term, tail), 0)
                 by Polynomial.coefficientOf_multiply_zero
           = Polynomial.coefficientOf(term(head), 0)
                 * CommutativeRing.productOver((t : index) ↦ Polynomial.coefficientOf(term(t), 0), tail)
                 by substituting IH
           = CommutativeRing.productOver((t : index) ↦ Polynomial.coefficientOf(term(t), 0),
                 List.prepend(index, head, tail))
  }

-- A sum of polynomials all bounded below degree n is bounded below n.
theorem Polynomial.sumOver_DegreeLessThan {c : CommutativeRing} {index : Type(0)}
        (term : index → CommutativeRing.carrier(CommutativeRing.polynomial_ring(c)))
        (items : List(index)) (n : ℕ)
        (bounds : ∀ (t : index). t ∈ items
            → Polynomial.DegreeLessThan(CommutativeRing.ring(c), term(t), n))
        : Polynomial.DegreeLessThan(CommutativeRing.ring(c),
              CommutativeRing.sumOver(term, items), n) :=
  by induction on items with IH {
    case List.empty: {
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                Polynomial.zero(CommutativeRing.ring(c)), 0)
            by Polynomial.DegreeLessThan.zero;
        0 ≤ n;
        done by Polynomial.DegreeLessThan.weaken
      }
    case List.prepend(head, tail): {
        head ∈ List.prepend(index, head, tail);
        Polynomial.DegreeLessThan(CommutativeRing.ring(c), term(head), n);
        ∀ (t : index). t ∈ tail
            → Polynomial.DegreeLessThan(CommutativeRing.ring(c), term(t), n)
            by (t : index) (tInTail : t ∈ tail) ↦ {
                t ∈ List.prepend(index, head, tail);
                done
              };
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                CommutativeRing.sumOver(term, tail), n)
            by IH;
        done by Polynomial.DegreeLessThan.add
      }
  }

-- A product of polynomials each bounded below degree 2 (degree ≤ 1) is
-- bounded below degree (length + 1) — the Leibniz term's degree budget.
theorem Polynomial.productOver_DegreeLessThan {c : CommutativeRing} {index : Type(0)}
        (term : index → CommutativeRing.carrier(CommutativeRing.polynomial_ring(c)))
        (items : List(index))
        (bounds : ∀ (t : index). t ∈ items
            → Polynomial.DegreeLessThan(CommutativeRing.ring(c), term(t), 2))
        : Polynomial.DegreeLessThan(CommutativeRing.ring(c),
              CommutativeRing.productOver(term, items), 1 + length(items)) :=
  by induction on items with IH {
    case List.empty: {
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                Polynomial.one(CommutativeRing.ring(c)), 1)
            by Polynomial.one_DegreeLessThan;
        length(List.empty(index)) = 0;
        1 + length(List.empty(index))
           = 1 + 0
           = 1
           as lengthEquation;
        done by substituting lengthEquation
      }
    case List.prepend(head, tail): {
        head ∈ List.prepend(index, head, tail);
        Polynomial.DegreeLessThan(CommutativeRing.ring(c), term(head), 2) as headBound;
        ∀ (t : index). t ∈ tail
            → Polynomial.DegreeLessThan(CommutativeRing.ring(c), term(t), 2)
            by (t : index) (tInTail : t ∈ tail) ↦ {
                t ∈ List.prepend(index, head, tail);
                done
              };
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                CommutativeRing.productOver(term, tail), 1 + length(tail))
            by IH as tailBound;
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                (term(head) * CommutativeRing.productOver(term, tail)),
                1 + (1 + length(tail)))
            by Polynomial.product_DegreeLessThan(aBound := headBound, bBound := tailBound);
        length(List.prepend(index, head, tail)) = 1 + length(tail) as prependLength;
        done by substituting prependLength
      }
  }

-- A product of polynomials of degree exactly 1 with leading coefficient
-- one is monic of degree = length: the top coefficient is the product of
-- the factors' top coefficients, and every factor's is one.
theorem Polynomial.productOver_monic {c : CommutativeRing} {index : Type(0)}
        (term : index → CommutativeRing.carrier(CommutativeRing.polynomial_ring(c)))
        (items : List(index))
        (bounds : ∀ (t : index). t ∈ items
            → Polynomial.DegreeLessThan(CommutativeRing.ring(c), term(t), 2))
        (monic : ∀ (t : index). t ∈ items
            → Polynomial.coefficientOf(term(t), 1) = Ring.one(CommutativeRing.ring(c)))
        : Polynomial.coefficientOf(CommutativeRing.productOver(term, items), length(items))
          = Ring.one(CommutativeRing.ring(c)) :=
  by induction on items with IH {
    case List.empty: {
        Polynomial.coefficientOf(CommutativeRing.productOver(term, List.empty(index)), 0)
           = Ring.one(CommutativeRing.ring(c));
        length(List.empty(index)) = 0 as emptyLength;
        done by substituting emptyLength
      }
    case List.prepend(head, tail): {
        head ∈ List.prepend(index, head, tail);
        Polynomial.DegreeLessThan(CommutativeRing.ring(c), term(head), 2);
        Polynomial.coefficientOf(term(head), 1) = Ring.one(CommutativeRing.ring(c))
            by monic as headMonic;
        ∀ (t : index). t ∈ tail
            → Polynomial.DegreeLessThan(CommutativeRing.ring(c), term(t), 2)
            by (t : index) (tInTail : t ∈ tail) ↦ {
                t ∈ List.prepend(index, head, tail);
                done
              };
        ∀ (t : index). t ∈ tail
            → Polynomial.coefficientOf(term(t), 1) = Ring.one(CommutativeRing.ring(c))
            by (t : index) (tInTail : t ∈ tail) ↦ {
                t ∈ List.prepend(index, head, tail);
                done
              };
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                CommutativeRing.productOver(term, tail), 1 + length(tail))
            by Polynomial.productOver_DegreeLessThan;
        Polynomial.coefficientOf(CommutativeRing.productOver(term, tail), length(tail))
           = Ring.one(CommutativeRing.ring(c)) by IH as tailTop;
        Polynomial.DegreeLessThan(CommutativeRing.ring(c), term(head), 1 + 1);
        Polynomial.coefficientOf(CommutativeRing.productOver(term, List.prepend(index, head, tail)),
                1 + length(tail))
           = Polynomial.coefficientOf((term(head) * CommutativeRing.productOver(term, tail)),
                 1 + length(tail))
           = Polynomial.coefficientOf(term(head), 1)
                 * Polynomial.coefficientOf(CommutativeRing.productOver(term, tail), length(tail))
                 by Polynomial.coefficientOf_product_at_sum
           = Ring.one(CommutativeRing.ring(c))
                 * Polynomial.coefficientOf(CommutativeRing.productOver(term, tail), length(tail))
                 by substituting headMonic
           = Ring.one(CommutativeRing.ring(c)) * Ring.one(CommutativeRing.ring(c))
                 by substituting tailTop
           = Ring.one(CommutativeRing.ring(c));
        length(List.prepend(index, head, tail)) = 1 + length(tail) as prependLength;
        done by substituting prependLength
      }
  }

-- Pulling a negation out of every factor: the product of the negated
-- terms is (−1)^length times the product of the terms.
theorem CommutativeRing.productOver_negate {c : CommutativeRing} {index : Type(0)}
        (g : index → CommutativeRing.carrier(c)) (items : List(index))
        : CommutativeRing.productOver((t : index) ↦ CommutativeRing.negate(g(t)), items)
          = CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), length(items))
            * CommutativeRing.productOver(g, items) :=
  by induction on items with IH {
    case List.empty: {
        length(List.empty(index)) = 0 as emptyLength;
        CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)),
                length(List.empty(index)))
           = CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), 0)
                 by substituting emptyLength
           = CommutativeRing.one(c)
           as powerValue;
        CommutativeRing.productOver((t : index) ↦ CommutativeRing.negate(g(t)), List.empty(index))
           = CommutativeRing.one(c)
           = CommutativeRing.one(c) * CommutativeRing.one(c)
           = CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)),
                 length(List.empty(index)))
                 * CommutativeRing.productOver(g, List.empty(index))
                 by substituting powerValue
      }
    case List.prepend(head, tail): {
        length(List.prepend(index, head, tail)) = 1 + length(tail) as prependLength;
        CommutativeRing.productOver((t : index) ↦ CommutativeRing.negate(g(t)),
              List.prepend(index, head, tail))
           = CommutativeRing.negate(g(head))
                 * CommutativeRing.productOver((t : index) ↦ CommutativeRing.negate(g(t)), tail)
           = CommutativeRing.negate(g(head))
                 * (CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), length(tail))
                       * CommutativeRing.productOver(g, tail))
                 by substituting IH
           = (CommutativeRing.negate(CommutativeRing.one(c))
                 * CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), length(tail)))
                 * (g(head) * CommutativeRing.productOver(g, tail))
                 by ring
           = CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), 1 + length(tail))
                 * (g(head) * CommutativeRing.productOver(g, tail))
                 by substituting CommutativeRing.power_add_one
           = CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), 1 + length(tail))
                 * CommutativeRing.productOver(g, List.prepend(index, head, tail))
           = CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)),
                 length(List.prepend(index, head, tail)))
                 * CommutativeRing.productOver(g, List.prepend(index, head, tail))
                 by substituting prependLength
      }
  }

-- ----------------------------------------------------------------------
-- The characteristic matrix's entries, coefficient by coefficient: every
-- entry has degree ≤ 1, the diagonal entries are monic of degree 1, and
-- every entry's constant term is −aᵢⱼ.

theorem Matrix.characteristic_entry_DegreeLessThan {c : CommutativeRing} {n : ℕ}
        (A : Matrix(c, n, n)) (i j : NaturalsBelow(n))
        : Polynomial.DegreeLessThan(CommutativeRing.ring(c), Matrix.characteristic(A)(i, j), 2) := {
  i = j ∨ ¬(i = j);
  done by cases {
    case i = j as diagonal: {
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                Polynomial.constant(CommutativeRing.ring(c), A(j, j)), 1 + 0)
            by Polynomial.monomial_DegreeLessThan;
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                Polynomial.constant(CommutativeRing.ring(c), A(j, j)), 1);
        1 ≤ 2;
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                Polynomial.constant(CommutativeRing.ring(c), A(j, j)), 2)
            by Polynomial.DegreeLessThan.weaken;
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                Polynomial.negate(Polynomial.constant(CommutativeRing.ring(c), A(j, j))), 2)
            by Polynomial.DegreeLessThan.negate;
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                Polynomial.indeterminate(CommutativeRing.ring(c)), 1 + 1)
            by Polynomial.monomial_DegreeLessThan;
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                Polynomial.indeterminate(CommutativeRing.ring(c)), 2);
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                (Polynomial.indeterminate(CommutativeRing.ring(c))
                    - Polynomial.constant(CommutativeRing.ring(c), A(j, j))), 2)
            by Polynomial.DegreeLessThan.add;
        Matrix.characteristic(A)(j, j)
           = Polynomial.indeterminate(CommutativeRing.ring(c))
             - Polynomial.constant(CommutativeRing.ring(c), A(j, j)) as entryEquation;
        done by substituting entryEquation
      }
    case ¬(i = j) as off: {
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                Polynomial.constant(CommutativeRing.ring(c), A(i, j)), 1 + 0)
            by Polynomial.monomial_DegreeLessThan;
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                Polynomial.constant(CommutativeRing.ring(c), A(i, j)), 1);
        1 ≤ 2;
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                Polynomial.constant(CommutativeRing.ring(c), A(i, j)), 2)
            by Polynomial.DegreeLessThan.weaken;
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                Polynomial.negate(Polynomial.constant(CommutativeRing.ring(c), A(i, j))), 2)
            by Polynomial.DegreeLessThan.negate;
        Matrix.characteristic(A)(i, j)
           = Polynomial.negate(Polynomial.constant(CommutativeRing.ring(c), A(i, j))) as entryEquation;
        done by substituting entryEquation
      }
  }
}

theorem Matrix.characteristic_entry_leading {c : CommutativeRing} {n : ℕ}
        (A : Matrix(c, n, n)) (i j : NaturalsBelow(n)) (equal : i = j)
        : Polynomial.coefficientOf(Matrix.characteristic(A)(i, j), 1)
          = Ring.one(CommutativeRing.ring(c)) := {
  Matrix.characteristic(A)(i, j)
     = Polynomial.indeterminate(CommutativeRing.ring(c))
       - Polynomial.constant(CommutativeRing.ring(c), A(i, j)) as entryEquation;
  ¬(1 = 0);
  Polynomial.coefficientOf(Polynomial.constant(CommutativeRing.ring(c), A(i, j)), 1)
     = Ring.zero(CommutativeRing.ring(c));
  Polynomial.coefficientOf(
          (Polynomial.indeterminate(CommutativeRing.ring(c))
              - Polynomial.constant(CommutativeRing.ring(c), A(i, j))), 1)
     = Polynomial.coefficientOf(Polynomial.indeterminate(CommutativeRing.ring(c)), 1)
       - Polynomial.coefficientOf(Polynomial.constant(CommutativeRing.ring(c), A(i, j)), 1)
     = Ring.one(CommutativeRing.ring(c))
       - Polynomial.coefficientOf(Polynomial.constant(CommutativeRing.ring(c), A(i, j)), 1)
     = Ring.one(CommutativeRing.ring(c)) - Ring.zero(CommutativeRing.ring(c))
     = Ring.one(CommutativeRing.ring(c))
           by ring;
  done by substituting entryEquation
}

theorem Matrix.characteristic_entry_constant {c : CommutativeRing} {n : ℕ}
        (A : Matrix(c, n, n)) (i j : NaturalsBelow(n))
        : Polynomial.coefficientOf(Matrix.characteristic(A)(i, j), 0)
          = CommutativeRing.negate(A(i, j)) := {
  i = j ∨ ¬(i = j);
  done by cases {
    case i = j as diagonal: {
        Matrix.characteristic(A)(j, j)
           = Polynomial.indeterminate(CommutativeRing.ring(c))
             - Polynomial.constant(CommutativeRing.ring(c), A(j, j)) as entryEquation;
        ¬(0 = 1);
        Polynomial.coefficientOf(Polynomial.indeterminate(CommutativeRing.ring(c)), 0)
           = Ring.zero(CommutativeRing.ring(c));
        Polynomial.coefficientOf(
                (Polynomial.indeterminate(CommutativeRing.ring(c))
                    - Polynomial.constant(CommutativeRing.ring(c), A(j, j))), 0)
           = Polynomial.coefficientOf(Polynomial.indeterminate(CommutativeRing.ring(c)), 0)
             - Polynomial.coefficientOf(Polynomial.constant(CommutativeRing.ring(c), A(j, j)), 0)
           = Ring.zero(CommutativeRing.ring(c))
             - Polynomial.coefficientOf(Polynomial.constant(CommutativeRing.ring(c), A(j, j)), 0)
           = Ring.zero(CommutativeRing.ring(c)) - A(j, j)
           = Ring.negate(CommutativeRing.ring(c), A(j, j))
                 by ring
           = CommutativeRing.negate(A(j, j));
        done by substituting entryEquation
      }
    case ¬(i = j) as off: {
        Matrix.characteristic(A)(i, j)
           = Polynomial.negate(Polynomial.constant(CommutativeRing.ring(c), A(i, j))) as entryEquation;
        Polynomial.coefficientOf(
                Polynomial.negate(Polynomial.constant(CommutativeRing.ring(c), A(i, j))), 0)
           = - Polynomial.coefficientOf(Polynomial.constant(CommutativeRing.ring(c), A(i, j)), 0)
           = CommutativeRing.negate(A(i, j));
        done by substituting entryEquation
      }
  }
}

-- ----------------------------------------------------------------------
-- The sign's image in R[x] is the constant ±1: degree ≤ 0, and its
-- constant term is the sign's image in R.

theorem Polynomial.sign_image_DegreeLessThan {c : CommutativeRing} (z : ℤ)
        (zUnit : z = 1 ∨ z = Integer.negate(1))
        : Polynomial.DegreeLessThan(CommutativeRing.ring(c),
              CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c), z), 1) :=
  done by cases {
    case z = 1 as positive: {
        CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c), 1)
           = CommutativeRing.one(CommutativeRing.polynomial_ring(c))
            by CommutativeRing.from_integer_one as imageEquation;
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                Polynomial.one(CommutativeRing.ring(c)), 1)
            by Polynomial.one_DegreeLessThan;
        done by substituting imageEquation
      }
    case z = Integer.negate(1) as negative: {
        CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c), Integer.negate(1))
           = CommutativeRing.negate(CommutativeRing.one(CommutativeRing.polynomial_ring(c)))
            by CommutativeRing.from_integer_negate_one as imageEquation;
        Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                Polynomial.negate(Polynomial.one(CommutativeRing.ring(c))), 1)
            by Polynomial.DegreeLessThan.negate(degreeP := Polynomial.one_DegreeLessThan(CommutativeRing.ring(c)));
        done by substituting imageEquation
      }
  }

theorem Polynomial.sign_image_constant {c : CommutativeRing} (z : ℤ)
        (zUnit : z = 1 ∨ z = Integer.negate(1))
        : Polynomial.coefficientOf(
              CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c), z), 0)
          = CommutativeRing.from_integer(c, z) :=
  done by cases {
    case z = 1 as positive: {
        CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c), 1)
           = CommutativeRing.one(CommutativeRing.polynomial_ring(c))
            by CommutativeRing.from_integer_one as imageEquation;
        Polynomial.coefficientOf(CommutativeRing.one(CommutativeRing.polynomial_ring(c)), 0)
           = Ring.one(CommutativeRing.ring(c))
                 by Polynomial.coefficientOf_one_zero
           = CommutativeRing.one(c)
           = CommutativeRing.from_integer(c, 1)
                 by CommutativeRing.from_integer_one;
        done by substituting imageEquation
      }
    case z = Integer.negate(1) as negative: {
        CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c), Integer.negate(1))
           = CommutativeRing.negate(CommutativeRing.one(CommutativeRing.polynomial_ring(c)))
            by CommutativeRing.from_integer_negate_one as imageEquation;
        Polynomial.coefficientOf(
                CommutativeRing.negate(CommutativeRing.one(CommutativeRing.polynomial_ring(c))), 0)
           = - Polynomial.coefficientOf(Polynomial.one(CommutativeRing.ring(c)), 0)
                 by Polynomial.coefficientOf_negate
           = CommutativeRing.negate(CommutativeRing.one(c))
                 by substituting Polynomial.coefficientOf_one_zero
           = CommutativeRing.from_integer(c, Integer.negate(1))
                 by CommutativeRing.from_integer_negate_one;
        done by substituting imageEquation
      }
  }

-- ----------------------------------------------------------------------
-- The headline corollaries: the characteristic polynomial of an n×n
-- matrix has degree ≤ n (and — next — is monic of degree exactly n).

theorem Matrix.characteristicPolynomial_DegreeLessThan {c : CommutativeRing} {n : ℕ}
        (A : Matrix(c, n, n))
        : Polynomial.DegreeLessThan(CommutativeRing.ring(c),
              Matrix.characteristicPolynomial(A), 1 + n) := {
  ∀ (sigma : Permutation(n)). sigma ∈ Permutation.allPermutations(n)
      → Polynomial.DegreeLessThan(CommutativeRing.ring(c),
            (CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c), Permutation.sign(sigma))
                * CommutativeRing.productOver(
                      (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, sigma(i)),
                      NaturalsBelow.enumerate(n))), 1 + n)
      by (sigma : Permutation(n)) (sigmaMember : sigma ∈ Permutation.allPermutations(n)) ↦ {
          Permutation.sign(sigma) = 1 ∨ Permutation.sign(sigma) = Integer.negate(1)
              by Permutation.sign_is_unit;
            Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                      Permutation.sign(sigma)), 1)
              by Polynomial.sign_image_DegreeLessThan;
          Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                      Permutation.sign(sigma)), 1 + 0)
              as signBound;
          ∀ (t : NaturalsBelow(n)). t ∈ NaturalsBelow.enumerate(n)
              → Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                    Matrix.characteristic(A)(t, sigma(t)), 2)
              by (t : NaturalsBelow(n)) (tMember : t ∈ NaturalsBelow.enumerate(n)) ↦
                  { done by Matrix.characteristic_entry_DegreeLessThan };
          Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  CommutativeRing.productOver(
                      (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, sigma(i)),
                      NaturalsBelow.enumerate(n)),
                  1 + length(NaturalsBelow.enumerate(n)))
              by Polynomial.productOver_DegreeLessThan;
          length(NaturalsBelow.enumerate(n)) = n;
          Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  CommutativeRing.productOver(
                      (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, sigma(i)),
                      NaturalsBelow.enumerate(n)), 1 + n)
              as productBound;
          Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  (CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                       Permutation.sign(sigma))
                      * CommutativeRing.productOver(
                            (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, sigma(i)),
                            NaturalsBelow.enumerate(n))), 1 + (0 + n))
              by Polynomial.product_DegreeLessThan(aBound := signBound, bBound := productBound);
          0 + n = n as zeroPlusEquation;
          done by substituting zeroPlusEquation
        };
  Polynomial.DegreeLessThan(CommutativeRing.ring(c),
          CommutativeRing.sumOver(
              (sigma : Permutation(n)) ↦
                  CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                      Permutation.sign(sigma))
                      * CommutativeRing.productOver(
                            (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, sigma(i)),
                            NaturalsBelow.enumerate(n)),
              Permutation.allPermutations(n)), 1 + n)
      by Polynomial.sumOver_DegreeLessThan;
  Matrix.characteristicPolynomial(A)
     = CommutativeRing.sumOver(
           (sigma : Permutation(n)) ↦
               CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                   Permutation.sign(sigma))
                   * CommutativeRing.productOver(
                         (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, sigma(i)),
                         NaturalsBelow.enumerate(n)),
           Permutation.allPermutations(n))
     by Matrix.determinant_expansion as expansionEquation;
  done by substituting expansionEquation
}

-- The characteristic polynomial is monic of degree n: only the identity
-- permutation's Leibniz term reaches degree n (any other permutation
-- moves some index, contributing a degree-0 off-diagonal factor), and the
-- diagonal product ∏(x − aᵢᵢ) is a product of monic linear factors.
theorem Matrix.characteristicPolynomial_monic {c : CommutativeRing} {n : ℕ}
        (A : Matrix(c, n, n))
        : Matrix.characteristicPolynomial(A)[n] = Ring.one(CommutativeRing.ring(c)) := {
  length(NaturalsBelow.enumerate(n)) = n;

  -- Every non-identity term's coefficient at n vanishes.
  ∀ (rho : Permutation(n)).
      rho ∈ Permutation.allPermutations(n) ∖ Permutation.identity(n)
      → Polynomial.coefficientOf(
            (CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                 Permutation.sign(rho))
                * CommutativeRing.productOver(
                      (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                      NaturalsBelow.enumerate(n))), n)
        = CommutativeRing.zero(c)
      by (rho : Permutation(n))
         (rhoMember : rho ∈ Permutation.allPermutations(n) ∖ Permutation.identity(n)) ↦ {
          List.Distinct(Permutation(n), Permutation.allPermutations(n))
              by Permutation.allPermutations_distinct;
          ¬(rho = Permutation.identity(n)) by List.remove_member_ne;
          ¬(∀ (i : NaturalsBelow(n)). rho(i) = i)
              by (allFixed : ∀ (i : NaturalsBelow(n)). rho(i) = i) ↦ {
                  ∀ (i : NaturalsBelow(n)). rho(i) = Permutation.identity(n)(i)
                      by (i : NaturalsBelow(n)) ↦ allFixed(i);
                  rho = Permutation.identity(n) by Permutation.equal_of_apply_equal;
                  done
                };
          ∃ (i0 : NaturalsBelow(n)). ¬(rho(i0) = i0)
              by Logic.not_forall_implies_exists_not(
                     predicate := (i : NaturalsBelow(n)) ↦ rho(i) = i);
          choose i0 such that ¬(rho(i0) = i0);
          ¬(i0 = rho(i0)) by (equal : i0 = rho(i0)) ↦ { rho(i0) = i0; done };
          i0 ∈ NaturalsBelow.enumerate(n) by NaturalsBelow.enumerate_complete;
          CommutativeRing.productOver(
                  (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                  NaturalsBelow.enumerate(n))
             = Matrix.characteristic(A)(i0, rho(i0))
               * CommutativeRing.productOver(
                     (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                     NaturalsBelow.enumerate(n) ∖ i0)
              by CommutativeRing.productOver_remove as productSplit;
            Matrix.characteristic(A)(i0, rho(i0))
             = Polynomial.negate(Polynomial.constant(CommutativeRing.ring(c), A(i0, rho(i0)))) as offEntry;
          Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  Polynomial.constant(CommutativeRing.ring(c), A(i0, rho(i0))), 1 + 0)
              by Polynomial.monomial_DegreeLessThan;
          Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  Polynomial.negate(Polynomial.constant(CommutativeRing.ring(c), A(i0, rho(i0)))),
                  1 + 0)
              by Polynomial.DegreeLessThan.negate;
          Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  Matrix.characteristic(A)(i0, rho(i0)), 1 + 0)
              by substituting offEntry as entryBound;
          ∀ (t : NaturalsBelow(n)). t ∈ NaturalsBelow.enumerate(n) ∖ i0
              → Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                    Matrix.characteristic(A)(t, rho(t)), 2)
              by (t : NaturalsBelow(n)) (tMember : t ∈ NaturalsBelow.enumerate(n) ∖ i0) ↦
                  { done by Matrix.characteristic_entry_DegreeLessThan };
          Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  CommutativeRing.productOver(
                      (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                      NaturalsBelow.enumerate(n) ∖ i0),
                  1 + length(NaturalsBelow.enumerate(n) ∖ i0))
              by Polynomial.productOver_DegreeLessThan as restBound;
          Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  (Matrix.characteristic(A)(i0, rho(i0))
                      * CommutativeRing.productOver(
                            (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                            NaturalsBelow.enumerate(n) ∖ i0)),
                  1 + (0 + length(NaturalsBelow.enumerate(n) ∖ i0)))
              by Polynomial.product_DegreeLessThan(aBound := entryBound, bBound := restBound);
          0 + length(NaturalsBelow.enumerate(n) ∖ i0)
             = length(NaturalsBelow.enumerate(n) ∖ i0);
          Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  (Matrix.characteristic(A)(i0, rho(i0))
                      * CommutativeRing.productOver(
                            (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                            NaturalsBelow.enumerate(n) ∖ i0)),
                  1 + length(NaturalsBelow.enumerate(n) ∖ i0))
              ;
          Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  CommutativeRing.productOver(
                      (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                      NaturalsBelow.enumerate(n)),
                  1 + length(NaturalsBelow.enumerate(n) ∖ i0))
              by substituting productSplit as fullProductBound;
          Permutation.sign(rho) = 1 ∨ Permutation.sign(rho) = Integer.negate(1)
              by Permutation.sign_is_unit;
          Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                      Permutation.sign(rho)), 1)
              by Polynomial.sign_image_DegreeLessThan;
          Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                      Permutation.sign(rho)), 1 + 0)
              as signBound;
          Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  (CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                       Permutation.sign(rho))
                      * CommutativeRing.productOver(
                            (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                            NaturalsBelow.enumerate(n))),
                  1 + (0 + length(NaturalsBelow.enumerate(n) ∖ i0)))
              by Polynomial.product_DegreeLessThan(aBound := signBound, bBound := fullProductBound);
          Polynomial.DegreeLessThan(CommutativeRing.ring(c),
                  (CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                       Permutation.sign(rho))
                      * CommutativeRing.productOver(
                            (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                            NaturalsBelow.enumerate(n))),
                  1 + length(NaturalsBelow.enumerate(n) ∖ i0))
              as termBound;
          length(NaturalsBelow.enumerate(n)) = 1 + length(NaturalsBelow.enumerate(n) ∖ i0)
              by List.length_remove_member as removeLength;
          n = length(NaturalsBelow.enumerate(n))
            = 1 + length(NaturalsBelow.enumerate(n) ∖ i0)   by removeLength
            as nEquation;
          1 + length(NaturalsBelow.enumerate(n) ∖ i0) ≤ n by substituting nEquation;
          done by termBound
        };

  -- The identity term's coefficient at n is one.
  ∀ (t : NaturalsBelow(n)). t ∈ NaturalsBelow.enumerate(n)
      → Polynomial.DegreeLessThan(CommutativeRing.ring(c),
            Matrix.characteristic(A)(t, Permutation.identity(n)(t)), 2)
      by (t : NaturalsBelow(n)) (tMember : t ∈ NaturalsBelow.enumerate(n)) ↦
          { done by Matrix.characteristic_entry_DegreeLessThan };
  ∀ (t : NaturalsBelow(n)). t ∈ NaturalsBelow.enumerate(n)
      → Polynomial.coefficientOf(Matrix.characteristic(A)(t, Permutation.identity(n)(t)), 1)
        = Ring.one(CommutativeRing.ring(c))
      by (t : NaturalsBelow(n)) (tMember : t ∈ NaturalsBelow.enumerate(n)) ↦ {
          t = Permutation.identity(n)(t);
          done by Matrix.characteristic_entry_leading
        };
  Polynomial.coefficientOf(
          CommutativeRing.productOver(
              (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, Permutation.identity(n)(i)),
              NaturalsBelow.enumerate(n)),
          length(NaturalsBelow.enumerate(n)))
     = Ring.one(CommutativeRing.ring(c))
      by Polynomial.productOver_monic;
  Polynomial.coefficientOf(
          CommutativeRing.productOver(
              (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, Permutation.identity(n)(i)),
              NaturalsBelow.enumerate(n)), n)
     = Ring.one(CommutativeRing.ring(c))
      as productAtN;
  Permutation.sign(Permutation.identity(n)) = 1 as signIdentity;
  Polynomial.coefficientOf(
          (CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
               Permutation.sign(Permutation.identity(n)))
              * CommutativeRing.productOver(
                    (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, Permutation.identity(n)(i)),
                    NaturalsBelow.enumerate(n))), n)
     = Polynomial.coefficientOf(
           (CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c), 1)
               * CommutativeRing.productOver(
                     (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, Permutation.identity(n)(i)),
                     NaturalsBelow.enumerate(n))), n)
           by substituting signIdentity
     = Polynomial.coefficientOf(
           (CommutativeRing.one(CommutativeRing.polynomial_ring(c))
               * CommutativeRing.productOver(
                     (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, Permutation.identity(n)(i)),
                     NaturalsBelow.enumerate(n))), n)
           by substituting CommutativeRing.from_integer_one
     = Polynomial.coefficientOf(
           CommutativeRing.productOver(
               (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, Permutation.identity(n)(i)),
               NaturalsBelow.enumerate(n)), n)
           by substituting CommutativeRing.one_multiply
     = Ring.one(CommutativeRing.ring(c))
           by productAtN
     as identityCoefficient;

  -- Assemble the sum: the identity term contributes one, the rest zero.
  Permutation.identity(n) ∈ Permutation.allPermutations(n)
      by Permutation.allPermutations_complete;
  CommutativeRing.sumOver(
          (rho : Permutation(n)) ↦
              Polynomial.coefficientOf(
                  (CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                       Permutation.sign(rho))
                      * CommutativeRing.productOver(
                            (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                            NaturalsBelow.enumerate(n))), n),
          Permutation.allPermutations(n) ∖ Permutation.identity(n))
     = CommutativeRing.zero(c)
      by CommutativeRing.sumOver_zero_on_members as remainderVanishes;
  Matrix.characteristicPolynomial(A)[n]
     = Polynomial.coefficientOf(
           CommutativeRing.sumOver(
               (sigma : Permutation(n)) ↦
                   CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                       Permutation.sign(sigma))
                       * CommutativeRing.productOver(
                             (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, sigma(i)),
                             NaturalsBelow.enumerate(n)),
               Permutation.allPermutations(n)), n)

     = CommutativeRing.sumOver(
           (rho : Permutation(n)) ↦
               Polynomial.coefficientOf(
                   (CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                        Permutation.sign(rho))
                       * CommutativeRing.productOver(
                             (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                             NaturalsBelow.enumerate(n))), n),
           Permutation.allPermutations(n))
           by Polynomial.coefficientOf_sumOver
     = Polynomial.coefficientOf(
           (CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                Permutation.sign(Permutation.identity(n)))
               * CommutativeRing.productOver(
                     (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, Permutation.identity(n)(i)),
                     NaturalsBelow.enumerate(n))), n)
       + CommutativeRing.sumOver(
             (rho : Permutation(n)) ↦
                 Polynomial.coefficientOf(
                     (CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                          Permutation.sign(rho))
                         * CommutativeRing.productOver(
                               (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                               NaturalsBelow.enumerate(n))), n),
             Permutation.allPermutations(n) ∖ Permutation.identity(n))
           by CommutativeRing.sumOver_remove
     = Ring.one(CommutativeRing.ring(c))
       + CommutativeRing.sumOver(
             (rho : Permutation(n)) ↦
                 Polynomial.coefficientOf(
                     (CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                          Permutation.sign(rho))
                         * CommutativeRing.productOver(
                               (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                               NaturalsBelow.enumerate(n))), n),
             Permutation.allPermutations(n) ∖ Permutation.identity(n))
           by substituting identityCoefficient
     = CommutativeRing.one(c) + CommutativeRing.zero(c)
           by substituting remainderVanishes
     = CommutativeRing.one(c)

}

-- The constant term is (−1)^n·det(A): at coefficient 0 every entry of
-- xI − A reads −aᵢⱼ, so each Leibniz term contributes sign(σ)·∏(−aᵢσᵢ),
-- and pulling the n negations out of the product reassembles det(A).
theorem Matrix.characteristicPolynomial_constant_term {c : CommutativeRing} {n : ℕ}
        (A : Matrix(c, n, n))
        : Matrix.characteristicPolynomial(A)[0]
          = CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), n)
            * Matrix.determinant(A) := {
  length(NaturalsBelow.enumerate(n)) = n as enumerateLength;

  -- Each term's constant coefficient: (−1)^n · (sign(ρ) · ∏ aᵢρᵢ).
  ∀ (rho : Permutation(n)).
      Polynomial.coefficientOf(
          (CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
               Permutation.sign(rho))
              * CommutativeRing.productOver(
                    (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                    NaturalsBelow.enumerate(n))), 0)
      = CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), n)
        * (CommutativeRing.from_integer(c, Permutation.sign(rho))
              * CommutativeRing.productOver((i : NaturalsBelow(n)) ↦ A(i, rho(i)),
                    NaturalsBelow.enumerate(n)))
      by (rho : Permutation(n)) ↦ {
          Permutation.sign(rho) = 1 ∨ Permutation.sign(rho) = Integer.negate(1)
              by Permutation.sign_is_unit;
          Polynomial.coefficientOf(
                  CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                      Permutation.sign(rho)), 0)
             = CommutativeRing.from_integer(c, Permutation.sign(rho))
              by Polynomial.sign_image_constant as signConstant;
          ∀ (t : NaturalsBelow(n)).
              Polynomial.coefficientOf(Matrix.characteristic(A)(t, rho(t)), 0)
              = CommutativeRing.negate(A(t, rho(t)))
              by (t : NaturalsBelow(n)) ↦
                  { done by Matrix.characteristic_entry_constant };
          CommutativeRing.productOver(
               (t : NaturalsBelow(n)) ↦
                   Polynomial.coefficientOf(Matrix.characteristic(A)(t, rho(t)), 0),
               NaturalsBelow.enumerate(n))
             = CommutativeRing.productOver(
                   (t : NaturalsBelow(n)) ↦ CommutativeRing.negate(A(t, rho(t))),
                   NaturalsBelow.enumerate(n))
              by CommutativeRing.productOver_congruence
              as productEntriesConstant;
          CommutativeRing.productOver(
                  (t : NaturalsBelow(n)) ↦ CommutativeRing.negate(A(t, rho(t))),
                  NaturalsBelow.enumerate(n))
             = CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)),
                   length(NaturalsBelow.enumerate(n)))
               * CommutativeRing.productOver((t : NaturalsBelow(n)) ↦ A(t, rho(t)),
                     NaturalsBelow.enumerate(n))
                 by CommutativeRing.productOver_negate
             = CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), n)
               * CommutativeRing.productOver((t : NaturalsBelow(n)) ↦ A(t, rho(t)),
                     NaturalsBelow.enumerate(n))
                 by substituting enumerateLength
             as negateExtraction;
          CommutativeRing.from_integer(c, Permutation.sign(rho))
            * (CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), n)
                  * CommutativeRing.productOver((t : NaturalsBelow(n)) ↦ A(t, rho(t)),
                        NaturalsBelow.enumerate(n)))
             = CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), n)
               * (CommutativeRing.from_integer(c, Permutation.sign(rho))
                     * CommutativeRing.productOver((t : NaturalsBelow(n)) ↦ A(t, rho(t)),
                           NaturalsBelow.enumerate(n)))
              by ring as signPowerSwap;
          Polynomial.coefficientOf(
                  (CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                       Permutation.sign(rho))
                      * CommutativeRing.productOver(
                            (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                            NaturalsBelow.enumerate(n))), 0)
             = Polynomial.coefficientOf(
                   CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                       Permutation.sign(rho)), 0)
               * Polynomial.coefficientOf(
                     CommutativeRing.productOver(
                         (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                         NaturalsBelow.enumerate(n)), 0)
                 by Polynomial.coefficientOf_multiply_zero
             = Polynomial.coefficientOf(
                   CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                       Permutation.sign(rho)), 0)
               * CommutativeRing.productOver(
                      (t : NaturalsBelow(n)) ↦
                          Polynomial.coefficientOf(Matrix.characteristic(A)(t, rho(t)), 0),
                      NaturalsBelow.enumerate(n))
                 by substituting Polynomial.coefficientOf_productOver_zero
             = Polynomial.coefficientOf(
                   CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                       Permutation.sign(rho)), 0)
               * CommutativeRing.productOver(
                     (t : NaturalsBelow(n)) ↦ CommutativeRing.negate(A(t, rho(t))),
                     NaturalsBelow.enumerate(n))
                 by substituting productEntriesConstant
             = Polynomial.coefficientOf(
                   CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                       Permutation.sign(rho)), 0)
               * (CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), n)
                     * CommutativeRing.productOver((t : NaturalsBelow(n)) ↦ A(t, rho(t)),
                           NaturalsBelow.enumerate(n)))
                 by substituting negateExtraction
             = CommutativeRing.from_integer(c, Permutation.sign(rho))
               * (CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), n)
                     * CommutativeRing.productOver((t : NaturalsBelow(n)) ↦ A(t, rho(t)),
                           NaturalsBelow.enumerate(n)))
                 by substituting signConstant
             = CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), n)
               * (CommutativeRing.from_integer(c, Permutation.sign(rho))
                     * CommutativeRing.productOver((t : NaturalsBelow(n)) ↦ A(t, rho(t)),
                           NaturalsBelow.enumerate(n)))
                 by signPowerSwap;
          done
        };

  -- Assemble: the coefficient sum is (−1)^n times the base determinant sum.
  Matrix.determinant(A)
     = CommutativeRing.sumOver(
           (rho : Permutation(n)) ↦
               CommutativeRing.from_integer(c, Permutation.sign(rho))
                   * CommutativeRing.productOver((i : NaturalsBelow(n)) ↦ A(i, rho(i)),
                         NaturalsBelow.enumerate(n)),
           Permutation.allPermutations(n))
     by Matrix.determinant_expansion as baseExpansion;
  Matrix.characteristicPolynomial(A)[0]
     = Polynomial.coefficientOf(
           CommutativeRing.sumOver(
               (sigma : Permutation(n)) ↦
                   CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                       Permutation.sign(sigma))
                       * CommutativeRing.productOver(
                             (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, sigma(i)),
                             NaturalsBelow.enumerate(n)),
               Permutation.allPermutations(n)), 0)

     = CommutativeRing.sumOver(
           (rho : Permutation(n)) ↦
               Polynomial.coefficientOf(
                   (CommutativeRing.from_integer(CommutativeRing.polynomial_ring(c),
                        Permutation.sign(rho))
                       * CommutativeRing.productOver(
                             (i : NaturalsBelow(n)) ↦ Matrix.characteristic(A)(i, rho(i)),
                             NaturalsBelow.enumerate(n))), 0),
           Permutation.allPermutations(n))
           by Polynomial.coefficientOf_sumOver
     = CommutativeRing.sumOver(
           (rho : Permutation(n)) ↦
               CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), n)
                   * (CommutativeRing.from_integer(c, Permutation.sign(rho))
                         * CommutativeRing.productOver((i : NaturalsBelow(n)) ↦ A(i, rho(i)),
                               NaturalsBelow.enumerate(n))),
           Permutation.allPermutations(n))
           by CommutativeRing.sumOver_congruence
     = CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), n)
       * CommutativeRing.sumOver(
             (rho : Permutation(n)) ↦
                 CommutativeRing.from_integer(c, Permutation.sign(rho))
                     * CommutativeRing.productOver((i : NaturalsBelow(n)) ↦ A(i, rho(i)),
                           NaturalsBelow.enumerate(n)),
             Permutation.allPermutations(n))
           by CommutativeRing.sumOver_scale_left
     = CommutativeRing.power(CommutativeRing.negate(CommutativeRing.one(c)), n)
       * Matrix.determinant(A)
           by substituting baseExpansion
}

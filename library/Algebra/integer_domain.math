-- Algebra/integer_domain.math
--
-- ℤ as a bundled integral domain. Bundles the existing
-- `Integer.is_commutative_ring` into the `Ring`/`CommutativeRing`/
-- `IntegralDomain` hierarchy, proving the two extra facts a domain needs:
-- `1 ≠ 0` and no zero divisors.
--
-- No-zero-divisors goes through `Integer.multiply_cancel_right_by_natural_-
-- successor`: a nonzero `y` is, up to sign, a positive Natural cast
-- `(successor k : Integer)`, and `x · (successor k) = 0 = 0 · (successor k)`
-- cancels to `x = 0`. The sign and negation juggling is all `ring`.

module Algebra.integer_domain

import axioms
import Logic.basics
import Logic.exists
import Logic.sum
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.subtraction
import Natural.factorization
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.instances
import Integer.embedding
import Integer.order
import Integer.sign
import Integer.cancellation
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.integral_domain

-- ----------------------------------------------------------------------
-- Bundling.

definition Integer.ring_bundle : Ring :=
  Ring.make(Integer, Integer.add, Integer.zero, Integer.negate,
      Integer.multiply, Integer.one, Integer.is_ring)

-- Canonical `Ring` for the carrier `Integer`: lets `{r : Ring}` resolve
-- from a concrete `Integer` / `Polynomial(Integer, …)` operand, so the
-- ring/polynomial operators (`+`, `*`, `-`) work in the concrete setting.
instance Integer.ring_bundle

theorem Integer.multiply_commutative_for_bundle
        : Ring.MultiplyCommutative(Integer.ring_bundle) := {
  let ⟨_, commutativity⟩ := Integer.is_commutative_ring;
  commutativity
}

definition Integer.commutative_ring_bundle : CommutativeRing :=
  CommutativeRing.make(Integer.ring_bundle,
      Integer.multiply_commutative_for_bundle)

-- ----------------------------------------------------------------------
-- 1 ≠ 0.

theorem Integer.one_not_zero : ¬(Integer.one = Integer.zero) := {
  suppose Integer.one = Integer.zero as oneEqualsZero;
  calc Natural.to_integer(1)
            = Integer.one
            = Integer.zero
            = Natural.to_integer(0) as castsEqual;
  absurd(Natural.zero_not_successor(0,
      Equality.symmetry(
          Natural.to_integer.injective(1, 0, castsEqual))))
}

-- ----------------------------------------------------------------------
-- No zero divisors.

theorem Integer.multiply_eq_zero_implies (x y : Integer)
        (productZero : x * y = Integer.zero)
        : x = Integer.zero ∨ y = Integer.zero := {
  decide y = Integer.zero {
    | yes yIsZero => okay
    | no yNonzero => {
        claim xIsZero : x = Integer.zero by {
          cases Integer.sign_split(y) {
            | Or.introduceLeft(yNonneg) => {
                obtain ⟨n, yIsImage⟩ from yNonneg;
                -- y = (n : Integer); n ≠ 0 (else y = 0).
                claim nNonzero : ¬(n = 0) by {
                  suppose n = 0 as nZero;
                  absurd(yNonzero(
                      calc y
                         = Natural.to_integer(n)
                         = Natural.to_integer(0)
                         = Integer.zero))
                };
                claim oneAtMostN : 1 ≤ n by {
                  cases Natural.is_zero_or_at_least_one(n) {
                    | Or.introduceLeft(nZero) => absurd(nNonzero(nZero))
                    | Or.introduceRight(positive) => positive
                  }
                };
                obtain ⟨predecessor, nEqualsSuccessor⟩
                    from Natural.subtraction_witness(1, n, oneAtMostN);
                -- nEqualsSuccessor : n = 1 + predecessor = successor(predecessor).
                calc x * (successor(predecessor) : Integer)
                          = x * Natural.to_integer(n)
                          = x * y
                          = Integer.zero
                          = Integer.zero * (successor(predecessor) : Integer) as productCancellable;
                Integer.multiply_cancel_right_by_natural_successor(
                    x, Integer.zero, predecessor, productCancellable)
              }
            | Or.introduceRight(yNegative) => {
                obtain ⟨n, yIsNegativeImage⟩ from yNegative;
                -- y = -(n : Integer); n ≠ 0 (else y = 0).
                claim nNonzero : ¬(n = 0) by {
                  suppose n = 0 as nZero;
                  absurd(yNonzero(
                      calc y
                         = -Natural.to_integer(n)
                         = -Natural.to_integer(0)
                         = Integer.zero))
                };
                claim oneAtMostN : 1 ≤ n by {
                  cases Natural.is_zero_or_at_least_one(n) {
                    | Or.introduceLeft(nZero) => absurd(nNonzero(nZero))
                    | Or.introduceRight(positive) => positive
                  }
                };
                obtain ⟨predecessor, nEqualsSuccessor⟩
                    from Natural.subtraction_witness(1, n, oneAtMostN);
                calc x * (successor(predecessor) : Integer)
                          = x * Natural.to_integer(n)
                          = x * (-y)
                                by congruenceOf(
                                       (z : Integer) ↦ x * z,
                                       calc Natural.to_integer(n)
                                          = -(-Natural.to_integer(n))
                                          = -y)
                          = Integer.zero * (successor(predecessor) : Integer)
                                by calc x * (-y)
                                      = -(x * y)
                                      = -Integer.zero
                                      = Integer.zero * (successor(predecessor) : Integer) as productCancellable;
                Integer.multiply_cancel_right_by_natural_successor(
                    x, Integer.zero, predecessor, productCancellable)
              }
          }
        };
        Or.introduceLeft(xIsZero)
      }
  }
}

-- ----------------------------------------------------------------------
-- ℤ as an integral domain.

theorem Integer.bundle_has_no_zero_divisors
        : Ring.HasNoZeroDivisors(Integer.ring_bundle) :=
  Integer.multiply_eq_zero_implies

definition Integer.integral_domain : IntegralDomain :=
  IntegralDomain.make(Integer.commutative_ring_bundle, Integer.one_not_zero,
      Integer.bundle_has_no_zero_divisors)

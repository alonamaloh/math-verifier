-- Algebra/rank_four_weighted_d4_third_double_covers.math
--
-- The nine selected forms with third residue 2.

module Algebra.rank_four_weighted_d4_third_double_covers

import Algebra.rank_four_weighted_d4_third_double_parity

theorem Matrix.weightedD4S0R2C4_universal_of_one_two_four_converse (converse : Matrix.OneTwoFourConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 2, 4)) :=
  by Matrix.weightedD4ThirdDouble_universal_selected_odd_core_of_converse(
      converse, coefficient := 3, core := 11, halfCore := 5, coreSum := done, coreOdd := done,
      coreAdmissible := (exponent b : ℕ) ↦
        Natural.four_power_times_nonzero_mod_four_core_not_one_three_six_four_obstruction(
          exponent, b, 11, 2, 3, done, done, done, done, done))


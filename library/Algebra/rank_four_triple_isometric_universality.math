-- Algebra/rank_four_triple_isometric_universality.math
--
-- The first selected form over x²+y²+3z² is just the diagonal form
-- x²+y²+3z²+2w².  Global deduplication records its coordinate-swap
-- isometry with the unselected double-family form x²+y²+2z²+3w²,
-- so no represented-set theorem for x²+y²+3z² is needed in this case.

module Algebra.rank_four_triple_isometric_universality

import Algebra.rank_four_double_zero_residue_universality
import Algebra.rank_four_isometry_certificates_generated

theorem Matrix.tripleR0C2_universal_of_three_squares_converse
        (converse : Matrix.ThreeSquaresConverse)
        : Matrix.IsUniversal(Matrix.sumOfTwoSquaresPlusScaledSquareRankFourRepresentative(3, 0, 2)) := {
  Matrix.IsUniversal(Matrix.sumOfTwoSquaresPlusScaledSquareRankFourRepresentative(2, 0, 3))
      by Matrix.doubleS0C3_universal_of_three_squares_converse(converse) as sourceUniversal;
  Matrix.IsIsometric(
      Matrix.sumOfTwoSquaresPlusScaledSquareRankFourRepresentative(3, 0, 2),
      Matrix.sumOfTwoSquaresPlusScaledSquareRankFourRepresentative(2, 0, 3))
      by Matrix.IsIsometric.symmetric(
          isometric := Matrix.rankFourGlobalIsometry_double_r0_c3_to_triple_r0_c2) as reverse;
  done by Matrix.isometric_universal(isometric := reverse, universal := sourceUniversal)
}

-- Algebra/integer_quadratic_form.math
--
-- Integer quadratic forms: what it means for a form to represent an
-- integer, to represent every positive integer (universality — the subject
-- of the fifteen theorem), and to be positive-definite. The two invariance
-- theorems: an isometric change of basis (U ∈ GLₙ(ℤ)) preserves the
-- represented set and the discriminant, and — the lever of the escalation
-- method — anything a sublattice's form represents, the ambient form
-- represents too.

module Algebra.integer_quadratic_form

import Logic.basics
import Logic.functions
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.order
import Natural.classical_decidable
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.embedding
import Integer.order
import Integer.units
import Set.finite
import Lists.list
import Lists.map
import Lists.distinct
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.commutative_ring_aggregation
import Algebra.ring_from_integer
import Algebra.integer_domain
import Algebra.finite_permutation
import Algebra.permutation_enumeration
import Algebra.permutation_sign
import Integer.integral_domain
import Algebra.matrix
import Algebra.matrix_ring
import Algebra.matrix_transpose
import Algebra.matrix_vector
import Algebra.matrix_submatrix
import Algebra.determinant
import Algebra.determinant_identity
import Algebra.determinant_transpose
import Algebra.determinant_multiplicative
import Algebra.alternating_collapse
import Algebra.determinant_row_permutation
import Algebra.adjugate
import Algebra.matrix_inverse
import Algebra.unimodular
import Algebra.quadratic_form

-- A form represents an integer when the integer is a value of the form.
definition Matrix.Represents {n : ℕ}
        (A : Matrix(Integer.commutative_ring_bundle, n, n)) (target : ℤ) : Proposition :=
  ∃ (x : RingVector(Integer.commutative_ring_bundle, n)). Matrix.quadraticForm(A, x) = target

-- Universality: the form represents every positive integer.
definition Matrix.IsUniversal {n : ℕ}
        (A : Matrix(Integer.commutative_ring_bundle, n, n)) : Proposition :=
  ∀ (m : ℕ). m ≥ 1 → Matrix.Represents(A, (m : ℤ))

-- Positive-definiteness, stated over integer vectors: the form is positive
-- away from zero. (Scaling by a common denominator shows this agrees with
-- the ℚ-vector statement; the ℝ statement is deferred to the stage that
-- needs it.)
definition Matrix.IsPositiveDefinite {n : ℕ}
        (A : Matrix(Integer.commutative_ring_bundle, n, n)) : Proposition :=
  ∀ (x : RingVector(Integer.commutative_ring_bundle, n)).
      ¬(x = RingVector.zero(Integer.commutative_ring_bundle, n))
      → Matrix.quadraticForm(A, x) > (0 : ℤ)

-- ----------------------------------------------------------------------
-- Sections of a positive-definite form are positive-definite: an injective
-- index selection embeds vectors without collapsing anything, so the
-- section's values are among the ambient form's values away from zero.
-- In particular every leading principal section is positive-definite, and
-- every diagonal entry — the form at a standard basis vector — is positive.

theorem Matrix.positive_definite_section {n k : ℕ}
        (A : Matrix(Integer.commutative_ring_bundle, n, n))
        (select : NaturalsBelow(k) → NaturalsBelow(n))
        (injective : Function.IsInjective(select))
        (positiveDefinite : Matrix.IsPositiveDefinite(A))
        : Matrix.IsPositiveDefinite(Matrix.submatrix(A, select, select)) := {
  take x : RingVector(Integer.commutative_ring_bundle, k);
  suppose ¬(x = RingVector.zero(Integer.commutative_ring_bundle, k));
  ¬(Matrix.inclusionMatrix(Integer.commutative_ring_bundle, select) · x
        = RingVector.zero(Integer.commutative_ring_bundle, n))
      by Matrix.inclusionMatrix_applyVector_nonzero;
  Matrix.quadraticForm(A, Matrix.inclusionMatrix(Integer.commutative_ring_bundle, select) · x)
      > (0 : ℤ) by positiveDefinite;
  Matrix.quadraticForm(Matrix.submatrix(A, select, select), x)
     = Matrix.quadraticForm(A, Matrix.inclusionMatrix(Integer.commutative_ring_bundle, select) · x)
         by Matrix.quadraticForm_submatrix as sectionAgrees;
  done by substituting sectionAgrees
}

theorem Matrix.positive_definite_leadingSubmatrix {n k : ℕ}
        (A : Matrix(Integer.commutative_ring_bundle, n, n)) (bound : k ≤ n)
        (positiveDefinite : Matrix.IsPositiveDefinite(A))
        : Matrix.IsPositiveDefinite(Matrix.leadingSubmatrix(A, bound)) := {
  Function.IsInjective(NaturalsBelow.embed(bound)) by NaturalsBelow.embed_injective;
  Matrix.IsPositiveDefinite(
        Matrix.submatrix(A, NaturalsBelow.embed(bound), NaturalsBelow.embed(bound)))
      by Matrix.positive_definite_section;
  done
}

theorem Matrix.positive_definite_diagonal {n : ℕ}
        (A : Matrix(Integer.commutative_ring_bundle, n, n)) (j : NaturalsBelow(n))
        (positiveDefinite : Matrix.IsPositiveDefinite(A))
        : A(j, j) > (0 : ℤ) := {
  -- The standard basis vector is nonzero: its j-th coordinate is 1.
  ¬(Matrix.standardBasisRow(Integer.commutative_ring_bundle, n, j)
        = RingVector.zero(Integer.commutative_ring_bundle, n))
      by (basisZero : Matrix.standardBasisRow(Integer.commutative_ring_bundle, n, j)
              = RingVector.zero(Integer.commutative_ring_bundle, n)) ↦ {
          Matrix.standardBasisRow(Integer.commutative_ring_bundle, n, j)(j) = Integer.one
              by Matrix.standardBasisRow_at as basisAtJ;
          Integer.one
             = Matrix.standardBasisRow(Integer.commutative_ring_bundle, n, j)(j)   by basisAtJ
             = RingVector.zero(Integer.commutative_ring_bundle, n)(j)              by substituting basisZero
             = Integer.zero;
          Integer.one ≠ Integer.zero by Integer.one_is_nonzero;
          done
        };
  Matrix.quadraticForm(A, Matrix.standardBasisRow(Integer.commutative_ring_bundle, n, j)) > (0 : ℤ)
      by positiveDefinite;
  done by substituting Matrix.quadraticForm_standardBasis
}

-- ----------------------------------------------------------------------
-- Sublattice monotonicity: if the restriction of A along M — the pulled-back
-- form MᵀAM — represents a number, the ambient form represents it at the
-- image vector M·x. This is the lever of every escalator universality proof.

theorem Matrix.represents_of_sublattice {n k : ℕ}
        (A : Matrix(Integer.commutative_ring_bundle, n, n))
        (M : Matrix(Integer.commutative_ring_bundle, n, k)) (target : ℤ)
        (sublatticeRepresents : Matrix.Represents(Mᵀ * A * M, target))
        : Matrix.Represents(A, target) := {
  choose x such that Matrix.quadraticForm(Mᵀ * A * M, x) = target from sublatticeRepresents;
  Matrix.quadraticForm(A, M · x)
     = Matrix.quadraticForm(Mᵀ * A * M, x)       by Matrix.quadraticForm_pullback
     = target;
  witness M · x with done
}

-- ----------------------------------------------------------------------
-- The represented set is an isometry invariant.

theorem Matrix.isometric_represents {n : ℕ}
        (A B : Matrix(Integer.commutative_ring_bundle, n, n)) (target : ℤ)
        (isometric : Matrix.IsIsometric(A, B))
        (represented : Matrix.Represents(B, target))
        : Matrix.Represents(A, target) := {
  choose U such that Matrix.IsInvertible(U) ∧ B = Uᵀ * A * U from isometric;
  Matrix.Represents(Uᵀ * A * U, target) by substituting (B = Uᵀ * A * U);
  done by Matrix.represents_of_sublattice
}

theorem Matrix.isometric_universal {n : ℕ}
        (A B : Matrix(Integer.commutative_ring_bundle, n, n))
        (isometric : Matrix.IsIsometric(A, B))
        (universal : Matrix.IsUniversal(B))
        : Matrix.IsUniversal(A) := {
  take m : ℕ;
  suppose m ≥ 1;
  Matrix.Represents(B, (m : ℤ)) by universal;
  done by Matrix.isometric_represents
}

-- Positive-definiteness is an isometry invariant: the pulled-back form
-- takes the same values, at vectors an invertible U keeps nonzero.
theorem Matrix.isometric_positive_definite {n : ℕ}
        (A B : Matrix(Integer.commutative_ring_bundle, n, n))
        (isometric : Matrix.IsIsometric(A, B))
        (positiveDefinite : Matrix.IsPositiveDefinite(A))
        : Matrix.IsPositiveDefinite(B) := {
  choose U such that Matrix.IsInvertible(U) ∧ B = Uᵀ * A * U from isometric;
  take x : RingVector(Integer.commutative_ring_bundle, n);
  suppose ¬(x = RingVector.zero(Integer.commutative_ring_bundle, n));
  Matrix.IsInvertible(U);
  ¬(U · x = RingVector.zero(Integer.commutative_ring_bundle, n))
      by Matrix.applyVector_nonzero_of_invertible;
  Matrix.quadraticForm(A, U · x) > (0 : ℤ) by positiveDefinite;
  Matrix.quadraticForm(B, x)
     = Matrix.quadraticForm(Uᵀ * A * U, x)      by substituting (B = Uᵀ * A * U)
     = Matrix.quadraticForm(A, U · x)           by Matrix.quadraticForm_pullback
  as formsAgree;
  done by substituting formsAgree
}

-- ----------------------------------------------------------------------
-- The discriminant is an isometry invariant: det changes by (det U)² = 1.

theorem Matrix.isometric_determinant {n : ℕ}
        (A B : Matrix(Integer.commutative_ring_bundle, n, n))
        (isometric : Matrix.IsIsometric(A, B))
        : Matrix.determinant(B) = Matrix.determinant(A) := {
  choose U such that Matrix.IsInvertible(U) ∧ B = Uᵀ * A * U from isometric;
  Matrix.IsInvertible(U);
  Matrix.determinant(U) = Integer.one ∨ Matrix.determinant(U) = Integer.negate(Integer.one)
      by Matrix.determinant_unimodular_of_invertible;
  Matrix.determinant(U) * Matrix.determinant(U) = Integer.one
      by Integer.unit_squares_to_one as determinantSquareOne;
  Matrix.determinant(B)
     = Matrix.determinant(Uᵀ * A * U)                                            by substituting (B = Uᵀ * A * U)
     = (Matrix.determinant(U) * Matrix.determinant(U)) * Matrix.determinant(A)   by Matrix.determinant_pullback
     = Integer.one * Matrix.determinant(A)                                       by substituting determinantSquareOne
     = Matrix.determinant(A)
}

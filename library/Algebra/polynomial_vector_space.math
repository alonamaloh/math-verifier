-- Algebra/polynomial_vector_space.math
--
-- The polynomial ring F[x] as a vector space over its field of scalars —
-- the worked INFINITE-dimensional example (its monomial basis {xⁿ} is
-- indexed by all of `Natural`, so F[x] is a basis-carrying space that is
-- NOT `FiniteDimensional`). Everything here is choice-free and direct.
--
-- Scalar action is multiplication by the constant polynomial: `a • p` is
-- `(a·x⁰)·p`, whose coefficients are `a` times those of `p`
-- (`Polynomial.coefficientOf_monomial_multiply` at exponent zero). The
-- module laws then reduce, index by index, to base-ring identities via
-- polynomial extensionality (`Polynomial.equal_of_coefficientOf_equal`).
--
-- The base ring of the polynomials is the field's own commutative ring,
-- `Field.coefficient_ring(f)`, whose carrier and constants are the
-- field's by definition — so the Polynomial operations and the field
-- scalars share a carrier with no coercion.

module Algebra.polynomial_vector_space

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.division
import Natural.monus
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.aggregation
import Algebra.ring
import Algebra.ring_lemmas
import Algebra.ring_bundle
import Algebra.ring_summation
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.field
import Algebra.field_bundle
import Algebra.vector_space
import Algebra.vector_space_lemmas
import Algebra.linear_combination
import Algebra.span
import Algebra.finite_dimensional
import Polynomial.basics
import Polynomial.addition
import Polynomial.negation
import Polynomial.additive_group
import Polynomial.multiplication
import Polynomial.multiply_laws
import Polynomial.instances
import Polynomial.degree
import Polynomial.degree_function
import Polynomial.division
import Polynomial.monomial

-- The coefficient ring of F[x]: the field's own commutative ring, viewed
-- as a plain `Ring`. Its carrier and constants are the field's — e.g.
-- `Ring.carrier(Field.coefficient_ring(f))` reduces to `Field.carrier(f)`
-- — so no coercion stands between the polynomial coefficients and the
-- field scalars.
definition Field.coefficient_ring (f : Field) : Ring :=
  CommutativeRing.ring(Field.commutative_ring(f))

-- Scalar multiplication of a polynomial by a field element: multiply by
-- the constant polynomial `a·x⁰`.
definition Field.polynomial_scale (f : Field) (a : Field.carrier(f))
        (p : Polynomial(Ring.carrier(Field.coefficient_ring(f)),
                        Ring.zero(Field.coefficient_ring(f))))
        : Polynomial(Ring.carrier(Field.coefficient_ring(f)),
                     Ring.zero(Field.coefficient_ring(f))) :=
  Polynomial.monomial(Field.coefficient_ring(f), a, 0) * p

-- Its coefficients: `a` times those of `p`, index by index. The
-- convolution with a degree-zero monomial collapses to a single term.
theorem Field.coefficientOf_polynomial_scale (f : Field) (a : Field.carrier(f))
        (p : Polynomial(Ring.carrier(Field.coefficient_ring(f)),
                        Ring.zero(Field.coefficient_ring(f))))
        (k : ℕ)
        : Field.polynomial_scale(f, a, p)[k] = a * p[k] :=
  (Polynomial.monomial(Field.coefficient_ring(f), a, 0) * p)[k]
     = a * p[k ∸ 0]
           by Polynomial.coefficientOf_monomial_multiply
     = a * p[k]

-- ----------------------------------------------------------------------
-- The four scalar-action laws, each reduced index by index to a
-- base-ring identity through polynomial extensionality.

theorem Field.polynomial_scale_vector_add (f : Field) (a : Field.carrier(f))
        (p q : Polynomial(Ring.carrier(Field.coefficient_ring(f)),
                          Ring.zero(Field.coefficient_ring(f))))
        : Field.polynomial_scale(f, a, (p + q))
          = Field.polynomial_scale(f, a, p) + Field.polynomial_scale(f, a, q) := {
  suffices ∀ (k : ℕ).
      Field.polynomial_scale(f, a, (p + q))[k]
      = (Field.polynomial_scale(f, a, p) + Field.polynomial_scale(f, a, q))[k]
    by Polynomial.equal_of_coefficientOf_equal;
  take k : ℕ;
  Field.polynomial_scale(f, a, (p + q))[k]
     = a * (p + q)[k]   by Field.coefficientOf_polynomial_scale
     = a * (p[k] + q[k])   by Polynomial.coefficientOf_add
     = a * p[k] + a * q[k]
     = Field.polynomial_scale(f, a, p)[k] + a * q[k]   by Field.coefficientOf_polynomial_scale
     = Field.polynomial_scale(f, a, p)[k] + Field.polynomial_scale(f, a, q)[k]
           by Field.coefficientOf_polynomial_scale
     = (Field.polynomial_scale(f, a, p) + Field.polynomial_scale(f, a, q))[k]
           by Polynomial.coefficientOf_add
}

theorem Field.polynomial_scale_scalar_add (f : Field) (a b : Field.carrier(f))
        (p : Polynomial(Ring.carrier(Field.coefficient_ring(f)),
                        Ring.zero(Field.coefficient_ring(f))))
        : Field.polynomial_scale(f, (a + b), p)
          = Field.polynomial_scale(f, a, p) + Field.polynomial_scale(f, b, p) := {
  suffices ∀ (k : ℕ).
      Field.polynomial_scale(f, (a + b), p)[k]
      = (Field.polynomial_scale(f, a, p) + Field.polynomial_scale(f, b, p))[k]
    by Polynomial.equal_of_coefficientOf_equal;
  take k : ℕ;
  Field.polynomial_scale(f, (a + b), p)[k]
     = (a + b) * p[k]   by Field.coefficientOf_polynomial_scale
     = a * p[k] + b * p[k]
     = Field.polynomial_scale(f, a, p)[k] + b * p[k]   by Field.coefficientOf_polynomial_scale
     = Field.polynomial_scale(f, a, p)[k] + Field.polynomial_scale(f, b, p)[k]
           by Field.coefficientOf_polynomial_scale
     = (Field.polynomial_scale(f, a, p) + Field.polynomial_scale(f, b, p))[k]
           by Polynomial.coefficientOf_add
}

theorem Field.polynomial_scale_scalar_multiply (f : Field) (a b : Field.carrier(f))
        (p : Polynomial(Ring.carrier(Field.coefficient_ring(f)),
                        Ring.zero(Field.coefficient_ring(f))))
        : Field.polynomial_scale(f, (a * b), p)
          = Field.polynomial_scale(f, a, Field.polynomial_scale(f, b, p)) := {
  suffices ∀ (k : ℕ).
      Field.polynomial_scale(f, (a * b), p)[k]
      = Field.polynomial_scale(f, a, Field.polynomial_scale(f, b, p))[k]
    by Polynomial.equal_of_coefficientOf_equal;
  take k : ℕ;
  Field.polynomial_scale(f, (a * b), p)[k]
     = (a * b) * p[k]   by Field.coefficientOf_polynomial_scale
     = a * (b * p[k])
     = a * Field.polynomial_scale(f, b, p)[k]   by Field.coefficientOf_polynomial_scale
     = Field.polynomial_scale(f, a, Field.polynomial_scale(f, b, p))[k]
           by Field.coefficientOf_polynomial_scale
}

theorem Field.polynomial_one_scale (f : Field)
        (p : Polynomial(Ring.carrier(Field.coefficient_ring(f)),
                        Ring.zero(Field.coefficient_ring(f))))
        : Field.polynomial_scale(f, Field.one(f), p) = p := {
  suffices ∀ (k : ℕ).
      Field.polynomial_scale(f, Field.one(f), p)[k] = p[k]
    by Polynomial.equal_of_coefficientOf_equal;
  take k : ℕ;
  Field.polynomial_scale(f, Field.one(f), p)[k]
     = Field.one(f) * p[k]   by Field.coefficientOf_polynomial_scale
     = p[k]
}

-- ----------------------------------------------------------------------
-- The bundled vector space F[x] over F.

theorem Field.polynomial_is_vector_space (f : Field)
        : IsVectorSpace(f,
              Polynomial(Ring.carrier(Field.coefficient_ring(f)),
                         Ring.zero(Field.coefficient_ring(f))),
              Polynomial.add, Polynomial.zero(Field.coefficient_ring(f)),
              Polynomial.negate, Field.polynomial_scale(f)) := {
  IsAbelianGroup(Polynomial(Ring.carrier(Field.coefficient_ring(f)),
                            Ring.zero(Field.coefficient_ring(f))),
                 Polynomial.add, Polynomial.zero(Field.coefficient_ring(f)),
                 Polynomial.negate)
      by Polynomial.add_is_abelian_group;
  ∀ (a : Field.carrier(f)).
      ∀ (u v : Polynomial(Ring.carrier(Field.coefficient_ring(f)),
                          Ring.zero(Field.coefficient_ring(f)))).
      Field.polynomial_scale(f, a, (u + v))
      = Field.polynomial_scale(f, a, u) + Field.polynomial_scale(f, a, v)
    by Field.polynomial_scale_vector_add;
  ∀ (a b : Field.carrier(f)).
      ∀ (v : Polynomial(Ring.carrier(Field.coefficient_ring(f)),
                        Ring.zero(Field.coefficient_ring(f)))).
      Field.polynomial_scale(f, (a + b), v)
      = Field.polynomial_scale(f, a, v) + Field.polynomial_scale(f, b, v)
    by Field.polynomial_scale_scalar_add;
  ∀ (a b : Field.carrier(f)).
      ∀ (v : Polynomial(Ring.carrier(Field.coefficient_ring(f)),
                        Ring.zero(Field.coefficient_ring(f)))).
      Field.polynomial_scale(f, (a * b), v)
      = Field.polynomial_scale(f, a, Field.polynomial_scale(f, b, v))
    by Field.polynomial_scale_scalar_multiply;
  ∀ (v : Polynomial(Ring.carrier(Field.coefficient_ring(f)),
                    Ring.zero(Field.coefficient_ring(f)))).
      Field.polynomial_scale(f, Field.one(f), v) = v
    by Field.polynomial_one_scale;
  done
}

definition Field.polynomial_vector_space (f : Field) : VectorSpace(f) :=
  VectorSpace.make(
      Polynomial(Ring.carrier(Field.coefficient_ring(f)),
                 Ring.zero(Field.coefficient_ring(f))),
      Polynomial.add, Polynomial.zero(Field.coefficient_ring(f)),
      Polynomial.negate, Field.polynomial_scale(f),
      Field.polynomial_is_vector_space)

-- ----------------------------------------------------------------------
-- Single-term extraction from a field sum. These are the additive-fold
-- analogues of `Ring.Sum.vanishes_below`/`single_point`, proved directly
-- over `Algebra.Fold` on the field so the monomial-basis arguments never
-- leave the field carrier. `fold_single_point` is BOUNDED — its
-- vanishing hypothesis is only required below the count — because a
-- linear combination's off-diagonal terms (with an arbitrary injective
-- selection) are controlled only for indices actually in range.

theorem Field.fold_vanishes (f : Field) (g : ℕ → Field.carrier(f))
        (count : ℕ)
        : (∀ (j : ℕ). j < count → g(j) = Field.zero(f))
          → Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f), g, 0, count)
            = Field.zero(f) :=
  by induction on count with IH {
    case base: (vanish : ∀ (j : ℕ). j < 0 → g(j) = Field.zero(f)) ↦ done
    case step(m):
        (vanish : ∀ (j : ℕ). j < 1 + m → g(j) = Field.zero(f)) ↦ {
          m < 1 + m as mBelow;
          g(m) = Field.zero(f) by vanish(m, mBelow) as gmZero;
          ∀ (j : ℕ). j < m → g(j) = Field.zero(f)
              by {
                take j : ℕ;
                suppose j < m as jLessM;
                j < 1 + m as jBelow;
                done by vanish(j, jBelow)
              }
            as vanishBelowM;
          Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f), g, 0, m)
              = Field.zero(f) by IH(vanishBelowM) as foldBelowZero;
          Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f), g, 0, 1 + m)
             = Field.add(Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f), g, 0, m), g(0 + m))
                   by Algebra.Fold_add_one
             = Field.add(Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f), g, 0, m), g(m))
             = Field.add(Field.zero(f), g(m)) by substituting foldBelowZero
             = Field.add(Field.zero(f), Field.zero(f)) by substituting gmZero
             = Field.zero(f)
        }
  }

theorem Field.fold_single_point (f : Field) (g : ℕ → Field.carrier(f))
        (target : ℕ) (count : ℕ)
        : target < count
          → (∀ (j : ℕ). j < count → ¬(j = target) → g(j) = Field.zero(f))
          → Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f), g, 0, count)
            = g(target) :=
  by induction on count with IH {
    case base:
        (targetBelow : target < 0)
                (vanish : ∀ (j : ℕ). j < 0 → ¬(j = target) → g(j) = Field.zero(f)) ↦ {
          ¬(target < 0) by Natural.not_less_than_zero;
          done
        }
    case step(m):
        (targetBelow : target < 1 + m)
                (vanish : ∀ (j : ℕ). j < 1 + m → ¬(j = target)
                          → g(j) = Field.zero(f)) ↦
            done by cases {
              case target = m as targetIsM: {
                  ∀ (j : ℕ). j < m → g(j) = Field.zero(f)
                      by {
                        take j : ℕ;
                        suppose j < m as jLessM;
                        j < target;
                        j < 1 + m as jBelow;
                        ¬(j = target) by Natural.not_equal_of_less_than as jNotTarget;
                        done by vanish(j, jBelow, jNotTarget)
                      };
                  Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f), g, 0, m)
                      = Field.zero(f) by Field.fold_vanishes as foldBelowZero;
                  Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f), g, 0, 1 + m)
                     = Field.add(Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f), g, 0, m), g(0 + m))
                           by Algebra.Fold_add_one
                     = Field.add(Field.zero(f), g(m)) by substituting foldBelowZero
                     = g(m)
                     = g(target)
                }
              otherwise as targetNotM: {
                  target ≤ m by Natural.le_of_lt_one_plus;
                  target < m as targetLessM;
                  m < 1 + m as mBelow;
                  ¬(m = target) by {
                    suppose m = target as mIsTarget;
                    target = m;
                    done
                  } as mNotTarget;
                  g(m) = Field.zero(f) by vanish(m, mBelow, mNotTarget) as gmZero;
                  ∀ (j : ℕ). j < m → ¬(j = target) → g(j) = Field.zero(f)
                      by {
                        take j : ℕ;
                        suppose j < m as jLessM;
                        suppose ¬(j = target) as jNotTarget;
                        j < 1 + m as jBelow;
                        done by vanish(j, jBelow, jNotTarget)
                      }
                    as vanishBelowM;
                  Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f), g, 0, m)
                      = g(target) by IH(targetLessM, vanishBelowM) as foldBelowTarget;
                  Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f), g, 0, 1 + m)
                     = Field.add(Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f), g, 0, m), g(0 + m))
                           by Algebra.Fold_add_one
                     = Field.add(g(target), g(m)) by substituting foldBelowTarget
                     = Field.add(g(target), Field.zero(f)) by substituting gmZero
                     = g(target)
                }
            }
  }

-- ----------------------------------------------------------------------
-- The monomial family {xⁿ} and its basis property.

-- The n-th monomial xⁿ as a vector of F[x].
definition Field.monomial_family (f : Field)
        : ℕ → VectorSpace.carrier(Field.polynomial_vector_space(f)) :=
  (n : ℕ) ↦ Polynomial.monomial(Field.coefficient_ring(f), Field.one(f), n)

-- The coefficient at index m of a linear combination of monomials is the
-- field sum of each term's coefficient contribution — `coefficientOf` is
-- an additive homomorphism, so it commutes with the combination fold.
theorem Field.coefficientOf_monomial_linearCombination (f : Field)
        (coefficients : ℕ → Field.carrier(f))
        (selection : ℕ → ℕ) (count : ℕ) (m : ℕ)
        : VectorSpace.linearCombination(Field.monomial_family(f), coefficients, selection, count)[m]
          = Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f),
                (j : ℕ) ↦ coefficients(j) * Field.monomial_family(f)(selection(j))[m],
                0, count) :=
  by induction on count with IH {
    case base: {
        VectorSpace.linearCombination(Field.monomial_family(f), coefficients, selection, 0)[m]
           = Field.zero(f) by Polynomial.coefficientOf_zero
           = Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f),
                 (j : ℕ) ↦ coefficients(j) * Field.monomial_family(f)(selection(j))[m],
                 0, 0)
                 by Algebra.Fold_zero
      }
    case step(n): {
        VectorSpace.linearCombination(Field.monomial_family(f), coefficients, selection, 1 + n)[m]
           = (VectorSpace.linearCombination(Field.monomial_family(f), coefficients, selection, n)
                 + coefficients(n) • Field.monomial_family(f)(selection(n)))[m]
                 by substituting VectorSpace.linearCombination_add_one
           = VectorSpace.linearCombination(Field.monomial_family(f), coefficients, selection, n)[m]
             + (coefficients(n) • Field.monomial_family(f)(selection(n)))[m]
                 by Polynomial.coefficientOf_add
           = Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f),
                 (j : ℕ) ↦ coefficients(j) * Field.monomial_family(f)(selection(j))[m],
                 0, n)
             + (coefficients(n) • Field.monomial_family(f)(selection(n)))[m]
                 by IH
           = Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f),
                 (j : ℕ) ↦ coefficients(j) * Field.monomial_family(f)(selection(j))[m],
                 0, n)
             + coefficients(n) * Field.monomial_family(f)(selection(n))[m]
                 by Field.coefficientOf_polynomial_scale
           = Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f),
                 (j : ℕ) ↦ coefficients(j) * Field.monomial_family(f)(selection(j))[m],
                 0, n)
             + coefficients(0 + n) * Field.monomial_family(f)(selection(0 + n))[m]
                 by substituting Natural.zero_add
           = Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f),
                 (j : ℕ) ↦ coefficients(j) * Field.monomial_family(f)(selection(j))[m],
                 0, 1 + n)
                 by Algebra.Fold_add_one
      }
  }

-- ----------------------------------------------------------------------
-- {xⁿ} spans F[x]: a polynomial of degree < N is the combination, with
-- the identity selection, of its first N coefficients against x⁰,…,x^{N−1}.

theorem Field.monomial_family_spans (f : Field)
        : VectorSpace.Spans(Field.monomial_family(f)) := {
  take p : VectorSpace.carrier(Field.polynomial_vector_space(f));
  ∃ (n : ℕ). Polynomial.DegreeLessThan(Field.coefficient_ring(f), p, n)
      by Polynomial.exists_degree_bound as degreeBoundExists;
  choose degreeBound such that Polynomial.DegreeLessThan(Field.coefficient_ring(f), p, degreeBound)
      as pBounded
      from degreeBoundExists;
  VectorSpace.linearCombination(Field.monomial_family(f), (i : ℕ) ↦ p[i], (i : ℕ) ↦ i, degreeBound)
      = p
      by {
        suffices ∀ (m : ℕ).
            VectorSpace.linearCombination(Field.monomial_family(f), (i : ℕ) ↦ p[i], (i : ℕ) ↦ i, degreeBound)[m]
            = p[m]
          by Polynomial.equal_of_coefficientOf_equal;
        take m : ℕ;
        m < degreeBound ∨ degreeBound ≤ m by Natural.lt_or_le;
        Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f),
                (j : ℕ) ↦ p[j] * Field.monomial_family(f)(j)[m],
                0, degreeBound)
            = p[m]
            by {
              done by cases {
                   case m < degreeBound as mLessBound: {
                       Field.monomial_family(f)(m)[m] = Field.one(f)
                           by Polynomial.coefficientOf_monomial_at as diagonalOne;
                       ∀ (j : ℕ). j < degreeBound → ¬(j = m)
                           → p[j] * Field.monomial_family(f)(j)[m] = Field.zero(f)
                           by {
                             take j : ℕ;
                             suppose j < degreeBound as jBelowBound;
                             suppose ¬(j = m) as jNotM;
                             ¬(m = j) by {
                               suppose m = j as mIsJ;
                               j = m by mIsJ;
                               done
                             };
                             Field.monomial_family(f)(j)[m] = Field.zero(f)
                                 by Polynomial.coefficientOf_monomial_off as offZero;
                             p[j] * Field.monomial_family(f)(j)[m]
                                = p[j] * Field.zero(f)
                                      by substituting offZero
                                = Field.zero(f)
                           };
                       Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f),
                             (j : ℕ) ↦ p[j] * Field.monomial_family(f)(j)[m],
                             0, degreeBound)
                          = p[m] * Field.monomial_family(f)(m)[m]
                                by Field.fold_single_point
                          = p[m] * Field.one(f)
                                by substituting diagonalOne
                          = p[m]
                     }
                   case degreeBound ≤ m as boundLeM: {
                       p[m] = Field.zero(f)
                           by pBounded(m, boundLeM) as coeffPZero;
                       ∀ (j : ℕ). j < degreeBound
                           → p[j] * Field.monomial_family(f)(j)[m] = Field.zero(f)
                           by {
                             take j : ℕ;
                             suppose j < degreeBound as jBelowBound;
                             j < m by { j < degreeBound by jBelowBound ≤ m by boundLeM };
                             ¬(m = j) by Natural.not_equal_of_less_than;
                             Field.monomial_family(f)(j)[m] = Field.zero(f)
                                 by Polynomial.coefficientOf_monomial_off as offZero;
                             p[j] * Field.monomial_family(f)(j)[m]
                                = p[j] * Field.zero(f)
                                      by substituting offZero
                                = Field.zero(f)
                           };
                       Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f),
                             (j : ℕ) ↦ p[j] * Field.monomial_family(f)(j)[m],
                             0, degreeBound)
                          = Field.zero(f) by Field.fold_vanishes
                          = p[m]
                                by coeffPZero
                     }
              }
            }
            as foldEqCoeff;
        VectorSpace.linearCombination(Field.monomial_family(f), (i : ℕ) ↦ p[i], (i : ℕ) ↦ i, degreeBound)[m]
           = Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f),
                 (j : ℕ) ↦ p[j] * Field.monomial_family(f)(j)[m],
                 0, degreeBound)
                 by Field.coefficientOf_monomial_linearCombination
           = p[m]
                 by foldEqCoeff
      }
      as combinationIsP;
  p = VectorSpace.linearCombination(Field.monomial_family(f), (i : ℕ) ↦ p[i], (i : ℕ) ↦ i, degreeBound)
      by combinationIsP
      as targetIsCombination;
  VectorSpace.InSpanOf(Field.monomial_family(f), p)
      by { witness degreeBound
               with witness ((i : ℕ) ↦ i)
               with witness ((i : ℕ) ↦ p[i])
               with targetIsCombination };
  done
}

-- ----------------------------------------------------------------------
-- {xⁿ} is linearly independent: read a vanishing combination's
-- coefficient at index selection(i). Injectivity makes every other
-- monomial vanish there, so that coefficient is exactly coefficients(i),
-- and the combination being zero forces it to zero.

theorem Field.monomial_family_independent (f : Field)
        : VectorSpace.LinearlyIndependent(Field.monomial_family(f)) := {
  take count : ℕ;
  take selection : ℕ → ℕ;
  take coefficients : ℕ → Field.carrier(f);
  suppose ∀ (i j : ℕ). i < count → j < count → selection(i) = selection(j) → i = j
      as selectionInjective;
  suppose VectorSpace.linearCombination(Field.monomial_family(f), coefficients, selection, count)
              = VectorSpace.zero(Field.polynomial_vector_space(f))
      as combinationVanishes;
  take i : ℕ;
  suppose i < count as indexBelowCount;
  Field.monomial_family(f)(selection(i))[selection(i)] = Field.one(f)
      by Polynomial.coefficientOf_monomial_at as diagonalOne;
  ∀ (j : ℕ). j < count → ¬(j = i)
      → coefficients(j) * Field.monomial_family(f)(selection(j))[selection(i)] = Field.zero(f)
      by {
        take j : ℕ;
        suppose j < count as jBelowCount;
        suppose ¬(j = i) as jNotI;
        ¬(selection(i) = selection(j)) by {
          suppose selection(i) = selection(j) as selectionsEqual;
          i = j;
          j = i;
          done
        };
        Field.monomial_family(f)(selection(j))[selection(i)] = Field.zero(f)
            by Polynomial.coefficientOf_monomial_off as offZero;
        coefficients(j) * Field.monomial_family(f)(selection(j))[selection(i)]
           = coefficients(j) * Field.zero(f) by substituting offZero
           = Field.zero(f)
      };
  VectorSpace.linearCombination(Field.monomial_family(f), coefficients, selection, count)[selection(i)]
     = Algebra.Fold(Field.carrier(f), Field.add, Field.zero(f),
           (j : ℕ) ↦ coefficients(j) * Field.monomial_family(f)(selection(j))[selection(i)],
           0, count)
           by Field.coefficientOf_monomial_linearCombination
     = coefficients(i) * Field.monomial_family(f)(selection(i))[selection(i)]
           by Field.fold_single_point
     = coefficients(i) * Field.one(f) by substituting diagonalOne
     = coefficients(i)
     as combinationCoefficientIsCi;
  coefficients(i)
     = VectorSpace.linearCombination(Field.monomial_family(f), coefficients, selection, count)[selection(i)]
           by combinationCoefficientIsCi
     = VectorSpace.zero(Field.polynomial_vector_space(f))[selection(i)]
           by substituting combinationVanishes
     = Field.zero(f) by Polynomial.coefficientOf_zero
}

theorem Field.monomial_family_is_basis (f : Field)
        : VectorSpace.IsBasis(Field.monomial_family(f)) := {
  VectorSpace.LinearlyIndependent(Field.monomial_family(f))
      by Field.monomial_family_independent;
  VectorSpace.Spans(Field.monomial_family(f)) by Field.monomial_family_spans;
  done
}

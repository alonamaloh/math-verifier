-- Algebra/conjugation_action.math
--
-- The conjugation action of a group on itself: g acts on x by
-- x â†¦ gآ·xآ·gâپ»آ¹. This is the canonical non-trivial group action, and it
-- ties the action machinery (Algebra/group_action) back to the center
-- (Algebra/center):
--
--   * conjugation is an action of G on its own carrier, and
--   * its kernel â€” the elements acting trivially on every point â€” is
--     exactly the center Z(G).
--
-- The second fact is the conceptual content of "the center is the kernel
-- of the conjugation action", proved here as the two set inclusions:
-- gâپ»آ¹ disappears precisely when g commutes with everything.
--
-- All algebra is by hand through Group.associative and the inverse/
-- identity laws (groups are not commutative).

module Algebra.conjugation_action

import Logic.basics
import Logic.exists
import Equality.basics
import Set.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.group_bundle
import Algebra.subgroup
import Algebra.normal_subgroup
import Algebra.group_action
import Algebra.center

-- Conjugation of x by g: gآ·xآ·gâپ»آ¹.
definition Group.conjugation (G : Group)
        (g x : Group.carrier(G)) : Group.carrier(G) :=
  g آ· x آ· gâپ»آ¹

-- Conjugation is an action of G on its carrier.
--
--   * identity:      eآ·xآ·eâپ»آ¹ = x
--   * compatibility: (gآ·h)آ·xآ·(gآ·h)âپ»آ¹ = gآ·(hآ·xآ·hâپ»آ¹)آ·gâپ»آ¹
theorem Group.conjugation_is_action (G : Group)
        : IsAction(G, Group.carrier(G), Group.conjugation(G)) :=
  âں¨(x : Group.carrier(G)) â†¦
     calc Group.identity(G) آ· x آ· Group.identity(G)âپ»آ¹
        = x آ· Group.identity(G)
        = x,
   (g h x : Group.carrier(G)) â†¦
     calc (g آ· h) آ· x آ· (g آ· h)âپ»آ¹
        = (g آ· (h آ· x)) آ· (hâپ»آ¹ آ· gâپ»آ¹)
        = g آ· ((h آ· x) آ· (hâپ»آ¹ آ· gâپ»آ¹))
        = g آ· (((h آ· x) آ· hâپ»آ¹) آ· gâپ»آ¹)
        = (g آ· ((h آ· x) آ· hâپ»آ¹)) آ· gâپ»آ¹âں©

-- ----------------------------------------------------------------------
-- The center is the kernel of the conjugation action.
--
-- The kernel of conjugation is { z | zآ·xآ·zâپ»آ¹ = x for all x }; the center
-- is { z | zآ·g = gآ·z for all g }. The two conditions are equivalent.

-- A central element acts trivially by conjugation: from zآ·x = xآ·z,
--   zآ·xآ·zâپ»آ¹ = xآ·zآ·zâپ»آ¹ = xآ·(zآ·zâپ»آ¹) = xآ·e = x.
theorem Group.center_subset_conjugation_kernel (G : Group)
        : Group.center(G)
          âٹ† Group.action.kernel(G, Group.carrier(G), Group.conjugation(G)) :=
  (z : Group.carrier(G)) (zCentral : z âˆˆ Group.center(G)) â†¦
    (x : Group.carrier(G)) â†¦
      calc z آ· x آ· zâپ»آ¹
         = x آ· z آ· zâپ»آ¹
               by rewrite(zCentral(x))
         = x آ· (z آ· zâپ»آ¹)
         = x آ· Group.identity(G)
         = x

-- Conversely, if z acts trivially by conjugation then z is central: from
-- zآ·gآ·zâپ»آ¹ = g, multiply on the right by z to clear the zâپ»آ¹:
--   zآ·g = (zآ·g)آ·(zâپ»آ¹آ·z) = ((zآ·g)آ·zâپ»آ¹)آ·z = gآ·z.
theorem Group.conjugation_kernel_subset_center (G : Group)
        : Group.action.kernel(G, Group.carrier(G), Group.conjugation(G))
          âٹ† Group.center(G) :=
  (z : Group.carrier(G))
           (zActsTrivially
               : z âˆˆ Group.action.kernel(G, Group.carrier(G), Group.conjugation(G))) â†¦
    (g : Group.carrier(G)) â†¦ {
      -- zآ·gآ·zâپ»آ¹ = g, the conjugation-kernel condition in unfolded form.
      claim z آ· g آ· zâپ»آ¹ = g by zActsTrivially(g);
      calc z آ· g
         = (z آ· g) آ· Group.identity(G)
         = (z آ· g) آ· (zâپ»آ¹ آ· z)
         = ((z آ· g) آ· zâپ»آ¹) آ· z
         = g آ· z
    }

-- The stabilizer of a point a under conjugation is a subgroup â€” this is
-- the centralizer of a, { g | gآ·aآ·gâپ»آ¹ = a } = { g | gآ·a = aآ·g }.
-- Instantiated from the generic stabilizer-is-subgroup lemma.
theorem Group.centralizer_is_subgroup (G : Group) (a : Group.carrier(G))
        : IsSubgroup(G,
              Group.action.stabilizer(G, Group.carrier(G), Group.conjugation(G), a)) :=
  Group.action.stabilizer_is_subgroup(
      G, Group.carrier(G), Group.conjugation(G),
      Group.conjugation_is_action(G), a)

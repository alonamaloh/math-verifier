-- Algebra/permutation_sign.math
--
-- The sign of a permutation and its multiplicativity, via the product formula
--   sign(σ) = ∏_{i<j} orient(σ(i), σ(j)),  orient(x, y) = ±1 by value order.
-- This file builds the orientation ±1 and its algebra; the sign product and
-- multiplicativity (Stage H brick 3 of PLAN_LINEAR_ALGEBRA.md) build on it.

module Algebra.permutation_sign

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.order
import Natural.classical_decidable
import Integer.basics
import Algebra.integer_domain
import Logic.product
import Lists.list
import Lists.map
import Lists.append
import Lists.filter
import Lists.permutation
import Lists.distinct
import Lists.cartesian
import Algebra.finite_permutation
import Algebra.permutation_enumeration

-- Two Natural order facts the antisymmetry proof leans on.
theorem Natural.lt_or_gt_of_ne (a b : Natural) (distinct : a ≠ b) : a < b ∨ b < a := {
  a < b ∨ a = b ∨ b < a by Natural.lt_trichotomy(a, b);
  done by cases {
    case a < b as below: below
    case a = b as equal: absurd(distinct(equal))
    case b < a as above: above
  }
}

theorem Natural.lt_asymmetric (a b : Natural) (below : a < b) : ¬(b < a) :=
  (above : b < a) ↦ {
    a < a by Natural.lt_transitive(a, b, a, below, above);
    False by Natural.lt_irreflexive(a);
    done
  }

-- The orientation of an ordered pair: +1 if x precedes y by value, −1 otherwise.
-- On a pair of DISTINCT indices this is the sign of the value difference.
definition Permutation.orient {n : Natural} (x y : NaturalsBelow(n)) : Integer :=
  if NaturalsBelow.value(x) < NaturalsBelow.value(y) then (1 : Integer) else Integer.negate(1)

theorem Permutation.orient_forward {n : Natural} (x y : NaturalsBelow(n))
        (precedes : NaturalsBelow.value(x) < NaturalsBelow.value(y))
        : Permutation.orient(x, y) = 1 :=
  done by Logic.if_positive

theorem Permutation.orient_backward {n : Natural} (x y : NaturalsBelow(n))
        (notPrecedes : ¬(NaturalsBelow.value(x) < NaturalsBelow.value(y)))
        : Permutation.orient(x, y) = Integer.negate(1) :=
  done by Logic.if_negative

-- The orientation is a unit: it is +1 or −1.
theorem Permutation.orient_is_unit {n : Natural} (x y : NaturalsBelow(n))
        : Permutation.orient(x, y) = 1 ∨ Permutation.orient(x, y) = Integer.negate(1) := {
  NaturalsBelow.value(x) < NaturalsBelow.value(y)
      ∨ ¬(NaturalsBelow.value(x) < NaturalsBelow.value(y));
  done by cases {
    case NaturalsBelow.value(x) < NaturalsBelow.value(y) as precedes: {
        Permutation.orient(x, y) = 1 by Permutation.orient_forward(x, y, precedes);
        done
      }
    case ¬(NaturalsBelow.value(x) < NaturalsBelow.value(y)) as notPrecedes: {
        Permutation.orient(x, y) = Integer.negate(1) by Permutation.orient_backward(x, y, notPrecedes);
        done
      }
  }
}

-- Antisymmetry: swapping the pair negates the orientation (for distinct values).
theorem Permutation.orient_antisymmetric {n : Natural} (x y : NaturalsBelow(n))
        (distinctValues : NaturalsBelow.value(x) ≠ NaturalsBelow.value(y))
        : Permutation.orient(x, y) = Integer.negate(Permutation.orient(y, x)) := {
  NaturalsBelow.value(x) < NaturalsBelow.value(y)
      ∨ NaturalsBelow.value(y) < NaturalsBelow.value(x)
      by Natural.lt_or_gt_of_ne(NaturalsBelow.value(x), NaturalsBelow.value(y), distinctValues);
  done by cases {
    case NaturalsBelow.value(x) < NaturalsBelow.value(y) as xFirst: {
        ¬(NaturalsBelow.value(y) < NaturalsBelow.value(x))
            by Natural.lt_asymmetric(NaturalsBelow.value(x), NaturalsBelow.value(y), xFirst)
            as notBack;
        Permutation.orient(x, y)
           = 1 by Permutation.orient_forward(x, y, xFirst)
           = Integer.negate(Integer.negate(1)) by ring
           = Integer.negate(Permutation.orient(y, x))
                 by substituting Permutation.orient_backward(y, x, notBack);
        done
      }
    case NaturalsBelow.value(y) < NaturalsBelow.value(x) as yFirst: {
        ¬(NaturalsBelow.value(x) < NaturalsBelow.value(y))
            by Natural.lt_asymmetric(NaturalsBelow.value(y), NaturalsBelow.value(x), yFirst);
        Permutation.orient(x, y)
           = Integer.negate(1) by Permutation.orient_backward(x, y)
           = Integer.negate(Permutation.orient(y, x))
                 by substituting Permutation.orient_forward(y, x, yFirst);
        done
      }
  }
}

-- ----------------------------------------------------------------------
-- The sign, as the product of orientations over the ordered index pairs.
-- `orderedPairs(n)` lists each pair (i, j) with value(i) < value(j) exactly
-- once (as the value-ordered filter of the Cartesian square of the index
-- enumeration), and the sign is the product of `orient(σi, σj)` over it.

definition Permutation.indexPairBelow {n : Natural}
        (p : Pair(NaturalsBelow(n), NaturalsBelow(n))) : Proposition :=
  NaturalsBelow.value(Product.first(p)) < NaturalsBelow.value(Product.second(p))

definition Permutation.orderedPairs (n : Natural) : List(Pair(NaturalsBelow(n), NaturalsBelow(n))) :=
  List.filter(Pair(NaturalsBelow(n), NaturalsBelow(n)), Permutation.indexPairBelow,
      List.cartesianProduct(NaturalsBelow(n), NaturalsBelow(n),
          NaturalsBelow.enumerate(n), NaturalsBelow.enumerate(n)))

definition Permutation.pairOrient {n : Natural} (sigma : Permutation(n))
        (p : Pair(NaturalsBelow(n), NaturalsBelow(n))) : Integer :=
  Permutation.orient(Permutation.apply(sigma, Product.first(p)), Permutation.apply(sigma, Product.second(p)))

definition Permutation.sign {n : Natural} (sigma : Permutation(n)) : Integer :=
  List.product(Integer, Integer.multiply, Integer.one,
      List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer,
          Permutation.pairOrient(sigma), Permutation.orderedPairs(n)))

-- Every value-ordered pair is enumerated, and every enumerated pair is
-- value-ordered and distinct.
theorem Permutation.orderedPairs_member (n : Natural) (i j : NaturalsBelow(n))
        (precedes : NaturalsBelow.value(i) < NaturalsBelow.value(j))
        : List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), Product.make(i, j),
              Permutation.orderedPairs(n)) :=
  List.filter_member_complete(Pair(NaturalsBelow(n), NaturalsBelow(n)), Permutation.indexPairBelow,
      Product.make(i, j),
      List.cartesianProduct(NaturalsBelow(n), NaturalsBelow(n),
          NaturalsBelow.enumerate(n), NaturalsBelow.enumerate(n)),
      List.cartesianProduct_member(NaturalsBelow(n), NaturalsBelow(n), i, j,
          NaturalsBelow.enumerate(n), NaturalsBelow.enumerate(n),
          NaturalsBelow.enumerate_complete(n, i), NaturalsBelow.enumerate_complete(n, j)),
      precedes)

theorem Permutation.orderedPairs_property (n : Natural)
        (p : Pair(NaturalsBelow(n), NaturalsBelow(n)))
        (memberP : List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), p, Permutation.orderedPairs(n)))
        : NaturalsBelow.value(Product.first(p)) < NaturalsBelow.value(Product.second(p)) :=
  List.filter_member_property(Pair(NaturalsBelow(n), NaturalsBelow(n)), Permutation.indexPairBelow, p,
      List.cartesianProduct(NaturalsBelow(n), NaturalsBelow(n),
          NaturalsBelow.enumerate(n), NaturalsBelow.enumerate(n)), memberP)

theorem Permutation.orderedPairs_distinct (n : Natural)
        : List.Distinct(Pair(NaturalsBelow(n), NaturalsBelow(n)), Permutation.orderedPairs(n)) :=
  List.filter_distinct(Pair(NaturalsBelow(n), NaturalsBelow(n)), Permutation.indexPairBelow,
      List.cartesianProduct(NaturalsBelow(n), NaturalsBelow(n),
          NaturalsBelow.enumerate(n), NaturalsBelow.enumerate(n)),
      List.cartesianProduct_distinct(NaturalsBelow(n), NaturalsBelow(n),
          NaturalsBelow.enumerate(n), NaturalsBelow.enumerate_distinct(n),
          NaturalsBelow.enumerate(n), NaturalsBelow.enumerate_distinct(n)))

-- The multiplicative unit of Integer, as the identity the fold-product needs.
theorem Integer.one_multiply_left (a : Integer) : Integer.multiply(Integer.one, a) = a := ring

-- A fold-product of a list every element of which is `one` is `one`.
theorem List.product_of_ones (A : Type(0)) (multiply : A → A → A) (one : A)
        (identityLeft : ∀ (a : A). multiply(one, a) = a)
        (l : List(A)) (allOne : ∀ (x : A). List.member(A, x, l) → x = one)
        : List.product(A, multiply, one, l) = one :=
  by induction on l with IH {
    case List.empty: reflexivity(one)
    case List.prepend(head, tail): {
        head = one by allOne(head, List.member.here(A, head, tail)) as headIsOne;
        (∀ (x : A). List.member(A, x, tail) → x = one)
            by (x : A) (xInTail : List.member(A, x, tail)) ↦
                allOne(x, List.member.there(A, x, head, tail, xInTail)) as tailAllOne;
        List.product(A, multiply, one, List.prepend(A, head, tail))
           = multiply(head, List.product(A, multiply, one, tail))
           = multiply(one, List.product(A, multiply, one, tail)) by substituting headIsOne
           = List.product(A, multiply, one, tail) by identityLeft(List.product(A, multiply, one, tail))
           = one by IH(tailAllOne);
        done
      }
  }

-- The identity has sign +1: on a value-ordered pair, orient keeps the order.
theorem Permutation.pairOrient_identity (n : Natural)
        (p : Pair(NaturalsBelow(n), NaturalsBelow(n)))
        (memberP : List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), p, Permutation.orderedPairs(n)))
        : Permutation.pairOrient(Permutation.identity(n), p) = 1 := {
  NaturalsBelow.value(Product.first(p)) < NaturalsBelow.value(Product.second(p))
      by Permutation.orderedPairs_property(n, p, memberP) as precedes;
  Permutation.pairOrient(Permutation.identity(n), p)
     = Permutation.orient(Permutation.apply(Permutation.identity(n), Product.first(p)),
           Permutation.apply(Permutation.identity(n), Product.second(p)))
     = Permutation.orient(Product.first(p), Permutation.apply(Permutation.identity(n), Product.second(p)))
           by substituting Permutation.apply_identity(n, Product.first(p))
     = Permutation.orient(Product.first(p), Product.second(p))
           by substituting Permutation.apply_identity(n, Product.second(p))
     = 1 by Permutation.orient_forward(Product.first(p), Product.second(p), precedes);
  done
}

theorem Permutation.sign_identity (n : Natural) : Permutation.sign(Permutation.identity(n)) = 1 := {
  (∀ (x : Integer). List.member(Integer, x,
      List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer,
          Permutation.pairOrient(Permutation.identity(n)), Permutation.orderedPairs(n))) → x = 1)
      by (x : Integer) (memberX : List.member(Integer, x,
          List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer,
              Permutation.pairOrient(Permutation.identity(n)), Permutation.orderedPairs(n)))) ↦ {
          choose p such that
              List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), p, Permutation.orderedPairs(n))
                  ∧ (Permutation.pairOrient(Permutation.identity(n), p) = x)
              from List.map_member_invert(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer,
                       Permutation.pairOrient(Permutation.identity(n)), x,
                       Permutation.orderedPairs(n), memberX);
          List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), p, Permutation.orderedPairs(n))
              as pMember;
          Permutation.pairOrient(Permutation.identity(n), p) = x as orientIsX;
          x = Permutation.pairOrient(Permutation.identity(n), p) by orientIsX
            = 1 by Permutation.pairOrient_identity(n, p, pMember);
          done
        } as allOne;
  done by List.product_of_ones(Integer, Integer.multiply, Integer.one, Integer.one_multiply_left,
      List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer,
          Permutation.pairOrient(Permutation.identity(n)), Permutation.orderedPairs(n)), allOne)
}

-- ----------------------------------------------------------------------
-- Multiplicativity: sign(σ ∘ τ) = sign σ · sign τ. The composite's product
-- factors pairwise into a τ-orientation and a σ-orientation on the τ-image of
-- the pair; the first product reassembles sign τ and the second, reindexed by
-- the τ-image (a permutation of the ordered pairs), reassembles sign σ.

-- A pair is its own components reassembled.
theorem Product.eta (A B : Type(0)) (p : Pair(A, B))
        : p = Product.make(Product.first(p), Product.second(p)) :=
  by induction on p {
    case Product.make(a, b): reflexivity(Product.make(a, b))
  }

-- Sorting a pair of indices into value order.
definition Permutation.sortPair {n : Natural} (a b : NaturalsBelow(n))
        : Pair(NaturalsBelow(n), NaturalsBelow(n)) :=
  if NaturalsBelow.value(a) < NaturalsBelow.value(b) then Product.make(a, b) else Product.make(b, a)

theorem Permutation.sortPair_forward {n : Natural} (a b : NaturalsBelow(n))
        (precedes : NaturalsBelow.value(a) < NaturalsBelow.value(b))
        : Permutation.sortPair(a, b) = Product.make(a, b) :=
  done by Logic.if_positive

theorem Permutation.sortPair_backward {n : Natural} (a b : NaturalsBelow(n))
        (notPrecedes : ¬(NaturalsBelow.value(a) < NaturalsBelow.value(b)))
        : Permutation.sortPair(a, b) = Product.make(b, a) :=
  done by Logic.if_negative

-- A list-map is unchanged if the two functions agree on the list's members.
theorem List.map_congruence_on (A B : Type(0)) (f g : A → B) (l : List(A))
        (agree : ∀ (x : A). List.member(A, x, l) → f(x) = g(x))
        : List.map(A, B, f, l) = List.map(A, B, g, l) :=
  by induction on l with IH {
    case List.empty: reflexivity(List.empty(B))
    case List.prepend(head, tail): {
        f(head) = g(head) by agree(head, List.member.here(A, head, tail)) as headAgree;
        (∀ (x : A). List.member(A, x, tail) → f(x) = g(x))
            by (x : A) (xInTail : List.member(A, x, tail)) ↦
                agree(x, List.member.there(A, x, head, tail, xInTail)) as tailAgree;
        List.map(A, B, f, List.prepend(A, head, tail))
           = List.prepend(B, f(head), List.map(A, B, f, tail))
           = List.prepend(B, g(head), List.map(A, B, f, tail)) by substituting headAgree
           = List.prepend(B, g(head), List.map(A, B, g, tail)) by substituting IH(tailAgree)
           = List.map(A, B, g, List.prepend(A, head, tail));
        done
      }
  }

-- The fold-product of a pointwise Integer product splits into the product of
-- the two fold-products.
theorem List.product_pointwise_multiply (B : Type(0)) (f g : B → Integer) (l : List(B))
        : List.product(Integer, Integer.multiply, Integer.one,
              List.map(B, Integer, (x : B) ↦ Integer.multiply(f(x), g(x)), l))
          = Integer.multiply(
                List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, f, l)),
                List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, g, l))) :=
  by induction on l with IH {
    case List.empty:
        List.product(Integer, Integer.multiply, Integer.one,
                 List.map(B, Integer, (x : B) ↦ Integer.multiply(f(x), g(x)), List.empty(B)))
           = Integer.one
           = Integer.multiply(Integer.one, Integer.one) by ring
           = Integer.multiply(
                 List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, f, List.empty(B))),
                 List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, g, List.empty(B))))
    case List.prepend(head, tail):
        List.product(Integer, Integer.multiply, Integer.one,
                 List.map(B, Integer, (x : B) ↦ Integer.multiply(f(x), g(x)), List.prepend(B, head, tail)))
           = Integer.multiply(Integer.multiply(f(head), g(head)),
                 List.product(Integer, Integer.multiply, Integer.one,
                     List.map(B, Integer, (x : B) ↦ Integer.multiply(f(x), g(x)), tail)))
           = Integer.multiply(Integer.multiply(f(head), g(head)),
                 Integer.multiply(
                     List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, f, tail)),
                     List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, g, tail))))
                 by substituting IH
           = Integer.multiply(
                 Integer.multiply(f(head),
                     List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, f, tail))),
                 Integer.multiply(g(head),
                     List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, g, tail))))
                 by ring
           = Integer.multiply(
                 List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, f, List.prepend(B, head, tail))),
                 List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, g, List.prepend(B, head, tail))))
  }

-- The reindexing map on ordered pairs: send (i, j) to the value-sorted image
-- (τ(i), τ(j)). It permutes `orderedPairs(n)` — the heart of the reindexing.
definition Permutation.pairImage {m : Natural} (tau : Permutation(m))
        (p : Pair(NaturalsBelow(m), NaturalsBelow(m))) : Pair(NaturalsBelow(m), NaturalsBelow(m)) :=
  Permutation.sortPair(Permutation.apply(tau, Product.first(p)), Permutation.apply(tau, Product.second(p)))

-- A value-ordered pair has distinct components.
theorem Permutation.pair_first_ne_second {n : Natural} (p : Pair(NaturalsBelow(n), NaturalsBelow(n)))
        (precedes : NaturalsBelow.value(Product.first(p)) < NaturalsBelow.value(Product.second(p)))
        : Product.first(p) ≠ Product.second(p) :=
  (equal : Product.first(p) = Product.second(p)) ↦ {
    NaturalsBelow.value(Product.first(p))
       < NaturalsBelow.value(Product.second(p)) by precedes
       = NaturalsBelow.value(Product.first(p)) by substituting equal;
    False by Natural.lt_irreflexive(NaturalsBelow.value(Product.first(p)));
    done
  }

-- A permutation sends distinct indices to indices with distinct values.
theorem Permutation.apply_values_distinct {n : Natural} (sigma : Permutation(n)) (a b : NaturalsBelow(n))
        (distinct : a ≠ b)
        : NaturalsBelow.value(Permutation.apply(sigma, a)) ≠ NaturalsBelow.value(Permutation.apply(sigma, b)) :=
  (valuesEqual : NaturalsBelow.value(Permutation.apply(sigma, a)) = NaturalsBelow.value(Permutation.apply(sigma, b))) ↦ {
    Permutation.apply(sigma, a) = Permutation.apply(sigma, b)
        by NaturalsBelow.equal_of_value(n, Permutation.apply(sigma, a), Permutation.apply(sigma, b), valuesEqual);
    a = b by Permutation.apply_injective(sigma, a, b);
    False by distinct;
    done
  }

-- The τ-image of an ordered pair is again an ordered pair.
theorem Permutation.pairImage_in_orderedPairs {n : Natural} (tau : Permutation(n))
        (p : Pair(NaturalsBelow(n), NaturalsBelow(n)))
        (memberP : List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), p, Permutation.orderedPairs(n)))
        : List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), Permutation.pairImage(tau, p),
              Permutation.orderedPairs(n)) := {
  NaturalsBelow.value(Product.first(p)) < NaturalsBelow.value(Product.second(p))
      by Permutation.orderedPairs_property(n, p, memberP) as precedes;
  Product.first(p) ≠ Product.second(p) by Permutation.pair_first_ne_second(p, precedes) as componentsDistinct;
  NaturalsBelow.value(Permutation.apply(tau, Product.first(p)))
      ≠ NaturalsBelow.value(Permutation.apply(tau, Product.second(p)))
      by Permutation.apply_values_distinct(tau, Product.first(p), Product.second(p), componentsDistinct)
      as imageValuesDistinct;
  NaturalsBelow.value(Permutation.apply(tau, Product.first(p))) < NaturalsBelow.value(Permutation.apply(tau, Product.second(p)))
      ∨ NaturalsBelow.value(Permutation.apply(tau, Product.second(p))) < NaturalsBelow.value(Permutation.apply(tau, Product.first(p)))
      by Natural.lt_or_gt_of_ne(NaturalsBelow.value(Permutation.apply(tau, Product.first(p))),
             NaturalsBelow.value(Permutation.apply(tau, Product.second(p))), imageValuesDistinct);
  done by cases {
    case NaturalsBelow.value(Permutation.apply(tau, Product.first(p))) < NaturalsBelow.value(Permutation.apply(tau, Product.second(p))) as imageForward: {
        Permutation.pairImage(tau, p)
           = Product.make(Permutation.apply(tau, Product.first(p)), Permutation.apply(tau, Product.second(p)))
                 by Permutation.sortPair_forward(Permutation.apply(tau, Product.first(p)), Permutation.apply(tau, Product.second(p)), imageForward);
        List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)),
              Product.make(Permutation.apply(tau, Product.first(p)), Permutation.apply(tau, Product.second(p))),
              Permutation.orderedPairs(n))
            by Permutation.orderedPairs_member(n, Permutation.apply(tau, Product.first(p)),
                   Permutation.apply(tau, Product.second(p)), imageForward);
        done
      }
    case NaturalsBelow.value(Permutation.apply(tau, Product.second(p))) < NaturalsBelow.value(Permutation.apply(tau, Product.first(p))) as imageBackward: {
        ¬(NaturalsBelow.value(Permutation.apply(tau, Product.first(p))) < NaturalsBelow.value(Permutation.apply(tau, Product.second(p))))
            by Natural.lt_asymmetric(NaturalsBelow.value(Permutation.apply(tau, Product.second(p))),
                   NaturalsBelow.value(Permutation.apply(tau, Product.first(p))), imageBackward) as notForward;
        Permutation.pairImage(tau, p)
           = Product.make(Permutation.apply(tau, Product.second(p)), Permutation.apply(tau, Product.first(p)))
                 by Permutation.sortPair_backward(Permutation.apply(tau, Product.first(p)), Permutation.apply(tau, Product.second(p)), notForward);
        List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)),
              Product.make(Permutation.apply(tau, Product.second(p)), Permutation.apply(tau, Product.first(p))),
              Permutation.orderedPairs(n))
            by Permutation.orderedPairs_member(n, Permutation.apply(tau, Product.second(p)),
                   Permutation.apply(tau, Product.first(p)), imageBackward);
        done
      }
  }
}

-- The τ-image is inverted by the τ⁻¹-image: it has a two-sided inverse on the
-- ordered pairs, hence is injective there.
theorem Permutation.pairImage_cancel {n : Natural} (tau : Permutation(n))
        (p : Pair(NaturalsBelow(n), NaturalsBelow(n)))
        (memberP : List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), p, Permutation.orderedPairs(n)))
        : Permutation.pairImage(Permutation.inverse(tau), Permutation.pairImage(tau, p)) = p := {
  let fp : NaturalsBelow(n) := Product.first(p);
  let sp : NaturalsBelow(n) := Product.second(p);
  NaturalsBelow.value(fp) < NaturalsBelow.value(sp)
      by Permutation.orderedPairs_property(n, p, memberP) as precedes;
  fp ≠ sp by Permutation.pair_first_ne_second(p, precedes) as fpNeSp;
  NaturalsBelow.value(Permutation.apply(tau, fp)) ≠ NaturalsBelow.value(Permutation.apply(tau, sp))
      by Permutation.apply_values_distinct(tau, fp, sp, fpNeSp) as imageDistinct;
  p = Product.make(fp, sp) by Product.eta(NaturalsBelow(n), NaturalsBelow(n), p) as pEta;
  NaturalsBelow.value(Permutation.apply(tau, fp)) < NaturalsBelow.value(Permutation.apply(tau, sp))
      ∨ NaturalsBelow.value(Permutation.apply(tau, sp)) < NaturalsBelow.value(Permutation.apply(tau, fp))
      by Natural.lt_or_gt_of_ne(NaturalsBelow.value(Permutation.apply(tau, fp)),
             NaturalsBelow.value(Permutation.apply(tau, sp)), imageDistinct);
  done by cases {
    case NaturalsBelow.value(Permutation.apply(tau, fp)) < NaturalsBelow.value(Permutation.apply(tau, sp)) as fwd: {
        Permutation.pairImage(tau, p)
            = Product.make(Permutation.apply(tau, fp), Permutation.apply(tau, sp))
                  by Permutation.sortPair_forward(Permutation.apply(tau, fp), Permutation.apply(tau, sp), fwd)
            as imageForward;
        Permutation.pairImage(Permutation.inverse(tau), Permutation.pairImage(tau, p))
           = Permutation.pairImage(Permutation.inverse(tau),
                 Product.make(Permutation.apply(tau, fp), Permutation.apply(tau, sp)))
                 by substituting imageForward
           = Permutation.sortPair(
                 Permutation.apply(Permutation.inverse(tau), Permutation.apply(tau, fp)),
                 Permutation.apply(Permutation.inverse(tau), Permutation.apply(tau, sp)))
           = Permutation.sortPair(Permutation.unapply(tau, Permutation.apply(tau, fp)),
                 Permutation.apply(Permutation.inverse(tau), Permutation.apply(tau, sp)))
                 by substituting Permutation.apply_inverse(tau, Permutation.apply(tau, fp))
           = Permutation.sortPair(fp, Permutation.apply(Permutation.inverse(tau), Permutation.apply(tau, sp)))
                 by substituting Permutation.left_inverse(tau, fp)
           = Permutation.sortPair(fp, Permutation.unapply(tau, Permutation.apply(tau, sp)))
                 by substituting Permutation.apply_inverse(tau, Permutation.apply(tau, sp))
           = Permutation.sortPair(fp, sp) by substituting Permutation.left_inverse(tau, sp)
           = Product.make(fp, sp) by Permutation.sortPair_forward(fp, sp, precedes)
           = p by pEta;
        done
      }
    case NaturalsBelow.value(Permutation.apply(tau, sp)) < NaturalsBelow.value(Permutation.apply(tau, fp)) as bwd: {
        ¬(NaturalsBelow.value(Permutation.apply(tau, fp)) < NaturalsBelow.value(Permutation.apply(tau, sp)))
            by Natural.lt_asymmetric(NaturalsBelow.value(Permutation.apply(tau, sp)),
                   NaturalsBelow.value(Permutation.apply(tau, fp)), bwd) as notForward;
        ¬(NaturalsBelow.value(sp) < NaturalsBelow.value(fp))
            by Natural.lt_asymmetric(NaturalsBelow.value(fp), NaturalsBelow.value(sp), precedes) as spNotBelowFp;
        Permutation.pairImage(tau, p)
            = Product.make(Permutation.apply(tau, sp), Permutation.apply(tau, fp))
                  by Permutation.sortPair_backward(Permutation.apply(tau, fp), Permutation.apply(tau, sp), notForward)
            as imageBackward;
        Permutation.pairImage(Permutation.inverse(tau), Permutation.pairImage(tau, p))
           = Permutation.pairImage(Permutation.inverse(tau),
                 Product.make(Permutation.apply(tau, sp), Permutation.apply(tau, fp)))
                 by substituting imageBackward
           = Permutation.sortPair(
                 Permutation.apply(Permutation.inverse(tau), Permutation.apply(tau, sp)),
                 Permutation.apply(Permutation.inverse(tau), Permutation.apply(tau, fp)))
           = Permutation.sortPair(Permutation.unapply(tau, Permutation.apply(tau, sp)),
                 Permutation.apply(Permutation.inverse(tau), Permutation.apply(tau, fp)))
                 by substituting Permutation.apply_inverse(tau, Permutation.apply(tau, sp))
           = Permutation.sortPair(sp, Permutation.apply(Permutation.inverse(tau), Permutation.apply(tau, fp)))
                 by substituting Permutation.left_inverse(tau, sp)
           = Permutation.sortPair(sp, Permutation.unapply(tau, Permutation.apply(tau, fp)))
                 by substituting Permutation.apply_inverse(tau, Permutation.apply(tau, fp))
           = Permutation.sortPair(sp, fp) by substituting Permutation.left_inverse(tau, fp)
           = Product.make(fp, sp) by Permutation.sortPair_backward(sp, fp, spNotBelowFp)
           = p by pEta;
        done
      }
  }
}

-- Injectivity of the τ-image on the ordered pairs (from the cancellation).
theorem Permutation.pairImage_injective_on {n : Natural} (tau : Permutation(n))
        (p q : Pair(NaturalsBelow(n), NaturalsBelow(n)))
        (memberP : List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), p, Permutation.orderedPairs(n)))
        (memberQ : List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), q, Permutation.orderedPairs(n)))
        (imagesEqual : Permutation.pairImage(tau, p) = Permutation.pairImage(tau, q))
        : p = q :=
  p = Permutation.pairImage(Permutation.inverse(tau), Permutation.pairImage(tau, p))
          by Permutation.pairImage_cancel(tau, p, memberP)
    = Permutation.pairImage(Permutation.inverse(tau), Permutation.pairImage(tau, q))
          by substituting imagesEqual
    = q by Permutation.pairImage_cancel(tau, q, memberQ)

-- Distinct values force distinct indices.
theorem NaturalsBelow.ne_of_value_ne {n : Natural} (a b : NaturalsBelow(n))
        (valuesNe : NaturalsBelow.value(a) ≠ NaturalsBelow.value(b)) : a ≠ b :=
  (equal : a = b) ↦ {
    NaturalsBelow.value(a) = NaturalsBelow.value(b) by substituting equal;
    False by valuesNe;
    done
  }

-- The pointwise factorization: on an ordered pair, the composite's orientation
-- is the τ-orientation times the σ-orientation on the sorted τ-image.
theorem Permutation.pairFactor {n : Natural} (sigma tau : Permutation(n))
        (p : Pair(NaturalsBelow(n), NaturalsBelow(n)))
        (memberP : List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), p, Permutation.orderedPairs(n)))
        : Permutation.pairOrient(Permutation.compose(sigma, tau), p)
          = Integer.multiply(Permutation.pairOrient(tau, p),
                Permutation.pairOrient(sigma, Permutation.pairImage(tau, p))) := {
  let fp : NaturalsBelow(n) := Product.first(p);
  let sp : NaturalsBelow(n) := Product.second(p);
  NaturalsBelow.value(fp) < NaturalsBelow.value(sp)
      by Permutation.orderedPairs_property(n, p, memberP) as precedes;
  fp ≠ sp by Permutation.pair_first_ne_second(p, precedes) as fpNeSp;
  NaturalsBelow.value(Permutation.apply(tau, fp)) ≠ NaturalsBelow.value(Permutation.apply(tau, sp))
      by Permutation.apply_values_distinct(tau, fp, sp, fpNeSp) as tauImageDistinct;
  Permutation.apply(tau, fp) ≠ Permutation.apply(tau, sp)
      by NaturalsBelow.ne_of_value_ne(Permutation.apply(tau, fp), Permutation.apply(tau, sp), tauImageDistinct)
      as tauImageNe;
  NaturalsBelow.value(Permutation.apply(sigma, Permutation.apply(tau, fp)))
      ≠ NaturalsBelow.value(Permutation.apply(sigma, Permutation.apply(tau, sp)))
      by Permutation.apply_values_distinct(sigma, Permutation.apply(tau, fp), Permutation.apply(tau, sp), tauImageNe)
      as sigmaImageDistinct;
  NaturalsBelow.value(Permutation.apply(tau, fp)) < NaturalsBelow.value(Permutation.apply(tau, sp))
      ∨ NaturalsBelow.value(Permutation.apply(tau, sp)) < NaturalsBelow.value(Permutation.apply(tau, fp))
      by Natural.lt_or_gt_of_ne(NaturalsBelow.value(Permutation.apply(tau, fp)),
             NaturalsBelow.value(Permutation.apply(tau, sp)), tauImageDistinct);
  done by cases {
    case NaturalsBelow.value(Permutation.apply(tau, fp)) < NaturalsBelow.value(Permutation.apply(tau, sp)) as fwd: {
        Permutation.pairOrient(tau, p) = 1
            by Permutation.orient_forward(Permutation.apply(tau, fp), Permutation.apply(tau, sp), fwd)
            as tauOrientOne;
        Permutation.pairImage(tau, p)
            = Product.make(Permutation.apply(tau, fp), Permutation.apply(tau, sp))
                  by Permutation.sortPair_forward(Permutation.apply(tau, fp), Permutation.apply(tau, sp), fwd)
            as imageForward;
        Permutation.pairOrient(sigma, Permutation.pairImage(tau, p))
           = Permutation.pairOrient(sigma,
                 Product.make(Permutation.apply(tau, fp), Permutation.apply(tau, sp))) by substituting imageForward
           = Permutation.orient(Permutation.apply(sigma, Permutation.apply(tau, fp)),
                 Permutation.apply(sigma, Permutation.apply(tau, sp)))
           as sigmaImageOrient;
        Permutation.pairOrient(Permutation.compose(sigma, tau), p)
           = Permutation.orient(Permutation.apply(Permutation.compose(sigma, tau), fp),
                 Permutation.apply(Permutation.compose(sigma, tau), sp))
           = Permutation.orient(Permutation.apply(sigma, Permutation.apply(tau, fp)),
                 Permutation.apply(Permutation.compose(sigma, tau), sp))
                 by substituting Permutation.apply_compose(sigma, tau, fp)
           = Permutation.orient(Permutation.apply(sigma, Permutation.apply(tau, fp)),
                 Permutation.apply(sigma, Permutation.apply(tau, sp)))
                 by substituting Permutation.apply_compose(sigma, tau, sp)
           = Integer.multiply(1, Permutation.orient(Permutation.apply(sigma, Permutation.apply(tau, fp)),
                 Permutation.apply(sigma, Permutation.apply(tau, sp)))) by ring
           = Integer.multiply(Permutation.pairOrient(tau, p),
                 Permutation.orient(Permutation.apply(sigma, Permutation.apply(tau, fp)),
                     Permutation.apply(sigma, Permutation.apply(tau, sp))))
                 by substituting tauOrientOne
           = Integer.multiply(Permutation.pairOrient(tau, p),
                 Permutation.pairOrient(sigma, Permutation.pairImage(tau, p)))
                 by substituting sigmaImageOrient;
        done
      }
    case NaturalsBelow.value(Permutation.apply(tau, sp)) < NaturalsBelow.value(Permutation.apply(tau, fp)) as bwd: {
        ¬(NaturalsBelow.value(Permutation.apply(tau, fp)) < NaturalsBelow.value(Permutation.apply(tau, sp)))
            by Natural.lt_asymmetric(NaturalsBelow.value(Permutation.apply(tau, sp)),
                   NaturalsBelow.value(Permutation.apply(tau, fp)), bwd) as notForward;
        Permutation.pairOrient(tau, p) = Integer.negate(1)
            by Permutation.orient_backward(Permutation.apply(tau, fp), Permutation.apply(tau, sp), notForward)
            as tauOrientNegOne;
        Permutation.pairImage(tau, p)
            = Product.make(Permutation.apply(tau, sp), Permutation.apply(tau, fp))
                  by Permutation.sortPair_backward(Permutation.apply(tau, fp), Permutation.apply(tau, sp), notForward)
            as imageBackward;
        Permutation.pairOrient(sigma, Permutation.pairImage(tau, p))
           = Permutation.pairOrient(sigma,
                 Product.make(Permutation.apply(tau, sp), Permutation.apply(tau, fp))) by substituting imageBackward
           = Permutation.orient(Permutation.apply(sigma, Permutation.apply(tau, sp)),
                 Permutation.apply(sigma, Permutation.apply(tau, fp)))
           as sigmaImageOrient;
        Permutation.pairOrient(Permutation.compose(sigma, tau), p)
           = Permutation.orient(Permutation.apply(Permutation.compose(sigma, tau), fp),
                 Permutation.apply(Permutation.compose(sigma, tau), sp))
           = Permutation.orient(Permutation.apply(sigma, Permutation.apply(tau, fp)),
                 Permutation.apply(Permutation.compose(sigma, tau), sp))
                 by substituting Permutation.apply_compose(sigma, tau, fp)
           = Permutation.orient(Permutation.apply(sigma, Permutation.apply(tau, fp)),
                 Permutation.apply(sigma, Permutation.apply(tau, sp)))
                 by substituting Permutation.apply_compose(sigma, tau, sp)
           = Integer.negate(Permutation.orient(Permutation.apply(sigma, Permutation.apply(tau, sp)),
                 Permutation.apply(sigma, Permutation.apply(tau, fp))))
                 by Permutation.orient_antisymmetric(Permutation.apply(sigma, Permutation.apply(tau, fp)),
                        Permutation.apply(sigma, Permutation.apply(tau, sp)), sigmaImageDistinct)
           = Integer.multiply(Integer.negate(1),
                 Permutation.orient(Permutation.apply(sigma, Permutation.apply(tau, sp)),
                     Permutation.apply(sigma, Permutation.apply(tau, fp)))) by ring
           = Integer.multiply(Permutation.pairOrient(tau, p),
                 Permutation.orient(Permutation.apply(sigma, Permutation.apply(tau, sp)),
                     Permutation.apply(sigma, Permutation.apply(tau, fp))))
                 by substituting tauOrientNegOne
           = Integer.multiply(Permutation.pairOrient(tau, p),
                 Permutation.pairOrient(sigma, Permutation.pairImage(tau, p)))
                 by substituting sigmaImageOrient;
        done
      }
  }
}

-- The τ-image permutes the ordered-pair list: it is an injective self-map with
-- image inside the list and the same length.
theorem Permutation.pairImage_permutes {n : Natural} (tau : Permutation(n))
        : List.Permutation(Pair(NaturalsBelow(n), NaturalsBelow(n)),
              List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Pair(NaturalsBelow(n), NaturalsBelow(n)),
                  Permutation.pairImage(tau), Permutation.orderedPairs(n)),
              Permutation.orderedPairs(n)) := {
  List.Distinct(Pair(NaturalsBelow(n), NaturalsBelow(n)),
          List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Pair(NaturalsBelow(n), NaturalsBelow(n)),
              Permutation.pairImage(tau), Permutation.orderedPairs(n)))
      by List.map_distinct_on(Pair(NaturalsBelow(n), NaturalsBelow(n)), Pair(NaturalsBelow(n), NaturalsBelow(n)),
             Permutation.pairImage(tau), Permutation.orderedPairs(n),
             (x y : Pair(NaturalsBelow(n), NaturalsBelow(n)))
                 (memberX : List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), x, Permutation.orderedPairs(n)))
                 (memberY : List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), y, Permutation.orderedPairs(n)))
                 (imagesEqual : Permutation.pairImage(tau, x) = Permutation.pairImage(tau, y)) ↦
                 Permutation.pairImage_injective_on(tau, x, y, memberX, memberY, imagesEqual),
             Permutation.orderedPairs_distinct(n))
      as imageDistinct;
  (∀ (x : Pair(NaturalsBelow(n), NaturalsBelow(n))).
      List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), x,
          List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Pair(NaturalsBelow(n), NaturalsBelow(n)),
              Permutation.pairImage(tau), Permutation.orderedPairs(n)))
      → List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), x, Permutation.orderedPairs(n)))
      by (x : Pair(NaturalsBelow(n), NaturalsBelow(n)))
         (memberX : List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), x,
             List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Pair(NaturalsBelow(n), NaturalsBelow(n)),
                 Permutation.pairImage(tau), Permutation.orderedPairs(n)))) ↦ {
          choose p such that
              List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), p, Permutation.orderedPairs(n))
                  ∧ (Permutation.pairImage(tau, p) = x)
              from List.map_member_invert(Pair(NaturalsBelow(n), NaturalsBelow(n)), Pair(NaturalsBelow(n), NaturalsBelow(n)),
                       Permutation.pairImage(tau), x, Permutation.orderedPairs(n), memberX);
          List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), p, Permutation.orderedPairs(n)) as pMember;
          Permutation.pairImage(tau, p) = x as imageIsX;
          List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), Permutation.pairImage(tau, p), Permutation.orderedPairs(n))
              by Permutation.pairImage_in_orderedPairs(tau, p, pMember);
          List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), x, Permutation.orderedPairs(n))
              by substituting imageIsX;
          done
        } as inclusion;
  length(List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Pair(NaturalsBelow(n), NaturalsBelow(n)),
              Permutation.pairImage(tau), Permutation.orderedPairs(n)))
      = length(Permutation.orderedPairs(n))
      by List.map_length(Pair(NaturalsBelow(n), NaturalsBelow(n)), Pair(NaturalsBelow(n), NaturalsBelow(n)),
             Permutation.pairImage(tau), Permutation.orderedPairs(n)) as lengthEq;
  done by List.permutation_of_distinct_inclusion(Pair(NaturalsBelow(n), NaturalsBelow(n)),
      List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Pair(NaturalsBelow(n), NaturalsBelow(n)),
          Permutation.pairImage(tau), Permutation.orderedPairs(n)),
      Permutation.orderedPairs(n), imageDistinct, Permutation.orderedPairs_distinct(n), inclusion, lengthEq)
}

-- Multiplicativity of the sign.
theorem Permutation.sign_compose {n : Natural} (sigma tau : Permutation(n))
        : Permutation.sign(Permutation.compose(sigma, tau))
          = Integer.multiply(Permutation.sign(sigma), Permutation.sign(tau)) := {
  -- Rewrite the composite's orientation map by the pointwise factorization.
  List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer,
          Permutation.pairOrient(Permutation.compose(sigma, tau)), Permutation.orderedPairs(n))
      = List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer,
            (p : Pair(NaturalsBelow(n), NaturalsBelow(n))) ↦
                Integer.multiply(Permutation.pairOrient(tau, p),
                    Permutation.pairOrient(sigma, Permutation.pairImage(tau, p))),
            Permutation.orderedPairs(n))
      by List.map_congruence_on(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer,
             Permutation.pairOrient(Permutation.compose(sigma, tau)),
             (p : Pair(NaturalsBelow(n), NaturalsBelow(n))) ↦
                 Integer.multiply(Permutation.pairOrient(tau, p),
                     Permutation.pairOrient(sigma, Permutation.pairImage(tau, p))),
             Permutation.orderedPairs(n),
             (p : Pair(NaturalsBelow(n), NaturalsBelow(n)))
                 (memberP : List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), p, Permutation.orderedPairs(n))) ↦
                 Permutation.pairFactor(sigma, tau, p, memberP))
      as mapFactored;
  -- The reindexed σ-orientations have equal product (the τ-image permutes).
  List.product(Integer, Integer.multiply, Integer.one,
          List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer, Permutation.pairOrient(sigma),
              List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Pair(NaturalsBelow(n), NaturalsBelow(n)),
                  Permutation.pairImage(tau), Permutation.orderedPairs(n))))
      = List.product(Integer, Integer.multiply, Integer.one,
            List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer, Permutation.pairOrient(sigma),
                Permutation.orderedPairs(n)))
      by List.Permutation.product_invariant(Integer, Integer.multiply, Integer.one,
             (x y z : Integer) ↦ Integer.multiply_associative(x, y, z),
             (x y : Integer) ↦ Integer.multiply_commutative(x, y),
             List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer, Permutation.pairOrient(sigma),
                 List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Pair(NaturalsBelow(n), NaturalsBelow(n)),
                     Permutation.pairImage(tau), Permutation.orderedPairs(n))),
             List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer, Permutation.pairOrient(sigma),
                 Permutation.orderedPairs(n)),
             List.Permutation.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer, Permutation.pairOrient(sigma),
                 List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Pair(NaturalsBelow(n), NaturalsBelow(n)),
                     Permutation.pairImage(tau), Permutation.orderedPairs(n)),
                 Permutation.orderedPairs(n), Permutation.pairImage_permutes(tau)))
      as reindexedProduct;
  Permutation.sign(Permutation.compose(sigma, tau))
     = List.product(Integer, Integer.multiply, Integer.one,
           List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer,
               (p : Pair(NaturalsBelow(n), NaturalsBelow(n))) ↦
                   Integer.multiply(Permutation.pairOrient(tau, p),
                       Permutation.pairOrient(sigma, Permutation.pairImage(tau, p))),
               Permutation.orderedPairs(n)))
           by substituting mapFactored
     = Integer.multiply(
           List.product(Integer, Integer.multiply, Integer.one,
               List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer, Permutation.pairOrient(tau),
                   Permutation.orderedPairs(n))),
           List.product(Integer, Integer.multiply, Integer.one,
               List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer,
                   (p : Pair(NaturalsBelow(n), NaturalsBelow(n))) ↦
                       Permutation.pairOrient(sigma, Permutation.pairImage(tau, p)),
                   Permutation.orderedPairs(n))))
           by List.product_pointwise_multiply(Pair(NaturalsBelow(n), NaturalsBelow(n)),
                  Permutation.pairOrient(tau),
                  (p : Pair(NaturalsBelow(n), NaturalsBelow(n))) ↦
                      Permutation.pairOrient(sigma, Permutation.pairImage(tau, p)),
                  Permutation.orderedPairs(n))
     = Integer.multiply(Permutation.sign(tau),
           List.product(Integer, Integer.multiply, Integer.one,
               List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer, Permutation.pairOrient(sigma),
                   List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Pair(NaturalsBelow(n), NaturalsBelow(n)),
                       Permutation.pairImage(tau), Permutation.orderedPairs(n)))))
           by substituting List.map_map(Pair(NaturalsBelow(n), NaturalsBelow(n)),
                  Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer, Permutation.pairImage(tau),
                  Permutation.pairOrient(sigma), Permutation.orderedPairs(n))
     = Integer.multiply(Permutation.sign(tau), Permutation.sign(sigma))
           by substituting reindexedProduct
     = Integer.multiply(Permutation.sign(sigma), Permutation.sign(tau)) by ring;
  done
}

-- ----------------------------------------------------------------------
-- The sign is a unit: ±1. (A product of ±1 orientations.)

theorem List.product_of_units (l : List(Integer))
        (allUnit : ∀ (x : Integer). List.member(Integer, x, l) → (x = 1 ∨ x = Integer.negate(1)))
        : List.product(Integer, Integer.multiply, Integer.one, l) = 1
          ∨ List.product(Integer, Integer.multiply, Integer.one, l) = Integer.negate(1) :=
  by induction on l with IH {
    case List.empty: {
        List.product(Integer, Integer.multiply, Integer.one, List.empty(Integer)) = 1;
        done
      }
    case List.prepend(head, tail): {
        head = 1 ∨ head = Integer.negate(1)
            by allUnit(head, List.member.here(Integer, head, tail));
        (∀ (x : Integer). List.member(Integer, x, tail) → (x = 1 ∨ x = Integer.negate(1)))
            by (x : Integer) (xInTail : List.member(Integer, x, tail)) ↦
                allUnit(x, List.member.there(Integer, x, head, tail, xInTail)) as tailUnit;
        List.product(Integer, Integer.multiply, Integer.one, tail) = 1
            ∨ List.product(Integer, Integer.multiply, Integer.one, tail) = Integer.negate(1)
            by IH(tailUnit);
        done by cases {
          case head = 1 as headOne: {
              done by cases {
                case List.product(Integer, Integer.multiply, Integer.one, tail) = 1 as tailOne: {
                    List.product(Integer, Integer.multiply, Integer.one, List.prepend(Integer, head, tail))
                       = Integer.multiply(head, List.product(Integer, Integer.multiply, Integer.one, tail))
                       = Integer.multiply(1, List.product(Integer, Integer.multiply, Integer.one, tail))
                             by substituting headOne
                       = Integer.multiply(1, 1) by substituting tailOne
                       = 1 by ring as productValue;
                    done by Or.introduceLeft(productValue)
                  }
                case List.product(Integer, Integer.multiply, Integer.one, tail) = Integer.negate(1) as tailNegOne: {
                    List.product(Integer, Integer.multiply, Integer.one, List.prepend(Integer, head, tail))
                       = Integer.multiply(head, List.product(Integer, Integer.multiply, Integer.one, tail))
                       = Integer.multiply(1, List.product(Integer, Integer.multiply, Integer.one, tail))
                             by substituting headOne
                       = Integer.multiply(1, Integer.negate(1)) by substituting tailNegOne
                       = Integer.negate(1) by ring as productValue;
                    done by Or.introduceRight(productValue)
                  }
              }
            }
          case head = Integer.negate(1) as headNegOne: {
              done by cases {
                case List.product(Integer, Integer.multiply, Integer.one, tail) = 1 as tailOne: {
                    List.product(Integer, Integer.multiply, Integer.one, List.prepend(Integer, head, tail))
                       = Integer.multiply(head, List.product(Integer, Integer.multiply, Integer.one, tail))
                       = Integer.multiply(Integer.negate(1), List.product(Integer, Integer.multiply, Integer.one, tail))
                             by substituting headNegOne
                       = Integer.multiply(Integer.negate(1), 1) by substituting tailOne
                       = Integer.negate(1) by ring as productValue;
                    done by Or.introduceRight(productValue)
                  }
                case List.product(Integer, Integer.multiply, Integer.one, tail) = Integer.negate(1) as tailNegOne: {
                    List.product(Integer, Integer.multiply, Integer.one, List.prepend(Integer, head, tail))
                       = Integer.multiply(head, List.product(Integer, Integer.multiply, Integer.one, tail))
                       = Integer.multiply(Integer.negate(1), List.product(Integer, Integer.multiply, Integer.one, tail))
                             by substituting headNegOne
                       = Integer.multiply(Integer.negate(1), Integer.negate(1)) by substituting tailNegOne
                       = 1 by ring as productValue;
                    done by Or.introduceLeft(productValue)
                  }
              }
            }
        }
      }
  }

theorem Permutation.sign_is_unit {n : Natural} (sigma : Permutation(n))
        : Permutation.sign(sigma) = 1 ∨ Permutation.sign(sigma) = Integer.negate(1) := {
  (∀ (x : Integer). List.member(Integer, x,
      List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer, Permutation.pairOrient(sigma),
          Permutation.orderedPairs(n))) → (x = 1 ∨ x = Integer.negate(1)))
      by (x : Integer) (memberX : List.member(Integer, x,
          List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer, Permutation.pairOrient(sigma),
              Permutation.orderedPairs(n)))) ↦ {
          choose p such that
              List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), p, Permutation.orderedPairs(n))
                  ∧ (Permutation.pairOrient(sigma, p) = x)
              from List.map_member_invert(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer,
                       Permutation.pairOrient(sigma), x, Permutation.orderedPairs(n), memberX);
          Permutation.pairOrient(sigma, p) = x as orientIsX;
          Permutation.pairOrient(sigma, p) = 1 ∨ Permutation.pairOrient(sigma, p) = Integer.negate(1)
              by Permutation.orient_is_unit(Permutation.apply(sigma, Product.first(p)),
                     Permutation.apply(sigma, Product.second(p)));
          x = 1 ∨ x = Integer.negate(1) by substituting orientIsX;
          done
        } as allUnit;
  done by List.product_of_units(
      List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer, Permutation.pairOrient(sigma),
          Permutation.orderedPairs(n)), allUnit)
}

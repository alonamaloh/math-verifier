-- Algebra/unique_factorization.math
--
-- Uniqueness of factorization into primes in any integral domain: two
-- lists of prime elements with the same product are permutations of one
-- another up to associates.
--
-- The statement is over lists of *prime* elements (Euclid's lemma holds
-- for primes in any domain). The PID development converts irreducible
-- factorizations into prime ones, so this is the uniqueness half of
-- "PID ⇒ UFD".
--
-- The proof inducts on the first list, carrying a floating unit `u` in
-- the equation `u · ∏ l1 = ∏ l2` so the leftover unit produced by each
-- cancellation can be absorbed into the next step rather than corrupting
-- the induction hypothesis.

module Algebra.unique_factorization

import Logic.basics
import Logic.exists
import Logic.sum
import Equality.basics
import Lists.list
import Lists.permutation
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Algebra.ring_divisibility
import Algebra.commutative_ring_bundle
import Algebra.integral_domain
import Algebra.irreducible
import Algebra.associate
import Algebra.factorization_list

-- ----------------------------------------------------------------------
-- listProduct is invariant under permutation (the fold is commutative
-- and associative).
theorem IntegralDomain.listProduct_permutation_invariant (d : IntegralDomain)
        (l1 l2 : List(Ring.carrier(IntegralDomain.ring(d))))
        (perm : List.Permutation(Ring.carrier(IntegralDomain.ring(d)), l1, l2))
        : IntegralDomain.listProduct(d, l1) = IntegralDomain.listProduct(d, l2) := {
  let s : Ring := IntegralDomain.ring(d);
  ∀ (x y z : Ring.carrier(s)). (x * y) * z = x * (y * z)
      by Ring.multiply_associative;
  ∀ (x y : Ring.carrier(s)). x * y = y * x
      by IntegralDomain.commutative;
  done by List.Permutation.product_invariant
}

-- ----------------------------------------------------------------------
-- The strengthened, unit-carrying uniqueness statement. Induction on l1.

theorem IntegralDomain.prime_factorization_unique_helper (d : IntegralDomain)
        (l1 : List(Ring.carrier(IntegralDomain.ring(d))))
        : (l2 : List(Ring.carrier(IntegralDomain.ring(d))))
          → (u : Ring.carrier(IntegralDomain.ring(d)))
          → ((k : Ring.carrier(IntegralDomain.ring(d)))
                → List.member(Ring.carrier(IntegralDomain.ring(d)), k, l1)
                → IntegralDomain.IsPrimeElement(d, k))
          → ((k : Ring.carrier(IntegralDomain.ring(d)))
                → List.member(Ring.carrier(IntegralDomain.ring(d)), k, l2)
                → IntegralDomain.IsPrimeElement(d, k))
          → Ring.IsUnit(IntegralDomain.ring(d), u)
          → u * IntegralDomain.listProduct(d, l1)
            = IntegralDomain.listProduct(d, l2)
          → ∃ (m : List(Ring.carrier(IntegralDomain.ring(d)))).
              List.Permutation(Ring.carrier(IntegralDomain.ring(d)), l2, m)
              ∧ IntegralDomain.ListAssociate(d, l1, m) :=
  by induction on l1 with uniqueOfShorter {
    case List.empty:
        (l2 : List(Ring.carrier(IntegralDomain.ring(d))))
        (u : Ring.carrier(IntegralDomain.ring(d)))
        (allPrime1 : (k : Ring.carrier(IntegralDomain.ring(d)))
                     → List.member(Ring.carrier(IntegralDomain.ring(d)), k,
                           List.empty(Ring.carrier(IntegralDomain.ring(d))))
                     → IntegralDomain.IsPrimeElement(d, k))
        (allPrime2 : (k : Ring.carrier(IntegralDomain.ring(d)))
                     → List.member(Ring.carrier(IntegralDomain.ring(d)), k, l2)
                     → IntegralDomain.IsPrimeElement(d, k))
        (uUnit : Ring.IsUnit(IntegralDomain.ring(d), u))
        (equation : u * IntegralDomain.listProduct(d,
                        List.empty(Ring.carrier(IntegralDomain.ring(d))))
                    = IntegralDomain.listProduct(d, l2)) ↦ {
          let s : Ring := IntegralDomain.ring(d);
          -- ∏ l2 = u, hence a unit; so l2 is empty.
          IntegralDomain.listProduct(d, l2) = u;
          Ring.IsUnit(s, IntegralDomain.listProduct(d, l2));
          l2 = List.empty(Ring.carrier(s)) as l2Empty;
          List.Permutation(Ring.carrier(s), List.empty(Ring.carrier(s)),
              List.empty(Ring.carrier(s)));
          List.Permutation(Ring.carrier(s), l2, List.empty(Ring.carrier(s)))
              by substituting l2Empty;
          IntegralDomain.ListAssociate(d, List.empty(Ring.carrier(s)),
              List.empty(Ring.carrier(s)));
          List.Permutation(Ring.carrier(s), l2, List.empty(Ring.carrier(s)))
              ∧ IntegralDomain.ListAssociate(d, List.empty(Ring.carrier(s)),
                    List.empty(Ring.carrier(s))) as emptyWitness;
          witness List.empty(Ring.carrier(s)) with emptyWitness
        }
    case List.prepend(p1, rest1):
        (l2 : List(Ring.carrier(IntegralDomain.ring(d))))
        (u : Ring.carrier(IntegralDomain.ring(d)))
        (allPrime1 : (k : Ring.carrier(IntegralDomain.ring(d)))
                     → List.member(Ring.carrier(IntegralDomain.ring(d)), k,
                           List.prepend(Ring.carrier(IntegralDomain.ring(d)),
                               p1, rest1))
                     → IntegralDomain.IsPrimeElement(d, k))
        (allPrime2 : (k : Ring.carrier(IntegralDomain.ring(d)))
                     → List.member(Ring.carrier(IntegralDomain.ring(d)), k, l2)
                     → IntegralDomain.IsPrimeElement(d, k))
        (uUnit : Ring.IsUnit(IntegralDomain.ring(d), u))
        (equation : u * IntegralDomain.listProduct(d,
                        List.prepend(Ring.carrier(IntegralDomain.ring(d)),
                            p1, rest1))
                    = IntegralDomain.listProduct(d, l2)) ↦ {
          let s : Ring := IntegralDomain.ring(d);
          let restProduct : Ring.carrier(s) := IntegralDomain.listProduct(d, rest1);
          IntegralDomain.IsPrimeElement(d, p1)
              by allPrime1(p1, List.member.here(Ring.carrier(s), p1, rest1));
          -- p1 is nonzero (it is prime) — cancelled below.
          p1 ≠ Ring.zero(s);

          -- p1 divides ∏ l2, because ∏ l2 = p1 · (u · ∏ rest1).
          p1 ∣ IntegralDomain.listProduct(d, l2)
              by witness u * restProduct with
                  IntegralDomain.listProduct(d, l2)
                     = u * (p1 * restProduct)
                     = p1 * (u * restProduct);

          -- some prime factor q of l2 has p1 ∣ q, and being irreducible q = p1·c.
          ∃ (q : Ring.carrier(s)).
              List.member(Ring.carrier(s), q, l2) ∧ p1 ∣ q
              by IntegralDomain.prime_divides_listProduct_member;
          choose q such that List.member(Ring.carrier(s), q, l2) ∧ p1 ∣ q;
          List.member(Ring.carrier(s), q, l2) as qMemberL2;
          IntegralDomain.IsPrimeElement(d, q) by allPrime2(q, qMemberL2);
          IntegralDomain.IsIrreducible(d, q)
              by IntegralDomain.prime_element_is_irreducible;
          IntegralDomain.Associate(d, p1, q)
              by IntegralDomain.associate_of_divides_irreducible;
          choose c such that Ring.IsUnit(s, c) ∧ q = p1 * c;
          q = p1 * c;

          -- rotate q to the front of l2.
          ∃ (l2rest : List(Ring.carrier(s))).
              List.Permutation(Ring.carrier(s), l2, List.prepend(Ring.carrier(s), q, l2rest))
              by List.Permutation.extract;
          choose l2rest such that
              List.Permutation(Ring.carrier(s), l2, List.prepend(Ring.carrier(s), q, l2rest));
          let restProduct2 : Ring.carrier(s) := IntegralDomain.listProduct(d, l2rest);
          IntegralDomain.listProduct(d, l2)
             = IntegralDomain.listProduct(d, List.prepend(Ring.carrier(s), q, l2rest))
             = q * restProduct2
             = (p1 * c) * restProduct2
             = p1 * (c * restProduct2);

          -- cancel p1: u · ∏ rest1 = c · ∏ l2rest.
          p1 * (u * restProduct)
             = u * (p1 * restProduct)
             = IntegralDomain.listProduct(d, l2)
             = p1 * (c * restProduct2);
          u * restProduct = c * restProduct2 by IntegralDomain.multiply_cancel_left;

          -- the next floating unit is u' = c⁻¹ · u.
          ∃ (cInverse : Ring.carrier(s)).
              Ring.IsUnit(s, cInverse) ∧ c * cInverse = Ring.one(s)
              by IntegralDomain.unit_inverse_is_unit;
          choose cInverse such that Ring.IsUnit(s, cInverse) ∧ c * cInverse = Ring.one(s);
          Ring.IsUnit(s, cInverse * u) by IntegralDomain.unit_product as uPrimeUnit;
          cInverse * c = c * cInverse = Ring.one(s);
          (cInverse * u) * restProduct
             = cInverse * (u * restProduct)
             = cInverse * (c * restProduct2)
             = (cInverse * c) * restProduct2
             = Ring.one(s) * restProduct2
             = restProduct2 as uPrimeEquation;

          -- recurse on rest1 against l2rest with the new unit.
          ∀ (k : Ring.carrier(s)). List.member(Ring.carrier(s), k, rest1)
                → IntegralDomain.IsPrimeElement(d, k)
              by (k : Ring.carrier(s))
                 (memberRest1 : List.member(Ring.carrier(s), k, rest1)) ↦
                   allPrime1(k, List.member.there(Ring.carrier(s), k, p1, rest1, memberRest1))
              as allPrimeRest1;
          ∀ (k : Ring.carrier(s)). List.member(Ring.carrier(s), k, l2rest)
                → IntegralDomain.IsPrimeElement(d, k) by {
            take k : Ring.carrier(s);
            suppose List.member(Ring.carrier(s), k, l2rest) as memberL2rest;
            List.member(Ring.carrier(s), k,
                List.prepend(Ring.carrier(s), q, l2rest)) by List.member.there;
            List.Permutation(Ring.carrier(s),
                List.prepend(Ring.carrier(s), q, l2rest), l2) by List.Permutation.symmetric;
            List.member(Ring.carrier(s), k, l2)
                by List.Permutation.member_forward as memberKL2;
            done by allPrime2(k, memberKL2)
          } as allPrimeL2rest;
          ∃ (mPrime : List(Ring.carrier(s))).
              List.Permutation(Ring.carrier(s), l2rest, mPrime)
              ∧ IntegralDomain.ListAssociate(d, rest1, mPrime)
              by uniqueOfShorter(l2rest, cInverse * u, allPrimeRest1, allPrimeL2rest,
                     uPrimeUnit, uPrimeEquation);
          choose mPrime such that
              List.Permutation(Ring.carrier(s), l2rest, mPrime)
              ∧ IntegralDomain.ListAssociate(d, rest1, mPrime);

          -- assemble m = q :: mPrime.
          List.Permutation(Ring.carrier(s),
              List.prepend(Ring.carrier(s), q, l2rest),
              List.prepend(Ring.carrier(s), q, mPrime));
          List.Permutation(Ring.carrier(s), l2,
              List.prepend(Ring.carrier(s), q, mPrime)) by List.Permutation.transitive;
          IntegralDomain.ListAssociate(d,
              List.prepend(Ring.carrier(s), p1, rest1),
              List.prepend(Ring.carrier(s), q, mPrime)) by IntegralDomain.ListAssociate.cons;
          List.Permutation(Ring.carrier(s), l2,
                  List.prepend(Ring.carrier(s), q, mPrime))
                ∧ IntegralDomain.ListAssociate(d,
                      List.prepend(Ring.carrier(s), p1, rest1),
                      List.prepend(Ring.carrier(s), q, mPrime)) as resultWitness;
          witness List.prepend(Ring.carrier(s), q, mPrime) with resultWitness
        }
  }

-- ----------------------------------------------------------------------
-- Uniqueness proper: equal products of prime lists are associate-
-- permutations. (The floating unit is 1.)
theorem IntegralDomain.prime_factorization_unique (d : IntegralDomain)
        (l1 l2 : List(Ring.carrier(IntegralDomain.ring(d))))
        (allPrime1 : (k : Ring.carrier(IntegralDomain.ring(d)))
                     → List.member(Ring.carrier(IntegralDomain.ring(d)), k, l1)
                     → IntegralDomain.IsPrimeElement(d, k))
        (allPrime2 : (k : Ring.carrier(IntegralDomain.ring(d)))
                     → List.member(Ring.carrier(IntegralDomain.ring(d)), k, l2)
                     → IntegralDomain.IsPrimeElement(d, k))
        (productEqual : IntegralDomain.listProduct(d, l1)
                      = IntegralDomain.listProduct(d, l2))
        : ∃ (m : List(Ring.carrier(IntegralDomain.ring(d)))).
            List.Permutation(Ring.carrier(IntegralDomain.ring(d)), l2, m)
            ∧ IntegralDomain.ListAssociate(d, l1, m) := {
  let s : Ring := IntegralDomain.ring(d);
  -- run the unit-carrying helper with the floating unit set to 1.
  Ring.IsUnit(s, Ring.one(s)) by Ring.one_is_unit;
  Ring.one(s) * IntegralDomain.listProduct(d, l1)
     = IntegralDomain.listProduct(d, l1)
     = IntegralDomain.listProduct(d, l2);
  done
}

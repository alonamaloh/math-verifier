-- Algebra/unique_factorization.math
--
-- Uniqueness of factorization into primes in any integral domain: two
-- lists of prime elements with the same product are permutations of one
-- another up to associates.
--
-- The statement is over lists of *prime* elements (Euclid's lemma holds
-- for primes in any domain). The PID development converts irreducible
-- factorizations into prime ones, so this is the uniqueness half of
-- "PID ⇒ UFD".
--
-- The proof inducts on the first list, carrying a floating unit `u` in
-- the equation `u · ∏ l1 = ∏ l2` so the leftover unit produced by each
-- cancellation can be absorbed into the next step rather than corrupting
-- the induction hypothesis.

module Algebra.unique_factorization

import Logic.basics
import Logic.exists
import Logic.sum
import Equality.basics
import Lists.list
import Lists.permutation
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Algebra.ring_divisibility
import Algebra.commutative_ring_bundle
import Algebra.integral_domain
import Algebra.irreducible
import Algebra.associate
import Algebra.factorization_list

-- ----------------------------------------------------------------------
-- listProduct is invariant under permutation (the fold is commutative
-- and associative).
theorem IntegralDomain.listProduct_permutation_invariant (d : IntegralDomain)
        (l1 l2 : List(Ring.carrier(IntegralDomain.ring(d))))
        (perm : List.Permutation(Ring.carrier(IntegralDomain.ring(d)), l1, l2))
        : IntegralDomain.listProduct(d, l1) = IntegralDomain.listProduct(d, l2) :=
  List.Permutation.product_invariant(
      Ring.carrier(IntegralDomain.ring(d)),
      (x y : Ring.carrier(IntegralDomain.ring(d))) ↦ x * y,
      Ring.one(IntegralDomain.ring(d)),
      Ring.multiply_associative(IntegralDomain.ring(d)),
      IntegralDomain.commutative(d),
      l1, l2, perm)

-- ----------------------------------------------------------------------
-- The strengthened, unit-carrying uniqueness statement. Induction on l1.

theorem IntegralDomain.prime_factorization_unique_helper (d : IntegralDomain)
        : (l1 : List(Ring.carrier(IntegralDomain.ring(d))))
          → (l2 : List(Ring.carrier(IntegralDomain.ring(d))))
          → (u : Ring.carrier(IntegralDomain.ring(d)))
          → ((k : Ring.carrier(IntegralDomain.ring(d)))
                → List.member(Ring.carrier(IntegralDomain.ring(d)), k, l1)
                → IntegralDomain.IsPrimeElement(d, k))
          → ((k : Ring.carrier(IntegralDomain.ring(d)))
                → List.member(Ring.carrier(IntegralDomain.ring(d)), k, l2)
                → IntegralDomain.IsPrimeElement(d, k))
          → Ring.IsUnit(IntegralDomain.ring(d), u)
          → u * IntegralDomain.listProduct(d, l1)
            = IntegralDomain.listProduct(d, l2)
          → ∃ (m : List(Ring.carrier(IntegralDomain.ring(d)))).
              List.Permutation(Ring.carrier(IntegralDomain.ring(d)), l2, m)
              ∧ IntegralDomain.ListAssociate(d, l1, m)
  | List.empty =>
      (l2 : List(Ring.carrier(IntegralDomain.ring(d))))
      (u : Ring.carrier(IntegralDomain.ring(d)))
      (allPrime1 : (k : Ring.carrier(IntegralDomain.ring(d)))
                   → List.member(Ring.carrier(IntegralDomain.ring(d)), k,
                         List.empty(Ring.carrier(IntegralDomain.ring(d))))
                   → IntegralDomain.IsPrimeElement(d, k))
      (allPrime2 : (k : Ring.carrier(IntegralDomain.ring(d)))
                   → List.member(Ring.carrier(IntegralDomain.ring(d)), k, l2)
                   → IntegralDomain.IsPrimeElement(d, k))
      (uUnit : Ring.IsUnit(IntegralDomain.ring(d), u))
      (equation : u * IntegralDomain.listProduct(d,
                      List.empty(Ring.carrier(IntegralDomain.ring(d))))
                  = IntegralDomain.listProduct(d, l2)) ↦ {
        let s : Ring := IntegralDomain.ring(d);
        -- listProduct(l2) = u, hence a unit; so l2 is empty.
        claim IntegralDomain.listProduct(d, l2) = u;
        claim Ring.IsUnit(s, IntegralDomain.listProduct(d, l2));
        claim l2Empty : l2 = List.empty(Ring.carrier(s));
        ⟨List.empty(Ring.carrier(s)),
         Equality.transport_proposition(
             (t : List(Ring.carrier(s))) ↦
                 List.Permutation(Ring.carrier(s), t,
                     List.empty(Ring.carrier(s))),
             List.empty(Ring.carrier(s)), l2,
             Equality.symmetry(l2Empty),
             List.Permutation.empty(Ring.carrier(s))),
         IntegralDomain.ListAssociate.empty(d)⟩
      }
  | List.prepend(p1, rest1) =>
      (l2 : List(Ring.carrier(IntegralDomain.ring(d))))
      (u : Ring.carrier(IntegralDomain.ring(d)))
      (allPrime1 : (k : Ring.carrier(IntegralDomain.ring(d)))
                   → List.member(Ring.carrier(IntegralDomain.ring(d)), k,
                         List.prepend(Ring.carrier(IntegralDomain.ring(d)),
                             p1, rest1))
                   → IntegralDomain.IsPrimeElement(d, k))
      (allPrime2 : (k : Ring.carrier(IntegralDomain.ring(d)))
                   → List.member(Ring.carrier(IntegralDomain.ring(d)), k, l2)
                   → IntegralDomain.IsPrimeElement(d, k))
      (uUnit : Ring.IsUnit(IntegralDomain.ring(d), u))
      (equation : u * IntegralDomain.listProduct(d,
                      List.prepend(Ring.carrier(IntegralDomain.ring(d)),
                          p1, rest1))
                  = IntegralDomain.listProduct(d, l2)) ↦ {
        let s : Ring := IntegralDomain.ring(d);
        let restProduct : Ring.carrier(s) := IntegralDomain.listProduct(d, rest1);
        claim p1Prime : IntegralDomain.IsPrimeElement(d, p1)
            by allPrime1(p1,
                   List.member.here(Ring.carrier(s), p1, rest1));
        let ⟨p1NotZero, p1NotUnit, _⟩ := p1Prime;

        -- p1 divides ∏ l2, because ∏ l2 = p1 · (u · ∏ rest1).
        claim p1DividesL2 : Ring.divides(s, p1, IntegralDomain.listProduct(d, l2))
            by ⟨u * restProduct,
                calc IntegralDomain.listProduct(d, l2)
                   = u * (p1 * restProduct)
                   = p1 * (u * restProduct)⟩;

        -- A prime factor q of l2 with p1 ∣ q, hence q's associate is p1.
        obtain ⟨q, qMember, p1DividesQ⟩
            from IntegralDomain.prime_divides_listProduct_member(d, p1, p1Prime,
                     l2, p1DividesL2);
        claim IntegralDomain.IsPrimeElement(d, q)
            by allPrime2(q, qMember);
        claim qIrreducible : IntegralDomain.IsIrreducible(d, q);
        obtain ⟨c, cUnit, qEqualsP1c⟩
            from IntegralDomain.associate_of_divides_irreducible(d, p1, q,
                     qIrreducible, p1NotUnit, p1DividesQ);
        -- qEqualsP1c : q = p1 · c, c a unit.

        -- Rotate q to the front of l2.
        obtain ⟨l2rest, permL2⟩
            from List.Permutation.extract(Ring.carrier(s), q, l2, qMember);
        let restProduct2 : Ring.carrier(s) := IntegralDomain.listProduct(d, l2rest);
        -- ∏ l2 = q · ∏ l2rest = p1 · (c · ∏ l2rest).
        calc IntegralDomain.listProduct(d, l2)
                  = IntegralDomain.listProduct(d,
                        List.prepend(Ring.carrier(s), q, l2rest))
                  = q * restProduct2
                  = (p1 * c) * restProduct2
                  = p1 * (c * restProduct2);

        -- Cancel p1: u · ∏ rest1 = c · ∏ l2rest.
        claim u * restProduct = c * restProduct2
            by IntegralDomain.multiply_cancel_left(d, p1,
                   u * restProduct,
                   c * restProduct2,
                   p1NotZero,
                   calc p1 * (u * restProduct)
                      = u * (p1 * restProduct)
                      = IntegralDomain.listProduct(d, l2)
                      = p1 * (c * restProduct2));

        -- Form the next floating unit u' = c⁻¹ · u.
        obtain ⟨cInverse, cInverseUnit, cTimesInverse⟩
            from IntegralDomain.unit_inverse_is_unit(d, c, cUnit);
        -- cTimesInverse : c · cInverse = 1.
        claim uPrimeUnit : Ring.IsUnit(s, cInverse * u);
        calc cInverse * c
                  = c * cInverse
                  = Ring.one(s);
        calc (cInverse * u) * restProduct
                  = cInverse * (u * restProduct)
                  = cInverse * (c * restProduct2)
                  = (cInverse * c) * restProduct2
                  = Ring.one(s) * restProduct2
                  = restProduct2 as uPrimeEquation;

        -- Recurse on rest1 against l2rest with the new unit.
        claim allPrimeRest1
            : ∀ (k : Ring.carrier(s)).
              List.member(Ring.carrier(s), k, rest1)
              → IntegralDomain.IsPrimeElement(d, k)
            by (k : Ring.carrier(s))
               (memberRest1 : List.member(Ring.carrier(s), k, rest1)) ↦
                 allPrime1(k,
                     List.member.there(Ring.carrier(s), k, p1, rest1,
                         memberRest1));
        claim allPrimeL2rest
            : ∀ (k : Ring.carrier(s)).
              List.member(Ring.carrier(s), k, l2rest)
              → IntegralDomain.IsPrimeElement(d, k)
            by (k : Ring.carrier(s))
               (memberL2rest : List.member(Ring.carrier(s), k, l2rest)) ↦
                 allPrime2(k,
                     List.Permutation.member_forward(Ring.carrier(s), k,
                         List.prepend(Ring.carrier(s), q, l2rest), l2,
                         List.Permutation.symmetric(Ring.carrier(s), l2,
                             List.prepend(Ring.carrier(s), q, l2rest), permL2),
                         List.member.there(Ring.carrier(s), k, q, l2rest,
                             memberL2rest)));
        obtain ⟨mPrime, permL2rest, listAssocRest⟩
            from IntegralDomain.prime_factorization_unique_helper(d, rest1, l2rest,
                     cInverse * u, allPrimeRest1, allPrimeL2rest,
                     uPrimeUnit, uPrimeEquation);

        -- Assemble m = prepend(q, mPrime).
        ⟨List.prepend(Ring.carrier(s), q, mPrime),
         List.Permutation.transitive(Ring.carrier(s),
             l2,
             List.prepend(Ring.carrier(s), q, l2rest),
             List.prepend(Ring.carrier(s), q, mPrime),
             permL2,
             List.Permutation.skip(Ring.carrier(s), q, l2rest, mPrime,
                 permL2rest)),
         IntegralDomain.ListAssociate.cons(d, p1, q,
             ⟨c, cUnit, qEqualsP1c⟩, rest1, mPrime, listAssocRest)⟩
      }

-- ----------------------------------------------------------------------
-- Uniqueness proper: equal products of prime lists are associate-
-- permutations. (The floating unit is 1.)
theorem IntegralDomain.prime_factorization_unique (d : IntegralDomain)
        (l1 l2 : List(Ring.carrier(IntegralDomain.ring(d))))
        (allPrime1 : (k : Ring.carrier(IntegralDomain.ring(d)))
                     → List.member(Ring.carrier(IntegralDomain.ring(d)), k, l1)
                     → IntegralDomain.IsPrimeElement(d, k))
        (allPrime2 : (k : Ring.carrier(IntegralDomain.ring(d)))
                     → List.member(Ring.carrier(IntegralDomain.ring(d)), k, l2)
                     → IntegralDomain.IsPrimeElement(d, k))
        (productEqual : IntegralDomain.listProduct(d, l1)
                      = IntegralDomain.listProduct(d, l2))
        : ∃ (m : List(Ring.carrier(IntegralDomain.ring(d)))).
            List.Permutation(Ring.carrier(IntegralDomain.ring(d)), l2, m)
            ∧ IntegralDomain.ListAssociate(d, l1, m) :=
  IntegralDomain.prime_factorization_unique_helper(d, l1, l2,
      Ring.one(IntegralDomain.ring(d)), allPrime1, allPrime2,
      Ring.one_is_unit(IntegralDomain.ring(d)),
      calc Ring.one(IntegralDomain.ring(d)) * IntegralDomain.listProduct(d, l1)
         = IntegralDomain.listProduct(d, l1)
         = IntegralDomain.listProduct(d, l2))

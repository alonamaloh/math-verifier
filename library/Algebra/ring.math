-- Algebra/ring.math
--
-- A ring is an abelian group under addition + a monoid under
-- multiplication + distributivity laws connecting the two
-- operations. A commutative ring additionally has commutative
-- multiplication.
--
-- These predicates take the additive and multiplicative structures
-- as separate parameters (`add`, `zero`, `negate`, `multiply`,
-- `one`) so that specific instances bind them to concrete
-- functions (`Integer.add`, `Integer.zero`, `Integer.negate`, …).

module Algebra.ring

import Logic.basics
import Equality.basics
import Algebra.monoid
import Algebra.group

definition IsRing
        (carrier : Type(0))
        (add : carrier → carrier → carrier)
        (zero : carrier)
        (negate : carrier → carrier)
        (multiply : carrier → carrier → carrier)
        (one : carrier)
        : Proposition :=
    IsAbelianGroup(carrier, add, zero, negate)
    ∧ IsMonoid(carrier, multiply, one)
    ∧ (∀ (x y z : carrier). 
           multiply(x, add(y, z)) = add(multiply(x, y), multiply(x, z)))
    ∧ (∀ (x y z : carrier). 
           multiply(add(x, y), z) = add(multiply(x, z), multiply(y, z)))

definition IsCommutativeRing
        (carrier : Type(0))
        (add : carrier → carrier → carrier)
        (zero : carrier)
        (negate : carrier → carrier)
        (multiply : carrier → carrier → carrier)
        (one : carrier)
        : Proposition :=
    IsRing(carrier, add, zero, negate, multiply, one)
    ∧ (∀ (x y : carrier).
           multiply(x, y) = multiply(y, x))

-- ----------------------------------------------------------------------
-- Accessors for the ring axioms.
--
-- `IsRing` bundles four facts (the additive abelian group, the
-- multiplicative monoid, and the two distributivity laws) as a nested
-- conjunction. Each accessor re-exposes one axiom (or the additive group) as
-- a named theorem; with `ringProof` a pervasive convention, the auto-prover
-- projects the conjunct it needs from context, so the proof is a bare `done`
-- and a ring lemma cites the axiom by name (`since IsRing.distributivity_right`)
-- rather than walking the nest by hand. The bundle below is the standing ring
-- signature.
convention carrier : Type(0)
convention (+) : carrier → carrier → carrier
convention zero : carrier
convention (-) : carrier → carrier
convention (·) : carrier → carrier → carrier
convention one : carrier
convention ringProof : IsRing(carrier, (+), zero, (-), (·), one)

-- The ring's additive group `(carrier, +, zero, -)`, viewed as a group —
-- what the generic `Group.*` lemmas take as their `groupProof`.
theorem IsRing.additive_group : IsGroup(carrier, (+), zero, (-)) :=
  done

-- Register the additive group as a forgetful (derived) instance: wherever a
-- `Group.*` lemma needs `IsGroup(carrier, +, zero, -)` and a `ringProof` is in
-- scope, the elaborator supplies it automatically via this projection — no
-- explicit `claim IsGroup(…) since IsRing.additive_group` at the use site.
instance IsRing.additive_group

theorem IsRing.add_identity_left (x : carrier) : zero + x = x :=
  done

theorem IsRing.add_identity_right (x : carrier) : x + zero = x :=
  done

theorem IsRing.add_inverse_left (x : carrier) : (-x) + x = zero :=
  done

automatic theorem IsRing.add_inverse_right (x : carrier) : x + (-x) = zero :=
  done

automatic theorem IsRing.distributivity_left (x y z : carrier)
        : x · (y + z) = x · y + x · z :=
  done

automatic theorem IsRing.distributivity_right (x y z : carrier)
        : (x + y) · z = x · z + y · z :=
  done

-- Algebra/ring.math
--
-- A ring is an abelian group under addition + a monoid under
-- multiplication + distributivity laws connecting the two
-- operations. A commutative ring additionally has commutative
-- multiplication.
--
-- These predicates take the additive and multiplicative structures
-- as separate parameters (`add`, `zero`, `negate`, `multiply`,
-- `one`) so that specific instances bind them to concrete
-- functions (`Integer.add`, `Integer.zero`, `Integer.negate`, …).

module Algebra.ring

import Logic.basics
import Equality.basics
import Algebra.monoid
import Algebra.group

definition IsRing
        (carrier : Type(0))
        (add : carrier → carrier → carrier)
        (zero : carrier)
        (negate : carrier → carrier)
        (multiply : carrier → carrier → carrier)
        (one : carrier)
        : Proposition :=
    IsAbelianGroup(carrier, add, zero, negate)
    ∧ IsMonoid(carrier, multiply, one)
    ∧ (∀ (x y z : carrier). 
           multiply(x, add(y, z)) = add(multiply(x, y), multiply(x, z)))
    ∧ (∀ (x y z : carrier). 
           multiply(add(x, y), z) = add(multiply(x, z), multiply(y, z)))

definition IsCommutativeRing
        (carrier : Type(0))
        (add : carrier → carrier → carrier)
        (zero : carrier)
        (negate : carrier → carrier)
        (multiply : carrier → carrier → carrier)
        (one : carrier)
        : Proposition :=
    IsRing(carrier, add, zero, negate, multiply, one)
    ∧ (∀ (x y : carrier).
           multiply(x, y) = multiply(y, x))

-- ----------------------------------------------------------------------
-- Accessors for the ring axioms.
--
-- `IsRing` bundles four facts (the additive abelian group, the
-- multiplicative monoid, and the two distributivity laws) as a nested
-- conjunction. Reaching one axiom from a ring proof means destructuring
-- that nest — `let ⟨⟨⟨_, idLeft, _⟩, …⟩, …⟩ := ringProof` — noise that
-- every ring lemma would otherwise repeat. These accessors do the
-- destructuring ONCE; a ring lemma cites the axiom by name
-- (`by IsRing.distributivity_right(…)`), with the implicit `ringProof`
-- recovered from context. The bundle below is the standing ring signature.
--
-- Only the distributivity and identity axioms get accessors: their
-- conclusions have a structured or variable right-hand side, so a citation
-- unifies cleanly against a goal. The inverse axioms (`add(negate(x), x) =
-- zero`) have the bare constant `zero` on the right, which a citation in a
-- congruence/reversed calc step mis-binds — those are still read off a
-- destructured additive group at the use site.
convention carrier : Type(0)
convention (+) : carrier → carrier → carrier
convention zero : carrier
convention (-) : carrier → carrier
convention (·) : carrier → carrier → carrier
convention one : carrier
convention ringProof : IsRing(carrier, (+), zero, (-), (·), one)

-- The ring's additive group `(carrier, +, zero, -)`, viewed as a group —
-- what the generic `Group.*` lemmas take as their `groupProof`.
theorem IsRing.additive_group : IsGroup(carrier, (+), zero, (-)) := {
    let ⟨additiveAbelianGroup, _, _, _⟩ := ringProof;
    let ⟨additiveGroup, _⟩ := additiveAbelianGroup;
    done by additiveGroup
}

theorem IsRing.add_identity_left (x : carrier) : zero + x = x := {
    let ⟨additiveAbelianGroup, _, _, _⟩ := ringProof;
    let ⟨additiveGroup, _⟩ := additiveAbelianGroup;
    let ⟨additiveMonoid, _, _⟩ := additiveGroup;
    let ⟨_, identityLeft, _⟩ := additiveMonoid;
    done by identityLeft(x)
}

theorem IsRing.add_identity_right (x : carrier) : x + zero = x := {
    let ⟨additiveAbelianGroup, _, _, _⟩ := ringProof;
    let ⟨additiveGroup, _⟩ := additiveAbelianGroup;
    let ⟨additiveMonoid, _, _⟩ := additiveGroup;
    let ⟨_, _, identityRight⟩ := additiveMonoid;
    done by identityRight(x)
}

theorem IsRing.add_inverse_left (x : carrier) : (-x) + x = zero := {
    let ⟨additiveAbelianGroup, _, _, _⟩ := ringProof;
    let ⟨additiveGroup, _⟩ := additiveAbelianGroup;
    let ⟨_, inverseLeft, _⟩ := additiveGroup;
    done by inverseLeft(x)
}

theorem IsRing.add_inverse_right (x : carrier) : x + (-x) = zero := {
    let ⟨additiveAbelianGroup, _, _, _⟩ := ringProof;
    let ⟨additiveGroup, _⟩ := additiveAbelianGroup;
    let ⟨_, _, inverseRight⟩ := additiveGroup;
    done by inverseRight(x)
}

theorem IsRing.distributivity_left (x y z : carrier)
        : x · (y + z) = x · y + x · z := {
    let ⟨_, _, distributivityLeft, _⟩ := ringProof;
    done by distributivityLeft(x, y, z)
}

theorem IsRing.distributivity_right (x y z : carrier)
        : (x + y) · z = x · z + y · z := {
    let ⟨_, _, _, distributivityRight⟩ := ringProof;
    done by distributivityRight(x, y, z)
}

  (41 : ℤ) * 41 + 2 * (1 * 1) + 2 * 1 * (-1 : ℤ) + 4 * ((-1 : ℤ) * (-1 : ℤ)) + 2 * 3 * 1 * (-3 : ℤ) + 10 * ((-3 : ℤ) * (-3 : ℤ)) = (1757 : ℤ) as scalarComputation;
  Matrix.represents_by_witness(A, target := 1757, vector := ⟨41, 1, -1, -3⟩,
    computes := Matrix.detSevenRankFour_coordinateTuple_computes(scalarComputation := scalarComputation));
  done by finite_check q from 0 until 3
}

theorem Matrix.detSevenFiniteQ3C10A581T3
        (n : ℕ) (positive : n ≥ 1)
        (bounded : n ≤ 2142)
        (remainderReads : Natural.modulo(n, 588) = 581)
        : Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 10),
            (n : ℤ)) := {
  let q : ℕ := Natural.floor_divide(n, 588);
  588 * q + Natural.modulo(n, 588) = n
      by Natural.floor_divide_modulo_decompose;
  588 * q + 581 = n by substituting remainderReads as exactDecomposition;
  q < 3 by Natural.quotient_below_of_bounded_decomposition(
    588, q, 581, n, 2142, 3, done, exactDecomposition, bounded)
  as qBelow;
  Matrix.Represents(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 10),
      (588 : ℤ) * (q : ℤ) + (581 : ℤ)) by {
  done by Matrix.detSevenFiniteQ3C10A581T3_part0(q, done, qBelow)
  };
  (588 : ℤ) * (q : ℤ) + (581 : ℤ)
     = ((588 * q : ℕ) : ℤ) + (581 : ℤ)
         by substituting Equality.symmetry(Natural.to_integer.multiply_preserves(588, q))
     = ((588 * q + 581 : ℕ) : ℤ)
         by Equality.symmetry(Natural.to_integer.add_preserves(588 * q, 581))
     = (n : ℤ) by substituting exactDecomposition
  as integerDecomposition;
  done by substituting integerDecomposition
}

theorem Matrix.rankFourWeightedDiagonalD4_border_m1_m3_p1
        : Matrix.IsRankFourWeightedDiagonalD4NormalForm(Matrix.squarePlusDoublePlusScaledRankFourCandidate(4, 14, (-1), (-3), 1)) := {
  ((-1) : ℤ) + (1 : ℤ) = 0 by ring as firstVanishes;
  ((-3) : ℤ) + 2 * (2 : ℤ) = (1 : ℤ) by ring as secondReduces;
  (1 : ℤ) + 4 * (0 : ℤ) = (1 : ℤ) by ring as thirdReduces;
  (14 : ℤ) + 2 * (((-1) : ℤ) * (1 : ℤ) + ((-3) : ℤ) * (2 : ℤ) + (1 : ℤ) * (0 : ℤ))
      + (1 : ℤ) * (1 : ℤ) + 2 * ((2 : ℤ) * (2 : ℤ)) + 4 * ((0 : ℤ) * (0 : ℤ)) = 9 by ring as cornerReduces;
  Matrix.IsIsometric(
      Matrix.squarePlusDoublePlusScaledRankFourCandidate(4, 14, (-1), (-3), 1),
      Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 1, 1, 9))
      by Matrix.squarePlusDoublePlusScaledRankFourCandidate_isometric_reduced(
        x := 1, y := 2, z := 0, secondResidue := 1, thirdResidue := 1, corner := 9,
        firstVanishes := firstVanishes, secondReduces := secondReduces,
        thirdReduces := thirdReduces, cornerReduces := cornerReduces)
  as reduced;
  done by disjunct(reduced)
}


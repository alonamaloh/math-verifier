-- Algebra/three_squares_residual_covers.math
--
-- Residual-cover reductions for the seven diagonal coefficients in the
-- selected rank-four pilot family.

module Algebra.three_squares_residual_covers

import Algebra.three_squares_residual_cover_one
import Algebra.three_squares_residual_cover_two
import Algebra.three_squares_residual_cover_three
import Algebra.three_squares_residual_cover_four
import Algebra.three_squares_residual_cover_five
import Algebra.three_squares_residual_cover_six
import Algebra.three_squares_residual_cover_seven

theorem Matrix.selectedRankFourPilot_universal_of_three_squares_converse
        (R : Matrix(Integer.commutative_ring_bundle, 4, 4))
        (selected : Matrix.IsSelectedRankFourPilotNormalForm(R))
        (converse : Matrix.ThreeSquaresConverse)
        : Matrix.IsUniversal(R) := {
  done by Matrix.selectedRankFourPilot_universal(
      R, selected,
      Matrix.threeSquareResidualCover_one_of_converse(converse),
      Matrix.threeSquareResidualCover_two_of_converse(converse),
      Matrix.threeSquareResidualCover_three_of_converse(converse),
      Matrix.threeSquareResidualCover_four_of_converse(converse),
      Matrix.threeSquareResidualCover_five_of_converse(converse),
      Matrix.threeSquareResidualCover_six_of_converse(converse),
      Matrix.threeSquareResidualCover_seven_of_converse(converse))
}

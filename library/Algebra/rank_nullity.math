-- Algebra/rank_nullity.math
--
-- The rank–nullity theorem: for a linear map `T : V → W` with `V`
-- finite-dimensional, `dim(V) = dim(ker T) + dim(im T)`. The route is basis
-- extension — no quotient space: extend a basis of the kernel to a basis of
-- `V`, and the `T`-images of the extension vectors form a basis of the image.
--
-- Everything the argument moves between a subspace and its ambient space runs
-- through ONE transport lemma, `Subspace.linearCombination_value`: the value of
-- a linear combination computed inside the subspace equals the combination of
-- the values computed in `V`. Independence and spanning transport between a
-- subspace family and its value-image in `V` are corollaries. This confines the
-- `Subtype`/`Subspace` boundary cost of the whole proof to that one induction.

module Algebra.rank_nullity

import Logic.basics
import Logic.exists
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.order
import Set.subtype
import Set.finite
import Set.equinumerous
import Algebra.field
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.field_bundle
import Algebra.vector_space
import Algebra.subspace
import Algebra.linear_map
import Algebra.linear_combination
import Algebra.span
import Algebra.exchange_lemma
import Algebra.basis_pruning
import Algebra.finite_dimensional
import Algebra.dimension

-- ----------------------------------------------------------------------
-- Brick 1 — the subtype-transport bridge.
--
-- The value of a linear combination formed inside the subspace
-- `Subspace.vector_space(V, subset, subspace)` is the linear combination of
-- the underlying values formed in `V`. Both `Subspace.add` and `Subspace.scale`
-- are defined so their value is the corresponding operation on values, so the
-- only real step in the induction is peeling the last term.
theorem Subspace.linearCombination_value {f : Field} {V : VectorSpace(f)} {I : Type(0)}
        (subset : Set(VectorSpace.carrier(V))) (subspace : IsSubspace(V, subset))
        (family : I → VectorSpace.carrier(Subspace.vector_space(V, subset, subspace)))
        (coefficients : Natural → Field.carrier(f))
        (selection : Natural → I) (count : Natural)
        : Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, count))
          = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
                coefficients, selection, count) :=
  by induction on count with IH {
    case base:
        Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, 0))
           = Subtype.value(VectorSpace.zero(Subspace.vector_space(V, subset, subspace)))
           = VectorSpace.zero(V)
           = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
                 coefficients, selection, 0)
    case step(m):
        Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, 1 + m))
           = Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, m)
                 + coefficients(m) • family(selection(m)))
                 by VectorSpace.linearCombination_add_one
           = Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, m))
                 + coefficients(m) • Subtype.value(family(selection(m)))
           = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
                 coefficients, selection, m)
                 + coefficients(m) • Subtype.value(family(selection(m)))
                 by IH
           = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
                 coefficients, selection, 1 + m)
                 by VectorSpace.linearCombination_add_one
  }

-- Independence and spanning transport across the value boundary, both
-- corollaries of the bridge above.

-- An independent family inside the subspace maps to an independent family in
-- `V`: a vanishing combination of the values, pushed through the bridge, is a
-- vanishing combination inside the subspace, whose coefficients the subspace
-- independence kills.
theorem Subspace.value_linearlyIndependent {f : Field} {V : VectorSpace(f)} {I : Type(0)}
        (subset : Set(VectorSpace.carrier(V))) (subspace : IsSubspace(V, subset))
        (family : I → VectorSpace.carrier(Subspace.vector_space(V, subset, subspace)))
        (independent : VectorSpace.LinearlyIndependent(family))
        : VectorSpace.LinearlyIndependent((i : I) ↦ Subtype.value(family(i))) := {
  take count : Natural;
  take selection : Natural → I;
  take coefficients : Natural → Field.carrier(f);
  suppose ∀ (a b : Natural). a < count → b < count → selection(a) = selection(b) → a = b
      as selectionInjective;
  suppose VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
              coefficients, selection, count) = VectorSpace.zero(V) as valuesVanish;
  Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, count))
     = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)), coefficients, selection, count)
           by Subspace.linearCombination_value
     = VectorSpace.zero(V) by valuesVanish
     = Subtype.value(VectorSpace.zero(Subspace.vector_space(V, subset, subspace)));
  VectorSpace.linearCombination(family, coefficients, selection, count)
      = VectorSpace.zero(Subspace.vector_space(V, subset, subspace))
      by Subtype.equal_of_value_equal as combinationZero;
  done by independent(count, selection, coefficients, selectionInjective, combinationZero)
}

-- A subspace family spans when every subspace vector's value is either zero or
-- a `V`-combination of the family values: the bridge turns that combination of
-- values back into a subspace combination, and equal values mean equal subtype
-- elements.
theorem Subspace.spans_of_value_covered {f : Field} {V : VectorSpace(f)} {I : Type(0)}
        (subset : Set(VectorSpace.carrier(V))) (subspace : IsSubspace(V, subset))
        (family : I → VectorSpace.carrier(Subspace.vector_space(V, subset, subspace)))
        (covered : ∀ (x : VectorSpace.carrier(Subspace.vector_space(V, subset, subspace))).
            Subtype.value(x) = VectorSpace.zero(V)
            ∨ VectorSpace.InSpanOf((i : I) ↦ Subtype.value(family(i)), Subtype.value(x)))
        : VectorSpace.Spans(family) := {
  take x : VectorSpace.carrier(Subspace.vector_space(V, subset, subspace));
  Subtype.value(x) = VectorSpace.zero(V)
      ∨ VectorSpace.InSpanOf((i : I) ↦ Subtype.value(family(i)), Subtype.value(x)) by covered;
  done by cases {
    case Subtype.value(x) = VectorSpace.zero(V) as valueZero: {
        Subtype.value(x) = VectorSpace.zero(V)
           = Subtype.value(VectorSpace.zero(Subspace.vector_space(V, subset, subspace)));
        x = VectorSpace.zero(Subspace.vector_space(V, subset, subspace))
            by Subtype.equal_of_value_equal;
        done
      }
    case VectorSpace.InSpanOf((i : I) ↦ Subtype.value(family(i)), Subtype.value(x)) as inSpan: {
        choose count, selection, coefficients such that
            Subtype.value(x) = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
                coefficients, selection, count) from inSpan;
        Subtype.value(x)
           = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)), coefficients, selection, count)
           = Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, count))
                 by Subspace.linearCombination_value;
        x = VectorSpace.linearCombination(family, coefficients, selection, count)
            by Subtype.equal_of_value_equal as xIsCombination;
        VectorSpace.InSpanOf(family, x) by { witness count with witness selection
            with witness coefficients with xIsCombination };
        done
      }
  }
}

-- ----------------------------------------------------------------------
-- The image of a linear combination under a linear map is the linear
-- combination of the images: linearity commutes with the finite sum.
theorem LinearMap.apply_linearCombination {f : Field} {V W : VectorSpace(f)} {I : Type(0)}
        {T : VectorSpace.carrier(V) → VectorSpace.carrier(W)} (linear : IsLinearMap(V, W, T))
        (family : I → VectorSpace.carrier(V))
        (coefficients : Natural → Field.carrier(f))
        (selection : Natural → I) (count : Natural)
        : T(VectorSpace.linearCombination(family, coefficients, selection, count))
          = VectorSpace.linearCombination((i : I) ↦ T(family(i)), coefficients, selection, count) :=
  by induction on count with IH {
    case base:
        T(VectorSpace.linearCombination(family, coefficients, selection, 0))
           = T(VectorSpace.zero(V))
           = VectorSpace.zero(W) by LinearMap.preserves_zero
           = VectorSpace.linearCombination((i : I) ↦ T(family(i)), coefficients, selection, 0)
    case step(m):
        T(VectorSpace.linearCombination(family, coefficients, selection, 1 + m))
           = T(VectorSpace.linearCombination(family, coefficients, selection, m)
                 + coefficients(m) • family(selection(m)))
                 by VectorSpace.linearCombination_add_one
           = T(VectorSpace.linearCombination(family, coefficients, selection, m))
                 + T(coefficients(m) • family(selection(m)))
                 by LinearMap.additive(linear, VectorSpace.linearCombination(family, coefficients, selection, m),
                        coefficients(m) • family(selection(m)))
           = VectorSpace.linearCombination((i : I) ↦ T(family(i)), coefficients, selection, m)
                 + T(coefficients(m) • family(selection(m)))
                 by IH
           = VectorSpace.linearCombination((i : I) ↦ T(family(i)), coefficients, selection, m)
                 + coefficients(m) • T(family(selection(m)))
                 by LinearMap.homogeneous(linear, coefficients(m), family(selection(m)))
           = VectorSpace.linearCombination((i : I) ↦ T(family(i)), coefficients, selection, 1 + m)
                 by VectorSpace.linearCombination_add_one
  }

-- ----------------------------------------------------------------------
-- Brick 2 — the image of a finite-dimensional space is finite-dimensional.
--
-- The images `T(b(i))` of a basis `b` of `V`, lifted into the image subtype,
-- span the image subspace: every element of the image is `T(v)`, and `v` is a
-- combination of the basis, so `T(v)` is the corresponding combination of the
-- `T(b(i))` by linearity. Finitely generated, hence finite-dimensional by
-- pruning.
theorem LinearMap.image_finite_dimensional {f : Field} (V W : VectorSpace(f))
        (T : VectorSpace.carrier(V) → VectorSpace.carrier(W)) (linear : IsLinearMap(V, W, T))
        (finiteV : VectorSpace.FiniteDimensional(V))
        : VectorSpace.FiniteDimensional(
              Subspace.vector_space(W, LinearMap.image(V, W, T),
                  LinearMap.image_is_subspace(V, W, T, linear))) := {
  IsSubspace(W, LinearMap.image(V, W, T)) by LinearMap.image_is_subspace as imageSubspace;
  VectorSpace.HasDimension(V, VectorSpace.dimension(V, finiteV))
      by VectorSpace.dimension_has_basis as vHasBasis;
  choose basisV such that VectorSpace.IsBasis(basisV) from vHasBasis;
  VectorSpace.Spans(basisV) by VectorSpace.IsBasis.spans as basisSpans;

  -- The lifted image family: index i ↦ the image T(basisV(i)) as an element of
  -- the image subtype.
  ∀ (i : NaturalsBelow(VectorSpace.dimension(V, finiteV))).
      T(basisV(i)) ∈ LinearMap.image(V, W, T)
    by { take i : NaturalsBelow(VectorSpace.dimension(V, finiteV));
         T(basisV(i)) = T(basisV(i));
         done by witness basisV(i) with reflexivity(T(basisV(i))) } as imageHits;

  ∀ (x : VectorSpace.carrier(Subspace.vector_space(W, LinearMap.image(V, W, T), imageSubspace))).
      Subtype.value(x) = VectorSpace.zero(W)
      ∨ VectorSpace.InSpanOf(
            (i : NaturalsBelow(VectorSpace.dimension(V, finiteV))) ↦ T(basisV(i)),
            Subtype.value(x))
    by {
          take x : VectorSpace.carrier(Subspace.vector_space(W, LinearMap.image(V, W, T), imageSubspace));
          Subtype.value(x) ∈ LinearMap.image(V, W, T) by Subtype.property;
          ∃ (v : VectorSpace.carrier(V)). T(v) = Subtype.value(x);
          choose v such that T(v) = Subtype.value(x) as vHits;
          Subtype.value(x) = VectorSpace.zero(W)
              ∨ VectorSpace.InSpanOf(
                    (i : NaturalsBelow(VectorSpace.dimension(V, finiteV))) ↦ T(basisV(i)),
                    Subtype.value(x))
            by {
              v = VectorSpace.zero(V)
                  ∨ (∃ (count : Natural). ∃ (selection : Natural → NaturalsBelow(VectorSpace.dimension(V, finiteV))).
                     ∃ (coefficients : Natural → Field.carrier(f)).
                         v = VectorSpace.linearCombination(basisV, coefficients, selection, count))
                  by basisSpans;
              done by cases {
                case v = VectorSpace.zero(V) as vZero: {
                    Subtype.value(x) = T(v) by vHits
                       = T(VectorSpace.zero(V)) by substituting vZero
                       = VectorSpace.zero(W) by LinearMap.preserves_zero;
                    done
                  }
                case ∃ (count : Natural). ∃ (selection : Natural → NaturalsBelow(VectorSpace.dimension(V, finiteV))).
                     ∃ (coefficients : Natural → Field.carrier(f)).
                         v = VectorSpace.linearCombination(basisV, coefficients, selection, count) as vCombo: {
                    choose count, selection, coefficients such that
                        v = VectorSpace.linearCombination(basisV, coefficients, selection, count) from vCombo;
                    Subtype.value(x) = T(v) by vHits
                       = T(VectorSpace.linearCombination(basisV, coefficients, selection, count))
                             by substituting (v = VectorSpace.linearCombination(basisV, coefficients, selection, count))
                       = VectorSpace.linearCombination(
                             (i : NaturalsBelow(VectorSpace.dimension(V, finiteV))) ↦ T(basisV(i)),
                             coefficients, selection, count)
                             by LinearMap.apply_linearCombination(linear, basisV, coefficients, selection, count)
                       as valueIsCombination;
                    VectorSpace.InSpanOf(
                        (i : NaturalsBelow(VectorSpace.dimension(V, finiteV))) ↦ T(basisV(i)),
                        Subtype.value(x))
                      by { witness count with witness selection with witness coefficients
                           with valueIsCombination };
                    done
                  }
              }
            };
      done
    } as coveredFact;
  VectorSpace.FinitelyGenerated(Subspace.vector_space(W, LinearMap.image(V, W, T), imageSubspace))
      by { witness VectorSpace.dimension(V, finiteV)
           with witness ((i : NaturalsBelow(VectorSpace.dimension(V, finiteV)))
                ↦ Subtype.make(VectorSpace.carrier(W), LinearMap.image(V, W, T),
                      T(basisV(i)), imageHits(i)))
           with Subspace.spans_of_value_covered(covered := coveredFact) };
  done by VectorSpace.FinitelyGenerated.finite_dimensional
}

-- ----------------------------------------------------------------------
-- Finite-family construction: appending a vector, and dropping a
-- zero-coefficient position from a combination. These are the tools the
-- basis-extension bricks (3–5) need to GROW an independent family, the
-- mirror of `basis_pruning`'s shrinking `dropIndex`.

-- The family `family` with one extra vector `x` appended at index `m`: below
-- `m` it reads `family`, at `m` (the last index) it reads `x`. Built on
-- `Function.extendBelow` (fallback `x`), so its two characterising equations
-- are immediate.
definition VectorSpace.appendVector {f : Field} {V : VectorSpace(f)} {m : Natural}
        (family : NaturalsBelow(m) → VectorSpace.carrier(V))
        (x : VectorSpace.carrier(V))
        : NaturalsBelow(1 + m) → VectorSpace.carrier(V) :=
  (i : NaturalsBelow(1 + m)) ↦
    Function.extendBelow(family, x)(NaturalsBelow.value(i))

theorem VectorSpace.appendVector_below {f : Field} {V : VectorSpace(f)} {m : Natural}
        (family : NaturalsBelow(m) → VectorSpace.carrier(V))
        (x : VectorSpace.carrier(V)) (i : NaturalsBelow(1 + m))
        (below : NaturalsBelow.value(i) < m)
        : VectorSpace.appendVector(family, x)(i)
          = family(NaturalsBelow.make(NaturalsBelow.value(i), below)) :=
  VectorSpace.appendVector(family, x)(i)
     = Function.extendBelow(family, x)(NaturalsBelow.value(i))
     = family(NaturalsBelow.make(NaturalsBelow.value(i), below))
           by Function.extendBelow_below

theorem VectorSpace.appendVector_last {f : Field} {V : VectorSpace(f)} {m : Natural}
        (family : NaturalsBelow(m) → VectorSpace.carrier(V))
        (x : VectorSpace.carrier(V)) (i : NaturalsBelow(1 + m))
        (atLast : NaturalsBelow.value(i) = m)
        : VectorSpace.appendVector(family, x)(i) = x := {
  m ≤ NaturalsBelow.value(i) by { NaturalsBelow.value(i) = m; done } as past;
  VectorSpace.appendVector(family, x)(i)
     = Function.extendBelow(family, x)(NaturalsBelow.value(i))
     = x by Function.extendBelow_past(past := past);
  done
}

-- Dropping a zero-coefficient position: a combination of `1 + n` terms whose
-- `p`-th coefficient is zero equals the `n`-term combination that reindexes
-- the coefficients and selection by `NaturalsBelow.skipValue(p, ·)` — the
-- order-preserving position map that skips `p`. (The dropped term is `0 • …`,
-- so it contributes nothing.) Induction on `n`, peeling the last position and
-- splitting on whether `p` is that last position.
theorem VectorSpace.linearCombination_drop_zero_position {f : Field} {V : VectorSpace(f)}
        {I : Type(0)} (family : I → VectorSpace.carrier(V))
        (coefficients : Natural → Field.carrier(f)) (selection : Natural → I)
        : ∀ (n : Natural). ∀ (p : Natural). p < 1 + n
              → coefficients(p) = Field.zero(f)
              → VectorSpace.linearCombination(family, coefficients, selection, 1 + n)
                = VectorSpace.linearCombination(family,
                      (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                      (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), n) :=
  by induction on n with IH {
    case base: {
        take p : Natural;
        suppose p < 1 + 0 as pBelow;
        suppose coefficients(p) = Field.zero(f) as coeffZero;
        p = 0 by { p ≤ 0 by Natural.le_of_lt_one_plus; done };
        VectorSpace.linearCombination(family, coefficients, selection, 1 + 0)
           = coefficients(0) • family(selection(0)) by VectorSpace.linearCombination_one
           = coefficients(p) • family(selection(p)) by substituting (p = 0)
           = Field.zero(f) • family(selection(p)) by substituting coeffZero
           = VectorSpace.zero(V) by VectorSpace.zero_scale
           = VectorSpace.linearCombination(family,
                 (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                 (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), 0)
      }
    case step(q): {
        take p : Natural;
        suppose p < 1 + (1 + q) as pBelow;
        suppose coefficients(p) = Field.zero(f) as coeffZero;
        p < 1 + q ∨ p = 1 + q by Natural.le_of_lt_one_plus;
        done by cases {
          case p < 1 + q as pNotLast: {
              -- `p` is not last: peel the last term (unchanged by the skip,
              -- since `skipValue(p, q) = 1 + q` for `q ≥ p`) and recurse.
              ¬(q < p) by { suppose q < p as qLtP; p ≤ q by Natural.le_of_lt_one_plus;
                            q < p ≤ q; done };
              NaturalsBelow.skipValue(p, q) = 1 + q
                  by NaturalsBelow.skipValue_above as skipLast;
              VectorSpace.linearCombination(family,
                    (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                    (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), 1 + q)
                 = VectorSpace.linearCombination(family,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), q)
                   + coefficients(NaturalsBelow.skipValue(p, q))
                       • family(selection(NaturalsBelow.skipValue(p, q)))
                       by VectorSpace.linearCombination_add_one
                 = VectorSpace.linearCombination(family,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), q)
                   + coefficients(1 + q) • family(selection(1 + q))
                       by substituting skipLast
                 as rhsPeeled;
              VectorSpace.linearCombination(family, coefficients, selection, 1 + (1 + q))
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                   + coefficients(1 + q) • family(selection(1 + q))
                       by VectorSpace.linearCombination_add_one
                 = VectorSpace.linearCombination(family,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), q)
                   + coefficients(1 + q) • family(selection(1 + q))
                       by IH(p, pNotLast, coeffZero)
                 = VectorSpace.linearCombination(family,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), 1 + q)
                       by rhsPeeled
            }
          case p = 1 + q as pLast: {
              -- The dropped position is the last one; the skip is the identity
              -- below `1 + q`, so the reindexed prefix is unchanged.
              ∀ (i : Natural). i < 1 + q →
                  coefficients(i) = coefficients(NaturalsBelow.skipValue(p, i))
                by { take i : Natural; suppose i < 1 + q as iBelow;
                     i < p by substituting pLast;
                     NaturalsBelow.skipValue(p, i) = i by NaturalsBelow.skipValue_below;
                     done by substituting (NaturalsBelow.skipValue(p, i) = i) } as coeffAgree;
              ∀ (i : Natural). i < 1 + q →
                  selection(i) = selection(NaturalsBelow.skipValue(p, i))
                by { take i : Natural; suppose i < 1 + q as iBelow;
                     i < p by substituting pLast;
                     NaturalsBelow.skipValue(p, i) = i by NaturalsBelow.skipValue_below;
                     done by substituting (NaturalsBelow.skipValue(p, i) = i) } as selAgree;
              coefficients(1 + q) = Field.zero(f)
                  by { coefficients(1 + q) = coefficients(p) by substituting pLast
                       = Field.zero(f) by coeffZero; done } as lastZero;
              VectorSpace.linearCombination(family, coefficients, selection, 1 + (1 + q))
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                   + coefficients(1 + q) • family(selection(1 + q))
                       by VectorSpace.linearCombination_add_one
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                   + Field.zero(f) • family(selection(1 + q))
                       by substituting lastZero
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                   + VectorSpace.zero(V) by VectorSpace.zero_scale
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                 = VectorSpace.linearCombination(family,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), 1 + q)
                       by VectorSpace.linearCombination_pointwise_below(
                              coefficientsAgree := coeffAgree, selectionsAgree := selAgree)
            }
        }
      }
  }

-- When every position of a combination over `appendVector(e, x)` selects an
-- index below `m` (an `e`-vector, never the appended `x`), the combination IS
-- a combination over `e` alone, reindexed by the clamp `NaturalsBelow(1+m) →
-- NaturalsBelow(m)`. (`ei0` is any `e`-index, supplying the clamp fallback.)
theorem VectorSpace.appendVector_reduces_to_e {f : Field} {V : VectorSpace(f)} {m : Natural}
        (e : NaturalsBelow(m) → VectorSpace.carrier(V)) (x : VectorSpace.carrier(V))
        (coefficients : Natural → Field.carrier(f))
        (selection : Natural → NaturalsBelow(1 + m)) (count : Natural)
        (ei0 : NaturalsBelow(m))
        (allBelow : ∀ (j : Natural). j < count → NaturalsBelow.value(selection(j)) < m)
        : VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, count)
          = VectorSpace.linearCombination(e, coefficients,
                (j : Natural) ↦ NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j))), count) := {
  ∀ (j : Natural). j < count →
      coefficients(j) • VectorSpace.appendVector(e, x)(selection(j))
      = coefficients(j) • e(NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j))))
    by {
      take j : Natural;
      suppose j < count as jBelow;
      NaturalsBelow.value(selection(j)) < m by allBelow as valBelow;
      VectorSpace.appendVector(e, x)(selection(j))
          = e(NaturalsBelow.make(NaturalsBelow.value(selection(j)), valBelow))
          by VectorSpace.appendVector_below as appAt;
      NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j)))
          = NaturalsBelow.make(NaturalsBelow.value(selection(j)), valBelow)
          by NaturalsBelow.clamp_below as clampAt;
      coefficients(j) • VectorSpace.appendVector(e, x)(selection(j))
         = coefficients(j) • e(NaturalsBelow.make(NaturalsBelow.value(selection(j)), valBelow))
             by substituting appAt
         = coefficients(j) • e(NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j))))
             by substituting clampAt
    };
  done by VectorSpace.linearCombination_congruence
}

-- The clamp reindex of an injective, below-`m` selection is itself injective:
-- distinct positions give distinct values give distinct clamped indices.
theorem VectorSpace.appendVector_clamp_injective {f : Field} {V : VectorSpace(f)} {m : Natural}
        (selection : Natural → NaturalsBelow(1 + m)) (count : Natural) (ei0 : NaturalsBelow(m))
        (selInjective : ∀ (a b : Natural). a < count → b < count → selection(a) = selection(b) → a = b)
        (allBelow : ∀ (j : Natural). j < count → NaturalsBelow.value(selection(j)) < m)
        : ∀ (a b : Natural). a < count → b < count →
              NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(a)))
              = NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(b))) → a = b := {
  take a : Natural; take b : Natural;
  suppose a < count as aBelow;
  suppose b < count as bBelow;
  suppose NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(a)))
          = NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(b))) as clampEqual;
  NaturalsBelow.value(selection(a)) < m by allBelow as aValBelow;
  NaturalsBelow.value(selection(b)) < m by allBelow as bValBelow;
  NaturalsBelow.value(selection(a))
     = NaturalsBelow.value(NaturalsBelow.make(NaturalsBelow.value(selection(a)), aValBelow))
     = NaturalsBelow.value(NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(a))))
           by NaturalsBelow.clamp_below
     = NaturalsBelow.value(NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(b))))
           by substituting clampEqual
     = NaturalsBelow.value(NaturalsBelow.make(NaturalsBelow.value(selection(b)), bValBelow))
           by NaturalsBelow.clamp_below
     = NaturalsBelow.value(selection(b));
  selection(a) = selection(b) by NaturalsBelow.equal_of_value(a := selection(a), b := selection(b));
  done by selInjective
}

-- Small arithmetic / position facts the append lemma leans on.
theorem Natural.less_than_one_is_zero (k : Natural) (h : k < 1) : k = 0 := {
  k ≤ 0 by Natural.le_of_lt_one_plus;
  done by Natural.less_or_equal_zero_implies_equals_zero
}

theorem Natural.positive_one_plus_monus_one (n : Natural) (pos : 0 < n)
        : n = 1 + (n ∸ 1) := {
  n = 0 ∨ ∃ (k : Natural). n = 1 + k by Natural.zero_or_one_plus;
  done by cases {
    case n = 0 as nZero: { 0 < 0 by substituting nZero;
                           ¬(0 < 0) by Natural.lt_irreflexive; done }
    case ∃ (k : Natural). n = 1 + k as nPlus: {
        choose k such that n = 1 + k from nPlus;
        (n ∸ 1) = ((1 + k) ∸ 1) by substituting (n = 1 + k)
           = k by NaturalsBelow.monus_one_plus_one as monusK;
        n = 1 + k = 1 + (n ∸ 1) by substituting monusK;
        done
    }
  }
}

theorem NaturalsBelow.skipValue_ne (jv j : Natural) : NaturalsBelow.skipValue(jv, j) ≠ jv := {
  j < jv ∨ jv ≤ j by Natural.lt_or_le;
  done by cases {
    case j < jv as below: {
        NaturalsBelow.skipValue(jv, j) = j by NaturalsBelow.skipValue_below as sv;
        j ≠ jv by Natural.not_equal_of_less_than;
        done by substituting sv
      }
    case jv ≤ j as ge: {
        ¬(j < jv) by { suppose j < jv as jLt; j < jv ≤ j; done };
        NaturalsBelow.skipValue(jv, j) = 1 + j by NaturalsBelow.skipValue_above as sv;
        jv < 1 + j by { jv ≤ j < 1 + j; done };
        1 + j ≠ jv by Natural.not_equal_of_greater_than;
        done by substituting sv
      }
  }
}

theorem NaturalsBelow.skipValue_injective (jv a b : Natural)
        (h : NaturalsBelow.skipValue(jv, a) = NaturalsBelow.skipValue(jv, b)) : a = b := {
  a < jv ∨ jv ≤ a by Natural.lt_or_le;
  done by cases {
    case a < jv as aBelow: {
        NaturalsBelow.skipValue(jv, a) = a by NaturalsBelow.skipValue_below as sa;
        b < jv ∨ jv ≤ b by Natural.lt_or_le;
        done by cases {
          case b < jv as bBelow: {
              NaturalsBelow.skipValue(jv, b) = b by NaturalsBelow.skipValue_below as sb;
              a = NaturalsBelow.skipValue(jv, a) by sa
                = NaturalsBelow.skipValue(jv, b) by h
                = b by sb;
              done
            }
          case jv ≤ b as bGe: {
              ¬(b < jv) by { suppose b < jv as bLt; b < jv ≤ b; done };
              NaturalsBelow.skipValue(jv, b) = 1 + b by NaturalsBelow.skipValue_above as sb;
              a = 1 + b by { a = NaturalsBelow.skipValue(jv, a) by sa
                               = NaturalsBelow.skipValue(jv, b) by h = 1 + b by sb; done } as aEq;
              a < 1 + b by { a < jv ≤ b < 1 + b; done };
              1 + b < 1 + b by substituting aEq;
              ¬(1 + b < 1 + b) by Natural.lt_irreflexive;
              done
            }
        }
      }
    case jv ≤ a as aGe: {
        ¬(a < jv) by { suppose a < jv as aLt; a < jv ≤ a; done };
        NaturalsBelow.skipValue(jv, a) = 1 + a by NaturalsBelow.skipValue_above as sa;
        b < jv ∨ jv ≤ b by Natural.lt_or_le;
        done by cases {
          case b < jv as bBelow: {
              NaturalsBelow.skipValue(jv, b) = b by NaturalsBelow.skipValue_below as sb;
              b = 1 + a by { b = NaturalsBelow.skipValue(jv, b) by sb
                               = NaturalsBelow.skipValue(jv, a) by h = 1 + a by sa; done } as bEq;
              b < 1 + a by { b < jv ≤ a < 1 + a; done };
              1 + a < 1 + a by substituting bEq;
              ¬(1 + a < 1 + a) by Natural.lt_irreflexive;
              done
            }
          case jv ≤ b as bGe: {
              ¬(b < jv) by { suppose b < jv as bLt; b < jv ≤ b; done };
              NaturalsBelow.skipValue(jv, b) = 1 + b by NaturalsBelow.skipValue_above as sb;
              1 + a = 1 + b by { 1 + a = NaturalsBelow.skipValue(jv, a) by sa
                                   = NaturalsBelow.skipValue(jv, b) by h = 1 + b by sb; done };
              done by Natural.add_cancel_left
            }
        }
      }
  }
}

-- ----------------------------------------------------------------------
-- The append lemma: a vector outside the span of an independent family
-- extends it to a larger independent family. This is the growing counterpart
-- of `independent_or_droppable`, and the engine behind basis EXTENSION.
--
-- A vanishing combination of `appendVector(e, x)` cannot use `x` (its
-- coefficient there would put `x` in the span of the `e`-vectors — the other
-- indices — contradicting `x ∉ span(e)`), so it reduces to a vanishing
-- combination of `e` alone, whose coefficients `e`'s independence kills. The
-- (at most one) position selecting `x` carries a zero coefficient and is
-- dropped by `linearCombination_drop_zero_position` to keep the reduced
-- selection injective.
theorem VectorSpace.independent_append_outside_span {f : Field} {V : VectorSpace(f)} {m : Natural}
        (e : NaturalsBelow(m) → VectorSpace.carrier(V)) (x : VectorSpace.carrier(V))
        (eIndependent : VectorSpace.LinearlyIndependent(e))
        (notInSpan : ¬(x = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(e, x)))
        : VectorSpace.LinearlyIndependent(VectorSpace.appendVector(e, x)) := {
  ¬VectorSpace.InSpanOf(e, x)
      by { suppose VectorSpace.InSpanOf(e, x) as inSpan;
           x = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(e, x); done };
  x ≠ VectorSpace.zero(V)
      by { suppose x = VectorSpace.zero(V) as isZero;
           x = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(e, x); done };
  take len : Natural;
  take selection : Natural → NaturalsBelow(1 + m);
  take coefficients : Natural → Field.carrier(f);
  suppose ∀ (a b : Natural). a < len → b < len → selection(a) = selection(b) → a = b
      as selectionInjective;
  suppose VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, len)
          = VectorSpace.zero(V) as vanishes;
  m = 0 ∨ ∃ (mp : Natural). m = 1 + mp by Natural.zero_or_one_plus;
  done by cases {
    case m = 0 as mZero: {
        -- The empty family: `appendVector` is the singleton `{x}`; any two
        -- positions select the sole index, so an injective selection has at
        -- most one position, and its coefficient kills `x`.
        ∀ (i : Natural). i < len → NaturalsBelow.value(selection(i)) = m
          by { take i : Natural; suppose i < len as iBelow;
               NaturalsBelow.value(selection(i)) < 1 + m by NaturalsBelow.below;
               1 + m = 1 by substituting mZero;
               NaturalsBelow.value(selection(i)) < 1;
               NaturalsBelow.value(selection(i)) = 0 by NaturalsBelow.below_one_is_zero;
               done by substituting mZero } as allAtLast;
        ¬(1 < len)
          by { suppose 1 < len as oneLtLen;
               0 < len by { 0 < 1 < len; done };
               NaturalsBelow.value(selection(0)) = m by allAtLast;
               NaturalsBelow.value(selection(1)) = m by allAtLast;
               NaturalsBelow.value(selection(0)) = NaturalsBelow.value(selection(1));
               selection(0) = selection(1)
                   by NaturalsBelow.equal_of_value(a := selection(0), b := selection(1));
               0 = 1 by selectionInjective(0, 1);
               done } as notOneLtLen;
        take i : Natural;
        suppose i < len as iBelow;
        0 < len by { 0 ≤ i < len; done } as lenPos;
        len ≤ 1 by { 1 < len ∨ len ≤ 1 by Natural.lt_or_le;
                     done by cases { case 1 < len as c: { ¬(1 < len) by notOneLtLen; done }
                                     case len ≤ 1 as c: { done } } };
        1 ≤ len by Natural.add_one_le_of_lt;
        len = 1 by Natural.le_antisymmetric as lenOne;
        i < 1 by substituting lenOne;
        i = 0 by Natural.less_than_one_is_zero as iZero;
        VectorSpace.appendVector(e, x)(selection(0)) = x
            by VectorSpace.appendVector_last(atLast := allAtLast(0, lenPos)) as app0;
        coefficients(i) • x = VectorSpace.zero(V)
          by {
            VectorSpace.zero(V)
               = VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, len)
                     by vanishes
               = VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, 1)
                     by substituting lenOne
               = coefficients(0) • VectorSpace.appendVector(e, x)(selection(0))
                     by VectorSpace.linearCombination_one
               = coefficients(0) • x by substituting app0
               = coefficients(i) • x by substituting iZero;
            done
          } as termZero;
        suppose coefficients(i) ≠ Field.zero(f) as ciNonzero for contradiction {
          x = Field.reciprocal(coefficients(i), ciNonzero) • (coefficients(i) • x)
                by VectorSpace.scale_reciprocal_cancel
            = Field.reciprocal(coefficients(i), ciNonzero) • VectorSpace.zero(V)
                by substituting termZero
            = VectorSpace.zero(V) by VectorSpace.scale_zero;
          done
        }
      }
    case ∃ (mp : Natural). m = 1 + mp as mPosExists: {
        choose mp such that m = 1 + mp from mPosExists;
        0 < m by { 0 < 1 + mp; done by substituting (m = 1 + mp) } as mPos;
        let ei0 : NaturalsBelow(m) := NaturalsBelow.make(0, mPos);

        -- Step 1: a position selecting the appended slot `x` carries a zero
        -- coefficient — else `x` would lie in the span of the other vectors,
        -- all of which are `e`-vectors, so in `span(e)`.
        ∀ (p : Natural). p < len → NaturalsBelow.value(selection(p)) = m → coefficients(p) = Field.zero(f)
          by {
            take p : Natural;
            suppose p < len as pBelow;
            suppose NaturalsBelow.value(selection(p)) = m as pAtLast;
            suppose coefficients(p) ≠ Field.zero(f) as cpNonzero for contradiction {
                VectorSpace.InSpanOf(VectorSpace.dropIndex(VectorSpace.appendVector(e, x), selection(p)),
                    VectorSpace.appendVector(e, x)(selection(p)))
                    by VectorSpace.dropIndex_redundant(countPos := mPos, i0 := p);
                VectorSpace.appendVector(e, x)(selection(p)) = x by VectorSpace.appendVector_last as appAtP;
                VectorSpace.InSpanOf(VectorSpace.dropIndex(VectorSpace.appendVector(e, x), selection(p)), x)
                    by substituting appAtP as xInDrop;
                ∀ (i : NaturalsBelow(m)).
                    VectorSpace.InSpanOf(e, VectorSpace.dropIndex(VectorSpace.appendVector(e, x), selection(p))(i))
                  by {
                    take i : NaturalsBelow(m);
                    NaturalsBelow.value(i) < m by NaturalsBelow.below as iValBelow;
                    NaturalsBelow.value(NaturalsBelow.skip(NaturalsBelow.value(selection(p)), i))
                       = NaturalsBelow.skipValue(NaturalsBelow.value(selection(p)), NaturalsBelow.value(i))
                           by NaturalsBelow.skip_value
                       = NaturalsBelow.skipValue(m, NaturalsBelow.value(i)) by substituting pAtLast
                       = NaturalsBelow.value(i)
                           by NaturalsBelow.skipValue_below(below := iValBelow)
                       as skipVal;
                    NaturalsBelow.value(NaturalsBelow.skip(NaturalsBelow.value(selection(p)), i)) < m
                        by substituting skipVal as skipBelow;
                    VectorSpace.dropIndex(VectorSpace.appendVector(e, x), selection(p))(i)
                       = VectorSpace.appendVector(e, x)(NaturalsBelow.skip(NaturalsBelow.value(selection(p)), i))
                       = e(NaturalsBelow.make(
                             NaturalsBelow.value(NaturalsBelow.skip(NaturalsBelow.value(selection(p)), i)),
                             skipBelow))
                           by VectorSpace.appendVector_below as dropAtI;
                    VectorSpace.InSpanOf(e, e(NaturalsBelow.make(
                        NaturalsBelow.value(NaturalsBelow.skip(NaturalsBelow.value(selection(p)), i)), skipBelow)))
                        by VectorSpace.InSpanOf.member;
                    done by substituting dropAtI
                  } as dropInSpanE;
                VectorSpace.InSpanOf(e, x)
                    by VectorSpace.InSpanOf.transitive(
                           outerInhabitant := ei0,
                           generatorsInSpan := dropInSpanE, member := xInDrop);
                done
            }
          } as xVanish;

        -- Step 2: reduce the whole vanishing combination to one over `e` and
        -- invoke `e`'s independence.
        ¬(∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m)
            ∨ (∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m)
          by { (∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m)
                   ∨ ¬(∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m)
                   by Logic.excluded_middle;
               done by cases {
                 case ∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m as ex: { done }
                 case ¬(∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m) as nex: { done }
               } };
        done by cases {
          case ¬(∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m) as noLast: {
              ∀ (j : Natural). j < len → NaturalsBelow.value(selection(j)) < m
                by { take j : Natural; suppose j < len as jBelow;
                     NaturalsBelow.value(selection(j)) < 1 + m by NaturalsBelow.below;
                     NaturalsBelow.value(selection(j)) ≤ m by Natural.le_of_lt_one_plus;
                     NaturalsBelow.value(selection(j)) ≠ m
                         by { suppose NaturalsBelow.value(selection(j)) = m as jAtLast;
                              ∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m
                                  by { witness j with And.introduction(jBelow, jAtLast) };
                              done };
                     done by Natural.lt_of_le_of_ne } as allBelow;
              VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, len)
                 = VectorSpace.linearCombination(e, coefficients,
                       (j : Natural) ↦ NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j))), len)
                       by VectorSpace.appendVector_reduces_to_e(ei0 := ei0, allBelow := allBelow) as reduceEq;
              VectorSpace.linearCombination(e, coefficients,
                    (j : Natural) ↦ NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j))), len)
                 = VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, len)
                       by reduceEq
                 = VectorSpace.zero(V) by vanishes as eCombZero;
              ∀ (a b : Natural). a < len → b < len →
                  NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(a)))
                  = NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(b))) → a = b
                  by VectorSpace.appendVector_clamp_injective(ei0 := ei0,
                         selInjective := selectionInjective, allBelow := allBelow) as clampInj;
              done by eIndependent(len,
                  (j : Natural) ↦ NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j))),
                  coefficients, clampInj, eCombZero)
            }
          case ∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m as lastExists: {
              choose p0 such that p0 < len ∧ NaturalsBelow.value(selection(p0)) = m from lastExists;
              p0 < len as p0Below;
              NaturalsBelow.value(selection(p0)) = m as p0AtLast;
              coefficients(p0) = Field.zero(f) by xVanish(p0, p0Below, p0AtLast) as cp0Zero;
              len = 1 + (len ∸ 1)
                  by { 0 < len by { 0 ≤ p0 < len; done };
                       done by Natural.positive_one_plus_monus_one } as lenShape;
              p0 < 1 + (len ∸ 1) by substituting lenShape as p0BelowShape;
              -- Drop position p0 (zero coefficient) to keep injectivity.
              VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, len)
                 = VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection,
                       1 + (len ∸ 1)) by substituting lenShape
                 = VectorSpace.linearCombination(VectorSpace.appendVector(e, x),
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p0, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p0, i)), len ∸ 1)
                       by VectorSpace.linearCombination_drop_zero_position(
                              VectorSpace.appendVector(e, x), coefficients, selection,
                              len ∸ 1, p0, p0BelowShape, cp0Zero)
                 as droppedComb;
              -- The dropped selection avoids the x-slot: all below m.
              ∀ (j : Natural). j < (len ∸ 1) →
                  NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, j))) < m
                by {
                  take j : Natural; suppose j < (len ∸ 1) as jBelow;
                  NaturalsBelow.skipValue(p0, j) < len
                    by { NaturalsBelow.skipValue(p0, j) < 1 + (len ∸ 1)
                             by NaturalsBelow.skipValue_bound(jv := p0,
                                    i := NaturalsBelow.make(j, jBelow));
                         done by substituting lenShape } as skipInLen;
                  NaturalsBelow.skipValue(p0, j) ≠ p0 by NaturalsBelow.skipValue_ne(jv := p0, j := j);
                  NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, j))) < 1 + m
                      by NaturalsBelow.below;
                  NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, j))) ≤ m
                      by Natural.le_of_lt_one_plus;
                  NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, j))) ≠ m
                    by { suppose NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, j))) = m as jAtLast;
                         NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, j)))
                             = NaturalsBelow.value(selection(p0)) by { done by substituting p0AtLast };
                         selection(NaturalsBelow.skipValue(p0, j)) = selection(p0)
                             by NaturalsBelow.equal_of_value(a := selection(NaturalsBelow.skipValue(p0, j)),
                                    b := selection(p0));
                         NaturalsBelow.skipValue(p0, j) = p0 by selectionInjective(
                             NaturalsBelow.skipValue(p0, j), p0, skipInLen, p0Below);
                         done };
                  done by Natural.lt_of_le_of_ne
                } as droppedBelow;
              VectorSpace.linearCombination(VectorSpace.appendVector(e, x),
                    (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p0, i)),
                    (i : Natural) ↦ selection(NaturalsBelow.skipValue(p0, i)), len ∸ 1)
                 = VectorSpace.linearCombination(e,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p0, i)),
                       (i : Natural) ↦ NaturalsBelow.clamp(ei0)(
                           NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, i)))),
                       len ∸ 1)
                       by VectorSpace.appendVector_reduces_to_e(ei0 := ei0, allBelow := droppedBelow)
                 as reduceEq;
              VectorSpace.linearCombination(e,
                    (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p0, i)),
                    (i : Natural) ↦ NaturalsBelow.clamp(ei0)(
                        NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, i)))),
                    len ∸ 1)
                 = VectorSpace.linearCombination(VectorSpace.appendVector(e, x),
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p0, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p0, i)), len ∸ 1)
                       by reduceEq
                 = VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, len)
                       by droppedComb
                 = VectorSpace.zero(V) by vanishes as eCombZero;
              -- The dropped selection is injective, so `e`-independence applies.
              ∀ (a b : Natural). a < (len ∸ 1) → b < (len ∸ 1) →
                  NaturalsBelow.clamp(ei0)(
                      NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, a))))
                  = NaturalsBelow.clamp(ei0)(
                      NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, b)))) → a = b
                by {
                  take a : Natural; take b : Natural;
                  suppose a < (len ∸ 1) as aBelow;
                  suppose b < (len ∸ 1) as bBelow;
                  suppose NaturalsBelow.clamp(ei0)(
                              NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, a))))
                          = NaturalsBelow.clamp(ei0)(
                              NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, b)))) as clampEq;
                  NaturalsBelow.skipValue(p0, a) < len
                    by { NaturalsBelow.skipValue(p0, a) < 1 + (len ∸ 1)
                             by NaturalsBelow.skipValue_bound(jv := p0, i := NaturalsBelow.make(a, aBelow));
                         done by substituting lenShape } as skipALen;
                  NaturalsBelow.skipValue(p0, b) < len
                    by { NaturalsBelow.skipValue(p0, b) < 1 + (len ∸ 1)
                             by NaturalsBelow.skipValue_bound(jv := p0, i := NaturalsBelow.make(b, bBelow));
                         done by substituting lenShape } as skipBLen;
                  NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, a))) < m
                      by droppedBelow(a, aBelow) as aValBelow;
                  NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, b))) < m
                      by droppedBelow(b, bBelow) as bValBelow;
                  NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, a)))
                     = NaturalsBelow.value(NaturalsBelow.make(
                           NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, a))), aValBelow))
                     = NaturalsBelow.value(NaturalsBelow.clamp(ei0)(
                           NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, a))))) by NaturalsBelow.clamp_below
                     = NaturalsBelow.value(NaturalsBelow.clamp(ei0)(
                           NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, b))))) by substituting clampEq
                     = NaturalsBelow.value(NaturalsBelow.make(
                           NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, b))), bValBelow))
                           by NaturalsBelow.clamp_below
                     = NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, b)));
                  selection(NaturalsBelow.skipValue(p0, a)) = selection(NaturalsBelow.skipValue(p0, b))
                      by NaturalsBelow.equal_of_value(a := selection(NaturalsBelow.skipValue(p0, a)),
                             b := selection(NaturalsBelow.skipValue(p0, b)));
                  NaturalsBelow.skipValue(p0, a) = NaturalsBelow.skipValue(p0, b)
                      by selectionInjective(NaturalsBelow.skipValue(p0, a), NaturalsBelow.skipValue(p0, b),
                             skipALen, skipBLen);
                  done by NaturalsBelow.skipValue_injective(jv := p0)
                } as droppedInj;
              ∀ (i : Natural). i < (len ∸ 1) →
                  coefficients(NaturalsBelow.skipValue(p0, i)) = Field.zero(f)
                  by eIndependent(len ∸ 1,
                      (i : Natural) ↦ NaturalsBelow.clamp(ei0)(
                          NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, i)))),
                      (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p0, i)),
                      droppedInj, eCombZero) as skippedCoeffsZero;
              -- Recover every original coefficient: p0 is zero directly, and
              -- j ≠ p0 is `skipValue(p0, skipInverse(p0, j))`.
              take i : Natural;
              suppose i < len as iBelow;
              i = p0 ∨ i ≠ p0 by Logic.excluded_middle;
              done by cases {
                case i = p0 as iIsP0: {
                    coefficients(i) = coefficients(p0) by substituting iIsP0
                       = Field.zero(f) by cp0Zero;
                    done
                  }
                case i ≠ p0 as iNeP0: {
                    i < 1 + (len ∸ 1) by substituting lenShape as iBelowShape;
                    p0 ≤ (len ∸ 1)
                        by { p0 < 1 + (len ∸ 1) by p0BelowShape;
                             done by Natural.le_of_lt_one_plus } as p0LeMonus;
                    NaturalsBelow.skipInverseValue(p0, i) < (len ∸ 1)
                        by NaturalsBelow.skipInverseValue_bound(count := len ∸ 1, jv := p0,
                               x := i, xBound := iBelowShape, jvBound := p0LeMonus,
                               ne := iNeP0) as skipInvBelow;
                    NaturalsBelow.skipValue(p0, NaturalsBelow.skipInverseValue(p0, i)) = i
                        by NaturalsBelow.skipValue_skipInverse(ne := iNeP0) as roundTrip;
                    coefficients(i)
                       = coefficients(NaturalsBelow.skipValue(p0, NaturalsBelow.skipInverseValue(p0, i)))
                             by substituting roundTrip
                       = Field.zero(f) by skippedCoeffsZero(NaturalsBelow.skipInverseValue(p0, i), skipInvBelow);
                    done
                  }
              }
            }
        }
    }
  }
}

-- ----------------------------------------------------------------------
-- Brick 3 — a subspace of a finite-dimensional space is finite-dimensional.
--
-- Independent families inside the subspace are bounded in size by `dim V`
-- (their value-images are independent in `V`, and the exchange lemma caps an
-- independent family by a spanning one). So a largest independent size exists;
-- a family realising it must SPAN the subspace — otherwise a vector outside its
-- span would, by the append lemma, extend it to a strictly larger independent
-- family. That maximal independent family is therefore a basis.
theorem VectorSpace.subspace_finite_dimensional {f : Field} {V : VectorSpace(f)}
        (subset : Set(VectorSpace.carrier(V))) (subspace : IsSubspace(V, subset))
        (finiteV : VectorSpace.FiniteDimensional(V))
        : VectorSpace.FiniteDimensional(Subspace.vector_space(V, subset, subspace)) := {
  let S : VectorSpace(f) := Subspace.vector_space(V, subset, subspace);
  let d : Natural := VectorSpace.dimension(V, finiteV);
  VectorSpace.HasDimension(V, d) by VectorSpace.dimension_has_basis as vHasBasis;
  choose b such that VectorSpace.IsBasis(b) from vHasBasis;
  VectorSpace.Spans(b) by VectorSpace.IsBasis.spans as bSpans;

  -- Any independent family in S has size ≤ d.
  ∀ (k : Natural).
      (∃ (family : NaturalsBelow(k) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
      → k ≤ d
    by {
      take k : Natural;
      suppose ∃ (family : NaturalsBelow(k) → VectorSpace.carrier(S)).
          VectorSpace.LinearlyIndependent(family) as hasK;
      choose family such that VectorSpace.LinearlyIndependent(family) from hasK;
      VectorSpace.LinearlyIndependent(
          (i : NaturalsBelow(k)) ↦ Subspace.inclusion(V, subset, subspace)(family(i)))
          by Subspace.value_linearlyIndependent(subset, subspace, family) as valueIndependent;
      done by VectorSpace.exchange(k, d,
          (i : NaturalsBelow(k)) ↦ Subspace.inclusion(V, subset, subspace)(family(i)),
          b, valueIndependent, bSpans)
    } as sizeBound;

  -- No independent family of size 1 + d exists.
  ¬(∃ (family : NaturalsBelow(1 + d) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
    by {
      suppose ∃ (family : NaturalsBelow(1 + d) → VectorSpace.carrier(S)).
          VectorSpace.LinearlyIndependent(family) as has1d;
      1 + d ≤ d by sizeBound(1 + d, has1d);
      d < d by { d < 1 + d; d < 1 + d ≤ d; done };
      ¬(d < d) by Natural.lt_irreflexive;
      done
    } as notPlus1d;

  -- A least size with no independent family; the empty family shows it is ≥ 1.
  ∃ (j0 : Natural).
      ¬(∃ (family : NaturalsBelow(j0) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
      ∧ (∀ (k : Natural).
            ¬(∃ (family : NaturalsBelow(k) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
            → j0 ≤ k)
    by Natural.least_witness(
        (k : Natural) ↦ ¬(∃ (family : NaturalsBelow(k) → VectorSpace.carrier(S)).
            VectorSpace.LinearlyIndependent(family)), 1 + d, notPlus1d) as leastExists;
  choose j0 such that
      ¬(∃ (family : NaturalsBelow(j0) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
      ∧ (∀ (k : Natural).
            ¬(∃ (family : NaturalsBelow(k) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
            → j0 ≤ k)
      from leastExists;
  ¬(∃ (family : NaturalsBelow(j0) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
     ;
  ∀ (k : Natural).
      ¬(∃ (family : NaturalsBelow(k) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
      → j0 ≤ k as j0IsLeast;

  VectorSpace.LinearlyIndependent((i : NaturalsBelow(0)) ↦ VectorSpace.zero(S))
      by VectorSpace.empty_family_independent as emptyIndependent;
  j0 ≠ 0
    by { suppose j0 = 0 as j0Zero;
         VectorSpace.LinearlyIndependent((i : NaturalsBelow(j0)) ↦ VectorSpace.zero(S))
             by { VectorSpace.LinearlyIndependent((i : NaturalsBelow(0)) ↦ VectorSpace.zero(S))
                      by emptyIndependent;
                  done by substituting j0Zero } as independentAtJ0;
         ∃ (family : NaturalsBelow(j0) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family)
             by { witness ((i : NaturalsBelow(j0)) ↦ VectorSpace.zero(S)) with independentAtJ0 };
         done } as j0Nonzero;
  j0 = 0 ∨ ∃ (m0 : Natural). j0 = 1 + m0 by Natural.zero_or_one_plus;
  done by cases {
    case j0 = 0 as contradiction0: { j0 ≠ 0 by j0Nonzero; done }
    case ∃ (m0 : Natural). j0 = 1 + m0 as j0Shape: {
        choose m0 such that j0 = 1 + m0 from j0Shape;
        -- The maximal independent family, of size m0.
        ∃ (family : NaturalsBelow(m0) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family)
          by {
            suppose ¬(∃ (family : NaturalsBelow(m0) → VectorSpace.carrier(S)).
                VectorSpace.LinearlyIndependent(family)) as noneAtM0 for contradiction {
              j0 ≤ m0 by j0IsLeast(m0, noneAtM0);
              m0 < j0 by { m0 < 1 + m0; done by substituting (j0 = 1 + m0) };
              m0 < j0 ≤ m0;
              done
            }
          } as maximalExists;
        choose eMax such that VectorSpace.LinearlyIndependent(eMax) from maximalExists;
        VectorSpace.LinearlyIndependent(eMax) as eMaxIndependent;
        -- It spans: a vector outside its span would extend it, contradicting maximality.
        VectorSpace.Spans(eMax)
          by {
            take y : VectorSpace.carrier(S);
            suppose ¬(y = VectorSpace.zero(S) ∨ VectorSpace.InSpanOf(eMax, y)) as yOutside
                for contradiction {
              VectorSpace.LinearlyIndependent(VectorSpace.appendVector(eMax, y))
                  by VectorSpace.independent_append_outside_span(eMax, y, eMaxIndependent, yOutside)
                  as appendIndependent;
              VectorSpace.LinearlyIndependent(VectorSpace.appendVector(eMax, y))
                  → (∃ (family : NaturalsBelow(j0) → VectorSpace.carrier(S)).
                        VectorSpace.LinearlyIndependent(family))
                by { suppose VectorSpace.LinearlyIndependent(VectorSpace.appendVector(eMax, y)) as ai;
                     ∃ (family : NaturalsBelow(1 + m0) → VectorSpace.carrier(S)).
                         VectorSpace.LinearlyIndependent(family)
                         by { witness VectorSpace.appendVector(eMax, y) with ai };
                     done by substituting (j0 = 1 + m0) } as bridge;
              ∃ (family : NaturalsBelow(j0) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family)
                  by bridge(appendIndependent);
              done
            }
          } as eMaxSpans;
        VectorSpace.IsBasis(eMax)
            by { VectorSpace.LinearlyIndependent(eMax) by eMaxIndependent;
                 VectorSpace.Spans(eMax) by eMaxSpans; done } as eMaxBasis;
        VectorSpace.HasDimension(S, m0) by { witness eMax with eMaxBasis } as sHasDimension;
        done by { witness m0 with sHasDimension }
    }
  }
}

-- ----------------------------------------------------------------------
-- Brick 4 — basis extension. An independent family extends to a basis of a
-- finite-dimensional space by appending spanning vectors not yet in its span.

-- Span is monotone under append: anything in the span of `family` stays in the
-- span of `appendVector(family, x)` (the extra vector simply goes unused). The
-- witnessing combination is reindexed by the value-preserving inclusion
-- `NaturalsBelow(m) ↪ NaturalsBelow(1 + m)`.
theorem NaturalsBelow.value_below_one_plus {m : Natural} (i : NaturalsBelow(m))
        : NaturalsBelow.value(i) < 1 + m := {
  NaturalsBelow.value(i) < m by NaturalsBelow.below;
  NaturalsBelow.value(i) < m < 1 + m;
  done
}

-- The value-preserving inclusion `NaturalsBelow(m) ↪ NaturalsBelow(1 + m)`.
definition NaturalsBelow.widen {m : Natural} (i : NaturalsBelow(m)) : NaturalsBelow(1 + m) :=
  NaturalsBelow.make(NaturalsBelow.value(i), NaturalsBelow.value_below_one_plus(i))

theorem NaturalsBelow.widen_value {m : Natural} (i : NaturalsBelow(m))
        : NaturalsBelow.value(NaturalsBelow.widen(i)) = NaturalsBelow.value(i) :=
  done

theorem VectorSpace.appendVector_widen {f : Field} {V : VectorSpace(f)} {m : Natural}
        (family : NaturalsBelow(m) → VectorSpace.carrier(V)) (x : VectorSpace.carrier(V))
        (i : NaturalsBelow(m))
        : VectorSpace.appendVector(family, x)(NaturalsBelow.widen(i)) = family(i) := {
  NaturalsBelow.value(NaturalsBelow.widen(i)) < m
      by { NaturalsBelow.value(NaturalsBelow.widen(i)) = NaturalsBelow.value(i) by NaturalsBelow.widen_value;
           NaturalsBelow.value(i) < m by NaturalsBelow.below; done } as widenBelow;
  NaturalsBelow.make(NaturalsBelow.value(NaturalsBelow.widen(i)), widenBelow) = i
      by NaturalsBelow.equal_of_value(a := NaturalsBelow.make(NaturalsBelow.value(NaturalsBelow.widen(i)), widenBelow),
             b := i) as makeEqI;
  VectorSpace.appendVector(family, x)(NaturalsBelow.widen(i))
     = family(NaturalsBelow.make(NaturalsBelow.value(NaturalsBelow.widen(i)), widenBelow))
         by VectorSpace.appendVector_below
     = family(i) by substituting makeEqI;
  done
}

theorem VectorSpace.InSpanOf.append_monotone {f : Field} {V : VectorSpace(f)} {m : Natural}
        (family : NaturalsBelow(m) → VectorSpace.carrier(V)) (x v : VectorSpace.carrier(V))
        (member : VectorSpace.InSpanOf(family, v))
        : VectorSpace.InSpanOf(VectorSpace.appendVector(family, x), v) := {
  choose count, selection, coefficients such that
      v = VectorSpace.linearCombination(family, coefficients, selection, count) from member;
  v = VectorSpace.linearCombination(family, coefficients, selection, count) as vCombo;
  ∀ (i : Natural). i < count →
      coefficients(i) • VectorSpace.appendVector(family, x)(NaturalsBelow.widen(selection(i)))
      = coefficients(i) • family(selection(i))
    by {
      take i : Natural; suppose i < count as iBelow;
      VectorSpace.appendVector(family, x)(NaturalsBelow.widen(selection(i))) = family(selection(i))
          by VectorSpace.appendVector_widen as appAt;
      done by substituting appAt
    };
  v = VectorSpace.linearCombination(family, coefficients, selection, count) by vCombo
    = VectorSpace.linearCombination(VectorSpace.appendVector(family, x), coefficients,
          (i : Natural) ↦ NaturalsBelow.widen(selection(i)), count)
          by VectorSpace.linearCombination_congruence
    as vAppendCombo;
  witness count with witness ((i : Natural) ↦ NaturalsBelow.widen(selection(i)))
      with witness coefficients with vAppendCombo
}

-- Disjunctive span transitivity. When every generator of `inner` is either
-- zero or in the span of `outer`, a whole combination of `inner` is likewise
-- either zero or in the span of `outer`. Because the empty combination lands
-- in the "zero" alternative, this never needs an inhabitant of `outer`'s
-- index — the obstruction that `InSpanOf.transitive` carries. Induction on the
-- combination length: the last term is zero-or-in-span (by the generator
-- hypothesis and scaling), the prefix is zero-or-in-span (by the induction
-- hypothesis), and their sum stays zero-or-in-span in all four combinations.
theorem VectorSpace.InSpanOf.of_combination_covered {f : Field} {V : VectorSpace(f)}
        {I J : Type(0)}
        (inner : I → VectorSpace.carrier(V)) (outer : J → VectorSpace.carrier(V))
        (generatorsCovered :
            ∀ (i : I). inner(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(outer, inner(i)))
        (coefficients : Natural → Field.carrier(f)) (selection : Natural → I)
        : ∀ (count : Natural).
              VectorSpace.linearCombination(inner, coefficients, selection, count) = VectorSpace.zero(V)
              ∨ VectorSpace.InSpanOf(outer,
                    VectorSpace.linearCombination(inner, coefficients, selection, count)) :=
  by induction on count with IH {
    case base: {
        VectorSpace.linearCombination(inner, coefficients, selection, 0) = VectorSpace.zero(V)
            by VectorSpace.linearCombination_zero;
        done
      }
    case step(m): {
        VectorSpace.linearCombination(inner, coefficients, selection, 1 + m)
           = VectorSpace.linearCombination(inner, coefficients, selection, m)
             + coefficients(m) • inner(selection(m))
             by VectorSpace.linearCombination_add_one as peelEq;

        coefficients(m) • inner(selection(m)) = VectorSpace.zero(V)
            ∨ VectorSpace.InSpanOf(outer, coefficients(m) • inner(selection(m)))
          by {
            inner(selection(m)) = VectorSpace.zero(V)
                ∨ VectorSpace.InSpanOf(outer, inner(selection(m))) by generatorsCovered;
            done by cases {
              case inner(selection(m)) = VectorSpace.zero(V) as innerZero: {
                  coefficients(m) • inner(selection(m))
                     = coefficients(m) • VectorSpace.zero(V) by substituting innerZero
                     = VectorSpace.zero(V) by VectorSpace.scale_zero;
                  done
                }
              case VectorSpace.InSpanOf(outer, inner(selection(m))) as innerInSpan: {
                  VectorSpace.InSpanOf(outer, coefficients(m) • inner(selection(m)))
                      by VectorSpace.InSpanOf.scale;
                  done
                }
            }
          } as termCovered;

        VectorSpace.linearCombination(inner, coefficients, selection, m) + coefficients(m) • inner(selection(m))
            = VectorSpace.zero(V)
            ∨ VectorSpace.InSpanOf(outer,
                  VectorSpace.linearCombination(inner, coefficients, selection, m)
                  + coefficients(m) • inner(selection(m)))
          by {
            VectorSpace.linearCombination(inner, coefficients, selection, m) = VectorSpace.zero(V)
                ∨ VectorSpace.InSpanOf(outer, VectorSpace.linearCombination(inner, coefficients, selection, m))
                by IH;
            done by cases {
              case VectorSpace.linearCombination(inner, coefficients, selection, m) = VectorSpace.zero(V)
                  as prefixZero: {
                  coefficients(m) • inner(selection(m)) = VectorSpace.zero(V)
                      ∨ VectorSpace.InSpanOf(outer, coefficients(m) • inner(selection(m))) by termCovered;
                  done by cases {
                    case coefficients(m) • inner(selection(m)) = VectorSpace.zero(V) as termZero: {
                        VectorSpace.linearCombination(inner, coefficients, selection, m)
                              + coefficients(m) • inner(selection(m))
                           = VectorSpace.zero(V) + coefficients(m) • inner(selection(m))
                                 by substituting prefixZero
                           = VectorSpace.zero(V) + VectorSpace.zero(V) by substituting termZero
                           = VectorSpace.zero(V) by VectorSpace.zero_add;
                        done
                      }
                    case VectorSpace.InSpanOf(outer, coefficients(m) • inner(selection(m))) as termInSpan: {
                        VectorSpace.linearCombination(inner, coefficients, selection, m)
                              + coefficients(m) • inner(selection(m))
                           = VectorSpace.zero(V) + coefficients(m) • inner(selection(m))
                                 by substituting prefixZero
                           = coefficients(m) • inner(selection(m)) by VectorSpace.zero_add
                           as sumIsTerm;
                        VectorSpace.InSpanOf(outer,
                            VectorSpace.linearCombination(inner, coefficients, selection, m)
                            + coefficients(m) • inner(selection(m)))
                            by { done by substituting sumIsTerm };
                        done
                      }
                  }
                }
              case VectorSpace.InSpanOf(outer, VectorSpace.linearCombination(inner, coefficients, selection, m))
                  as prefixInSpan: {
                  coefficients(m) • inner(selection(m)) = VectorSpace.zero(V)
                      ∨ VectorSpace.InSpanOf(outer, coefficients(m) • inner(selection(m))) by termCovered;
                  done by cases {
                    case coefficients(m) • inner(selection(m)) = VectorSpace.zero(V) as termZero: {
                        VectorSpace.linearCombination(inner, coefficients, selection, m)
                              + coefficients(m) • inner(selection(m))
                           = VectorSpace.linearCombination(inner, coefficients, selection, m) + VectorSpace.zero(V)
                                 by substituting termZero
                           = VectorSpace.linearCombination(inner, coefficients, selection, m)
                                 by VectorSpace.add_zero
                           as sumIsPrefix;
                        VectorSpace.InSpanOf(outer,
                            VectorSpace.linearCombination(inner, coefficients, selection, m)
                            + coefficients(m) • inner(selection(m)))
                            by { done by substituting sumIsPrefix };
                        done
                      }
                    case VectorSpace.InSpanOf(outer, coefficients(m) • inner(selection(m))) as termInSpan: {
                        VectorSpace.InSpanOf(outer,
                            VectorSpace.linearCombination(inner, coefficients, selection, m)
                            + coefficients(m) • inner(selection(m)))
                            by VectorSpace.InSpanOf.add;
                        done
                      }
                  }
                }
            }
          };
        done by substituting peelEq
      }
  }

-- A family covers a spanning family — each generator is zero or in its span —
-- then it spans the whole space. The zero vector goes to `Spans`' own zero
-- alternative; a nonzero vector is a combination of `inner`, carried into
-- `outer`'s span by the disjunctive transitivity above.
theorem VectorSpace.Spans.transitive_covered {f : Field} {V : VectorSpace(f)} {I J : Type(0)}
        (inner : I → VectorSpace.carrier(V)) (outer : J → VectorSpace.carrier(V))
        (innerSpans : VectorSpace.Spans(inner))
        (generatorsCovered :
            ∀ (i : I). inner(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(outer, inner(i)))
        : VectorSpace.Spans(outer) := {
  take v : VectorSpace.carrier(V);
  v = VectorSpace.zero(V)
      ∨ (∃ (count : Natural). ∃ (selection : Natural → I). ∃ (coefficients : Natural → Field.carrier(f)).
             v = VectorSpace.linearCombination(inner, coefficients, selection, count))
      by innerSpans;
  done by cases {
    case v = VectorSpace.zero(V) as vZero: { done }
    case ∃ (count : Natural). ∃ (selection : Natural → I). ∃ (coefficients : Natural → Field.carrier(f)).
           v = VectorSpace.linearCombination(inner, coefficients, selection, count) as vCombo: {
        choose count, selection, coefficients such that
            v = VectorSpace.linearCombination(inner, coefficients, selection, count) as vIsCombo from vCombo;
        VectorSpace.linearCombination(inner, coefficients, selection, count) = VectorSpace.zero(V)
            ∨ VectorSpace.InSpanOf(outer, VectorSpace.linearCombination(inner, coefficients, selection, count))
            by VectorSpace.InSpanOf.of_combination_covered;
        done by cases {
          case VectorSpace.linearCombination(inner, coefficients, selection, count) = VectorSpace.zero(V)
              as combZero: {
              v = VectorSpace.linearCombination(inner, coefficients, selection, count) by vIsCombo
                = VectorSpace.zero(V) by combZero;
              done
            }
          case VectorSpace.InSpanOf(outer, VectorSpace.linearCombination(inner, coefficients, selection, count))
              as combInSpan: {
              VectorSpace.InSpanOf(outer, v) by { done by substituting vIsCombo };
              done
            }
        }
      }
  }
}

-- ----------------------------------------------------------------------
-- Brick 4 — basis extension. An independent family `e` extends to a basis of
-- a finite-dimensional `V`, agreeing with `e` on its first `k` indices.
--
-- Sift a spanning family `s` of `V` one vector at a time. The running family
-- `ext` starts as `e` and grows only when the next `s`-vector lies outside its
-- span (`appendVector` + the append lemma keep it independent); otherwise `ext`
-- is untouched and the `InSpanOf` facts already collected carry forward under
-- `append_monotone`. The invariant: `ext` is independent, agrees with `e`
-- wherever indices match values, and covers every `s`-vector processed so far.
-- After all of `s` is processed, `ext` covers a spanning family, so it spans.

theorem Natural.one_plus_add (a b : Natural) : 1 + (a + b) = a + (1 + b) := ring

theorem VectorSpace.sift_extend_aux {f : Field} {V : VectorSpace(f)} {k d : Natural}
        (e : NaturalsBelow(k) → VectorSpace.carrier(V))
        (eIndependent : VectorSpace.LinearlyIndependent(e))
        (s : NaturalsBelow(d) → VectorSpace.carrier(V))
        : ∀ (n : Natural). n ≤ d →
              ∃ (sz : Natural). ∃ (r : Natural). ∃ (ext : NaturalsBelow(sz) → VectorSpace.carrier(V)).
                  sz = k + r
                  ∧ VectorSpace.LinearlyIndependent(ext)
                  ∧ (∀ (i : NaturalsBelow(sz)). ∀ (j : NaturalsBelow(k)).
                        NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext(i) = e(j))
                  ∧ (∀ (i : NaturalsBelow(d)). NaturalsBelow.value(i) < n
                        → s(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext, s(i))) :=
  by induction on n with IH {
    case base: {
        suppose 0 ≤ d as zeroBound;
        k = k + 0 by Natural.add_zero as szEq;
        ∀ (i : NaturalsBelow(k)). ∀ (j : NaturalsBelow(k)).
            NaturalsBelow.value(i) = NaturalsBelow.value(j) → e(i) = e(j)
          by { take i : NaturalsBelow(k); take j : NaturalsBelow(k);
               suppose NaturalsBelow.value(i) = NaturalsBelow.value(j) as valEq;
               i = j by NaturalsBelow.equal_of_value(a := i, b := j);
               done by substituting (i = j) } as prefixAgree;
        ∀ (i : NaturalsBelow(d)). NaturalsBelow.value(i) < 0
            → s(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(e, s(i))
          by { take i : NaturalsBelow(d); suppose NaturalsBelow.value(i) < 0 as belowZero;
               ¬(NaturalsBelow.value(i) < 0) by Natural.not_less_than_zero; done } as coveredAgree;
        k = k + 0
            ∧ VectorSpace.LinearlyIndependent(e)
            ∧ (∀ (i : NaturalsBelow(k)). ∀ (j : NaturalsBelow(k)).
                  NaturalsBelow.value(i) = NaturalsBelow.value(j) → e(i) = e(j))
            ∧ (∀ (i : NaturalsBelow(d)). NaturalsBelow.value(i) < 0
                  → s(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(e, s(i)))
          by { szEq; eIndependent; prefixAgree; coveredAgree; done } as bundle;
        witness k with witness 0 with witness e with bundle
      }
    case step(n0): {
        suppose 1 + n0 ≤ d as stepBound;
        n0 ≤ d by { n0 ≤ 1 + n0 by Natural.less_or_equal_add_left;
                    n0 ≤ 1 + n0 ≤ d; done } as n0LeD;
        n0 < d by Natural.lt_of_add_one_le as n0LtD;
        let sn0 : VectorSpace.carrier(V) := s(NaturalsBelow.make(n0, n0LtD));

        ∃ (sz : Natural). ∃ (r : Natural). ∃ (ext : NaturalsBelow(sz) → VectorSpace.carrier(V)).
            sz = k + r
            ∧ VectorSpace.LinearlyIndependent(ext)
            ∧ (∀ (i : NaturalsBelow(sz)). ∀ (j : NaturalsBelow(k)).
                  NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext(i) = e(j))
            ∧ (∀ (i : NaturalsBelow(d)). NaturalsBelow.value(i) < n0
                  → s(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext, s(i)))
            by IH(n0LeD) as prevExists;
        choose sz0, r0, ext0 such that
            sz0 = k + r0
            ∧ VectorSpace.LinearlyIndependent(ext0)
            ∧ (∀ (i : NaturalsBelow(sz0)). ∀ (j : NaturalsBelow(k)).
                  NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext0(i) = e(j))
            ∧ (∀ (i : NaturalsBelow(d)). NaturalsBelow.value(i) < n0
                  → s(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext0, s(i)))
            from prevExists;
        sz0 = k + r0 as sz0Eq;
        VectorSpace.LinearlyIndependent(ext0) as ext0Indep;
        ∀ (i : NaturalsBelow(sz0)). ∀ (j : NaturalsBelow(k)).
            NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext0(i) = e(j) as ext0Prefix;
        ∀ (i : NaturalsBelow(d)). NaturalsBelow.value(i) < n0
            → s(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext0, s(i)) as ext0Covered;
        k ≤ sz0 by { k ≤ k + r0 by Natural.less_or_equal_add_right;
                     done by substituting sz0Eq };

        (sn0 = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext0, sn0))
            ∨ ¬(sn0 = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext0, sn0))
            by Logic.excluded_middle;
        done by cases {
          case sn0 = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext0, sn0) as sn0Covered: {
              ∀ (i : NaturalsBelow(d)). NaturalsBelow.value(i) < 1 + n0
                  → s(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext0, s(i))
                by {
                  take i : NaturalsBelow(d);
                  suppose NaturalsBelow.value(i) < 1 + n0 as iBound;
                  NaturalsBelow.value(i) = n0 ∨ NaturalsBelow.value(i) ≠ n0 by Logic.excluded_middle;
                  done by cases {
                    case NaturalsBelow.value(i) = n0 as iAtN0: {
                        i = NaturalsBelow.make(n0, n0LtD)
                            by NaturalsBelow.equal_of_value(a := i, b := NaturalsBelow.make(n0, n0LtD));
                        s(i) = s(NaturalsBelow.make(n0, n0LtD)) by substituting (i = NaturalsBelow.make(n0, n0LtD))
                           = sn0 as siIsSn0;
                        sn0 = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext0, sn0) by sn0Covered;
                        done by substituting siIsSn0
                      }
                    case NaturalsBelow.value(i) ≠ n0 as iNeN0: {
                        NaturalsBelow.value(i) ≤ n0 by Natural.le_of_lt_one_plus;
                        NaturalsBelow.value(i) < n0 by Natural.lt_of_le_of_ne;
                        done by ext0Covered(i)
                      }
                  }
                } as keepCovered;
              sz0 = k + r0
                  ∧ VectorSpace.LinearlyIndependent(ext0)
                  ∧ (∀ (i : NaturalsBelow(sz0)). ∀ (j : NaturalsBelow(k)).
                        NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext0(i) = e(j))
                  ∧ (∀ (i : NaturalsBelow(d)). NaturalsBelow.value(i) < 1 + n0
                        → s(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext0, s(i)))
                by { sz0Eq; ext0Indep; ext0Prefix; keepCovered; done } as bundle;
              witness sz0 with witness r0 with witness ext0 with bundle
            }
          case ¬(sn0 = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext0, sn0)) as sn0Outside: {
              let ext1 : NaturalsBelow(1 + sz0) → VectorSpace.carrier(V) :=
                  VectorSpace.appendVector(ext0, sn0);
              VectorSpace.LinearlyIndependent(ext1)
                  by VectorSpace.independent_append_outside_span(ext0, sn0, ext0Indep, sn0Outside)
                  as ext1Indep;
              1 + sz0 = k + (1 + r0)
                  by { 1 + sz0 = 1 + (k + r0) by substituting sz0Eq
                         = k + (1 + r0) by Natural.one_plus_add; done } as sz1Eq;

              ∀ (i : NaturalsBelow(1 + sz0)). ∀ (j : NaturalsBelow(k)).
                  NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext1(i) = e(j)
                by {
                  take i : NaturalsBelow(1 + sz0); take j : NaturalsBelow(k);
                  suppose NaturalsBelow.value(i) = NaturalsBelow.value(j) as valEq;
                  NaturalsBelow.value(j) < k by NaturalsBelow.below;
                  NaturalsBelow.value(i) < k by substituting valEq;
                  NaturalsBelow.value(i) < sz0 by { NaturalsBelow.value(i) < k ≤ sz0; done } as iBelowSz0;
                  ext1(i) = ext0(NaturalsBelow.make(NaturalsBelow.value(i), iBelowSz0))
                      by VectorSpace.appendVector_below as ext1At;
                  NaturalsBelow.value(NaturalsBelow.make(NaturalsBelow.value(i), iBelowSz0))
                      = NaturalsBelow.value(j) by valEq;
                  ext0(NaturalsBelow.make(NaturalsBelow.value(i), iBelowSz0)) = e(j)
                      by ext0Prefix(NaturalsBelow.make(NaturalsBelow.value(i), iBelowSz0), j) as ext0AtEqEj;
                  ext1(i) = ext0(NaturalsBelow.make(NaturalsBelow.value(i), iBelowSz0)) by ext1At
                     = e(j) by ext0AtEqEj;
                  done
                } as ext1Prefix;

              ∀ (i : NaturalsBelow(d)). NaturalsBelow.value(i) < 1 + n0
                  → s(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext1, s(i))
                by {
                  take i : NaturalsBelow(d);
                  suppose NaturalsBelow.value(i) < 1 + n0 as iBound;
                  NaturalsBelow.value(i) = n0 ∨ NaturalsBelow.value(i) ≠ n0 by Logic.excluded_middle;
                  done by cases {
                    case NaturalsBelow.value(i) = n0 as iAtN0: {
                        i = NaturalsBelow.make(n0, n0LtD)
                            by NaturalsBelow.equal_of_value(a := i, b := NaturalsBelow.make(n0, n0LtD));
                        s(i) = s(NaturalsBelow.make(n0, n0LtD)) by substituting (i = NaturalsBelow.make(n0, n0LtD))
                           = sn0 as siIsSn0;
                        sz0 < 1 + sz0 by Natural.lt_one_plus as lastBelow;
                        VectorSpace.appendVector(ext0, sn0)(NaturalsBelow.make(sz0, lastBelow)) = sn0
                            by VectorSpace.appendVector_last(atLast := reflexivity(sz0)) as lastIsSn0;
                        VectorSpace.InSpanOf(ext1, VectorSpace.appendVector(ext0, sn0)(NaturalsBelow.make(sz0, lastBelow)))
                            by VectorSpace.InSpanOf.member;
                        VectorSpace.InSpanOf(ext1, sn0) by substituting lastIsSn0;
                        VectorSpace.InSpanOf(ext1, s(i)) by substituting siIsSn0;
                        done
                      }
                    case NaturalsBelow.value(i) ≠ n0 as iNeN0: {
                        NaturalsBelow.value(i) ≤ n0 by Natural.le_of_lt_one_plus;
                        NaturalsBelow.value(i) < n0 by Natural.lt_of_le_of_ne;
                        s(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext0, s(i)) by ext0Covered(i);
                        done by cases {
                          case s(i) = VectorSpace.zero(V) as siZero: { done }
                          case VectorSpace.InSpanOf(ext0, s(i)) as siInExt0: {
                              VectorSpace.InSpanOf(ext1, s(i)) by VectorSpace.InSpanOf.append_monotone;
                              done
                            }
                        }
                      }
                  }
                } as appendCovered;

              1 + sz0 = k + (1 + r0)
                  ∧ VectorSpace.LinearlyIndependent(ext1)
                  ∧ (∀ (i : NaturalsBelow(1 + sz0)). ∀ (j : NaturalsBelow(k)).
                        NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext1(i) = e(j))
                  ∧ (∀ (i : NaturalsBelow(d)). NaturalsBelow.value(i) < 1 + n0
                        → s(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext1, s(i)))
                by { sz1Eq; ext1Indep; ext1Prefix; appendCovered; done } as bundle;
              witness (1 + sz0) with witness (1 + r0) with witness ext1 with bundle
            }
        }
      }
  }

-- The extension itself: an independent family in a finite-dimensional space
-- extends to a basis. Sift a basis of `V` through `sift_extend_aux`; every
-- basis vector ends up covered by the result, so the disjunctive transitivity
-- makes it span. It is already independent, hence a basis, and the sift never
-- disturbs the `e`-prefix. The size is `k + r` — `e`'s `k` vectors followed by
-- the `r` appended ones — which the count in brick 5 reads off.
theorem VectorSpace.extend_to_basis {f : Field} {V : VectorSpace(f)} {k : Natural}
        (e : NaturalsBelow(k) → VectorSpace.carrier(V))
        (eIndependent : VectorSpace.LinearlyIndependent(e))
        (finiteV : VectorSpace.FiniteDimensional(V))
        : ∃ (sz : Natural). ∃ (r : Natural). ∃ (ext : NaturalsBelow(sz) → VectorSpace.carrier(V)).
              sz = k + r
              ∧ VectorSpace.IsBasis(ext)
              ∧ (∀ (i : NaturalsBelow(sz)). ∀ (j : NaturalsBelow(k)).
                    NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext(i) = e(j)) := {
  let d : Natural := VectorSpace.dimension(V, finiteV);
  VectorSpace.HasDimension(V, d) by VectorSpace.dimension_has_basis as vHasBasis;
  choose basisV such that VectorSpace.IsBasis(basisV) from vHasBasis;
  VectorSpace.Spans(basisV) by VectorSpace.IsBasis.spans as basisSpans;
  d ≤ d by Natural.LessOrEqual.reflexive as dLeD;
  ∃ (sz : Natural). ∃ (r : Natural). ∃ (ext : NaturalsBelow(sz) → VectorSpace.carrier(V)).
      sz = k + r
      ∧ VectorSpace.LinearlyIndependent(ext)
      ∧ (∀ (i : NaturalsBelow(sz)). ∀ (j : NaturalsBelow(k)).
            NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext(i) = e(j))
      ∧ (∀ (i : NaturalsBelow(d)). NaturalsBelow.value(i) < d
            → basisV(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext, basisV(i)))
      by VectorSpace.sift_extend_aux(e, eIndependent, basisV, d, dLeD) as extExists;
  choose sz, r, ext such that
      sz = k + r
      ∧ VectorSpace.LinearlyIndependent(ext)
      ∧ (∀ (i : NaturalsBelow(sz)). ∀ (j : NaturalsBelow(k)).
            NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext(i) = e(j))
      ∧ (∀ (i : NaturalsBelow(d)). NaturalsBelow.value(i) < d
            → basisV(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext, basisV(i)))
      from extExists;
  sz = k + r as szEq;
  VectorSpace.LinearlyIndependent(ext) as extIndep;
  ∀ (i : NaturalsBelow(sz)). ∀ (j : NaturalsBelow(k)).
      NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext(i) = e(j) as extPrefix;
  ∀ (i : NaturalsBelow(d)). NaturalsBelow.value(i) < d
      → basisV(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext, basisV(i)) as extCovered;
  ∀ (i : NaturalsBelow(d)). basisV(i) = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext, basisV(i))
    by { take i : NaturalsBelow(d); NaturalsBelow.value(i) < d by NaturalsBelow.below;
         done by extCovered(i) } as coveredAll;
  VectorSpace.Spans(ext)
      by VectorSpace.Spans.transitive_covered(basisV, ext, basisSpans, coveredAll) as extSpans;
  VectorSpace.IsBasis(ext)
      by { VectorSpace.LinearlyIndependent(ext) by extIndep;
           VectorSpace.Spans(ext) by extSpans; done } as extBasis;
  sz = k + r
      ∧ VectorSpace.IsBasis(ext)
      ∧ (∀ (i : NaturalsBelow(sz)). ∀ (j : NaturalsBelow(k)).
            NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext(i) = e(j))
    by { szEq; extBasis; extPrefix; done } as bundle;
  witness sz with witness r with witness ext with bundle
}

-- ----------------------------------------------------------------------
-- Brick 5 — the count. The images of the appended vectors form a basis of the
-- image, so the number appended equals `dim(im T)`, and `dim V = k + r`
-- becomes `dim(ker T) + dim(im T)`.

-- A subspace family that spans carries the value transport of that spanning:
-- every subspace vector's value is zero or a `V`-combination of the family
-- values. The forward companion of `spans_of_value_covered`.
theorem Subspace.spanning_value_covered {f : Field} {V : VectorSpace(f)} {I : Type(0)}
        (subset : Set(VectorSpace.carrier(V))) (subspace : IsSubspace(V, subset))
        (family : I → VectorSpace.carrier(Subspace.vector_space(V, subset, subspace)))
        (spanning : VectorSpace.Spans(family))
        : ∀ (x : VectorSpace.carrier(Subspace.vector_space(V, subset, subspace))).
              Subtype.value(x) = VectorSpace.zero(V)
              ∨ VectorSpace.InSpanOf((i : I) ↦ Subtype.value(family(i)), Subtype.value(x)) := {
  take x : VectorSpace.carrier(Subspace.vector_space(V, subset, subspace));
  x = VectorSpace.zero(Subspace.vector_space(V, subset, subspace))
      ∨ (∃ (count : Natural). ∃ (selection : Natural → I). ∃ (coefficients : Natural → Field.carrier(f)).
             x = VectorSpace.linearCombination(family, coefficients, selection, count))
      by spanning;
  done by cases {
    case x = VectorSpace.zero(Subspace.vector_space(V, subset, subspace)) as xZero: {
        Subtype.value(x) = Subtype.value(VectorSpace.zero(Subspace.vector_space(V, subset, subspace)))
               by substituting xZero
           = VectorSpace.zero(V);
        done
      }
    case ∃ (count : Natural). ∃ (selection : Natural → I). ∃ (coefficients : Natural → Field.carrier(f)).
           x = VectorSpace.linearCombination(family, coefficients, selection, count) as xInSpan: {
        choose count, selection, coefficients such that
            x = VectorSpace.linearCombination(family, coefficients, selection, count) as xIsCombo from xInSpan;
        Subtype.value(x)
           = Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, count))
                 by substituting xIsCombo
           = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)), coefficients, selection, count)
                 by Subspace.linearCombination_value as valEq;
        VectorSpace.InSpanOf((i : I) ↦ Subtype.value(family(i)), Subtype.value(x))
            by { witness count with witness selection with witness coefficients with valEq };
        done
      }
  }
}

theorem Natural.lt_of_add_left_lt (a x y : Natural) (h : a + x < a + y) : x < y := {
  a + (x + 1) = (a + x) + 1 by ring
     ≤ a + y by Natural.add_one_le_of_lt;
  x + 1 ≤ y by Natural.add_left_le_cancel;
  done by Natural.lt_of_add_one_le
}

-- The images of the appended vectors span the image. Every image element is
-- `T(v)` with `v` a combination of the basis `ext`; `T` distributes over that
-- combination, and each `T(ext(i))` is either zero (the `e`-prefix, which lies
-- in the kernel) or one of the `T(aFamily(j))` (the appended suffix). The
-- disjunctive `of_combination_covered` carries that over the whole sum.
theorem LinearMap.appended_images_span {f : Field} {V W : VectorSpace(f)} {k r sz : Natural}
        (T : VectorSpace.carrier(V) → VectorSpace.carrier(W)) (linear : IsLinearMap(V, W, T))
        (e : NaturalsBelow(k) → VectorSpace.carrier(V))
        (ext : NaturalsBelow(sz) → VectorSpace.carrier(V))
        (aFamily : NaturalsBelow(r) → VectorSpace.carrier(V))
        (imgSub : IsSubspace(W, LinearMap.image(V, W, T)))
        (TaFamily : NaturalsBelow(r) → VectorSpace.carrier(Subspace.vector_space(W, LinearMap.image(V, W, T), imgSub)))
        (taValue : ∀ (j : NaturalsBelow(r)). Subtype.value(TaFamily(j)) = T(aFamily(j)))
        (szEq : sz = k + r)
        (extSpans : VectorSpace.Spans(ext))
        (eKernel : ∀ (i : NaturalsBelow(k)). T(e(i)) = VectorSpace.zero(W))
        (extPrefix : ∀ (i : NaturalsBelow(sz)). ∀ (j : NaturalsBelow(k)).
            NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext(i) = e(j))
        (extSuffix : ∀ (i : NaturalsBelow(sz)). ∀ (j : NaturalsBelow(r)).
            NaturalsBelow.value(i) = k + NaturalsBelow.value(j) → ext(i) = aFamily(j))
        : VectorSpace.Spans(TaFamily) := {

  ∀ (i : NaturalsBelow(sz)).
      T(ext(i)) = VectorSpace.zero(W)
      ∨ VectorSpace.InSpanOf((j : NaturalsBelow(r)) ↦ T(aFamily(j)), T(ext(i)))
    by {
      take i : NaturalsBelow(sz);
      NaturalsBelow.value(i) < k ∨ k ≤ NaturalsBelow.value(i) by Natural.lt_or_le;
      done by cases {
        case NaturalsBelow.value(i) < k as iBelow: {
            NaturalsBelow.value(i) = NaturalsBelow.value(NaturalsBelow.make(NaturalsBelow.value(i), iBelow));
            ext(i) = e(NaturalsBelow.make(NaturalsBelow.value(i), iBelow))
                by extPrefix(i, NaturalsBelow.make(NaturalsBelow.value(i), iBelow)) as extAtI;
            T(ext(i)) = T(e(NaturalsBelow.make(NaturalsBelow.value(i), iBelow))) by substituting extAtI
               = VectorSpace.zero(W) by eKernel(NaturalsBelow.make(NaturalsBelow.value(i), iBelow));
            done
          }
        case k ≤ NaturalsBelow.value(i) as iAtLeast: {
            NaturalsBelow.value(i) = k + (NaturalsBelow.value(i) ∸ k)
                by NaturalsBelow.decompose_at_least(k, NaturalsBelow.value(i)) as decomp;
            NaturalsBelow.value(i) < sz by NaturalsBelow.below;
            k + (NaturalsBelow.value(i) ∸ k) < sz by substituting decomp;
            k + (NaturalsBelow.value(i) ∸ k) < k + r by substituting szEq;
            (NaturalsBelow.value(i) ∸ k) < r by Natural.lt_of_add_left_lt as qBelow;
            NaturalsBelow.value(i)
                = k + NaturalsBelow.value(NaturalsBelow.make(NaturalsBelow.value(i) ∸ k, qBelow))
                by decomp as valMatch;
            ext(i) = aFamily(NaturalsBelow.make(NaturalsBelow.value(i) ∸ k, qBelow))
                by extSuffix(i, NaturalsBelow.make(NaturalsBelow.value(i) ∸ k, qBelow), valMatch)
                as extAtI;
            VectorSpace.InSpanOf((j : NaturalsBelow(r)) ↦ T(aFamily(j)),
                T(aFamily(NaturalsBelow.make(NaturalsBelow.value(i) ∸ k, qBelow))))
                by VectorSpace.InSpanOf.member((j : NaturalsBelow(r)) ↦ T(aFamily(j)),
                       NaturalsBelow.make(NaturalsBelow.value(i) ∸ k, qBelow));
            T(ext(i)) = T(aFamily(NaturalsBelow.make(NaturalsBelow.value(i) ∸ k, qBelow)))
                by substituting extAtI;
            VectorSpace.InSpanOf((j : NaturalsBelow(r)) ↦ T(aFamily(j)), T(ext(i)))
                by substituting (T(ext(i)) = T(aFamily(NaturalsBelow.make(NaturalsBelow.value(i) ∸ k, qBelow))));
            done
          }
      }
    };

  ∀ (x : VectorSpace.carrier(Subspace.vector_space(W, LinearMap.image(V, W, T), imgSub))).
      Subtype.value(x) = VectorSpace.zero(W)
      ∨ VectorSpace.InSpanOf((j : NaturalsBelow(r)) ↦ T(aFamily(j)), Subtype.value(x))
    by {
      take x : VectorSpace.carrier(Subspace.vector_space(W, LinearMap.image(V, W, T), imgSub));
      Subtype.value(x) ∈ LinearMap.image(V, W, T) by Subtype.property;
      ∃ (v : VectorSpace.carrier(V)). T(v) = Subtype.value(x);
      choose v such that T(v) = Subtype.value(x) as vHits;
      v = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(ext, v) by extSpans;
      done by cases {
        case v = VectorSpace.zero(V) as vZero: {
            Subtype.value(x) = T(v) by vHits
               = T(VectorSpace.zero(V)) by substituting vZero
               = VectorSpace.zero(W) by LinearMap.preserves_zero;
            done
          }
        case VectorSpace.InSpanOf(ext, v) as vInSpan: {
            choose count, selection, coefficients such that
                v = VectorSpace.linearCombination(ext, coefficients, selection, count) as vCombo from vInSpan;
            T(v) = T(VectorSpace.linearCombination(ext, coefficients, selection, count)) by substituting vCombo
               = VectorSpace.linearCombination((i : NaturalsBelow(sz)) ↦ T(ext(i)), coefficients, selection, count)
                     by LinearMap.apply_linearCombination(linear, ext, coefficients, selection, count)
               as tvEq;
            VectorSpace.linearCombination((i : NaturalsBelow(sz)) ↦ T(ext(i)), coefficients, selection, count)
                = VectorSpace.zero(W)
                ∨ VectorSpace.InSpanOf((j : NaturalsBelow(r)) ↦ T(aFamily(j)),
                      VectorSpace.linearCombination((i : NaturalsBelow(sz)) ↦ T(ext(i)),
                          coefficients, selection, count))
                by VectorSpace.InSpanOf.of_combination_covered;
            done by cases {
              case VectorSpace.linearCombination((i : NaturalsBelow(sz)) ↦ T(ext(i)), coefficients, selection, count)
                     = VectorSpace.zero(W) as combZero: {
                  Subtype.value(x) = T(v) by vHits
                     = VectorSpace.linearCombination((i : NaturalsBelow(sz)) ↦ T(ext(i)), coefficients, selection, count)
                           by tvEq
                     = VectorSpace.zero(W) by combZero;
                  done
                }
              case VectorSpace.InSpanOf((j : NaturalsBelow(r)) ↦ T(aFamily(j)),
                     VectorSpace.linearCombination((i : NaturalsBelow(sz)) ↦ T(ext(i)),
                         coefficients, selection, count)) as combInSpan: {
                  Subtype.value(x) = T(v) by vHits
                     = VectorSpace.linearCombination((i : NaturalsBelow(sz)) ↦ T(ext(i)), coefficients, selection, count)
                           by tvEq
                     as vxEq;
                  VectorSpace.InSpanOf((j : NaturalsBelow(r)) ↦ T(aFamily(j)), Subtype.value(x))
                      by { done by substituting vxEq };
                  done
                }
            }
          }
      }
    } as coveredFact;

  VectorSpace.Spans(TaFamily)
    by {
  take x : VectorSpace.carrier(Subspace.vector_space(W, LinearMap.image(V, W, T), imgSub));
  x = VectorSpace.zero(Subspace.vector_space(W, LinearMap.image(V, W, T), imgSub))
      ∨ VectorSpace.InSpanOf(TaFamily, x)
    by {
  Subtype.value(x) = VectorSpace.zero(W)
      ∨ VectorSpace.InSpanOf((j : NaturalsBelow(r)) ↦ T(aFamily(j)), Subtype.value(x)) by coveredFact;
  done by cases {
    case Subtype.value(x) = VectorSpace.zero(W) as valueZero: {
        Subtype.value(x) = VectorSpace.zero(W)
           = Subtype.value(VectorSpace.zero(Subspace.vector_space(W, LinearMap.image(V, W, T), imgSub)));
        x = VectorSpace.zero(Subspace.vector_space(W, LinearMap.image(V, W, T), imgSub))
            by Subtype.equal_of_value_equal;
        done
      }
    case VectorSpace.InSpanOf((j : NaturalsBelow(r)) ↦ T(aFamily(j)), Subtype.value(x)) as valueInSpan: {
        choose count, selection, coefficients such that
            Subtype.value(x) = VectorSpace.linearCombination(
                (j : NaturalsBelow(r)) ↦ T(aFamily(j)), coefficients, selection, count)
            as vxCombo from valueInSpan;
        ∀ (i : Natural). i < count →
            coefficients(i) • Subtype.value(TaFamily(selection(i)))
            = coefficients(i) • T(aFamily(selection(i)))
          by { take i : Natural; suppose i < count as iBelow;
               Subtype.value(TaFamily(selection(i))) = T(aFamily(selection(i))) by taValue as tv;
               done by substituting tv };
        Subtype.value(VectorSpace.linearCombination(TaFamily, coefficients, selection, count))
           = VectorSpace.linearCombination((j : NaturalsBelow(r)) ↦ Subtype.value(TaFamily(j)),
                 coefficients, selection, count)
                 by Subspace.linearCombination_value
           = VectorSpace.linearCombination((j : NaturalsBelow(r)) ↦ T(aFamily(j)), coefficients, selection, count)
                 by VectorSpace.linearCombination_congruence
           as bridgeEq;
        Subtype.value(x)
           = VectorSpace.linearCombination((j : NaturalsBelow(r)) ↦ T(aFamily(j)), coefficients, selection, count)
                 by vxCombo
           = Subtype.value(VectorSpace.linearCombination(TaFamily, coefficients, selection, count)) by bridgeEq;
        x = VectorSpace.linearCombination(TaFamily, coefficients, selection, count)
            by Subtype.equal_of_value_equal as xIsCombination;
        VectorSpace.InSpanOf(TaFamily, x)
            by { witness count with witness selection with witness coefficients with xIsCombination };
        done
      }
  }
    };
  done
  };
  done
}

-- The images of the appended vectors are linearly independent. A vanishing
-- combination `Σ cⱼ T(aⱼ) = 0` pulls back through linearity to `Σ cⱼ aⱼ ∈ ker T`,
-- which lies in the span of the kernel family `e`. Reindexing the appended
-- combination into `ext` (its selection lands in the suffix `[k, sz)`) and the
-- kernel expansion into `ext` in canonical form (identity selection over the
-- prefix `[0, k)` via `linearCombination_standardize`), their difference is a
-- single vanishing combination of `ext` whose selection is injective — the two
-- index ranges are disjoint. Independence of `ext` kills every coefficient, the
-- `cⱼ` among them.
theorem LinearMap.appended_images_independent {f : Field} {V W : VectorSpace(f)} {k r sz : Natural}
        (T : VectorSpace.carrier(V) → VectorSpace.carrier(W)) (linear : IsLinearMap(V, W, T))
        (e : NaturalsBelow(k) → VectorSpace.carrier(V))
        (ext : NaturalsBelow(sz) → VectorSpace.carrier(V))
        (aFamily : NaturalsBelow(r) → VectorSpace.carrier(V))
        (imgSub : IsSubspace(W, LinearMap.image(V, W, T)))
        (TaFamily : NaturalsBelow(r) → VectorSpace.carrier(Subspace.vector_space(W, LinearMap.image(V, W, T), imgSub)))
        (taValue : ∀ (j : NaturalsBelow(r)). Subtype.value(TaFamily(j)) = T(aFamily(j)))
        (szEq : sz = k + r)
        (extIndependent : VectorSpace.LinearlyIndependent(ext))
        (extPrefix : ∀ (i : NaturalsBelow(sz)). ∀ (j : NaturalsBelow(k)).
            NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext(i) = e(j))
        (extSuffix : ∀ (i : NaturalsBelow(sz)). ∀ (j : NaturalsBelow(r)).
            NaturalsBelow.value(i) = k + NaturalsBelow.value(j) → ext(i) = aFamily(j))
        (kerCoverage : ∀ (w : VectorSpace.carrier(V)).
            T(w) = VectorSpace.zero(W) → w = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(e, w))
        : VectorSpace.LinearlyIndependent(TaFamily) := {
  take cnt : Natural;
  take sel : Natural → NaturalsBelow(r);
  take coeff : Natural → Field.carrier(f);
  suppose ∀ (a b : Natural). a < cnt → b < cnt → sel(a) = sel(b) → a = b as selInjective;
  suppose VectorSpace.linearCombination(TaFamily, coeff, sel, cnt)
          = VectorSpace.zero(Subspace.vector_space(W, LinearMap.image(V, W, T), imgSub)) as vanishes;

  -- Pull the vanishing back into `V`: `Σ cⱼ aⱼ` lies in the kernel.
  ∀ (i : Natural). i < cnt →
      coeff(i) • Subtype.value(TaFamily(sel(i))) = coeff(i) • T(aFamily(sel(i)))
    by { take i : Natural; suppose i < cnt as iBelow;
         Subtype.value(TaFamily(sel(i))) = T(aFamily(sel(i))) by taValue as tv;
         done by substituting tv };
  Subtype.value(VectorSpace.linearCombination(TaFamily, coeff, sel, cnt))
     = VectorSpace.linearCombination((j : NaturalsBelow(r)) ↦ Subtype.value(TaFamily(j)), coeff, sel, cnt)
           by Subspace.linearCombination_value
     = VectorSpace.linearCombination((j : NaturalsBelow(r)) ↦ T(aFamily(j)), coeff, sel, cnt)
           by VectorSpace.linearCombination_congruence
     as valueBridge;
  VectorSpace.linearCombination((j : NaturalsBelow(r)) ↦ T(aFamily(j)), coeff, sel, cnt)
     = Subtype.value(VectorSpace.linearCombination(TaFamily, coeff, sel, cnt)) by valueBridge
     = Subtype.value(VectorSpace.zero(Subspace.vector_space(W, LinearMap.image(V, W, T), imgSub)))
           by substituting vanishes
     = VectorSpace.zero(W) as imagesVanish;
  T(VectorSpace.linearCombination(aFamily, coeff, sel, cnt))
     = VectorSpace.linearCombination((j : NaturalsBelow(r)) ↦ T(aFamily(j)), coeff, sel, cnt)
           by LinearMap.apply_linearCombination(linear, aFamily, coeff, sel, cnt)
     = VectorSpace.zero(W) by imagesVanish as combinationInKernel;
  VectorSpace.linearCombination(aFamily, coeff, sel, cnt) = VectorSpace.zero(V)
      ∨ VectorSpace.InSpanOf(e, VectorSpace.linearCombination(aFamily, coeff, sel, cnt))
      by kerCoverage(VectorSpace.linearCombination(aFamily, coeff, sel, cnt), combinationInKernel)
     ;

  take target : Natural;
  suppose target < cnt as targetBelow;

  -- Reindex the appended combination into `ext`: the selection lands in the
  -- suffix `[k, sz)` and is injective there.
  ∀ (i : Natural). i < cnt → k + NaturalsBelow.value(sel(i)) < sz
    by { take i : Natural; suppose i < cnt as iBelow;
         NaturalsBelow.value(sel(i)) < r by NaturalsBelow.below;
         k + NaturalsBelow.value(sel(i)) < k + r by Natural.add_left_strict_monotone;
         done by substituting szEq } as selExtBound;
  let selExtFallback : NaturalsBelow(sz) :=
      NaturalsBelow.make(k + NaturalsBelow.value(sel(target)), selExtBound(target, targetBelow));
  let selExt : Natural → NaturalsBelow(sz) :=
      (i : Natural) ↦ NaturalsBelow.clamp(selExtFallback)(k + NaturalsBelow.value(sel(i)));

  ∀ (i : Natural). i < cnt → NaturalsBelow.value(selExt(i)) = k + NaturalsBelow.value(sel(i))
    by {
      take i : Natural; suppose i < cnt as iBelow;
      k + NaturalsBelow.value(sel(i)) < sz by selExtBound(i, iBelow) as ib;
      selExt(i) = NaturalsBelow.make(k + NaturalsBelow.value(sel(i)), ib)
          by NaturalsBelow.clamp_below(sz, selExtFallback, k + NaturalsBelow.value(sel(i)), ib) as selExtAt;
      NaturalsBelow.value(selExt(i))
         = NaturalsBelow.value(NaturalsBelow.make(k + NaturalsBelow.value(sel(i)), ib)) by selExtAt
         = k + NaturalsBelow.value(sel(i));
      done
    } as selExtValue;

  ∀ (i : Natural). i < cnt →
      coeff(i) • aFamily(sel(i)) = coeff(i) • ext(selExt(i))
    by {
      take i : Natural; suppose i < cnt as iBelow;
      NaturalsBelow.value(selExt(i)) = k + NaturalsBelow.value(sel(i)) by selExtValue(i, iBelow) as sv;
      ext(selExt(i)) = aFamily(sel(i)) by extSuffix(selExt(i), sel(i), sv) as extAt;
      done by substituting extAt
    };
  VectorSpace.linearCombination(aFamily, coeff, sel, cnt)
     = VectorSpace.linearCombination(ext, coeff, selExt, cnt)
           by VectorSpace.linearCombination_congruence as aReindex;

  ∀ (a b : Natural). a < cnt → b < cnt → selExt(a) = selExt(b) → a = b
    by {
      take a : Natural; take b : Natural;
      suppose a < cnt as aBelow; suppose b < cnt as bBelow;
      suppose selExt(a) = selExt(b) as selExtEq;
      k + NaturalsBelow.value(sel(a))
         = NaturalsBelow.value(selExt(a)) by selExtValue(a, aBelow)
         = NaturalsBelow.value(selExt(b)) by substituting selExtEq
         = k + NaturalsBelow.value(sel(b)) by selExtValue(b, bBelow);
      NaturalsBelow.value(sel(a)) = NaturalsBelow.value(sel(b)) by Natural.add_cancel_left;
      sel(a) = sel(b) by NaturalsBelow.equal_of_value(a := sel(a), b := sel(b));
      done by selInjective(a, b, aBelow, bBelow)
    } as selExtInjective;

  done by cases {
    case VectorSpace.linearCombination(aFamily, coeff, sel, cnt) = VectorSpace.zero(V) as combZero: {
        VectorSpace.linearCombination(ext, coeff, selExt, cnt)
           = VectorSpace.linearCombination(aFamily, coeff, sel, cnt) by aReindex
           = VectorSpace.zero(V) by combZero as extCombZero;
        done by extIndependent(cnt, selExt, coeff, selExtInjective, extCombZero)
      }
    case VectorSpace.InSpanOf(e, VectorSpace.linearCombination(aFamily, coeff, sel, cnt)) as combInSpan: {
        0 < sz by { 0 ≤ k + NaturalsBelow.value(sel(target)) < sz
                        by selExtBound(target, targetBelow); done } as szPositive;
        let idEFallback : NaturalsBelow(sz) := NaturalsBelow.make(0, szPositive);
        let idE : Natural → NaturalsBelow(sz) := NaturalsBelow.clamp(idEFallback);
        ∀ (i : Natural). i < sz → NaturalsBelow.value(idE(i)) = i
          by {
            take i : Natural; suppose i < sz as below;
            idE(i) = NaturalsBelow.make(i, below) by NaturalsBelow.clamp_below(sz, idEFallback, i, below) as idEAt;
            NaturalsBelow.value(idE(i)) = NaturalsBelow.value(NaturalsBelow.make(i, below)) by idEAt = i;
            done
          } as idEValue;

        -- Expand the kernel membership canonically over the prefix `[0, k)`.
        choose cntE, selE, cE such that
            VectorSpace.linearCombination(aFamily, coeff, sel, cnt)
            = VectorSpace.linearCombination(e, cE, selE, cntE) as wIsECombo from combInSpan;
        ∀ (i : Natural). k ≤ i → Function.extendBelow(e, VectorSpace.zero(V))(i) = VectorSpace.zero(V)
          by { take i : Natural; suppose k ≤ i as atLeast;
               done by Function.extendBelow_past(past := atLeast) } as eeVanishes;
        ∀ (l : Natural). l < cntE →
            cE(l) • e(selE(l))
            = cE(l) • Function.extendBelow(e, VectorSpace.zero(V))(NaturalsBelow.value(selE(l)))
          by {
            take l : Natural; suppose l < cntE as lBelow;
            NaturalsBelow.value(selE(l)) < k by NaturalsBelow.below as valBelow;
            Function.extendBelow(e, VectorSpace.zero(V))(NaturalsBelow.value(selE(l)))
                = e(NaturalsBelow.make(NaturalsBelow.value(selE(l)), valBelow)) by Function.extendBelow_below
                = e(selE(l)) by NaturalsBelow.equal_of_value as eeAt;
            done by substituting eeAt
          };
        VectorSpace.linearCombination(aFamily, coeff, sel, cnt)
           = VectorSpace.linearCombination(e, cE, selE, cntE) by wIsECombo
           = VectorSpace.linearCombination(Function.extendBelow(e, VectorSpace.zero(V)), cE,
                 (l : Natural) ↦ NaturalsBelow.value(selE(l)), cntE)
                 by VectorSpace.linearCombination_congruence
           as wIsEeCombo;
        ∃ (dPrime : Natural → Field.carrier(f)).
            VectorSpace.linearCombination(Function.extendBelow(e, VectorSpace.zero(V)), cE,
                (l : Natural) ↦ NaturalsBelow.value(selE(l)), cntE)
            = VectorSpace.standardCombination(Function.extendBelow(e, VectorSpace.zero(V)), dPrime, k)
            by VectorSpace.linearCombination_standardize(Function.extendBelow(e, VectorSpace.zero(V)), k,
                   eeVanishes, cE, (l : Natural) ↦ NaturalsBelow.value(selE(l)), cntE)
            as standardizeExists;
        choose dPrime such that
            VectorSpace.linearCombination(Function.extendBelow(e, VectorSpace.zero(V)), cE,
                (l : Natural) ↦ NaturalsBelow.value(selE(l)), cntE)
            = VectorSpace.standardCombination(Function.extendBelow(e, VectorSpace.zero(V)), dPrime, k)
            as wIsStandard from standardizeExists;

        -- Reindex the canonical prefix combination into `ext` (identity into `[0, k)`).
        ∀ (i : Natural). i < k →
            dPrime(i) • Function.extendBelow(e, VectorSpace.zero(V))(i)
            = dPrime(i) • ext(idE(i))
          by {
            take i : Natural; suppose i < k as iBelowK;
            i < sz by { i < k ≤ sz by { k ≤ k + r by Natural.less_or_equal_add_right;
                                        done by substituting szEq }; done } as iBelowSz;
            Function.extendBelow(e, VectorSpace.zero(V))(i) = e(NaturalsBelow.make(i, iBelowK))
                by Function.extendBelow_below as eeAtI;
            NaturalsBelow.value(idE(i)) = NaturalsBelow.value(NaturalsBelow.make(i, iBelowK))
                by idEValue(i, iBelowSz) as idEMatch;
            ext(idE(i)) = e(NaturalsBelow.make(i, iBelowK))
                by extPrefix(idE(i), NaturalsBelow.make(i, iBelowK), idEMatch) as extAtI;
            dPrime(i) • Function.extendBelow(e, VectorSpace.zero(V))(i)
               = dPrime(i) • e(NaturalsBelow.make(i, iBelowK)) by substituting eeAtI
               = dPrime(i) • ext(idE(i)) by substituting extAtI;
            done
          };
        VectorSpace.linearCombination(aFamily, coeff, sel, cnt)
           = VectorSpace.linearCombination(Function.extendBelow(e, VectorSpace.zero(V)), cE,
                 (l : Natural) ↦ NaturalsBelow.value(selE(l)), cntE) by wIsEeCombo
           = VectorSpace.standardCombination(Function.extendBelow(e, VectorSpace.zero(V)), dPrime, k) by wIsStandard
           = VectorSpace.linearCombination(Function.extendBelow(e, VectorSpace.zero(V)), dPrime,
                 (i : Natural) ↦ i, k)
           = VectorSpace.linearCombination(ext, dPrime, idE, k) by VectorSpace.linearCombination_congruence
          ;

        -- Difference of the two `ext`-combinations vanishes; concatenate.
        VectorSpace.negate(VectorSpace.linearCombination(ext, dPrime, idE, k))
           = Field.negate(Field.one(f)) • VectorSpace.linearCombination(ext, dPrime, idE, k)
                 by VectorSpace.negate_one_scale
           = VectorSpace.linearCombination(ext, (i : Natural) ↦ Field.negate(Field.one(f)) * dPrime(i), idE, k)
                 by VectorSpace.linearCombination_scale
           as negatedPrefix;
        VectorSpace.linearCombination(ext, coeff, selExt, cnt)
           + VectorSpace.linearCombination(ext, (i : Natural) ↦ Field.negate(Field.one(f)) * dPrime(i), idE, k)
           = VectorSpace.linearCombination(ext, coeff, selExt, cnt)
             + VectorSpace.negate(VectorSpace.linearCombination(ext, dPrime, idE, k)) by negatedPrefix
           = VectorSpace.linearCombination(aFamily, coeff, sel, cnt)
             + VectorSpace.negate(VectorSpace.linearCombination(aFamily, coeff, sel, cnt))
                 by substituting aReindex
           = VectorSpace.zero(V) by VectorSpace.add_negate_right
           as combinedVanishesRaw;
        VectorSpace.linearCombination(ext, coeff, selExt, cnt)
           + VectorSpace.linearCombination(ext, (i : Natural) ↦ Field.negate(Field.one(f)) * dPrime(i), idE, k)
           = VectorSpace.linearCombination(ext,
                 VectorSpace.combineFunctions(coeff, (i : Natural) ↦ Field.negate(Field.one(f)) * dPrime(i), cnt),
                 VectorSpace.combineFunctions(selExt, idE, cnt), cnt + k)
                 by VectorSpace.linearCombination_concatenate as concatEq;
        VectorSpace.linearCombination(ext,
              VectorSpace.combineFunctions(coeff, (i : Natural) ↦ Field.negate(Field.one(f)) * dPrime(i), cnt),
              VectorSpace.combineFunctions(selExt, idE, cnt), cnt + k)
           = VectorSpace.linearCombination(ext, coeff, selExt, cnt)
             + VectorSpace.linearCombination(ext, (i : Natural) ↦ Field.negate(Field.one(f)) * dPrime(i), idE, k)
                 by concatEq
           = VectorSpace.zero(V) by combinedVanishesRaw as combinedVanishes;

        -- The concatenated selection lands in `[k, sz)` on the front block
        -- (the `selExt` values) and in `[0, k)` on the back block (the `idE`
        -- values), read off through `combineFunctions`.
        ∀ (x : Natural). x < cnt →
            NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(x))
            = k + NaturalsBelow.value(sel(x))
          by {
            take x : Natural; suppose x < cnt as xFront;
            NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(x))
               = NaturalsBelow.value(selExt(x)) by VectorSpace.combineFunctions_below
               = k + NaturalsBelow.value(sel(x)) by selExtValue(x, xFront);
            done
          } as frontValue;
        ∀ (x : Natural). cnt ≤ x → x < cnt + k →
            NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(x)) = x ∸ cnt
          by {
            take x : Natural; suppose cnt ≤ x as xGe; suppose x < cnt + k as xLt;
            x = cnt + (x ∸ cnt) by NaturalsBelow.decompose_at_least(cnt, x, xGe) as xDecomp;
            (x ∸ cnt) < k
                by { cnt + (x ∸ cnt) < cnt + k by substituting xDecomp;
                     done by Natural.lt_of_add_left_lt };
            (x ∸ cnt) < sz
                by { (x ∸ cnt) < k ≤ sz
                         by { k ≤ k + r by Natural.less_or_equal_add_right; done by substituting szEq };
                     done } as monusBelowSz;
            NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(x))
               = NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(cnt + (x ∸ cnt)))
                     by substituting xDecomp
               = NaturalsBelow.value(idE(x ∸ cnt)) by VectorSpace.combineFunctions_shifted
               = x ∸ cnt by idEValue(x ∸ cnt, monusBelowSz);
            done
          } as backValue;

        -- Hence the concatenated selection is injective: front and back values
        -- never coincide (front `≥ k`, back `< k`), so a shared value forces the
        -- same block, where `selExt`/`idE` are each injective.
        ∀ (a b : Natural). a < cnt + k → b < cnt + k →
            VectorSpace.combineFunctions(selExt, idE, cnt)(a)
            = VectorSpace.combineFunctions(selExt, idE, cnt)(b) → a = b
          by {
            take a : Natural; take b : Natural;
            suppose a < cnt + k as aBelow; suppose b < cnt + k as bBelow;
            suppose VectorSpace.combineFunctions(selExt, idE, cnt)(a)
                    = VectorSpace.combineFunctions(selExt, idE, cnt)(b) as combSelEq;
            NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(a))
                = NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(b))
                by substituting combSelEq as valEq;
            done by cases {
              case a < cnt as aFront: {
                  NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(a)) = k + NaturalsBelow.value(sel(a))
                      by frontValue(a, aFront) as aVal;
                  done by cases {
                    case b < cnt as bFront: {
                        NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(b)) = k + NaturalsBelow.value(sel(b))
                            by frontValue(b, bFront) as bVal;
                        k + NaturalsBelow.value(sel(a))
                           = NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(a)) by aVal
                           = NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(b)) by valEq
                           = k + NaturalsBelow.value(sel(b)) by bVal;
                        NaturalsBelow.value(sel(a)) = NaturalsBelow.value(sel(b)) by Natural.add_cancel_left;
                        sel(a) = sel(b) by NaturalsBelow.equal_of_value(a := sel(a), b := sel(b));
                        done by selInjective(a, b, aFront, bFront)
                      }
                    case ¬(b < cnt) as bBack: {
                        cnt ≤ b by Natural.less_or_equal_of_not_less_than as bGe;
                        NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(b)) = b ∸ cnt
                            by backValue(b, bGe, bBelow) as bVal;
                        (b ∸ cnt) < k
                            by { b = cnt + (b ∸ cnt) by NaturalsBelow.decompose_at_least(cnt, b, bGe);
                                 cnt + (b ∸ cnt) < cnt + k by substituting (b = cnt + (b ∸ cnt));
                                 done by Natural.lt_of_add_left_lt };
                        k ≤ (b ∸ cnt)
                            by { k ≤ k + NaturalsBelow.value(sel(a)) by Natural.less_or_equal_add_right;
                                 k + NaturalsBelow.value(sel(a))
                                     = NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(a)) by aVal
                                     = NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(b)) by valEq
                                     = b ∸ cnt by bVal;
                                 done };
                        (b ∸ cnt) < k ≤ (b ∸ cnt);
                        ¬((b ∸ cnt) < (b ∸ cnt)) by Natural.lt_irreflexive;
                        done
                      }
                  }
                }
              case ¬(a < cnt) as aBack: {
                  cnt ≤ a by Natural.less_or_equal_of_not_less_than as aGe;
                  NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(a)) = a ∸ cnt
                      by backValue(a, aGe, aBelow) as aVal;
                  (a ∸ cnt) < k
                      by { a = cnt + (a ∸ cnt) by NaturalsBelow.decompose_at_least(cnt, a, aGe);
                           cnt + (a ∸ cnt) < cnt + k by substituting (a = cnt + (a ∸ cnt));
                           done by Natural.lt_of_add_left_lt };
                  done by cases {
                    case b < cnt as bFront: {
                        NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(b)) = k + NaturalsBelow.value(sel(b))
                            by frontValue(b, bFront) as bVal;
                        k ≤ (a ∸ cnt)
                            by { k ≤ k + NaturalsBelow.value(sel(b)) by Natural.less_or_equal_add_right;
                                 k + NaturalsBelow.value(sel(b))
                                     = NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(b)) by bVal
                                     = NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(a)) by valEq
                                     = a ∸ cnt by aVal;
                                 done };
                        (a ∸ cnt) < k ≤ (a ∸ cnt);
                        ¬((a ∸ cnt) < (a ∸ cnt)) by Natural.lt_irreflexive;
                        done
                      }
                    case ¬(b < cnt) as bBack: {
                        cnt ≤ b by Natural.less_or_equal_of_not_less_than as bGe;
                        NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(b)) = b ∸ cnt
                            by backValue(b, bGe, bBelow) as bVal;
                        (a ∸ cnt) = (b ∸ cnt)
                           by { (a ∸ cnt)
                                  = NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(a)) by aVal
                                  = NaturalsBelow.value(VectorSpace.combineFunctions(selExt, idE, cnt)(b)) by valEq
                                  = b ∸ cnt by bVal; done } as monusEq;
                        b = cnt + (b ∸ cnt) by NaturalsBelow.decompose_at_least(cnt, b, bGe) as bDecomp;
                        a = cnt + (a ∸ cnt) by NaturalsBelow.decompose_at_least(cnt, a, aGe)
                          = cnt + (b ∸ cnt) by substituting monusEq
                          = b by bDecomp;
                        done
                      }
                  }
                }
            }
          } as combinedInjective;

        -- Independence of `ext` kills the concatenated coefficients; the first
        -- `cnt` of them are the `coeff` we care about.
        ∀ (i : Natural). i < cnt + k →
            VectorSpace.combineFunctions(coeff, (i : Natural) ↦ Field.negate(Field.one(f)) * dPrime(i), cnt)(i)
            = Field.zero(f)
          by extIndependent(cnt + k,
                 VectorSpace.combineFunctions(selExt, idE, cnt),
                 VectorSpace.combineFunctions(coeff, (i : Natural) ↦ Field.negate(Field.one(f)) * dPrime(i), cnt),
                 combinedInjective, combinedVanishes) as concatCoeffsZero;
        target < cnt + k by { target < cnt ≤ cnt + k by Natural.less_or_equal_add_right; done } as targetBelowSum;
        coeff(target)
           = VectorSpace.combineFunctions(coeff, (i : Natural) ↦ Field.negate(Field.one(f)) * dPrime(i), cnt)(target)
                 by VectorSpace.combineFunctions_below
           = Field.zero(f) by concatCoeffsZero(target, targetBelowSum);
        done
      }
  }
}

-- ----------------------------------------------------------------------
-- The rank–nullity theorem. Extend a basis of `ker T` to a basis of `V`; the
-- images of the extension vectors form a basis of `im T`. Counting: `dim V`
-- (the size of the extended basis) is `dim ker T` (the kernel-basis prefix)
-- plus the number of extension vectors, which is `dim im T`.
theorem LinearMap.rank_nullity {f : Field} (V W : VectorSpace(f))
        (T : VectorSpace.carrier(V) → VectorSpace.carrier(W)) (linear : IsLinearMap(V, W, T))
        (finiteV : VectorSpace.FiniteDimensional(V))
        (kerFinite : VectorSpace.FiniteDimensional(
            Subspace.vector_space(V, LinearMap.kernel(V, W, T), LinearMap.kernel_is_subspace(V, W, T, linear))))
        (imageFinite : VectorSpace.FiniteDimensional(
            Subspace.vector_space(W, LinearMap.image(V, W, T), LinearMap.image_is_subspace(V, W, T, linear))))
        : VectorSpace.dimension(V, finiteV)
          = VectorSpace.dimension(
                Subspace.vector_space(V, LinearMap.kernel(V, W, T), LinearMap.kernel_is_subspace(V, W, T, linear)),
                kerFinite)
            + VectorSpace.dimension(
                Subspace.vector_space(W, LinearMap.image(V, W, T), LinearMap.image_is_subspace(V, W, T, linear)),
                imageFinite) := {
  let kerSet : Set(VectorSpace.carrier(V)) := LinearMap.kernel(V, W, T);
  let kerSub : IsSubspace(V, kerSet) := LinearMap.kernel_is_subspace(V, W, T, linear);
  let imgSet : Set(VectorSpace.carrier(W)) := LinearMap.image(V, W, T);
  let imgSub : IsSubspace(W, imgSet) := LinearMap.image_is_subspace(V, W, T, linear);
  let kdim : Natural := VectorSpace.dimension(Subspace.vector_space(V, kerSet, kerSub), kerFinite);

  -- A basis of the kernel, transported into `V`.
  VectorSpace.HasDimension(Subspace.vector_space(V, kerSet, kerSub), kdim)
      by VectorSpace.dimension_has_basis as kerHasBasis;
  choose eK such that VectorSpace.IsBasis(eK) from kerHasBasis;
  VectorSpace.Spans(eK) by VectorSpace.IsBasis.spans as eKSpans;
  VectorSpace.LinearlyIndependent(eK) by VectorSpace.IsBasis.linearly_independent as eKIndependent;
  let e : NaturalsBelow(kdim) → VectorSpace.carrier(V) :=
      (i : NaturalsBelow(kdim)) ↦ Subspace.inclusion(V, kerSet, kerSub)(eK(i));
  VectorSpace.LinearlyIndependent(e)
      by Subspace.value_linearlyIndependent(kerSet, kerSub, eK, eKIndependent) as eIndependent;
  ∀ (i : NaturalsBelow(kdim)). T(e(i)) = VectorSpace.zero(W)
      by { take i : NaturalsBelow(kdim);
           Subtype.value(eK(i)) ∈ kerSet by Subtype.property; done } as eKernel;

  -- Extend it to a basis of `V`.
  ∃ (sz : Natural). ∃ (rr : Natural). ∃ (ext : NaturalsBelow(sz) → VectorSpace.carrier(V)).
      sz = kdim + rr
      ∧ VectorSpace.IsBasis(ext)
      ∧ (∀ (i : NaturalsBelow(sz)). ∀ (j : NaturalsBelow(kdim)).
            NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext(i) = e(j))
      by VectorSpace.extend_to_basis(e, eIndependent, finiteV) as extendExists;
  choose sz, rr, ext such that
      sz = kdim + rr
      ∧ VectorSpace.IsBasis(ext)
      ∧ (∀ (i : NaturalsBelow(sz)). ∀ (j : NaturalsBelow(kdim)).
            NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext(i) = e(j))
      from extendExists;
  sz = kdim + rr as szEq;
  VectorSpace.IsBasis(ext) as extBasis;
  ∀ (i : NaturalsBelow(sz)). ∀ (j : NaturalsBelow(kdim)).
      NaturalsBelow.value(i) = NaturalsBelow.value(j) → ext(i) = e(j) as extPrefix;
  VectorSpace.LinearlyIndependent(ext) by VectorSpace.IsBasis.linearly_independent as extIndependent;
  VectorSpace.Spans(ext) by VectorSpace.IsBasis.spans as extSpans;

  -- `dim V = sz`.
  VectorSpace.HasDimension(V, sz) by { witness ext with extBasis } as vHasDimSz;
  VectorSpace.dimension(V, finiteV) = sz by VectorSpace.dimension_equals(V, finiteV, sz, vHasDimSz) as dimVeq;

  -- The appended vectors `aFamily(j) = ext` at index `kdim + j`, and their images.
  ∀ (j : NaturalsBelow(rr)). kdim + NaturalsBelow.value(j) < sz
    by { take j : NaturalsBelow(rr); NaturalsBelow.value(j) < rr by NaturalsBelow.below;
         kdim + NaturalsBelow.value(j) < kdim + rr by Natural.add_left_strict_monotone;
         done by substituting szEq } as aBound;
  let aFamily : NaturalsBelow(rr) → VectorSpace.carrier(V) :=
      (j : NaturalsBelow(rr)) ↦ ext(NaturalsBelow.make(kdim + NaturalsBelow.value(j), aBound(j)));
  ∀ (i : NaturalsBelow(sz)). ∀ (j : NaturalsBelow(rr)).
      NaturalsBelow.value(i) = kdim + NaturalsBelow.value(j) → ext(i) = aFamily(j)
    by {
      take i : NaturalsBelow(sz); take j : NaturalsBelow(rr);
      suppose NaturalsBelow.value(i) = kdim + NaturalsBelow.value(j) as valEq;
      NaturalsBelow.value(i) = NaturalsBelow.value(NaturalsBelow.make(kdim + NaturalsBelow.value(j), aBound(j)))
          by valEq;
      i = NaturalsBelow.make(kdim + NaturalsBelow.value(j), aBound(j))
          by NaturalsBelow.equal_of_value(a := i, b := NaturalsBelow.make(kdim + NaturalsBelow.value(j), aBound(j)));
      ext(i) = ext(NaturalsBelow.make(kdim + NaturalsBelow.value(j), aBound(j)))
          by substituting (i = NaturalsBelow.make(kdim + NaturalsBelow.value(j), aBound(j)));
      done
    } as extSuffix;
  ∀ (j : NaturalsBelow(rr)). T(aFamily(j)) ∈ LinearMap.image(V, W, T)
      by { take j : NaturalsBelow(rr); done by witness aFamily(j) with reflexivity(T(aFamily(j))) }
      as imageMemberA;
  let TaFamily : NaturalsBelow(rr) → VectorSpace.carrier(Subspace.vector_space(W, imgSet, imgSub)) :=
      (j : NaturalsBelow(rr)) ↦ Subtype.make(VectorSpace.carrier(W), imgSet, T(aFamily(j)), imageMemberA(j));
  ∀ (j : NaturalsBelow(rr)). Subtype.value(TaFamily(j)) = T(aFamily(j))
      by { take j : NaturalsBelow(rr); done } as taValue;

  -- The images span the image and are independent, hence a basis of `im T`.
  VectorSpace.Spans(TaFamily)
      by LinearMap.appended_images_span(T, linear, e, ext, aFamily, imgSub, TaFamily, taValue,
             szEq, extSpans, eKernel, extPrefix, extSuffix) as taSpans;
  ∀ (w : VectorSpace.carrier(V)).
      T(w) = VectorSpace.zero(W) → w = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(e, w)
    by {
      take w : VectorSpace.carrier(V);
      suppose T(w) = VectorSpace.zero(W) as wInKernel;
      w ∈ kerSet by wInKernel;
      Subtype.value(Subtype.make(VectorSpace.carrier(V), kerSet, w, wInKernel)) = VectorSpace.zero(V)
          ∨ VectorSpace.InSpanOf((i : NaturalsBelow(kdim)) ↦ Subtype.value(eK(i)),
                Subtype.value(Subtype.make(VectorSpace.carrier(V), kerSet, w, wInKernel)))
          by Subspace.spanning_value_covered(kerSet, kerSub, eK, eKSpans);
      done
    } as kerCoverage;
  VectorSpace.LinearlyIndependent(TaFamily)
      by LinearMap.appended_images_independent(T, linear, e, ext, aFamily, imgSub, TaFamily, taValue,
             szEq, extIndependent, extPrefix, extSuffix, kerCoverage) as taIndependent;
  VectorSpace.IsBasis(TaFamily)
      by { VectorSpace.LinearlyIndependent(TaFamily) by taIndependent;
           VectorSpace.Spans(TaFamily) by taSpans; done } as taBasis;

  -- `dim im T = rr`.
  VectorSpace.HasDimension(Subspace.vector_space(W, imgSet, imgSub), rr)
      by { witness TaFamily with taBasis } as imgHasDimRr;
  VectorSpace.dimension(Subspace.vector_space(W, imgSet, imgSub), imageFinite) = rr
      by VectorSpace.dimension_equals(Subspace.vector_space(W, imgSet, imgSub), imageFinite, rr, imgHasDimRr)
      as dimImgeq;

  -- Count: `dim V = sz = kdim + rr = dim ker T + dim im T`.
  VectorSpace.dimension(V, finiteV)
     = sz by dimVeq
     = kdim + rr by szEq
     = VectorSpace.dimension(Subspace.vector_space(V, kerSet, kerSub), kerFinite)
       + VectorSpace.dimension(Subspace.vector_space(W, imgSet, imgSub), imageFinite)
           by substituting dimImgeq;
  done
}

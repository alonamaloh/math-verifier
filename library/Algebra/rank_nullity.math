-- Algebra/rank_nullity.math
--
-- The rank–nullity theorem: for a linear map `T : V → W` with `V`
-- finite-dimensional, `dim(V) = dim(ker T) + dim(im T)`. The route is basis
-- extension — no quotient space: extend a basis of the kernel to a basis of
-- `V`, and the `T`-images of the extension vectors form a basis of the image.
--
-- Everything the argument moves between a subspace and its ambient space runs
-- through ONE transport lemma, `Subspace.linearCombination_value`: the value of
-- a linear combination computed inside the subspace equals the combination of
-- the values computed in `V`. Independence and spanning transport between a
-- subspace family and its value-image in `V` are corollaries. This confines the
-- `Subtype`/`Subspace` boundary cost of the whole proof to that one induction.

module Algebra.rank_nullity

import Logic.basics
import Logic.exists
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.order
import Set.subtype
import Set.finite
import Set.equinumerous
import Algebra.field
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.field_bundle
import Algebra.vector_space
import Algebra.subspace
import Algebra.linear_map
import Algebra.linear_combination
import Algebra.span
import Algebra.exchange_lemma
import Algebra.basis_pruning
import Algebra.finite_dimensional
import Algebra.dimension

-- ----------------------------------------------------------------------
-- Brick 1 — the subtype-transport bridge.
--
-- The value of a linear combination formed inside the subspace
-- `Subspace.vector_space(V, subset, subspace)` is the linear combination of
-- the underlying values formed in `V`. Both `Subspace.add` and `Subspace.scale`
-- are defined so their value is the corresponding operation on values, so the
-- only real step in the induction is peeling the last term.
theorem Subspace.linearCombination_value {f : Field} {V : VectorSpace(f)} {I : Type(0)}
        (subset : Set(VectorSpace.carrier(V))) (subspace : IsSubspace(V, subset))
        (family : I → VectorSpace.carrier(Subspace.vector_space(V, subset, subspace)))
        (coefficients : Natural → Field.carrier(f))
        (selection : Natural → I) (count : Natural)
        : Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, count))
          = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
                coefficients, selection, count) :=
  by induction on count with IH {
    case base:
        Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, 0))
           = Subtype.value(VectorSpace.zero(Subspace.vector_space(V, subset, subspace)))
           = VectorSpace.zero(V)
           = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
                 coefficients, selection, 0)
    case step(m):
        Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, 1 + m))
           = Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, m)
                 + coefficients(m) • family(selection(m)))
                 by VectorSpace.linearCombination_add_one
           = Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, m))
                 + coefficients(m) • Subtype.value(family(selection(m)))
           = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
                 coefficients, selection, m)
                 + coefficients(m) • Subtype.value(family(selection(m)))
                 by IH
           = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
                 coefficients, selection, 1 + m)
                 by VectorSpace.linearCombination_add_one
  }

-- Independence and spanning transport across the value boundary, both
-- corollaries of the bridge above.

-- An independent family inside the subspace maps to an independent family in
-- `V`: a vanishing combination of the values, pushed through the bridge, is a
-- vanishing combination inside the subspace, whose coefficients the subspace
-- independence kills.
theorem Subspace.value_linearlyIndependent {f : Field} {V : VectorSpace(f)} {I : Type(0)}
        (subset : Set(VectorSpace.carrier(V))) (subspace : IsSubspace(V, subset))
        (family : I → VectorSpace.carrier(Subspace.vector_space(V, subset, subspace)))
        (independent : VectorSpace.LinearlyIndependent(family))
        : VectorSpace.LinearlyIndependent((i : I) ↦ Subtype.value(family(i))) := {
  take count : Natural;
  take selection : Natural → I;
  take coefficients : Natural → Field.carrier(f);
  suppose ∀ (a b : Natural). a < count → b < count → selection(a) = selection(b) → a = b
      as selectionInjective;
  suppose VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
              coefficients, selection, count) = VectorSpace.zero(V) as valuesVanish;
  Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, count))
     = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)), coefficients, selection, count)
           by Subspace.linearCombination_value
     = VectorSpace.zero(V) by valuesVanish
     = Subtype.value(VectorSpace.zero(Subspace.vector_space(V, subset, subspace)));
  VectorSpace.linearCombination(family, coefficients, selection, count)
      = VectorSpace.zero(Subspace.vector_space(V, subset, subspace))
      by Subtype.equal_of_value_equal as combinationZero;
  done by independent(count, selection, coefficients, selectionInjective, combinationZero)
}

-- A subspace family spans when every subspace vector's value is either zero or
-- a `V`-combination of the family values: the bridge turns that combination of
-- values back into a subspace combination, and equal values mean equal subtype
-- elements.
theorem Subspace.spans_of_value_covered {f : Field} {V : VectorSpace(f)} {I : Type(0)}
        (subset : Set(VectorSpace.carrier(V))) (subspace : IsSubspace(V, subset))
        (family : I → VectorSpace.carrier(Subspace.vector_space(V, subset, subspace)))
        (covered : ∀ (x : VectorSpace.carrier(Subspace.vector_space(V, subset, subspace))).
            Subtype.value(x) = VectorSpace.zero(V)
            ∨ VectorSpace.InSpanOf((i : I) ↦ Subtype.value(family(i)), Subtype.value(x)))
        : VectorSpace.Spans(family) := {
  take x : VectorSpace.carrier(Subspace.vector_space(V, subset, subspace));
  Subtype.value(x) = VectorSpace.zero(V)
      ∨ VectorSpace.InSpanOf((i : I) ↦ Subtype.value(family(i)), Subtype.value(x)) by covered;
  done by cases {
    case Subtype.value(x) = VectorSpace.zero(V) as valueZero: {
        Subtype.value(x) = VectorSpace.zero(V)
           = Subtype.value(VectorSpace.zero(Subspace.vector_space(V, subset, subspace)));
        x = VectorSpace.zero(Subspace.vector_space(V, subset, subspace))
            by Subtype.equal_of_value_equal;
        done
      }
    case VectorSpace.InSpanOf((i : I) ↦ Subtype.value(family(i)), Subtype.value(x)) as inSpan: {
        choose count, selection, coefficients such that
            Subtype.value(x) = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
                coefficients, selection, count) from inSpan;
        Subtype.value(x)
           = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)), coefficients, selection, count)
           = Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, count))
                 by Subspace.linearCombination_value;
        x = VectorSpace.linearCombination(family, coefficients, selection, count)
            by Subtype.equal_of_value_equal as xIsCombination;
        VectorSpace.InSpanOf(family, x) by { witness count with witness selection
            with witness coefficients with xIsCombination };
        done
      }
  }
}

-- ----------------------------------------------------------------------
-- The image of a linear combination under a linear map is the linear
-- combination of the images: linearity commutes with the finite sum.
theorem LinearMap.apply_linearCombination {f : Field} {V W : VectorSpace(f)} {I : Type(0)}
        {T : VectorSpace.carrier(V) → VectorSpace.carrier(W)} (linear : IsLinearMap(V, W, T))
        (family : I → VectorSpace.carrier(V))
        (coefficients : Natural → Field.carrier(f))
        (selection : Natural → I) (count : Natural)
        : T(VectorSpace.linearCombination(family, coefficients, selection, count))
          = VectorSpace.linearCombination((i : I) ↦ T(family(i)), coefficients, selection, count) :=
  by induction on count with IH {
    case base:
        T(VectorSpace.linearCombination(family, coefficients, selection, 0))
           = T(VectorSpace.zero(V))
           = VectorSpace.zero(W) by LinearMap.preserves_zero
           = VectorSpace.linearCombination((i : I) ↦ T(family(i)), coefficients, selection, 0)
    case step(m):
        T(VectorSpace.linearCombination(family, coefficients, selection, 1 + m))
           = T(VectorSpace.linearCombination(family, coefficients, selection, m)
                 + coefficients(m) • family(selection(m)))
                 by VectorSpace.linearCombination_add_one
           = T(VectorSpace.linearCombination(family, coefficients, selection, m))
                 + T(coefficients(m) • family(selection(m)))
                 by LinearMap.additive(linear, VectorSpace.linearCombination(family, coefficients, selection, m),
                        coefficients(m) • family(selection(m)))
           = VectorSpace.linearCombination((i : I) ↦ T(family(i)), coefficients, selection, m)
                 + T(coefficients(m) • family(selection(m)))
                 by IH
           = VectorSpace.linearCombination((i : I) ↦ T(family(i)), coefficients, selection, m)
                 + coefficients(m) • T(family(selection(m)))
                 by LinearMap.homogeneous(linear, coefficients(m), family(selection(m)))
           = VectorSpace.linearCombination((i : I) ↦ T(family(i)), coefficients, selection, 1 + m)
                 by VectorSpace.linearCombination_add_one
  }

-- ----------------------------------------------------------------------
-- Brick 2 — the image of a finite-dimensional space is finite-dimensional.
--
-- The images `T(b(i))` of a basis `b` of `V`, lifted into the image subtype,
-- span the image subspace: every element of the image is `T(v)`, and `v` is a
-- combination of the basis, so `T(v)` is the corresponding combination of the
-- `T(b(i))` by linearity. Finitely generated, hence finite-dimensional by
-- pruning.
theorem LinearMap.image_finite_dimensional {f : Field} (V W : VectorSpace(f))
        (T : VectorSpace.carrier(V) → VectorSpace.carrier(W)) (linear : IsLinearMap(V, W, T))
        (finiteV : VectorSpace.FiniteDimensional(V))
        : VectorSpace.FiniteDimensional(
              Subspace.vector_space(W, LinearMap.image(V, W, T),
                  LinearMap.image_is_subspace(V, W, T, linear))) := {
  IsSubspace(W, LinearMap.image(V, W, T)) by LinearMap.image_is_subspace as imageSubspace;
  VectorSpace.HasDimension(V, VectorSpace.dimension(V, finiteV))
      by VectorSpace.dimension_has_basis as vHasBasis;
  choose basisV such that VectorSpace.IsBasis(basisV) from vHasBasis;
  VectorSpace.Spans(basisV) by VectorSpace.IsBasis.spans as basisSpans;

  -- The lifted image family: index i ↦ the image T(basisV(i)) as an element of
  -- the image subtype.
  ∀ (i : NaturalsBelow(VectorSpace.dimension(V, finiteV))).
      T(basisV(i)) ∈ LinearMap.image(V, W, T)
    by { take i : NaturalsBelow(VectorSpace.dimension(V, finiteV));
         T(basisV(i)) = T(basisV(i));
         done by witness basisV(i) with reflexivity(T(basisV(i))) } as imageHits;

  ∀ (x : VectorSpace.carrier(Subspace.vector_space(W, LinearMap.image(V, W, T), imageSubspace))).
      Subtype.value(x) = VectorSpace.zero(W)
      ∨ VectorSpace.InSpanOf(
            (i : NaturalsBelow(VectorSpace.dimension(V, finiteV))) ↦ T(basisV(i)),
            Subtype.value(x))
    by {
          take x : VectorSpace.carrier(Subspace.vector_space(W, LinearMap.image(V, W, T), imageSubspace));
          Subtype.value(x) ∈ LinearMap.image(V, W, T) by Subtype.property;
          ∃ (v : VectorSpace.carrier(V)). T(v) = Subtype.value(x);
          choose v such that T(v) = Subtype.value(x) as vHits;
          Subtype.value(x) = VectorSpace.zero(W)
              ∨ VectorSpace.InSpanOf(
                    (i : NaturalsBelow(VectorSpace.dimension(V, finiteV))) ↦ T(basisV(i)),
                    Subtype.value(x))
            by {
              v = VectorSpace.zero(V)
                  ∨ (∃ (count : Natural). ∃ (selection : Natural → NaturalsBelow(VectorSpace.dimension(V, finiteV))).
                     ∃ (coefficients : Natural → Field.carrier(f)).
                         v = VectorSpace.linearCombination(basisV, coefficients, selection, count))
                  by basisSpans;
              done by cases {
                case v = VectorSpace.zero(V) as vZero: {
                    Subtype.value(x) = T(v) by vHits
                       = T(VectorSpace.zero(V)) by substituting vZero
                       = VectorSpace.zero(W) by LinearMap.preserves_zero;
                    done
                  }
                case ∃ (count : Natural). ∃ (selection : Natural → NaturalsBelow(VectorSpace.dimension(V, finiteV))).
                     ∃ (coefficients : Natural → Field.carrier(f)).
                         v = VectorSpace.linearCombination(basisV, coefficients, selection, count) as vCombo: {
                    choose count, selection, coefficients such that
                        v = VectorSpace.linearCombination(basisV, coefficients, selection, count) from vCombo;
                    Subtype.value(x) = T(v) by vHits
                       = T(VectorSpace.linearCombination(basisV, coefficients, selection, count))
                             by substituting (v = VectorSpace.linearCombination(basisV, coefficients, selection, count))
                       = VectorSpace.linearCombination(
                             (i : NaturalsBelow(VectorSpace.dimension(V, finiteV))) ↦ T(basisV(i)),
                             coefficients, selection, count)
                             by LinearMap.apply_linearCombination(linear, basisV, coefficients, selection, count)
                       as valueIsCombination;
                    VectorSpace.InSpanOf(
                        (i : NaturalsBelow(VectorSpace.dimension(V, finiteV))) ↦ T(basisV(i)),
                        Subtype.value(x))
                      by { witness count with witness selection with witness coefficients
                           with valueIsCombination };
                    done
                  }
              }
            };
      done
    } as coveredFact;
  VectorSpace.FinitelyGenerated(Subspace.vector_space(W, LinearMap.image(V, W, T), imageSubspace))
      by { witness VectorSpace.dimension(V, finiteV)
           with witness ((i : NaturalsBelow(VectorSpace.dimension(V, finiteV)))
                ↦ Subtype.make(VectorSpace.carrier(W), LinearMap.image(V, W, T),
                      T(basisV(i)), imageHits(i)))
           with Subspace.spans_of_value_covered(covered := coveredFact) };
  done by VectorSpace.FinitelyGenerated.finite_dimensional
}

-- ----------------------------------------------------------------------
-- Finite-family construction: appending a vector, and dropping a
-- zero-coefficient position from a combination. These are the tools the
-- basis-extension bricks (3–5) need to GROW an independent family, the
-- mirror of `basis_pruning`'s shrinking `dropIndex`.

-- The family `family` with one extra vector `x` appended at index `m`: below
-- `m` it reads `family`, at `m` (the last index) it reads `x`. Built on
-- `Function.extendBelow` (fallback `x`), so its two characterising equations
-- are immediate.
definition VectorSpace.appendVector {f : Field} {V : VectorSpace(f)} {m : Natural}
        (family : NaturalsBelow(m) → VectorSpace.carrier(V))
        (x : VectorSpace.carrier(V))
        : NaturalsBelow(1 + m) → VectorSpace.carrier(V) :=
  (i : NaturalsBelow(1 + m)) ↦
    Function.extendBelow(family, x)(NaturalsBelow.value(i))

theorem VectorSpace.appendVector_below {f : Field} {V : VectorSpace(f)} {m : Natural}
        (family : NaturalsBelow(m) → VectorSpace.carrier(V))
        (x : VectorSpace.carrier(V)) (i : NaturalsBelow(1 + m))
        (below : NaturalsBelow.value(i) < m)
        : VectorSpace.appendVector(family, x)(i)
          = family(NaturalsBelow.make(NaturalsBelow.value(i), below)) :=
  VectorSpace.appendVector(family, x)(i)
     = Function.extendBelow(family, x)(NaturalsBelow.value(i))
     = family(NaturalsBelow.make(NaturalsBelow.value(i), below))
           by Function.extendBelow_below

theorem VectorSpace.appendVector_last {f : Field} {V : VectorSpace(f)} {m : Natural}
        (family : NaturalsBelow(m) → VectorSpace.carrier(V))
        (x : VectorSpace.carrier(V)) (i : NaturalsBelow(1 + m))
        (atLast : NaturalsBelow.value(i) = m)
        : VectorSpace.appendVector(family, x)(i) = x := {
  m ≤ NaturalsBelow.value(i) by { NaturalsBelow.value(i) = m; done } as past;
  VectorSpace.appendVector(family, x)(i)
     = Function.extendBelow(family, x)(NaturalsBelow.value(i))
     = x by Function.extendBelow_past(past := past);
  done
}

-- Dropping a zero-coefficient position: a combination of `1 + n` terms whose
-- `p`-th coefficient is zero equals the `n`-term combination that reindexes
-- the coefficients and selection by `NaturalsBelow.skipValue(p, ·)` — the
-- order-preserving position map that skips `p`. (The dropped term is `0 • …`,
-- so it contributes nothing.) Induction on `n`, peeling the last position and
-- splitting on whether `p` is that last position.
theorem VectorSpace.linearCombination_drop_zero_position {f : Field} {V : VectorSpace(f)}
        {I : Type(0)} (family : I → VectorSpace.carrier(V))
        (coefficients : Natural → Field.carrier(f)) (selection : Natural → I)
        : ∀ (n : Natural). ∀ (p : Natural). p < 1 + n
              → coefficients(p) = Field.zero(f)
              → VectorSpace.linearCombination(family, coefficients, selection, 1 + n)
                = VectorSpace.linearCombination(family,
                      (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                      (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), n) :=
  by induction on n with IH {
    case base: {
        take p : Natural;
        suppose p < 1 + 0 as pBelow;
        suppose coefficients(p) = Field.zero(f) as coeffZero;
        p = 0 by { p ≤ 0 by Natural.le_of_lt_one_plus; done };
        VectorSpace.linearCombination(family, coefficients, selection, 1 + 0)
           = coefficients(0) • family(selection(0)) by VectorSpace.linearCombination_one
           = coefficients(p) • family(selection(p)) by substituting (p = 0)
           = Field.zero(f) • family(selection(p)) by substituting coeffZero
           = VectorSpace.zero(V) by VectorSpace.zero_scale
           = VectorSpace.linearCombination(family,
                 (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                 (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), 0)
      }
    case step(q): {
        take p : Natural;
        suppose p < 1 + (1 + q) as pBelow;
        suppose coefficients(p) = Field.zero(f) as coeffZero;
        p < 1 + q ∨ p = 1 + q by Natural.le_of_lt_one_plus;
        done by cases {
          case p < 1 + q as pNotLast: {
              -- `p` is not last: peel the last term (unchanged by the skip,
              -- since `skipValue(p, q) = 1 + q` for `q ≥ p`) and recurse.
              ¬(q < p) by { suppose q < p as qLtP; p ≤ q by Natural.le_of_lt_one_plus;
                            q < p ≤ q; done };
              NaturalsBelow.skipValue(p, q) = 1 + q
                  by NaturalsBelow.skipValue_above as skipLast;
              VectorSpace.linearCombination(family,
                    (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                    (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), 1 + q)
                 = VectorSpace.linearCombination(family,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), q)
                   + coefficients(NaturalsBelow.skipValue(p, q))
                       • family(selection(NaturalsBelow.skipValue(p, q)))
                       by VectorSpace.linearCombination_add_one
                 = VectorSpace.linearCombination(family,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), q)
                   + coefficients(1 + q) • family(selection(1 + q))
                       by substituting skipLast
                 as rhsPeeled;
              VectorSpace.linearCombination(family, coefficients, selection, 1 + (1 + q))
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                   + coefficients(1 + q) • family(selection(1 + q))
                       by VectorSpace.linearCombination_add_one
                 = VectorSpace.linearCombination(family,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), q)
                   + coefficients(1 + q) • family(selection(1 + q))
                       by IH(p, pNotLast, coeffZero)
                 = VectorSpace.linearCombination(family,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), 1 + q)
                       by rhsPeeled
            }
          case p = 1 + q as pLast: {
              -- The dropped position is the last one; the skip is the identity
              -- below `1 + q`, so the reindexed prefix is unchanged.
              ∀ (i : Natural). i < 1 + q →
                  coefficients(i) = coefficients(NaturalsBelow.skipValue(p, i))
                by { take i : Natural; suppose i < 1 + q as iBelow;
                     i < p by substituting pLast;
                     NaturalsBelow.skipValue(p, i) = i by NaturalsBelow.skipValue_below;
                     done by substituting (NaturalsBelow.skipValue(p, i) = i) } as coeffAgree;
              ∀ (i : Natural). i < 1 + q →
                  selection(i) = selection(NaturalsBelow.skipValue(p, i))
                by { take i : Natural; suppose i < 1 + q as iBelow;
                     i < p by substituting pLast;
                     NaturalsBelow.skipValue(p, i) = i by NaturalsBelow.skipValue_below;
                     done by substituting (NaturalsBelow.skipValue(p, i) = i) } as selAgree;
              coefficients(1 + q) = Field.zero(f)
                  by { coefficients(1 + q) = coefficients(p) by substituting pLast
                       = Field.zero(f) by coeffZero; done } as lastZero;
              VectorSpace.linearCombination(family, coefficients, selection, 1 + (1 + q))
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                   + coefficients(1 + q) • family(selection(1 + q))
                       by VectorSpace.linearCombination_add_one
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                   + Field.zero(f) • family(selection(1 + q))
                       by substituting lastZero
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                   + VectorSpace.zero(V) by VectorSpace.zero_scale
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                 = VectorSpace.linearCombination(family,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), 1 + q)
                       by VectorSpace.linearCombination_pointwise_below(
                              coefficientsAgree := coeffAgree, selectionsAgree := selAgree)
            }
        }
      }
  }

-- When every position of a combination over `appendVector(e, x)` selects an
-- index below `m` (an `e`-vector, never the appended `x`), the combination IS
-- a combination over `e` alone, reindexed by the clamp `NaturalsBelow(1+m) →
-- NaturalsBelow(m)`. (`ei0` is any `e`-index, supplying the clamp fallback.)
theorem VectorSpace.appendVector_reduces_to_e {f : Field} {V : VectorSpace(f)} {m : Natural}
        (e : NaturalsBelow(m) → VectorSpace.carrier(V)) (x : VectorSpace.carrier(V))
        (coefficients : Natural → Field.carrier(f))
        (selection : Natural → NaturalsBelow(1 + m)) (count : Natural)
        (ei0 : NaturalsBelow(m))
        (allBelow : ∀ (j : Natural). j < count → NaturalsBelow.value(selection(j)) < m)
        : VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, count)
          = VectorSpace.linearCombination(e, coefficients,
                (j : Natural) ↦ NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j))), count) := {
  ∀ (j : Natural). j < count →
      coefficients(j) • VectorSpace.appendVector(e, x)(selection(j))
      = coefficients(j) • e(NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j))))
    by {
      take j : Natural;
      suppose j < count as jBelow;
      NaturalsBelow.value(selection(j)) < m by allBelow as valBelow;
      VectorSpace.appendVector(e, x)(selection(j))
          = e(NaturalsBelow.make(NaturalsBelow.value(selection(j)), valBelow))
          by VectorSpace.appendVector_below as appAt;
      NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j)))
          = NaturalsBelow.make(NaturalsBelow.value(selection(j)), valBelow)
          by NaturalsBelow.clamp_below as clampAt;
      coefficients(j) • VectorSpace.appendVector(e, x)(selection(j))
         = coefficients(j) • e(NaturalsBelow.make(NaturalsBelow.value(selection(j)), valBelow))
             by substituting appAt
         = coefficients(j) • e(NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j))))
             by substituting clampAt
    };
  done by VectorSpace.linearCombination_congruence
}

-- The clamp reindex of an injective, below-`m` selection is itself injective:
-- distinct positions give distinct values give distinct clamped indices.
theorem VectorSpace.appendVector_clamp_injective {f : Field} {V : VectorSpace(f)} {m : Natural}
        (selection : Natural → NaturalsBelow(1 + m)) (count : Natural) (ei0 : NaturalsBelow(m))
        (selInjective : ∀ (a b : Natural). a < count → b < count → selection(a) = selection(b) → a = b)
        (allBelow : ∀ (j : Natural). j < count → NaturalsBelow.value(selection(j)) < m)
        : ∀ (a b : Natural). a < count → b < count →
              NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(a)))
              = NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(b))) → a = b := {
  take a : Natural; take b : Natural;
  suppose a < count as aBelow;
  suppose b < count as bBelow;
  suppose NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(a)))
          = NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(b))) as clampEqual;
  NaturalsBelow.value(selection(a)) < m by allBelow as aValBelow;
  NaturalsBelow.value(selection(b)) < m by allBelow as bValBelow;
  NaturalsBelow.value(selection(a))
     = NaturalsBelow.value(NaturalsBelow.make(NaturalsBelow.value(selection(a)), aValBelow))
     = NaturalsBelow.value(NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(a))))
           by NaturalsBelow.clamp_below
     = NaturalsBelow.value(NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(b))))
           by substituting clampEqual
     = NaturalsBelow.value(NaturalsBelow.make(NaturalsBelow.value(selection(b)), bValBelow))
           by NaturalsBelow.clamp_below
     = NaturalsBelow.value(selection(b));
  selection(a) = selection(b) by NaturalsBelow.equal_of_value(a := selection(a), b := selection(b));
  done by selInjective
}

-- Small arithmetic / position facts the append lemma leans on.
theorem Natural.less_than_one_is_zero (k : Natural) (h : k < 1) : k = 0 := {
  k ≤ 0 by Natural.le_of_lt_one_plus;
  done by Natural.less_or_equal_zero_implies_equals_zero
}

theorem Natural.positive_one_plus_monus_one (n : Natural) (pos : 0 < n)
        : n = 1 + Natural.monus(n, 1) := {
  n = 0 ∨ ∃ (k : Natural). n = 1 + k by Natural.zero_or_one_plus;
  done by cases {
    case n = 0 as nZero: { 0 < 0 by substituting nZero;
                           ¬(0 < 0) by Natural.lt_irreflexive; done }
    case ∃ (k : Natural). n = 1 + k as nPlus: {
        choose k such that n = 1 + k from nPlus;
        Natural.monus(n, 1) = Natural.monus(1 + k, 1) by substituting (n = 1 + k)
           = k by NaturalsBelow.monus_one_plus_one as monusK;
        n = 1 + k = 1 + Natural.monus(n, 1) by substituting monusK;
        done
    }
  }
}

theorem NaturalsBelow.skipValue_ne (jv j : Natural) : NaturalsBelow.skipValue(jv, j) ≠ jv := {
  j < jv ∨ jv ≤ j by Natural.lt_or_le;
  done by cases {
    case j < jv as below: {
        NaturalsBelow.skipValue(jv, j) = j by NaturalsBelow.skipValue_below as sv;
        j ≠ jv by Natural.not_equal_of_less_than;
        done by substituting sv
      }
    case jv ≤ j as ge: {
        ¬(j < jv) by { suppose j < jv as jLt; j < jv ≤ j; done };
        NaturalsBelow.skipValue(jv, j) = 1 + j by NaturalsBelow.skipValue_above as sv;
        jv < 1 + j by { jv ≤ j < 1 + j; done };
        1 + j ≠ jv by Natural.not_equal_of_greater_than;
        done by substituting sv
      }
  }
}

theorem NaturalsBelow.skipValue_injective (jv a b : Natural)
        (h : NaturalsBelow.skipValue(jv, a) = NaturalsBelow.skipValue(jv, b)) : a = b := {
  a < jv ∨ jv ≤ a by Natural.lt_or_le;
  done by cases {
    case a < jv as aBelow: {
        NaturalsBelow.skipValue(jv, a) = a by NaturalsBelow.skipValue_below as sa;
        b < jv ∨ jv ≤ b by Natural.lt_or_le;
        done by cases {
          case b < jv as bBelow: {
              NaturalsBelow.skipValue(jv, b) = b by NaturalsBelow.skipValue_below as sb;
              a = NaturalsBelow.skipValue(jv, a) by sa
                = NaturalsBelow.skipValue(jv, b) by h
                = b by sb;
              done
            }
          case jv ≤ b as bGe: {
              ¬(b < jv) by { suppose b < jv as bLt; b < jv ≤ b; done };
              NaturalsBelow.skipValue(jv, b) = 1 + b by NaturalsBelow.skipValue_above as sb;
              a = 1 + b by { a = NaturalsBelow.skipValue(jv, a) by sa
                               = NaturalsBelow.skipValue(jv, b) by h = 1 + b by sb; done } as aEq;
              a < 1 + b by { a < jv ≤ b < 1 + b; done };
              1 + b < 1 + b by substituting aEq;
              ¬(1 + b < 1 + b) by Natural.lt_irreflexive;
              done
            }
        }
      }
    case jv ≤ a as aGe: {
        ¬(a < jv) by { suppose a < jv as aLt; a < jv ≤ a; done };
        NaturalsBelow.skipValue(jv, a) = 1 + a by NaturalsBelow.skipValue_above as sa;
        b < jv ∨ jv ≤ b by Natural.lt_or_le;
        done by cases {
          case b < jv as bBelow: {
              NaturalsBelow.skipValue(jv, b) = b by NaturalsBelow.skipValue_below as sb;
              b = 1 + a by { b = NaturalsBelow.skipValue(jv, b) by sb
                               = NaturalsBelow.skipValue(jv, a) by h = 1 + a by sa; done } as bEq;
              b < 1 + a by { b < jv ≤ a < 1 + a; done };
              1 + a < 1 + a by substituting bEq;
              ¬(1 + a < 1 + a) by Natural.lt_irreflexive;
              done
            }
          case jv ≤ b as bGe: {
              ¬(b < jv) by { suppose b < jv as bLt; b < jv ≤ b; done };
              NaturalsBelow.skipValue(jv, b) = 1 + b by NaturalsBelow.skipValue_above as sb;
              1 + a = 1 + b by { 1 + a = NaturalsBelow.skipValue(jv, a) by sa
                                   = NaturalsBelow.skipValue(jv, b) by h = 1 + b by sb; done };
              done by Natural.add_cancel_left
            }
        }
      }
  }
}

-- ----------------------------------------------------------------------
-- The append lemma: a vector outside the span of an independent family
-- extends it to a larger independent family. This is the growing counterpart
-- of `independent_or_droppable`, and the engine behind basis EXTENSION.
--
-- A vanishing combination of `appendVector(e, x)` cannot use `x` (its
-- coefficient there would put `x` in the span of the `e`-vectors — the other
-- indices — contradicting `x ∉ span(e)`), so it reduces to a vanishing
-- combination of `e` alone, whose coefficients `e`'s independence kills. The
-- (at most one) position selecting `x` carries a zero coefficient and is
-- dropped by `linearCombination_drop_zero_position` to keep the reduced
-- selection injective.
theorem VectorSpace.independent_append_outside_span {f : Field} {V : VectorSpace(f)} {m : Natural}
        (e : NaturalsBelow(m) → VectorSpace.carrier(V)) (x : VectorSpace.carrier(V))
        (eIndependent : VectorSpace.LinearlyIndependent(e))
        (notInSpan : ¬(x = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(e, x)))
        : VectorSpace.LinearlyIndependent(VectorSpace.appendVector(e, x)) := {
  ¬VectorSpace.InSpanOf(e, x)
      by { suppose VectorSpace.InSpanOf(e, x) as inSpan;
           x = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(e, x); done } as xNotInSpan;
  x ≠ VectorSpace.zero(V)
      by { suppose x = VectorSpace.zero(V) as isZero;
           x = VectorSpace.zero(V) ∨ VectorSpace.InSpanOf(e, x); done } as xNonzero;
  take len : Natural;
  take selection : Natural → NaturalsBelow(1 + m);
  take coefficients : Natural → Field.carrier(f);
  suppose ∀ (a b : Natural). a < len → b < len → selection(a) = selection(b) → a = b
      as selectionInjective;
  suppose VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, len)
          = VectorSpace.zero(V) as vanishes;
  m = 0 ∨ ∃ (mp : Natural). m = 1 + mp by Natural.zero_or_one_plus;
  done by cases {
    case m = 0 as mZero: {
        -- The empty family: `appendVector` is the singleton `{x}`; any two
        -- positions select the sole index, so an injective selection has at
        -- most one position, and its coefficient kills `x`.
        ∀ (i : Natural). i < len → NaturalsBelow.value(selection(i)) = m
          by { take i : Natural; suppose i < len as iBelow;
               NaturalsBelow.value(selection(i)) < 1 + m by NaturalsBelow.below;
               1 + m = 1 by substituting mZero;
               NaturalsBelow.value(selection(i)) < 1;
               NaturalsBelow.value(selection(i)) = 0 by NaturalsBelow.below_one_is_zero;
               done by substituting mZero } as allAtLast;
        ¬(1 < len)
          by { suppose 1 < len as oneLtLen;
               0 < len by { 0 < 1 < len; done };
               NaturalsBelow.value(selection(0)) = m by allAtLast;
               NaturalsBelow.value(selection(1)) = m by allAtLast;
               NaturalsBelow.value(selection(0)) = NaturalsBelow.value(selection(1));
               selection(0) = selection(1)
                   by NaturalsBelow.equal_of_value(a := selection(0), b := selection(1));
               0 = 1 by selectionInjective(0, 1);
               done } as notOneLtLen;
        take i : Natural;
        suppose i < len as iBelow;
        0 < len by { 0 ≤ i < len; done } as lenPos;
        len ≤ 1 by { 1 < len ∨ len ≤ 1 by Natural.lt_or_le;
                     done by cases { case 1 < len as c: { ¬(1 < len) by notOneLtLen; done }
                                     case len ≤ 1 as c: { done } } } as lenLeOne;
        1 ≤ len by Natural.successor_le_of_lt;
        len = 1 by Natural.le_antisymmetric as lenOne;
        i < 1 by substituting lenOne as iLtOne;
        i = 0 by Natural.less_than_one_is_zero as iZero;
        VectorSpace.appendVector(e, x)(selection(0)) = x
            by VectorSpace.appendVector_last(atLast := allAtLast(0, lenPos)) as app0;
        coefficients(i) • x = VectorSpace.zero(V)
          by {
            VectorSpace.zero(V)
               = VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, len)
                     by vanishes
               = VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, 1)
                     by substituting lenOne
               = coefficients(0) • VectorSpace.appendVector(e, x)(selection(0))
                     by VectorSpace.linearCombination_one
               = coefficients(0) • x by substituting app0
               = coefficients(i) • x by substituting iZero;
            done
          } as termZero;
        suppose coefficients(i) ≠ Field.zero(f) as ciNonzero for contradiction {
          x = Field.reciprocal(coefficients(i), ciNonzero) • (coefficients(i) • x)
                by VectorSpace.scale_reciprocal_cancel
            = Field.reciprocal(coefficients(i), ciNonzero) • VectorSpace.zero(V)
                by substituting termZero
            = VectorSpace.zero(V) by VectorSpace.scale_zero;
          done
        }
      }
    case ∃ (mp : Natural). m = 1 + mp as mPosExists: {
        choose mp such that m = 1 + mp from mPosExists;
        0 < m by { 0 < 1 + mp; done by substituting (m = 1 + mp) } as mPos;
        let ei0 : NaturalsBelow(m) := NaturalsBelow.make(0, mPos);

        -- Step 1: a position selecting the appended slot `x` carries a zero
        -- coefficient — else `x` would lie in the span of the other vectors,
        -- all of which are `e`-vectors, so in `span(e)`.
        ∀ (p : Natural). p < len → NaturalsBelow.value(selection(p)) = m → coefficients(p) = Field.zero(f)
          by {
            take p : Natural;
            suppose p < len as pBelow;
            suppose NaturalsBelow.value(selection(p)) = m as pAtLast;
            suppose coefficients(p) ≠ Field.zero(f) as cpNonzero for contradiction {
                VectorSpace.InSpanOf(VectorSpace.dropIndex(VectorSpace.appendVector(e, x), selection(p)),
                    VectorSpace.appendVector(e, x)(selection(p)))
                    by VectorSpace.dropIndex_redundant(countPos := mPos, i0 := p);
                VectorSpace.appendVector(e, x)(selection(p)) = x by VectorSpace.appendVector_last as appAtP;
                VectorSpace.InSpanOf(VectorSpace.dropIndex(VectorSpace.appendVector(e, x), selection(p)), x)
                    by substituting appAtP as xInDrop;
                ∀ (i : NaturalsBelow(m)).
                    VectorSpace.InSpanOf(e, VectorSpace.dropIndex(VectorSpace.appendVector(e, x), selection(p))(i))
                  by {
                    take i : NaturalsBelow(m);
                    NaturalsBelow.value(i) < m by NaturalsBelow.below as iValBelow;
                    NaturalsBelow.value(NaturalsBelow.skip(NaturalsBelow.value(selection(p)), i))
                       = NaturalsBelow.skipValue(NaturalsBelow.value(selection(p)), NaturalsBelow.value(i))
                           by NaturalsBelow.skip_value
                       = NaturalsBelow.skipValue(m, NaturalsBelow.value(i)) by substituting pAtLast
                       = NaturalsBelow.value(i)
                           by NaturalsBelow.skipValue_below(below := iValBelow)
                       as skipVal;
                    NaturalsBelow.value(NaturalsBelow.skip(NaturalsBelow.value(selection(p)), i)) < m
                        by substituting skipVal as skipBelow;
                    VectorSpace.dropIndex(VectorSpace.appendVector(e, x), selection(p))(i)
                       = VectorSpace.appendVector(e, x)(NaturalsBelow.skip(NaturalsBelow.value(selection(p)), i))
                       = e(NaturalsBelow.make(
                             NaturalsBelow.value(NaturalsBelow.skip(NaturalsBelow.value(selection(p)), i)),
                             skipBelow))
                           by VectorSpace.appendVector_below as dropAtI;
                    VectorSpace.InSpanOf(e, e(NaturalsBelow.make(
                        NaturalsBelow.value(NaturalsBelow.skip(NaturalsBelow.value(selection(p)), i)), skipBelow)))
                        by VectorSpace.InSpanOf.member;
                    done by substituting dropAtI
                  } as dropInSpanE;
                VectorSpace.InSpanOf(e, x)
                    by VectorSpace.InSpanOf.transitive(
                           outerInhabitant := ei0,
                           generatorsInSpan := dropInSpanE, member := xInDrop);
                done
            }
          } as xVanish;

        -- Step 2: reduce the whole vanishing combination to one over `e` and
        -- invoke `e`'s independence.
        ¬(∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m)
            ∨ (∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m)
          by { (∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m)
                   ∨ ¬(∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m)
                   by Logic.excluded_middle;
               done by cases {
                 case ∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m as ex: { done }
                 case ¬(∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m) as nex: { done }
               } };
        done by cases {
          case ¬(∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m) as noLast: {
              ∀ (j : Natural). j < len → NaturalsBelow.value(selection(j)) < m
                by { take j : Natural; suppose j < len as jBelow;
                     NaturalsBelow.value(selection(j)) < 1 + m by NaturalsBelow.below;
                     NaturalsBelow.value(selection(j)) ≤ m by Natural.le_of_lt_one_plus;
                     NaturalsBelow.value(selection(j)) ≠ m
                         by { suppose NaturalsBelow.value(selection(j)) = m as jAtLast;
                              ∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m
                                  by { witness j with And.introduction(jBelow, jAtLast) };
                              done };
                     done by Natural.lt_of_le_of_ne } as allBelow;
              VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, len)
                 = VectorSpace.linearCombination(e, coefficients,
                       (j : Natural) ↦ NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j))), len)
                       by VectorSpace.appendVector_reduces_to_e(ei0 := ei0, allBelow := allBelow) as reduceEq;
              VectorSpace.linearCombination(e, coefficients,
                    (j : Natural) ↦ NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j))), len)
                 = VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, len)
                       by reduceEq
                 = VectorSpace.zero(V) by vanishes as eCombZero;
              ∀ (a b : Natural). a < len → b < len →
                  NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(a)))
                  = NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(b))) → a = b
                  by VectorSpace.appendVector_clamp_injective(ei0 := ei0,
                         selInjective := selectionInjective, allBelow := allBelow) as clampInj;
              done by eIndependent(len,
                  (j : Natural) ↦ NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j))),
                  coefficients, clampInj, eCombZero)
            }
          case ∃ (p : Natural). p < len ∧ NaturalsBelow.value(selection(p)) = m as lastExists: {
              choose p0 such that p0 < len ∧ NaturalsBelow.value(selection(p0)) = m from lastExists;
              p0 < len as p0Below;
              NaturalsBelow.value(selection(p0)) = m as p0AtLast;
              coefficients(p0) = Field.zero(f) by xVanish(p0, p0Below, p0AtLast) as cp0Zero;
              len = 1 + Natural.monus(len, 1)
                  by { 0 < len by { 0 ≤ p0 < len; done };
                       done by Natural.positive_one_plus_monus_one } as lenShape;
              p0 < 1 + Natural.monus(len, 1) by substituting lenShape as p0BelowShape;
              -- Drop position p0 (zero coefficient) to keep injectivity.
              VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, len)
                 = VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection,
                       1 + Natural.monus(len, 1)) by substituting lenShape
                 = VectorSpace.linearCombination(VectorSpace.appendVector(e, x),
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p0, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p0, i)), Natural.monus(len, 1))
                       by VectorSpace.linearCombination_drop_zero_position(
                              VectorSpace.appendVector(e, x), coefficients, selection,
                              Natural.monus(len, 1), p0, p0BelowShape, cp0Zero)
                 as droppedComb;
              -- The dropped selection avoids the x-slot: all below m.
              ∀ (j : Natural). j < Natural.monus(len, 1) →
                  NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, j))) < m
                by {
                  take j : Natural; suppose j < Natural.monus(len, 1) as jBelow;
                  NaturalsBelow.skipValue(p0, j) < len
                    by { NaturalsBelow.skipValue(p0, j) < 1 + Natural.monus(len, 1)
                             by NaturalsBelow.skipValue_bound(jv := p0,
                                    i := NaturalsBelow.make(j, jBelow));
                         done by substituting lenShape } as skipInLen;
                  NaturalsBelow.skipValue(p0, j) ≠ p0 by NaturalsBelow.skipValue_ne(jv := p0, j := j) as skipNeP0;
                  NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, j))) < 1 + m
                      by NaturalsBelow.below;
                  NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, j))) ≤ m
                      by Natural.le_of_lt_one_plus;
                  NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, j))) ≠ m
                    by { suppose NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, j))) = m as jAtLast;
                         NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, j)))
                             = NaturalsBelow.value(selection(p0)) by { done by substituting p0AtLast };
                         selection(NaturalsBelow.skipValue(p0, j)) = selection(p0)
                             by NaturalsBelow.equal_of_value(a := selection(NaturalsBelow.skipValue(p0, j)),
                                    b := selection(p0));
                         NaturalsBelow.skipValue(p0, j) = p0 by selectionInjective(
                             NaturalsBelow.skipValue(p0, j), p0, skipInLen, p0Below);
                         done };
                  done by Natural.lt_of_le_of_ne
                } as droppedBelow;
              VectorSpace.linearCombination(VectorSpace.appendVector(e, x),
                    (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p0, i)),
                    (i : Natural) ↦ selection(NaturalsBelow.skipValue(p0, i)), Natural.monus(len, 1))
                 = VectorSpace.linearCombination(e,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p0, i)),
                       (i : Natural) ↦ NaturalsBelow.clamp(ei0)(
                           NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, i)))),
                       Natural.monus(len, 1))
                       by VectorSpace.appendVector_reduces_to_e(ei0 := ei0, allBelow := droppedBelow)
                 as reduceEq;
              VectorSpace.linearCombination(e,
                    (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p0, i)),
                    (i : Natural) ↦ NaturalsBelow.clamp(ei0)(
                        NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, i)))),
                    Natural.monus(len, 1))
                 = VectorSpace.linearCombination(VectorSpace.appendVector(e, x),
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p0, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p0, i)), Natural.monus(len, 1))
                       by reduceEq
                 = VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, len)
                       by droppedComb
                 = VectorSpace.zero(V) by vanishes as eCombZero;
              -- The dropped selection is injective, so `e`-independence applies.
              ∀ (a b : Natural). a < Natural.monus(len, 1) → b < Natural.monus(len, 1) →
                  NaturalsBelow.clamp(ei0)(
                      NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, a))))
                  = NaturalsBelow.clamp(ei0)(
                      NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, b)))) → a = b
                by {
                  take a : Natural; take b : Natural;
                  suppose a < Natural.monus(len, 1) as aBelow;
                  suppose b < Natural.monus(len, 1) as bBelow;
                  suppose NaturalsBelow.clamp(ei0)(
                              NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, a))))
                          = NaturalsBelow.clamp(ei0)(
                              NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, b)))) as clampEq;
                  NaturalsBelow.skipValue(p0, a) < len
                    by { NaturalsBelow.skipValue(p0, a) < 1 + Natural.monus(len, 1)
                             by NaturalsBelow.skipValue_bound(jv := p0, i := NaturalsBelow.make(a, aBelow));
                         done by substituting lenShape } as skipALen;
                  NaturalsBelow.skipValue(p0, b) < len
                    by { NaturalsBelow.skipValue(p0, b) < 1 + Natural.monus(len, 1)
                             by NaturalsBelow.skipValue_bound(jv := p0, i := NaturalsBelow.make(b, bBelow));
                         done by substituting lenShape } as skipBLen;
                  NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, a))) < m
                      by droppedBelow(a, aBelow) as aValBelow;
                  NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, b))) < m
                      by droppedBelow(b, bBelow) as bValBelow;
                  NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, a)))
                     = NaturalsBelow.value(NaturalsBelow.make(
                           NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, a))), aValBelow))
                     = NaturalsBelow.value(NaturalsBelow.clamp(ei0)(
                           NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, a))))) by NaturalsBelow.clamp_below
                     = NaturalsBelow.value(NaturalsBelow.clamp(ei0)(
                           NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, b))))) by substituting clampEq
                     = NaturalsBelow.value(NaturalsBelow.make(
                           NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, b))), bValBelow))
                           by NaturalsBelow.clamp_below
                     = NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, b)));
                  selection(NaturalsBelow.skipValue(p0, a)) = selection(NaturalsBelow.skipValue(p0, b))
                      by NaturalsBelow.equal_of_value(a := selection(NaturalsBelow.skipValue(p0, a)),
                             b := selection(NaturalsBelow.skipValue(p0, b)));
                  NaturalsBelow.skipValue(p0, a) = NaturalsBelow.skipValue(p0, b)
                      by selectionInjective(NaturalsBelow.skipValue(p0, a), NaturalsBelow.skipValue(p0, b),
                             skipALen, skipBLen);
                  done by NaturalsBelow.skipValue_injective(jv := p0)
                } as droppedInj;
              ∀ (i : Natural). i < Natural.monus(len, 1) →
                  coefficients(NaturalsBelow.skipValue(p0, i)) = Field.zero(f)
                  by eIndependent(Natural.monus(len, 1),
                      (i : Natural) ↦ NaturalsBelow.clamp(ei0)(
                          NaturalsBelow.value(selection(NaturalsBelow.skipValue(p0, i)))),
                      (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p0, i)),
                      droppedInj, eCombZero) as skippedCoeffsZero;
              -- Recover every original coefficient: p0 is zero directly, and
              -- j ≠ p0 is `skipValue(p0, skipInverse(p0, j))`.
              take i : Natural;
              suppose i < len as iBelow;
              i = p0 ∨ i ≠ p0 by Logic.excluded_middle;
              done by cases {
                case i = p0 as iIsP0: {
                    coefficients(i) = coefficients(p0) by substituting iIsP0
                       = Field.zero(f) by cp0Zero;
                    done
                  }
                case i ≠ p0 as iNeP0: {
                    i < 1 + Natural.monus(len, 1) by substituting lenShape as iBelowShape;
                    p0 ≤ Natural.monus(len, 1)
                        by { p0 < 1 + Natural.monus(len, 1) by p0BelowShape;
                             done by Natural.le_of_lt_one_plus } as p0LeMonus;
                    NaturalsBelow.skipInverseValue(p0, i) < Natural.monus(len, 1)
                        by NaturalsBelow.skipInverseValue_bound(count := Natural.monus(len, 1), jv := p0,
                               x := i, xBound := iBelowShape, jvBound := p0LeMonus,
                               ne := iNeP0) as skipInvBelow;
                    NaturalsBelow.skipValue(p0, NaturalsBelow.skipInverseValue(p0, i)) = i
                        by NaturalsBelow.skipValue_skipInverse(ne := iNeP0) as roundTrip;
                    coefficients(i)
                       = coefficients(NaturalsBelow.skipValue(p0, NaturalsBelow.skipInverseValue(p0, i)))
                             by substituting roundTrip
                       = Field.zero(f) by skippedCoeffsZero(NaturalsBelow.skipInverseValue(p0, i), skipInvBelow);
                    done
                  }
              }
            }
        }
    }
  }
}

-- ----------------------------------------------------------------------
-- Brick 3 — a subspace of a finite-dimensional space is finite-dimensional.
--
-- Independent families inside the subspace are bounded in size by `dim V`
-- (their value-images are independent in `V`, and the exchange lemma caps an
-- independent family by a spanning one). So a largest independent size exists;
-- a family realising it must SPAN the subspace — otherwise a vector outside its
-- span would, by the append lemma, extend it to a strictly larger independent
-- family. That maximal independent family is therefore a basis.
theorem VectorSpace.subspace_finite_dimensional {f : Field} {V : VectorSpace(f)}
        (subset : Set(VectorSpace.carrier(V))) (subspace : IsSubspace(V, subset))
        (finiteV : VectorSpace.FiniteDimensional(V))
        : VectorSpace.FiniteDimensional(Subspace.vector_space(V, subset, subspace)) := {
  let S : VectorSpace(f) := Subspace.vector_space(V, subset, subspace);
  let d : Natural := VectorSpace.dimension(V, finiteV);
  VectorSpace.HasDimension(V, d) by VectorSpace.dimension_has_basis as vHasBasis;
  choose b such that VectorSpace.IsBasis(b) from vHasBasis;
  VectorSpace.Spans(b) by VectorSpace.IsBasis.spans as bSpans;

  -- Any independent family in S has size ≤ d.
  ∀ (k : Natural).
      (∃ (family : NaturalsBelow(k) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
      → k ≤ d
    by {
      take k : Natural;
      suppose ∃ (family : NaturalsBelow(k) → VectorSpace.carrier(S)).
          VectorSpace.LinearlyIndependent(family) as hasK;
      choose family such that VectorSpace.LinearlyIndependent(family) from hasK;
      VectorSpace.LinearlyIndependent(
          (i : NaturalsBelow(k)) ↦ Subspace.inclusion(V, subset, subspace)(family(i)))
          by Subspace.value_linearlyIndependent(subset, subspace, family) as valueIndependent;
      done by VectorSpace.exchange(k, d,
          (i : NaturalsBelow(k)) ↦ Subspace.inclusion(V, subset, subspace)(family(i)),
          b, valueIndependent, bSpans)
    } as sizeBound;

  -- No independent family of size 1 + d exists.
  ¬(∃ (family : NaturalsBelow(1 + d) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
    by {
      suppose ∃ (family : NaturalsBelow(1 + d) → VectorSpace.carrier(S)).
          VectorSpace.LinearlyIndependent(family) as has1d;
      1 + d ≤ d by sizeBound(1 + d, has1d);
      d < d by { d < 1 + d; d < 1 + d ≤ d; done };
      ¬(d < d) by Natural.lt_irreflexive;
      done
    } as notPlus1d;

  -- A least size with no independent family; the empty family shows it is ≥ 1.
  ∃ (j0 : Natural).
      ¬(∃ (family : NaturalsBelow(j0) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
      ∧ (∀ (k : Natural).
            ¬(∃ (family : NaturalsBelow(k) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
            → j0 ≤ k)
    by Natural.least_witness(
        (k : Natural) ↦ ¬(∃ (family : NaturalsBelow(k) → VectorSpace.carrier(S)).
            VectorSpace.LinearlyIndependent(family)), 1 + d, notPlus1d) as leastExists;
  choose j0 such that
      ¬(∃ (family : NaturalsBelow(j0) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
      ∧ (∀ (k : Natural).
            ¬(∃ (family : NaturalsBelow(k) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
            → j0 ≤ k)
      from leastExists;
  ¬(∃ (family : NaturalsBelow(j0) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
      as noneAtJ0;
  ∀ (k : Natural).
      ¬(∃ (family : NaturalsBelow(k) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family))
      → j0 ≤ k as j0IsLeast;

  VectorSpace.LinearlyIndependent((i : NaturalsBelow(0)) ↦ VectorSpace.zero(S))
      by VectorSpace.empty_family_independent as emptyIndependent;
  j0 ≠ 0
    by { suppose j0 = 0 as j0Zero;
         VectorSpace.LinearlyIndependent((i : NaturalsBelow(j0)) ↦ VectorSpace.zero(S))
             by { VectorSpace.LinearlyIndependent((i : NaturalsBelow(0)) ↦ VectorSpace.zero(S))
                      by emptyIndependent;
                  done by substituting j0Zero } as independentAtJ0;
         ∃ (family : NaturalsBelow(j0) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family)
             by { witness ((i : NaturalsBelow(j0)) ↦ VectorSpace.zero(S)) with independentAtJ0 };
         done } as j0Nonzero;
  j0 = 0 ∨ ∃ (m0 : Natural). j0 = 1 + m0 by Natural.zero_or_one_plus;
  done by cases {
    case j0 = 0 as contradiction0: { j0 ≠ 0 by j0Nonzero; done }
    case ∃ (m0 : Natural). j0 = 1 + m0 as j0Shape: {
        choose m0 such that j0 = 1 + m0 from j0Shape;
        -- The maximal independent family, of size m0.
        ∃ (family : NaturalsBelow(m0) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family)
          by {
            suppose ¬(∃ (family : NaturalsBelow(m0) → VectorSpace.carrier(S)).
                VectorSpace.LinearlyIndependent(family)) as noneAtM0 for contradiction {
              j0 ≤ m0 by j0IsLeast(m0, noneAtM0);
              m0 < j0 by { m0 < 1 + m0; done by substituting (j0 = 1 + m0) };
              m0 < j0 ≤ m0;
              done
            }
          } as maximalExists;
        choose eMax such that VectorSpace.LinearlyIndependent(eMax) from maximalExists;
        VectorSpace.LinearlyIndependent(eMax) as eMaxIndependent;
        -- It spans: a vector outside its span would extend it, contradicting maximality.
        VectorSpace.Spans(eMax)
          by {
            take y : VectorSpace.carrier(S);
            suppose ¬(y = VectorSpace.zero(S) ∨ VectorSpace.InSpanOf(eMax, y)) as yOutside
                for contradiction {
              VectorSpace.LinearlyIndependent(VectorSpace.appendVector(eMax, y))
                  by VectorSpace.independent_append_outside_span(eMax, y, eMaxIndependent, yOutside)
                  as appendIndependent;
              VectorSpace.LinearlyIndependent(VectorSpace.appendVector(eMax, y))
                  → (∃ (family : NaturalsBelow(j0) → VectorSpace.carrier(S)).
                        VectorSpace.LinearlyIndependent(family))
                by { suppose VectorSpace.LinearlyIndependent(VectorSpace.appendVector(eMax, y)) as ai;
                     ∃ (family : NaturalsBelow(1 + m0) → VectorSpace.carrier(S)).
                         VectorSpace.LinearlyIndependent(family)
                         by { witness VectorSpace.appendVector(eMax, y) with ai };
                     done by substituting (j0 = 1 + m0) } as bridge;
              ∃ (family : NaturalsBelow(j0) → VectorSpace.carrier(S)). VectorSpace.LinearlyIndependent(family)
                  by bridge(appendIndependent);
              done
            }
          } as eMaxSpans;
        VectorSpace.IsBasis(eMax)
            by { VectorSpace.LinearlyIndependent(eMax) by eMaxIndependent;
                 VectorSpace.Spans(eMax) by eMaxSpans; done } as eMaxBasis;
        VectorSpace.HasDimension(S, m0) by { witness eMax with eMaxBasis } as sHasDimension;
        done by { witness m0 with sHasDimension }
    }
  }
}

-- ----------------------------------------------------------------------
-- Brick 4 — basis extension. An independent family extends to a basis of a
-- finite-dimensional space by appending spanning vectors not yet in its span.

-- Span is monotone under append: anything in the span of `family` stays in the
-- span of `appendVector(family, x)` (the extra vector simply goes unused). The
-- witnessing combination is reindexed by the value-preserving inclusion
-- `NaturalsBelow(m) ↪ NaturalsBelow(1 + m)`.
theorem NaturalsBelow.value_below_one_plus {m : Natural} (i : NaturalsBelow(m))
        : NaturalsBelow.value(i) < 1 + m := {
  NaturalsBelow.value(i) < m by NaturalsBelow.below;
  NaturalsBelow.value(i) < m < 1 + m;
  done
}

-- The value-preserving inclusion `NaturalsBelow(m) ↪ NaturalsBelow(1 + m)`.
definition NaturalsBelow.widen {m : Natural} (i : NaturalsBelow(m)) : NaturalsBelow(1 + m) :=
  NaturalsBelow.make(NaturalsBelow.value(i), NaturalsBelow.value_below_one_plus(i))

theorem NaturalsBelow.widen_value {m : Natural} (i : NaturalsBelow(m))
        : NaturalsBelow.value(NaturalsBelow.widen(i)) = NaturalsBelow.value(i) :=
  done

theorem VectorSpace.appendVector_widen {f : Field} {V : VectorSpace(f)} {m : Natural}
        (family : NaturalsBelow(m) → VectorSpace.carrier(V)) (x : VectorSpace.carrier(V))
        (i : NaturalsBelow(m))
        : VectorSpace.appendVector(family, x)(NaturalsBelow.widen(i)) = family(i) := {
  NaturalsBelow.value(NaturalsBelow.widen(i)) < m
      by { NaturalsBelow.value(NaturalsBelow.widen(i)) = NaturalsBelow.value(i) by NaturalsBelow.widen_value;
           NaturalsBelow.value(i) < m by NaturalsBelow.below; done } as widenBelow;
  NaturalsBelow.make(NaturalsBelow.value(NaturalsBelow.widen(i)), widenBelow) = i
      by NaturalsBelow.equal_of_value(a := NaturalsBelow.make(NaturalsBelow.value(NaturalsBelow.widen(i)), widenBelow),
             b := i) as makeEqI;
  VectorSpace.appendVector(family, x)(NaturalsBelow.widen(i))
     = family(NaturalsBelow.make(NaturalsBelow.value(NaturalsBelow.widen(i)), widenBelow))
         by VectorSpace.appendVector_below
     = family(i) by substituting makeEqI;
  done
}

theorem VectorSpace.InSpanOf.append_monotone {f : Field} {V : VectorSpace(f)} {m : Natural}
        (family : NaturalsBelow(m) → VectorSpace.carrier(V)) (x v : VectorSpace.carrier(V))
        (member : VectorSpace.InSpanOf(family, v))
        : VectorSpace.InSpanOf(VectorSpace.appendVector(family, x), v) := {
  choose count, selection, coefficients such that
      v = VectorSpace.linearCombination(family, coefficients, selection, count) from member;
  v = VectorSpace.linearCombination(family, coefficients, selection, count) as vCombo;
  ∀ (i : Natural). i < count →
      coefficients(i) • VectorSpace.appendVector(family, x)(NaturalsBelow.widen(selection(i)))
      = coefficients(i) • family(selection(i))
    by {
      take i : Natural; suppose i < count as iBelow;
      VectorSpace.appendVector(family, x)(NaturalsBelow.widen(selection(i))) = family(selection(i))
          by VectorSpace.appendVector_widen as appAt;
      done by substituting appAt
    };
  v = VectorSpace.linearCombination(family, coefficients, selection, count) by vCombo
    = VectorSpace.linearCombination(VectorSpace.appendVector(family, x), coefficients,
          (i : Natural) ↦ NaturalsBelow.widen(selection(i)), count)
          by VectorSpace.linearCombination_congruence
    as vAppendCombo;
  witness count with witness ((i : Natural) ↦ NaturalsBelow.widen(selection(i)))
      with witness coefficients with vAppendCombo
}

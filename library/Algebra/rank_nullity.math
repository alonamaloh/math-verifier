-- Algebra/rank_nullity.math
--
-- The rank–nullity theorem: for a linear map `T : V → W` with `V`
-- finite-dimensional, `dim(V) = dim(ker T) + dim(im T)`. The route is basis
-- extension — no quotient space: extend a basis of the kernel to a basis of
-- `V`, and the `T`-images of the extension vectors form a basis of the image.
--
-- Everything the argument moves between a subspace and its ambient space runs
-- through ONE transport lemma, `Subspace.linearCombination_value`: the value of
-- a linear combination computed inside the subspace equals the combination of
-- the values computed in `V`. Independence and spanning transport between a
-- subspace family and its value-image in `V` are corollaries. This confines the
-- `Subtype`/`Subspace` boundary cost of the whole proof to that one induction.

module Algebra.rank_nullity

import Logic.basics
import Logic.exists
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.order
import Set.subtype
import Set.finite
import Set.equinumerous
import Algebra.field
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.field_bundle
import Algebra.vector_space
import Algebra.subspace
import Algebra.linear_map
import Algebra.linear_combination
import Algebra.span
import Algebra.exchange_lemma
import Algebra.basis_pruning
import Algebra.finite_dimensional
import Algebra.dimension

-- ----------------------------------------------------------------------
-- Brick 1 — the subtype-transport bridge.
--
-- The value of a linear combination formed inside the subspace
-- `Subspace.vector_space(V, subset, subspace)` is the linear combination of
-- the underlying values formed in `V`. Both `Subspace.add` and `Subspace.scale`
-- are defined so their value is the corresponding operation on values, so the
-- only real step in the induction is peeling the last term.
theorem Subspace.linearCombination_value {f : Field} {V : VectorSpace(f)} {I : Type(0)}
        (subset : Set(VectorSpace.carrier(V))) (subspace : IsSubspace(V, subset))
        (family : I → VectorSpace.carrier(Subspace.vector_space(V, subset, subspace)))
        (coefficients : Natural → Field.carrier(f))
        (selection : Natural → I) (count : Natural)
        : Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, count))
          = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
                coefficients, selection, count) :=
  by induction on count with IH {
    case base:
        Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, 0))
           = Subtype.value(VectorSpace.zero(Subspace.vector_space(V, subset, subspace)))
           = VectorSpace.zero(V)
           = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
                 coefficients, selection, 0)
    case step(m):
        Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, 1 + m))
           = Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, m)
                 + coefficients(m) • family(selection(m)))
                 by VectorSpace.linearCombination_add_one
           = Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, m))
                 + coefficients(m) • Subtype.value(family(selection(m)))
           = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
                 coefficients, selection, m)
                 + coefficients(m) • Subtype.value(family(selection(m)))
                 by IH
           = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
                 coefficients, selection, 1 + m)
                 by VectorSpace.linearCombination_add_one
  }

-- Independence and spanning transport across the value boundary, both
-- corollaries of the bridge above.

-- An independent family inside the subspace maps to an independent family in
-- `V`: a vanishing combination of the values, pushed through the bridge, is a
-- vanishing combination inside the subspace, whose coefficients the subspace
-- independence kills.
theorem Subspace.value_linearlyIndependent {f : Field} {V : VectorSpace(f)} {I : Type(0)}
        (subset : Set(VectorSpace.carrier(V))) (subspace : IsSubspace(V, subset))
        (family : I → VectorSpace.carrier(Subspace.vector_space(V, subset, subspace)))
        (independent : VectorSpace.LinearlyIndependent(family))
        : VectorSpace.LinearlyIndependent((i : I) ↦ Subtype.value(family(i))) := {
  take count : Natural;
  take selection : Natural → I;
  take coefficients : Natural → Field.carrier(f);
  suppose ∀ (a b : Natural). a < count → b < count → selection(a) = selection(b) → a = b
      as selectionInjective;
  suppose VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
              coefficients, selection, count) = VectorSpace.zero(V) as valuesVanish;
  Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, count))
     = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)), coefficients, selection, count)
           by Subspace.linearCombination_value
     = VectorSpace.zero(V) by valuesVanish
     = Subtype.value(VectorSpace.zero(Subspace.vector_space(V, subset, subspace)));
  VectorSpace.linearCombination(family, coefficients, selection, count)
      = VectorSpace.zero(Subspace.vector_space(V, subset, subspace))
      by Subtype.equal_of_value_equal as combinationZero;
  done by independent(count, selection, coefficients, selectionInjective, combinationZero)
}

-- A subspace family spans when every subspace vector's value is either zero or
-- a `V`-combination of the family values: the bridge turns that combination of
-- values back into a subspace combination, and equal values mean equal subtype
-- elements.
theorem Subspace.spans_of_value_covered {f : Field} {V : VectorSpace(f)} {I : Type(0)}
        (subset : Set(VectorSpace.carrier(V))) (subspace : IsSubspace(V, subset))
        (family : I → VectorSpace.carrier(Subspace.vector_space(V, subset, subspace)))
        (covered : ∀ (x : VectorSpace.carrier(Subspace.vector_space(V, subset, subspace))).
            Subtype.value(x) = VectorSpace.zero(V)
            ∨ VectorSpace.InSpanOf((i : I) ↦ Subtype.value(family(i)), Subtype.value(x)))
        : VectorSpace.Spans(family) := {
  take x : VectorSpace.carrier(Subspace.vector_space(V, subset, subspace));
  Subtype.value(x) = VectorSpace.zero(V)
      ∨ VectorSpace.InSpanOf((i : I) ↦ Subtype.value(family(i)), Subtype.value(x)) by covered;
  done by cases {
    case Subtype.value(x) = VectorSpace.zero(V) as valueZero: {
        Subtype.value(x) = VectorSpace.zero(V)
           = Subtype.value(VectorSpace.zero(Subspace.vector_space(V, subset, subspace)));
        x = VectorSpace.zero(Subspace.vector_space(V, subset, subspace))
            by Subtype.equal_of_value_equal;
        done
      }
    case VectorSpace.InSpanOf((i : I) ↦ Subtype.value(family(i)), Subtype.value(x)) as inSpan: {
        choose count, selection, coefficients such that
            Subtype.value(x) = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)),
                coefficients, selection, count) from inSpan;
        Subtype.value(x)
           = VectorSpace.linearCombination((i : I) ↦ Subtype.value(family(i)), coefficients, selection, count)
           = Subtype.value(VectorSpace.linearCombination(family, coefficients, selection, count))
                 by Subspace.linearCombination_value;
        x = VectorSpace.linearCombination(family, coefficients, selection, count)
            by Subtype.equal_of_value_equal as xIsCombination;
        VectorSpace.InSpanOf(family, x) by { witness count with witness selection
            with witness coefficients with xIsCombination };
        done
      }
  }
}

-- ----------------------------------------------------------------------
-- The image of a linear combination under a linear map is the linear
-- combination of the images: linearity commutes with the finite sum.
theorem LinearMap.apply_linearCombination {f : Field} {V W : VectorSpace(f)} {I : Type(0)}
        {T : VectorSpace.carrier(V) → VectorSpace.carrier(W)} (linear : IsLinearMap(V, W, T))
        (family : I → VectorSpace.carrier(V))
        (coefficients : Natural → Field.carrier(f))
        (selection : Natural → I) (count : Natural)
        : T(VectorSpace.linearCombination(family, coefficients, selection, count))
          = VectorSpace.linearCombination((i : I) ↦ T(family(i)), coefficients, selection, count) :=
  by induction on count with IH {
    case base:
        T(VectorSpace.linearCombination(family, coefficients, selection, 0))
           = T(VectorSpace.zero(V))
           = VectorSpace.zero(W) by LinearMap.preserves_zero
           = VectorSpace.linearCombination((i : I) ↦ T(family(i)), coefficients, selection, 0)
    case step(m):
        T(VectorSpace.linearCombination(family, coefficients, selection, 1 + m))
           = T(VectorSpace.linearCombination(family, coefficients, selection, m)
                 + coefficients(m) • family(selection(m)))
                 by VectorSpace.linearCombination_add_one
           = T(VectorSpace.linearCombination(family, coefficients, selection, m))
                 + T(coefficients(m) • family(selection(m)))
                 by LinearMap.additive(linear, VectorSpace.linearCombination(family, coefficients, selection, m),
                        coefficients(m) • family(selection(m)))
           = VectorSpace.linearCombination((i : I) ↦ T(family(i)), coefficients, selection, m)
                 + T(coefficients(m) • family(selection(m)))
                 by IH
           = VectorSpace.linearCombination((i : I) ↦ T(family(i)), coefficients, selection, m)
                 + coefficients(m) • T(family(selection(m)))
                 by LinearMap.homogeneous(linear, coefficients(m), family(selection(m)))
           = VectorSpace.linearCombination((i : I) ↦ T(family(i)), coefficients, selection, 1 + m)
                 by VectorSpace.linearCombination_add_one
  }

-- ----------------------------------------------------------------------
-- Brick 2 — the image of a finite-dimensional space is finite-dimensional.
--
-- The images `T(b(i))` of a basis `b` of `V`, lifted into the image subtype,
-- span the image subspace: every element of the image is `T(v)`, and `v` is a
-- combination of the basis, so `T(v)` is the corresponding combination of the
-- `T(b(i))` by linearity. Finitely generated, hence finite-dimensional by
-- pruning.
theorem LinearMap.image_finite_dimensional {f : Field} (V W : VectorSpace(f))
        (T : VectorSpace.carrier(V) → VectorSpace.carrier(W)) (linear : IsLinearMap(V, W, T))
        (finiteV : VectorSpace.FiniteDimensional(V))
        : VectorSpace.FiniteDimensional(
              Subspace.vector_space(W, LinearMap.image(V, W, T),
                  LinearMap.image_is_subspace(V, W, T, linear))) := {
  IsSubspace(W, LinearMap.image(V, W, T)) by LinearMap.image_is_subspace as imageSubspace;
  VectorSpace.HasDimension(V, VectorSpace.dimension(V, finiteV))
      by VectorSpace.dimension_has_basis as vHasBasis;
  choose basisV such that VectorSpace.IsBasis(basisV) from vHasBasis;
  VectorSpace.Spans(basisV) by VectorSpace.IsBasis.spans as basisSpans;

  -- The lifted image family: index i ↦ the image T(basisV(i)) as an element of
  -- the image subtype.
  ∀ (i : NaturalsBelow(VectorSpace.dimension(V, finiteV))).
      T(basisV(i)) ∈ LinearMap.image(V, W, T)
    by { take i : NaturalsBelow(VectorSpace.dimension(V, finiteV));
         T(basisV(i)) = T(basisV(i));
         done by witness basisV(i) with reflexivity(T(basisV(i))) } as imageHits;

  ∀ (x : VectorSpace.carrier(Subspace.vector_space(W, LinearMap.image(V, W, T), imageSubspace))).
      Subtype.value(x) = VectorSpace.zero(W)
      ∨ VectorSpace.InSpanOf(
            (i : NaturalsBelow(VectorSpace.dimension(V, finiteV))) ↦ T(basisV(i)),
            Subtype.value(x))
    by {
          take x : VectorSpace.carrier(Subspace.vector_space(W, LinearMap.image(V, W, T), imageSubspace));
          Subtype.value(x) ∈ LinearMap.image(V, W, T) by Subtype.property;
          ∃ (v : VectorSpace.carrier(V)). T(v) = Subtype.value(x);
          choose v such that T(v) = Subtype.value(x) as vHits;
          Subtype.value(x) = VectorSpace.zero(W)
              ∨ VectorSpace.InSpanOf(
                    (i : NaturalsBelow(VectorSpace.dimension(V, finiteV))) ↦ T(basisV(i)),
                    Subtype.value(x))
            by {
              v = VectorSpace.zero(V)
                  ∨ (∃ (count : Natural). ∃ (selection : Natural → NaturalsBelow(VectorSpace.dimension(V, finiteV))).
                     ∃ (coefficients : Natural → Field.carrier(f)).
                         v = VectorSpace.linearCombination(basisV, coefficients, selection, count))
                  by basisSpans;
              done by cases {
                case v = VectorSpace.zero(V) as vZero: {
                    Subtype.value(x) = T(v) by vHits
                       = T(VectorSpace.zero(V)) by substituting vZero
                       = VectorSpace.zero(W) by LinearMap.preserves_zero;
                    done
                  }
                case ∃ (count : Natural). ∃ (selection : Natural → NaturalsBelow(VectorSpace.dimension(V, finiteV))).
                     ∃ (coefficients : Natural → Field.carrier(f)).
                         v = VectorSpace.linearCombination(basisV, coefficients, selection, count) as vCombo: {
                    choose count, selection, coefficients such that
                        v = VectorSpace.linearCombination(basisV, coefficients, selection, count) from vCombo;
                    Subtype.value(x) = T(v) by vHits
                       = T(VectorSpace.linearCombination(basisV, coefficients, selection, count))
                             by substituting (v = VectorSpace.linearCombination(basisV, coefficients, selection, count))
                       = VectorSpace.linearCombination(
                             (i : NaturalsBelow(VectorSpace.dimension(V, finiteV))) ↦ T(basisV(i)),
                             coefficients, selection, count)
                             by LinearMap.apply_linearCombination(linear, basisV, coefficients, selection, count)
                       as valueIsCombination;
                    VectorSpace.InSpanOf(
                        (i : NaturalsBelow(VectorSpace.dimension(V, finiteV))) ↦ T(basisV(i)),
                        Subtype.value(x))
                      by { witness count with witness selection with witness coefficients
                           with valueIsCombination };
                    done
                  }
              }
            };
      done
    } as coveredFact;
  VectorSpace.FinitelyGenerated(Subspace.vector_space(W, LinearMap.image(V, W, T), imageSubspace))
      by { witness VectorSpace.dimension(V, finiteV)
           with witness ((i : NaturalsBelow(VectorSpace.dimension(V, finiteV)))
                ↦ Subtype.make(VectorSpace.carrier(W), LinearMap.image(V, W, T),
                      T(basisV(i)), imageHits(i)))
           with Subspace.spans_of_value_covered(covered := coveredFact) };
  done by VectorSpace.FinitelyGenerated.finite_dimensional
}

-- ----------------------------------------------------------------------
-- Finite-family construction: appending a vector, and dropping a
-- zero-coefficient position from a combination. These are the tools the
-- basis-extension bricks (3–5) need to GROW an independent family, the
-- mirror of `basis_pruning`'s shrinking `dropIndex`.

-- The family `family` with one extra vector `x` appended at index `m`: below
-- `m` it reads `family`, at `m` (the last index) it reads `x`. Built on
-- `Function.extendBelow` (fallback `x`), so its two characterising equations
-- are immediate.
definition VectorSpace.appendVector {f : Field} {V : VectorSpace(f)} {m : Natural}
        (family : NaturalsBelow(m) → VectorSpace.carrier(V))
        (x : VectorSpace.carrier(V))
        : NaturalsBelow(1 + m) → VectorSpace.carrier(V) :=
  (i : NaturalsBelow(1 + m)) ↦
    Function.extendBelow(family, x)(NaturalsBelow.value(i))

theorem VectorSpace.appendVector_below {f : Field} {V : VectorSpace(f)} {m : Natural}
        (family : NaturalsBelow(m) → VectorSpace.carrier(V))
        (x : VectorSpace.carrier(V)) (i : NaturalsBelow(1 + m))
        (below : NaturalsBelow.value(i) < m)
        : VectorSpace.appendVector(family, x)(i)
          = family(NaturalsBelow.make(NaturalsBelow.value(i), below)) :=
  VectorSpace.appendVector(family, x)(i)
     = Function.extendBelow(family, x)(NaturalsBelow.value(i))
     = family(NaturalsBelow.make(NaturalsBelow.value(i), below))
           by Function.extendBelow_below

theorem VectorSpace.appendVector_last {f : Field} {V : VectorSpace(f)} {m : Natural}
        (family : NaturalsBelow(m) → VectorSpace.carrier(V))
        (x : VectorSpace.carrier(V)) (i : NaturalsBelow(1 + m))
        (atLast : NaturalsBelow.value(i) = m)
        : VectorSpace.appendVector(family, x)(i) = x := {
  m ≤ NaturalsBelow.value(i) by { NaturalsBelow.value(i) = m; done } as past;
  VectorSpace.appendVector(family, x)(i)
     = Function.extendBelow(family, x)(NaturalsBelow.value(i))
     = x by Function.extendBelow_past(past := past);
  done
}

-- Dropping a zero-coefficient position: a combination of `1 + n` terms whose
-- `p`-th coefficient is zero equals the `n`-term combination that reindexes
-- the coefficients and selection by `NaturalsBelow.skipValue(p, ·)` — the
-- order-preserving position map that skips `p`. (The dropped term is `0 • …`,
-- so it contributes nothing.) Induction on `n`, peeling the last position and
-- splitting on whether `p` is that last position.
theorem VectorSpace.linearCombination_drop_zero_position {f : Field} {V : VectorSpace(f)}
        {I : Type(0)} (family : I → VectorSpace.carrier(V))
        (coefficients : Natural → Field.carrier(f)) (selection : Natural → I)
        : ∀ (n : Natural). ∀ (p : Natural). p < 1 + n
              → coefficients(p) = Field.zero(f)
              → VectorSpace.linearCombination(family, coefficients, selection, 1 + n)
                = VectorSpace.linearCombination(family,
                      (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                      (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), n) :=
  by induction on n with IH {
    case base: {
        take p : Natural;
        suppose p < 1 + 0 as pBelow;
        suppose coefficients(p) = Field.zero(f) as coeffZero;
        p = 0 by { p ≤ 0 by Natural.le_of_lt_one_plus; done };
        VectorSpace.linearCombination(family, coefficients, selection, 1 + 0)
           = coefficients(0) • family(selection(0)) by VectorSpace.linearCombination_one
           = coefficients(p) • family(selection(p)) by substituting (p = 0)
           = Field.zero(f) • family(selection(p)) by substituting coeffZero
           = VectorSpace.zero(V) by VectorSpace.zero_scale
           = VectorSpace.linearCombination(family,
                 (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                 (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), 0)
      }
    case step(q): {
        take p : Natural;
        suppose p < 1 + (1 + q) as pBelow;
        suppose coefficients(p) = Field.zero(f) as coeffZero;
        p < 1 + q ∨ p = 1 + q by Natural.le_of_lt_one_plus;
        done by cases {
          case p < 1 + q as pNotLast: {
              -- `p` is not last: peel the last term (unchanged by the skip,
              -- since `skipValue(p, q) = 1 + q` for `q ≥ p`) and recurse.
              ¬(q < p) by { suppose q < p as qLtP; p ≤ q by Natural.le_of_lt_one_plus;
                            q < p ≤ q; done };
              NaturalsBelow.skipValue(p, q) = 1 + q
                  by NaturalsBelow.skipValue_above as skipLast;
              VectorSpace.linearCombination(family,
                    (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                    (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), 1 + q)
                 = VectorSpace.linearCombination(family,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), q)
                   + coefficients(NaturalsBelow.skipValue(p, q))
                       • family(selection(NaturalsBelow.skipValue(p, q)))
                       by VectorSpace.linearCombination_add_one
                 = VectorSpace.linearCombination(family,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), q)
                   + coefficients(1 + q) • family(selection(1 + q))
                       by substituting skipLast
                 as rhsPeeled;
              VectorSpace.linearCombination(family, coefficients, selection, 1 + (1 + q))
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                   + coefficients(1 + q) • family(selection(1 + q))
                       by VectorSpace.linearCombination_add_one
                 = VectorSpace.linearCombination(family,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), q)
                   + coefficients(1 + q) • family(selection(1 + q))
                       by IH(p, pNotLast, coeffZero)
                 = VectorSpace.linearCombination(family,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), 1 + q)
                       by rhsPeeled
            }
          case p = 1 + q as pLast: {
              -- The dropped position is the last one; the skip is the identity
              -- below `1 + q`, so the reindexed prefix is unchanged.
              ∀ (i : Natural). i < 1 + q →
                  coefficients(i) = coefficients(NaturalsBelow.skipValue(p, i))
                by { take i : Natural; suppose i < 1 + q as iBelow;
                     i < p by substituting pLast;
                     NaturalsBelow.skipValue(p, i) = i by NaturalsBelow.skipValue_below;
                     done by substituting (NaturalsBelow.skipValue(p, i) = i) } as coeffAgree;
              ∀ (i : Natural). i < 1 + q →
                  selection(i) = selection(NaturalsBelow.skipValue(p, i))
                by { take i : Natural; suppose i < 1 + q as iBelow;
                     i < p by substituting pLast;
                     NaturalsBelow.skipValue(p, i) = i by NaturalsBelow.skipValue_below;
                     done by substituting (NaturalsBelow.skipValue(p, i) = i) } as selAgree;
              coefficients(1 + q) = Field.zero(f)
                  by { coefficients(1 + q) = coefficients(p) by substituting pLast
                       = Field.zero(f) by coeffZero; done } as lastZero;
              VectorSpace.linearCombination(family, coefficients, selection, 1 + (1 + q))
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                   + coefficients(1 + q) • family(selection(1 + q))
                       by VectorSpace.linearCombination_add_one
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                   + Field.zero(f) • family(selection(1 + q))
                       by substituting lastZero
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                   + VectorSpace.zero(V) by VectorSpace.zero_scale
                 = VectorSpace.linearCombination(family, coefficients, selection, 1 + q)
                 = VectorSpace.linearCombination(family,
                       (i : Natural) ↦ coefficients(NaturalsBelow.skipValue(p, i)),
                       (i : Natural) ↦ selection(NaturalsBelow.skipValue(p, i)), 1 + q)
                       by VectorSpace.linearCombination_pointwise_below(
                              coefficientsAgree := coeffAgree, selectionsAgree := selAgree)
            }
        }
      }
  }

-- When every position of a combination over `appendVector(e, x)` selects an
-- index below `m` (an `e`-vector, never the appended `x`), the combination IS
-- a combination over `e` alone, reindexed by the clamp `NaturalsBelow(1+m) →
-- NaturalsBelow(m)`. (`ei0` is any `e`-index, supplying the clamp fallback.)
theorem VectorSpace.appendVector_reduces_to_e {f : Field} {V : VectorSpace(f)} {m : Natural}
        (e : NaturalsBelow(m) → VectorSpace.carrier(V)) (x : VectorSpace.carrier(V))
        (coefficients : Natural → Field.carrier(f))
        (selection : Natural → NaturalsBelow(1 + m)) (count : Natural)
        (ei0 : NaturalsBelow(m))
        (allBelow : ∀ (j : Natural). j < count → NaturalsBelow.value(selection(j)) < m)
        : VectorSpace.linearCombination(VectorSpace.appendVector(e, x), coefficients, selection, count)
          = VectorSpace.linearCombination(e, coefficients,
                (j : Natural) ↦ NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j))), count) := {
  ∀ (j : Natural). j < count →
      coefficients(j) • VectorSpace.appendVector(e, x)(selection(j))
      = coefficients(j) • e(NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j))))
    by {
      take j : Natural;
      suppose j < count as jBelow;
      NaturalsBelow.value(selection(j)) < m by allBelow as valBelow;
      VectorSpace.appendVector(e, x)(selection(j))
          = e(NaturalsBelow.make(NaturalsBelow.value(selection(j)), valBelow))
          by VectorSpace.appendVector_below as appAt;
      NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j)))
          = NaturalsBelow.make(NaturalsBelow.value(selection(j)), valBelow)
          by NaturalsBelow.clamp_below as clampAt;
      coefficients(j) • VectorSpace.appendVector(e, x)(selection(j))
         = coefficients(j) • e(NaturalsBelow.make(NaturalsBelow.value(selection(j)), valBelow))
             by substituting appAt
         = coefficients(j) • e(NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(j))))
             by substituting clampAt
    };
  done by VectorSpace.linearCombination_congruence
}

-- The clamp reindex of an injective, below-`m` selection is itself injective:
-- distinct positions give distinct values give distinct clamped indices.
theorem VectorSpace.appendVector_clamp_injective {f : Field} {V : VectorSpace(f)} {m : Natural}
        (selection : Natural → NaturalsBelow(1 + m)) (count : Natural) (ei0 : NaturalsBelow(m))
        (selInjective : ∀ (a b : Natural). a < count → b < count → selection(a) = selection(b) → a = b)
        (allBelow : ∀ (j : Natural). j < count → NaturalsBelow.value(selection(j)) < m)
        : ∀ (a b : Natural). a < count → b < count →
              NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(a)))
              = NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(b))) → a = b := {
  take a : Natural; take b : Natural;
  suppose a < count as aBelow;
  suppose b < count as bBelow;
  suppose NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(a)))
          = NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(b))) as clampEqual;
  NaturalsBelow.value(selection(a)) < m by allBelow as aValBelow;
  NaturalsBelow.value(selection(b)) < m by allBelow as bValBelow;
  NaturalsBelow.value(selection(a))
     = NaturalsBelow.value(NaturalsBelow.make(NaturalsBelow.value(selection(a)), aValBelow))
     = NaturalsBelow.value(NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(a))))
           by NaturalsBelow.clamp_below
     = NaturalsBelow.value(NaturalsBelow.clamp(ei0)(NaturalsBelow.value(selection(b))))
           by substituting clampEqual
     = NaturalsBelow.value(NaturalsBelow.make(NaturalsBelow.value(selection(b)), bValBelow))
           by NaturalsBelow.clamp_below
     = NaturalsBelow.value(selection(b));
  selection(a) = selection(b) by NaturalsBelow.equal_of_value(a := selection(a), b := selection(b));
  done by selInjective
}

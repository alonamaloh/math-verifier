        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusDoubleSquareForm, (13 : ℤ)) := {
  done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents(
      a := 3, b := 2, k := 0)
}

theorem Matrix.sumOfTwoSquaresPlusDoubleSquareForm_not_represents_fourteen
        : ¬(Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusDoubleSquareForm, (14 : ℤ))) := {
  suppose Matrix.Represents(
      Matrix.sumOfTwoSquaresPlusDoubleSquareForm, (14 : ℤ)) as represented;
  choose x : RingVector(Integer.commutative_ring_bundle, 1 + 2) such that
      Matrix.quadraticForm(
          Matrix.sumOfTwoSquaresPlusDoubleSquareForm, x) = 14
      from represented;
  let y : RingVector(Integer.commutative_ring_bundle, 2) :=
      RingVector.restrict(x);
  let t : ℤ := x(NaturalsBelow.top(2));
  let q : ℤ := Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, y);
  q + t * t * 2
     = Matrix.quadraticForm(
           Matrix.sumOfTwoSquaresPlusDoubleSquareForm, x)
           by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_value
     = 14
  as valueIsFourteen;
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, q)
      by { witness y with done };
  0 ≤ q
      by Matrix.sumOfTwoSquaresForm_quadraticForm_nonnegative;
  2 * (t * t)
     = t * t * 2
     = 0 + t * t * 2
     ≤ q + t * t * 2 by Integer.add_preserves_less_or_equal
     = 14 by valueIsFourteen
     = 2 * 7;
  t * t ≤ 7 by Integer.cancel_le_by_positive;
  t * t ≤ 7 < 8;
  t * t < 8 by Integer.LessThan.transitive_left;
  t = -2 ∨ t = -1 ∨ t = 0 ∨ t = 1 ∨ t = 2
      by Integer.square_below_eight;
  done by cases {
    case t = -2: {
        q + (-(2 : ℤ)) * (-(2 : ℤ)) * 2 = 14
            by substituting (t = -2) as specializedValue;
        q = 6 by linear_combination(specializedValue) as qIsSix;
        Matrix.Represents(Matrix.sumOfTwoSquaresForm, (6 : ℤ))
            by substituting qIsSix;
        done by Matrix.sumOfTwoSquaresForm_not_represents_six
      }
    case t = -1 ∨ t = 0 ∨ t = 1 ∨ t = 2: done by cases {
        case t = -1: {
            q + (-(1 : ℤ)) * (-(1 : ℤ)) * 2 = 14
                by substituting (t = -1) as specializedValue;
            q = 12 by linear_combination(specializedValue) as qIsTwelve;
            Matrix.Represents(Matrix.sumOfTwoSquaresForm, (12 : ℤ))
                by substituting qIsTwelve;
            done by Matrix.sumOfTwoSquaresForm_not_represents_twelve
          }
        case t = 0 ∨ t = 1 ∨ t = 2: done by cases {
            case t = 0: {
                q + 0 * 0 * 2 = 14
                    by substituting (t = 0) as specializedValue;
                q = 14 by linear_combination(specializedValue) as qIsFourteen;
                Matrix.Represents(Matrix.sumOfTwoSquaresForm, (14 : ℤ))
                    by substituting qIsFourteen;
                done by Matrix.sumOfTwoSquaresForm_not_represents_fourteen
              }
            case t = 1 ∨ t = 2: done by cases {
                case t = 1: {
                    q + 1 * 1 * 2 = 14
                        by substituting (t = 1) as specializedValue;
                    q = 12 by linear_combination(specializedValue) as qIsTwelve;
                    Matrix.Represents(Matrix.sumOfTwoSquaresForm, (12 : ℤ))
                        by substituting qIsTwelve;
                    done by Matrix.sumOfTwoSquaresForm_not_represents_twelve
                  }
                case t = 2: {
                    q + 2 * 2 * 2 = 14
                        by substituting (t = 2) as specializedValue;
                    q = 6 by linear_combination(specializedValue) as qIsSix;
                    Matrix.Represents(Matrix.sumOfTwoSquaresForm, (6 : ℤ))
                        by substituting qIsSix;
                    done by Matrix.sumOfTwoSquaresForm_not_represents_six
                  }
              }
          }
      }
  }
}

theorem Matrix.sumOfTwoSquaresPlusDoubleSquareForm_truant_fourteen
        : Matrix.IsTruant(
            Matrix.sumOfTwoSquaresPlusDoubleSquareForm, 14) := {
  14 ≥ 1;
  ¬(Matrix.Represents(
      Matrix.sumOfTwoSquaresPlusDoubleSquareForm, (14 : ℤ))) by {
    done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_not_represents_fourteen
  };
  ∀ (s : ℕ). s ≥ 1 → s < 14 →
      Matrix.Represents(
          Matrix.sumOfTwoSquaresPlusDoubleSquareForm, (s : ℤ))
      by (s : ℕ) (positive : s ≥ 1) (belowFourteen : s < 14) ↦ {
          s = 1 ∨ s = 2 ∨ s = 3 ∨ s = 4 ∨ s = 5 ∨ s = 6
            ∨ s = 7 ∨ s = 8 ∨ s = 9 ∨ s = 10 ∨ s = 11 ∨ s = 12
            ∨ s = 13 by Natural.positive_below_fourteen;
          done by cases {
            case s = 1:
              done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents_one
            case s = 2 ∨ s = 3 ∨ s = 4 ∨ s = 5 ∨ s = 6
                ∨ s = 7 ∨ s = 8 ∨ s = 9 ∨ s = 10 ∨ s = 11 ∨ s = 12
                ∨ s = 13: done by cases {
                case s = 2:
                  done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents_two
                case s = 3 ∨ s = 4 ∨ s = 5 ∨ s = 6 ∨ s = 7
                    ∨ s = 8 ∨ s = 9 ∨ s = 10 ∨ s = 11 ∨ s = 12
                    ∨ s = 13: done by cases {
                    case s = 3:
                      done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents_three
                    case s = 4 ∨ s = 5 ∨ s = 6 ∨ s = 7 ∨ s = 8
                        ∨ s = 9 ∨ s = 10 ∨ s = 11 ∨ s = 12 ∨ s = 13:
                      done by cases {
                        case s = 4:
                          done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents_four
                        case s = 5 ∨ s = 6 ∨ s = 7 ∨ s = 8 ∨ s = 9
                            ∨ s = 10 ∨ s = 11 ∨ s = 12 ∨ s = 13:
                          done by cases {
                            case s = 5:
                              done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents_five
                            case s = 6 ∨ s = 7 ∨ s = 8 ∨ s = 9
                                ∨ s = 10 ∨ s = 11 ∨ s = 12 ∨ s = 13:
                              done by cases {
                                case s = 6:
                                  done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents_six
                                case s = 7 ∨ s = 8 ∨ s = 9 ∨ s = 10
                                    ∨ s = 11 ∨ s = 12 ∨ s = 13:
                                  done by cases {
                                    case s = 7:
                                      done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents_seven
                                    case s = 8 ∨ s = 9 ∨ s = 10
                                        ∨ s = 11 ∨ s = 12 ∨ s = 13:
                                      done by cases {
                                        case s = 8:
                                          done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents_eight
                                        case s = 9 ∨ s = 10 ∨ s = 11
                                            ∨ s = 12 ∨ s = 13:
                                          done by cases {
                                            case s = 9:
                                              done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents_nine
                                            case s = 10 ∨ s = 11
                                                ∨ s = 12 ∨ s = 13:
                                              done by cases {
                                                case s = 10:
                                                  done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents_ten
                                                case s = 11 ∨ s = 12
                                                    ∨ s = 13:
                                                  done by cases {
                                                    case s = 11:
                                                      done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents_eleven
                                                    case s = 12 ∨ s = 13:
                                                      done by cases {
                                                        case s = 12:
                                                          done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents_twelve
                                                        case s = 13:
                                                          done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents_thirteen
                                                      }
                                                  }
                                              }
                                          }
                                      }
                                  }
                              }
                          }
                      }
                  }
              }
          }
        };
  done
}

theorem Matrix.sumOfTwoSquaresPlusDoubleSquareForm_truant
        : Matrix.truant(
            Matrix.sumOfTwoSquaresPlusDoubleSquareForm) = 14 := {
  done by Matrix.truant_equals
}

theorem Matrix.sumOfTwoSquaresPlusDoubleSquareForm_isometric_oneUnitBorderCandidate
        (a b : ℤ) (unitValue : a * a + b * b = 1)
        : Matrix.IsIsometric(
            Matrix.sumOfTwoSquaresPlusDoubleSquareForm,
            Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) := {
  let v : RingVector(Integer.commutative_ring_bundle, 2) :=
      RingVector.twoCoordinates(a, b);
  Matrix.sumOfTwoSquaresForm · v
     = Matrix.identity(Integer.commutative_ring_bundle, 2) · v
           by substituting Matrix.sumOfTwoSquaresForm_is_identity
     = v by Matrix.applyVector_identity
  as actionReads;
  Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, v)
     = a * a + b * b
           by Matrix.sumOfTwoSquaresForm_twoCoordinates_value
     = (1 : ℤ) by unitValue
  as valueReads;
  Matrix.topShear(v)ᵀ
      * Matrix.sumOfTwoSquaresPlusDoubleSquareForm
      * Matrix.topShear(v)
     = Matrix.borderedAssembly(
           Matrix.sumOfTwoSquaresForm,
           Matrix.sumOfTwoSquaresForm · v,
           2 + Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, v))
           by Matrix.topShear_pullback_diagonalExtension
     = Matrix.borderedAssembly(
           Matrix.sumOfTwoSquaresForm, v,
           2 + Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, v))
           by substituting actionReads
     = Matrix.borderedAssembly(
           Matrix.sumOfTwoSquaresForm, v, (2 : ℤ) + 1)
           by substituting valueReads
     = Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)
  as pullbackReads;
  Matrix.IsInvertible(Matrix.topShear(v))
      by Matrix.topShear_invertible;
  Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)
      = Matrix.topShear(v)ᵀ
        * Matrix.sumOfTwoSquaresPlusDoubleSquareForm
        * Matrix.topShear(v)
      by pullbackReads;
  witness Matrix.topShear(v) with done
}

theorem Matrix.sumOfTwoSquaresOneUnitBorderCandidate_truant
        (a b : ℤ) (unitValue : a * a + b * b = 1)
        : Matrix.truant(
            Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 14 := {
  Matrix.IsIsometric(
      Matrix.sumOfTwoSquaresPlusDoubleSquareForm,
      Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b))
      by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_isometric_oneUnitBorderCandidate
      as isometric;
  done by Matrix.isometric_truant_equals(
      isometric := isometric,
      isTruant := Matrix.sumOfTwoSquaresPlusDoubleSquareForm_truant_fourteen)
}

-- ----------------------------------------------------------------------
-- A first orbit in the 23-candidate cone above x²+2y².
--
-- Pulling diag(1,2,3) back by the second-coordinate top shear produces
-- border (0,2) and corner 5. The only coordinate split is packaged once in
-- the action lemma; the isometry proof itself stays entirely at matrix level.

definition Matrix.squarePlusDoubleSquarePlusTripleSquareForm
        : Matrix(Integer.commutative_ring_bundle, 1 + 2, 1 + 2) :=
  Matrix.diagonalExtension(Matrix.squarePlusDoubleSquareForm, (3 : ℤ))

definition Matrix.squarePlusDoubleSquareSecondColumn
        : RingVector(Integer.commutative_ring_bundle, 2) :=
  RingVector.twoCoordinates((0 : ℤ), (2 : ℤ))

definition Matrix.squarePlusDoubleSquareSecondColumnCandidate
        : Matrix(Integer.commutative_ring_bundle, 1 + 2, 1 + 2) :=
  Matrix.borderedAssembly(
      Matrix.squarePlusDoubleSquareForm,
      Matrix.squarePlusDoubleSquareSecondColumn,
      (5 : ℤ))

theorem Matrix.squarePlusDoubleSquareForm_apply_secondBasis
        : Matrix.squarePlusDoubleSquareForm
            · Matrix.standardBasisRow(
                Integer.commutative_ring_bundle,
                2, NaturalsBelow.secondOfTwo)
          = Matrix.squarePlusDoubleSquareSecondColumn := {
  let e : RingVector(Integer.commutative_ring_bundle, 2) :=
      Matrix.standardBasisRow(
          Integer.commutative_ring_bundle,
          2, NaturalsBelow.secondOfTwo);
  ∀ (i : NaturalsBelow(2)).
      (Matrix.squarePlusDoubleSquareForm · e)(i)
        = Matrix.squarePlusDoubleSquareSecondColumn(i)
      by (i : NaturalsBelow(2)) ↦ {
          i = NaturalsBelow.firstOfTwo
            ∨ i = NaturalsBelow.secondOfTwo
            by NaturalsBelow.two_split;
          done by cases {
            case i = NaturalsBelow.firstOfTwo as first: {
                ¬(NaturalsBelow.firstOfTwo
                    = NaturalsBelow.secondOfTwo)
                    by NaturalsBelow.firstOfTwo_not_secondOfTwo;
                (Matrix.squarePlusDoubleSquareForm · e)(i)
                   = (Matrix.squarePlusDoubleSquareForm · e)(
                       NaturalsBelow.firstOfTwo)
                         by substituting first
                   = Matrix.squarePlusDoubleSquareForm(
                       NaturalsBelow.firstOfTwo,
                       NaturalsBelow.secondOfTwo)
                         by Matrix.applyVector_standardBasisRow
                   = (Matrix.identity(
                         Integer.commutative_ring_bundle, 2)
                       + Matrix.lowerRightUnit)(
                           NaturalsBelow.firstOfTwo,
                           NaturalsBelow.secondOfTwo)
                         by substituting
                             Matrix.squarePlusDoubleSquareForm_splits
                   = Matrix.identity(
                         Integer.commutative_ring_bundle, 2)(
                           NaturalsBelow.firstOfTwo,
                           NaturalsBelow.secondOfTwo)
                     + Matrix.lowerRightUnit(
                         NaturalsBelow.firstOfTwo,
                         NaturalsBelow.secondOfTwo)
                   = 0 + Matrix.lowerRightUnit(
                         NaturalsBelow.firstOfTwo,
                         NaturalsBelow.secondOfTwo)
                         by substituting Matrix.identity_entry_off
                   = (0 : ℤ)
                         by substituting
                             Matrix.lowerRightUnit_top_vanishes
                   = Matrix.squarePlusDoubleSquareSecondColumn(
                       NaturalsBelow.firstOfTwo)
                         by RingVector.twoCoordinates_first
                   = Matrix.squarePlusDoubleSquareSecondColumn(i)
                         by substituting first
                as entryReads;
                done by entryReads
              }
            case i = NaturalsBelow.secondOfTwo as second: {
                (Matrix.squarePlusDoubleSquareForm · e)(i)
                   = (Matrix.squarePlusDoubleSquareForm · e)(
                       NaturalsBelow.secondOfTwo)
                         by substituting second
                   = Matrix.squarePlusDoubleSquareForm(
                       NaturalsBelow.secondOfTwo,
                       NaturalsBelow.secondOfTwo)
                         by Matrix.applyVector_standardBasisRow
                   = (2 : ℤ)
                         by
                           Matrix.squarePlusDoubleSquareForm_second_diagonal
                   = Matrix.squarePlusDoubleSquareSecondColumn(
                       NaturalsBelow.secondOfTwo)
                         by RingVector.twoCoordinates_second
                   = Matrix.squarePlusDoubleSquareSecondColumn(i)
                         by substituting second
                as entryReads;
                done by entryReads
              }
          }
        };
  done by RingVector.equal_of_pointwise
}

theorem Matrix.squarePlusDoubleSquareForm_secondBasis_value
        : Matrix.quadraticForm(
            Matrix.squarePlusDoubleSquareForm,
            Matrix.standardBasisRow(
                Integer.commutative_ring_bundle,
                2, NaturalsBelow.secondOfTwo)) = (2 : ℤ) := {
  Matrix.quadraticForm(
      Matrix.squarePlusDoubleSquareForm,
      Matrix.standardBasisRow(
          Integer.commutative_ring_bundle,
          2, NaturalsBelow.secondOfTwo))
     = Matrix.squarePlusDoubleSquareForm(
           NaturalsBelow.secondOfTwo,
           NaturalsBelow.secondOfTwo)
           by Matrix.quadraticForm_standardBasis
     = (2 : ℤ)
           by Matrix.squarePlusDoubleSquareForm_second_diagonal;
  done
}

theorem Matrix.squarePlusDoubleSquareSecondColumnCandidate_isometric
        : Matrix.IsIsometric(
            Matrix.squarePlusDoubleSquarePlusTripleSquareForm,
            Matrix.squarePlusDoubleSquareSecondColumnCandidate) := {
  let e : RingVector(Integer.commutative_ring_bundle, 2) :=
      Matrix.standardBasisRow(
          Integer.commutative_ring_bundle,
          2, NaturalsBelow.secondOfTwo);
  Matrix.IsIsometric(
      Matrix.diagonalExtension(
          Matrix.squarePlusDoubleSquareForm, (3 : ℤ)),
      Matrix.borderedAssembly(
          Matrix.squarePlusDoubleSquareForm,
          Matrix.squarePlusDoubleSquareForm · e,
          (3 : ℤ) + Matrix.quadraticForm(
              Matrix.squarePlusDoubleSquareForm, e)))
      by Matrix.diagonalExtension_isometric_borderedAssembly(
          symmetric :=
              Matrix.squarePlusDoubleSquareForm_symmetric);
  Matrix.squarePlusDoubleSquareForm · e
      = Matrix.squarePlusDoubleSquareSecondColumn
      by Matrix.squarePlusDoubleSquareForm_apply_secondBasis
      as borderReads;
  (3 : ℤ) + Matrix.quadraticForm(
      Matrix.squarePlusDoubleSquareForm, e) = (5 : ℤ)
      by substituting
          Matrix.squarePlusDoubleSquareForm_secondBasis_value
      as cornerReads;
  Matrix.borderedAssembly(
      Matrix.squarePlusDoubleSquareForm,
      Matrix.squarePlusDoubleSquareForm · e,
      (3 : ℤ) + Matrix.quadraticForm(
          Matrix.squarePlusDoubleSquareForm, e))
     = Matrix.borderedAssembly(
           Matrix.squarePlusDoubleSquareForm,
           Matrix.squarePlusDoubleSquareSecondColumn,
           (3 : ℤ) + Matrix.quadraticForm(
               Matrix.squarePlusDoubleSquareForm, e))
           by substituting borderReads
     = Matrix.borderedAssembly(
           Matrix.squarePlusDoubleSquareForm,
           Matrix.squarePlusDoubleSquareSecondColumn,
           (5 : ℤ))
           by substituting cornerReads
     = Matrix.squarePlusDoubleSquareSecondColumnCandidate
  as candidateReads;
  done by substituting candidateReads
}

        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusDoubleSquareForm, (6 : ℤ)) := {
  done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents(
      a := 2, b := 0, k := 1)
}


        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusDoubleSquareForm, (3 : ℤ)) := {
  done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents(
      a := 1, b := 0, k := 1)
}


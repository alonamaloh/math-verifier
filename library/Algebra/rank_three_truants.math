-- The rank-two classification below 16 already contains all the arithmetic
-- needed for the negative half of the next truant calculation.  Package its
-- conversion from Integer witnesses once, then cite it at the two residuals
-- 7 and 10 that arise after fixing the third coordinate.
theorem Matrix.squarePlusDoubleSquareForm_not_represents_below_sixteen
        (target : ℕ) (targetBelow : target < 16)
        (notSmallValue :
          ¬(Natural.IsSquarePlusDoubleSquareValueBelowSixteen(target)))
        : ¬(Matrix.Represents(
            Matrix.squarePlusDoubleSquareForm, (target : ℤ))) := {
  suppose Matrix.Represents(
      Matrix.squarePlusDoubleSquareForm, (target : ℤ)) as represented;
  ∃ (a b : ℤ). (target : ℤ) = a * a + 2 * (b * b)
      by Matrix.squarePlusDoubleSquareForm_represents_only_squares;
  choose a such that
      ∃ (b : ℤ). (target : ℤ) = a * a + 2 * (b * b);
  choose b such that (target : ℤ) = a * a + 2 * (b * b);
  ∃ (m : ℕ). a * a = ((m * m : ℕ) : ℤ)
      by Integer.square_as_natural_square;
  choose m such that a * a = ((m * m : ℕ) : ℤ);
  ∃ (n : ℕ). b * b = ((n * n : ℕ) : ℤ)
      by Integer.square_as_natural_square;
  choose n such that b * b = ((n * n : ℕ) : ℤ);
  (target : ℤ)
     = a * a + 2 * (b * b)
     = ((m * m : ℕ) : ℤ) + 2 * ((n * n : ℕ) : ℤ)
     = ((m * m + 2 * (n * n) : ℕ) : ℤ);
  target = m * m + 2 * (n * n) by Natural.to_integer.injective;
  m * m + 2 * (n * n) = target;
  ¬(m * m + 2 * (n * n) = target)
      by Natural.not_square_plus_double_square_below_sixteen(
          targetBelow := targetBelow,
          notSmallValue := notSmallValue);
  done
}

theorem Natural.seven_not_square_plus_double_square_value_below_sixteen
        : ¬(Natural.IsSquarePlusDoubleSquareValueBelowSixteen(7)) :=
  done by unfolding Natural.IsSquarePlusDoubleSquareValueBelowSixteen

theorem Natural.ten_not_square_plus_double_square_value_below_sixteen
        : ¬(Natural.IsSquarePlusDoubleSquareValueBelowSixteen(10)) :=
  done by unfolding Natural.IsSquarePlusDoubleSquareValueBelowSixteen

theorem Matrix.squarePlusDoubleSquareForm_not_represents_seven
        : ¬(Matrix.Represents(
            Matrix.squarePlusDoubleSquareForm, (7 : ℤ))) :=
  by Matrix.squarePlusDoubleSquareForm_not_represents_below_sixteen

theorem Matrix.squarePlusDoubleSquareForm_not_represents_ten
        : ¬(Matrix.Represents(
            Matrix.squarePlusDoubleSquareForm, (10 : ℤ))) :=
  by Matrix.squarePlusDoubleSquareForm_not_represents_below_sixteen

theorem Matrix.squarePlusDoubleSquarePlusTripleSquareForm_not_represents_ten
        : ¬(Matrix.Represents(
            Matrix.squarePlusDoubleSquarePlusTripleSquareForm, (10 : ℤ))) := {
  suppose Matrix.Represents(
      Matrix.squarePlusDoubleSquarePlusTripleSquareForm, (10 : ℤ))
      as represented;
  choose x : RingVector(Integer.commutative_ring_bundle, 3) such that
      Matrix.quadraticForm(
          Matrix.squarePlusDoubleSquarePlusTripleSquareForm, x) = 10
      from represented;
  let y : RingVector(Integer.commutative_ring_bundle, 2) :=
      RingVector.restrict(x);
  let t : ℤ := x(NaturalsBelow.top(2));
  let q : ℤ := Matrix.quadraticForm(
      Matrix.squarePlusDoubleSquareForm, y);
  q + t * t * 3
     = Matrix.quadraticForm(
           Matrix.squarePlusDoubleSquarePlusTripleSquareForm, x)
           by Matrix.squarePlusDoubleSquarePlusTripleSquareForm_value
     = 10
  as valueIsTen;
  Matrix.Represents(Matrix.squarePlusDoubleSquareForm, q)
      by { witness y with done };
  0 ≤ q by {
    ∃ (a b : ℤ). q = a * a + 2 * (b * b)
        by Matrix.squarePlusDoubleSquareForm_represents_only_squares;
    choose a such that ∃ (b : ℤ). q = a * a + 2 * (b * b);
    choose b such that q = a * a + 2 * (b * b) as qReads;
    0 ≤ a * a by Integer.zero_less_or_equal_of_nonneg;
    0 ≤ b * b by Integer.zero_less_or_equal_of_nonneg;
    0 ≤ 2 * (b * b) by Integer.IsNonneg.multiply;
    0 ≤ a * a + 2 * (b * b) by Integer.IsNonneg.add;
    done by substituting qReads
  };
  3 * (t * t)
     = t * t * 3
     = 0 + t * t * 3
     ≤ q + t * t * 3 by Integer.add_preserves_less_or_equal
     = 10 by valueIsTen
     < 12
     = 3 * 4;
  3 * (t * t) < 3 * 4;
  t * t < 4 by Integer.cancel_lt_by_positive;
  t * t < 4 < 5;
  t * t < 5 by Integer.LessThan.transitive_left;
  t = -2 ∨ t = -1 ∨ t = 0 ∨ t = 1 ∨ t = 2
      by Integer.square_below_five;
  done by cases {
    case t = -2: {
        4 = (-(2 : ℤ)) * (-(2 : ℤ))
          = t * t by substituting (t = -2)
          < 4;
        done
      }
    case t = -1 ∨ t = 0 ∨ t = 1 ∨ t = 2: done by cases {
        case t = -1: {
            q + (-(1 : ℤ)) * (-(1 : ℤ)) * 3 = 10
                by substituting (t = -1) as specializedValue;
            q = 7 by linear_combination(specializedValue) as qIsSeven;
            Matrix.Represents(Matrix.squarePlusDoubleSquareForm, (7 : ℤ))
                by substituting qIsSeven;
            done by Matrix.squarePlusDoubleSquareForm_not_represents_seven
          }
        case t = 0 ∨ t = 1 ∨ t = 2: done by cases {
            case t = 0: {
                q + 0 * 0 * 3 = 10
                    by substituting (t = 0) as specializedValue;
                q = 10 by linear_combination(specializedValue) as qIsTen;
                Matrix.Represents(
                    Matrix.squarePlusDoubleSquareForm, (10 : ℤ))
                    by substituting qIsTen;
                done by Matrix.squarePlusDoubleSquareForm_not_represents_ten
              }
            case t = 1 ∨ t = 2: done by cases {
                case t = 1: {
                    q + 1 * 1 * 3 = 10
                        by substituting (t = 1) as specializedValue;
                    q = 7
                        by linear_combination(specializedValue) as qIsSeven;
                    Matrix.Represents(
                        Matrix.squarePlusDoubleSquareForm, (7 : ℤ))
                        by substituting qIsSeven;
                    done by Matrix.squarePlusDoubleSquareForm_not_represents_seven
                  }
                case t = 2: {
                    4 = 2 * 2
                      = t * t by substituting (t = 2)
                      < 4;
                    done
                  }
              }
          }
      }
  }
}

theorem Matrix.squarePlusDoubleSquarePlusTripleSquareForm_truant_ten
        : Matrix.IsTruant(
            Matrix.squarePlusDoubleSquarePlusTripleSquareForm, 10) := {
  10 ≥ 1;
  ¬(Matrix.Represents(
      Matrix.squarePlusDoubleSquarePlusTripleSquareForm, (10 : ℤ))) by {
    done by
      Matrix.squarePlusDoubleSquarePlusTripleSquareForm_not_represents_ten
  };
  ∀ (s : ℕ). s ≥ 1 → s < 10 →
      Matrix.Represents(
          Matrix.squarePlusDoubleSquarePlusTripleSquareForm, (s : ℤ))
      by finite_check s from 1 until 10;
  done
}

theorem Matrix.squarePlusDoubleSquarePlusTripleSquareForm_truant
        : Matrix.truant(
            Matrix.squarePlusDoubleSquarePlusTripleSquareForm) = 10 :=
  by Matrix.truant_equals

theorem Matrix.squarePlusDoubleSquareSecondColumnCandidate_truant
        : Matrix.truant(
            Matrix.squarePlusDoubleSquareSecondColumnCandidate) = 10 := {
  done by Matrix.isometric_truant_equals(
      isometric :=
        Matrix.squarePlusDoubleSquareSecondColumnCandidate_isometric,
      isTruant :=
        Matrix.squarePlusDoubleSquarePlusTripleSquareForm_truant_ten)
}

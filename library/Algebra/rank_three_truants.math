-- Algebra/rank_three_truants.math
--
-- The first concrete rank-3 truant calculation. The zero-border
-- escalation of x²+y² at its truant 3 is x²+y²+3z². It represents
-- 1 through 5 and misses 6: if x²+y²+3z²=6, then z²≤2, so z is
-- -1, 0, or 1, reducing the equation to the already excluded binary
-- values 3 or 6.

module Algebra.rank_three_truants

import Logic.basics
import Logic.functions
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.multiply_bounds
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.embedding
import Integer.order
import Integer.order_multiply
import Integer.sign
import Integer.integral_domain
import Integer.sum_of_squares
import Algebra.ring
import Algebra.ring_bundle
import Algebra.linear_combination
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.commutative_ring_aggregation
import Algebra.matrix
import Algebra.matrix_ring
import Algebra.matrix_transpose
import Algebra.matrix_vector
import Algebra.matrix_submatrix
import Algebra.matrix_direct_sum
import Algebra.quadratic_form
import Algebra.integer_quadratic_form
import Algebra.square_form
import Algebra.schur_complement
import Algebra.truant
import Algebra.escalation
import Algebra.rank_two_escalators
import Algebra.rank_two_truants
import Algebra.escalator_tree

definition Matrix.sumOfTwoSquaresPlusTripleSquareForm
        : Matrix(Integer.commutative_ring_bundle, 1 + 2, 1 + 2) :=
  Matrix.diagonalExtension(Matrix.sumOfTwoSquaresForm, (3 : ℤ))

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_symmetric
        : Matrix.IsSymmetric(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm) := {
  done by Matrix.diagonalExtension_symmetric(
      symmetric := Matrix.sumOfTwoSquaresForm_symmetric)
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_leadingBlock
        : Matrix.leadingBlock(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm)
          = Matrix.sumOfTwoSquaresForm := {
  done by Matrix.diagonalExtension_leadingBlock
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_borderColumn
        : Matrix.borderColumn(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm)
          = RingVector.zero(Integer.commutative_ring_bundle, 2) := {
  done by Matrix.diagonalExtension_borderColumn
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_corner
        : Matrix.corner(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm) = (3 : ℤ) := {
  done by Matrix.diagonalExtension_corner
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_value
        (x : RingVector(Integer.commutative_ring_bundle, 1 + 2))
        : Matrix.quadraticForm(
              Matrix.sumOfTwoSquaresPlusTripleSquareForm, x)
          = Matrix.quadraticForm(
                Matrix.sumOfTwoSquaresForm, RingVector.restrict(x))
            + x(NaturalsBelow.top(2)) * x(NaturalsBelow.top(2)) * 3 := {
  done by Matrix.diagonalExtension_quadraticForm(
      symmetric := Matrix.sumOfTwoSquaresForm_symmetric)
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_parent
        (target : ℤ)
        (represented : Matrix.Represents(Matrix.sumOfTwoSquaresForm, target))
        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, target) := {
  done by Matrix.diagonalExtension_represents_parent(
      symmetric := Matrix.sumOfTwoSquaresForm_symmetric,
      represented := represented)
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_one
        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, (1 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (1 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 1, b := 0);
  done by Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_parent
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_two
        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, (2 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (2 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 1, b := 1);
  done by Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_parent
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_three
        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, (3 : ℤ)) := {
  done by Matrix.diagonalExtension_represents_corner(
      symmetric := Matrix.sumOfTwoSquaresForm_symmetric)
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_four
        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, (4 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (4 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 2, b := 0);
  done by Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_parent
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_five
        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, (5 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (5 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 2, b := 1);
  done by Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_parent
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_not_represents_six
        : ¬(Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, (6 : ℤ))) := {
  suppose Matrix.Represents(
      Matrix.sumOfTwoSquaresPlusTripleSquareForm, (6 : ℤ)) as represented;
  choose x : RingVector(Integer.commutative_ring_bundle, 1 + 2) such that
      Matrix.quadraticForm(
          Matrix.sumOfTwoSquaresPlusTripleSquareForm, x) = (6 : ℤ)
      from represented;
  let y : RingVector(Integer.commutative_ring_bundle, 2) :=
      RingVector.restrict(x);
  let t : ℤ := x(NaturalsBelow.top(2));
  let q : ℤ := Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, y);
  q + t * t * 3
     = Matrix.quadraticForm(
           Matrix.sumOfTwoSquaresPlusTripleSquareForm, x)
           by Matrix.sumOfTwoSquaresPlusTripleSquareForm_value
     = (6 : ℤ)
  as valueIsSix;

  (0 : ℤ) ≤ q
      by Matrix.sumOfTwoSquaresForm_quadraticForm_nonnegative;

  3 * (t * t)
     = t * t * 3
     = 0 + t * t * 3
     ≤ q + t * t * 3 by Integer.add_preserves_less_or_equal
     = 6 by valueIsSix
     = 3 * 2;
  t * t ≤ 2 by Integer.cancel_le_by_positive;
  t * t ≤ 2 < 3;
  t * t < 3 by Integer.LessThan.transitive_left;
  t = -(1 : ℤ) ∨ t = 0 ∨ t = 1 by Integer.square_below_three;
  done by cases {
    case t = -(1 : ℤ): {
        q = 3 by {
          q + t * t * 3 = 6 by valueIsSix;
          q + (-(1 : ℤ)) * (-(1 : ℤ)) * 3 = 6
              by substituting (t = -(1 : ℤ)) as specializedValue;
          done by linear_combination(specializedValue)
        };
        Matrix.Represents(Matrix.sumOfTwoSquaresForm, (3 : ℤ)) by {
          Matrix.Represents(Matrix.sumOfTwoSquaresForm, q)
              by { witness y with done };
          done by substitution
        };
        done by Matrix.sumOfTwoSquaresForm_not_represents_three
      }
    case t = 0 ∨ t = 1: done by cases {
        case t = 0: {
            q = 6 by {
              q + t * t * 3 = 6 by valueIsSix;
              q + 0 * 0 * 3 = 6 by substituting (t = 0) as specializedValue;
              done by linear_combination(specializedValue)
            };
            Matrix.Represents(Matrix.sumOfTwoSquaresForm, (6 : ℤ)) by {
              Matrix.Represents(Matrix.sumOfTwoSquaresForm, q)
                  by { witness y with done };
              done by substitution
            };
            done by Matrix.sumOfTwoSquaresForm_not_represents_six
          }
        case t = 1: {
            q = 3 by {
              q + t * t * 3 = 6 by valueIsSix;
              q + 1 * 1 * 3 = 6 by substituting (t = 1) as specializedValue;
              done by linear_combination(specializedValue)
            };
            Matrix.Represents(Matrix.sumOfTwoSquaresForm, (3 : ℤ)) by {
              Matrix.Represents(Matrix.sumOfTwoSquaresForm, q)
                  by { witness y with done };
              done by substitution
            };
            done by Matrix.sumOfTwoSquaresForm_not_represents_three
          }
      }
  }
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_truant_six
        : Matrix.IsTruant(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, 6) := {
  6 ≥ 1;
  ¬(Matrix.Represents(
      Matrix.sumOfTwoSquaresPlusTripleSquareForm, ((6 : ℕ) : ℤ))) by {
    done by Matrix.sumOfTwoSquaresPlusTripleSquareForm_not_represents_six
  };
  ∀ (s : ℕ). s ≥ 1 → s < 6 →
      Matrix.Represents(
          Matrix.sumOfTwoSquaresPlusTripleSquareForm, (s : ℤ))
      by (s : ℕ) (positive : s ≥ 1) (belowSix : s < 6) ↦ {
          s = 1 ∨ s = 2 ∨ s = 3 ∨ s = 4 ∨ s = 5
              by Natural.positive_below_six;
          done by cases {
            case s = 1:
              done by Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_one
            case s = 2 ∨ s = 3 ∨ s = 4 ∨ s = 5: done by cases {
                case s = 2:
                  done by Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_two
                case s = 3 ∨ s = 4 ∨ s = 5: done by cases {
                    case s = 3:
                      done by Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_three
                    case s = 4 ∨ s = 5: done by cases {
                        case s = 4:
                          done by Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_four
                        case s = 5:
                          done by Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_five
                      }
                  }
              }
          }
        };
  done
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_truant
        : Matrix.truant(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm) = 6 :=
  by Matrix.truant_equals

-- ----------------------------------------------------------------------
-- The diagonal representative x²+y²+z². The two-nonzero-border child
-- above x²+y² completes squares to this form; the explicit integral
-- shear connecting them is the next isometry-classification step.

definition Matrix.sumOfThreeSquaresForm
        : Matrix(Integer.commutative_ring_bundle, 1 + 2, 1 + 2) :=
  Matrix.diagonalExtension(Matrix.sumOfTwoSquaresForm, (1 : ℤ))

theorem Matrix.sumOfThreeSquaresForm_value
        (x : RingVector(Integer.commutative_ring_bundle, 1 + 2))
        : Matrix.quadraticForm(Matrix.sumOfThreeSquaresForm, x)
          = Matrix.quadraticForm(
                Matrix.sumOfTwoSquaresForm, RingVector.restrict(x))
            + x(NaturalsBelow.top(2)) * x(NaturalsBelow.top(2)) := {
  Matrix.quadraticForm(Matrix.sumOfThreeSquaresForm, x)
     = Matrix.quadraticForm(
           Matrix.sumOfTwoSquaresForm, RingVector.restrict(x))
       + x(NaturalsBelow.top(2)) * x(NaturalsBelow.top(2)) * 1
           by Matrix.diagonalExtension_quadraticForm(
               symmetric := Matrix.sumOfTwoSquaresForm_symmetric)
     = Matrix.quadraticForm(
           Matrix.sumOfTwoSquaresForm, RingVector.restrict(x))
       + x(NaturalsBelow.top(2)) * x(NaturalsBelow.top(2))
           by ring
  as valueReads;
  done by valueReads
}

theorem Matrix.sumOfThreeSquaresForm_represents_parent
        (target : ℤ)
        (represented : Matrix.Represents(Matrix.sumOfTwoSquaresForm, target))
        : Matrix.Represents(Matrix.sumOfThreeSquaresForm, target) := {
  done by Matrix.diagonalExtension_represents_parent(
      symmetric := Matrix.sumOfTwoSquaresForm_symmetric,
      represented := represented)
}

theorem Matrix.sumOfThreeSquaresForm_represents_one
        : Matrix.Represents(Matrix.sumOfThreeSquaresForm, (1 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (1 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 1, b := 0);
  done by Matrix.sumOfThreeSquaresForm_represents_parent
}

theorem Matrix.sumOfThreeSquaresForm_represents_two
        : Matrix.Represents(Matrix.sumOfThreeSquaresForm, (2 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (2 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 1, b := 1);
  done by Matrix.sumOfThreeSquaresForm_represents_parent
}

theorem Matrix.sumOfThreeSquaresForm_represents_three
        : Matrix.Represents(Matrix.sumOfThreeSquaresForm, (3 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (2 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 1, b := 1) as parentRepresentsTwo;
  Matrix.Represents(
      Matrix.sumOfThreeSquaresForm, (2 : ℤ) + 1 * 1 * 1)
      by Matrix.diagonalExtension_represents_parent_plus_square(
          symmetric := Matrix.sumOfTwoSquaresForm_symmetric,
          represented := parentRepresentsTwo);
  done
}

theorem Matrix.sumOfThreeSquaresForm_represents_four
        : Matrix.Represents(Matrix.sumOfThreeSquaresForm, (4 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (4 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 2, b := 0);
  done by Matrix.sumOfThreeSquaresForm_represents_parent
}

theorem Matrix.sumOfThreeSquaresForm_represents_five
        : Matrix.Represents(Matrix.sumOfThreeSquaresForm, (5 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (5 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 2, b := 1);
  done by Matrix.sumOfThreeSquaresForm_represents_parent
}

theorem Matrix.sumOfThreeSquaresForm_represents_six
        : Matrix.Represents(Matrix.sumOfThreeSquaresForm, (6 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (5 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 2, b := 1) as parentRepresentsFive;
  Matrix.Represents(
      Matrix.sumOfThreeSquaresForm, (5 : ℤ) + 1 * 1 * 1)
      by Matrix.diagonalExtension_represents_parent_plus_square(
          symmetric := Matrix.sumOfTwoSquaresForm_symmetric,
          represented := parentRepresentsFive);
  done
}

theorem Matrix.sumOfThreeSquaresForm_not_represents_seven
        : ¬(Matrix.Represents(Matrix.sumOfThreeSquaresForm, (7 : ℤ))) := {
  suppose Matrix.Represents(
      Matrix.sumOfThreeSquaresForm, (7 : ℤ)) as represented;
  choose x : RingVector(Integer.commutative_ring_bundle, 1 + 2) such that
      Matrix.quadraticForm(Matrix.sumOfThreeSquaresForm, x) = (7 : ℤ)
      from represented;
  let y : RingVector(Integer.commutative_ring_bundle, 2) :=
      RingVector.restrict(x);
  let t : ℤ := x(NaturalsBelow.top(2));
  let q : ℤ := Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, y);
  q + t * t
     = Matrix.quadraticForm(Matrix.sumOfThreeSquaresForm, x)
           by Matrix.sumOfThreeSquaresForm_value
     = (7 : ℤ)
  as valueIsSeven;
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, q)
      by { witness y with done };
  (0 : ℤ) ≤ q
      by Matrix.sumOfTwoSquaresForm_quadraticForm_nonnegative;
  t * t
     = 0 + t * t
     ≤ q + t * t by Integer.add_preserves_less_or_equal
     = 7 by valueIsSeven;
  t * t ≤ 7 < 8;
  t * t < 8 by Integer.LessThan.transitive_left;
  t = -(2 : ℤ) ∨ t = -(1 : ℤ) ∨ t = 0 ∨ t = 1 ∨ t = 2
      by Integer.square_below_eight;
  done by cases {
    case t = -(2 : ℤ): {
        q + (-(2 : ℤ)) * (-(2 : ℤ)) = 7
            by substituting (t = -(2 : ℤ)) as specializedValue;
        q = 3 by linear_combination(specializedValue) as qIsThree;
        Matrix.Represents(Matrix.sumOfTwoSquaresForm, (3 : ℤ))
            by substituting qIsThree;
        done by Matrix.sumOfTwoSquaresForm_not_represents_three
      }
    case t = -(1 : ℤ) ∨ t = 0 ∨ t = 1 ∨ t = 2: done by cases {
        case t = -(1 : ℤ): {
            q + (-(1 : ℤ)) * (-(1 : ℤ)) = 7
                by substituting (t = -(1 : ℤ)) as specializedValue;
            q = 6 by linear_combination(specializedValue) as qIsSix;
            Matrix.Represents(Matrix.sumOfTwoSquaresForm, (6 : ℤ))
                by substituting qIsSix;
            done by Matrix.sumOfTwoSquaresForm_not_represents_six
          }
        case t = 0 ∨ t = 1 ∨ t = 2: done by cases {
            case t = 0: {
                q + 0 * 0 = 7 by substituting (t = 0) as specializedValue;
                q = 7 by linear_combination(specializedValue) as qIsSeven;
                Matrix.Represents(Matrix.sumOfTwoSquaresForm, (7 : ℤ))
                    by substituting qIsSeven;
                done by Matrix.sumOfTwoSquaresForm_not_represents_seven
              }
            case t = 1 ∨ t = 2: done by cases {
                case t = 1: {
                    q + 1 * 1 = 7
                        by substituting (t = 1) as specializedValue;
                    q = 6 by linear_combination(specializedValue) as qIsSix;
                    Matrix.Represents(Matrix.sumOfTwoSquaresForm, (6 : ℤ))
                        by substituting qIsSix;
                    done by Matrix.sumOfTwoSquaresForm_not_represents_six
                  }
                case t = 2: {
                    q + 2 * 2 = 7
                        by substituting (t = 2) as specializedValue;
                    q = 3 by linear_combination(specializedValue) as qIsThree;
                    Matrix.Represents(Matrix.sumOfTwoSquaresForm, (3 : ℤ))
                        by substituting qIsThree;
                    done by Matrix.sumOfTwoSquaresForm_not_represents_three
                  }
              }
          }
      }
  }
}

theorem Matrix.sumOfThreeSquaresForm_truant_seven
        : Matrix.IsTruant(Matrix.sumOfThreeSquaresForm, 7) := {
  7 ≥ 1;
  ¬(Matrix.Represents(Matrix.sumOfThreeSquaresForm, ((7 : ℕ) : ℤ))) by {
    done by Matrix.sumOfThreeSquaresForm_not_represents_seven
  };
  ∀ (s : ℕ). s ≥ 1 → s < 7 →
      Matrix.Represents(Matrix.sumOfThreeSquaresForm, (s : ℤ))
      by (s : ℕ) (positive : s ≥ 1) (belowSeven : s < 7) ↦ {
          s = 1 ∨ s = 2 ∨ s = 3 ∨ s = 4 ∨ s = 5 ∨ s = 6
              by Natural.positive_below_seven;
          done by cases {
            case s = 1: done by Matrix.sumOfThreeSquaresForm_represents_one
            case s = 2 ∨ s = 3 ∨ s = 4 ∨ s = 5 ∨ s = 6: done by cases {
                case s = 2: done by Matrix.sumOfThreeSquaresForm_represents_two
                case s = 3 ∨ s = 4 ∨ s = 5 ∨ s = 6: done by cases {
                    case s = 3: done by Matrix.sumOfThreeSquaresForm_represents_three
                    case s = 4 ∨ s = 5 ∨ s = 6: done by cases {
                        case s = 4: done by Matrix.sumOfThreeSquaresForm_represents_four
                        case s = 5 ∨ s = 6: done by cases {
                            case s = 5: done by Matrix.sumOfThreeSquaresForm_represents_five
                            case s = 6: done by Matrix.sumOfThreeSquaresForm_represents_six
                          }
                      }
                  }
              }
          }
        };
  done
}

theorem Matrix.sumOfThreeSquaresForm_truant
        : Matrix.truant(Matrix.sumOfThreeSquaresForm) = 7 :=
  by Matrix.truant_equals

        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusDoubleSquareForm, (2 : ℤ)) := {
  done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents(
      a := 0, b := 0, k := 1)
}


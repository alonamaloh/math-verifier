-- Algebra/rank_three_truants.math
--
-- The first concrete rank-3 truant calculation. The zero-border
-- escalation of x²+y² at its truant 3 is x²+y²+3z². It represents
-- 1 through 5 and misses 6: if x²+y²+3z²=6, then z²≤2, so z is
-- -1, 0, or 1, reducing the equation to the already excluded binary
-- values 3 or 6.

module Algebra.rank_three_truants

import Logic.basics
import Logic.functions
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.multiply_bounds
import Natural.finite_range
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.embedding
import Integer.order
import Integer.order_multiply
import Integer.sign
import Integer.integral_domain
import Integer.sum_of_squares
import Algebra.ring
import Algebra.ring_bundle
import Algebra.linear_combination
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.commutative_ring_aggregation
import Algebra.matrix
import Algebra.matrix_ring
import Algebra.matrix_transpose
import Algebra.matrix_vector
import Algebra.matrix_submatrix
import Algebra.matrix_direct_sum
import Algebra.quadratic_form
import Algebra.integer_quadratic_form
import Algebra.square_form
import Algebra.schur_complement
import Algebra.truant
import Algebra.escalation
import Algebra.rank_two_escalators
import Algebra.rank_two_truants
import Algebra.rank_three_escalation_bounds
import Algebra.escalator_tree

definition Matrix.sumOfTwoSquaresPlusTripleSquareForm
        : Matrix(Integer.commutative_ring_bundle, 1 + 2, 1 + 2) :=
  Matrix.diagonalExtension(Matrix.sumOfTwoSquaresForm, (3 : ℤ))

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_symmetric
        : Matrix.IsSymmetric(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm) := {
  done by Matrix.diagonalExtension_symmetric(
      symmetric := Matrix.sumOfTwoSquaresForm_symmetric)
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_leadingBlock
        : Matrix.leadingBlock(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm)
          = Matrix.sumOfTwoSquaresForm := {
  done by Matrix.diagonalExtension_leadingBlock
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_borderColumn
        : Matrix.borderColumn(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm)
          = RingVector.zero(Integer.commutative_ring_bundle, 2) := {
  done by Matrix.diagonalExtension_borderColumn
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_corner
        : Matrix.corner(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm) = (3 : ℤ) := {
  done by Matrix.diagonalExtension_corner
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_value
        (x : RingVector(Integer.commutative_ring_bundle, 1 + 2))
        : Matrix.quadraticForm(
              Matrix.sumOfTwoSquaresPlusTripleSquareForm, x)
          = Matrix.quadraticForm(
                Matrix.sumOfTwoSquaresForm, RingVector.restrict(x))
            + x(NaturalsBelow.top(2)) * x(NaturalsBelow.top(2)) * 3 := {
  done by Matrix.diagonalExtension_quadraticForm(
      symmetric := Matrix.sumOfTwoSquaresForm_symmetric)
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_parent
        (target : ℤ)
        (represented : Matrix.Represents(Matrix.sumOfTwoSquaresForm, target))
        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, target) := {
  done by Matrix.diagonalExtension_represents_parent(
      symmetric := Matrix.sumOfTwoSquaresForm_symmetric,
      represented := represented)
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_one
        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, (1 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (1 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 1, b := 0);
  done by Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_parent
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_two
        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, (2 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (2 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 1, b := 1);
  done by Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_parent
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_three
        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, (3 : ℤ)) := {
  done by Matrix.diagonalExtension_represents_corner(
      symmetric := Matrix.sumOfTwoSquaresForm_symmetric)
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_four
        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, (4 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (4 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 2, b := 0);
  done by Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_parent
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_five
        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, (5 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (5 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 2, b := 1);
  done by Matrix.sumOfTwoSquaresPlusTripleSquareForm_represents_parent
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_not_represents_six
        : ¬(Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, (6 : ℤ))) := {
  suppose Matrix.Represents(
      Matrix.sumOfTwoSquaresPlusTripleSquareForm, (6 : ℤ)) as represented;
  choose x : RingVector(Integer.commutative_ring_bundle, 1 + 2) such that
      Matrix.quadraticForm(
          Matrix.sumOfTwoSquaresPlusTripleSquareForm, x) = (6 : ℤ)
      from represented;
  let y : RingVector(Integer.commutative_ring_bundle, 2) :=
      RingVector.restrict(x);
  let t : ℤ := x(NaturalsBelow.top(2));
  let q : ℤ := Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, y);
  q + t * t * 3
     = Matrix.quadraticForm(
           Matrix.sumOfTwoSquaresPlusTripleSquareForm, x)
           by Matrix.sumOfTwoSquaresPlusTripleSquareForm_value
     = (6 : ℤ)
  as valueIsSix;

  (0 : ℤ) ≤ q
      by Matrix.sumOfTwoSquaresForm_quadraticForm_nonnegative;

  3 * (t * t)
     = t * t * 3
     = 0 + t * t * 3
     ≤ q + t * t * 3 by Integer.add_preserves_less_or_equal
     = 6 by valueIsSix
     = 3 * 2;
  t * t ≤ 2 by Integer.cancel_le_by_positive;
  t * t ≤ 2 < 3;
  t * t < 3 by Integer.LessThan.transitive_left;
  t = -(1 : ℤ) ∨ t = 0 ∨ t = 1 by Integer.square_below_three;
  done by cases {
    case t = -(1 : ℤ): {
        q = 3 by {
          q + t * t * 3 = 6 by valueIsSix;
          q + (-(1 : ℤ)) * (-(1 : ℤ)) * 3 = 6
              by substituting (t = -(1 : ℤ)) as specializedValue;
          done by linear_combination(specializedValue)
        };
        Matrix.Represents(Matrix.sumOfTwoSquaresForm, (3 : ℤ)) by {
          Matrix.Represents(Matrix.sumOfTwoSquaresForm, q)
              by { witness y with done };
          done by substitution
        };
        done by Matrix.sumOfTwoSquaresForm_not_represents_three
      }
    case t = 0 ∨ t = 1: done by cases {
        case t = 0: {
            q = 6 by {
              q + t * t * 3 = 6 by valueIsSix;
              q + 0 * 0 * 3 = 6 by substituting (t = 0) as specializedValue;
              done by linear_combination(specializedValue)
            };
            Matrix.Represents(Matrix.sumOfTwoSquaresForm, (6 : ℤ)) by {
              Matrix.Represents(Matrix.sumOfTwoSquaresForm, q)
                  by { witness y with done };
              done by substitution
            };
            done by Matrix.sumOfTwoSquaresForm_not_represents_six
          }
        case t = 1: {
            q = 3 by {
              q + t * t * 3 = 6 by valueIsSix;
              q + 1 * 1 * 3 = 6 by substituting (t = 1) as specializedValue;
              done by linear_combination(specializedValue)
            };
            Matrix.Represents(Matrix.sumOfTwoSquaresForm, (3 : ℤ)) by {
              Matrix.Represents(Matrix.sumOfTwoSquaresForm, q)
                  by { witness y with done };
              done by substitution
            };
            done by Matrix.sumOfTwoSquaresForm_not_represents_three
          }
      }
  }
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_truant_six
        : Matrix.IsTruant(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm, 6) := {
  6 ≥ 1;
  ¬(Matrix.Represents(
      Matrix.sumOfTwoSquaresPlusTripleSquareForm, ((6 : ℕ) : ℤ))) by {
    done by Matrix.sumOfTwoSquaresPlusTripleSquareForm_not_represents_six
  };
  ∀ (s : ℕ). s ≥ 1 → s < 6 →
      Matrix.Represents(
          Matrix.sumOfTwoSquaresPlusTripleSquareForm, (s : ℤ))
      by finite_check s from 1 until 6;
  done
}

theorem Matrix.sumOfTwoSquaresPlusTripleSquareForm_truant
        : Matrix.truant(
            Matrix.sumOfTwoSquaresPlusTripleSquareForm) = 6 :=
  by Matrix.truant_equals

-- ----------------------------------------------------------------------
-- The diagonal representative x²+y²+z². The two-nonzero-border child
-- above x²+y² completes squares to this form; the explicit integral
-- shear connecting them is the next isometry-classification step.

definition Matrix.sumOfThreeSquaresForm
        : Matrix(Integer.commutative_ring_bundle, 1 + 2, 1 + 2) :=
  Matrix.diagonalExtension(Matrix.sumOfTwoSquaresForm, (1 : ℤ))

theorem Matrix.sumOfThreeSquaresForm_symmetric
        : Matrix.IsSymmetric(Matrix.sumOfThreeSquaresForm) := {
  done by Matrix.diagonalExtension_symmetric(
      symmetric := Matrix.sumOfTwoSquaresForm_symmetric)
}

theorem Matrix.sumOfThreeSquaresForm_value
        (x : RingVector(Integer.commutative_ring_bundle, 1 + 2))
        : Matrix.quadraticForm(Matrix.sumOfThreeSquaresForm, x)
          = Matrix.quadraticForm(
                Matrix.sumOfTwoSquaresForm, RingVector.restrict(x))
            + x(NaturalsBelow.top(2)) * x(NaturalsBelow.top(2)) := {
  Matrix.quadraticForm(Matrix.sumOfThreeSquaresForm, x)
     = Matrix.quadraticForm(
           Matrix.sumOfTwoSquaresForm, RingVector.restrict(x))
       + x(NaturalsBelow.top(2)) * x(NaturalsBelow.top(2)) * 1
           by Matrix.diagonalExtension_quadraticForm(
               symmetric := Matrix.sumOfTwoSquaresForm_symmetric)
     = Matrix.quadraticForm(
           Matrix.sumOfTwoSquaresForm, RingVector.restrict(x))
       + x(NaturalsBelow.top(2)) * x(NaturalsBelow.top(2))
           by ring
  as valueReads;
  done by valueReads
}

theorem Matrix.sumOfThreeSquaresForm_represents_parent
        (target : ℤ)
        (represented : Matrix.Represents(Matrix.sumOfTwoSquaresForm, target))
        : Matrix.Represents(Matrix.sumOfThreeSquaresForm, target) := {
  done by Matrix.diagonalExtension_represents_parent(
      symmetric := Matrix.sumOfTwoSquaresForm_symmetric,
      represented := represented)
}

theorem Matrix.sumOfThreeSquaresForm_represents_one
        : Matrix.Represents(Matrix.sumOfThreeSquaresForm, (1 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (1 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 1, b := 0);
  done by Matrix.sumOfThreeSquaresForm_represents_parent
}

theorem Matrix.sumOfThreeSquaresForm_represents_two
        : Matrix.Represents(Matrix.sumOfThreeSquaresForm, (2 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (2 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 1, b := 1);
  done by Matrix.sumOfThreeSquaresForm_represents_parent
}

theorem Matrix.sumOfThreeSquaresForm_represents_three
        : Matrix.Represents(Matrix.sumOfThreeSquaresForm, (3 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (2 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 1, b := 1) as parentRepresentsTwo;
  Matrix.Represents(
      Matrix.sumOfThreeSquaresForm, (2 : ℤ) + 1 * 1 * 1)
      by Matrix.diagonalExtension_represents_parent_plus_square(
          symmetric := Matrix.sumOfTwoSquaresForm_symmetric,
          represented := parentRepresentsTwo);
  done
}

theorem Matrix.sumOfThreeSquaresForm_represents_four
        : Matrix.Represents(Matrix.sumOfThreeSquaresForm, (4 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (4 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 2, b := 0);
  done by Matrix.sumOfThreeSquaresForm_represents_parent
}

theorem Matrix.sumOfThreeSquaresForm_represents_five
        : Matrix.Represents(Matrix.sumOfThreeSquaresForm, (5 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (5 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 2, b := 1);
  done by Matrix.sumOfThreeSquaresForm_represents_parent
}

theorem Matrix.sumOfThreeSquaresForm_represents_six
        : Matrix.Represents(Matrix.sumOfThreeSquaresForm, (6 : ℤ)) := {
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, (5 : ℤ))
      by Matrix.sumOfTwoSquaresForm_represents(a := 2, b := 1) as parentRepresentsFive;
  Matrix.Represents(
      Matrix.sumOfThreeSquaresForm, (5 : ℤ) + 1 * 1 * 1)
      by Matrix.diagonalExtension_represents_parent_plus_square(
          symmetric := Matrix.sumOfTwoSquaresForm_symmetric,
          represented := parentRepresentsFive);
  done
}

theorem Matrix.sumOfThreeSquaresForm_not_represents_seven
        : ¬(Matrix.Represents(Matrix.sumOfThreeSquaresForm, (7 : ℤ))) := {
  suppose Matrix.Represents(
      Matrix.sumOfThreeSquaresForm, (7 : ℤ)) as represented;
  choose x : RingVector(Integer.commutative_ring_bundle, 1 + 2) such that
      Matrix.quadraticForm(Matrix.sumOfThreeSquaresForm, x) = (7 : ℤ)
      from represented;
  let y : RingVector(Integer.commutative_ring_bundle, 2) :=
      RingVector.restrict(x);
  let t : ℤ := x(NaturalsBelow.top(2));
  let q : ℤ := Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, y);
  q + t * t
     = Matrix.quadraticForm(Matrix.sumOfThreeSquaresForm, x)
           by Matrix.sumOfThreeSquaresForm_value
     = (7 : ℤ)
  as valueIsSeven;
  Matrix.Represents(Matrix.sumOfTwoSquaresForm, q)
      by { witness y with done };
  (0 : ℤ) ≤ q
      by Matrix.sumOfTwoSquaresForm_quadraticForm_nonnegative;
  t * t
     = 0 + t * t
     ≤ q + t * t by Integer.add_preserves_less_or_equal
     = 7 by valueIsSeven;
  t * t ≤ 7 < 8;
  t * t < 8 by Integer.LessThan.transitive_left;
  t = -(2 : ℤ) ∨ t = -(1 : ℤ) ∨ t = 0 ∨ t = 1 ∨ t = 2
      by Integer.square_below_eight;
  done by cases {
    case t = -(2 : ℤ): {
        q + (-(2 : ℤ)) * (-(2 : ℤ)) = 7
            by substituting (t = -(2 : ℤ)) as specializedValue;
        q = 3 by linear_combination(specializedValue) as qIsThree;
        Matrix.Represents(Matrix.sumOfTwoSquaresForm, (3 : ℤ))
            by substituting qIsThree;
        done by Matrix.sumOfTwoSquaresForm_not_represents_three
      }
    case t = -(1 : ℤ) ∨ t = 0 ∨ t = 1 ∨ t = 2: done by cases {
        case t = -(1 : ℤ): {
            q + (-(1 : ℤ)) * (-(1 : ℤ)) = 7
                by substituting (t = -(1 : ℤ)) as specializedValue;
            q = 6 by linear_combination(specializedValue) as qIsSix;
            Matrix.Represents(Matrix.sumOfTwoSquaresForm, (6 : ℤ))
                by substituting qIsSix;
            done by Matrix.sumOfTwoSquaresForm_not_represents_six
          }
        case t = 0 ∨ t = 1 ∨ t = 2: done by cases {
            case t = 0: {
                q + 0 * 0 = 7 by substituting (t = 0) as specializedValue;
                q = 7 by linear_combination(specializedValue) as qIsSeven;
                Matrix.Represents(Matrix.sumOfTwoSquaresForm, (7 : ℤ))
                    by substituting qIsSeven;
                done by Matrix.sumOfTwoSquaresForm_not_represents_seven
              }
            case t = 1 ∨ t = 2: done by cases {
                case t = 1: {
                    q + 1 * 1 = 7
                        by substituting (t = 1) as specializedValue;
                    q = 6 by linear_combination(specializedValue) as qIsSix;
                    Matrix.Represents(Matrix.sumOfTwoSquaresForm, (6 : ℤ))
                        by substituting qIsSix;
                    done by Matrix.sumOfTwoSquaresForm_not_represents_six
                  }
                case t = 2: {
                    q + 2 * 2 = 7
                        by substituting (t = 2) as specializedValue;
                    q = 3 by linear_combination(specializedValue) as qIsThree;
                    Matrix.Represents(Matrix.sumOfTwoSquaresForm, (3 : ℤ))
                        by substituting qIsThree;
                    done by Matrix.sumOfTwoSquaresForm_not_represents_three
                  }
              }
          }
      }
  }
}

theorem Matrix.sumOfThreeSquaresForm_truant_seven
        : Matrix.IsTruant(Matrix.sumOfThreeSquaresForm, 7) := {
  7 ≥ 1;
  ¬(Matrix.Represents(Matrix.sumOfThreeSquaresForm, ((7 : ℕ) : ℤ))) by {
    done by Matrix.sumOfThreeSquaresForm_not_represents_seven
  };
  ∀ (s : ℕ). s ≥ 1 → s < 7 →
      Matrix.Represents(Matrix.sumOfThreeSquaresForm, (s : ℤ))
      by finite_check s from 1 until 7;
  done
}

theorem Matrix.sumOfThreeSquaresForm_truant
        : Matrix.truant(Matrix.sumOfThreeSquaresForm) = 7 :=
  by Matrix.truant_equals

-- ----------------------------------------------------------------------
-- The raw border (1,1) above x²+y² is the top-shear pullback of the
-- sum of three squares: (x+z)²+(y+z)²+z².

definition Matrix.sumOfTwoSquaresUnitBorderCandidate (a b : ℤ)
        : Matrix(Integer.commutative_ring_bundle, 1 + 2, 1 + 2) :=
  Matrix.borderedAssembly(
      Matrix.sumOfTwoSquaresForm,
      RingVector.twoCoordinates(a, b),
      (3 : ℤ))

definition Matrix.sumOfTwoSquaresTwoUnitBorderCandidate
        : Matrix(Integer.commutative_ring_bundle, 1 + 2, 1 + 2) :=
  Matrix.sumOfTwoSquaresUnitBorderCandidate((1 : ℤ), (1 : ℤ))

theorem Matrix.sumOfTwoSquaresForm_twoCoordinates_value
        (a b : ℤ)
        : Matrix.quadraticForm(
            Matrix.sumOfTwoSquaresForm,
            RingVector.twoCoordinates(a, b)) = a * a + b * b := {
  let firstBasis : RingVector(Integer.commutative_ring_bundle, 2) :=
      Matrix.standardBasisRow(
          Integer.commutative_ring_bundle, 2, NaturalsBelow.firstOfTwo);
  let secondBasis : RingVector(Integer.commutative_ring_bundle, 2) :=
      Matrix.standardBasisRow(
          Integer.commutative_ring_bundle, 2, NaturalsBelow.secondOfTwo);
  let v : RingVector(Integer.commutative_ring_bundle, 2) :=
      RingVector.twoCoordinates(a, b);
  RingVector.innerProduct(firstBasis, firstBasis)
     = firstBasis(NaturalsBelow.firstOfTwo)
           by RingVector.innerProduct_standardBasisRow_left
     = (1 : ℤ) by Matrix.standardBasisRow_at
  as firstSelf;
  RingVector.innerProduct(firstBasis, secondBasis) = (0 : ℤ) by {
    ¬(NaturalsBelow.firstOfTwo = NaturalsBelow.secondOfTwo)
        by NaturalsBelow.firstOfTwo_not_secondOfTwo;
    RingVector.innerProduct(firstBasis, secondBasis)
       = secondBasis(NaturalsBelow.firstOfTwo)
             by RingVector.innerProduct_standardBasisRow_left
       = (0 : ℤ) by Matrix.standardBasisRow_off;
    done
  }
  as firstSecond;
  RingVector.innerProduct(secondBasis, firstBasis) = (0 : ℤ) by {
    ¬(NaturalsBelow.secondOfTwo = NaturalsBelow.firstOfTwo) by {
      suppose NaturalsBelow.secondOfTwo = NaturalsBelow.firstOfTwo;
      NaturalsBelow.firstOfTwo = NaturalsBelow.secondOfTwo;
      done by NaturalsBelow.firstOfTwo_not_secondOfTwo
    };
    RingVector.innerProduct(secondBasis, firstBasis)
       = firstBasis(NaturalsBelow.secondOfTwo)
             by RingVector.innerProduct_standardBasisRow_left
       = (0 : ℤ) by Matrix.standardBasisRow_off;
    done
  }
  as secondFirst;
  RingVector.innerProduct(secondBasis, secondBasis)
     = secondBasis(NaturalsBelow.secondOfTwo)
           by RingVector.innerProduct_standardBasisRow_left
     = (1 : ℤ) by Matrix.standardBasisRow_at
  as secondSelf;
  Matrix.sumOfTwoSquaresForm · v = v by {
    Matrix.sumOfTwoSquaresForm · v
       = Matrix.identity(Integer.commutative_ring_bundle, 2) · v
             by substituting Matrix.sumOfTwoSquaresForm_is_identity
       = v by Matrix.applyVector_identity;
    done
  }
  as actionReads;
  Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, v)
     = RingVector.innerProduct(v, Matrix.sumOfTwoSquaresForm · v)
     = RingVector.innerProduct(v, v) by substituting actionReads
     = RingVector.innerProduct(
           a • firstBasis + b • secondBasis,
           a • firstBasis + b • secondBasis)
     = RingVector.innerProduct(
           a • firstBasis, a • firstBasis + b • secondBasis)
       + RingVector.innerProduct(
           b • secondBasis, a • firstBasis + b • secondBasis)
           by RingVector.innerProduct_add_left
     = a * RingVector.innerProduct(
           firstBasis, a • firstBasis + b • secondBasis)
       + RingVector.innerProduct(
           b • secondBasis, a • firstBasis + b • secondBasis)
           by substituting RingVector.innerProduct_scale_left
     = a * RingVector.innerProduct(
           firstBasis, a • firstBasis + b • secondBasis)
       + b * RingVector.innerProduct(
           secondBasis, a • firstBasis + b • secondBasis)
           by substituting RingVector.innerProduct_scale_left
     = a * (RingVector.innerProduct(firstBasis, a • firstBasis)
            + RingVector.innerProduct(firstBasis, b • secondBasis))
       + b * RingVector.innerProduct(
           secondBasis, a • firstBasis + b • secondBasis)
           by substituting RingVector.innerProduct_add_right
     = a * (RingVector.innerProduct(firstBasis, a • firstBasis)
            + RingVector.innerProduct(firstBasis, b • secondBasis))
       + b * (RingVector.innerProduct(secondBasis, a • firstBasis)
              + RingVector.innerProduct(secondBasis, b • secondBasis))
           by substituting RingVector.innerProduct_add_right
     = a * (a * RingVector.innerProduct(firstBasis, firstBasis)
            + RingVector.innerProduct(firstBasis, b • secondBasis))
       + b * (RingVector.innerProduct(secondBasis, a • firstBasis)
              + RingVector.innerProduct(secondBasis, b • secondBasis))
           by substituting RingVector.innerProduct_scale_right
     = a * (a * RingVector.innerProduct(firstBasis, firstBasis)
            + b * RingVector.innerProduct(firstBasis, secondBasis))
       + b * (RingVector.innerProduct(secondBasis, a • firstBasis)
              + RingVector.innerProduct(secondBasis, b • secondBasis))
           by substituting RingVector.innerProduct_scale_right
     = a * (a * RingVector.innerProduct(firstBasis, firstBasis)
            + b * RingVector.innerProduct(firstBasis, secondBasis))
       + b * (a * RingVector.innerProduct(secondBasis, firstBasis)
              + RingVector.innerProduct(secondBasis, b • secondBasis))
           by substituting RingVector.innerProduct_scale_right
     = a * (a * RingVector.innerProduct(firstBasis, firstBasis)
            + b * RingVector.innerProduct(firstBasis, secondBasis))
       + b * (a * RingVector.innerProduct(secondBasis, firstBasis)
              + b * RingVector.innerProduct(secondBasis, secondBasis))
           by substituting RingVector.innerProduct_scale_right
     = a * (a * 1 + b * RingVector.innerProduct(firstBasis, secondBasis))
       + b * (a * RingVector.innerProduct(secondBasis, firstBasis)
              + b * RingVector.innerProduct(secondBasis, secondBasis))
           by substituting firstSelf
     = a * (a * 1 + b * 0)
       + b * (a * RingVector.innerProduct(secondBasis, firstBasis)
              + b * RingVector.innerProduct(secondBasis, secondBasis))
           by substituting firstSecond
     = a * (a * 1 + b * 0)
       + b * (a * 0
              + b * RingVector.innerProduct(secondBasis, secondBasis))
           by substituting secondFirst
     = a * (a * 1 + b * 0)
       + b * (a * 0 + b * 1)
           by substituting secondSelf
     = a * a + b * b by ring;
  done
}

-- The function-encoded pair constructed by `⟨a, b⟩` agrees with the
-- standard-basis spelling used by the older rank-two API.
theorem RingVector.coordinatePair_eq_twoCoordinates (a b : ℤ)
        : RingVector.appendCoordinate(
            (RingVector.oneCoordinate(a)
              : RingVector(Integer.commutative_ring_bundle, 1)), b)
          = (RingVector.twoCoordinates(a, b)
              : RingVector(Integer.commutative_ring_bundle, 2)) := {
  ∀ (i : NaturalsBelow(2)).
      RingVector.appendCoordinate(
        (RingVector.oneCoordinate(a)
          : RingVector(Integer.commutative_ring_bundle, 1)), b)(i)
        = (RingVector.twoCoordinates(a, b)
            : RingVector(Integer.commutative_ring_bundle, 2))(i)
      by (i : NaturalsBelow(2)) ↦ {
          i = NaturalsBelow.firstOfTwo
            ∨ i = NaturalsBelow.secondOfTwo by NaturalsBelow.two_split;
          done by cases {
            case i = NaturalsBelow.firstOfTwo as first: {
                RingVector.appendCoordinate(
                    (RingVector.oneCoordinate(a)
                      : RingVector(Integer.commutative_ring_bundle, 1)), b)(i)
                   = RingVector.appendCoordinate(
                       (RingVector.oneCoordinate(a)
                         : RingVector(Integer.commutative_ring_bundle, 1)), b)(
                         NaturalsBelow.firstOfTwo) by substituting first
                   = RingVector.appendCoordinate(
                       (RingVector.oneCoordinate(a)
                         : RingVector(Integer.commutative_ring_bundle, 1)), b)(
                         NaturalsBelow.inclusion(
                           1, NaturalsBelow.top(0)))
                         by substituting NaturalsBelow.firstOfTwo_is_inclusion
                   = (RingVector.oneCoordinate(a)
                        : RingVector(Integer.commutative_ring_bundle, 1))(
                          NaturalsBelow.top(0))
                         by RingVector.appendCoordinate_inclusion
                   = a by RingVector.oneCoordinate_at
                   = (RingVector.twoCoordinates(a, b)
                       : RingVector(Integer.commutative_ring_bundle, 2))(
                       NaturalsBelow.firstOfTwo)
                         by RingVector.twoCoordinates_first
                   = (RingVector.twoCoordinates(a, b)
                       : RingVector(Integer.commutative_ring_bundle, 2))(i)
                         by substituting first;
                done
              }
            case i = NaturalsBelow.secondOfTwo as second: {
                RingVector.appendCoordinate(
                    (RingVector.oneCoordinate(a)
                      : RingVector(Integer.commutative_ring_bundle, 1)), b)(i)
                   = RingVector.appendCoordinate(
                       (RingVector.oneCoordinate(a)
                         : RingVector(Integer.commutative_ring_bundle, 1)), b)(
                         NaturalsBelow.secondOfTwo) by substituting second
                   = RingVector.appendCoordinate(
                       (RingVector.oneCoordinate(a)
                         : RingVector(Integer.commutative_ring_bundle, 1)), b)(
                           NaturalsBelow.top(1))
                         by substituting NaturalsBelow.secondOfTwo_is_top
                   = b by RingVector.appendCoordinate_top
                   = (RingVector.twoCoordinates(a, b)
                       : RingVector(Integer.commutative_ring_bundle, 2))(
                       NaturalsBelow.secondOfTwo)
                         by RingVector.twoCoordinates_second
                   = (RingVector.twoCoordinates(a, b)
                       : RingVector(Integer.commutative_ring_bundle, 2))(i)
                         by substituting second;
                done
              }
          }
        };
  done by RingVector.equal_of_pointwise
}

-- A narrow automatic evaluator for the coordinate-tuple spelling.  It keeps
-- matrix structure out of `ring`: the structural lemmas reduce the form to a
-- polynomial, then `ring` handles only that polynomial.
theorem Matrix.sumOfThreeSquaresForm_coordinateTuple_value
        (a b c : ℤ)
        : Matrix.quadraticForm(
            Matrix.sumOfThreeSquaresForm,
            RingVector.appendCoordinate(
              (RingVector.appendCoordinate(
                 (RingVector.oneCoordinate(a)
                   : RingVector(Integer.commutative_ring_bundle, 1)), b)
                : RingVector(Integer.commutative_ring_bundle, 2)), c))
          = a * a + b * b + c * c := {
  let pair : RingVector(Integer.commutative_ring_bundle, 2) :=
      RingVector.appendCoordinate(
        (RingVector.oneCoordinate(a)
          : RingVector(Integer.commutative_ring_bundle, 1)), b);
  let triple : RingVector(Integer.commutative_ring_bundle, 3) :=
      RingVector.appendCoordinate(pair, c);
  (RingVector.restrict(triple)
      : RingVector(Integer.commutative_ring_bundle, 2)) = pair
      by RingVector.restrict_appendCoordinate as restrictReads;
  pair = (RingVector.twoCoordinates(a, b)
            : RingVector(Integer.commutative_ring_bundle, 2))
      by RingVector.coordinatePair_eq_twoCoordinates as pairReads;
  triple(NaturalsBelow.top(2)) = c
      by RingVector.appendCoordinate_top as topReads;
  Matrix.quadraticForm(Matrix.sumOfThreeSquaresForm, triple)
     = Matrix.quadraticForm(
           Matrix.sumOfTwoSquaresForm, RingVector.restrict(triple))
       + triple(NaturalsBelow.top(2)) * triple(NaturalsBelow.top(2))
           by Matrix.sumOfThreeSquaresForm_value
     = Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, pair)
       + triple(NaturalsBelow.top(2)) * triple(NaturalsBelow.top(2))
           by substituting restrictReads
     = Matrix.quadraticForm(
           Matrix.sumOfTwoSquaresForm, RingVector.twoCoordinates(a, b))
       + triple(NaturalsBelow.top(2)) * triple(NaturalsBelow.top(2))
           by substituting pairReads
     = (a * a + b * b)
       + triple(NaturalsBelow.top(2)) * triple(NaturalsBelow.top(2))
           by substituting Matrix.sumOfTwoSquaresForm_twoCoordinates_value
     = (a * a + b * b) + c * c by substituting topReads
     = a * a + b * b + c * c;
  done
}

-- Let the local prover finish the final scalar calculation while keeping the
-- structural matrix evaluation in the theorem above.  This is the bridge
-- used when `represents_by_witness` asks for its `computes` premise.
automatic theorem Matrix.sumOfThreeSquaresForm_coordinateTuple_computes
        (a b c target : ℤ)
        (scalarComputation : a * a + b * b + c * c = target)
        : Matrix.quadraticForm(
            Matrix.sumOfThreeSquaresForm,
            RingVector.appendCoordinate(
              (RingVector.appendCoordinate(
                 (RingVector.oneCoordinate(a)
                   : RingVector(Integer.commutative_ring_bundle, 1)), b)
                : RingVector(Integer.commutative_ring_bundle, 2)), c))
          = target := {
  Matrix.quadraticForm(
      Matrix.sumOfThreeSquaresForm,
      RingVector.appendCoordinate(
        (RingVector.appendCoordinate(
           (RingVector.oneCoordinate(a)
             : RingVector(Integer.commutative_ring_bundle, 1)), b)
          : RingVector(Integer.commutative_ring_bundle, 2)), c))
     = a * a + b * b + c * c
         by Matrix.sumOfThreeSquaresForm_coordinateTuple_value
     = target by scalarComputation;
  done
}

theorem Matrix.sumOfTwoSquaresForm_twoUnits_value
        : Matrix.quadraticForm(
            Matrix.sumOfTwoSquaresForm,
            RingVector.twoCoordinates((1 : ℤ), (1 : ℤ))) = 2 :=
  by Matrix.sumOfTwoSquaresForm_twoCoordinates_value

theorem Matrix.sumOfThreeSquaresForm_isometric_unitBorderCandidate
        (a b : ℤ) (aSquareOne : a * a = 1)
        (bSquareOne : b * b = 1)
        : Matrix.IsIsometric(
            Matrix.sumOfThreeSquaresForm,
            Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) := {
  let v : RingVector(Integer.commutative_ring_bundle, 2) :=
      RingVector.twoCoordinates(a, b);
  Matrix.sumOfTwoSquaresForm · v
     = Matrix.identity(Integer.commutative_ring_bundle, 2) · v
           by substituting Matrix.sumOfTwoSquaresForm_is_identity
     = v by Matrix.applyVector_identity
  as actionReads;
  Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, v)
     = a * a + b * b
           by Matrix.sumOfTwoSquaresForm_twoCoordinates_value
     = (1 : ℤ) + b * b by substituting aSquareOne
     = (1 : ℤ) + 1 by substituting bSquareOne
     = (2 : ℤ)
  as valueReads;
  Matrix.topShear(v)ᵀ * Matrix.sumOfThreeSquaresForm * Matrix.topShear(v)
     = Matrix.borderedAssembly(
           Matrix.sumOfTwoSquaresForm,
           Matrix.sumOfTwoSquaresForm · v,
           1 + Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, v))
           by Matrix.topShear_pullback_diagonalExtension
     = Matrix.borderedAssembly(
           Matrix.sumOfTwoSquaresForm, v,
           1 + Matrix.quadraticForm(Matrix.sumOfTwoSquaresForm, v))
           by substituting actionReads
     = Matrix.borderedAssembly(
           Matrix.sumOfTwoSquaresForm, v, (1 : ℤ) + 2)
           by substituting valueReads
     = Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)
  as pullbackReads;
  Matrix.IsInvertible(Matrix.topShear(v))
      by Matrix.topShear_invertible;
  Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)
      = Matrix.topShear(v)ᵀ
        * Matrix.sumOfThreeSquaresForm
        * Matrix.topShear(v)
      by pullbackReads;
  witness Matrix.topShear(v) with done
}

theorem Matrix.sumOfThreeSquaresForm_isometric_twoUnitBorderCandidate
        : Matrix.IsIsometric(
            Matrix.sumOfThreeSquaresForm,
            Matrix.sumOfTwoSquaresTwoUnitBorderCandidate) := {
  done by Matrix.sumOfThreeSquaresForm_isometric_unitBorderCandidate
}

theorem Matrix.sumOfTwoSquaresUnitBorderCandidate_truant
        (a b : ℤ) (aSquareOne : a * a = 1)
        (bSquareOne : b * b = 1)
        : Matrix.truant(
            Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b)) = 7 := {
  Matrix.IsIsometric(
      Matrix.sumOfThreeSquaresForm,
      Matrix.sumOfTwoSquaresUnitBorderCandidate(a, b))
      by Matrix.sumOfThreeSquaresForm_isometric_unitBorderCandidate
      as isometric;
  done by Matrix.isometric_truant_equals(
      isometric := isometric,
      isTruant := Matrix.sumOfThreeSquaresForm_truant_seven)
}

theorem Matrix.sumOfTwoSquaresTwoUnitBorderCandidate_truant
        : Matrix.truant(
            Matrix.sumOfTwoSquaresTwoUnitBorderCandidate) = 7 := {
  done by Matrix.sumOfTwoSquaresUnitBorderCandidate_truant
}

-- ----------------------------------------------------------------------
-- The remaining one-unit borders complete squares to
-- x²+y²+2z². This diagonal form represents 1 through 13 and misses 14.

definition Matrix.sumOfTwoSquaresPlusDoubleSquareForm
        : Matrix(Integer.commutative_ring_bundle, 1 + 2, 1 + 2) :=
  Matrix.diagonalExtension(Matrix.sumOfTwoSquaresForm, (2 : ℤ))

theorem Matrix.sumOfTwoSquaresPlusDoubleSquareForm_value
        (x : RingVector(Integer.commutative_ring_bundle, 1 + 2))
        : Matrix.quadraticForm(
              Matrix.sumOfTwoSquaresPlusDoubleSquareForm, x)
          = Matrix.quadraticForm(
                Matrix.sumOfTwoSquaresForm, RingVector.restrict(x))
            + x(NaturalsBelow.top(2)) * x(NaturalsBelow.top(2)) * 2 := {
  done by Matrix.diagonalExtension_quadraticForm(
      symmetric := Matrix.sumOfTwoSquaresForm_symmetric)
}

theorem Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents
        (a b k target : ℤ)
        (valueComputes : a * a + b * b + k * k * 2 = target)
        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusDoubleSquareForm, target) := {
  Matrix.Represents(
      Matrix.sumOfTwoSquaresForm, a * a + b * b)
      by Matrix.sumOfTwoSquaresForm_represents(
          a := a, b := b, target := a * a + b * b)
      as parentRepresents;
  Matrix.Represents(
      Matrix.sumOfTwoSquaresPlusDoubleSquareForm,
      (a * a + b * b) + k * k * 2)
      by Matrix.diagonalExtension_represents_parent_plus_square(
          symmetric := Matrix.sumOfTwoSquaresForm_symmetric,
          represented := parentRepresents);
  done by substituting valueComputes
}

theorem Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents_one
        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusDoubleSquareForm, (1 : ℤ)) := {
  done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents(
      a := 1, b := 0, k := 0)
}

theorem Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents_two
        : Matrix.Represents(
            Matrix.sumOfTwoSquaresPlusDoubleSquareForm, (2 : ℤ)) := {
  done by Matrix.sumOfTwoSquaresPlusDoubleSquareForm_represents(
      a := 0, b := 0, k := 1)
}


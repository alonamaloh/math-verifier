module Algebra.rank_four_weighted_d4_zero_c12

import Algebra.rank_four_weighted_d4_zero_residue_cover

theorem Matrix.weightedD4S0R0C12_universal_of_one_two_four_converse (converse : Matrix.OneTwoFourConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 0, 12)) :=
  by Matrix.weightedZero_universal_of_residual_cover(
      4, 12, Matrix.oneTwoFourResidualCover_selected_core_of_converse(
          converse, coefficient := 12, core := 2, coreSum := done,
          coreAdmissible := (exponent b : ℕ) ↦
            Natural.four_power_times_nonzero_mod_four_core_not_one_three_six_four_obstruction(
              exponent, b, 2, 0, 2, done, done, done, done, done)))

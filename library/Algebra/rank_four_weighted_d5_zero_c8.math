module Algebra.rank_four_weighted_d5_zero_c8

import Algebra.rank_four_weighted_d5_zero_residue_cover

theorem Matrix.weightedD5S0R0C8_universal_of_one_two_five_converse (converse : Matrix.OneTwoFiveConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(5, 0, 0, 8)) :=
  by Matrix.weightedZero_universal_of_residual_cover(
      5, 8, Matrix.oneTwoFiveResidualCover_selected_cores_of_converse(
          converse, coefficient := 8, coreTen := 2, coreFifteen := 7,
          tenCoreSum := done, fifteenCoreSum := done,
          tenCoreAdmissible := (exponent b : ℕ) ↦
            Natural.twenty_five_power_times_admissible_core_not_one_two_five_obstruction(
                exponent, b, 2, done, done, done, done),
          fifteenCoreAdmissible := (exponent b : ℕ) ↦
            Natural.twenty_five_power_times_admissible_core_not_one_two_five_obstruction(
                exponent, b, 7, done, done, done, done)))

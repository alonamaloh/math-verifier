-- Algebra/three_squares_matrix_bridge.math
--
-- Conversion between the matrix-level representation predicate for the
-- sum-of-three-squares form and its scalar existential presentation.

module Algebra.three_squares_matrix_bridge

import Algebra.three_squares_parity_transforms
import Algebra.rank_four_weighted_diagonal_orbits

theorem Integer.three_square_representation_of_matrix_representation
        (n : ℤ) (represented : Matrix.Represents(Matrix.sumOfThreeSquaresForm, n))
        : Integer.ThreeSquareRepresentation(n) := {
  choose vector : RingVector(Integer.commutative_ring_bundle, 3) such that
      Matrix.quadraticForm(Matrix.sumOfThreeSquaresForm, vector) = n
      as valueReads from represented;
  let x : ℤ := vector(NaturalsBelow.inclusion(2, NaturalsBelow.firstOfTwo));
  let y : ℤ := vector(NaturalsBelow.inclusion(2, NaturalsBelow.secondOfTwo));
  let z : ℤ := vector(NaturalsBelow.top(2));
  vector = (⟨x, y, z⟩ : RingVector(Integer.commutative_ring_bundle, 3))
      by RingVector.eq_threeCoordinates(vector) as vectorReads;
  Matrix.quadraticForm(Matrix.sumOfThreeSquaresForm, (⟨x, y, z⟩ : RingVector(Integer.commutative_ring_bundle, 3)))
     = Matrix.quadraticForm(Matrix.sumOfThreeSquaresForm, vector)
         by substituting Equality.symmetry(vectorReads)
     = n by valueReads
  as tupleValueReads;
  x * x + y * y + z * z
     = Matrix.quadraticForm(Matrix.sumOfThreeSquaresForm, (⟨x, y, z⟩ : RingVector(Integer.commutative_ring_bundle, 3)))
         by Equality.symmetry(Matrix.sumOfThreeSquaresForm_coordinateTuple_value(x, y, z))
     = n by tupleValueReads
  as scalarReads;
  witness x with witness y with witness z with scalarReads
}

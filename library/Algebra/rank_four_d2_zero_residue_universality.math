-- Algebra/rank_four_d2_zero_residue_universality.math
--
-- The six selected diagonal rank-four forms above x²+2y²+2z².
-- The ternary parent has the same represented set as three squares, so the
-- already-proved residual covers for coefficients 2,...,7 apply unchanged.

module Algebra.rank_four_d2_zero_residue_universality

import Algebra.three_squares_matrix_bridge
import Algebra.three_squares_residual_covers
import Algebra.rank_four_completed_cover_universality
import Algebra.rank_four_weighted_diagonal_orbits

theorem Matrix.weightedD2ZeroResidueCover_of_threeSquareResidualCover
        (corner : ℤ) (cover : Matrix.ThreeSquareResidualCover(corner))
        : Matrix.WeightedCompletedCover(2, 0, 0, corner) := {
  take m : ℕ;
  suppose m ≥ 1 as positive;
  choose residual : ℤ such that
      ∃ (w : ℤ).
        Matrix.Represents(Matrix.sumOfThreeSquaresForm, residual)
        ∧ residual + w * w * corner = (m : ℤ)
      from cover(m, positive);
  choose w : ℤ such that
      Matrix.Represents(Matrix.sumOfThreeSquaresForm, residual)
      ∧ residual + w * w * corner = (m : ℤ);
  Matrix.Represents(Matrix.sumOfThreeSquaresForm, residual) as residualRepresented;
  residual + w * w * corner = (m : ℤ) as valueReads;
  Integer.ThreeSquareRepresentation(residual)
      by Integer.three_square_representation_of_matrix_representation(residual, residualRepresented)
      as threeSquareRepresentation;
  choose x : ℤ such that
      ∃ (y z : ℤ). x * x + 2 * (y * y) + 2 * (z * z) = residual
      from Integer.three_square_representation_to_square_double_double(
          residual, threeSquareRepresentation);
  choose y : ℤ such that
      ∃ (z : ℤ). x * x + 2 * (y * y) + 2 * (z * z) = residual;
  choose z : ℤ such that
      x * x + 2 * (y * y) + 2 * (z * z) = residual as residualReads;
  let u : ℤ := 2 * y;
  let v : ℤ := 2 * z;
  u = 2 * y + 0 * w by ring as uReads;
  v = 2 * z + 0 * w by ring as vReads;
  (2 * 2) * (m : ℤ)
     = (2 * 2) * (residual + w * w * corner) by substituting Equality.symmetry(valueReads)
     = (2 * 2) * (x * x + 2 * (y * y) + 2 * (z * z) + w * w * corner)
         by substituting Equality.symmetry(residualReads)
     = (2 * 2) * (x * x) + 2 * (u * u) + 2 * (v * v)
       + (2 * 2 * corner - 2 * (0 * 0) - 2 * (0 * 0)) * (w * w) by ring
  as completed;
  witness x with witness y with witness z with witness w with witness u with witness v with
    And.introduction(uReads, And.introduction(vReads, completed))
}

theorem Matrix.weightedD2ZeroResidue_universal_of_threeSquareResidualCover
        (corner : ℤ) (cover : Matrix.ThreeSquareResidualCover(corner))
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(2, 0, 0, corner)) := {
  (2 : ℤ) * 2 ≠ 0 as scaleNonzero;
  Matrix.WeightedCompletedCover(2, 0, 0, corner)
      by Matrix.weightedD2ZeroResidueCover_of_threeSquareResidualCover(corner, cover)
      as completedCover;
  done by Matrix.squarePlusDoublePlusScaledRankFourRepresentative_universal(
      2, 0, 0, corner, scaleNonzero, completedCover)
}

theorem Matrix.weightedD2S0R0C2_universal_of_three_squares_converse
        (converse : Matrix.ThreeSquaresConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(2, 0, 0, 2)) :=
  by Matrix.weightedD2ZeroResidue_universal_of_threeSquareResidualCover(
      2, Matrix.threeSquareResidualCover_two_of_converse(converse))

theorem Matrix.weightedD2S0R0C3_universal_of_three_squares_converse
        (converse : Matrix.ThreeSquaresConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(2, 0, 0, 3)) :=
  by Matrix.weightedD2ZeroResidue_universal_of_threeSquareResidualCover(
      3, Matrix.threeSquareResidualCover_three_of_converse(converse))

theorem Matrix.weightedD2S0R0C4_universal_of_three_squares_converse
        (converse : Matrix.ThreeSquaresConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(2, 0, 0, 4)) :=
  by Matrix.weightedD2ZeroResidue_universal_of_threeSquareResidualCover(
      4, Matrix.threeSquareResidualCover_four_of_converse(converse))

theorem Matrix.weightedD2S0R0C5_universal_of_three_squares_converse
        (converse : Matrix.ThreeSquaresConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(2, 0, 0, 5)) :=
  by Matrix.weightedD2ZeroResidue_universal_of_threeSquareResidualCover(
      5, Matrix.threeSquareResidualCover_five_of_converse(converse))

theorem Matrix.weightedD2S0R0C6_universal_of_three_squares_converse
        (converse : Matrix.ThreeSquaresConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(2, 0, 0, 6)) :=
  by Matrix.weightedD2ZeroResidue_universal_of_threeSquareResidualCover(
      6, Matrix.threeSquareResidualCover_six_of_converse(converse))

theorem Matrix.weightedD2S0R0C7_universal_of_three_squares_converse
        (converse : Matrix.ThreeSquaresConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(2, 0, 0, 7)) :=
  by Matrix.weightedD2ZeroResidue_universal_of_threeSquareResidualCover(
      7, Matrix.threeSquareResidualCover_seven_of_converse(converse))

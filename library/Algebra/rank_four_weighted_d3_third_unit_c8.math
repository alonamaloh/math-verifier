module Algebra.rank_four_weighted_d3_third_unit_c8

import Algebra.rank_four_weighted_d3_third_unit_universality

theorem Matrix.weightedD3S0R1C8_universal_of_one_three_six_converse (converse : Matrix.OneThreeSixLocalConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 0, 1, 8)) := {
  3 * 8 = 23 + 1 by ring as coefficientShape;
  3 * 8 ∸ 1 = 23 by Natural.three_times_monus_one_value(8, 23, coefficientShape) as naturalCoefficientReads;
  ((3 * 8 ∸ 1 : ℕ) : ℤ) = 3 * (8 : ℤ) - 1
      by Natural.three_times_monus_one_to_integer(8, 23, coefficientShape) as coefficientReads;
  33 + (3 * 8 ∸ 1) = 33 + 23 by substituting naturalCoefficientReads = 56 by ring as halfCoreSum;
  7 + (3 * 8 ∸ 1) = 7 + 23 by substituting naturalCoefficientReads = 30 by ring as baseCoreSum;
  1 = 4 * 0 + 1 by ring as oneShape;
  1 + (1 + 2) = 4 by ring as oneBelowFourReads;
  1 < 4 by Natural.lt_intro(1, 4, 2, oneBelowFourReads) as oneBelowFour;
  0 + (1 + 0) = 1 by ring as onePositiveReads;
  0 < 1 by Natural.lt_intro(0, 1, 0, onePositiveReads) as onePositive;
  1 ≠ 0 by Natural.not_equal_of_greater_than(1, 0, onePositive) as oneNonzero;
  1 + (1 + 14) = 16 by ring as oneBelowSixteenReads;
  1 < 16 by Natural.lt_intro(1, 16, 14, oneBelowSixteenReads) as oneBelowSixteen;
  1 + (1 + 12) = 14 by ring as oneBelowFourteenReads;
  1 < 14 by Natural.lt_intro(1, 14, 12, oneBelowFourteenReads) as oneBelowFourteen;
  1 ≠ 14 by Natural.not_equal_of_less_than(1, 14, oneBelowFourteen) as oneNotFourteen;
  7 = 4 * 1 + 3 by ring as sevenShape;
  3 + (1 + 0) = 4 by ring as threeBelowFourReads;
  3 < 4 by Natural.lt_intro(3, 4, 0, threeBelowFourReads) as threeBelowFour;
  0 + (1 + 2) = 3 by ring as threePositiveReads;
  0 < 3 by Natural.lt_intro(0, 3, 2, threePositiveReads) as threePositive;
  3 ≠ 0 by Natural.not_equal_of_greater_than(3, 0, threePositive) as threeNonzero;
  7 + (1 + 8) = 16 by ring as sevenBelowSixteenReads;
  7 < 16 by Natural.lt_intro(7, 16, 8, sevenBelowSixteenReads) as sevenBelowSixteen;
  7 + (1 + 6) = 14 by ring as sevenBelowFourteenReads;
  7 < 14 by Natural.lt_intro(7, 14, 6, sevenBelowFourteenReads) as sevenBelowFourteen;
  7 ≠ 14 by Natural.not_equal_of_less_than(7, 14, sevenBelowFourteen) as sevenNotFourteen;
  Matrix.OneThreeSixTripleTargetCover(8)
      by Matrix.oneThreeSixTripleTargetCover_half_scale_of_local_converse(
          converse, corner := 8, halfCore := 33, baseCore := 7,
          coefficientReads := coefficientReads, halfCoreSum := halfCoreSum, baseCoreSum := baseCoreSum,
          halfAdmissible := (exponent b : ℕ) ↦ {
            4 ^ exponent * (64 * b + 33) = 4 ^ exponent * (16 * (4 * b + 2) + 1) by ring as valueReads;
            suppose Natural.IsOneThreeSixFourObstruction(4 ^ exponent * (64 * b + 33)) as obstruction;
            Natural.IsOneThreeSixFourObstruction(4 ^ exponent * (16 * (4 * b + 2) + 1))
                by substituting valueReads as transformedObstruction;
            done by Natural.four_power_times_nonzero_mod_four_core_not_one_three_six_four_obstruction(
                exponent, 4 * b + 2, 1, 0, 1, oneShape,
                oneBelowFour, oneNonzero, oneBelowSixteen, oneNotFourteen)(transformedObstruction)
          },
          baseAdmissible := (b : ℕ) ↦ {
            4 ^ 0 * (16 * b + 7) = 16 * b + 7 by substituting Natural.power_zero(4) as valueReads;
            suppose Natural.IsOneThreeSixFourObstruction(16 * b + 7) as obstruction;
            Natural.IsOneThreeSixFourObstruction(4 ^ 0 * (16 * b + 7))
                by substituting Equality.symmetry(valueReads) as transformedObstruction;
            done by Natural.four_power_times_nonzero_mod_four_core_not_one_three_six_four_obstruction(
                0, b, 7, 1, 3, sevenShape,
                threeBelowFour, threeNonzero, sevenBelowSixteen, sevenNotFourteen)(transformedObstruction)
          })
      as cover;
  done by Matrix.weightedD3ThirdUnit_universal_of_cover(8, coefficientReads, cover)
}

-- Algebra/rank_four_odd_c4_sublattice_pilots.math
--
-- Two determinant-seven pilots proved by restricting to index-two
-- sublattices whose forms already have conditional universality proofs.
--
-- For oddC4R0C4, the coordinate map
--
--   (x,y,z,w) ↦ (x,-y-w,2w,-z)
--
-- pulls the odd form back to x²+2y²+4z²+14w².
--
-- For oddC4R3C7, the coordinate map
--
--   (x,y,z,w) ↦ (x,-y-2z+w,z+w,z-w)
--
-- pulls it back to the weighted-D3 form
-- x²+2y²+3z²+2zw+9w².

module Algebra.rank_four_odd_c4_sublattice_pilots

import Algebra.one_two_four_converse_reduction
import Algebra.rank_four_weighted_d4_zero_c14
import Algebra.rank_four_weighted_d3_third_unit_c9

theorem Matrix.oddC4R0C4_represents_of_weightedD4S0R0C14
        (target : ℤ)
        (represented : Matrix.Represents(
          Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 0, 14), target))
        : Matrix.Represents(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 4), target) := {
  choose vector : RingVector(Integer.commutative_ring_bundle, 4) such that
      Matrix.quadraticForm(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 0, 14), vector) = target
      as valueReads from represented;
  let x : ℤ := vector(NaturalsBelow.firstOfFour);
  let y : ℤ := vector(NaturalsBelow.secondOfFour);
  let z : ℤ := vector(NaturalsBelow.thirdOfFour);
  let w : ℤ := vector(NaturalsBelow.fourthOfFour);
  vector = (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4))
      by RingVector.eq_fourCoordinates(vector) as vectorReads;
  x * x + 2 * (y * y) + 4 * (z * z) + 14 * (w * w)
     = x * x + 2 * (y * y) + 4 * (z * z) + 2 * 0 * y * w + 2 * 0 * z * w + 14 * (w * w) by ring
     = Matrix.quadraticForm(
         Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 0, 14),
         (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4)))
         by Equality.symmetry(
           Matrix.squarePlusDoublePlusScaledRankFourRepresentative_coordinateTuple_value(
             4, 0, 0, 14, x, y, z, w))
     = Matrix.quadraticForm(
         Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 0, 14), vector)
         by substituting Equality.symmetry(vectorReads)
     = target by valueReads
  as donorValue;
  x * x + 2 * ((-y - w) * (-y - w)) + 2 * (-y - w) * (2 * w) + 4 * ((2 * w) * (2 * w))
      + 2 * 0 * (-y - w) * (-z) + 4 * ((-z) * (-z))
     = x * x + 2 * (y * y) + 4 * (z * z) + 14 * (w * w) by ring
     = target by donorValue
  as scalarComputation;
  done by Matrix.represents_by_witness(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 4),
      target := target, vector := ⟨x, -y - w, 2 * w, -z⟩,
      computes := Matrix.squarePlusDoubleSquareOddRankFourRepresentative_coordinateTuple_computes(
        scalarComputation := scalarComputation))
}

theorem Matrix.oddC4R0C4_universal_of_three_squares_converse
        (converse : Matrix.ThreeSquaresConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 4)) := {
  Matrix.OneTwoFourConverse by Matrix.one_two_four_converse_of_three_squares(converse) as oneTwoFour;
  Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 0, 14))
      by Matrix.weightedD4S0R0C14_universal_of_one_two_four_converse(oneTwoFour) as donorUniversal;
  take m : ℕ;
  suppose m ≥ 1;
  done by Matrix.oddC4R0C4_represents_of_weightedD4S0R0C14(
      m, donorUniversal(m, done))
}

theorem Matrix.oddC4R3C7_represents_of_weightedD3S0R1C9
        (target : ℤ)
        (represented : Matrix.Represents(
          Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 0, 1, 9), target))
        : Matrix.Represents(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 7), target) := {
  choose vector : RingVector(Integer.commutative_ring_bundle, 4) such that
      Matrix.quadraticForm(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 0, 1, 9), vector) = target
      as valueReads from represented;
  let x : ℤ := vector(NaturalsBelow.firstOfFour);
  let y : ℤ := vector(NaturalsBelow.secondOfFour);
  let z : ℤ := vector(NaturalsBelow.thirdOfFour);
  let w : ℤ := vector(NaturalsBelow.fourthOfFour);
  vector = (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4))
      by RingVector.eq_fourCoordinates(vector) as vectorReads;
  x * x + 2 * (y * y) + 3 * (z * z) + 2 * z * w + 9 * (w * w)
     = x * x + 2 * (y * y) + 3 * (z * z) + 2 * 0 * y * w + 2 * 1 * z * w + 9 * (w * w) by ring
     = Matrix.quadraticForm(
         Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 0, 1, 9),
         (⟨x, y, z, w⟩ : RingVector(Integer.commutative_ring_bundle, 4)))
         by Equality.symmetry(
           Matrix.squarePlusDoublePlusScaledRankFourRepresentative_coordinateTuple_value(
             3, 0, 1, 9, x, y, z, w))
     = Matrix.quadraticForm(
         Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 0, 1, 9), vector)
         by substituting Equality.symmetry(vectorReads)
     = target by valueReads
  as donorValue;
  x * x + 2 * ((-y - 2 * z + w) * (-y - 2 * z + w))
      + 2 * (-y - 2 * z + w) * (z + w) + 4 * ((z + w) * (z + w))
      + 2 * 3 * (-y - 2 * z + w) * (z - w) + 7 * ((z - w) * (z - w))
     = x * x + 2 * (y * y) + 3 * (z * z) + 2 * z * w + 9 * (w * w) by ring
     = target by donorValue
  as scalarComputation;
  done by Matrix.represents_by_witness(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 7),
      target := target, vector := ⟨x, -y - 2 * z + w, z + w, z - w⟩,
      computes := Matrix.squarePlusDoubleSquareOddRankFourRepresentative_coordinateTuple_computes(
        scalarComputation := scalarComputation))
}

theorem Matrix.oddC4R3C7_universal_of_one_three_six_converse
        (converse : Matrix.OneThreeSixLocalConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 7)) := {
  Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 0, 1, 9))
      by Matrix.weightedD3S0R1C9_universal_of_one_three_six_converse(converse) as donorUniversal;
  take m : ℕ;
  suppose m ≥ 1;
  done by Matrix.oddC4R3C7_represents_of_weightedD3S0R1C9(
      m, donorUniversal(m, done))
}

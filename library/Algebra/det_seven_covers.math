-- Algebra/det_seven_covers.math
--
-- Final assembly of the seven determinant-seven rank-four covers.  The
-- theorem deliberately exposes both classical inputs: the restricted
-- determinant-seven converse used by every form, and Legendre's converse
-- used by the exceptional even branch of Q_(1,7).

module Algebra.det_seven_covers

import Algebra.det_seven_generic_covers
import Algebra.det_seven_exceptional_cover

theorem Matrix.detSeven_seven_universal
        (detSeven : Matrix.DetSevenSafeConverse)
        (threeSquares : Matrix.ThreeSquaresConverse)
        : Matrix.IsUniversal(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 7))
          ∧ Matrix.IsUniversal(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 1, 6))
          ∧ Matrix.IsUniversal(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 1, 7))
          ∧ Matrix.IsUniversal(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 8))
          ∧ Matrix.IsUniversal(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 9))
          ∧ Matrix.IsUniversal(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 10))
          ∧ Matrix.IsUniversal(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 11)) := {
  Matrix.IsUniversal(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 7))
      by Matrix.oddC4R0C7_universal_of_det_seven_safe_converse(detSeven);
  Matrix.IsUniversal(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 1, 6))
      by Matrix.oddC4R1C6_universal_of_det_seven_safe_converse(detSeven);
  Matrix.IsUniversal(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 1, 7))
      by Matrix.oddC4R1C7_universal_of_det_seven_and_three_squares(
        detSeven, threeSquares);
  Matrix.IsUniversal(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 8))
      by Matrix.oddC4R2C8_universal_of_det_seven_safe_converse(detSeven);
  Matrix.IsUniversal(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 9))
      by Matrix.oddC4R2C9_universal_of_det_seven_safe_converse(detSeven);
  Matrix.IsUniversal(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 10))
      by Matrix.oddC4R3C10_universal_of_det_seven_safe_converse(detSeven);
  Matrix.IsUniversal(
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 11))
      by Matrix.oddC4R3C11_universal_of_det_seven_safe_converse(detSeven);
  done
}

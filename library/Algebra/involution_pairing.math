-- Algebra/involution_pairing.math
--
-- The orbit-pairing sum-zero lemma: a finite sum over a distinct list that
-- is closed under a fixed-point-free, sign-reversing involution vanishes.
-- Genuine 2-element-orbit pairing (each `g(x) + g(ι x) = 0`), NOT the
-- `Σ g = Σ g∘ι = −Σ g ⟹ 2Σ = 0 ⟹ Σ = 0` shortcut — that would need
-- char ≠ 2, and this must hold over ANY field (Stage H det multiplicativity).
--
-- Route: strong induction on the list length. In the step, remove the head's
-- orbit `{head, ι head}` (its two terms sum to zero), leaving a shorter list
-- still distinct and ι-closed, and recurse.

module Algebra.involution_pairing

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Natural.order
import Natural.strong_recursion
import Lists.list
import Lists.distinct
import Lists.length
import Lists.remove
import Algebra.field
import Algebra.field_bundle
import Algebra.field_aggregation

-- Strong-induction workhorse: the pairing lemma with the list length pinned
-- to the induction variable `n`.
theorem Field.sumOver_involution_pairing_aux {f : Field} {index : Type(0)}
        (g : index → Field.carrier(f)) (iota : index → index)
        (n : ℕ)
        : ∀ (items : List(index)).
          length(items) = n
          → List.Distinct(index, items)
          → (∀ (x : index). x ∈ items → iota(x) ∈ items)
          → (∀ (x : index). x ∈ items → ¬(iota(x) = x))
          → (∀ (x : index). x ∈ items → iota(iota(x)) = x)
          → (∀ (x : index). x ∈ items → g(x) + g(iota(x)) = Field.zero(f))
          → Field.sumOver(g, items) = Field.zero(f) :=
  by induction on n using Natural.strong_induction with subject, IH {
      take items : List(index);
      suppose length(items) = subject as lengthEquation;
      suppose List.Distinct(index, items) as distinct;
      suppose (∀ (x : index). x ∈ items
          → iota(x) ∈ items) as closed;
      suppose (∀ (x : index). x ∈ items → ¬(iota(x) = x)) as noFixedPoint;
      suppose (∀ (x : index). x ∈ items → iota(iota(x)) = x) as involutive;
      suppose (∀ (x : index). x ∈ items
          → g(x) + g(iota(x)) = Field.zero(f)) as reversing;
      done by cases {
        case items = List.empty(index):
            Field.sumOver(g, List.empty(index)) = Field.zero(f)
        case items = List.prepend(index, head, tail)
            for some (head : index), (tail : List(index)): {
          ¬(head ∈ tail)
              by List.Distinct.head_not_member as headNotInTail;
          List.Distinct(index, tail) by List.Distinct.tail_distinct;

          -- The head and its orbit partner ι(head), which lands in the tail.
          head ∈ List.prepend(index, head, tail) as headMember;
          iota(head) ∈ List.prepend(index, head, tail) by closed(head, headMember);
          ¬(iota(head) = head) by noFixedPoint(head, headMember);
          iota(head) ∈ tail by List.member_of_prepend_not_head;

          -- The removed list and its length, strictly below `subject`.
          let removed : List(index) := tail ∖ iota(head);
          length(tail) = 1 + length(removed)
              by List.length_remove_member as tailLengthEquation;
          length(removed)
             < 1 + length(removed)
             = length(tail)                              by tailLengthEquation
             < 1 + length(tail)
             = length(List.prepend(index, head, tail))
             = subject
             as removedLengthBelow;

          -- Every member of `removed` came from `items`; restrict the
          -- fixed-point-free / involutive / reversing hypotheses down to it.
          ∀ (x : index). x ∈ removed
              → x ∈ List.prepend(index, head, tail)
              by (x : index) (xInRemoved : x ∈ removed) ↦ {
                  x ∈ tail by List.remove_member_subset;
                  done
                } as memberLift;

          -- `removed` is still closed under ι.
          ∀ (x : index). x ∈ removed
              → iota(x) ∈ removed
              by (x : index) (xInRemoved : x ∈ removed) ↦ {
                  x ∈ tail by List.remove_member_subset;
                  x ∈ List.prepend(index, head, tail)
                      by memberLift(x, xInRemoved) as xInItems;
                  iota(x) ∈ List.prepend(index, head, tail) by closed(x, xInItems);
                  iota(iota(x)) = x by involutive(x, xInItems) as involutiveX;
                  -- ι(x) ≠ head: else x = ι(head), removed from the tail.
                  ¬(iota(x) = head)
                      by (iotaXEqHead : iota(x) = head) ↦ {
                          x = iota(iota(x))                     by involutiveX
                            = iota(head)                        by substituting iotaXEqHead;
                          ¬(x = iota(head)) by List.remove_member_ne;
                          done
                        };
                  iota(x) ∈ tail by List.member_of_prepend_not_head;
                  -- ι(x) ≠ ι(head): else x = head, but x ∈ tail and head ∉ tail.
                  ¬(iota(x) = iota(head))
                      by (iotaXEqIotaHead : iota(x) = iota(head)) ↦ {
                          x = iota(iota(x))                     by involutiveX
                            = iota(iota(head))                  by substituting iotaXEqIotaHead
                            = head                              by involutive(head, headMember)
                            as xEqHead;
                          head ∈ tail by substituting xEqHead as headInTail;
                          headNotInTail(headInTail)
                        };
                  done by List.remove_member_complete
                } as closedRemoved;

          ∀ (x : index). x ∈ removed → ¬(iota(x) = x)
              by (x : index) (xInRemoved : x ∈ removed) ↦
                  noFixedPoint(x, memberLift(x, xInRemoved)) as noFixedPointRemoved;
          ∀ (x : index). x ∈ removed → iota(iota(x)) = x
              by (x : index) (xInRemoved : x ∈ removed) ↦
                  involutive(x, memberLift(x, xInRemoved)) as involutiveRemoved;
          ∀ (x : index). x ∈ removed
              → g(x) + g(iota(x)) = Field.zero(f)
              by (x : index) (xInRemoved : x ∈ removed) ↦
                  reversing(x, memberLift(x, xInRemoved)) as reversingRemoved;

          -- Recurse on the shorter list, then reassemble the orbit.
          List.Distinct(index, removed) by List.remove_distinct as removedDistinct;
          Field.sumOver(g, removed) = Field.zero(f)
              by IH(length(removed), removedLengthBelow)(removed,
                     reflexivity(ℕ, length(removed)),
                     removedDistinct,
                     closedRemoved, noFixedPointRemoved, involutiveRemoved, reversingRemoved)
              as removedSumZero;
          Field.sumOver(g, tail)
              = g(iota(head)) + Field.sumOver(g, removed)
              by Field.sumOver_remove as tailSum;
          g(head) + g(iota(head)) = Field.zero(f)
              by reversing(head, headMember) as orbitZero;

          Field.sumOver(g, List.prepend(index, head, tail))
             = g(head) + Field.sumOver(g, tail)
             = g(head) + (g(iota(head)) + Field.sumOver(g, removed))   by substituting tailSum
             = (g(head) + g(iota(head))) + Field.sumOver(g, removed)
             = Field.zero(f) + Field.sumOver(g, removed)               by substituting orbitZero
             = Field.zero(f) + Field.zero(f)                           by substituting removedSumZero
             = Field.zero(f)
        }
      }
  }

-- The orbit-pairing sum-zero lemma. `iota` is a fixed-point-free involution
-- of the distinct list `items` under which `g` is sign-reversing
-- (`g(x) + g(ι x) = 0`); the sum vanishes.
theorem Field.sumOver_involution_pairing {f : Field} {index : Type(0)}
        (g : index → Field.carrier(f)) (iota : index → index)
        (items : List(index))
        (distinct : List.Distinct(index, items))
        (closed : ∀ (x : index). x ∈ items → iota(x) ∈ items)
        (noFixedPoint : ∀ (x : index). x ∈ items → ¬(iota(x) = x))
        (involutive : ∀ (x : index). x ∈ items → iota(iota(x)) = x)
        (reversing : ∀ (x : index). x ∈ items
            → g(x) + g(iota(x)) = Field.zero(f))
        : Field.sumOver(g, items) = Field.zero(f) :=
  by Field.sumOver_involution_pairing_aux(n := length(items))

module Algebra.rank_four_weighted_d3_third_unit_c3

import Algebra.rank_four_weighted_d3_third_unit_universality

theorem Matrix.weightedD3S0R1C3_universal_of_one_three_six_converse (converse : Matrix.OneThreeSixLocalConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 0, 1, 3)) := {
  3 * 3 = 8 + 1 by ring as coefficientShape;
  3 * 3 ∸ 1 = 8 by Natural.three_times_monus_one_value(3, 8, coefficientShape) as naturalCoefficientReads;
  ((3 * 3 ∸ 1 : ℕ) : ℤ) = 3 * (3 : ℤ) - 1
      by Natural.three_times_monus_one_to_integer(3, 8, coefficientShape) as coefficientReads;
  6 + (3 * 3 ∸ 1) = 6 + 8 by substituting naturalCoefficientReads = 14 by ring as coreSum;
  6 = 4 * 1 + 2 by ring as coreShape;
  2 + (1 + 1) = 4 by ring as remainderBelowReads;
  2 < 4 by Natural.lt_intro(2, 4, 1, remainderBelowReads) as remainderBelow;
  0 + (1 + 1) = 2 by ring as remainderPositiveReads;
  0 < 2 by Natural.lt_intro(0, 2, 1, remainderPositiveReads) as remainderPositive;
  2 ≠ 0 by Natural.not_equal_of_greater_than(2, 0, remainderPositive) as remainderNonzero;
  6 + (1 + 9) = 16 by ring as coreBelowReads;
  6 < 16 by Natural.lt_intro(6, 16, 9, coreBelowReads) as coreBelow;
  6 + (1 + 7) = 14 by ring as coreBelowFourteenReads;
  6 < 14 by Natural.lt_intro(6, 14, 7, coreBelowFourteenReads) as coreBelowFourteen;
  6 ≠ 14 by Natural.not_equal_of_less_than(6, 14, coreBelowFourteen) as coreNotFourteen;
  Matrix.OneThreeSixTripleTargetCover(3)
      by Matrix.oneThreeSixTripleTargetCover_full_scale_of_local_converse(
          converse, corner := 3, core := 6, quotient := 1, remainder := 2,
          coefficientReads := coefficientReads, coreSum := coreSum, coreShape := coreShape,
          remainderBelow := remainderBelow, remainderNonzero := remainderNonzero,
          coreBelow := coreBelow, coreNotFourteen := coreNotFourteen)
      as cover;
  done by Matrix.weightedD3ThirdUnit_universal_of_cover(3, coefficientReads, cover)
}

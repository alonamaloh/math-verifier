-- Algebra/ring_difference.math
--
-- Difference (x + (вҲ’y)) rearrangement identities in an arbitrary
-- bundled ring `s`. These are the abstract-ring analogues of the
-- `ring`-tactic rewrites that the concrete-carrier constructions
-- (IntegerMod) get for free: the `ring` tactic only fires on carriers
-- with registered `+`/`*`/`-` operators (Integer, Rational, вҖҰ), but a
-- bundled ring's operations are `Ring.add(s, вҖҰ)` applications with no
-- operator syntax, so the rearrangements a quotient-by-principal-ideal
-- construction needs are proved here once, from the bundle's flattened
-- law projections plus the abstract group/ring lemmas.
--
-- The "difference of x and y" is written out as `Ring.add(s, x,
-- Ring.negate(s, y))` everywhere (no separate `subtract` definition):
-- keeping every term add/negate-headed lets the diff-inferred `by`
-- congruence in `calc` line the endpoints up structurally.

module Algebra.ring_difference

import Logic.basics
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas

-- Negation distributes over a sum (additive group is abelian):
-- вҲ’(a + b) = (вҲ’a) + (вҲ’b).
theorem Ring.negate_add_distribute (s : Ring) (a b : Ring.carrier(s))
        : Ring.negate(s, Ring.add(s, a, b))
          = Ring.add(s, Ring.negate(s, a), Ring.negate(s, b)) := {
  let вҹЁadditiveAbelianGroup, _, _, _вҹ© := Ring.is_ring(s);
  AbelianGroup.inverse_operation(
      Ring.carrier(s), Ring.add, Ring.zero(s), Ring.negate,
      additiveAbelianGroup, a, b)
}

-- Negating a difference flips it: вҲ’(g + (вҲ’h)) = h + (вҲ’g).
theorem Ring.negate_difference (s : Ring) (g h : Ring.carrier(s))
        : Ring.negate(s, Ring.add(s, g, Ring.negate(s, h)))
          = Ring.add(s, h, Ring.negate(s, g)) := {
  let вҹЁadditiveAbelianGroup, _, _, _вҹ© := Ring.is_ring(s);
  let вҹЁadditiveGroup, _вҹ© := additiveAbelianGroup;
  calc Ring.negate(s, Ring.add(s, g, Ring.negate(s, h)))
     = Ring.add(s, Ring.negate(s, g), Ring.negate(s, Ring.negate(s, h)))
           by Ring.negate_add_distribute(s, g, Ring.negate(s, h))
     = Ring.add(s, Ring.negate(s, g), h)
           by Group.inverse_involution(
                  Ring.carrier(s), Ring.add, Ring.zero(s), Ring.negate,
                  additiveGroup, h)
     = Ring.add(s, h, Ring.negate(s, g))
           by Ring.add_commutative(s, Ring.negate(s, g), h)
}

-- Telescoping cancellation: (g + (вҲ’h)) + (h + (вҲ’k)) = g + (вҲ’k).
theorem Ring.difference_telescope (s : Ring) (g h k : Ring.carrier(s))
        : Ring.add(s, Ring.add(s, g, Ring.negate(s, h)),
                   Ring.add(s, h, Ring.negate(s, k)))
          = Ring.add(s, g, Ring.negate(s, k)) := {
  calc Ring.add(s, Ring.add(s, g, Ring.negate(s, h)),
                Ring.add(s, h, Ring.negate(s, k)))
     = Ring.add(s, g,
                Ring.add(s, Ring.negate(s, h),
                         Ring.add(s, h, Ring.negate(s, k))))
           by Ring.add_associative(s, g, Ring.negate(s, h),
                  Ring.add(s, h, Ring.negate(s, k)))
     = Ring.add(s, g,
                Ring.add(s, Ring.add(s, Ring.negate(s, h), h),
                         Ring.negate(s, k)))
           by Equality.symmetry(
                  Ring.add_associative(s, Ring.negate(s, h), h,
                      Ring.negate(s, k)))
     = Ring.add(s, g, Ring.add(s, Ring.zero(s), Ring.negate(s, k)))
           by Ring.add_negate_left(s, h)
     = Ring.add(s, g, Ring.negate(s, k))
           by Ring.zero_add(s, Ring.negate(s, k))
}

-- Differences add componentwise:
-- (a + (вҲ’a')) + (b + (вҲ’b')) = (a + b) + (вҲ’(a' + b')).
theorem Ring.difference_add_distribute (s : Ring) (a a' b b' : Ring.carrier(s))
        : Ring.add(s, Ring.add(s, a, Ring.negate(s, a')),
                   Ring.add(s, b, Ring.negate(s, b')))
          = Ring.add(s, Ring.add(s, a, b),
                     Ring.negate(s, Ring.add(s, a', b'))) := {
  calc Ring.add(s, Ring.add(s, a, Ring.negate(s, a')),
                Ring.add(s, b, Ring.negate(s, b')))
     = Ring.add(s, Ring.add(s, a, b),
                Ring.add(s, Ring.negate(s, a'), Ring.negate(s, b')))
           by Ring.add_four_swap(s, a, Ring.negate(s, a'), b, Ring.negate(s, b'))
     = Ring.add(s, Ring.add(s, a, b),
                Ring.negate(s, Ring.add(s, a', b')))
           by Equality.symmetry(Ring.negate_add_distribute(s, a', b'))
}

-- The multiplication-respects rearrangement, with no commutativity
-- needed: (a + (вҲ’a'))В·b + a'В·(b + (вҲ’b')) = aВ·b + (вҲ’(a'В·b')). Both
-- products expand by distributivity to a four-term telescope whose
-- middle terms вҲ’(a'В·b) and a'В·b cancel.
theorem Ring.difference_multiply_split (s : Ring) (a a' b b' : Ring.carrier(s))
        : Ring.add(s,
              Ring.multiply(s, Ring.add(s, a, Ring.negate(s, a')), b),
              Ring.multiply(s, a', Ring.add(s, b, Ring.negate(s, b'))))
          = Ring.add(s, Ring.multiply(s, a, b),
                     Ring.negate(s, Ring.multiply(s, a', b'))) := {
  claim leftExpansion
      : Ring.multiply(s, Ring.add(s, a, Ring.negate(s, a')), b)
        = Ring.add(s, Ring.multiply(s, a, b),
                   Ring.negate(s, Ring.multiply(s, a', b)))
      by calc Ring.multiply(s, Ring.add(s, a, Ring.negate(s, a')), b)
            = Ring.add(s, Ring.multiply(s, a, b),
                       Ring.multiply(s, Ring.negate(s, a'), b))
                  by Ring.distributivity_right(s, a, Ring.negate(s, a'), b)
            = Ring.add(s, Ring.multiply(s, a, b),
                       Ring.negate(s, Ring.multiply(s, a', b)))
                  by Ring.multiply_negate_left(
                         Ring.carrier(s), Ring.add, Ring.zero(s),
                         Ring.negate, Ring.multiply, Ring.one(s),
                         Ring.is_ring(s), a', b);
  claim rightExpansion
      : Ring.multiply(s, a', Ring.add(s, b, Ring.negate(s, b')))
        = Ring.add(s, Ring.multiply(s, a', b),
                   Ring.negate(s, Ring.multiply(s, a', b')))
      by calc Ring.multiply(s, a', Ring.add(s, b, Ring.negate(s, b')))
            = Ring.add(s, Ring.multiply(s, a', b),
                       Ring.multiply(s, a', Ring.negate(s, b')))
                  by Ring.distributivity_left(s, a', b, Ring.negate(s, b'))
            = Ring.add(s, Ring.multiply(s, a', b),
                       Ring.negate(s, Ring.multiply(s, a', b')))
                  by Ring.multiply_negate_right(
                         Ring.carrier(s), Ring.add, Ring.zero(s),
                         Ring.negate, Ring.multiply, Ring.one(s),
                         Ring.is_ring(s), a', b');
  calc Ring.add(s,
           Ring.multiply(s, Ring.add(s, a, Ring.negate(s, a')), b),
           Ring.multiply(s, a', Ring.add(s, b, Ring.negate(s, b'))))
     = Ring.add(s,
           Ring.add(s, Ring.multiply(s, a, b),
                    Ring.negate(s, Ring.multiply(s, a', b))),
           Ring.multiply(s, a', Ring.add(s, b, Ring.negate(s, b'))))
           by leftExpansion
     = Ring.add(s,
           Ring.add(s, Ring.multiply(s, a, b),
                    Ring.negate(s, Ring.multiply(s, a', b))),
           Ring.add(s, Ring.multiply(s, a', b),
                    Ring.negate(s, Ring.multiply(s, a', b'))))
           by rightExpansion
     = Ring.add(s, Ring.multiply(s, a, b),
                Ring.negate(s, Ring.multiply(s, a', b')))
           by Ring.difference_telescope(s, Ring.multiply(s, a, b),
                  Ring.multiply(s, a', b), Ring.multiply(s, a', b'))
}

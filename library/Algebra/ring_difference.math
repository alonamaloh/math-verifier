-- Algebra/ring_difference.math
--
-- Negation distributes over a sum in an arbitrary bundled ring `s`:
-- −(a + b) = (−a) + (−b). This holds in any ring (the additive group is
-- abelian) and is stated over a plain `(s : Ring)`. It is also the law the
-- abstract-ring `ring` normaliser cites to push negation inward, so it must
-- be in scope wherever `ring` is expected to handle subtraction.
--
-- (The derived difference rearrangements — telescope, componentwise add,
-- the multiply split, negate-a-difference — used to live here too; they are
-- now proved on demand by `ring` over an abstract carrier, so their call
-- sites construct the divisibility witness directly instead.)

module Algebra.ring_difference

import Logic.basics
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas

-- Negation distributes over a sum (additive group is abelian):
-- −(a + b) = (−a) + (−b).
theorem Ring.negate_add_distribute (s : Ring) (a b : Ring.carrier(s))
        : Ring.negate(s, a + b)
          = Ring.negate(s, a) + Ring.negate(s, b) := {
  claim IsRing(Ring.carrier(s), Ring.add, Ring.zero(s), Ring.negate, Ring.multiply, Ring.one(s))
      by Ring.is_ring;
  claim IsAbelianGroup(Ring.carrier(s), Ring.add, Ring.zero(s), Ring.negate);
  done by AbelianGroup.inverse_operation
}

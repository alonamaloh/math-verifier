-- Algebra/ring_bundle.math
--
-- A *bundled* ring: a single value `r : Ring` carrying its carrier
-- type, the five operations, and the `IsRing` proof together. This is
-- the consumer-facing layer over the unbundled `IsRing` predicate —
-- it lets a generic construction (e.g. Polynomial) thread one `r`
-- instead of `(carrier, add, zero, negate, multiply, one, ringProof)`
-- at every call.
--
-- `Ring` is a single-constructor inductive (a dependent record); the
-- projections below recover each field, and the kernel reduces them on
-- a concrete `Ring.make(...)`. The flattened law projections
-- (`Ring.add_associative`, `Ring.zero_add`, …) pull the individual
-- equations out of the nested-∧ `IsRing` once, so consumers never walk
-- the hierarchy by hand.
--
-- NOTE: the field projections are written with a destructuring
-- `let ⟨…⟩ := r in …` rather than the pattern-match-definition form
-- `| Ring.make(…) => …`. The latter's codegen does not yet handle a
-- dependent motive (the return type of `add` mentions `Ring.carrier(r)`);
-- the destructuring-let builds the motive correctly.

module Algebra.ring_bundle

import Logic.basics
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.ring
import Algebra.ring_lemmas

-- A ring bundled with its carrier, operations, and laws. Lives in
-- Type(1) because it carries a Type(0) carrier.
inductive Ring : Type(1) where
  | Ring.make
      : (carrier : Type(0))
        → (add : carrier → carrier → carrier)
        → (zero : carrier)
        → (negate : carrier → carrier)
        → (multiply : carrier → carrier → carrier)
        → (one : carrier)
        → IsRing(carrier, add, zero, negate, multiply, one)
        → Ring

-- ----------------------------------------------------------------------
-- Field projections.

definition Ring.carrier : Ring → Type(0)
  | Ring.make(carrier, add, zero, negate, multiply, one, isRing) => carrier

-- The operation projections take their ring implicitly, so they read as
-- operators: `x + y` / `x * y` / `x - y` over an abstract `Ring.carrier`
-- recover `{r}` from the operand type. Full-application call sites
-- (`Ring.add(r, x, y)`) still work by passing `r` positionally; only
-- partial/slot uses must be written bare (`Ring.add`), recovering `r`
-- from the expected operation type. The constants `zero`/`one` keep an
-- explicit ring (no operands to recover from).
definition Ring.add {r : Ring}
        : Ring.carrier(r) → Ring.carrier(r) → Ring.carrier(r) :=
  let ⟨carrier, add, zero, negate, multiply, one, isRing⟩ := r in
    add

definition Ring.zero (r : Ring) : Ring.carrier(r) :=
  let ⟨carrier, add, zero, negate, multiply, one, isRing⟩ := r in
    zero

definition Ring.negate {r : Ring}
        : Ring.carrier(r) → Ring.carrier(r) :=
  let ⟨carrier, add, zero, negate, multiply, one, isRing⟩ := r in
    negate

definition Ring.multiply {r : Ring}
        : Ring.carrier(r) → Ring.carrier(r) → Ring.carrier(r) :=
  let ⟨carrier, add, zero, negate, multiply, one, isRing⟩ := r in
    multiply

definition Ring.one (r : Ring) : Ring.carrier(r) :=
  let ⟨carrier, add, zero, negate, multiply, one, isRing⟩ := r in
    one

-- x − y := x + (−y) on the bundle's carrier.
definition Ring.subtract {r : Ring} (x y : Ring.carrier(r)) : Ring.carrier(r) :=
  Ring.add(x, Ring.negate(y))

-- Operator overloads dispatch on the carrier-projection head, distinct
-- from any concrete carrier's head, so they never clash with the
-- per-carrier operators (Integer, Rational, …).
operator (+) on (Ring.carrier, Ring.carrier) := Ring.add
operator (-) on (Ring.carrier, Ring.carrier) := Ring.subtract
operator (*) on (Ring.carrier, Ring.carrier) := Ring.multiply

definition Ring.is_ring (r : Ring)
        : IsRing(Ring.carrier(r), Ring.add, Ring.zero(r),
                 Ring.negate, Ring.multiply, Ring.one(r)) :=
  let ⟨carrier, add, zero, negate, multiply, one, isRing⟩ := r in
    isRing

-- ----------------------------------------------------------------------
-- Flattened law projections. Each brings the ring structure into
-- context (a `claim IsRing(…)` step) and lets the auto-prover
-- project what it needs out of the nested-∧ hierarchy — a buried equation
-- leg for the direct axioms, or the sub-structure (e.g. the additive
-- group) that a generic group lemma asks for. IsRing unfolds to
--   IsAbelianGroup ∧ IsMonoid(·) ∧ distribLeft ∧ distribRight,
-- IsAbelianGroup to IsGroup ∧ commutative, IsGroup to
--   IsMonoid(+) ∧ negateLeft ∧ negateRight, and each IsMonoid to
--   associative ∧ identityLeft ∧ identityRight.

automatic theorem Ring.add_associative (r : Ring)
        : ∀ (x y z : Ring.carrier(r)).
          Ring.add(r, Ring.add(r, x, y), z)
            = Ring.add(r, x, Ring.add(r, y, z)) := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done
}

automatic theorem Ring.zero_add (r : Ring)
        : ∀ (x : Ring.carrier(r)). Ring.add(r, Ring.zero(r), x) = x := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done
}

automatic theorem Ring.add_zero (r : Ring)
        : ∀ (x : Ring.carrier(r)). Ring.add(r, x, Ring.zero(r)) = x := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done
}

automatic theorem Ring.add_negate_left (r : Ring)
        : ∀ (x : Ring.carrier(r)).
          Ring.add(r, Ring.negate(r, x), x) = Ring.zero(r) := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done
}

automatic theorem Ring.add_negate_right (r : Ring)
        : ∀ (x : Ring.carrier(r)).
          Ring.add(r, x, Ring.negate(r, x)) = Ring.zero(r) := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done
}

automatic theorem Ring.add_commutative (r : Ring)
        : ∀ (x y : Ring.carrier(r)).
          Ring.add(r, x, y) = Ring.add(r, y, x) := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done
}

-- Negating the additive identity gives the identity.
theorem Ring.negate_zero (r : Ring)
        : Ring.negate(r, Ring.zero(r)) = Ring.zero(r) := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done by Group.inverse_identity
}

theorem Ring.negate_negate (r : Ring) (x : Ring.carrier(r))
        : Ring.negate(r, Ring.negate(r, x)) = x := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done by Group.inverse_involution
}

-- Derived abelian rearrangement: (a+b)+(c+d) = (a+c)+(b+d). The
-- four-term interchange, used by the Sum.add lemma.
theorem Ring.add_four_swap (r : Ring) (a b c d : Ring.carrier(r))
        : (a + b) + (c + d) = (a + c) + (b + d) := ring

-- Zero annihilates multiplication. (Named with `_left`/`_right` to avoid
-- colliding with the abstract `Ring.zero_multiply` / `Ring.multiply_zero`.)
automatic theorem Ring.zero_multiply_left (r : Ring) (x : Ring.carrier(r))
        : Ring.multiply(r, Ring.zero(r), x) = Ring.zero(r) := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done by Ring.zero_multiply
}

theorem Ring.multiply_zero_right (r : Ring) (x : Ring.carrier(r))
        : Ring.multiply(r, x, Ring.zero(r)) = Ring.zero(r) := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done by Ring.multiply_zero
}

-- Negation factors out of a product: `(−a)·b = −(a·b)`.
theorem Ring.negate_multiply_left (r : Ring) (a b : Ring.carrier(r))
        : Ring.multiply(r, Ring.negate(r, a), b)
          = Ring.negate(r, Ring.multiply(r, a, b)) := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done by Ring.multiply_negate_left
}

-- ...and `a·(−b) = −(a·b)`.
theorem Ring.negate_multiply_right (r : Ring) (a b : Ring.carrier(r))
        : Ring.multiply(r, a, Ring.negate(r, b))
          = Ring.negate(r, Ring.multiply(r, a, b)) := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done by Ring.multiply_negate_right
}

automatic theorem Ring.multiply_associative (r : Ring)
        : ∀ (x y z : Ring.carrier(r)).
          Ring.multiply(r, Ring.multiply(r, x, y), z)
            = Ring.multiply(r, x, Ring.multiply(r, y, z)) := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done
}

automatic theorem Ring.one_multiply (r : Ring)
        : ∀ (x : Ring.carrier(r)). Ring.multiply(r, Ring.one(r), x) = x := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done
}

automatic theorem Ring.multiply_one (r : Ring)
        : ∀ (x : Ring.carrier(r)). Ring.multiply(r, x, Ring.one(r)) = x := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done
}

automatic theorem Ring.distributivity_left (r : Ring)
        : ∀ (x y z : Ring.carrier(r)).
          Ring.multiply(r, x, Ring.add(r, y, z))
            = Ring.add(r, Ring.multiply(r, x, y), Ring.multiply(r, x, z)) := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done
}

automatic theorem Ring.distributivity_right (r : Ring)
        : ∀ (x y z : Ring.carrier(r)).
          Ring.multiply(r, Ring.add(r, x, y), z)
            = Ring.add(r, Ring.multiply(r, x, z), Ring.multiply(r, y, z)) := {
  IsRing(Ring.carrier(r), Ring.add, Ring.zero(r), Ring.negate, Ring.multiply, Ring.one(r));
  done
}

-- Multiplication distributes over subtraction, on either side.
theorem Ring.multiply_subtract (r : Ring) (x y z : Ring.carrier(r))
        : x * (y - z) = x * y - x * z :=
  x * (y - z)
     = x * y + x * (- z)      by Ring.distributivity_left
     = x * y + (- (x * z))    by substituting Ring.negate_multiply_right
     = x * y - x * z

theorem Ring.subtract_multiply (r : Ring) (x y z : Ring.carrier(r))
        : (x - y) * z = x * z - y * z :=
  (x - y) * z
     = x * z + (- y) * z      by Ring.distributivity_right
     = x * z + (- (y * z))    by substituting Ring.negate_multiply_left
     = x * z - y * z

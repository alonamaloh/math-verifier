  done by finite_check s from 1 until 15
}

-- The two truant-10 forms.

theorem Matrix.oddC4R0C3_represents_below_ten
        : ∀ (s : ℕ). s ≥ 1 → s < 10 → Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 3), (s : ℤ)) := {
  let A : Matrix(Integer.commutative_ring_bundle, 4, 4) :=
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 3);
  Matrix.represents_by_witness(A, target := 1, vector := ⟨1, 0, 0, 0⟩);
  Matrix.represents_by_witness(A, target := 2, vector := ⟨0, 1, 0, 0⟩);
  Matrix.represents_by_witness(A, target := 3, vector := ⟨0, 0, 0, 1⟩);
  Matrix.represents_by_witness(A, target := 4, vector := ⟨0, 0, 1, 0⟩);
  Matrix.represents_by_witness(A, target := 5, vector := ⟨0, 1, 0, 1⟩);
  Matrix.represents_by_witness(A, target := 6, vector := ⟨1, 1, 0, 1⟩);
  Matrix.represents_by_witness(A, target := 7, vector := ⟨0, 0, 1, 1⟩);
  Matrix.represents_by_witness(A, target := 8, vector := ⟨0, 1, 1, 0⟩);
  Matrix.represents_by_witness(A, target := 9, vector := ⟨1, 1, 1, 0⟩);
  done by finite_check s from 1 until 10
}

theorem Matrix.oddC4R2C7_represents_below_ten
        : ∀ (s : ℕ). s ≥ 1 → s < 10 → Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 7), (s : ℤ)) := {
  let A : Matrix(Integer.commutative_ring_bundle, 4, 4) :=
      Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 7);
  Matrix.represents_by_witness(A, target := 1, vector := ⟨1, 0, 0, 0⟩);
  Matrix.represents_by_witness(A, target := 2, vector := ⟨0, 1, 0, 0⟩);
  Matrix.represents_by_witness(A, target := 3, vector := ⟨1, 1, 0, 0⟩);
  Matrix.represents_by_witness(A, target := 4, vector := ⟨0, 0, 1, 0⟩);
  Matrix.represents_by_witness(A, target := 5, vector := ⟨1, 0, 1, 0⟩);
  Matrix.represents_by_witness(A, target := 6, vector := ⟨1, -1, 0, 1⟩);
  Matrix.represents_by_witness(A, target := 7, vector := ⟨0, 0, 0, 1⟩);
  Matrix.represents_by_witness(A, target := 8, vector := ⟨0, 1, 1, 0⟩);
  Matrix.represents_by_witness(A, target := 9, vector := ⟨1, 1, 1, 0⟩);
  done by finite_check s from 1 until 10
}

theorem Matrix.oddC4R0C3_truant_ten
        : Matrix.IsTruant(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 3), 10) := {
  (10 : ℕ) ≥ 1;
  ¬(Matrix.Represents(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 0, 3), (10 : ℤ)))
      by Matrix.oddC4R0C3_not_represents_ten;
  done by Matrix.oddC4R0C3_represents_below_ten
}

theorem Matrix.oddC4R2C7_truant_ten
        : Matrix.IsTruant(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 7), 10) := {
  (10 : ℕ) ≥ 1;
  ¬(Matrix.Represents(Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 7), (10 : ℤ)))
      by Matrix.oddC4R2C7_not_represents_ten;
  done by Matrix.oddC4R2C7_represents_below_ten
}

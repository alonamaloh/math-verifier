module Algebra.rank_four_weighted_d4_zero_c10

import Algebra.rank_four_weighted_d4_zero_residue_cover

theorem Matrix.weightedD4S0R0C10_universal_of_one_two_four_converse (converse : Matrix.OneTwoFourConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 0, 0, 10)) :=
  by Matrix.weightedZero_universal_of_residual_cover(
      4, 10, Matrix.oneTwoFourResidualCover_selected_core_of_converse(
          converse, coefficient := 10, core := 4, coreSum := done,
          coreAdmissible := Natural.four_power_times_sixteen_plus_four_not_one_three_six_four_obstruction))

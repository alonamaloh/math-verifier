            ∧ Natural.modulo(a, 49) ≠ 42) as unsafe;
  a < 49 ∨ 49 ≤ a by Natural.lt_or_le;
  done by cases {
    case a < 49 as below49:
      done by Natural.detSevenResidueCover_m329_selected_table_part0(
        a, aNonnegative, below49, parityCondition, notMultipleFortyNine, unsafe)
    case 49 ≤ a as atLeast49: {

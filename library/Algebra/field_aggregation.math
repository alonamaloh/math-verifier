-- Algebra/field_aggregation.math
--
-- Finite sums and products of field-valued terms over a list, and their
-- algebra: how they interact with `append`/`map`, scalar distributivity,
-- pointwise congruence, and the bilinear expansion of a product of sums.
-- These are the reusable backbone for the determinant's Leibniz
-- manipulations (Stage H brick 6 of PLAN_LINEAR_ALGEBRA.md) — permutation-
-- free field/list algebra.

module Algebra.field_aggregation

import Logic.basics
import Equality.basics
import Lists.list
import Lists.map
import Lists.append
import Lists.remove
import Lists.permutation
import Lists.distinct
import Algebra.field
import Algebra.field_bundle

-- Sum a field-valued term over a list: the additive fold of the mapped list.
definition Field.sumOver {f : Field} {index : Type(0)}
        (term : index → Field.carrier(f)) (items : List(index))
        : Field.carrier(f) :=
  List.product(Field.carrier(f), Field.add, Field.zero(f),
      List.map(index, Field.carrier(f), term, items))

-- Multiply a field-valued term over a list: the multiplicative fold.
definition Field.productOver {f : Field} {index : Type(0)}
        (term : index → Field.carrier(f)) (items : List(index))
        : Field.carrier(f) :=
  List.product(Field.carrier(f), Field.multiply, Field.one(f),
      List.map(index, Field.carrier(f), term, items))

-- The empty and prepend reductions, straight off the folds.
theorem Field.sumOver_empty {f : Field} {index : Type(0)}
        (term : index → Field.carrier(f))
        : Field.sumOver(term, List.empty(index)) = Field.zero(f) :=
  done

theorem Field.sumOver_prepend {f : Field} {index : Type(0)}
        (term : index → Field.carrier(f)) (head : index) (tail : List(index))
        : Field.sumOver(term, List.prepend(index, head, tail))
          = term(head) + Field.sumOver(term, tail) :=
  done

theorem Field.productOver_prepend {f : Field} {index : Type(0)}
        (term : index → Field.carrier(f)) (head : index) (tail : List(index))
        : Field.productOver(term, List.prepend(index, head, tail))
          = term(head) * Field.productOver(term, tail) :=
  done

-- Sums and products split over concatenation.
theorem Field.sumOver_append {f : Field} {index : Type(0)}
        (term : index → Field.carrier(f)) (first second : List(index))
        : Field.sumOver(term, List.append(index, first, second))
          = Field.sumOver(term, first) + Field.sumOver(term, second) :=
  Field.sumOver(term, List.append(index, first, second))
     = List.product(Field.carrier(f), Field.add, Field.zero(f),
           List.append(Field.carrier(f),
               List.map(index, Field.carrier(f), term, first),
               List.map(index, Field.carrier(f), term, second)))
           by substituting List.map_append
     = Field.sumOver(term, first) + Field.sumOver(term, second)
           by List.product_append(Field.carrier(f), Field.add, Field.zero(f),
                  (a b c : Field.carrier(f)) ↦ Field.add_associative(f, a, b, c),
                  (a : Field.carrier(f)) ↦ Field.zero_add(f, a),
                  List.map(index, Field.carrier(f), term, first),
                  List.map(index, Field.carrier(f), term, second))

theorem Field.productOver_append {f : Field} {index : Type(0)}
        (term : index → Field.carrier(f)) (first second : List(index))
        : Field.productOver(term, List.append(index, first, second))
          = Field.productOver(term, first) * Field.productOver(term, second) :=
  Field.productOver(term, List.append(index, first, second))
     = List.product(Field.carrier(f), Field.multiply, Field.one(f),
           List.append(Field.carrier(f),
               List.map(index, Field.carrier(f), term, first),
               List.map(index, Field.carrier(f), term, second)))
           by substituting List.map_append
     = Field.productOver(term, first) * Field.productOver(term, second)
           by List.product_append(Field.carrier(f), Field.multiply, Field.one(f),
                  (a b c : Field.carrier(f)) ↦ Field.multiply_associative(f, a, b, c),
                  (a : Field.carrier(f)) ↦ Field.one_multiply(f, a),
                  List.map(index, Field.carrier(f), term, first),
                  List.map(index, Field.carrier(f), term, second))

-- Reindexing a sum/product through a map on the item list.
theorem Field.sumOver_map {f : Field} {source target : Type(0)}
        (term : target → Field.carrier(f)) (reindex : source → target)
        (items : List(source))
        : Field.sumOver(term, List.map(source, target, reindex, items))
          = Field.sumOver((x : source) ↦ term(reindex(x)), items) :=
  Field.sumOver(term, List.map(source, target, reindex, items))
     = List.product(Field.carrier(f), Field.add, Field.zero(f),
           List.map(target, Field.carrier(f), term, List.map(source, target, reindex, items)))
     = List.product(Field.carrier(f), Field.add, Field.zero(f),
           List.map(source, Field.carrier(f), (x : source) ↦ term(reindex(x)), items))
           by substituting List.map_map
     = Field.sumOver((x : source) ↦ term(reindex(x)), items)

theorem Field.productOver_map {f : Field} {source target : Type(0)}
        (term : target → Field.carrier(f)) (reindex : source → target)
        (items : List(source))
        : Field.productOver(term, List.map(source, target, reindex, items))
          = Field.productOver((x : source) ↦ term(reindex(x)), items) :=
  Field.productOver(term, List.map(source, target, reindex, items))
     = List.product(Field.carrier(f), Field.multiply, Field.one(f),
           List.map(target, Field.carrier(f), term, List.map(source, target, reindex, items)))
     = List.product(Field.carrier(f), Field.multiply, Field.one(f),
           List.map(source, Field.carrier(f), (x : source) ↦ term(reindex(x)), items))
           by substituting List.map_map
     = Field.productOver((x : source) ↦ term(reindex(x)), items)

-- Pointwise-equal terms give equal sums and products.
theorem Field.sumOver_congruence {f : Field} {index : Type(0)}
        (term termPrime : index → Field.carrier(f)) (items : List(index))
        (pointwise : ∀ (x : index). term(x) = termPrime(x))
        : Field.sumOver(term, items) = Field.sumOver(termPrime, items) :=
  by induction on items with IH {
    case List.empty:
        Field.sumOver(term, List.empty(index))
           = Field.zero(f)
           = Field.sumOver(termPrime, List.empty(index))
    case List.prepend(head, tail):
        Field.sumOver(term, List.prepend(index, head, tail))
           = term(head) + Field.sumOver(term, tail)
           = termPrime(head) + Field.sumOver(term, tail)         by substituting pointwise(head)
           = termPrime(head) + Field.sumOver(termPrime, tail)    by IH
           = Field.sumOver(termPrime, List.prepend(index, head, tail))
  }

theorem Field.productOver_congruence {f : Field} {index : Type(0)}
        (term termPrime : index → Field.carrier(f)) (items : List(index))
        (pointwise : ∀ (x : index). term(x) = termPrime(x))
        : Field.productOver(term, items) = Field.productOver(termPrime, items) :=
  by induction on items with IH {
    case List.empty:
        Field.productOver(term, List.empty(index))
           = Field.one(f)
           = Field.productOver(termPrime, List.empty(index))
    case List.prepend(head, tail):
        Field.productOver(term, List.prepend(index, head, tail))
           = term(head) * Field.productOver(term, tail)
           = termPrime(head) * Field.productOver(term, tail)         by substituting pointwise(head)
           = termPrime(head) * Field.productOver(termPrime, tail)    by IH
           = Field.productOver(termPrime, List.prepend(index, head, tail))
  }

-- Scalar distributivity: a constant factor pulls in and out of a sum.
theorem Field.sumOver_scale_left {f : Field} {index : Type(0)}
        (constant : Field.carrier(f)) (term : index → Field.carrier(f))
        (items : List(index))
        : constant * Field.sumOver(term, items)
          = Field.sumOver((x : index) ↦ constant * term(x), items) :=
  by induction on items with IH {
    case List.empty:
        constant * Field.sumOver(term, List.empty(index))
           = constant * Field.zero(f)
           = Field.zero(f)                                          by ring
           = Field.sumOver((x : index) ↦ constant * term(x), List.empty(index))
    case List.prepend(head, tail):
        constant * Field.sumOver(term, List.prepend(index, head, tail))
           = constant * (term(head) + Field.sumOver(term, tail))
           = constant * term(head) + constant * Field.sumOver(term, tail)   by ring
           = constant * term(head) + Field.sumOver((x : index) ↦ constant * term(x), tail)
                 by substituting IH
           = Field.sumOver((x : index) ↦ constant * term(x), List.prepend(index, head, tail))
  }

theorem Field.sumOver_scale_right {f : Field} {index : Type(0)}
        (term : index → Field.carrier(f)) (constant : Field.carrier(f))
        (items : List(index))
        : Field.sumOver(term, items) * constant
          = Field.sumOver((x : index) ↦ term(x) * constant, items) :=
  by induction on items with IH {
    case List.empty:
        Field.sumOver(term, List.empty(index)) * constant
           = Field.zero(f) * constant
           = Field.zero(f)                                          by ring
           = Field.sumOver((x : index) ↦ term(x) * constant, List.empty(index))
    case List.prepend(head, tail):
        Field.sumOver(term, List.prepend(index, head, tail)) * constant
           = (term(head) + Field.sumOver(term, tail)) * constant
           = term(head) * constant + Field.sumOver(term, tail) * constant   by ring
           = term(head) * constant + Field.sumOver((x : index) ↦ term(x) * constant, tail)
                 by substituting IH
           = Field.sumOver((x : index) ↦ term(x) * constant, List.prepend(index, head, tail))
  }

-- The bilinear expansion: a product of two sums is the double sum of the
-- pairwise products.
theorem Field.sumOver_multiply_sumOver {f : Field} {left right : Type(0)}
        (leftTerm : left → Field.carrier(f)) (rightTerm : right → Field.carrier(f))
        (leftItems : List(left)) (rightItems : List(right))
        : Field.sumOver(leftTerm, leftItems) * Field.sumOver(rightTerm, rightItems)
          = Field.sumOver(
                (x : left) ↦ Field.sumOver((y : right) ↦ leftTerm(x) * rightTerm(y), rightItems),
                leftItems) :=
  Field.sumOver(leftTerm, leftItems) * Field.sumOver(rightTerm, rightItems)
     = Field.sumOver((x : left) ↦ leftTerm(x) * Field.sumOver(rightTerm, rightItems), leftItems)
           by Field.sumOver_scale_right(leftTerm, Field.sumOver(rightTerm, rightItems), leftItems)
     = Field.sumOver(
           (x : left) ↦ Field.sumOver((y : right) ↦ leftTerm(x) * rightTerm(y), rightItems),
           leftItems)
           by Field.sumOver_congruence(
                  (x : left) ↦ leftTerm(x) * Field.sumOver(rightTerm, rightItems),
                  (x : left) ↦ Field.sumOver((y : right) ↦ leftTerm(x) * rightTerm(y), rightItems),
                  leftItems,
                  (x : left) ↦ Field.sumOver_scale_left(leftTerm(x), rightTerm, rightItems))

-- A sum of two sums over the same list is the sum of the pointwise sums.
theorem Field.sumOver_add {f : Field} {index : Type(0)}
        (term termPrime : index → Field.carrier(f)) (items : List(index))
        : Field.sumOver(term, items) + Field.sumOver(termPrime, items)
          = Field.sumOver((x : index) ↦ term(x) + termPrime(x), items) :=
  by induction on items with IH {
    case List.empty:
        Field.sumOver(term, List.empty(index)) + Field.sumOver(termPrime, List.empty(index))
           = Field.zero(f) + Field.zero(f)
           = Field.zero(f)                                          by ring
           = Field.sumOver((x : index) ↦ term(x) + termPrime(x), List.empty(index))
    case List.prepend(head, tail):
        Field.sumOver(term, List.prepend(index, head, tail))
              + Field.sumOver(termPrime, List.prepend(index, head, tail))
           = (term(head) + Field.sumOver(term, tail))
                 + (termPrime(head) + Field.sumOver(termPrime, tail))
           = (term(head) + termPrime(head))
                 + (Field.sumOver(term, tail) + Field.sumOver(termPrime, tail))    by ring
           = (term(head) + termPrime(head))
                 + Field.sumOver((x : index) ↦ term(x) + termPrime(x), tail)        by substituting IH
           = Field.sumOver((x : index) ↦ term(x) + termPrime(x), List.prepend(index, head, tail))
  }

-- The sum of a constant-zero term vanishes.
theorem Field.sumOver_zero_function {f : Field} {index : Type(0)}
        (items : List(index))
        : Field.sumOver((x : index) ↦ Field.zero(f), items) = Field.zero(f) :=
  by induction on items with IH {
    case List.empty:
        Field.sumOver((x : index) ↦ Field.zero(f), List.empty(index)) = Field.zero(f)
    case List.prepend(head, tail):
        Field.sumOver((x : index) ↦ Field.zero(f), List.prepend(index, head, tail))
           = Field.zero(f) + Field.sumOver((x : index) ↦ Field.zero(f), tail)
           = Field.zero(f) + Field.zero(f)                          by substituting IH
           = Field.zero(f)                                          by ring
  }

-- Fubini for finite list sums: the order of a double sum is immaterial.
theorem Field.sumOver_interchange {f : Field} {left right : Type(0)}
        (term : left → right → Field.carrier(f))
        (leftItems : List(left)) (rightItems : List(right))
        : Field.sumOver((a : left) ↦ Field.sumOver((b : right) ↦ term(a, b), rightItems), leftItems)
          = Field.sumOver((b : right) ↦ Field.sumOver((a : left) ↦ term(a, b), leftItems), rightItems) :=
  by induction on leftItems with IH {
    case List.empty:
        Field.sumOver((a : left) ↦ Field.sumOver((b : right) ↦ term(a, b), rightItems),
              List.empty(left))
           = Field.zero(f)
           = Field.sumOver((b : right) ↦ Field.zero(f), rightItems)
                 by Field.sumOver_zero_function(rightItems)
           = Field.sumOver((b : right) ↦ Field.sumOver((a : left) ↦ term(a, b), List.empty(left)),
                 rightItems)
    case List.prepend(head, tail):
        Field.sumOver((a : left) ↦ Field.sumOver((b : right) ↦ term(a, b), rightItems),
              List.prepend(left, head, tail))
           = Field.sumOver((b : right) ↦ term(head, b), rightItems)
                 + Field.sumOver((a : left) ↦ Field.sumOver((b : right) ↦ term(a, b), rightItems), tail)
           = Field.sumOver((b : right) ↦ term(head, b), rightItems)
                 + Field.sumOver((b : right) ↦ Field.sumOver((a : left) ↦ term(a, b), tail), rightItems)
                 by substituting IH
           = Field.sumOver(
                 (b : right) ↦ term(head, b) + Field.sumOver((a : left) ↦ term(a, b), tail),
                 rightItems)
                 by Field.sumOver_add(
                        (b : right) ↦ term(head, b),
                        (b : right) ↦ Field.sumOver((a : left) ↦ term(a, b), tail),
                        rightItems)
           = Field.sumOver(
                 (b : right) ↦ Field.sumOver((a : left) ↦ term(a, b), List.prepend(left, head, tail)),
                 rightItems)
  }

-- Isolating a summand: a member of the item list contributes its term, and
-- the rest of the sum is the sum over the list with that element removed.
theorem Field.sumOver_remove {f : Field} {index : Type(0)}
        (g : index → Field.carrier(f)) (x : index) (items : List(index))
        : List.member(index, x, items)
          → Field.sumOver(g, items) = g(x) + Field.sumOver(g, List.remove(index, x, items)) :=
  by induction on items with IH {
    case List.empty:
        (mem : List.member(index, x, List.empty(index))) ↦
            absurd(List.no_member_empty(index, x, mem))
    case List.prepend(head, tail):
        (mem : List.member(index, x, List.prepend(index, head, tail))) ↦ {
          head = x ∨ ¬(head = x) by Logic.excluded_middle;
          done by cases {
            case head = x as headEqualsX:
                Field.sumOver(g, List.prepend(index, x, tail))
                   = g(x) + Field.sumOver(g, tail)                     by Field.sumOver_prepend
                   = g(x) + Field.sumOver(g, List.remove(index, x, List.prepend(index, x, tail)))
                       by substituting List.remove_prepend_equal
            case ¬(head = x) as headNeqX: {
                List.member(index, x, tail)
                    by { x = head ∨ List.member(index, x, tail) by List.member_prepend_invert;
                         done by cases {
                           case x = head as xHead: absurd(headNeqX(Equality.symmetry(xHead)))
                           case List.member(index, x, tail) as memberTail: memberTail
                         }
                       } as memTail;
                Field.sumOver(g, tail) = g(x) + Field.sumOver(g, List.remove(index, x, tail))
                    by IH(memTail) as tailEquation;
                Field.sumOver(g, List.prepend(index, head, tail))
                    = g(head) + Field.sumOver(g, tail)                 by Field.sumOver_prepend
                    as prependEquation;
                Field.sumOver(g, List.prepend(index, head, List.remove(index, x, tail)))
                    = g(head) + Field.sumOver(g, List.remove(index, x, tail))
                    by Field.sumOver_prepend as foldEquation;
                List.remove(index, x, List.prepend(index, head, tail))
                    = List.prepend(index, head, List.remove(index, x, tail))
                    by List.remove_prepend_unequal as removeEquation;
                Field.sumOver(g, List.prepend(index, head, tail))
                   = g(head) + Field.sumOver(g, tail)                             by prependEquation
                   = g(head) + (g(x) + Field.sumOver(g, List.remove(index, x, tail)))
                         by substituting tailEquation
                   = g(x) + (g(head) + Field.sumOver(g, List.remove(index, x, tail)))   by ring
                   = g(x) + Field.sumOver(g, List.prepend(index, head, List.remove(index, x, tail)))
                         by foldEquation
                   = g(x) + Field.sumOver(g, List.remove(index, x, List.prepend(index, head, tail)))
                         by removeEquation
              }
          }
        }
  }

-- A product of pointwise products splits into the product of the factors.
theorem Field.productOver_multiply {f : Field} {index : Type(0)}
        (term termPrime : index → Field.carrier(f)) (items : List(index))
        : Field.productOver((x : index) ↦ term(x) * termPrime(x), items)
          = Field.productOver(term, items) * Field.productOver(termPrime, items) :=
  by induction on items with IH {
    case List.empty:
        Field.productOver((x : index) ↦ term(x) * termPrime(x), List.empty(index))
           = Field.one(f)
           = Field.one(f) * Field.one(f)                           by ring
           = Field.productOver(term, List.empty(index)) * Field.productOver(termPrime, List.empty(index))
    case List.prepend(head, tail):
        Field.productOver((x : index) ↦ term(x) * termPrime(x), List.prepend(index, head, tail))
           = (term(head) * termPrime(head))
                 * Field.productOver((x : index) ↦ term(x) * termPrime(x), tail)
           = (term(head) * termPrime(head))
                 * (Field.productOver(term, tail) * Field.productOver(termPrime, tail))
                 by substituting IH
           = (term(head) * Field.productOver(term, tail))
                 * (termPrime(head) * Field.productOver(termPrime, tail))            by ring
           = Field.productOver(term, List.prepend(index, head, tail))
                 * Field.productOver(termPrime, List.prepend(index, head, tail))
  }

-- A product over a list is invariant under permuting the item list (the
-- field's multiplication is commutative and associative), by lifting
-- `List.Permutation.product_invariant` across the `map` of the term.
theorem Field.productOver_permutation {f : Field} {index : Type(0)}
        (term : index → Field.carrier(f)) (items1 items2 : List(index))
        (perm : List.Permutation(index, items1, items2))
        : Field.productOver(term, items1) = Field.productOver(term, items2) :=
  Field.productOver(term, items1)
     = List.product(Field.carrier(f), Field.multiply, Field.one(f),
           List.map(index, Field.carrier(f), term, items1))
     = List.product(Field.carrier(f), Field.multiply, Field.one(f),
           List.map(index, Field.carrier(f), term, items2))
           by List.Permutation.product_invariant(Field.carrier(f), Field.multiply, Field.one(f),
                  (x y z : Field.carrier(f)) ↦ Field.multiply_associative(f, x, y, z),
                  (x y : Field.carrier(f)) ↦ Field.multiply_commutative(f, x, y),
                  List.map(index, Field.carrier(f), term, items1),
                  List.map(index, Field.carrier(f), term, items2),
                  List.Permutation.map(index, Field.carrier(f), term, items1, items2, perm))
     = Field.productOver(term, items2)

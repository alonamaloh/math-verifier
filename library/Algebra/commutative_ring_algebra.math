-- Algebra/commutative_ring_algebra.math
--
-- The ring operations and laws on the carrier of a bundled
-- `CommutativeRing`, exposed under the `CommutativeRing.*` namespace so
-- that the `ring` tactic can drive an abstract commutative-ring goal:
-- `theorem foo (c : CommutativeRing) (a b : CommutativeRing.carrier(c)) :
--  a * (b + c) = … := ring`.
--
-- Each operation delegates to the underlying ring
-- `CommutativeRing.ring(c)` and is therefore definitionally equal to the
-- corresponding `Ring.*` form; the laws are then discharged from the
-- bundled `IsRing` instance (`CommutativeRing.is_ring`), with
-- multiplicative commutativity coming from the bundle's own
-- `CommutativeRing.commutative` field. Grouping every law
-- under one namespace with the single index `c` is what lets `ring`
-- treat a commutative-ring carrier uniformly (operation namespace
-- `CommutativeRing`, structure prefix `[c]`) — including
-- `multiply_commutative`, which for a plain `Ring` would not exist.

module Algebra.commutative_ring_algebra

import Logic.basics
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle

-- ----------------------------------------------------------------------
-- Operations. The binary/unary ones take `c` implicitly (recovered from
-- the operand type `CommutativeRing.carrier(c)`); the constants take it
-- explicitly. Each is the corresponding underlying-ring operation.

definition CommutativeRing.add {c : CommutativeRing}
        : CommutativeRing.carrier(c) → CommutativeRing.carrier(c) → CommutativeRing.carrier(c) :=
  Ring.add

definition CommutativeRing.negate {c : CommutativeRing}
        : CommutativeRing.carrier(c) → CommutativeRing.carrier(c) :=
  Ring.negate

definition CommutativeRing.multiply {c : CommutativeRing}
        : CommutativeRing.carrier(c) → CommutativeRing.carrier(c) → CommutativeRing.carrier(c) :=
  Ring.multiply

definition CommutativeRing.zero (c : CommutativeRing) : CommutativeRing.carrier(c) :=
  Ring.zero(CommutativeRing.ring(c))

definition CommutativeRing.one (c : CommutativeRing) : CommutativeRing.carrier(c) :=
  Ring.one(CommutativeRing.ring(c))

definition CommutativeRing.subtract {c : CommutativeRing}
        (x y : CommutativeRing.carrier(c)) : CommutativeRing.carrier(c) :=
  CommutativeRing.add(x, CommutativeRing.negate(y))

operator (+) on (CommutativeRing.carrier, CommutativeRing.carrier) := CommutativeRing.add
operator (-) on (CommutativeRing.carrier, CommutativeRing.carrier) := CommutativeRing.subtract
operator (*) on (CommutativeRing.carrier, CommutativeRing.carrier) := CommutativeRing.multiply

-- ----------------------------------------------------------------------
-- The bundled IsRing instance, in the CommutativeRing operation vocabulary
-- (definitionally the underlying ring's). Registered as a forgetful
-- instance so every law below projects from it: a bare `done` discharges
-- the direct ring axioms, and the abstract derived ring lemmas
-- (`Ring.zero_multiply`, `Ring.multiply_negate_*`) cite by name.
definition CommutativeRing.is_ring (c : CommutativeRing)
        : IsRing(CommutativeRing.carrier(c), CommutativeRing.add,
                 CommutativeRing.zero(c), CommutativeRing.negate,
                 CommutativeRing.multiply, CommutativeRing.one(c)) :=
  Ring.is_ring(CommutativeRing.ring(c))

instance CommutativeRing.is_ring

-- ----------------------------------------------------------------------
-- Laws. The direct ring axioms are projected from the registered instance
-- by the auto-prover; `multiply_commutative` is the bundle's commutativity
-- field.

theorem CommutativeRing.add_associative (c : CommutativeRing)
        (x y z : CommutativeRing.carrier(c))
        : (x + y) + z = x + (y + z) :=
  done

theorem CommutativeRing.add_commutative (c : CommutativeRing)
        (x y : CommutativeRing.carrier(c))
        : x + y = y + x :=
  done

theorem CommutativeRing.zero_add (c : CommutativeRing) (x : CommutativeRing.carrier(c))
        : CommutativeRing.zero(c) + x = x :=
  done

theorem CommutativeRing.add_zero (c : CommutativeRing) (x : CommutativeRing.carrier(c))
        : x + CommutativeRing.zero(c) = x :=
  done

theorem CommutativeRing.add_negate_left (c : CommutativeRing) (x : CommutativeRing.carrier(c))
        : -x + x = CommutativeRing.zero(c) :=
  done

theorem CommutativeRing.add_negate_right (c : CommutativeRing) (x : CommutativeRing.carrier(c))
        : x + -x = CommutativeRing.zero(c) :=
  done

theorem CommutativeRing.multiply_associative (c : CommutativeRing)
        (x y z : CommutativeRing.carrier(c))
        : (x * y) * z = x * (y * z) :=
  done

theorem CommutativeRing.multiply_commutative (c : CommutativeRing)
        (x y : CommutativeRing.carrier(c))
        : x * y = y * x :=
  done by CommutativeRing.commutative

theorem CommutativeRing.one_multiply (c : CommutativeRing) (x : CommutativeRing.carrier(c))
        : CommutativeRing.one(c) * x = x :=
  done

theorem CommutativeRing.multiply_one (c : CommutativeRing) (x : CommutativeRing.carrier(c))
        : x * CommutativeRing.one(c) = x :=
  done

theorem CommutativeRing.distributivity_left (c : CommutativeRing)
        (x y z : CommutativeRing.carrier(c))
        : x * (y + z) = x * y + x * z :=
  done

theorem CommutativeRing.distributivity_right (c : CommutativeRing)
        (x y z : CommutativeRing.carrier(c))
        : (x + y) * z = x * z + y * z :=
  done

-- Negation laws the `ring` normaliser uses when pushing negation through
-- a canonical form. Proved from the additive (abelian) group of the
-- underlying ring.

theorem CommutativeRing.negate_negate (c : CommutativeRing) (a : CommutativeRing.carrier(c))
        : -(-a) = a := {
  claim IsRing(CommutativeRing.carrier(c), CommutativeRing.add, CommutativeRing.zero(c),
               CommutativeRing.negate, CommutativeRing.multiply, CommutativeRing.one(c)) since CommutativeRing.is_ring;
  done since Group.inverse_involution
}

theorem CommutativeRing.negate_add (c : CommutativeRing) (a b : CommutativeRing.carrier(c))
        : -(a + b) = -a + -b := {
  claim IsRing(CommutativeRing.carrier(c), CommutativeRing.add, CommutativeRing.zero(c),
               CommutativeRing.negate, CommutativeRing.multiply, CommutativeRing.one(c)) since CommutativeRing.is_ring;
  claim IsAbelianGroup(CommutativeRing.carrier(c), CommutativeRing.add, CommutativeRing.zero(c), CommutativeRing.negate);
  done since AbelianGroup.inverse_operation
}

-- Derived multiplicative laws in the CommutativeRing vocabulary, from
-- the abstract ring lemmas at the bundled instance. The `ring`
-- normaliser (and the RingModulo quotient lifts) demand these names
-- when a goal mentions zero or negation under multiplication.

theorem CommutativeRing.zero_multiply (c : CommutativeRing) (x : CommutativeRing.carrier(c))
        : CommutativeRing.zero(c) * x = CommutativeRing.zero(c) := {
  claim IsRing(CommutativeRing.carrier(c), CommutativeRing.add, CommutativeRing.zero(c),
               CommutativeRing.negate, CommutativeRing.multiply, CommutativeRing.one(c)) since CommutativeRing.is_ring;
  done since Ring.zero_multiply
}

theorem CommutativeRing.multiply_zero (c : CommutativeRing) (x : CommutativeRing.carrier(c))
        : x * CommutativeRing.zero(c) = CommutativeRing.zero(c) := {
  claim IsRing(CommutativeRing.carrier(c), CommutativeRing.add, CommutativeRing.zero(c),
               CommutativeRing.negate, CommutativeRing.multiply, CommutativeRing.one(c)) since CommutativeRing.is_ring;
  done since Ring.multiply_zero
}

theorem CommutativeRing.multiply_negate_left (c : CommutativeRing) (a b : CommutativeRing.carrier(c))
        : -a * b = -(a * b) := {
  claim IsRing(CommutativeRing.carrier(c), CommutativeRing.add, CommutativeRing.zero(c),
               CommutativeRing.negate, CommutativeRing.multiply, CommutativeRing.one(c)) since CommutativeRing.is_ring;
  done since Ring.multiply_negate_left
}

theorem CommutativeRing.multiply_negate_right (c : CommutativeRing) (a b : CommutativeRing.carrier(c))
        : a * -b = -(a * b) := {
  claim IsRing(CommutativeRing.carrier(c), CommutativeRing.add, CommutativeRing.zero(c),
               CommutativeRing.negate, CommutativeRing.multiply, CommutativeRing.one(c)) since CommutativeRing.is_ring;
  done since Ring.multiply_negate_right
}

-- Algebra/permutation_transposition_sign.math
--
-- A transposition is odd: `Permutation.sign(Permutation.swap(a, b)) = −1` for
-- distinct a, b (Stage H brick 6b of PLAN_LINEAR_ALGEBRA.md). The alternating
-- collapse of det(AB) (brick 6c) pairs each permutation with its composite by a
-- transposition; this is what makes those two terms cancel.
--
-- Route: reduce to value(a) < value(b) (swap is symmetric), then induct on the
-- value-distance. The base case is an adjacent transposition — it inverts
-- exactly one ordered pair, so its sign is a single −1 factor. The step
-- conjugates by an adjacent transposition to drop the distance by one, using
-- sign multiplicativity and that a transposition's sign squares to 1.

module Algebra.permutation_transposition_sign

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.order
import Natural.arithmetic
import Natural.classical_decidable
import Integer.basics
import Integer.algebra
import Algebra.integer_domain
import Logic.product
import Lists.list
import Lists.map
import Lists.distinct
import Set.finite
import Set.finite_pigeonhole
import Algebra.finite_permutation
import Algebra.permutation_enumeration
import Algebra.permutation_sign

-- ----------------------------------------------------------------------
-- A product over a distinct list with exactly one non-unit factor equals that
-- factor: every other element maps to `one`, so it drops out.
theorem List.product_isolate_single (B : Type(0)) (f : B → ℤ) (e0 : B)
        (l : List(B)) (distinctL : List.Distinct(B, l)) (memberE0 : e0 ∈ l)
        (othersAreOne : ∀ (x : B). x ∈ l → x ≠ e0 → f(x) = Integer.one)
        : List.product(ℤ, Integer.multiply, Integer.one, List.map(B, ℤ, f, l)) = f(e0) :=
  by induction on l with IH {
    case List.empty: {
        ¬(e0 ∈ List.empty(B)) by List.no_member_empty as notMember;
        absurd(notMember(memberE0))
      }
    case List.prepend(head, tail): {
        ¬(head ∈ tail) by List.Distinct.head_not_member;
        List.Distinct(B, tail) by List.Distinct.tail_distinct as tailDistinct;
        e0 = head ∨ e0 ∈ tail
            by List.member_prepend_invert;
        done by cases {
          case e0 = head as e0IsHead: {
              (∀ (x : B). x ∈ tail → f(x) = Integer.one)
                  by (x : B) (xInTail : x ∈ tail) ↦ {
                    x ∈ List.prepend(B, head, tail);
                    x ≠ e0 by {
                      suppose x = e0 for contradiction {
                        x = e0 as xIsE0;
                        head = e0 = x by xIsE0 as headEqX;
                        head ∈ tail by substituting headEqX;
                        False;
                        done
                      };
                      done
                    };
                    f(x) = Integer.one;
                    done
                  } as tailOnes;
              (∀ (y : ℤ). y ∈ List.map(B, ℤ, f, tail) → y = Integer.one)
                  by (y : ℤ) (yInMap : y ∈ List.map(B, ℤ, f, tail)) ↦ {
                    choose x : B such that x ∈ tail ∧ (f(x) = y) from List.map_member_invert;
                    x ∈ tail as xInTail2;
                    f(x) = y as fxIsY;
                    y = f(x) by fxIsY = Integer.one by tailOnes(x, xInTail2);
                    done
                  };
              List.product(ℤ, Integer.multiply, Integer.one, List.map(B, ℤ, f, tail)) = Integer.one
                  by List.product_of_ones recalling Integer.one_multiply_left as tailProductOne;
              List.product(ℤ, Integer.multiply, Integer.one,
                    List.map(B, ℤ, f, List.prepend(B, head, tail)))
                 = Integer.multiply(f(head),
                       List.product(ℤ, Integer.multiply, Integer.one, List.map(B, ℤ, f, tail)))
                 = Integer.multiply(f(head), Integer.one) by substituting tailProductOne
                 = f(head) by ring
                 = f(e0) by substituting e0IsHead;
              done
            }
          case e0 ∈ tail as e0InTail: {
              head ≠ e0 by {
                suppose head = e0 for contradiction {
                  head = e0 as headIsE0;
                  head ∈ tail by substituting headIsE0;
                  False;
                  done
                };
                done
              } as headNeqE0;
              f(head) = Integer.one
                  by othersAreOne(head, List.member.here(B, head, tail), headNeqE0) as fHeadIsOne;
              (∀ (x : B). x ∈ tail → x ≠ e0 → f(x) = Integer.one)
                  by (x : B) (xInTail : x ∈ tail) ↦
                      othersAreOne(x, List.member.there(B, x, head, tail, xInTail)) as tailOthers;
              List.product(ℤ, Integer.multiply, Integer.one,
                    List.map(B, ℤ, f, List.prepend(B, head, tail)))
                 = Integer.multiply(f(head),
                       List.product(ℤ, Integer.multiply, Integer.one, List.map(B, ℤ, f, tail)))
                 = Integer.multiply(Integer.one,
                       List.product(ℤ, Integer.multiply, Integer.one, List.map(B, ℤ, f, tail)))
                       by substituting fHeadIsOne
                 = List.product(ℤ, Integer.multiply, Integer.one, List.map(B, ℤ, f, tail))
                 = f(e0) by IH(tailDistinct, e0InTail, tailOthers);
              done
            }
        }
      }
  }

-- ----------------------------------------------------------------------
-- Reducing a transposition's sign to that of a closer one by conjugation.

-- A transposition's sign squares to one: it is a unit.
theorem Permutation.sign_swap_square {n : ℕ} (a b : NaturalsBelow(n))
        : Integer.multiply(Permutation.sign(Permutation.swap(a, b)),
              Permutation.sign(Permutation.swap(a, b))) = Integer.one := {
  Permutation.sign(Permutation.swap(a, b)) = 1
      ∨ Permutation.sign(Permutation.swap(a, b)) = Integer.negate(1)
      by Permutation.sign_is_unit;
  done by cases {
    case Permutation.sign(Permutation.swap(a, b)) = 1 as isPositive:
        Integer.multiply(Permutation.sign(Permutation.swap(a, b)),
              Permutation.sign(Permutation.swap(a, b)))
           = Integer.multiply(1, 1) by substituting isPositive
           = Integer.one by ring
    case Permutation.sign(Permutation.swap(a, b)) = Integer.negate(1) as isNegative:
        Integer.multiply(Permutation.sign(Permutation.swap(a, b)),
              Permutation.sign(Permutation.swap(a, b)))
           = Integer.multiply(Integer.negate(1), Integer.negate(1)) by substituting isNegative
           = Integer.one by ring
  }
}

-- Conjugating swap(a, b) by the transposition swap(a, c) yields swap(c, b):
-- swap(a, c) ∘ swap(a, b) ∘ swap(a, c) = swap(c, b), for a, b, c with b outside
-- {a, c} and a ≠ c. This is the group identity behind the distance reduction.
theorem Permutation.swap_conjugate_by_swap {n : ℕ} (a b c : NaturalsBelow(n))
        (aNeqC : a ≠ c) (bNeqA : b ≠ a) (bNeqC : b ≠ c)
        : Permutation.swap(a, c) ∘ (Permutation.swap(a, b) ∘ Permutation.swap(a, c)) = Permutation.swap(c, b) := {
  c ≠ a by Equality.not_equal_symmetric;
  a ≠ b by Equality.not_equal_symmetric;
  c ≠ b by Equality.not_equal_symmetric;
  done by Permutation.equal_of_apply_equal(applyEqual :=
      (i : NaturalsBelow(n)) ↦ {
        i = c ∨ i ≠ c;
        done by cases {
          case i = c as iIsC: {
              (Permutation.swap(a, c) ∘ (Permutation.swap(a, b) ∘ Permutation.swap(a, c)))(i)
                 = Permutation.swap(a, c)(Permutation.swap(a, b)(Permutation.swap(a, c)(i))) by Permutation.apply_compose
                 = Permutation.swap(a, c)(Permutation.swap(a, b)(Permutation.swap(a, c)(c))) by substituting iIsC
                 = Permutation.swap(a, c)(Permutation.swap(a, b)(a)) by substituting Permutation.apply_swap_right
                 = Permutation.swap(a, c)(b) by substituting Permutation.apply_swap_left
                 = b by Permutation.apply_swap_other
                 as lhsEq;
              Permutation.swap(c, b)(i)
                 = Permutation.swap(c, b)(c) by substituting iIsC
                 = b by Permutation.apply_swap_left
                 as rhsEq;
              (Permutation.swap(a, c) ∘ (Permutation.swap(a, b) ∘ Permutation.swap(a, c)))(i)
                 = b by lhsEq
                 = Permutation.swap(c, b)(i) by rhsEq;
              done
            }
          case i ≠ c as iNeqC: {
              i = b ∨ i ≠ b;
              done by cases {
                case i = b as iIsB: {
                    (Permutation.swap(a, c) ∘ (Permutation.swap(a, b) ∘ Permutation.swap(a, c)))(i)
                       = Permutation.swap(a, c)(Permutation.swap(a, b)(Permutation.swap(a, c)(i))) by Permutation.apply_compose
                       = Permutation.swap(a, c)(Permutation.swap(a, b)(Permutation.swap(a, c)(b))) by substituting iIsB
                       = Permutation.swap(a, c)(Permutation.swap(a, b)(b)) by substituting Permutation.apply_swap_other
                       = Permutation.swap(a, c)(a) by substituting Permutation.apply_swap_right
                       = c by Permutation.apply_swap_left
                       as lhsEq;
                    Permutation.swap(c, b)(i)
                       = Permutation.swap(c, b)(b) by substituting iIsB
                       = c by Permutation.apply_swap_right
                       as rhsEq;
                    (Permutation.swap(a, c) ∘ (Permutation.swap(a, b) ∘ Permutation.swap(a, c)))(i)
                       = c by lhsEq
                       = Permutation.swap(c, b)(i) by rhsEq;
                    done
                  }
                case i ≠ b as iNeqB: {
                    i = a ∨ i ≠ a;
                    done by cases {
                      case i = a as iIsA: {
                          (Permutation.swap(a, c) ∘ (Permutation.swap(a, b) ∘ Permutation.swap(a, c)))(i)
                             = Permutation.swap(a, c)(Permutation.swap(a, b)(Permutation.swap(a, c)(i))) by Permutation.apply_compose
                             = Permutation.swap(a, c)(Permutation.swap(a, b)(Permutation.swap(a, c)(a))) by substituting iIsA
                             = Permutation.swap(a, c)(Permutation.swap(a, b)(c)) by substituting Permutation.apply_swap_left
                             = Permutation.swap(a, c)(c) by substituting Permutation.apply_swap_other
                             = a by Permutation.apply_swap_right
                             as lhsEq;
                          Permutation.swap(c, b)(i)
                             = Permutation.swap(c, b)(a) by substituting iIsA
                             = a by Permutation.apply_swap_other
                             as rhsEq;
                          (Permutation.swap(a, c) ∘ (Permutation.swap(a, b) ∘ Permutation.swap(a, c)))(i)
                             = a by lhsEq
                             = Permutation.swap(c, b)(i) by rhsEq;
                          done
                        }
                      case i ≠ a as iNeqA: {
                          (Permutation.swap(a, c) ∘ (Permutation.swap(a, b) ∘ Permutation.swap(a, c)))(i)
                             = Permutation.swap(a, c)(Permutation.swap(a, b)(Permutation.swap(a, c)(i))) by Permutation.apply_compose
                             = Permutation.swap(a, c)(Permutation.swap(a, b)(i)) by substituting Permutation.apply_swap_other
                             = Permutation.swap(a, c)(i) by substituting Permutation.apply_swap_other
                             = i by Permutation.apply_swap_other
                             as lhsEq;
                          Permutation.swap(c, b)(i)
                             = i by Permutation.apply_swap_other
                             as rhsEq;
                          (Permutation.swap(a, c) ∘ (Permutation.swap(a, b) ∘ Permutation.swap(a, c)))(i)
                             = i by lhsEq
                             = Permutation.swap(c, b)(i) by rhsEq;
                          done
                        }
                    }
                  }
              }
            }
        }
      })
}

-- ----------------------------------------------------------------------
-- The base case: an adjacent transposition inverts exactly one ordered pair.

-- How a transposition moves the value of an index: to the partner's value at
-- the two swapped indices, unchanged elsewhere. (Stated by value, since a
-- value pins down the index.)
theorem Permutation.value_apply_swap_at_left {n : ℕ} (a b x : NaturalsBelow(n))
        (atA : NaturalsBelow.value(x) = NaturalsBelow.value(a))
        : NaturalsBelow.value(Permutation.swap(a, b)(x)) = NaturalsBelow.value(b) := {
  x = a by NaturalsBelow.equal_of_value as xIsA;
  NaturalsBelow.value(Permutation.swap(a, b)(x))
     = NaturalsBelow.value(Permutation.swap(a, b)(a)) by substituting xIsA
     = NaturalsBelow.value(b) by substituting Permutation.apply_swap_left;
  done
}

theorem Permutation.value_apply_swap_at_right {n : ℕ} (a b x : NaturalsBelow(n))
        (atB : NaturalsBelow.value(x) = NaturalsBelow.value(b))
        : NaturalsBelow.value(Permutation.swap(a, b)(x)) = NaturalsBelow.value(a) := {
  x = b by NaturalsBelow.equal_of_value as xIsB;
  NaturalsBelow.value(Permutation.swap(a, b)(x))
     = NaturalsBelow.value(Permutation.swap(a, b)(b)) by substituting xIsB
     = NaturalsBelow.value(a) by substituting Permutation.apply_swap_right;
  done
}

theorem Permutation.value_apply_swap_at_other {n : ℕ} (a b x : NaturalsBelow(n))
        (offA : NaturalsBelow.value(x) ≠ NaturalsBelow.value(a))
        (offB : NaturalsBelow.value(x) ≠ NaturalsBelow.value(b))
        : NaturalsBelow.value(Permutation.swap(a, b)(x)) = NaturalsBelow.value(x) := {
  x ≠ a by NaturalsBelow.ne_of_value_ne;
  x ≠ b by NaturalsBelow.ne_of_value_ne;
  NaturalsBelow.value(Permutation.swap(a, b)(x))
     = NaturalsBelow.value(x) by substituting Permutation.apply_swap_other;
  done
}

-- From a strict inequality, the two sides differ.
-- The heart of the base case: on any ordered pair OTHER than {a, b} itself, an
-- adjacent transposition preserves the value order, so its orientation is +1.
theorem Permutation.pairOrient_swap_adjacent_other {n : ℕ} (a b : NaturalsBelow(n))
        (adjacent : NaturalsBelow.value(b) = 1 + NaturalsBelow.value(a))
        (p : Pair(NaturalsBelow(n), NaturalsBelow(n)))
        (memberP : p ∈ Permutation.orderedPairs(n))
        (notThePair : p ≠ Product.make(a, b))
        : Permutation.pairOrient(Permutation.swap(a, b), p) = 1 :=
  by induction on p with pInduct {
    case Product.make(i, j): {
      1 + NaturalsBelow.value(a) = NaturalsBelow.value(b) by adjacent as adjacentBack;
      NaturalsBelow.value(i) < NaturalsBelow.value(j)
          by Permutation.orderedPairs_property as ordered;
      ¬(NaturalsBelow.value(i) = NaturalsBelow.value(a) ∧ NaturalsBelow.value(j) = NaturalsBelow.value(b))
          by {
            suppose NaturalsBelow.value(i) = NaturalsBelow.value(a)
                ∧ NaturalsBelow.value(j) = NaturalsBelow.value(b) for contradiction {
              NaturalsBelow.value(i) = NaturalsBelow.value(a);
              NaturalsBelow.value(j) = NaturalsBelow.value(b);
              i = a by NaturalsBelow.equal_of_value;
              j = b by NaturalsBelow.equal_of_value;
              Product.make(i, j) = Product.make(a, b)
                  by Product.make_equal;
              False by notThePair;
              done
            };
            done
          } as notBothMatch;
      NaturalsBelow.value(Permutation.swap(a, b)(i)) < NaturalsBelow.value(Permutation.swap(a, b)(j)) by {
            NaturalsBelow.value(i) = NaturalsBelow.value(a)
                ∨ NaturalsBelow.value(i) ≠ NaturalsBelow.value(a);
            done by cases {
              case NaturalsBelow.value(i) = NaturalsBelow.value(a) as iIsA: {
                  NaturalsBelow.value(Permutation.swap(a, b)(i)) = NaturalsBelow.value(b) by Permutation.value_apply_swap_at_left as swapI;
                  NaturalsBelow.value(a) < NaturalsBelow.value(j)
                      by { NaturalsBelow.value(a) = NaturalsBelow.value(i) by iIsA
                               < NaturalsBelow.value(j) by ordered; done };
                  NaturalsBelow.value(j) ≠ NaturalsBelow.value(b) by {
                    suppose NaturalsBelow.value(j) = NaturalsBelow.value(b) for contradiction {
                      NaturalsBelow.value(i) = NaturalsBelow.value(a)
                          ∧ NaturalsBelow.value(j) = NaturalsBelow.value(b);
                      False by notBothMatch;
                      done
                    };
                    done
                  };
                  NaturalsBelow.value(a) ≠ NaturalsBelow.value(j) by Natural.not_equal_of_less_than;
                  NaturalsBelow.value(j) ≠ NaturalsBelow.value(a) by Equality.not_equal_symmetric;
                  NaturalsBelow.value(Permutation.swap(a, b)(j)) = NaturalsBelow.value(j) by Permutation.value_apply_swap_at_other as swapJ;
                  1 + NaturalsBelow.value(a) ≤ NaturalsBelow.value(j)
                      by Natural.add_one_le_of_lt;
                  NaturalsBelow.value(j) ≠ 1 + NaturalsBelow.value(a) by substituting adjacentBack;
                  1 + NaturalsBelow.value(a) ≠ NaturalsBelow.value(j) by Equality.not_equal_symmetric;
                  1 + NaturalsBelow.value(a) < NaturalsBelow.value(j)
                      by Natural.lt_of_le_of_ne
                      as oneVaLtJ;
                  NaturalsBelow.value(Permutation.swap(a, b)(i))
                     = NaturalsBelow.value(b) by swapI
                     = 1 + NaturalsBelow.value(a) by adjacent
                     < NaturalsBelow.value(j) by oneVaLtJ
                     = NaturalsBelow.value(Permutation.swap(a, b)(j)) by swapJ;
                  done
                }
              case NaturalsBelow.value(i) ≠ NaturalsBelow.value(a) as iNotA: {
                  NaturalsBelow.value(i) = NaturalsBelow.value(b)
                      ∨ NaturalsBelow.value(i) ≠ NaturalsBelow.value(b);
                  done by cases {
                    case NaturalsBelow.value(i) = NaturalsBelow.value(b) as iIsB: {
                        NaturalsBelow.value(Permutation.swap(a, b)(i)) = NaturalsBelow.value(a)
                            by Permutation.value_apply_swap_at_right as swapI;
                        1 + NaturalsBelow.value(a) < NaturalsBelow.value(j)
                            by { 1 + NaturalsBelow.value(a) = NaturalsBelow.value(b) by adjacentBack
                                     = NaturalsBelow.value(i) by iIsB
                                     < NaturalsBelow.value(j) by ordered; done } as oneVaLtJ;
                        NaturalsBelow.value(a) < NaturalsBelow.value(j)
                            by { NaturalsBelow.value(a) < 1 + NaturalsBelow.value(a) by Natural.lt_one_plus
                                     < NaturalsBelow.value(j) by oneVaLtJ; done } as aLtJ;
                        NaturalsBelow.value(b) < NaturalsBelow.value(j)
                            by { NaturalsBelow.value(b) = 1 + NaturalsBelow.value(a) by adjacent
                                     < NaturalsBelow.value(j) by oneVaLtJ; done };
                        NaturalsBelow.value(a) ≠ NaturalsBelow.value(j) by Natural.not_equal_of_less_than;
                        NaturalsBelow.value(j) ≠ NaturalsBelow.value(a) by Equality.not_equal_symmetric;
                        NaturalsBelow.value(b) ≠ NaturalsBelow.value(j) by Natural.not_equal_of_less_than;
                        NaturalsBelow.value(j) ≠ NaturalsBelow.value(b) by Equality.not_equal_symmetric;
                        NaturalsBelow.value(Permutation.swap(a, b)(j)) = NaturalsBelow.value(j)
                            by Permutation.value_apply_swap_at_other as swapJ;
                        NaturalsBelow.value(Permutation.swap(a, b)(i))
                           = NaturalsBelow.value(a) by swapI
                           < NaturalsBelow.value(j) by aLtJ
                           = NaturalsBelow.value(Permutation.swap(a, b)(j)) by swapJ;
                        done
                      }
                    case NaturalsBelow.value(i) ≠ NaturalsBelow.value(b) as iNotB: {
                        NaturalsBelow.value(Permutation.swap(a, b)(i)) = NaturalsBelow.value(i)
                            by Permutation.value_apply_swap_at_other as swapI;
                        NaturalsBelow.value(j) = NaturalsBelow.value(a)
                            ∨ NaturalsBelow.value(j) ≠ NaturalsBelow.value(a);
                        done by cases {
                          case NaturalsBelow.value(j) = NaturalsBelow.value(a) as jIsA: {
                              NaturalsBelow.value(Permutation.swap(a, b)(j))
                                  = NaturalsBelow.value(b) by Permutation.value_apply_swap_at_left as swapJ;
                              NaturalsBelow.value(i) < NaturalsBelow.value(a)
                                  by { NaturalsBelow.value(i) < NaturalsBelow.value(j) by ordered
                                           = NaturalsBelow.value(a) by jIsA; done } as iLtA;
                              NaturalsBelow.value(a) < NaturalsBelow.value(b)
                                  by { NaturalsBelow.value(a) < 1 + NaturalsBelow.value(a) by Natural.lt_one_plus
                                           = NaturalsBelow.value(b) by adjacentBack; done } as aLtB;
                              NaturalsBelow.value(Permutation.swap(a, b)(i))
                                 = NaturalsBelow.value(i) by swapI
                                 < NaturalsBelow.value(a) by iLtA
                                 < NaturalsBelow.value(b) by aLtB
                                 = NaturalsBelow.value(Permutation.swap(a, b)(j)) by swapJ;
                              done
                            }
                          case NaturalsBelow.value(j) ≠ NaturalsBelow.value(a) as jNotA: {
                              NaturalsBelow.value(j) = NaturalsBelow.value(b)
                                  ∨ NaturalsBelow.value(j) ≠ NaturalsBelow.value(b);
                              done by cases {
                                case NaturalsBelow.value(j) = NaturalsBelow.value(b) as jIsB: {
                                    NaturalsBelow.value(Permutation.swap(a, b)(j))
                                        = NaturalsBelow.value(a) by Permutation.value_apply_swap_at_right as swapJ;
                                    NaturalsBelow.value(i) < 1 + NaturalsBelow.value(a)
                                        by { NaturalsBelow.value(i) < NaturalsBelow.value(j) by ordered
                                                 = NaturalsBelow.value(b) by jIsB
                                                 = 1 + NaturalsBelow.value(a) by adjacent; done };
                                    NaturalsBelow.value(i) ≤ NaturalsBelow.value(a)
                                        by Natural.le_of_lt_one_plus;
                                    NaturalsBelow.value(i) < NaturalsBelow.value(a)
                                        by Natural.lt_of_le_of_ne as iLtA;
                                    NaturalsBelow.value(Permutation.swap(a, b)(i))
                                       = NaturalsBelow.value(i) by swapI
                                       < NaturalsBelow.value(a) by iLtA
                                       = NaturalsBelow.value(Permutation.swap(a, b)(j)) by swapJ;
                                    done
                                  }
                                case NaturalsBelow.value(j) ≠ NaturalsBelow.value(b) as jNotB: {
                                    NaturalsBelow.value(Permutation.swap(a, b)(j))
                                        = NaturalsBelow.value(j) by Permutation.value_apply_swap_at_other as swapJ;
                                    NaturalsBelow.value(Permutation.swap(a, b)(i))
                                       = NaturalsBelow.value(i) by swapI
                                       < NaturalsBelow.value(j) by ordered
                                       = NaturalsBelow.value(Permutation.swap(a, b)(j)) by swapJ;
                                    done
                                  }
                              }
                            }
                        }
                      }
                  }
                }
            }
          };
      Permutation.pairOrient(Permutation.swap(a, b), Product.make(i, j))
         = Permutation.orient(Permutation.swap(a, b)(i), Permutation.swap(a, b)(j))
         = 1 by Permutation.orient_forward;
      done
    }
  }

-- The base case itself: an adjacent transposition has sign −1. Its unique
-- inverted pair is {a, b} (orientation −1); every other pair keeps its order
-- (orientation +1), so the sign-product isolates the single −1.
theorem Permutation.sign_swap_adjacent {n : ℕ} (a b : NaturalsBelow(n))
        (adjacent : NaturalsBelow.value(b) = 1 + NaturalsBelow.value(a))
        : Permutation.sign(Permutation.swap(a, b)) = Integer.negate(1) := {
  1 + NaturalsBelow.value(a) = NaturalsBelow.value(b) by adjacent as adjacentBack;
  NaturalsBelow.value(a) < NaturalsBelow.value(b)
      by { NaturalsBelow.value(a) < 1 + NaturalsBelow.value(a) by Natural.lt_one_plus
               = NaturalsBelow.value(b) by adjacentBack; done };
  ¬(NaturalsBelow.value(b) < NaturalsBelow.value(a))
      by Natural.lt_asymmetric;
  List.Distinct(Pair(NaturalsBelow(n), NaturalsBelow(n)), Permutation.orderedPairs(n)) by Permutation.orderedPairs_distinct;
  Product.make(a, b) ∈ Permutation.orderedPairs(n) by Permutation.orderedPairs_member;
  (∀ (p : Pair(NaturalsBelow(n), NaturalsBelow(n))). p ∈ Permutation.orderedPairs(n)
      → p ≠ Product.make(a, b) → Permutation.pairOrient(Permutation.swap(a, b), p) = Integer.one)
      by (p : Pair(NaturalsBelow(n), NaturalsBelow(n)))
         (memberP : p ∈ Permutation.orderedPairs(n))
         (notThePair : p ≠ Product.make(a, b)) ↦
             done by Permutation.pairOrient_swap_adjacent_other;
  Permutation.sign(Permutation.swap(a, b))
     = List.product(ℤ, Integer.multiply, Integer.one,
           List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), ℤ,
               Permutation.pairOrient(Permutation.swap(a, b)), Permutation.orderedPairs(n)))
     = Permutation.pairOrient(Permutation.swap(a, b), Product.make(a, b))
           by List.product_isolate_single
     = Permutation.orient(Permutation.swap(a, b)(a), Permutation.swap(a, b)(b))
     = Permutation.orient(b, Permutation.swap(a, b)(b))
           by substituting Permutation.apply_swap_left
     = Permutation.orient(b, a) by substituting Permutation.apply_swap_right
     = Integer.negate(1) by Permutation.orient_backward;
  done
}

-- ----------------------------------------------------------------------
-- The distance induction and the general result.

-- A transposition is symmetric in its two indices.
theorem Permutation.swap_symmetric {n : ℕ} (a b : NaturalsBelow(n))
        : Permutation.swap(a, b) = Permutation.swap(b, a) :=
  Permutation.equal_of_apply_equal(applyEqual :=
      (i : NaturalsBelow(n)) ↦ {
        i = a ∨ i ≠ a;
        done by cases {
          case i = a as iIsA:
              Permutation.swap(a, b)(i)
                 = Permutation.swap(a, b)(a) by substituting iIsA
                 = b by Permutation.apply_swap_left
                 = Permutation.swap(b, a)(a) by Permutation.apply_swap_right
                 = Permutation.swap(b, a)(i) by substituting iIsA
          case i ≠ a as iNeqA: {
              i = b ∨ i ≠ b;
              done by cases {
                case i = b as iIsB:
                    Permutation.swap(a, b)(i)
                       = Permutation.swap(a, b)(b) by substituting iIsB
                       = a by Permutation.apply_swap_right
                       = Permutation.swap(b, a)(b) by Permutation.apply_swap_left
                       = Permutation.swap(b, a)(i) by substituting iIsB
                case i ≠ b as iNeqB:
                    Permutation.swap(a, b)(i)
                       = i by Permutation.apply_swap_other
                       = Permutation.swap(b, a)(i) by Permutation.apply_swap_other
              }
            }
        }
      })

-- Distance induction: a transposition whose indices differ in value by 1 + d
-- has sign −1. The step conjugates by an adjacent transposition (swap(a, c)
-- with value(c) = value(a) + 1) to reach one of distance d.
theorem Permutation.sign_swap_gap (n : ℕ) (d : ℕ)
        : ∀ (a b : NaturalsBelow(n)).
              NaturalsBelow.value(b) = (1 + d) + NaturalsBelow.value(a)
              → Permutation.sign(Permutation.swap(a, b)) = Integer.negate(1) :=
  by induction on d with IH {
    case base:
        (a b : NaturalsBelow(n))
        (gapHyp : NaturalsBelow.value(b) = (1 + 0) + NaturalsBelow.value(a)) ↦ {
          NaturalsBelow.value(b) = 1 + NaturalsBelow.value(a) by gapHyp;
          done by Permutation.sign_swap_adjacent
        }
    case step(dPred):
        (a b : NaturalsBelow(n))
        (gapHyp : NaturalsBelow.value(b) = (1 + (1 + dPred)) + NaturalsBelow.value(a)) ↦ {
          1 + NaturalsBelow.value(a) < NaturalsBelow.value(b) by {
            NaturalsBelow.value(b) = (1 + (1 + dPred)) + NaturalsBelow.value(a) by gapHyp
               = NaturalsBelow.value(a) + (1 + (1 + dPred)) by ring as vbEq;
            1 ≤ 1 + dPred by Natural.zero_least;
            1 < 1 + (1 + dPred) by Natural.lt_add_of_one_le;
            1 + NaturalsBelow.value(a) = NaturalsBelow.value(a) + 1 by ring
               < NaturalsBelow.value(a) + (1 + (1 + dPred)) by Natural.add_left_strict_monotone
               = NaturalsBelow.value(b) by vbEq;
            done
          } as cBoundLtB;
          NaturalsBelow.value(b) < n by NaturalsBelow.below as bBelow;
          1 + NaturalsBelow.value(a) < n by {
            1 + NaturalsBelow.value(a) < NaturalsBelow.value(b) by cBoundLtB < n by bBelow; done
          } as cBound;
          let c : NaturalsBelow(n) := NaturalsBelow.make(1 + NaturalsBelow.value(a), cBound);
          NaturalsBelow.value(c) = 1 + NaturalsBelow.value(a) as valueC;
          NaturalsBelow.value(a) < NaturalsBelow.value(b) by {
            NaturalsBelow.value(a) < 1 + NaturalsBelow.value(a) by Natural.lt_one_plus
               < NaturalsBelow.value(b) by cBoundLtB; done
          };
          NaturalsBelow.value(a) ≠ NaturalsBelow.value(b) by Natural.not_equal_of_less_than;
          NaturalsBelow.value(b) ≠ NaturalsBelow.value(a) by Equality.not_equal_symmetric;
          b ≠ a by NaturalsBelow.ne_of_value_ne;
          NaturalsBelow.value(b) ≠ NaturalsBelow.value(c) by {
            1 + NaturalsBelow.value(a) ≠ NaturalsBelow.value(b) by Natural.not_equal_of_less_than;
            NaturalsBelow.value(b) ≠ 1 + NaturalsBelow.value(a) by Equality.not_equal_symmetric;
            done by substituting valueC
          };
          b ≠ c by NaturalsBelow.ne_of_value_ne;
          NaturalsBelow.value(a) ≠ NaturalsBelow.value(c) by {
            NaturalsBelow.value(a) ≠ 1 + NaturalsBelow.value(a) by Natural.not_equal_of_less_than;
            done by substituting valueC
          };
          a ≠ c by NaturalsBelow.ne_of_value_ne;
          NaturalsBelow.value(b) = (1 + dPred) + NaturalsBelow.value(c) by {
            NaturalsBelow.value(b) = (1 + (1 + dPred)) + NaturalsBelow.value(a) by gapHyp
               = (1 + dPred) + (1 + NaturalsBelow.value(a)) by ring
               = (1 + dPred) + NaturalsBelow.value(c) by substituting valueC;
            done
          } as gapCB;
          Permutation.sign(Permutation.swap(c, b)) = Integer.negate(1) by IH(c, b, gapCB) as signCB;
          Permutation.swap(c, b)
              = Permutation.swap(a, c) ∘ (Permutation.swap(a, b) ∘ Permutation.swap(a, c))
              by Permutation.swap_conjugate_by_swap as identBack;
          Permutation.sign(Permutation.swap(c, b))
             = Permutation.sign(Permutation.swap(a, c) ∘ (Permutation.swap(a, b) ∘ Permutation.swap(a, c)))
                   by substituting identBack
             = Permutation.sign(Permutation.swap(a, c))
                   * Permutation.sign(Permutation.swap(a, b) ∘ Permutation.swap(a, c))
                   by Permutation.sign_compose
             = Permutation.sign(Permutation.swap(a, c))
                   * (Permutation.sign(Permutation.swap(a, b)) * Permutation.sign(Permutation.swap(a, c)))
                   by substituting Permutation.sign_compose
             = Permutation.sign(Permutation.swap(a, b))
                   * (Permutation.sign(Permutation.swap(a, c)) * Permutation.sign(Permutation.swap(a, c)))
                   by ring
             = Permutation.sign(Permutation.swap(a, b)) * Integer.one
                   by substituting Permutation.sign_swap_square
             = Permutation.sign(Permutation.swap(a, b)) by ring
             as signCBeqAB;
          Permutation.sign(Permutation.swap(a, b))
             = Permutation.sign(Permutation.swap(c, b)) by signCBeqAB
             = Integer.negate(1) by signCB;
          done
        }
  }

-- A transposition of distinct indices is odd: its sign is −1.
theorem Permutation.sign_swap {n : ℕ} (a b : NaturalsBelow(n)) (distinct : a ≠ b)
        : Permutation.sign(Permutation.swap(a, b)) = Integer.negate(1) := {
  NaturalsBelow.value(a) ≠ NaturalsBelow.value(b) by {
    suppose NaturalsBelow.value(a) = NaturalsBelow.value(b) for contradiction {
      NaturalsBelow.value(a) = NaturalsBelow.value(b);
      a = b by NaturalsBelow.equal_of_value;
      False by distinct;
      done
    };
    done
  };
  NaturalsBelow.value(a) < NaturalsBelow.value(b) ∨ NaturalsBelow.value(b) < NaturalsBelow.value(a)
      by Natural.lt_or_gt_of_ne;
  done by cases {
    case NaturalsBelow.value(a) < NaturalsBelow.value(b) as aLtB: {
        choose d such that NaturalsBelow.value(a) + (1 + d) = NaturalsBelow.value(b)
            from Natural.lt_elim;
        NaturalsBelow.value(a) + (1 + d) = NaturalsBelow.value(b) as gapEq;
        NaturalsBelow.value(b) = (1 + d) + NaturalsBelow.value(a) by {
          NaturalsBelow.value(b) = NaturalsBelow.value(a) + (1 + d) by gapEq
             = (1 + d) + NaturalsBelow.value(a) by ring;
          done
        };
        done by Permutation.sign_swap_gap
      }
    case NaturalsBelow.value(b) < NaturalsBelow.value(a) as bLtA: {
        choose d such that NaturalsBelow.value(b) + (1 + d) = NaturalsBelow.value(a)
            from Natural.lt_elim;
        NaturalsBelow.value(b) + (1 + d) = NaturalsBelow.value(a) as gapEq;
        NaturalsBelow.value(a) = (1 + d) + NaturalsBelow.value(b) by {
          NaturalsBelow.value(a) = NaturalsBelow.value(b) + (1 + d) by gapEq
             = (1 + d) + NaturalsBelow.value(b) by ring;
          done
        };
        Permutation.sign(Permutation.swap(b, a)) = Integer.negate(1)
            by Permutation.sign_swap_gap as signBA;
        Permutation.sign(Permutation.swap(a, b))
           = Permutation.sign(Permutation.swap(b, a)) by substituting Permutation.swap_symmetric
           = Integer.negate(1) by signBA;
        done
      }
  }
}

-- Algebra/permutation_transposition_sign.math
--
-- A transposition is odd: `Permutation.sign(Permutation.swap(a, b)) = −1` for
-- distinct a, b (Stage H brick 6b of PLAN_LINEAR_ALGEBRA.md). The alternating
-- collapse of det(AB) (brick 6c) pairs each permutation with its composite by a
-- transposition; this is what makes those two terms cancel.
--
-- Route: reduce to value(a) < value(b) (swap is symmetric), then induct on the
-- value-distance. The base case is an adjacent transposition — it inverts
-- exactly one ordered pair, so its sign is a single −1 factor. The step
-- conjugates by an adjacent transposition to drop the distance by one, using
-- sign multiplicativity and that a transposition's sign squares to 1.

module Algebra.permutation_transposition_sign

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.order
import Natural.arithmetic
import Natural.classical_decidable
import Integer.basics
import Algebra.integer_domain
import Logic.product
import Lists.list
import Lists.map
import Lists.distinct
import Set.finite
import Set.finite_pigeonhole
import Algebra.finite_permutation
import Algebra.permutation_enumeration
import Algebra.permutation_sign

-- ----------------------------------------------------------------------
-- A product over a distinct list with exactly one non-unit factor equals that
-- factor: every other element maps to `one`, so it drops out.
theorem List.product_isolate_single (B : Type(0)) (f : B → Integer) (e0 : B)
        (l : List(B)) (distinctL : List.Distinct(B, l)) (memberE0 : List.member(B, e0, l))
        (othersAreOne : ∀ (x : B). List.member(B, x, l) → x ≠ e0 → f(x) = Integer.one)
        : List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, f, l)) = f(e0) :=
  by induction on l with IH {
    case List.empty:
        absurd(List.no_member_empty(B, e0, memberE0))
    case List.prepend(head, tail): {
        ¬(List.member(B, head, tail)) by List.Distinct.head_not_member(B, head, tail, distinctL)
            as headNotInTail;
        List.Distinct(B, tail) by List.Distinct.tail_distinct(B, head, tail, distinctL) as tailDistinct;
        e0 = head ∨ List.member(B, e0, tail)
            by List.member_prepend_invert(B, e0, head, tail, memberE0);
        done by cases {
          case e0 = head as e0IsHead: {
              (∀ (x : B). List.member(B, x, tail) → f(x) = Integer.one)
                  by (x : B) (xInTail : List.member(B, x, tail)) ↦ {
                    List.member(B, x, List.prepend(B, head, tail))
                        by List.member.there(B, x, head, tail, xInTail) as xInList;
                    x ≠ e0 by {
                      suppose x = e0 for contradiction {
                        x = e0 as xIsE0;
                        head = e0 by e0IsHead = x by xIsE0 as headEqX;
                        List.member(B, head, tail) by substituting headEqX;
                        False by headNotInTail;
                        done
                      };
                      done
                    } as xNeqE0;
                    f(x) = Integer.one by othersAreOne(x, xInList, xNeqE0);
                    done
                  } as tailOnes;
              List.product(Integer, Integer.multiply, Integer.one,
                    List.map(B, Integer, f, List.prepend(B, head, tail)))
                 = Integer.multiply(f(head),
                       List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, f, tail)))
                 = Integer.multiply(f(head), Integer.one)
                       by substituting List.product_of_ones(Integer, Integer.multiply, Integer.one,
                              Integer.one_multiply_left, List.map(B, Integer, f, tail),
                              (y : Integer) (yInMap : List.member(Integer, y, List.map(B, Integer, f, tail))) ↦ {
                                choose x such that List.member(B, x, tail) ∧ (f(x) = y)
                                    from List.map_member_invert(B, Integer, f, y, tail, yInMap);
                                List.member(B, x, tail) as xInTail2;
                                f(x) = y as fxIsY;
                                y = f(x) by fxIsY = Integer.one by tailOnes(x, xInTail2);
                                done
                              })
                 = f(head) by ring
                 = f(e0) by substituting e0IsHead;
              done
            }
          case List.member(B, e0, tail) as e0InTail: {
              head ≠ e0 by {
                suppose head = e0 for contradiction {
                  head = e0 as headIsE0;
                  List.member(B, head, tail) by substituting headIsE0;
                  False by headNotInTail;
                  done
                };
                done
              } as headNeqE0;
              f(head) = Integer.one
                  by othersAreOne(head, List.member.here(B, head, tail), headNeqE0) as fHeadIsOne;
              (∀ (x : B). List.member(B, x, tail) → x ≠ e0 → f(x) = Integer.one)
                  by (x : B) (xInTail : List.member(B, x, tail)) ↦
                      othersAreOne(x, List.member.there(B, x, head, tail, xInTail)) as tailOthers;
              List.product(Integer, Integer.multiply, Integer.one,
                    List.map(B, Integer, f, List.prepend(B, head, tail)))
                 = Integer.multiply(f(head),
                       List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, f, tail)))
                 = Integer.multiply(Integer.one,
                       List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, f, tail)))
                       by substituting fHeadIsOne
                 = List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, f, tail))
                       by ring
                 = f(e0) by IH(tailDistinct, e0InTail, tailOthers);
              done
            }
        }
      }
  }

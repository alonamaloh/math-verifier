-- Algebra/permutation_transposition_sign.math
--
-- A transposition is odd: `Permutation.sign(Permutation.swap(a, b)) = −1` for
-- distinct a, b (Stage H brick 6b of PLAN_LINEAR_ALGEBRA.md). The alternating
-- collapse of det(AB) (brick 6c) pairs each permutation with its composite by a
-- transposition; this is what makes those two terms cancel.
--
-- Route: reduce to value(a) < value(b) (swap is symmetric), then induct on the
-- value-distance. The base case is an adjacent transposition — it inverts
-- exactly one ordered pair, so its sign is a single −1 factor. The step
-- conjugates by an adjacent transposition to drop the distance by one, using
-- sign multiplicativity and that a transposition's sign squares to 1.

module Algebra.permutation_transposition_sign

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.order
import Natural.arithmetic
import Natural.classical_decidable
import Integer.basics
import Algebra.integer_domain
import Logic.product
import Lists.list
import Lists.map
import Lists.distinct
import Set.finite
import Set.finite_pigeonhole
import Algebra.finite_permutation
import Algebra.permutation_enumeration
import Algebra.permutation_sign

-- ----------------------------------------------------------------------
-- A product over a distinct list with exactly one non-unit factor equals that
-- factor: every other element maps to `one`, so it drops out.
theorem List.product_isolate_single (B : Type(0)) (f : B → Integer) (e0 : B)
        (l : List(B)) (distinctL : List.Distinct(B, l)) (memberE0 : List.member(B, e0, l))
        (othersAreOne : ∀ (x : B). List.member(B, x, l) → x ≠ e0 → f(x) = Integer.one)
        : List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, f, l)) = f(e0) :=
  by induction on l with IH {
    case List.empty:
        absurd(List.no_member_empty(B, e0, memberE0))
    case List.prepend(head, tail): {
        ¬(List.member(B, head, tail)) by List.Distinct.head_not_member(B, head, tail, distinctL)
            as headNotInTail;
        List.Distinct(B, tail) by List.Distinct.tail_distinct(B, head, tail, distinctL) as tailDistinct;
        e0 = head ∨ List.member(B, e0, tail)
            by List.member_prepend_invert(B, e0, head, tail, memberE0);
        done by cases {
          case e0 = head as e0IsHead: {
              (∀ (x : B). List.member(B, x, tail) → f(x) = Integer.one)
                  by (x : B) (xInTail : List.member(B, x, tail)) ↦ {
                    List.member(B, x, List.prepend(B, head, tail))
                        by List.member.there(B, x, head, tail, xInTail) as xInList;
                    x ≠ e0 by {
                      suppose x = e0 for contradiction {
                        x = e0 as xIsE0;
                        head = e0 by e0IsHead = x by xIsE0 as headEqX;
                        List.member(B, head, tail) by substituting headEqX;
                        False by headNotInTail;
                        done
                      };
                      done
                    } as xNeqE0;
                    f(x) = Integer.one by othersAreOne(x, xInList, xNeqE0);
                    done
                  } as tailOnes;
              List.product(Integer, Integer.multiply, Integer.one,
                    List.map(B, Integer, f, List.prepend(B, head, tail)))
                 = Integer.multiply(f(head),
                       List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, f, tail)))
                 = Integer.multiply(f(head), Integer.one)
                       by substituting List.product_of_ones(Integer, Integer.multiply, Integer.one,
                              Integer.one_multiply_left, List.map(B, Integer, f, tail),
                              (y : Integer) (yInMap : List.member(Integer, y, List.map(B, Integer, f, tail))) ↦ {
                                choose x such that List.member(B, x, tail) ∧ (f(x) = y)
                                    from List.map_member_invert(B, Integer, f, y, tail, yInMap);
                                List.member(B, x, tail) as xInTail2;
                                f(x) = y as fxIsY;
                                y = f(x) by fxIsY = Integer.one by tailOnes(x, xInTail2);
                                done
                              })
                 = f(head) by ring
                 = f(e0) by substituting e0IsHead;
              done
            }
          case List.member(B, e0, tail) as e0InTail: {
              head ≠ e0 by {
                suppose head = e0 for contradiction {
                  head = e0 as headIsE0;
                  List.member(B, head, tail) by substituting headIsE0;
                  False by headNotInTail;
                  done
                };
                done
              } as headNeqE0;
              f(head) = Integer.one
                  by othersAreOne(head, List.member.here(B, head, tail), headNeqE0) as fHeadIsOne;
              (∀ (x : B). List.member(B, x, tail) → x ≠ e0 → f(x) = Integer.one)
                  by (x : B) (xInTail : List.member(B, x, tail)) ↦
                      othersAreOne(x, List.member.there(B, x, head, tail, xInTail)) as tailOthers;
              List.product(Integer, Integer.multiply, Integer.one,
                    List.map(B, Integer, f, List.prepend(B, head, tail)))
                 = Integer.multiply(f(head),
                       List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, f, tail)))
                 = Integer.multiply(Integer.one,
                       List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, f, tail)))
                       by substituting fHeadIsOne
                 = List.product(Integer, Integer.multiply, Integer.one, List.map(B, Integer, f, tail))
                       by ring
                 = f(e0) by IH(tailDistinct, e0InTail, tailOthers);
              done
            }
        }
      }
  }

-- ----------------------------------------------------------------------
-- Reducing a transposition's sign to that of a closer one by conjugation.

-- Symmetry of disequality (a generic helper).
theorem Equality.ne_symmetric (A : Type(0)) (x y : A) (ne : x ≠ y) : y ≠ x :=
  (equal : y = x) ↦ {
    x = y by equal;
    done by ne
  }

-- A transposition's sign squares to one: it is a unit.
theorem Permutation.sign_swap_square {n : Natural} (a b : NaturalsBelow(n))
        : Integer.multiply(Permutation.sign(Permutation.swap(a, b)),
              Permutation.sign(Permutation.swap(a, b))) = Integer.one := {
  Permutation.sign(Permutation.swap(a, b)) = 1
      ∨ Permutation.sign(Permutation.swap(a, b)) = Integer.negate(1)
      by Permutation.sign_is_unit(Permutation.swap(a, b));
  done by cases {
    case Permutation.sign(Permutation.swap(a, b)) = 1 as isPositive:
        Integer.multiply(Permutation.sign(Permutation.swap(a, b)),
              Permutation.sign(Permutation.swap(a, b)))
           = Integer.multiply(1, 1) by substituting isPositive
           = Integer.one by ring
    case Permutation.sign(Permutation.swap(a, b)) = Integer.negate(1) as isNegative:
        Integer.multiply(Permutation.sign(Permutation.swap(a, b)),
              Permutation.sign(Permutation.swap(a, b)))
           = Integer.multiply(Integer.negate(1), Integer.negate(1)) by substituting isNegative
           = Integer.one by ring
  }
}

-- Conjugating swap(a, b) by the transposition swap(a, c) yields swap(c, b):
-- swap(a, c) ∘ swap(a, b) ∘ swap(a, c) = swap(c, b), for a, b, c with b outside
-- {a, c} and a ≠ c. This is the group identity behind the distance reduction.
theorem Permutation.swap_conjugate_by_swap {n : Natural} (a b c : NaturalsBelow(n))
        (aNeqC : a ≠ c) (bNeqA : b ≠ a) (bNeqC : b ≠ c)
        : Permutation.compose(Permutation.swap(a, c),
              Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, c)))
          = Permutation.swap(c, b) := {
  c ≠ a by Equality.ne_symmetric(NaturalsBelow(n), a, c, aNeqC) as cNeqA;
  a ≠ b by Equality.ne_symmetric(NaturalsBelow(n), b, a, bNeqA) as aNeqB;
  c ≠ b by Equality.ne_symmetric(NaturalsBelow(n), b, c, bNeqC) as cNeqB;
  done by Permutation.equal_of_apply_equal(
      Permutation.compose(Permutation.swap(a, c),
          Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, c))),
      Permutation.swap(c, b),
      (i : NaturalsBelow(n)) ↦ {
        i = c ∨ i ≠ c;
        done by cases {
          case i = c as iIsC: {
              Permutation.apply(Permutation.compose(Permutation.swap(a, c),
                    Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, c))), i)
                 = Permutation.apply(Permutation.swap(a, c),
                       Permutation.apply(Permutation.swap(a, b),
                           Permutation.apply(Permutation.swap(a, c), i)))
                       by Permutation.apply_compose
                 = Permutation.apply(Permutation.swap(a, c),
                       Permutation.apply(Permutation.swap(a, b),
                           Permutation.apply(Permutation.swap(a, c), c)))
                       by substituting iIsC
                 = Permutation.apply(Permutation.swap(a, c),
                       Permutation.apply(Permutation.swap(a, b), a))
                       by substituting Permutation.apply_swap_right(a, c)
                 = Permutation.apply(Permutation.swap(a, c), b)
                       by substituting Permutation.apply_swap_left(a, b)
                 = b by Permutation.apply_swap_other(a, c, b, bNeqA, bNeqC)
                 as lhsEq;
              Permutation.apply(Permutation.swap(c, b), i)
                 = Permutation.apply(Permutation.swap(c, b), c) by substituting iIsC
                 = b by Permutation.apply_swap_left(c, b)
                 as rhsEq;
              Permutation.apply(Permutation.compose(Permutation.swap(a, c),
                    Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, c))), i)
                 = b by lhsEq
                 = Permutation.apply(Permutation.swap(c, b), i) by rhsEq;
              done
            }
          case i ≠ c as iNeqC: {
              i = b ∨ i ≠ b;
              done by cases {
                case i = b as iIsB: {
                    Permutation.apply(Permutation.compose(Permutation.swap(a, c),
                          Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, c))), i)
                       = Permutation.apply(Permutation.swap(a, c),
                             Permutation.apply(Permutation.swap(a, b),
                                 Permutation.apply(Permutation.swap(a, c), i)))
                             by Permutation.apply_compose
                       = Permutation.apply(Permutation.swap(a, c),
                             Permutation.apply(Permutation.swap(a, b),
                                 Permutation.apply(Permutation.swap(a, c), b)))
                             by substituting iIsB
                       = Permutation.apply(Permutation.swap(a, c),
                             Permutation.apply(Permutation.swap(a, b), b))
                             by substituting Permutation.apply_swap_other(a, c, b, bNeqA, bNeqC)
                       = Permutation.apply(Permutation.swap(a, c), a)
                             by substituting Permutation.apply_swap_right(a, b)
                       = c by Permutation.apply_swap_left(a, c)
                       as lhsEq;
                    Permutation.apply(Permutation.swap(c, b), i)
                       = Permutation.apply(Permutation.swap(c, b), b) by substituting iIsB
                       = c by Permutation.apply_swap_right(c, b)
                       as rhsEq;
                    Permutation.apply(Permutation.compose(Permutation.swap(a, c),
                          Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, c))), i)
                       = c by lhsEq
                       = Permutation.apply(Permutation.swap(c, b), i) by rhsEq;
                    done
                  }
                case i ≠ b as iNeqB: {
                    i = a ∨ i ≠ a;
                    done by cases {
                      case i = a as iIsA: {
                          Permutation.apply(Permutation.compose(Permutation.swap(a, c),
                                Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, c))), i)
                             = Permutation.apply(Permutation.swap(a, c),
                                   Permutation.apply(Permutation.swap(a, b),
                                       Permutation.apply(Permutation.swap(a, c), i)))
                                   by Permutation.apply_compose
                             = Permutation.apply(Permutation.swap(a, c),
                                   Permutation.apply(Permutation.swap(a, b),
                                       Permutation.apply(Permutation.swap(a, c), a)))
                                   by substituting iIsA
                             = Permutation.apply(Permutation.swap(a, c),
                                   Permutation.apply(Permutation.swap(a, b), c))
                                   by substituting Permutation.apply_swap_left(a, c)
                             = Permutation.apply(Permutation.swap(a, c), c)
                                   by substituting Permutation.apply_swap_other(a, b, c, cNeqA, cNeqB)
                             = a by Permutation.apply_swap_right(a, c)
                             as lhsEq;
                          Permutation.apply(Permutation.swap(c, b), i)
                             = Permutation.apply(Permutation.swap(c, b), a) by substituting iIsA
                             = a by Permutation.apply_swap_other(c, b, a, aNeqC, aNeqB)
                             as rhsEq;
                          Permutation.apply(Permutation.compose(Permutation.swap(a, c),
                                Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, c))), i)
                             = a by lhsEq
                             = Permutation.apply(Permutation.swap(c, b), i) by rhsEq;
                          done
                        }
                      case i ≠ a as iNeqA: {
                          Permutation.apply(Permutation.compose(Permutation.swap(a, c),
                                Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, c))), i)
                             = Permutation.apply(Permutation.swap(a, c),
                                   Permutation.apply(Permutation.swap(a, b),
                                       Permutation.apply(Permutation.swap(a, c), i)))
                                   by Permutation.apply_compose
                             = Permutation.apply(Permutation.swap(a, c),
                                   Permutation.apply(Permutation.swap(a, b), i))
                                   by substituting Permutation.apply_swap_other(a, c, i, iNeqA, iNeqC)
                             = Permutation.apply(Permutation.swap(a, c), i)
                                   by substituting Permutation.apply_swap_other(a, b, i, iNeqA, iNeqB)
                             = i by Permutation.apply_swap_other(a, c, i, iNeqA, iNeqC)
                             as lhsEq;
                          Permutation.apply(Permutation.swap(c, b), i)
                             = i by Permutation.apply_swap_other(c, b, i, iNeqC, iNeqB)
                             as rhsEq;
                          Permutation.apply(Permutation.compose(Permutation.swap(a, c),
                                Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, c))), i)
                             = i by lhsEq
                             = Permutation.apply(Permutation.swap(c, b), i) by rhsEq;
                          done
                        }
                    }
                  }
              }
            }
        }
      })
}

-- ----------------------------------------------------------------------
-- The base case: an adjacent transposition inverts exactly one ordered pair.

-- How a transposition moves the value of an index: to the partner's value at
-- the two swapped indices, unchanged elsewhere. (Stated by value, since a
-- value pins down the index.)
theorem Permutation.value_apply_swap_at_left {n : Natural} (a b x : NaturalsBelow(n))
        (atA : NaturalsBelow.value(x) = NaturalsBelow.value(a))
        : NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), x)) = NaturalsBelow.value(b) := {
  x = a by NaturalsBelow.equal_of_value(n, x, a, atA) as xIsA;
  NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), x))
     = NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), a)) by substituting xIsA
     = NaturalsBelow.value(b) by substituting Permutation.apply_swap_left(a, b);
  done
}

theorem Permutation.value_apply_swap_at_right {n : Natural} (a b x : NaturalsBelow(n))
        (atB : NaturalsBelow.value(x) = NaturalsBelow.value(b))
        : NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), x)) = NaturalsBelow.value(a) := {
  x = b by NaturalsBelow.equal_of_value(n, x, b, atB) as xIsB;
  NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), x))
     = NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), b)) by substituting xIsB
     = NaturalsBelow.value(a) by substituting Permutation.apply_swap_right(a, b);
  done
}

theorem Permutation.value_apply_swap_at_other {n : Natural} (a b x : NaturalsBelow(n))
        (offA : NaturalsBelow.value(x) ≠ NaturalsBelow.value(a))
        (offB : NaturalsBelow.value(x) ≠ NaturalsBelow.value(b))
        : NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), x)) = NaturalsBelow.value(x) := {
  x ≠ a by NaturalsBelow.ne_of_value_ne(x, a, offA) as xNeqA;
  x ≠ b by NaturalsBelow.ne_of_value_ne(x, b, offB) as xNeqB;
  NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), x))
     = NaturalsBelow.value(x) by substituting Permutation.apply_swap_other(a, b, x, xNeqA, xNeqB);
  done
}

-- From a strict inequality, the two sides differ.
theorem Natural.ne_of_lt (a b : Natural) (h : a < b) : a ≠ b :=
  (e : a = b) ↦ {
    a < a by { a < b by h = a by e; done };
    False by Natural.lt_irreflexive(a);
    done
  }

-- The heart of the base case: on any ordered pair OTHER than {a, b} itself, an
-- adjacent transposition preserves the value order, so its orientation is +1.
theorem Permutation.pairOrient_swap_adjacent_other {n : Natural} (a b : NaturalsBelow(n))
        (adjacent : NaturalsBelow.value(b) = 1 + NaturalsBelow.value(a))
        (p : Pair(NaturalsBelow(n), NaturalsBelow(n)))
        (memberP : List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), p, Permutation.orderedPairs(n)))
        (notThePair : p ≠ Product.make(a, b))
        : Permutation.pairOrient(Permutation.swap(a, b), p) = 1 :=
  by induction on p with pInduct {
    case Product.make(i, j): {
      1 + NaturalsBelow.value(a) = NaturalsBelow.value(b) by adjacent as adjacentBack;
      NaturalsBelow.value(i) < NaturalsBelow.value(j)
          by Permutation.orderedPairs_property(n, Product.make(i, j), memberP) as ordered;
      ¬(NaturalsBelow.value(i) = NaturalsBelow.value(a) ∧ NaturalsBelow.value(j) = NaturalsBelow.value(b))
          by {
            suppose NaturalsBelow.value(i) = NaturalsBelow.value(a)
                ∧ NaturalsBelow.value(j) = NaturalsBelow.value(b) for contradiction {
              NaturalsBelow.value(i) = NaturalsBelow.value(a) as iMatchA;
              NaturalsBelow.value(j) = NaturalsBelow.value(b) as jMatchB;
              i = a by NaturalsBelow.equal_of_value(n, i, a, iMatchA) as iIsAeq;
              j = b by NaturalsBelow.equal_of_value(n, j, b, jMatchB) as jIsBeq;
              Product.make(i, j) = Product.make(a, b)
                  by Product.make_equal(NaturalsBelow(n), NaturalsBelow(n), i, a, j, b, iIsAeq, jIsBeq);
              False by notThePair;
              done
            };
            done
          } as notBothMatch;
      NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), i))
          < NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), j))
          by {
            NaturalsBelow.value(i) = NaturalsBelow.value(a)
                ∨ NaturalsBelow.value(i) ≠ NaturalsBelow.value(a);
            done by cases {
              case NaturalsBelow.value(i) = NaturalsBelow.value(a) as iIsA: {
                  NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), i)) = NaturalsBelow.value(b)
                      by Permutation.value_apply_swap_at_left(a, b, i, iIsA) as swapI;
                  NaturalsBelow.value(a) < NaturalsBelow.value(j)
                      by { NaturalsBelow.value(a) = NaturalsBelow.value(i) by iIsA
                               < NaturalsBelow.value(j) by ordered; done } as aLtJ;
                  NaturalsBelow.value(j) ≠ NaturalsBelow.value(b) by {
                    suppose NaturalsBelow.value(j) = NaturalsBelow.value(b) for contradiction {
                      NaturalsBelow.value(i) = NaturalsBelow.value(a)
                          ∧ NaturalsBelow.value(j) = NaturalsBelow.value(b);
                      False by notBothMatch;
                      done
                    };
                    done
                  } as jNotB;
                  NaturalsBelow.value(j) ≠ NaturalsBelow.value(a)
                      by Equality.ne_symmetric(Natural, NaturalsBelow.value(a), NaturalsBelow.value(j),
                             Natural.ne_of_lt(NaturalsBelow.value(a), NaturalsBelow.value(j), aLtJ)) as jNotA;
                  NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), j)) = NaturalsBelow.value(j)
                      by Permutation.value_apply_swap_at_other(a, b, j, jNotA, jNotB) as swapJ;
                  1 + NaturalsBelow.value(a) ≤ NaturalsBelow.value(j)
                      by Natural.successor_le_of_lt(NaturalsBelow.value(a), NaturalsBelow.value(j), aLtJ)
                      as oneVaLeJ;
                  NaturalsBelow.value(j) ≠ 1 + NaturalsBelow.value(a) by substituting adjacentBack as jNotOneVa;
                  1 + NaturalsBelow.value(a) < NaturalsBelow.value(j)
                      by Natural.lt_of_le_of_ne(1 + NaturalsBelow.value(a), NaturalsBelow.value(j), oneVaLeJ,
                             Equality.ne_symmetric(Natural, NaturalsBelow.value(j), 1 + NaturalsBelow.value(a),
                                 jNotOneVa)) as oneVaLtJ;
                  NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), i))
                     = NaturalsBelow.value(b) by swapI
                     = 1 + NaturalsBelow.value(a) by adjacent
                     < NaturalsBelow.value(j) by oneVaLtJ
                     = NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), j)) by swapJ;
                  done
                }
              case NaturalsBelow.value(i) ≠ NaturalsBelow.value(a) as iNotA: {
                  NaturalsBelow.value(i) = NaturalsBelow.value(b)
                      ∨ NaturalsBelow.value(i) ≠ NaturalsBelow.value(b);
                  done by cases {
                    case NaturalsBelow.value(i) = NaturalsBelow.value(b) as iIsB: {
                        NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), i)) = NaturalsBelow.value(a)
                            by Permutation.value_apply_swap_at_right(a, b, i, iIsB) as swapI;
                        1 + NaturalsBelow.value(a) < NaturalsBelow.value(j)
                            by { 1 + NaturalsBelow.value(a) = NaturalsBelow.value(b) by adjacentBack
                                     = NaturalsBelow.value(i) by iIsB
                                     < NaturalsBelow.value(j) by ordered; done } as oneVaLtJ;
                        NaturalsBelow.value(a) < NaturalsBelow.value(j)
                            by { NaturalsBelow.value(a) < 1 + NaturalsBelow.value(a) by Natural.lt_one_plus
                                     < NaturalsBelow.value(j) by oneVaLtJ; done } as aLtJ;
                        NaturalsBelow.value(b) < NaturalsBelow.value(j)
                            by { NaturalsBelow.value(b) = 1 + NaturalsBelow.value(a) by adjacent
                                     < NaturalsBelow.value(j) by oneVaLtJ; done } as bLtJ;
                        NaturalsBelow.value(j) ≠ NaturalsBelow.value(a)
                            by Equality.ne_symmetric(Natural, NaturalsBelow.value(a), NaturalsBelow.value(j),
                                   Natural.ne_of_lt(NaturalsBelow.value(a), NaturalsBelow.value(j), aLtJ)) as jNotA;
                        NaturalsBelow.value(j) ≠ NaturalsBelow.value(b)
                            by Equality.ne_symmetric(Natural, NaturalsBelow.value(b), NaturalsBelow.value(j),
                                   Natural.ne_of_lt(NaturalsBelow.value(b), NaturalsBelow.value(j), bLtJ)) as jNotB;
                        NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), j)) = NaturalsBelow.value(j)
                            by Permutation.value_apply_swap_at_other(a, b, j, jNotA, jNotB) as swapJ;
                        NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), i))
                           = NaturalsBelow.value(a) by swapI
                           < NaturalsBelow.value(j) by aLtJ
                           = NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), j)) by swapJ;
                        done
                      }
                    case NaturalsBelow.value(i) ≠ NaturalsBelow.value(b) as iNotB: {
                        NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), i)) = NaturalsBelow.value(i)
                            by Permutation.value_apply_swap_at_other(a, b, i, iNotA, iNotB) as swapI;
                        NaturalsBelow.value(j) = NaturalsBelow.value(a)
                            ∨ NaturalsBelow.value(j) ≠ NaturalsBelow.value(a);
                        done by cases {
                          case NaturalsBelow.value(j) = NaturalsBelow.value(a) as jIsA: {
                              NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), j))
                                  = NaturalsBelow.value(b)
                                  by Permutation.value_apply_swap_at_left(a, b, j, jIsA) as swapJ;
                              NaturalsBelow.value(i) < NaturalsBelow.value(a)
                                  by { NaturalsBelow.value(i) < NaturalsBelow.value(j) by ordered
                                           = NaturalsBelow.value(a) by jIsA; done } as iLtA;
                              NaturalsBelow.value(a) < NaturalsBelow.value(b)
                                  by { NaturalsBelow.value(a) < 1 + NaturalsBelow.value(a) by Natural.lt_one_plus
                                           = NaturalsBelow.value(b) by adjacentBack; done } as aLtB;
                              NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), i))
                                 = NaturalsBelow.value(i) by swapI
                                 < NaturalsBelow.value(a) by iLtA
                                 < NaturalsBelow.value(b) by aLtB
                                 = NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), j)) by swapJ;
                              done
                            }
                          case NaturalsBelow.value(j) ≠ NaturalsBelow.value(a) as jNotA: {
                              NaturalsBelow.value(j) = NaturalsBelow.value(b)
                                  ∨ NaturalsBelow.value(j) ≠ NaturalsBelow.value(b);
                              done by cases {
                                case NaturalsBelow.value(j) = NaturalsBelow.value(b) as jIsB: {
                                    NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), j))
                                        = NaturalsBelow.value(a)
                                        by Permutation.value_apply_swap_at_right(a, b, j, jIsB) as swapJ;
                                    NaturalsBelow.value(i) < 1 + NaturalsBelow.value(a)
                                        by { NaturalsBelow.value(i) < NaturalsBelow.value(j) by ordered
                                                 = NaturalsBelow.value(b) by jIsB
                                                 = 1 + NaturalsBelow.value(a) by adjacent; done } as iLtOneVa;
                                    NaturalsBelow.value(i) ≤ NaturalsBelow.value(a)
                                        by Natural.le_of_lt_one_plus(NaturalsBelow.value(i), NaturalsBelow.value(a),
                                               iLtOneVa) as iLeA;
                                    NaturalsBelow.value(i) < NaturalsBelow.value(a)
                                        by Natural.lt_of_le_of_ne(NaturalsBelow.value(i), NaturalsBelow.value(a),
                                               iLeA, iNotA) as iLtA;
                                    NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), i))
                                       = NaturalsBelow.value(i) by swapI
                                       < NaturalsBelow.value(a) by iLtA
                                       = NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), j)) by swapJ;
                                    done
                                  }
                                case NaturalsBelow.value(j) ≠ NaturalsBelow.value(b) as jNotB: {
                                    NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), j))
                                        = NaturalsBelow.value(j)
                                        by Permutation.value_apply_swap_at_other(a, b, j, jNotA, jNotB) as swapJ;
                                    NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), i))
                                       = NaturalsBelow.value(i) by swapI
                                       < NaturalsBelow.value(j) by ordered
                                       = NaturalsBelow.value(Permutation.apply(Permutation.swap(a, b), j)) by swapJ;
                                    done
                                  }
                              }
                            }
                        }
                      }
                  }
                }
            }
          } as swapOrdered;
      Permutation.pairOrient(Permutation.swap(a, b), Product.make(i, j))
         = Permutation.orient(Permutation.apply(Permutation.swap(a, b), i),
               Permutation.apply(Permutation.swap(a, b), j))
         = 1 by Permutation.orient_forward(Permutation.apply(Permutation.swap(a, b), i),
                    Permutation.apply(Permutation.swap(a, b), j), swapOrdered);
      done
    }
  }

-- The base case itself: an adjacent transposition has sign −1. Its unique
-- inverted pair is {a, b} (orientation −1); every other pair keeps its order
-- (orientation +1), so the sign-product isolates the single −1.
theorem Permutation.sign_swap_adjacent {n : Natural} (a b : NaturalsBelow(n))
        (adjacent : NaturalsBelow.value(b) = 1 + NaturalsBelow.value(a))
        : Permutation.sign(Permutation.swap(a, b)) = Integer.negate(1) := {
  1 + NaturalsBelow.value(a) = NaturalsBelow.value(b) by adjacent as adjacentBack;
  NaturalsBelow.value(a) < NaturalsBelow.value(b)
      by { NaturalsBelow.value(a) < 1 + NaturalsBelow.value(a) by Natural.lt_one_plus
               = NaturalsBelow.value(b) by adjacentBack; done } as aLtB;
  ¬(NaturalsBelow.value(b) < NaturalsBelow.value(a))
      by Natural.lt_asymmetric(NaturalsBelow.value(a), NaturalsBelow.value(b), aLtB) as notBack;
  Permutation.sign(Permutation.swap(a, b))
     = List.product(Integer, Integer.multiply, Integer.one,
           List.map(Pair(NaturalsBelow(n), NaturalsBelow(n)), Integer,
               Permutation.pairOrient(Permutation.swap(a, b)), Permutation.orderedPairs(n)))
     = Permutation.pairOrient(Permutation.swap(a, b), Product.make(a, b))
           by List.product_isolate_single(Pair(NaturalsBelow(n), NaturalsBelow(n)),
                  Permutation.pairOrient(Permutation.swap(a, b)), Product.make(a, b),
                  Permutation.orderedPairs(n), Permutation.orderedPairs_distinct(n),
                  Permutation.orderedPairs_member(n, a, b, aLtB),
                  (p : Pair(NaturalsBelow(n), NaturalsBelow(n)))
                      (memberP : List.member(Pair(NaturalsBelow(n), NaturalsBelow(n)), p,
                          Permutation.orderedPairs(n)))
                      (notThePair : p ≠ Product.make(a, b)) ↦
                      Permutation.pairOrient_swap_adjacent_other(a, b, adjacent, p, memberP, notThePair))
     = Permutation.orient(Permutation.apply(Permutation.swap(a, b), a),
           Permutation.apply(Permutation.swap(a, b), b))
     = Permutation.orient(b, Permutation.apply(Permutation.swap(a, b), b))
           by substituting Permutation.apply_swap_left(a, b)
     = Permutation.orient(b, a) by substituting Permutation.apply_swap_right(a, b)
     = Integer.negate(1) by Permutation.orient_backward(b, a, notBack);
  done
}

-- ----------------------------------------------------------------------
-- The distance induction and the general result.

-- A transposition is symmetric in its two indices.
theorem Permutation.swap_symmetric {n : Natural} (a b : NaturalsBelow(n))
        : Permutation.swap(a, b) = Permutation.swap(b, a) :=
  Permutation.equal_of_apply_equal(Permutation.swap(a, b), Permutation.swap(b, a),
      (i : NaturalsBelow(n)) ↦ {
        i = a ∨ i ≠ a;
        done by cases {
          case i = a as iIsA:
              Permutation.apply(Permutation.swap(a, b), i)
                 = Permutation.apply(Permutation.swap(a, b), a) by substituting iIsA
                 = b by Permutation.apply_swap_left(a, b)
                 = Permutation.apply(Permutation.swap(b, a), a) by Permutation.apply_swap_right(b, a)
                 = Permutation.apply(Permutation.swap(b, a), i) by substituting iIsA
          case i ≠ a as iNeqA: {
              i = b ∨ i ≠ b;
              done by cases {
                case i = b as iIsB:
                    Permutation.apply(Permutation.swap(a, b), i)
                       = Permutation.apply(Permutation.swap(a, b), b) by substituting iIsB
                       = a by Permutation.apply_swap_right(a, b)
                       = Permutation.apply(Permutation.swap(b, a), b) by Permutation.apply_swap_left(b, a)
                       = Permutation.apply(Permutation.swap(b, a), i) by substituting iIsB
                case i ≠ b as iNeqB:
                    Permutation.apply(Permutation.swap(a, b), i)
                       = i by Permutation.apply_swap_other(a, b, i, iNeqA, iNeqB)
                       = Permutation.apply(Permutation.swap(b, a), i)
                             by Permutation.apply_swap_other(b, a, i, iNeqB, iNeqA)
              }
            }
        }
      })

-- Distance induction: a transposition whose indices differ in value by 1 + d
-- has sign −1. The step conjugates by an adjacent transposition (swap(a, c)
-- with value(c) = value(a) + 1) to reach one of distance d.
theorem Permutation.sign_swap_gap (n : Natural) (d : Natural)
        : ∀ (a b : NaturalsBelow(n)).
              NaturalsBelow.value(b) = (1 + d) + NaturalsBelow.value(a)
              → Permutation.sign(Permutation.swap(a, b)) = Integer.negate(1) :=
  by induction on d with IH {
    case base:
        (a b : NaturalsBelow(n))
        (gapHyp : NaturalsBelow.value(b) = (1 + 0) + NaturalsBelow.value(a)) ↦ {
          NaturalsBelow.value(b) = 1 + NaturalsBelow.value(a) by gapHyp as adjacentEq;
          done by Permutation.sign_swap_adjacent(a, b, adjacentEq)
        }
    case step(dPred):
        (a b : NaturalsBelow(n))
        (gapHyp : NaturalsBelow.value(b) = (1 + (1 + dPred)) + NaturalsBelow.value(a)) ↦ {
          1 + NaturalsBelow.value(a) < NaturalsBelow.value(b) by {
            NaturalsBelow.value(b) = (1 + (1 + dPred)) + NaturalsBelow.value(a) by gapHyp
               = NaturalsBelow.value(a) + (1 + (1 + dPred)) by ring as vbEq;
            1 + NaturalsBelow.value(a) = NaturalsBelow.value(a) + 1 by ring
               < NaturalsBelow.value(a) + (1 + (1 + dPred))
                     by Natural.add_left_strict_monotone(NaturalsBelow.value(a), 1, 1 + (1 + dPred),
                            Natural.lt_add_of_one_le(1, 1 + dPred,
                                Natural.add_left_monotone(1, 0, dPred, Natural.zero_least(dPred))))
               = NaturalsBelow.value(b) by vbEq;
            done
          } as cBoundLtB;
          NaturalsBelow.value(b) < n by NaturalsBelow.below as bBelow;
          1 + NaturalsBelow.value(a) < n by {
            1 + NaturalsBelow.value(a) < NaturalsBelow.value(b) by cBoundLtB < n by bBelow; done
          } as cBound;
          let c : NaturalsBelow(n) := NaturalsBelow.make(1 + NaturalsBelow.value(a), cBound);
          NaturalsBelow.value(c) = 1 + NaturalsBelow.value(a) as valueC;
          NaturalsBelow.value(a) < NaturalsBelow.value(b) by {
            NaturalsBelow.value(a) < 1 + NaturalsBelow.value(a) by Natural.lt_one_plus
               < NaturalsBelow.value(b) by cBoundLtB; done
          } as aLtB;
          b ≠ a by NaturalsBelow.ne_of_value_ne(b, a,
              Equality.ne_symmetric(Natural, NaturalsBelow.value(a), NaturalsBelow.value(b),
                  Natural.ne_of_lt(NaturalsBelow.value(a), NaturalsBelow.value(b), aLtB))) as bNeqA;
          NaturalsBelow.value(b) ≠ NaturalsBelow.value(c) by {
            NaturalsBelow.value(c) = 1 + NaturalsBelow.value(a) by valueC;
            NaturalsBelow.value(b) ≠ 1 + NaturalsBelow.value(a)
                by Equality.ne_symmetric(Natural, 1 + NaturalsBelow.value(a), NaturalsBelow.value(b),
                       Natural.ne_of_lt(1 + NaturalsBelow.value(a), NaturalsBelow.value(b), cBoundLtB));
            done by substituting valueC
          } as bValueNeqC;
          b ≠ c by NaturalsBelow.ne_of_value_ne(b, c, bValueNeqC) as bNeqC;
          NaturalsBelow.value(a) ≠ NaturalsBelow.value(c) by {
            NaturalsBelow.value(a) ≠ 1 + NaturalsBelow.value(a)
                by Natural.ne_of_lt(NaturalsBelow.value(a), 1 + NaturalsBelow.value(a), Natural.lt_one_plus);
            done by substituting valueC
          } as aValueNeqC;
          a ≠ c by NaturalsBelow.ne_of_value_ne(a, c, aValueNeqC) as aNeqC;
          NaturalsBelow.value(b) = (1 + dPred) + NaturalsBelow.value(c) by {
            NaturalsBelow.value(b) = (1 + (1 + dPred)) + NaturalsBelow.value(a) by gapHyp
               = (1 + dPred) + (1 + NaturalsBelow.value(a)) by ring
               = (1 + dPred) + NaturalsBelow.value(c) by substituting valueC;
            done
          } as gapCB;
          Permutation.sign(Permutation.swap(c, b)) = Integer.negate(1) by IH(c, b, gapCB) as signCB;
          Permutation.swap(c, b)
              = Permutation.compose(Permutation.swap(a, c),
                    Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, c)))
              by Equality.symmetry(Permutation(n),
                     Permutation.compose(Permutation.swap(a, c),
                         Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, c))),
                     Permutation.swap(c, b),
                     Permutation.swap_conjugate_by_swap(a, b, c, aNeqC, bNeqA, bNeqC)) as identBack;
          Permutation.sign(Permutation.swap(c, b))
             = Permutation.sign(Permutation.compose(Permutation.swap(a, c),
                   Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, c))))
                   by substituting identBack
             = Permutation.sign(Permutation.swap(a, c))
                   * Permutation.sign(Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, c)))
                   by Permutation.sign_compose(Permutation.swap(a, c),
                          Permutation.compose(Permutation.swap(a, b), Permutation.swap(a, c)))
             = Permutation.sign(Permutation.swap(a, c))
                   * (Permutation.sign(Permutation.swap(a, b)) * Permutation.sign(Permutation.swap(a, c)))
                   by substituting Permutation.sign_compose(Permutation.swap(a, b), Permutation.swap(a, c))
             = Permutation.sign(Permutation.swap(a, b))
                   * (Permutation.sign(Permutation.swap(a, c)) * Permutation.sign(Permutation.swap(a, c)))
                   by ring
             = Permutation.sign(Permutation.swap(a, b)) * Integer.one
                   by substituting Permutation.sign_swap_square(a, c)
             = Permutation.sign(Permutation.swap(a, b)) by ring
             as signCBeqAB;
          Permutation.sign(Permutation.swap(a, b))
             = Permutation.sign(Permutation.swap(c, b)) by signCBeqAB
             = Integer.negate(1) by signCB;
          done
        }
  }

-- A transposition of distinct indices is odd: its sign is −1.
theorem Permutation.sign_swap {n : Natural} (a b : NaturalsBelow(n)) (distinct : a ≠ b)
        : Permutation.sign(Permutation.swap(a, b)) = Integer.negate(1) := {
  NaturalsBelow.value(a) ≠ NaturalsBelow.value(b) by {
    suppose NaturalsBelow.value(a) = NaturalsBelow.value(b) for contradiction {
      NaturalsBelow.value(a) = NaturalsBelow.value(b) as valuesEq;
      a = b by NaturalsBelow.equal_of_value(n, a, b, valuesEq);
      False by distinct;
      done
    };
    done
  } as valuesNe;
  NaturalsBelow.value(a) < NaturalsBelow.value(b) ∨ NaturalsBelow.value(b) < NaturalsBelow.value(a)
      by Natural.lt_or_gt_of_ne(NaturalsBelow.value(a), NaturalsBelow.value(b), valuesNe);
  done by cases {
    case NaturalsBelow.value(a) < NaturalsBelow.value(b) as aLtB: {
        choose d such that NaturalsBelow.value(a) + (1 + d) = NaturalsBelow.value(b)
            from Natural.lt_elim;
        NaturalsBelow.value(a) + (1 + d) = NaturalsBelow.value(b) as gapEq;
        NaturalsBelow.value(b) = (1 + d) + NaturalsBelow.value(a) by {
          NaturalsBelow.value(b) = NaturalsBelow.value(a) + (1 + d) by gapEq
             = (1 + d) + NaturalsBelow.value(a) by ring;
          done
        } as gapHyp;
        done by Permutation.sign_swap_gap(n, d, a, b, gapHyp)
      }
    case NaturalsBelow.value(b) < NaturalsBelow.value(a) as bLtA: {
        choose d such that NaturalsBelow.value(b) + (1 + d) = NaturalsBelow.value(a)
            from Natural.lt_elim;
        NaturalsBelow.value(b) + (1 + d) = NaturalsBelow.value(a) as gapEq;
        NaturalsBelow.value(a) = (1 + d) + NaturalsBelow.value(b) by {
          NaturalsBelow.value(a) = NaturalsBelow.value(b) + (1 + d) by gapEq
             = (1 + d) + NaturalsBelow.value(b) by ring;
          done
        } as gapHyp;
        Permutation.sign(Permutation.swap(b, a)) = Integer.negate(1)
            by Permutation.sign_swap_gap(n, d, b, a, gapHyp) as signBA;
        Permutation.sign(Permutation.swap(a, b))
           = Permutation.sign(Permutation.swap(b, a)) by substituting Permutation.swap_symmetric(a, b)
           = Integer.negate(1) by signBA;
        done
      }
  }
}

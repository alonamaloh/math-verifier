-- Algebra/rank_four_weighted_d4_both_unit_covers.math
--
-- The thirteen selected forms x²+2y²+4z²+2yw+2zw+cw², 2 ≤ c ≤ 14.

module Algebra.rank_four_weighted_d4_both_unit_covers

import Algebra.rank_four_weighted_d4_odd_cosets

theorem Matrix.weightedD4BothUnit_universal_selected_core_of_converse
        (converse : Matrix.OneTwoFourConverse)
        (corner coefficient shift core quarter : ℕ)
        (coefficientReads : (coefficient : ℤ) = 4 * (corner : ℤ) - 3)
        (completionReads : 16 * shift + core + coefficient = 56)
        (coreReads : core = 4 * quarter + 3) (coreBelow : core < 16) (coreNotFourteen : core ≠ 14)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(
            4, 1, 1, (corner : ℤ))) :=
  by Matrix.weightedD4_universal_of_base_coset(
      converse, secondResidue := 1, thirdResidue := 1, corner := corner,
      coefficient := coefficient, shift := shift, core := core,
      coefficientReads := {
        (coefficient : ℤ)
           = 4 * (corner : ℤ) - 3 by coefficientReads
           = 4 * (corner : ℤ) - 2 * (1 : ℤ) * (1 : ℤ) - (1 : ℤ) * (1 : ℤ) by ring
      },
      completionReads := completionReads,
      baseControl := Matrix.oneTwoFour_one_one_base_coset_of_converse(
          converse, core, quarter, coreReads,
          coreAdmissible := (b : ℕ) ↦
            Natural.sixteen_plus_nonzero_mod_four_core_not_one_three_six_four_obstruction(
                b, core, quarter, 3, coreReads, done, done, coreBelow, coreNotFourteen)))

theorem Matrix.weightedD4S1R1C2_universal_of_one_two_four_converse (converse : Matrix.OneTwoFourConverse)
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(4, 1, 1, 2)) :=
  by Matrix.weightedD4BothUnit_universal_selected_core_of_converse(
      converse, corner := 2, coefficient := 5, shift := 3, core := 3, quarter := 0,
      coefficientReads := done, completionReads := done, coreReads := done, coreBelow := done, coreNotFourteen := done)


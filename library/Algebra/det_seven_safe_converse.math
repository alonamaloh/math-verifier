-- Algebra/det_seven_safe_converse.math
--
-- The exact determinant-seven ternary input used by the final seven
-- rank-four covers.  This is deliberately a one-way, conservative
-- interface: multiples of 49 are rejected even when the ternary form
-- may represent them.

module Algebra.det_seven_safe_converse

import Natural.floor_divide
import Algebra.rank_three_orbits

definition Natural.IsDetSevenSafe (n : ℕ) : Proposition :=
  Natural.modulo(n, 12) ≠ 7
  ∧ Natural.modulo(n, 12) ≠ 10
  ∧ Natural.modulo(n, 49) ≠ 0
  ∧ Natural.modulo(n, 49) ≠ 21
  ∧ Natural.modulo(n, 49) ≠ 35
  ∧ Natural.modulo(n, 49) ≠ 42

definition Matrix.DetSevenSafeConverse : Proposition :=
  ∀ (n : ℕ). n ≥ 1 → Natural.IsDetSevenSafe(n) →
    Matrix.Represents(Matrix.squarePlusDoubleSquareOddForm(4), (n : ℤ))

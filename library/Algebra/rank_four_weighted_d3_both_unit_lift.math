-- Algebra/rank_four_weighted_d3_both_unit_lift.math
--
-- Recover the two completed coordinates and lift a 2u²+3v²+6x²
-- residual cover to the original quaternary form.

module Algebra.rank_four_weighted_d3_both_unit_lift

import Algebra.rank_four_weighted_d3_both_unit_foundation

theorem Matrix.weightedD3BothUnit_universal_of_cover
        (corner : ℕ) (coefficientReads : ((6 * corner ∸ 5 : ℕ) : ℤ) = 6 * (corner : ℤ) - 5)
        (cover : Matrix.TwoThreeSixSextupleTargetCover(corner))
        : Matrix.IsUniversal(Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 1, 1, (corner : ℤ))) := {
  take m : ℕ;
  suppose m ≥ 1 as positive;
  choose residual : ℕ, w : ℕ such that
      Integer.TwoThreeSixRepresentation((residual : ℤ))
      ∧ residual + w * w * (6 * corner ∸ 5) = 6 * m
      as covered from cover(m, positive);
  Integer.TwoThreeSixRepresentation((residual : ℤ))
      by And.left(
          Integer.TwoThreeSixRepresentation((residual : ℤ)),
          residual + w * w * (6 * corner ∸ 5) = 6 * m, covered)
      as residualRepresented;
  residual + w * w * (6 * corner ∸ 5) = 6 * m
      by And.right(
          Integer.TwoThreeSixRepresentation((residual : ℤ)),
          residual + w * w * (6 * corner ∸ 5) = 6 * m, covered)
      as naturalCompletedReads;
  choose u : ℤ such that ∃ (v x : ℤ). 2 * (u * u) + 3 * (v * v) + 6 * (x * x) = (residual : ℤ)
      from residualRepresented;
  choose v : ℤ such that ∃ (x : ℤ). 2 * (u * u) + 3 * (v * v) + 6 * (x * x) = (residual : ℤ);
  choose x : ℤ such that 2 * (u * u) + 3 * (v * v) + 6 * (x * x) = (residual : ℤ) as residualReads;
  let wz : ℤ := w;
  wz = (w : ℤ) by reflexivity(ℤ, wz) as wzReads;
  (residual : ℤ) + wz * wz * ((6 * corner ∸ 5 : ℕ) : ℤ)
     = ((residual + w * w * (6 * corner ∸ 5) : ℕ) : ℤ) by {
          ((residual + w * w * (6 * corner ∸ 5) : ℕ) : ℤ)
             = (residual : ℤ) + ((w * w * (6 * corner ∸ 5) : ℕ) : ℤ)
                 by Natural.to_integer.add_preserves
             = (residual : ℤ) + ((w * w : ℕ) : ℤ) * ((6 * corner ∸ 5 : ℕ) : ℤ)
                 by substituting Natural.to_integer.multiply_preserves(w * w, 6 * corner ∸ 5)
             = (residual : ℤ) + (w : ℤ) * (w : ℤ) * ((6 * corner ∸ 5 : ℕ) : ℤ)
                 by substituting Natural.to_integer.multiply_preserves(w, w);
          (residual : ℤ) + (w : ℤ) * (w : ℤ) * ((6 * corner ∸ 5 : ℕ) : ℤ)
             = (residual : ℤ) + wz * wz * ((6 * corner ∸ 5 : ℕ) : ℤ)
                 by substituting Equality.symmetry(wzReads);
          done
        }
     = ((6 * m : ℕ) : ℤ) by substituting naturalCompletedReads
     = 6 * (m : ℤ) by Natural.to_integer.multiply_preserves
  as castCompletedReads;
  2 * (u * u) + 3 * (v * v) + 6 * (x * x) + (6 * (corner : ℤ) - 5) * (wz * wz)
     = (residual : ℤ) + (6 * (corner : ℤ) - 5) * (wz * wz) by substituting residualReads
     = (residual : ℤ) + ((6 * corner ∸ 5 : ℕ) : ℤ) * (wz * wz)
         by substituting Equality.symmetry(coefficientReads)
     = (residual : ℤ) + wz * wz * ((6 * corner ∸ 5 : ℕ) : ℤ) by ring
     = 6 * (m : ℤ) by castCompletedReads
  as completedReads;
  Integer.divides(2, v - wz)
      by Integer.weightedD3_both_unit_parity_compatible(
          u, v, x, wz, (m : ℤ), (corner : ℤ), completedReads)
      as parityCompatible;
  choose y : ℤ such that v - wz = 2 * y as differenceReads from parityCompatible;
  v = 2 * y + wz by linear_combination(differenceReads) as vReads;
  Integer.divides(3, u * u - wz * wz)
      by Integer.weightedD3_both_unit_mod_three_compatible(
          u, v, x, wz, (m : ℤ), (corner : ℤ), completedReads)
      as squareDifferenceDivisible;
  choose signedU : ℤ, z : ℤ such that
      (signedU = u ∨ signedU = -u) ∧ signedU = 3 * z + wz
      as signed from Integer.choose_sign_congruent_mod_three(u, wz, squareDifferenceDivisible);
  signedU = u ∨ signedU = -u
      by And.left(signedU = u ∨ signedU = -u, signedU = 3 * z + wz, signed) as signReads;
  signedU = 3 * z + wz
      by And.right(signedU = u ∨ signedU = -u, signedU = 3 * z + wz, signed) as signedUReads;
  signedU * signedU = u * u by Or.eliminate(
      signedU = u, signedU = -u, signedU * signedU = u * u,
      (sameSign : signedU = u) ↦ { signedU * signedU = u * u by substituting sameSign; done },
      (oppositeSign : signedU = -u) ↦ {
        signedU * signedU = (-u) * (-u) by substituting oppositeSign = u * u by ring;
        done
      },
      signReads)
  as squareReads;
  6 * (x * x + 2 * (y * y) + 3 * (z * z) + 2 * y * wz + 2 * z * wz + (corner : ℤ) * (wz * wz))
     = 2 * ((3 * z + wz) * (3 * z + wz)) + 3 * ((2 * y + wz) * (2 * y + wz)) + 6 * (x * x)
       + (6 * (corner : ℤ) - 5) * (wz * wz) by ring
     = 2 * (signedU * signedU) + 3 * ((2 * y + wz) * (2 * y + wz)) + 6 * (x * x)
       + (6 * (corner : ℤ) - 5) * (wz * wz) by substituting Equality.symmetry(signedUReads)
     = 2 * (u * u) + 3 * ((2 * y + wz) * (2 * y + wz)) + 6 * (x * x)
       + (6 * (corner : ℤ) - 5) * (wz * wz) by substituting squareReads
     = 2 * (u * u) + 3 * (v * v) + 6 * (x * x) + (6 * (corner : ℤ) - 5) * (wz * wz)
         by substituting Equality.symmetry(vReads)
     = 6 * (m : ℤ) by completedReads
  as sextupledScalarReads;
  (6 : ℤ) ≠ 0 as sixNonzero;
  x * x + 2 * (y * y) + 3 * (z * z) + 2 * y * wz + 2 * z * wz + (corner : ℤ) * (wz * wz) = (m : ℤ)
      by Integer.multiply_cancel_left_by_nonzero(
          x * x + 2 * (y * y) + 3 * (z * z) + 2 * y * wz + 2 * z * wz + (corner : ℤ) * (wz * wz),
          (m : ℤ), 6, sixNonzero, sextupledScalarReads)
      as scalarCore;
  x * x + 2 * (y * y) + 3 * (z * z) + 2 * 1 * y * wz + 2 * 1 * z * wz + (corner : ℤ) * (wz * wz)
     = x * x + 2 * (y * y) + 3 * (z * z) + 2 * y * wz + 2 * z * wz + (corner : ℤ) * (wz * wz) by ring
     = (m : ℤ) by scalarCore
  as scalarComputation;
  done by Matrix.represents_by_witness(
      Matrix.squarePlusDoublePlusScaledRankFourRepresentative(3, 1, 1, (corner : ℤ)),
      target := m, vector := ⟨x, y, z, wz⟩,
      computes := Matrix.squarePlusDoublePlusScaledRankFourRepresentative_coordinateTuple_computes(
          scalarComputation := scalarComputation))
}

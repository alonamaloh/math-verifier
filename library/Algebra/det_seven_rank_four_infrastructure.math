        (residual t : ℤ)
        (represented : Matrix.Represents(Matrix.squarePlusDoubleSquareOddForm(4), residual))
        : Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 10),

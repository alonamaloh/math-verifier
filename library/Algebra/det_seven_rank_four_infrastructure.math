        (residual t : ℤ)
        (represented : Matrix.Represents(Matrix.squarePlusDoubleSquareOddForm(4), residual))
        : Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 2, 8),
            residual + 280 * (t * t)) :=
  by Matrix.detSeven_nonzero_residue_orthogonal_lift_with_norm(

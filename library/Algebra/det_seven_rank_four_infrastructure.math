theorem Matrix.oddC4R3C11_orthogonal_lift
        (residual t : ℤ)
        (represented : Matrix.Represents(Matrix.squarePlusDoubleSquareOddForm(4), residual))
        : Matrix.Represents(
            Matrix.squarePlusDoubleSquareOddRankFourRepresentative(4, 3, 11),

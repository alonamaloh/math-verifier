-- Integer/cancellation.math
--
-- Multiplicative cancellation on Integer when the multiplier is a
-- positive natural lifted to Integer:
--     x · to_integer(c) = y · to_integer(c)  →  x = y     (for c ≥ 1)
-- The proof descends through `Quotient.equal_implies_equivalent` to recover the underlying
-- cross-equation at the multiplied representatives, factors `c` out of each
-- side (by `ring`), applies the Natural-level cancellation, and reassembles
-- the class equality. This is the step the original Rational plan needed and
-- couldn't get.

module Integer.cancellation

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.extensionality
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.cancellation
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding

-- ----------------------------------------------------------------------
-- Natural-level kernel of the cancellation argument. Given the
-- equivalence relation between the two multiplied representatives,
-- conclude the equivalence between the original representatives.
-- The proof simplifies the multiplied-out equation to one factor of
-- `c` on each side, then cancels the positive factor.

theorem Integer.cancellation_natural
        (p1 q1 p2 q2 c : Natural) (positive : 1 ≤ c)
        (equivalenceAfterMultiply
            : (p1 * c + q1 * 0)
              + (p2 * 0 + q2 * c)
              = (p1 * 0 + q1 * c)
                + (p2 * c + q2 * 0))
        : p1 + q2 = q1 + p2 := {
    -- Each side is `c` times a sum; they agree by the multiplied
    -- hypothesis, so cancelling the positive `c` gives the result.
    calc (p1 + q2) * c
       = (p1 * c + q1 * 0) + (p2 * 0 + q2 * c)
       = (p1 * 0 + q1 * c) + (p2 * c + q2 * 0)   since equivalenceAfterMultiply
       = (q1 + p2) * c;
    done since Natural.multiply_cancel_right
}

-- ----------------------------------------------------------------------
-- At representatives: destructure both, recover the Natural-level
-- equivalence from the multiplied equality via Quotient.equal_implies_equivalent, then
-- hand it to the Natural-level cancellation kernel.

theorem Integer.multiply_cancel_right_at_representatives
        (c : Natural) (positive : 1 ≤ c)
        : ∀ (representativeX representativeY : IntegerRepresentative).
            Integer.multiply(
                    Quotient.class_of(representativeX),
                    (c : Integer))
            = Integer.multiply(
                    Quotient.class_of(representativeY),
                    (c : Integer))
          → (Quotient.class_of(representativeX) : Integer)
            = Quotient.class_of(representativeY)
  | IntegerRepresentative.make(p1, q1),
    IntegerRepresentative.make(p2, q2),
    multipliedEquality => {
      -- `multipliedEquality` says the two multiplied difference classes are
      -- equal; `Quotient.equal_implies_equivalent` recovers their equivalence, which (the
      -- equivalence being transparent) IS the cross-equation. The explicit
      -- `Quotient.equal_implies_equivalent` (with `unfold Integer`) is required here: the opaque
      -- `Integer` boundary blocks the bare-claim exact-bridge's WHNF match.
      claim (p1 * c + q1 * 0) + (p2 * 0 + q2 * c)
              = (p1 * 0 + q1 * c) + (p2 * c + q2 * 0)
          by Quotient.equal_implies_equivalent(
                 IntegerRepresentative.make(
                     p1 * c + q1 * 0,
                     p1 * 0 + q1 * c),
                 IntegerRepresentative.make(
                     p2 * c + q2 * 0,
                     p2 * 0 + q2 * c),
                 unfold Integer in multipliedEquality);
      -- The cancellation kernel extracts `p1 + q2 = q1 + p2`, which IS the
      -- class equality the goal asks for (the equivalence is transparent).
      claim naturalEquation : p1 + q2 = q1 + p2 since Integer.cancellation_natural;
      naturalEquation
  }

-- ----------------------------------------------------------------------
-- Main theorem: lift the at-representatives version through
-- Quotient.induct_two so it applies to any Integer x and y.

theorem Integer.multiply_cancel_right_by_positive_natural
        (x y : Integer) (c : Natural) (positive : 1 ≤ c)
        (productEquality
            : x * (c : Integer) = y * (c : Integer))
        : x = y :=
  cases x refining productEquality { | representativeX =>
    cases y refining productEquality { | representativeY =>
      done since Integer.multiply_cancel_right_at_representatives } }

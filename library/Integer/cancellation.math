-- Integer/cancellation.math
--
-- Multiplicative cancellation on Integer when the multiplier is a
-- positive natural lifted to Integer:
--     x · to_integer(succ(k)) = y · to_integer(succ(k))  →  x = y
-- The proof descends through `Quotient.exact` (newly available from
-- propositional extensionality) to recover the underlying
-- `IntegerEquivalent` at the multiplied representatives, simplifies
-- away the `_·0` and `0+_` noise that the kernel can't reduce
-- structurally, factors out `succ(k)`, applies the Natural-level
-- cancellation, and reassembles via `Quotient.sound`. This is the
-- step that the original Rational plan needed and couldn't get.

module Integer.cancellation

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.extensionality
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.cancellation
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding

-- ----------------------------------------------------------------------
-- Natural-level kernel of the cancellation argument. Given the
-- equivalence relation between the two multiplied representatives,
-- conclude the equivalence between the original representatives.
-- The proof simplifies the multiplied-out equation to one factor of
-- `succ(k)` on each side, then cancels.

theorem Integer.cancellation_natural
        (p1 q1 p2 q2 k : Natural)
        (equivalenceAfterMultiply
            : (p1 * successor(k) + q1 * 0)
              + (p2 * 0 + q2 * successor(k))
              = (p1 * 0 + q1 * successor(k))
                + (p2 * successor(k) + q2 * 0))
        : p1 + q2 = q1 + p2 := {
    -- Simplify zeros on each side, then factor succ(k).
    calc (p1 * successor(k) + q1 * 0)
            + (p2 * 0 + q2 * successor(k))
       = (p1 * successor(k) + 0)
           + (p2 * 0 + q2 * successor(k))
       = (p1 * successor(k) + 0)
           + (0 + q2 * successor(k))
       = p1 * successor(k) + (0 + q2 * successor(k))
       = p1 * successor(k) + q2 * successor(k)
       = (p1 + q2) * successor(k);
    calc (p1 * 0 + q1 * successor(k))
            + (p2 * successor(k) + q2 * 0)
       = (0 + q1 * successor(k))
           + (p2 * successor(k) + q2 * 0)
       = (0 + q1 * successor(k))
           + (p2 * successor(k) + 0)
       = q1 * successor(k) + (p2 * successor(k) + 0)
       = q1 * successor(k) + p2 * successor(k)
       = (q1 + p2) * successor(k);
    calc (p1 + q2) * successor(k)
       = (p1 * successor(k) + q1 * 0)
           + (p2 * 0 + q2 * successor(k))
       = (p1 * 0 + q1 * successor(k))
           + (p2 * successor(k) + q2 * 0)
       = (q1 + p2) * successor(k);
    claim 1 ≤ successor(k) by Natural.successor_positive;
    -- Cancel the positive factor successor(k) from both sides.
    done by Natural.multiply_cancel_right
}

-- ----------------------------------------------------------------------
-- At representatives: destructure both, recover the Natural-level
-- equivalence from the multiplied equality via Quotient.exact, then
-- hand it to the Natural-level cancellation kernel.

theorem Integer.multiply_cancel_right_at_representatives
        (k : Natural)
        : ∀ (representativeX representativeY : IntegerRepresentative).
            Integer.multiply(
                    Quotient.mk(representativeX),
                    (successor(k) : Integer))
            = Integer.multiply(
                    Quotient.mk(representativeY),
                    (successor(k) : Integer))
          → (Quotient.mk(representativeX) : Integer)
            = Quotient.mk(representativeY)
  | IntegerRepresentative.make(p1, q1),
    IntegerRepresentative.make(p2, q2),
    multipliedEquality => {
      -- `multipliedEquality` says the two multiplied difference classes are
      -- equal; `Quotient.exact` recovers their equivalence and `to_natural`
      -- reads it back as the cross-equation. The explicit `Quotient.exact`
      -- (with `unfold Integer`) is required here: the opaque `Integer`
      -- boundary blocks the bare-claim exact-bridge's WHNF match.
      claim (p1 * successor(k) + q1 * 0) + (p2 * 0 + q2 * successor(k))
              = (p1 * 0 + q1 * successor(k)) + (p2 * successor(k) + q2 * 0)
          by IntegerEquivalent.to_natural(
                 Quotient.exact(
                     IntegerRepresentative.make(
                         p1 * successor(k) + q1 * 0,
                         p1 * 0 + q1 * successor(k)),
                     IntegerRepresentative.make(
                         p2 * successor(k) + q2 * 0,
                         p2 * 0 + q2 * successor(k)),
                     unfold Integer in multipliedEquality));
      -- The cancellation kernel extracts `p1 + q2 = q1 + p2`; `from_natural`
      -- bridges that back to the class equality the goal asks for.
      claim naturalEquation : p1 + q2 = q1 + p2 by Integer.cancellation_natural;
      IntegerEquivalent.from_natural(naturalEquation)
  }

-- ----------------------------------------------------------------------
-- Main theorem: lift the at-representatives version through
-- Quotient.induct_two so it applies to any Integer x and y.

theorem Integer.multiply_cancel_right_by_natural_successor
        (x y : Integer) (k : Natural)
        (productEquality
            : x * (successor(k) : Integer) = y * (successor(k) : Integer))
        : x = y :=
  cases x refining productEquality { | representativeX =>
    cases y refining productEquality { | representativeY =>
      done by Integer.multiply_cancel_right_at_representatives } }

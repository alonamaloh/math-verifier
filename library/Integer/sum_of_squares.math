-- Integer/sum_of_squares.math
--
-- Integer-square bridges and small-square classifications. A square is
-- non-negative (it is the image of a Natural square); this proves both that
-- a² + b² = 0 forces a = b = 0 and that small bounds leave finite root sets.

module Integer.sum_of_squares

import Logic.basics
import Logic.exists
import Logic.product
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.cancellation
import Natural.order
import Natural.multiply_bounds
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.embedding
import Integer.order
import Integer.sign
import Algebra.integer_domain

-- The Natural embedding is injective at 0: (m : ℤ) = 0 ⟹ m = 0.
theorem Natural.to_integer.eq_zero_implies (m : ℕ)
        (imageZero : Natural.to_integer(m) = Integer.zero) : m = 0 :=
  -- `(m : ℤ) = 0` is `from_difference(m, 0) = from_difference(0, 0)`;
  -- the boundary reads it back as the cross-equation `m + 0 = 0 + 0`.
  m
     = m + 0
     = 0 + 0
     = 0

-- A square is non-negative: ∃ n. a·a = (n : ℤ).
theorem Integer.square_is_nonneg (a : ℤ) : Integer.IsNonneg(a * a) := {
  Integer.IsNonneg(a) ∨ (∃ (k : ℕ). a = -(k : ℤ))
      by Integer.sign_split;
  done by cases {
    case Integer.IsNonneg(a) as nonnegative: {
        choose n such that a = (n : ℤ) from nonnegative;
        witness n * n with
            a * a
               = (n : ℤ) * (n : ℤ)
               = ((n * n : ℕ) : ℤ)
      }
    case ∃ (k : ℕ). a = -(k : ℤ) as negative: {
        choose k such that a = -(k : ℤ) from negative;
        witness k * k with
            a * a
               = (-(k : ℤ)) * (-(k : ℤ))
               = (k : ℤ) * (k : ℤ)
               = ((k * k : ℕ) : ℤ)
      }
  }
}

-- a² + b² = 0 ⟹ a = 0 ∧ b = 0.
theorem Integer.sum_of_squares_zero (a b : ℤ)
        (squaresSumZero : a * a + b * b = Integer.zero)
        : a = Integer.zero ∧ b = Integer.zero := {
  choose m such that a * a = (m : ℤ) from Integer.square_is_nonneg;
  choose n such that b * b = (n : ℤ) from Integer.square_is_nonneg;
  -- (m + n : ℤ) = a² + b² = 0, so m + n = 0 as Naturals.
  Natural.to_integer(m + n)
     = (m : ℤ) + (n : ℤ)
     = a * a + (n : ℤ)
     = a * a + b * b
     = Integer.zero;
  m + n = 0;
  m = 0;
  n = 0;
  -- a² = (m : ℤ) = (0 : ℤ) = 0, so a = 0; likewise b.
  a * a
     = (m : ℤ)
     = (0 : ℤ)
     = Integer.zero;
  b * b
     = (n : ℤ)
     = (0 : ℤ)
     = Integer.zero;
  a = Integer.zero ∨ a = Integer.zero by Integer.multiply_eq_zero_implies;
  a = Integer.zero by cases {
    case a = Integer.zero as aIsZero: aIsZero
    case a = Integer.zero as aIsZero: aIsZero
  };
  b = Integer.zero ∨ b = Integer.zero by Integer.multiply_eq_zero_implies;
  b = Integer.zero by cases {
    case b = Integer.zero as bIsZero: bIsZero
    case b = Integer.zero as bIsZero: bIsZero
  };
  done
}

-- Every integer square is the cast of a natural square: the sign split
-- names |a| as a natural, and both signs square to the same value. The
-- bridge that moves a square identity from ℤ down to ℕ.
theorem Integer.square_as_natural_square (a : ℤ)
        : ∃ (m : ℕ). a * a = ((m * m : ℕ) : ℤ) := {
  Integer.IsNonneg(a) ∨ ∃ (m : ℕ). a = -(m : ℤ) by Integer.sign_split;
  done by cases {
    case Integer.IsNonneg(a): {
        choose m such that a = (m : ℤ);
        witness m with
            a * a
               = (m : ℤ) * (m : ℤ)
               = ((m * m : ℕ) : ℤ)
      }
    case ∃ (m : ℕ). a = -(m : ℤ): {
        choose m such that a = -(m : ℤ);
        witness m with
            a * a
               = (-(m : ℤ)) * (-(m : ℤ))
               = (m : ℤ) * (m : ℤ)
               = ((m * m : ℕ) : ℤ)
      }
  }
}

-- Small integer squares are classified by splitting the sign and reflecting
-- the resulting bound to the corresponding Natural square.
theorem Integer.square_below_three (b : ℤ) (bound : b * b < 3)
        : b = -(1 : ℤ) ∨ b = 0 ∨ b = 1 := {
  Integer.IsNonneg(b) ∨ ∃ (m : ℕ). b = -(m : ℤ) by Integer.sign_split;
  done by cases {
    case Integer.IsNonneg(b): {
        choose m such that b = m;
        ((m * m : ℕ) : ℤ)
           = m * m
           = b * b by substituting (b = m)
           < 3 by bound
           < 4
           = 4;
        m * m < 4 by Natural.to_integer.LessThan_reflects;
        m = 0 ∨ m = 1 by Natural.square_below_four;
        done by cases {
          case m = 0:
              b = m = 0
          case m = 1:
              b = m = 1
        }
      }
    case ∃ (m : ℕ). b = -(m : ℤ): {
        choose m such that b = -(m : ℤ);
        ((m * m : ℕ) : ℤ)
           = m * m
           = (-(m : ℤ)) * (-(m : ℤ))
           = b * b by substituting (b = -(m : ℤ))
           < 3 by bound
           < 4
           = 4;
        m * m < 4 by Natural.to_integer.LessThan_reflects;
        m = 0 ∨ m = 1 by Natural.square_below_four;
        done by cases {
          case m = 0:
              b = -(m : ℤ) = -(0 : ℤ) = 0
          case m = 1:
              b = -(m : ℤ) = -(1 : ℤ)
        }
      }
  }
}

theorem Integer.square_below_five (b : ℤ) (bound : b * b < 5)
        : b = -(2 : ℤ) ∨ b = -(1 : ℤ) ∨ b = 0 ∨ b = 1 ∨ b = 2 := {
  Integer.IsNonneg(b) ∨ ∃ (m : ℕ). b = -(m : ℤ) by Integer.sign_split;
  done by cases {
    case Integer.IsNonneg(b): {
        choose m such that b = m;
        ((m * m : ℕ) : ℤ)
           = m * m
           = b * b by substituting (b = m)
           < 5 by bound
           < 6
           = 6;
        m * m < 6 by Natural.to_integer.LessThan_reflects;
        m = 0 ∨ m = 1 ∨ m = 2 by Natural.square_below_six;
        done by cases {
          case m = 0:
              b = m = 0
          case m = 1 ∨ m = 2: done by cases {
              case m = 1:
                  b = m = 1
              case m = 2:
                  b = m = 2
            }
        }
      }
    case ∃ (m : ℕ). b = -(m : ℤ): {
        choose m such that b = -(m : ℤ);
        ((m * m : ℕ) : ℤ)
           = m * m
           = (-(m : ℤ)) * (-(m : ℤ))
           = b * b by substituting (b = -(m : ℤ))
           < 5 by bound
           < 6
           = 6;
        m * m < 6 by Natural.to_integer.LessThan_reflects;
        m = 0 ∨ m = 1 ∨ m = 2 by Natural.square_below_six;
        done by cases {
          case m = 0:
              b = -(m : ℤ) = -(0 : ℤ) = 0
          case m = 1 ∨ m = 2: done by cases {
              case m = 1:
                  b = -(m : ℤ) = -(1 : ℤ)
              case m = 2:
                  b = -(m : ℤ) = -(2 : ℤ)
            }
        }
      }
  }
}

theorem Integer.square_below_ten (b : ℤ) (bound : b * b < 10)
        : b = -(3 : ℤ) ∨ b = -(2 : ℤ) ∨ b = -(1 : ℤ)
          ∨ b = 0 ∨ b = 1 ∨ b = 2 ∨ b = 3 := {
  Integer.IsNonneg(b) ∨ ∃ (m : ℕ). b = -(m : ℤ) by Integer.sign_split;
  done by cases {
    case Integer.IsNonneg(b): {
        choose m such that b = m;
        ((m * m : ℕ) : ℤ)
           = m * m
           = b * b by substituting (b = m)
           < 10 by bound
           = 10;
        m * m < 10 by Natural.to_integer.LessThan_reflects;
        m = 0 ∨ m = 1 ∨ m = 2 ∨ m = 3 by Natural.square_below_ten;
        done by cases {
          case m = 0:
              b = m = 0
          case m = 1 ∨ m = 2 ∨ m = 3: done by cases {
              case m = 1:
                  b = m = 1
              case m = 2 ∨ m = 3: done by cases {
                  case m = 2:
                      b = m = 2
                  case m = 3:
                      b = m = 3
                }
            }
        }
      }
    case ∃ (m : ℕ). b = -(m : ℤ): {
        choose m such that b = -(m : ℤ);
        ((m * m : ℕ) : ℤ)
           = m * m
           = (-(m : ℤ)) * (-(m : ℤ))
           = b * b by substituting (b = -(m : ℤ))
           < 10 by bound
           = 10;
        m * m < 10 by Natural.to_integer.LessThan_reflects;
        m = 0 ∨ m = 1 ∨ m = 2 ∨ m = 3 by Natural.square_below_ten;
        done by cases {
          case m = 0:
              b = -(m : ℤ) = -(0 : ℤ) = 0
          case m = 1 ∨ m = 2 ∨ m = 3: done by cases {
              case m = 1:
                  b = -(m : ℤ) = -(1 : ℤ)
              case m = 2 ∨ m = 3: done by cases {
                  case m = 2:
                      b = -(m : ℤ) = -(2 : ℤ)
                  case m = 3:
                      b = -(m : ℤ) = -(3 : ℤ)
                }
            }
        }
      }
  }
}

theorem Integer.square_below_eight (b : ℤ) (bound : b * b < 8)
        : b = -(2 : ℤ) ∨ b = -(1 : ℤ) ∨ b = 0 ∨ b = 1 ∨ b = 2 := {
  b * b < 8 < 10 by Natural.to_integer.LessThan_preserves;
  b = -(3 : ℤ) ∨ b = -(2 : ℤ) ∨ b = -(1 : ℤ)
      ∨ b = 0 ∨ b = 1 ∨ b = 2 ∨ b = 3
      by Integer.square_below_ten;
  done by cases {
    case b = -(3 : ℤ): {
        b * b = (9 : ℤ);
        (9 : ℤ) < (8 : ℤ);
        (9 : ℕ) < 8 by Natural.to_integer.LessThan_reflects;
        (9 : ℕ) < 8 < 9;
        False by Natural.lt_irreflexive;
        done
      }
    case b = -(2 : ℤ): done
    case b = -(1 : ℤ) ∨ b = 0 ∨ b = 1 ∨ b = 2 ∨ b = 3: done by cases {
        case b = -(1 : ℤ): done
        case b = 0 ∨ b = 1 ∨ b = 2 ∨ b = 3: done by cases {
            case b = 0: done
            case b = 1 ∨ b = 2 ∨ b = 3: done by cases {
                case b = 1: done
                case b = 2: done
                case b = 3: {
                    b * b = (9 : ℤ);
                    (9 : ℤ) < (8 : ℤ);
                    (9 : ℕ) < 8 by Natural.to_integer.LessThan_reflects;
                    (9 : ℕ) < 8 < 9;
                    False by Natural.lt_irreflexive;
                    done
                  }
              }
          }
      }
  }
}

-- Integer/sum_of_squares.math
--
-- a² + b² = 0 over ℤ forces a = b = 0. A square is non-negative (it is the
-- image of a Natural square), and a sum of two Natural images is zero only
-- when both are; then a² = 0 gives a = 0 (ℤ has no zero divisors).

module Integer.sum_of_squares

import Logic.basics
import Logic.exists
import Logic.product
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.cancellation
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.embedding
import Integer.order
import Integer.sign
import Algebra.integer_domain

-- The Natural embedding is injective at 0: (m : Integer) = 0 ⟹ m = 0.
theorem Natural.to_integer.eq_zero_implies (m : Natural)
        (imageZero : Natural.to_integer(m) = Integer.zero) : m = 0 :=
  -- `(m : Integer) = 0` is `from_difference(m, 0) = from_difference(0, 0)`;
  -- the boundary reads it back as the cross-equation `m + 0 = 0 + 0`.
  calc m
     = m + 0
     = 0 + 0       since Integer.difference_equal_implies
     = 0

-- A square is non-negative: ∃ n. a·a = (n : Integer).
theorem Integer.square_is_nonneg (a : Integer) : Integer.IsNonneg(a * a) :=
  claim Integer.IsNonneg(a) ∨ (∃ (k : Natural). a = -(k : Integer))
      by Integer.sign_split
  claim by cases {
    in (Integer.IsNonneg(a)) as nonnegative: {
        choose n such that a = (n : Integer) as aEqualsN from nonnegative;
        witness n * n with
            calc a * a
               = (n : Integer) * (n : Integer)        since aEqualsN
               = ((n * n : Natural) : Integer)         since Natural.to_integer.multiply_preserves
      }
    in (∃ (k : Natural). a = -(k : Integer)) as negative: {
        choose k such that a = -(k : Integer) as aEqualsNegativeK from negative;
        witness k * k with
            calc a * a
               = (-(k : Integer)) * (-(k : Integer))   since aEqualsNegativeK
               = (k : Integer) * (k : Integer)
               = ((k * k : Natural) : Integer)          since Natural.to_integer.multiply_preserves
      }
  }

-- a² + b² = 0 ⟹ a = 0 ∧ b = 0.
theorem Integer.sum_of_squares_zero (a b : Integer)
        (squaresSumZero : a * a + b * b = Integer.zero)
        : a = Integer.zero ∧ b = Integer.zero := {
  choose m such that a * a = (m : Integer) as aaEqualsM from Integer.square_is_nonneg;
  choose n such that b * b = (n : Integer) as bbEqualsN from Integer.square_is_nonneg;
  -- (m + n : Integer) = a² + b² = 0, so m + n = 0 as Naturals.
  let _ : Natural.to_integer(m + n) = Integer.zero :=
      calc Natural.to_integer(m + n)
         = (m : Integer) + (n : Integer)
         = a * a + (n : Integer)         since aaEqualsM
         = a * a + b * b                 since bbEqualsN
         = Integer.zero                  since squaresSumZero;
  claim m + n = 0 since Natural.to_integer.eq_zero_implies;
  claim mZero : m = 0 since Natural.add_equals_zero_left;
  claim nZero : n = 0 since Natural.add_equals_zero_right;
  -- a² = (m : Integer) = (0 : Integer) = 0, so a = 0; likewise b.
  calc a * a
     = (m : Integer)    since aaEqualsM
     = (0 : Integer)    since mZero
     = Integer.zero;
  calc b * b
     = (n : Integer)    since bbEqualsN
     = (0 : Integer)    since nZero
     = Integer.zero;
  claim a = Integer.zero ∨ a = Integer.zero since Integer.multiply_eq_zero_implies;
  claim a = Integer.zero by cases {
    in (a = Integer.zero) as aIsZero: aIsZero
    in (a = Integer.zero) as aIsZero: aIsZero
  };
  claim b = Integer.zero ∨ b = Integer.zero since Integer.multiply_eq_zero_implies;
  claim b = Integer.zero by cases {
    in (b = Integer.zero) as bIsZero: bIsZero
    in (b = Integer.zero) as bIsZero: bIsZero
  };
  done
}

-- Integer/order.math
--
-- The ≤ relation on Integer. Defined directly: `x ≤ y` iff there is
-- a natural `n` such that `y = x + (n : ℤ)`. This shape makes
-- reflexivity and transitivity straightforward, and integrates cleanly
-- with the additive ring laws (no need to drop down to representatives).

module Integer.order

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.subtraction
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra

-- `x` is non-negative iff it equals some ℕ's image.
definition Integer.IsNonneg (x : ℤ) : Proposition :=
  ∃ (n : ℕ). x = (n : ℤ)

-- ≤ on ℤ: `x ≤ y` iff there's a ℕ `n` with y = x + n.
definition Integer.LessOrEqual (x y : ℤ) : Proposition :=
  ∃ (n : ℕ). y = x + (n : ℤ)

-- Strict <: `x + 1 ≤ y`.
definition Integer.LessThan (x y : ℤ) : Proposition :=
  Integer.LessOrEqual(x + Integer.one, y)

operator (≤) on (Integer, Integer) := Integer.LessOrEqual
operator (<) on (Integer, Integer) := Integer.LessThan

-- ----------------------------------------------------------------------
-- IsNonneg basics.

-- 0 is non-negative.
automatic theorem Integer.zero_is_nonneg : Integer.IsNonneg(Integer.zero) :=
  witness 0 with done

-- Every embedded ℕ is non-negative.
automatic theorem Integer.from_natural_is_nonneg (n : ℕ)
        : Integer.IsNonneg((n : ℤ)) :=
  witness n with done

-- `IsNonneg(x)` and `0 ≤ x` say the same thing: `IsNonneg` is `∃n. x = (n:ℤ)`
-- and `0 ≤ x` is `∃n. x = 0 + (n:ℤ)`, identical once `0 + (n:ℤ)` collapses.
-- These let order-level code speak `≤` while reusing the non-negativity
-- machinery (closure under +, ·, squares) stated with `IsNonneg`.
theorem Integer.zero_less_or_equal_of_nonneg (x : ℤ)
        (xNonneg : Integer.IsNonneg(x))
        : (0 : ℤ) ≤ x := {
  choose n such that x = (n : ℤ) from xNonneg;
  witness n with x = (n : ℤ) = (0 : ℤ) + (n : ℤ)
}

theorem Integer.nonneg_of_zero_less_or_equal (x : ℤ)
        (xNonneg : (0 : ℤ) ≤ x)
        : Integer.IsNonneg(x) := {
  choose n such that x = (0 : ℤ) + (n : ℤ) from xNonneg;
  witness n with x = (0 : ℤ) + (n : ℤ) = (n : ℤ)
}

-- ----------------------------------------------------------------------
-- ≤ basic properties.

-- Reflexivity: x ≤ x. Witness: 0, since x = x + 0.
theorem Integer.LessOrEqual.reflexive (x : ℤ) : x ≤ x :=
  witness 0 with done

-- Transitivity: x ≤ y and y ≤ z give x ≤ z.
-- With y = x + a and z = y + b:  z = (x + a) + b = x + (a + b).
theorem Integer.LessOrEqual.transitive (x y z : ℤ)
        (xLessOrEqualY : x ≤ y) (yLessOrEqualZ : y ≤ z)
        : x ≤ z := {
  choose a such that y = x + (a : ℤ) from xLessOrEqualY;
  choose b such that z = y + (b : ℤ) from yLessOrEqualZ;
  witness a + b with
      z
         = y + (b : ℤ)
         = (x + (a : ℤ)) + (b : ℤ)
         = x + ((a : ℤ) + (b : ℤ))
         = x + (a + b : ℤ)
}

-- a < b weakens to a ≤ b: a ≤ a + 1 (witness the ℕ 1) and a + 1 ≤ b (the
-- definition of `<`), by transitivity.
theorem Integer.LessThan.weaken (a b : ℤ) (aLessThanB : a < b) : a ≤ b := {
  a + Integer.one ≤ b;
  a ≤ a + Integer.one
      by witness (1 : ℕ) with (a + Integer.one = a + ((1 : ℕ) : ℤ));
  done
}

-- Weak-then-strict: x ≤ y ∧ y < z → x < z. With y = x + a and
-- z = (y + 1) + b, the difference between z and x + 1 is a + b.
theorem Integer.LessThan.transitive_left (x y z : ℤ)
        (xLessOrEqualY : x ≤ y) (yLessThanZ : y < z)
        : x < z := {
  y + Integer.one ≤ z as yPlusOneBelowZ;
  choose a such that y = x + (a : ℤ) from xLessOrEqualY;
  choose b such that z = (y + Integer.one) + (b : ℤ) from yPlusOneBelowZ;
  witness a + b with
      z
         = (y + Integer.one) + (b : ℤ)
         = ((x + (a : ℤ)) + Integer.one) + (b : ℤ)
         = (x + Integer.one) + ((a : ℤ) + (b : ℤ))
         = (x + Integer.one) + (a + b : ℤ)
}

-- Strict-then-weak: x < y ∧ y ≤ z → x < z. Both sides speak x + 1 ≤ ·,
-- so ≤-transitivity carries the strict bound through.
theorem Integer.LessThan.transitive_right (x y z : ℤ)
        (xLessThanY : x < y) (yLessOrEqualZ : y ≤ z)
        : x < z := {
  x + Integer.one ≤ y;
  x + Integer.one ≤ z;
  done
}

-- ----------------------------------------------------------------------
-- The Natural→Integer embedding preserves order (the ℕ→ℤ rung of the tower).

-- a ≤ b ⟹ (a:ℤ) ≤ (b:ℤ): with b = a + k, the difference is the image of k.
theorem Natural.to_integer.LessOrEqual_preserves (n m : ℕ) (nLeqM : n ≤ m)
        : (n : ℤ) ≤ (m : ℤ) := {
  choose k such that m = n + k from Natural.subtraction_witness;
  witness k with
      (m : ℤ)
         = (n + k : ℤ)
         = (n : ℤ) + (k : ℤ)
}

-- a < b ⟹ (a:ℤ) < (b:ℤ): a + 1 ≤ b preserves to (a:ℤ) + 1 ≤ (b:ℤ), which is `<`.
theorem Natural.to_integer.LessThan_preserves (a b : ℕ) (aLessThanB : a < b)
        : (a : ℤ) < (b : ℤ) := {
  a + 1 ≤ b;
  ((a + 1 : ℕ) : ℤ) ≤ (b : ℤ);
  (a : ℤ) + Integer.one ≤ (b : ℤ);
  done
}

-- 0 < n ⟹ 0 < (n:ℤ). Automatic: the ℕ→ℤ rung of the positivity tower the
-- division/nonzero discharge walks.
automatic theorem Natural.to_integer.positive_preserves (n : ℕ) (nPositive : 0 < n)
        : Integer.zero < (n : ℤ) := {
  ((0 : ℕ) : ℤ) < (n : ℤ);
  done
}

-- ----------------------------------------------------------------------
-- … and reflects it: an inequality between the images forces the Natural one.

-- (a:ℤ) ≤ (b:ℤ) ⟹ a ≤ b: the gap witness reads back through the difference
-- boundary as b = a + gap.
theorem Natural.to_integer.LessOrEqual_reflects (a b : ℕ)
        (imageLessOrEqual : (a : ℤ) ≤ (b : ℤ)) : a ≤ b := {
  choose gap such that (b : ℤ) = (a : ℤ) + (gap : ℤ) from imageLessOrEqual;
  (b : ℤ)
     = (a : ℤ) + (gap : ℤ)
     = ((a + gap : ℕ) : ℤ);
  b + 0 = 0 + (a + gap);
  b
     = b + 0
     = 0 + (a + gap)
     = a + gap;
  a ≤ a + gap;
  done
}

-- (a:ℤ) < (b:ℤ) ⟹ a < b: strictness lowers through the `+ 1` shift —
-- (a:ℤ) + 1 is the image of a + 1, so a + 1 ≤ b.
theorem Natural.to_integer.LessThan_reflects (a b : ℕ)
        (imageLessThan : (a : ℤ) < (b : ℤ)) : a < b := {
  (a : ℤ) + Integer.one ≤ (b : ℤ);
  ((a + 1 : ℕ) : ℤ) ≤ (b : ℤ);
  a + 1 ≤ b by Natural.to_integer.LessOrEqual_reflects;
  done by Natural.lt_of_add_one_le
}

-- ----------------------------------------------------------------------
-- Order vs. addition.

-- ≤ is preserved by adding the same value: x ≤ y implies x + z ≤ y + z.
-- With y = x + n, we have y + z = (x + z) + n by associativity +
-- commutativity. Witness: same n.
theorem Integer.add_preserves_less_or_equal (x y z : ℤ)
        (xLessOrEqualY : x ≤ y)
        : x + z ≤ y + z := {
  choose n such that y = x + (n : ℤ) from xLessOrEqualY;
  witness n with
      y + z
         = (x + (n : ℤ)) + z
         = (x + z) + (n : ℤ)
}

-- Every Natural's image is ≥ 0.
theorem Integer.zero_less_or_equal_from_natural (n : ℕ)
        : Integer.zero ≤ (n : ℤ) :=
  witness n with done

-- A non-negative integer other than zero is positive: its witness is
-- 1 + k, which peels off the strict unit.
theorem Integer.positive_of_nonneg_nonzero (x : ℤ)
        (xNonneg : Integer.IsNonneg(x)) (xNonzero : ¬(x = Integer.zero))
        : x > (0 : ℤ) := {
  choose n such that x = (n : ℤ) from xNonneg;
  n = 0 ∨ ∃ (k : ℕ). n = 1 + k;
  done by cases {
    case n = 0 as nZero: {
        x  = (n : ℤ)
           = ((0 : ℕ) : ℤ)   by substituting nZero
           = Integer.zero;
        done
      }
    case ∃ (k : ℕ). n = 1 + k as nPositive: {
        choose k such that n = 1 + k from nPositive;
        witness k with
            x  = (n : ℤ)
               = ((1 + k : ℕ) : ℤ)                  by substituting (n = 1 + k)
               = ((0 : ℤ) + Integer.one) + (k : ℤ)
      }
  }
}

-- A positive difference witnesses a strict inequality.
theorem Integer.lt_of_positive_difference (a b : ℤ)
        (differencePositive : b - a > (0 : ℤ))
        : a < b := {
  choose n such that b - a = ((0 : ℤ) + Integer.one) + (n : ℤ) from differencePositive;
  witness n with
      b  = (b - a) + a
         = (((0 : ℤ) + Integer.one) + (n : ℤ)) + a   by substituting (b - a = ((0 : ℤ) + Integer.one) + (n : ℤ))
         = (a + Integer.one) + (n : ℤ)
}

-- Adding a non-negative term keeps a positive sum positive.
theorem Integer.add_nonneg_positive (a b : ℤ)
        (aNonneg : a ≥ (0 : ℤ)) (bPositive : b > (0 : ℤ))
        : a + b > (0 : ℤ) := {
  b  = (0 : ℤ) + b
     ≤ a + b        by Integer.add_preserves_less_or_equal;
  done by Integer.LessThan.transitive_right
}

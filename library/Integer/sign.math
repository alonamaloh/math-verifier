-- Integer/sign.math
--
-- Sign decomposition: every Integer is either the image of a Natural
-- or the negation of the image of a positive Natural. Foundation for
-- the absolute-value multiplicativity, the Rational IsNonneg respect
-- proof, and the rational power function used by p-adics.

module Integer.sign

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.subtraction
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Integer.absolute_value

-- Helper: subtracting at the representative level (when b ≤ a) gives
-- a representative equivalent to the natural difference.
-- Specifically: mk(make(a, b)) = (k : Integer) where a = b + k.
theorem Integer.from_subtraction_witness
        (a b k : Natural)
        (witnessEquation : a = b + k)
        : Integer.from_difference(a, b)
          = (k : Integer) := {
  -- `(k : Integer)` is `from_difference(k, 0)`; the boundary needs the
  -- cross-equation `a + 0 = b + k`.
  claim a + 0 = b + k;
  done
}

-- Helper: when a ≤ b, mk(make(a, b)) is the negation of a Natural image.
-- Specifically: mk(make(a, b)) = -(k : Integer) where b = a + k.
theorem Integer.from_reverse_subtraction_witness
        (a b k : Natural)
        (witnessEquation : b = a + k)
        : Integer.from_difference(a, b)
          = -(k : Integer) := {
  -- `-(k : Integer)` is `from_difference(0, k)`; the boundary needs the
  -- cross-equation `a + k = b + 0`.
  claim a + k = b + 0;
  done
}

-- The two disjuncts as named propositions (avoid huge inline forms).
definition Integer.MkIsNonneg (a b : Natural) : Proposition :=
  ∃ (k : Natural).
    Integer.from_difference(a, b)
    = (k : Integer)

definition Integer.MkIsNegated (a b : Natural) : Proposition :=
  ∃ (k : Natural).
    Integer.from_difference(a, b)
    = -(k : Integer)

-- Sign trichotomy at the representative level.
theorem Integer.sign_split_at_representative
        (a b : Natural)
        : Integer.MkIsNonneg(a, b) ∨ Integer.MkIsNegated(a, b) :=
  claim a ≤ b ∨ b ≤ a
  claim by cases {
    in (a ≤ b) as aLeqB: {
        choose k such that b = a + k from Natural.subtraction_witness;
        claim Integer.MkIsNegated(a, b) by {
          witness k with done
        };
        done
    }
    in (b ≤ a) as bLeqA: {
        choose k such that a = b + k from Natural.subtraction_witness;
        claim Integer.MkIsNonneg(a, b) by {
          witness k with done
        };
        done
    }
  }

-- The sign-split motive on Integers.
definition Integer.SignSplitProp (y : Integer) : Proposition :=
  Integer.IsNonneg(y) ∨ ∃ (k : Natural). y = -(k : Integer)

-- Top-level sign split via Quotient.induct.
theorem Integer.sign_split (x : Integer) : Integer.SignSplitProp(x) :=
  by_representatives x as ⟨a, b⟩ => {
    claim Integer.MkIsNonneg(a, b) ∨ Integer.MkIsNegated(a, b);
    done
  }

-- ----------------------------------------------------------------------
-- Helper lemmas for cancellation arguments.

-- Natural-level: a + b = zero implies a = zero.
theorem Natural.add_eq_zero_left_zero
        : ∀ (a b : Natural). a + b = 0 → a = 0
  | zero, _, _ =>
      done
  | successor(k), b, equation => {
      claim isZero : successor(k + b) = 0 by substituting Natural.successor_add;
      absurd(isZero)
    }

-- And the right component.
theorem Natural.add_eq_zero_right_zero
        (a b : Natural) (equation : a + b = 0) : b = 0 :=
  { done by Natural.add_eq_zero_left_zero }

-- a * succ(d) = zero implies a = zero.
theorem Natural.multiply_successor_eq_zero_left_zero
        : ∀ (a d : Natural). a * successor(d) = 0 → a = 0
  | zero, _, _ =>
      done
  | successor(k), d, equation => {
      -- successor(k) * successor(d) reduces to a successor — never zero.
      claim isZero : successor(d + k * successor(d)) = 0;
      absurd(isZero)
    }

-- The Natural-to-Integer embedding is injective.
theorem Natural.to_integer.injective (n m : Natural)
        (embeddingEquality : (n : Integer) = (m : Integer))
        : n = m :=
  -- `(n : Integer) = (m : Integer)` is `from_difference(n, 0) =
  -- from_difference(m, 0)`; the boundary reads it back as `n + 0 = 0 + m`.
  calc n
     = n + 0
     = 0 + m     since Integer.difference_equal_implies
     = m

-- ----------------------------------------------------------------------
-- The key cancellation/sign lemma for Rational.IsNonneg_respect:
-- if `(a : Integer) * (succ(d2) : Integer) = -(k : Integer) *
-- (succ(d1) : Integer)`, then k = zero.
theorem Integer.natural_eq_negate_natural_implies_both_zero
        (a k d1 d2 : Natural)
        (mixedEquality
            : (a : Integer) * (successor(d2) : Integer)
              = -(k : Integer) * (successor(d1) : Integer))
        : k = 0 := {
    calc -(k : Integer) * (successor(d1) : Integer)
       = -((k : Integer) * (successor(d1) : Integer))
       = -(k * successor(d1) : Integer);
    -- Combine with the hypothesis: (a·succ d2 : ℤ) = -(k·succ d1 : ℤ).
    calc (a * successor(d2) : Integer)
              = (a : Integer) * (successor(d2) : Integer)
              = -(k : Integer) * (successor(d1) : Integer)
              = -(k * successor(d1) : Integer);
    -- Move the negated term across: the sum of the two naturals vanishes.
    calc (a * successor(d2) + k * successor(d1) : Integer)
       = (a * successor(d2) : Integer)
         + (k * successor(d1) : Integer)
       = -(k * successor(d1) : Integer)
         + (k * successor(d1) : Integer)
       = Integer.zero;
    claim a * successor(d2) + k * successor(d1) = 0;
    claim k * successor(d1) = 0;
    done since Natural.multiply_successor_eq_zero_left_zero
}

-- ----------------------------------------------------------------------
-- Absolute-value multiplicativity restricted to a positive-natural
-- second factor. Sufficient for Rational.absolute_value_respect; the
-- fully general |x*y| = |x|*|y| can wait.

theorem Integer.absolute_value_multiply_by_positive_natural
        (x : Integer) (d : Natural)
        : abs(x * (successor(d) : Integer))
          = abs(x) * (successor(d) : Integer) :=
  claim Integer.IsNonneg(x) ∨ (∃ (k : Natural). x = -(k : Integer))
      by Integer.sign_split
  claim by cases {
    in (Integer.IsNonneg(x)) as xIsNonneg: {
        choose a such that x = (a : Integer) from xIsNonneg;
        -- |x * succ(d)| = |(a : I) * (succ(d) : I)|
        -- = |(a * succ(d) : I)| = (a * succ(d) : I)
        -- = (a : I) * (succ(d) : I) = |x| * (succ(d) : I).
        calc abs(
                 x * (successor(d) : Integer))
           = abs(
                 (a : Integer) * (successor(d) : Integer))
           = abs(
                 (a * successor(d) : Integer))
           = (a * successor(d) : Integer)
           = (a : Integer) * (successor(d) : Integer)
           = abs((a : Integer))
             * (successor(d) : Integer)
           = abs(x) * (successor(d) : Integer)
    }
    in (∃ (k : Natural). x = -(k : Integer)) as xNegEvidence: {
        choose k such that x = -(k : Integer) from xNegEvidence;
        -- |x * succ(d)| = |-(k : I) * (succ(d) : I)|
        -- = |-((k : I) * (succ(d) : I))| = |(k * succ(d) : I)|
        -- = (k * succ(d) : I) = (k : I) * (succ(d) : I)
        -- = |(k : I)| * (succ(d) : I) = |-(k : I)| * (succ(d) : I)
        -- = |x| * (succ(d) : I).
        calc abs(
                 x * (successor(d) : Integer))
           = abs(
                 -(k : Integer) * (successor(d) : Integer))
           = abs(
                 -((k : Integer) * (successor(d) : Integer)))
           = abs(
                 (k : Integer) * (successor(d) : Integer))
           = abs((k * successor(d) : Integer))
           = (k * successor(d) : Integer)
           = (k : Integer) * (successor(d) : Integer)
           = abs(-(k : Integer))
             * (successor(d) : Integer)
           = abs(x) * (successor(d) : Integer)
    }
  }

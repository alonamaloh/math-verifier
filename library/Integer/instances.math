-- Integer/instances.math
--
-- Witnesses that Integer satisfies the standard algebraic
-- abstractions: an abelian group under (+, 0, −) and a commutative
-- ring under (+, ·, 0, 1). Each instance just assembles the
-- already-proved identities — the auto-prover conjoins them, so the
-- proof is a bare `done`; no new mathematical content, just packaging.

module Integer.instances

import Logic.basics
import Equality.basics
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.ring
import Integer.negation
import Algebra.monoid
import Algebra.group
import Algebra.group_bundle
import Algebra.ring

-- ℤ is a monoid under (+, 0).
theorem Integer.add_is_monoid
        : IsMonoid(ℤ, Integer.add, Integer.zero) :=
  done

-- ℤ is a commutative monoid under (+, 0).
theorem Integer.add_is_commutative_monoid
        : IsCommutativeMonoid(ℤ, Integer.add, Integer.zero) :=
  done

-- ℤ is a group under (+, 0, −).
theorem Integer.add_is_group
        : IsGroup(ℤ, Integer.add, Integer.zero, Integer.negate) :=
  done

-- ℤ is an abelian group under (+, 0, −).
theorem Integer.add_is_abelian_group
        : IsAbelianGroup(ℤ, Integer.add, Integer.zero,
                          Integer.negate) :=
  done

-- The bundled additive group of the integers: (ℤ, +, 0, −) packaged as
-- a single `Group` value, the concrete inhabitant of the bundled-group
-- abstraction (homomorphisms, subgroups, kernels) in Algebra.
definition Integer.additive_group : Group :=
    Group.make(ℤ, Integer.add, Integer.zero, Integer.negate,
               Integer.add_is_group)

-- ℤ is a monoid under (·, 1).
theorem Integer.multiply_is_monoid
        : IsMonoid(ℤ, Integer.multiply, Integer.one) :=
  done

-- ℤ is a commutative monoid under (·, 1).
theorem Integer.multiply_is_commutative_monoid
        : IsCommutativeMonoid(ℤ, Integer.multiply, Integer.one) :=
  done

-- ℤ is a ring under (+, 0, −, ·, 1).
theorem Integer.is_ring
        : IsRing(ℤ, Integer.add, Integer.zero, Integer.negate,
                  Integer.multiply, Integer.one) :=
  done

-- Canonical `IsRing(Integer, …)` instance: lets the generic ring lemmas
-- be cited argument-free at ℤ (the `ringProof` premise resolves from here).
instance Integer.is_ring

-- ℤ is a commutative ring.
theorem Integer.is_commutative_ring
        : IsCommutativeRing(ℤ, Integer.add, Integer.zero,
                             Integer.negate, Integer.multiply,
                             Integer.one) :=
  done

-- Fold-capable operations: certify (+, 0) and (·, 1) so the fold layer
-- (Algebra.Fold, the coming binder/ellipsis forms) can aggregate over ℤ.
fold_operation (+) on Integer := Integer.add_is_monoid
fold_operation (*) on Integer := Integer.multiply_is_monoid

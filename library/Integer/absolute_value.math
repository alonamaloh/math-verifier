-- Integer/absolute_value.math
--
-- Absolute value on Integer. On representatives `(a, b)` (where the
-- intuitive value is `a - b`), the absolute value is the symmetric
-- difference `Natural.distance(a, b)` lifted back to Integer. The
-- respect proof reduces to `Natural.distance_respects_integer_equivalent`.

module Integer.absolute_value

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.distance
import Natural.subtraction
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order

-- The function on representatives: |make(a, b)| := (distance(a, b) : Integer).
definition Integer.absolute_value_at_representative
        : IntegerRepresentative → Integer
  | IntegerRepresentative.make(a, b) =>
      (Natural.distance(a, b) : Integer)

-- Respect kernel: given `a + d = b + c`, the two representatives'
-- absolute-value-at-representative agree as Integers. Direct from
-- `Natural.distance_respects_integer_equivalent`.
theorem Integer.absolute_value_respect_natural
        (a b c d : Natural)
        (aPlusDEqualsBPlusC : a + d = b + c)
        : (Natural.distance(a, b) : Integer)
          = (Natural.distance(c, d) : Integer) :=
  calc (Natural.distance(a, b) : Integer)
     = (Natural.distance(c, d) : Integer)

theorem Integer.absolute_value_respect
        : ∀ (rep1 rep1Prime : IntegerRepresentative).
          IntegerEquivalent(rep1, rep1Prime)
          → Integer.absolute_value_at_representative(rep1)
            = Integer.absolute_value_at_representative(rep1Prime)
  | IntegerRepresentative.make(a, b),
    IntegerRepresentative.make(c, d),
    aPlusDEqualsBPlusC =>
      done

-- Absolute value as a function on Integer.
definition Integer.absolute_value : Integer → Integer
  by representatives rep ↦ Integer.absolute_value_at_representative(rep)
  well_defined by Integer.absolute_value_respect

-- Register `abs` as a per-type alias. Downstream code that imports
-- this file can write `abs(x)` where `x : Integer` and the elaborator
-- resolves to `Integer.absolute_value(x)`. Each carrier's
-- absolute_value file adds its own `overload abs := …` entry so the
-- alias dispatches on argument type at the call site.
overload abs := Integer.absolute_value

-- |0| = 0. Direct from the lift's β-reduction and
-- distance(0, 0) = 0.
theorem Integer.absolute_value_zero
        : abs(Integer.zero) = Integer.zero :=
  okay

-- |(n : Integer)| = (n : Integer) for n : Natural. Via lift β:
-- (n : Integer) = mk(make(n, zero)), |.| = (distance(n, zero) :
-- Integer) = (n : Integer) by distance_zero_right.
automatic theorem Integer.absolute_value_of_natural (n : Natural)
        : abs((n : Integer)) = (n : Integer) := {
    calc Natural.distance(n, 0) + 0
       = Natural.distance(n, 0)
       = n
       = 0 + n;
    done
}

-- |-x| = |x| at the representative level: negate swaps (a, b) to
-- (b, a), and distance is symmetric.
theorem Integer.absolute_value_negate_at_representative
        : ∀ (rep : IntegerRepresentative).
          Integer.absolute_value_at_representative(
                Integer.negate_representatives(rep))
            = Integer.absolute_value_at_representative(rep)
  | IntegerRepresentative.make(a, b) =>
      calc (Natural.distance(b, a) : Integer)
         = (Natural.distance(a, b) : Integer)

-- |-x| = |x| on Integer.
theorem Integer.absolute_value_negate (x : Integer)
        : abs(-x) = abs(x) :=
  by_representatives x as ⟨a, b⟩ =>
      calc (Natural.distance(b, a) : Integer)
         = (Natural.distance(a, b) : Integer)

-- -(-x) = x at the representative level: double-negation cancels.
theorem Integer.negate_negate_at_representative
        : ∀ (rep : IntegerRepresentative).
          Integer.negate_representatives(
                Integer.negate_representatives(rep)) = rep
  | IntegerRepresentative.make(a, b) => okay

-- -(-x) = x on Integer. At a representative (a, b) both sides reduce
-- to make(a, b).
theorem Integer.negate_negate (x : Integer) : -(-x) = x :=
  by_representatives x as ⟨a, b⟩ => okay

-- -(p + q) = -p + -q at the representative level. Both sides reduce
-- to make(β + δ, α + γ) when p = mk(make(α, β)), q = mk(make(γ, δ)).
theorem Integer.negate_add_at_representatives
        : ∀ (rep_p rep_q : IntegerRepresentative).
          Integer.negate_representatives(
                Integer.add_representatives(rep_p, rep_q))
            = Integer.add_representatives(
                Integer.negate_representatives(rep_p),
                Integer.negate_representatives(rep_q))
  | IntegerRepresentative.make(alpha, beta),
    IntegerRepresentative.make(gamma, δ) => okay

-- -(p + q) = -p + -q on Integer. Take representatives for both p and q.
theorem Integer.negate_add (p q : Integer) : -(p + q) = -p + -q :=
  by_representatives p as ⟨alpha, beta⟩, q as ⟨gamma, δ⟩ => okay

-- ----------------------------------------------------------------------
-- Triangle inequality.

-- Monotonicity of the Natural ↪ Integer embedding: n ≤ m on Naturals
-- implies (n : I) ≤ (m : I). Witness via Natural.subtraction_witness.
-- |x + y| at representatives reduces directly: mk(a, b) + mk(c, d)
-- = mk(a + c, b + d), |·| = (distance(a + c, b + d) : I). Stated as
-- a sanity check / convenience.
theorem Integer.absolute_value_add_at_representatives
        (a b c d : Natural)
        : abs(((Integer.from_difference(a, b)
                + Integer.from_difference(c, d)) : Integer))
          = (Natural.distance(a + c, b + d) : Integer) :=
  okay

-- Triangle inequality on representatives. Establishes the Integer ≤
-- between the embedded distances. The actual Integer.triangle_inequality
-- then takes representatives for both arguments.
theorem Integer.triangle_inequality_at_representatives
        (a b c d : Natural)
        : (Natural.distance(a + c, b + d) : Integer)
          ≤ (Natural.distance(a, b) : Integer)
            + (Natural.distance(c, d) : Integer) := {
    Natural.distance(a + c, b + d)
      ≤ Natural.distance(a, b) + Natural.distance(c, d)
      by Natural.distance_add_triangle;
    calc (Natural.distance(a + c, b + d) : Integer)
       ≤ ((Natural.distance(a, b) + Natural.distance(c, d)) : Integer)
           by Natural.to_integer.LessOrEqual_preserves
       = (Natural.distance(a, b) : Integer)
           + (Natural.distance(c, d) : Integer)
}

-- |x + y| ≤ |x| + |y| on Integer. Take representatives x = [(a, b)],
-- y = [(c, d)]; the result follows from the at-representatives lemma.
theorem Integer.triangle_inequality (x y : Integer)
        : abs(x + y)
          ≤ abs(x) + abs(y) :=
  by_representatives x as ⟨a, b⟩, y as ⟨c, d⟩ =>
      calc (Natural.distance(a + c, b + d) : Integer)
         ≤ (Natural.distance(a, b) : Integer)
             + (Natural.distance(c, d) : Integer)
             by Integer.triangle_inequality_at_representatives


-- x - y = -(y - x). Single ring identity; the auto-prover closes
-- the whole chain via the lemma index + negate_add + comm.
theorem Integer.subtract_swap (x y : Integer) : x - y = -(y - x) :=
  calc x - y
     = -(y - x)

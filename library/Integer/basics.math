-- Integer/basics.math
--
-- Integers as the quotient of `IntegerRepresentative` (pairs of
-- naturals) by the equivalence `(a, b) ~ (c, d) iff a + d = b + c`.
-- The intuition: `IntegerRepresentative.make(a, b)` represents the
-- difference `a - b`. Two pairs represent the same integer exactly
-- when their differences agree — an equality that stays inside
-- Natural and so doesn't depend on integer subtraction at all.
--
-- `Integer` is **opaque**: the rest of the library reasons about Integers
-- through the boundary lemmas published here (`Integer.difference_equal`
-- and its converse), never by unfolding the quotient. How the integers are
-- built is an implementation detail behind that boundary.
--
-- `IntegerEquivalent` (the equivalence relation), by contrast, is
-- **transparent**: it is only ever touched by the `Integer/` construction
-- itself, which genuinely reasons about it, so `IntegerEquivalent(make(a,
-- b), make(c, d))` is just `a + d = b + c` definitionally — no bridge
-- lemmas, no unfolding. Opacity there bought nothing (no external consumer
-- to protect) and only imposed ceremony on the modules that must see it.

module Integer.basics

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

-- Representative pair: `make(positivePart, negativePart)` stands for
-- `positivePart - negativePart`. Multiple pairs represent the same
-- integer; the quotient below identifies them.
inductive IntegerRepresentative : Type(0) where
  | IntegerRepresentative.make
      : Natural → Natural → IntegerRepresentative

-- Projections — the positive and negative parts. These are the *only*
-- pattern-matches on a representative; the equivalence and its proofs go
-- through them, so they read as "the positive part of x", never
-- "destructure x".
definition IntegerRepresentative.positivePart : IntegerRepresentative → Natural
  | IntegerRepresentative.make(positive, negative) => positive
definition IntegerRepresentative.negativePart : IntegerRepresentative → Natural
  | IntegerRepresentative.make(positive, negative) => negative

-- (a, b) ~ (c, d) iff a + d = b + c — their differences `a - b`, `c - d`
-- agree. Stated through the projections (a plain `:=`, no pattern match),
-- so the equivalence proofs reason about `positivePart(x)` / `negativePart(x)`
-- for an abstract `x` without ever destructuring it. Transparent: it is
-- internal to this construction, so it reduces freely (no boundary lemmas).
definition IntegerEquivalent (x y : IntegerRepresentative) : Proposition :=
  IntegerRepresentative.positivePart(x) + IntegerRepresentative.negativePart(y)
    = IntegerRepresentative.negativePart(x) + IntegerRepresentative.positivePart(y)

-- The equivalence at concrete representatives IS the cross-addition
-- equation: `IntegerEquivalent(make(a, b), make(c, d))` is definitionally
-- `a + d = b + c`. So a cross-equation and the equivalence are
-- interchangeable by reduction — no bridge lemmas, no unfolding needed.

-- ----------------------------------------------------------------------
-- The equivalence relation is reflexive, symmetric, transitive. Each proof
-- reduces (`IntegerEquivalent` being transparent) to a Natural-component
-- identity about the projections of an abstract representative — no
-- destructure, and the named kernel lemma `since`-cites the real content.

-- Reflexive: positivePart(x) + negativePart(x) = negativePart(x) + positivePart(x).
theorem IntegerEquivalent.reflexive (x : IntegerRepresentative)
        : IntegerEquivalent(x, x) :=
  done since Natural.add_commutative

-- Symmetry kernel at the Natural level: a + d = b + c gives c + b = d + a.
theorem IntegerEquivalent.symmetric_natural (a b c d : Natural)
        (crossEquation : a + d = b + c) : c + b = d + a :=
  calc c + b
     = b + c
     = a + d    since crossEquation
     = d + a

theorem IntegerEquivalent.symmetric (x y : IntegerRepresentative)
        (xEquivalentY : IntegerEquivalent(x, y))
        : IntegerEquivalent(y, x) :=
  done since IntegerEquivalent.symmetric_natural

-- Transitivity kernel at the Natural level. From `a + d = b + c` and
-- `c + f = d + e`, derive `a + f = b + e`: sum the hypotheses, rearrange
-- both sides into `_ + (c + d)`, then cancel the common addend.
theorem IntegerEquivalent.transitive_natural
        (a b c d e f : Natural)
        (firstCrossEquation : a + d = b + c)
        (secondCrossEquation : c + f = d + e)
        : a + f = b + e := {
  calc (a + f) + (c + d)
     = (a + d) + (c + f)
     = (b + c) + (c + f)     since firstCrossEquation
     = (b + c) + (d + e)     since secondCrossEquation
     = (b + e) + (c + d);
  done since Natural.add_cancel_right
}

theorem IntegerEquivalent.transitive (x y z : IntegerRepresentative)
        (xEquivalentY : IntegerEquivalent(x, y))
        (yEquivalentZ : IntegerEquivalent(y, z))
        : IntegerEquivalent(x, z) :=
  done since IntegerEquivalent.transitive_natural

-- ----------------------------------------------------------------------
-- The Integer type: equivalence classes of IntegerRepresentative.
-- Opaque — the quotient structure is sealed behind the boundary lemmas.
opaque definition Integer : Type(0) :=
  Quotient(IntegerRepresentative, IntegerEquivalent)

-- The equivalence bundled as an `IsEquivalenceRelation`, registered as
-- the canonical instance. This is what lets `Quotient.equal_implies_equivalent` recover
-- reflexivity / symmetry / transitivity automatically.
definition Integer.equivalence
        : IsEquivalenceRelation(IntegerRepresentative, IntegerEquivalent) := {
  claim ∀ (x : IntegerRepresentative). IntegerEquivalent(x, x)
      since IntegerEquivalent.reflexive;
  claim ∀ (x y : IntegerRepresentative). IntegerEquivalent(x, y) → IntegerEquivalent(y, x)
      since IntegerEquivalent.symmetric;
  claim ∀ (x y z : IntegerRepresentative).
          IntegerEquivalent(x, y) → IntegerEquivalent(y, z) → IntegerEquivalent(x, z)
      since IntegerEquivalent.transitive;
  done
}

instance Integer.equivalence

-- The canonical introduction form: the class of the difference `a - b`.
-- Registered as a `construction` so proofs read `Integer.from_difference(a, b)`.
-- The `unfold Integer` pierces the opaque type once, here at the boundary.
construction Integer.from_difference (a b : Natural) : Integer :=
  unfold Integer in Quotient.class_of(IntegerRepresentative.make(a, b))

-- ----------------------------------------------------------------------
-- The boundary API. Every consumer compares Integers through these two
-- lemmas: `from_difference(a, b) = from_difference(c, d)` is exactly the
-- Natural cross-equation `a + d = b + c`, in both directions. The opaque
-- `Integer` is pierced only here (the equivalence is already transparent).

-- Cross-equation ⇒ equal classes (via Quotient.equivalent_implies_equal).
theorem Integer.difference_equal (a b c d : Natural)
        (crossEquation : a + d = b + c)
        : Integer.from_difference(a, b) = Integer.from_difference(c, d) :=
  unfold Integer in
    Quotient.equivalent_implies_equal(IntegerRepresentative.make(a, b),
                   IntegerRepresentative.make(c, d),
                   crossEquation)

-- Equal classes ⇒ cross-equation (via Quotient.equal_implies_equivalent).
theorem Integer.difference_equal_implies (a b c d : Natural)
        (differenceEquality
            : Integer.from_difference(a, b) = Integer.from_difference(c, d))
        : a + d = b + c :=
  Quotient.equal_implies_equivalent(IntegerRepresentative.make(a, b),
                 IntegerRepresentative.make(c, d),
                 unfold Integer in differenceEquality)

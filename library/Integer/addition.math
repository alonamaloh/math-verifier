-- Integer/addition.math
--
-- Addition on Integer, lifted from componentwise addition on
-- `IntegerRepresentative`. The lift uses Quotient.lift twice — once
-- for each Integer argument — and discharges respect for the
-- equivalence in two pieces (one per argument). Both respect proofs
-- factor through a Natural-level kernel lemma and a small destructure
-- chain.

module Integer.addition

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Integer.basics

-- Componentwise addition: (a - b) + (c - d) = (a + c) - (b + d).
definition Integer.add_representatives
        : IntegerRepresentative
          → IntegerRepresentative
          → IntegerRepresentative
  | IntegerRepresentative.make(a, b),
    IntegerRepresentative.make(c, d) =>
      IntegerRepresentative.make(a + c, b + d)

-- ----------------------------------------------------------------------
-- Respect of add_representatives in the first argument:
-- (a, b) ~ (a', b') implies add(a, b)(c, d) ~ add(a', b')(c, d).

-- Natural-level kernel: with a + b' = b + a' as the equivalence
-- hypothesis, conclude (a + c) + (b' + d) = (b + d) + (a' + c).
-- Reshuffle both sides via `add_two_two_swap` to bring (c + d) to the
-- outside, then substitute the hypothesis on the (a + b')/(b + a')
-- term.
theorem Integer.add_respects_first_natural
        (a b a' b' c d : Natural)
        (aPlusBPrimeEqualsBPlusAPrime : a + b' = b + a')
        : (a + c) + (b' + d) = (b + d) + (a' + c) :=
  calc (a + c) + (b' + d)
     = (a + b') + (c + d)
     = (b + a') + (c + d)
     = (b + d) + (a' + c)

-- Destructure all three representatives plus the equivalence proof in
-- one row; the inner-pattern refinement gives `eq` its Natural-level
-- form for direct hand-off to `_natural`.
theorem Integer.add_respects_first
        : (rep1 rep1' rep2 : IntegerRepresentative)
          → IntegerEquivalent(rep1, rep1')
          → IntegerEquivalent(
                Integer.add_representatives(rep1, rep2),
                Integer.add_representatives(rep1', rep2))
  | IntegerRepresentative.make(a, b),
    IntegerRepresentative.make(a', b'),
    IntegerRepresentative.make(c, d),
    eq =>
      done by Integer.add_respects_first_natural

-- ----------------------------------------------------------------------
-- Respect of add_representatives in the second argument:
-- (c, d) ~ (c', d') implies add(a, b)(c, d) ~ add(a, b)(c', d').

-- Natural-level kernel: with c + d' = d + c' as the equivalence
-- hypothesis, conclude (a + c) + (b + d') = (b + d) + (a + c').
theorem Integer.add_respects_second_natural
        (a b c d c' d' : Natural)
        (cPlusDPrimeEqualsDPlusCPrime : c + d' = d + c')
        : (a + c) + (b + d') = (b + d) + (a + c') :=
  calc (a + c) + (b + d')
     = (a + b) + (c + d')
     = (a + b) + (d + c')
     = (b + d) + (a + c')

-- Destructure rep1, rep2, rep2' plus the equivalence proof in one row;
-- inner-pattern refinement gives `eq` its Natural-level form.
theorem Integer.add_respects_second
        : (rep1 rep2 rep2' : IntegerRepresentative)
          → IntegerEquivalent(rep2, rep2')
          → IntegerEquivalent(
                Integer.add_representatives(rep1, rep2),
                Integer.add_representatives(rep1, rep2'))
  | IntegerRepresentative.make(a, b),
    IntegerRepresentative.make(c, d),
    IntegerRepresentative.make(cPrime, dPrime),
    eq =>
      done by Integer.add_respects_second_natural

-- ----------------------------------------------------------------------
-- Integer.add itself: lift add_representatives over both arguments.
-- The outer Quotient.lift varies rep1; the inner one (captured by the
-- outer function) varies rep2 with the chosen rep1. The kernel's
-- Quotient.lift reduction rule makes both lifts collapse on
-- Quotient.mk inputs to a plain mk(add_representatives(...)), which
-- is what the respect proofs need to compare.

-- Add the difference-pair representatives componentwise; well-defined in
-- each argument because addition respects the equivalence (the two
-- *_respects lemmas above). The binary define-by-representatives
-- synthesises the nested lift over both arguments.
definition Integer.add : Integer → Integer → Integer
  by representatives a, c ↦ Quotient.mk(Integer.add_representatives(a, c))
  well_defined by Integer.add_respects_first, Integer.add_respects_second

-- ----------------------------------------------------------------------
-- Canonical constants.

definition Integer.zero : Integer :=
  Integer.from_difference(0, 0)

definition Integer.one : Integer :=
  Integer.from_difference(1, 0)

-- Operator overload: `+` on Integers routes here.
operator (+) on (Integer, Integer) := Integer.add

-- Smoke test: zero + one = one (definitionally via the kernel
-- Quotient.lift reduction — both lifts collapse on the mk-form
-- inputs).
theorem Integer.add_zero_one_equals_one
        : Integer.zero + Integer.one = Integer.one :=
  done by substituting Natural.zero_add

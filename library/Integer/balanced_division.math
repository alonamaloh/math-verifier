-- Integer/balanced_division.math
--
-- Balanced division on ℤ: for a positive modulus m, any integer a can be
-- written a = m·q + s with the remainder symmetric, recorded as the clean
-- squared bound 4·s² ≤ m² (i.e. |s| ≤ m/2). This is the rounding step
-- behind nearest-integer (Gaussian) division: the ordinary non-negative
-- remainder r from `divide_by_positive` is kept when r + r ≤ m, otherwise
-- the quotient is bumped and the remainder becomes −(m − r).
--
-- Doubling is written `t + t`, not `2 * t`, throughout: the cast
-- `((t + t : ℕ) : ℤ) = (t : ℤ) + (t : ℤ)` is a clean `add_preserves`,
-- whereas a `2 *` literal leaves `((2 : ℕ) : ℤ)` as an atom `ring` can't see.

module Integer.balanced_division

import Logic.basics
import Logic.exists
import Logic.sum
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.add_order
import Natural.arithmetic
import Natural.multiply_bounds
import Natural.subtraction
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.embedding
import Integer.order
import Algebra.integer_euclidean

-- The Natural embedding is monotone: a ≤ b ⟹ (a : ℤ) ≤ (b : ℤ).
-- t + t ≤ m forces 4t² ≤ m² (square the bound in ℕ, then transport to ℤ).
theorem Integer.four_square_le_from_natural (t m : ℕ) (bound : t + t ≤ m)
        : (4 : ℤ) * (t : ℤ)² ≤ (m : ℤ)² := {
  (t + t)² ≤ (t + t) * m = m * (t + t) ≤ m²;
  ((t + t)² : ℤ) ≤ (m² : ℤ)
      by Natural.to_integer.LessOrEqual_preserves as castSquared;
  (4 : ℤ) * (t : ℤ)²
     = ((t + t)² : ℤ)
     ≤ (m² : ℤ)                   by castSquared
     = (m : ℤ)²
}

-- Balanced division: dividing by a positive integer leaves a remainder
-- of absolute value at most half the divisor (stated multiplication-
-- only: 4·remainder² ≤ m²).
theorem Integer.divide_balanced (a m : ℤ) (mPositive : m > (0 : ℤ))
        : ∃ (quotient : ℤ). ∃ (remainder : ℤ).
            a = m * quotient + remainder
            ∧ 4 * remainder² ≤ m² := {
  -- Positivity exhibits m as the image of a positive Natural, which the
  -- Natural division machinery consumes.
  choose k such that m = ((0 : ℤ) + Integer.one) + (k : ℤ)
      as mDecomposition from mPositive;
  m = ((0 : ℤ) + Integer.one) + (k : ℤ)   by mDecomposition
    = ((1 + k : ℕ) : ℤ)                   by substituting Natural.to_integer.add_preserves
    as mCast;
  choose quotient0, naturalRemainder such that
      a = ((1 + k : ℕ) : ℤ) * quotient0 + (naturalRemainder : ℤ) ∧ naturalRemainder < 1 + k
      from Integer.divide_by_positive(a, 1 + k, (1 ≤ 1 + k));
  a = m * quotient0 + (naturalRemainder : ℤ)
      by substituting mCast as aEquationM;
  naturalRemainder + naturalRemainder ≤ 1 + k
      ∨ 1 + k ≤ naturalRemainder + naturalRemainder
      by Natural.totality_of_less_or_equal;
  done by cases {
    case naturalRemainder + naturalRemainder ≤ 1 + k as smallRemainder: {
        -- r + r ≤ 1 + k: keep r. remainder = (r : ℤ), quotient = quotient0.
        witness quotient0 with
        witness (naturalRemainder : ℤ) with
            { 4 * (naturalRemainder : ℤ)² ≤ ((1 + k : ℕ) : ℤ)²
                  by Integer.four_square_le_from_natural;
              4 * (naturalRemainder : ℤ)² ≤ m²
                  by substituting mCast as keepBound;
              And.introduction(aEquationM, keepBound) }
      }
    case 1 + k ≤ naturalRemainder + naturalRemainder as largeRemainder: {
        -- 1 + k ≤ r + r: bump. With 1 + k = r + d, remainder = −(d : ℤ),
        -- quotient = quotient0 + 1.
        naturalRemainder ≤ 1 + k by Natural.LessThan.weaken;
        ∃ (d : ℕ). 1 + k = naturalRemainder + d by Natural.subtraction_witness as dExists;
        choose d such that 1 + k = naturalRemainder + d as mEquation from dExists;
        -- d ≤ r: from 1 + k ≤ r + r and 1 + k = r + d, cancel r.
        naturalRemainder + d = 1 + k ≤ naturalRemainder + naturalRemainder   by largeRemainder;
        d ≤ naturalRemainder;
        -- d + d ≤ r + d = 1 + k.
        d + d ≤ naturalRemainder + d   by Natural.le_add_preserves_left
              = 1 + k;
        4 * (d : ℤ)² ≤ ((1 + k : ℕ) : ℤ)²
            by Integer.four_square_le_from_natural;
        4 * (d : ℤ)² ≤ m² by substituting mCast;
        m = ((1 + k : ℕ) : ℤ)                  by mCast
          = ((naturalRemainder + d : ℕ) : ℤ)   by substituting mEquation
          = (naturalRemainder : ℤ) + (d : ℤ)
          as remainderSplit;
        (naturalRemainder : ℤ) = m - (d : ℤ)
            by substituting remainderSplit as remainderCast;
        a = m * quotient0 + (naturalRemainder : ℤ)   by aEquationM
          = m * quotient0 + (m - (d : ℤ))            by substituting remainderCast
          = m * (quotient0 + (1 : ℤ)) + (-(d : ℤ))
                by ring
          as aBalanced;
        (-(d : ℤ))² = (d : ℤ)² by ring as squareNegate;
        4 * (-(d : ℤ))² ≤ m²
            by substituting squareNegate as remainderBound;
        witness quotient0 + (1 : ℤ) with
        witness -(d : ℤ) with
            And.introduction(aBalanced, remainderBound)
      }
  }
}

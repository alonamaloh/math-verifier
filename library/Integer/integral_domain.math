-- Integer/integral_domain.math
--
-- ℤ is an integral domain: multiplication by a nonzero element cancels,
-- and a product of nonzero elements is nonzero. These are the facts the
-- field-of-fractions construction of Rational needs (transitivity of the
-- cross-multiplication equivalence, and that the product of two nonzero
-- denominators is again a valid denominator).
--
-- The cancellation reuses `Integer.multiply_cancel_right_by_positive_natural`:
-- a nonzero Integer is, by sign split, either a nonzero natural image
-- `(n : Integer)` or its negation `-(k : Integer)`; either way the positive
-- natural (`n` or `k`, at least one since the Integer is nonzero) is the
-- multiplier to cancel, and the negated case is bridged by `ring`.

module Integer.integral_domain

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Integer.order_multiply
import Integer.absolute_value
import Integer.absolute_value_natural
import Integer.cancellation
import Integer.sign
import Natural.add_order

-- Cancel a nonzero right factor: x·c = y·c with c ≠ 0 forces x = y.
theorem Integer.multiply_cancel_right_by_nonzero
        (x y c : Integer) (cNonzero : c ≠ Integer.zero)
        (productEquality : x * c = y * c)
        : x = y := {
  claim Integer.IsNonneg(c) ∨ ∃ (k : Natural). c = -(k : Integer)
      since Integer.sign_split;
  claim by cases {
    in (Integer.IsNonneg(c)) as cNonneg: {
        choose n such that c = (n : Integer) from cNonneg;
        claim n ≠ 0 by {
          suppose n = 0 as nIsZero;
          absurd(cNonzero(calc c
                             = (n : Integer)
                             = ((0 : Natural) : Integer)
                             = Integer.zero))
        };
        claim 1 ≤ n since Natural.one_le_of_nonzero;
        calc x * (n : Integer)
           = x * c
           = y * c
           = y * (n : Integer);
        done since Integer.multiply_cancel_right_by_positive_natural
      }
    in (∃ (k : Natural). c = -(k : Integer)) as cNegated: {
        choose k such that c = -(k : Integer) from cNegated;
        claim k ≠ 0 by {
          suppose k = 0 as kIsZero;
          absurd(cNonzero(calc c
                             = -(k : Integer)
                             = -((0 : Natural) : Integer)
                             = Integer.zero))
        };
        claim 1 ≤ k since Natural.one_le_of_nonzero;
        calc x * (k : Integer)
           = -(x * -(k : Integer))
           = -(x * c)
           = -(y * c)
           = -(y * -(k : Integer))
           = y * (k : Integer);
        done since Integer.multiply_cancel_right_by_positive_natural
      }
  }
}

-- 1 ≠ 0 in ℤ: the unit denominator is a valid (nonzero) denominator.
theorem Integer.one_is_nonzero : Integer.one ≠ Integer.zero := {
  suppose Integer.one = Integer.zero as oneEqualsZero;
  claim ((1 : Natural) : Integer) = ((0 : Natural) : Integer) since oneEqualsZero;
  claim 1 = (0 : Natural) since Natural.to_integer.injective;
  absurd(1 = (0 : Natural))
}

-- The product of two nonzero integers is nonzero (no zero divisors).
theorem Integer.multiply_nonzero
        (x y : Integer)
        (xNonzero : x ≠ Integer.zero) (yNonzero : y ≠ Integer.zero)
        : x * y ≠ Integer.zero := {
  suppose x * y = Integer.zero as productZero;
  calc x * y
     = Integer.zero
     = Integer.zero * y;
  claim x = Integer.zero since Integer.multiply_cancel_right_by_nonzero;
  absurd(xNonzero(x = Integer.zero))
}

-- ----------------------------------------------------------------------
-- Sign helpers for the (signed-denominator) Rational order.

-- If both x and -x are nonnegative, x = 0.
theorem Integer.nonneg_and_negate_nonneg_implies_zero
        (x : Integer)
        (xNonneg : Integer.IsNonneg(x))
        (negateNonneg : Integer.IsNonneg(-x))
        : x = Integer.zero := {
  choose m such that x = (m : Integer) from xNonneg;
  choose j such that -x = (j : Integer) from negateNonneg;
  calc ((m + j : Natural) : Integer)
     = (m : Integer) + (j : Integer)
     = x + (j : Integer)
     = x + -x
     = ((0 : Natural) : Integer);
  claim m + j = 0 since Natural.to_integer.injective;
  claim m = 0 since Natural.add_eq_zero_implies_left_zero;
  calc x
     = (m : Integer)
     = ((0 : Natural) : Integer)
     = Integer.zero
}

-- Cancel a positive factor from a nonnegativity: if a·p ≥ 0 with p ≥ 0 and
-- p ≠ 0 (so p > 0), then a ≥ 0.
theorem Integer.IsNonneg_of_product_with_positive
        (a p : Integer)
        (productNonneg : Integer.IsNonneg(a * p))
        (pNonneg : Integer.IsNonneg(p))
        (pNonzero : p ≠ Integer.zero)
        : Integer.IsNonneg(a) := {
  claim Integer.IsNonneg(a) ∨ ∃ (k : Natural). a = -(k : Integer)
      since Integer.sign_split;
  claim by cases {
    in (Integer.IsNonneg(a)) as aNonneg: aNonneg
    in (∃ (k : Natural). a = -(k : Integer)) as aNegated: {
        choose k such that a = -(k : Integer) from aNegated;
        claim Integer.IsNonneg((k : Integer)) since Integer.from_natural_is_nonneg;
        claim Integer.IsNonneg((k : Integer) * p) since Integer.multiply_nonneg;
        calc a * p
           = -(k : Integer) * p
           = -((k : Integer) * p)   as productForm;
        claim Integer.IsNonneg(-((k : Integer) * p)) by substituting productForm;
        claim (k : Integer) * p = Integer.zero
            since Integer.nonneg_and_negate_nonneg_implies_zero;
        calc (k : Integer) * p
           = Integer.zero
           = Integer.zero * p;
        claim (k : Integer) = Integer.zero
            since Integer.multiply_cancel_right_by_nonzero;
        calc a
           = -(k : Integer)
           = -(Integer.zero)
           = Integer.zero       as aIsZero;
        done by substituting aIsZero
    }
  }
}

-- ----------------------------------------------------------------------
-- Absolute value and nonzero-ness (for |n/d| = |n|/|d| on Rational).

-- |x| = 0 forces x = 0.
theorem Integer.absolute_value_eq_zero_implies_zero
        (x : Integer) (absoluteValueZero : abs(x) = Integer.zero)
        : x = Integer.zero := {
  claim Integer.IsNonneg(x) ∨ ∃ (k : Natural). x = -(k : Integer)
      since Integer.sign_split;
  claim by cases {
    in (Integer.IsNonneg(x)) as xNonneg: {
        choose k such that x = (k : Integer) from xNonneg;
        calc x
           = (k : Integer)
           = abs((k : Integer))   since Integer.absolute_value_of_natural
           = abs(x)
           = Integer.zero
      }
    in (∃ (k : Natural). x = -(k : Integer)) as xNegated: {
        choose k such that x = -(k : Integer) from xNegated;
        calc (k : Integer)
           = abs(-(k : Integer))   since Integer.absolute_value_negate
           = Integer.zero;
        calc x
           = -(k : Integer)
           = -(Integer.zero)
           = Integer.zero
      }
  }
}

-- |x| ≠ 0 when x ≠ 0.
theorem Integer.absolute_value_nonzero
        (x : Integer) (xNonzero : x ≠ Integer.zero)
        : abs(x) ≠ Integer.zero := {
  suppose abs(x) = Integer.zero as absoluteValueZero;
  claim x = Integer.zero since Integer.absolute_value_eq_zero_implies_zero;
  absurd(xNonzero(x = Integer.zero))
}

-- A successor-natural image is a valid (nonzero) denominator: the common
-- case for denominators built from positive naturals.
theorem Integer.from_natural_successor_nonzero (k : Natural)
        : (successor(k) : Integer) ≠ Integer.zero := {
  suppose (successor(k) : Integer) = Integer.zero as castZero;
  calc ((successor(k) : Natural) : Integer)
     = Integer.zero
     = ((0 : Natural) : Integer);
  claim successor(k) = (0 : Natural) since Natural.to_integer.injective;
  absurd(successor(k) = (0 : Natural))
}

-- Same fact stated in `1 + n` form, so consumers never need to spell
-- `successor` in fraction denominators. (`Natural.add` is opaque, so
-- `1 + k` is not definitionally `successor(k)`; bridge via `Natural.one_add`.)
theorem Integer.one_plus_natural_nonzero (k : Natural)
        : ((1 + k) : Integer) ≠ Integer.zero := {
  suppose ((1 + k) : Integer) = Integer.zero as castZero;
  calc ((1 + k) : Integer)
     = Integer.zero
     = ((0 : Natural) : Integer);
  claim 1 + k = (0 : Natural) since Natural.to_integer.injective;
  calc successor(k)
     = 1 + k          since Natural.one_add
     = (0 : Natural);
  absurd(successor(k) = (0 : Natural))
}

-- |x| ≥ 0: the absolute value is the image of a natural.
theorem Integer.absolute_value_is_nonneg (x : Integer)
        : Integer.IsNonneg(abs(x)) := {
  claim imageForm : abs(x) = (Integer.absolute_value_natural(x) : Integer)
      since Integer.absolute_value_natural_is_image;
  claim Integer.IsNonneg((Integer.absolute_value_natural(x) : Integer))
      since Integer.from_natural_is_nonneg;
  done by substituting imageForm
}

-- |d| ≥ 1 when d ≠ 0 (as IsNonneg(|d| − 1)): the absolute value of a nonzero
-- integer is a positive natural image, so subtracting one stays non-negative.
theorem Integer.absolute_value_minus_one_nonneg
        (d : Integer) (dNonzero : d ≠ Integer.zero)
        : Integer.IsNonneg(abs(d) + -Integer.one) := {
  claim abs(d) = (Integer.absolute_value_natural(d) : Integer)
      since Integer.absolute_value_natural_is_image;
  claim absoluteNaturalNonzero : Integer.absolute_value_natural(d) ≠ 0 by {
      suppose Integer.absolute_value_natural(d) = 0 as absoluteNaturalZero;
      calc abs(d)
         = (Integer.absolute_value_natural(d) : Integer)
         = ((0 : Natural) : Integer)
         = Integer.zero;
      claim d = Integer.zero since Integer.absolute_value_eq_zero_implies_zero;
      absurd(dNonzero(d = Integer.zero))
  };
  claim Integer.absolute_value_natural(d) = 0
          ∨ ∃ (k : Natural). Integer.absolute_value_natural(d) = k + 1
      since Natural.zero_or_add_one;
  claim by cases {
    in (Integer.absolute_value_natural(d) = 0) as isZero: absurd(absoluteNaturalNonzero(isZero))
    in (∃ (k : Natural). Integer.absolute_value_natural(d) = k + 1) as isSuccessor: {
        choose j such that Integer.absolute_value_natural(d) = j + 1 from isSuccessor;
        witness j with
            calc abs(d) + -Integer.one
               = (Integer.absolute_value_natural(d) : Integer) + -Integer.one
               = ((j + 1 : Natural) : Integer) + -Integer.one
               = ((j : Integer) + Integer.one) + -Integer.one
                     since Natural.to_integer.add_one_preserves
               = (j : Integer)
      }
  }
}

-- The magnitude of a nonzero integer is a positive natural.
theorem Integer.absolute_value_natural_positive_of_nonzero
        (d : Integer) (dNonzero : d ≠ Integer.zero)
        : 1 ≤ Integer.absolute_value_natural(d) := {
  claim Integer.absolute_value_natural(d) = 0
          ∨ ∃ (k : Natural). Integer.absolute_value_natural(d) = k + 1
      since Natural.zero_or_add_one;
  claim by cases {
    in (Integer.absolute_value_natural(d) = 0) as isZero: {
        calc abs(d)
           = (Integer.absolute_value_natural(d) : Integer)  since Integer.absolute_value_natural_is_image
           = ((0 : Natural) : Integer)
           = Integer.zero;
        claim d = Integer.zero since Integer.absolute_value_eq_zero_implies_zero;
        absurd(dNonzero(d = Integer.zero))
      }
    in (∃ (k : Natural). Integer.absolute_value_natural(d) = k + 1) as isSuccessor: {
        choose j such that Integer.absolute_value_natural(d) = j + 1 from isSuccessor;
        calc (1 : Natural)
           ≤ j + 1                                since Natural.one_le_add_one
           = Integer.absolute_value_natural(d)
      }
  }
}

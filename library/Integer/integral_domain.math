-- Integer/integral_domain.math
--
-- ℤ is an integral domain: multiplication by a nonzero element cancels,
-- and a product of nonzero elements is nonzero. These are the facts the
-- field-of-fractions construction of Rational needs (transitivity of the
-- cross-multiplication equivalence, and that the product of two nonzero
-- denominators is again a valid denominator).
--
-- The cancellation reuses `Integer.multiply_cancel_right_by_positive_natural`:
-- a nonzero Integer is, by sign split, either a nonzero natural image
-- `(n : ℤ)` or its negation `-(k : ℤ)`; either way the positive
-- natural (`n` or `k`, at least one since the Integer is nonzero) is the
-- multiplier to cancel, and the negated case is bridged by `ring`.

module Integer.integral_domain

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Integer.order_multiply
import Integer.absolute_value
import Integer.absolute_value_natural
import Integer.cancellation
import Integer.sign
import Natural.add_order

-- Cancel a nonzero right factor: x·c = y·c with c ≠ 0 forces x = y.
theorem Integer.multiply_cancel_right_by_nonzero
        (x y c : ℤ) (cNonzero : c ≠ Integer.zero)
        (productEquality : x * c = y * c)
        : x = y := {
  Integer.IsNonneg(c) ∨ ∃ (k : ℕ). c = -(k : ℤ)
      by Integer.sign_split;
  done by cases {
    case Integer.IsNonneg(c) as cNonneg: {
        choose n such that c = (n : ℤ) from cNonneg;
        n ≠ 0 by {
          suppose n = 0 as nIsZero;
          c = (n : ℤ)
            = ((0 : ℕ) : ℤ)
            = Integer.zero;
          done
        };
        1 ≤ n;
        x * (n : ℤ)
           = x * c
           = y * c
           = y * (n : ℤ);
        done by Integer.multiply_cancel_right_by_positive_natural
      }
    case ∃ (k : ℕ). c = -(k : ℤ) as cNegated: {
        choose k such that c = -(k : ℤ) from cNegated;
        k ≠ 0 by {
          suppose k = 0 as kIsZero;
          c = -(k : ℤ)
            = -((0 : ℕ) : ℤ)
            = Integer.zero;
          done
        };
        1 ≤ k;
        x * (k : ℤ)
           = -(x * -(k : ℤ))
           = -(x * c)
           = -(y * c)
           = -(y * -(k : ℤ))
           = y * (k : ℤ);
        done by Integer.multiply_cancel_right_by_positive_natural
      }
  }
}

-- 1 ≠ 0 in ℤ: the unit denominator is a valid (nonzero) denominator.
theorem Integer.one_is_nonzero : Integer.one ≠ Integer.zero := {
  suppose Integer.one = Integer.zero as oneEqualsZero;
  ((1 : ℕ) : ℤ) = ((0 : ℕ) : ℤ);
  1 = (0 : ℕ);
  absurd(1 = (0 : ℕ))
}

-- The product of two nonzero integers is nonzero (no zero divisors).
theorem Integer.multiply_nonzero
        (x y : ℤ)
        (xNonzero : x ≠ Integer.zero) (yNonzero : y ≠ Integer.zero)
        : x * y ≠ Integer.zero := {
  suppose x * y = Integer.zero as productZero;
  x * y
     = Integer.zero
     = Integer.zero * y;
  x = Integer.zero;
  absurd(xNonzero(x = Integer.zero))
}

-- ----------------------------------------------------------------------
-- Sign helpers for the (signed-denominator) Rational order.

-- If both x and -x are nonnegative, x = 0.
theorem Integer.nonneg_and_negate_nonneg_implies_zero
        (x : ℤ)
        (xNonneg : Integer.IsNonneg(x))
        (negateNonneg : Integer.IsNonneg(-x))
        : x = Integer.zero := {
  choose m such that x = (m : ℤ) from xNonneg;
  choose j such that -x = (j : ℤ) from negateNonneg;
  ((m + j : ℕ) : ℤ)
     = (m : ℤ) + (j : ℤ)
     = x + (j : ℤ)
     = x + -x
     = ((0 : ℕ) : ℤ);
  m + j = 0;
  m = 0;
  x
     = (m : ℤ)
     = ((0 : ℕ) : ℤ)
     = Integer.zero
}

-- Cancel a positive factor from a nonnegativity: if a·p ≥ 0 with p ≥ 0 and
-- p ≠ 0 (so p > 0), then a ≥ 0.
theorem Integer.IsNonneg_of_product_with_positive
        (a p : ℤ)
        (productNonneg : Integer.IsNonneg(a * p))
        (pNonneg : Integer.IsNonneg(p))
        (pNonzero : p ≠ Integer.zero)
        : Integer.IsNonneg(a) := {
  Integer.IsNonneg(a) ∨ ∃ (k : ℕ). a = -(k : ℤ)
      by Integer.sign_split;
  done by cases {
    case Integer.IsNonneg(a) as aNonneg: aNonneg
    case ∃ (k : ℕ). a = -(k : ℤ) as aNegated: {
        choose k such that a = -(k : ℤ) from aNegated;
        Integer.IsNonneg((k : ℤ));
        Integer.IsNonneg((k : ℤ) * p);
        a * p
           = -(k : ℤ) * p
           = -((k : ℤ) * p);
        Integer.IsNonneg(-((k : ℤ) * p));
        (k : ℤ) * p = Integer.zero;
        (k : ℤ) * p
           = Integer.zero
           = Integer.zero * p;
        (k : ℤ) = Integer.zero
            by Integer.multiply_cancel_right_by_nonzero;
        a
           = -(k : ℤ)
           = -(Integer.zero)
           = Integer.zero;
        done
    }
  }
}

-- ----------------------------------------------------------------------
-- Absolute value and nonzero-ness (for |n/d| = |n|/|d| on Rational).

-- |x| = 0 forces x = 0.
theorem Integer.absolute_value_eq_zero_implies_zero
        (x : ℤ) (absoluteValueZero : abs(x) = Integer.zero)
        : x = Integer.zero := {
  Integer.IsNonneg(x) ∨ ∃ (k : ℕ). x = -(k : ℤ)
      by Integer.sign_split;
  done by cases {
    case Integer.IsNonneg(x) as xNonneg: {
        choose k such that x = (k : ℤ) from xNonneg;
        x
           = (k : ℤ)
           = abs((k : ℤ))
           = abs(x)
           = Integer.zero
      }
    case ∃ (k : ℕ). x = -(k : ℤ) as xNegated: {
        choose k such that x = -(k : ℤ) from xNegated;
        (k : ℤ)
           = abs(-(k : ℤ))
           = Integer.zero;
        x
           = -(k : ℤ)
           = -(Integer.zero)
           = Integer.zero
      }
  }
}

-- |x| ≠ 0 when x ≠ 0.
theorem Integer.absolute_value_nonzero
        (x : ℤ) (xNonzero : x ≠ Integer.zero)
        : abs(x) ≠ Integer.zero := {
  suppose abs(x) = Integer.zero as absoluteValueZero;
  x = Integer.zero;
  absurd(xNonzero(x = Integer.zero))
}

-- The image of a nonzero natural is a valid (nonzero) denominator: the
-- common case for denominators built from positive naturals.
theorem Integer.from_natural_nonzero (k : ℕ) (nonzero : ¬(k = 0))
        : (k : ℤ) ≠ Integer.zero := {
  suppose (k : ℤ) = Integer.zero as castZero;
  ((k : ℕ) : ℤ)
     = Integer.zero
     = ((0 : ℕ) : ℤ);
  k = (0 : ℕ) as kZero;
  nonzero(kZero)
}

-- The same fact in `1 + n` form, so consumers never need to spell the
-- constructor in fraction denominators (`1 + k` is never zero — its left
-- summand `1` is not).
theorem Integer.one_plus_natural_nonzero (k : ℕ)
        : ((1 + k) : ℤ) ≠ Integer.zero := {
  ¬((1 + k : ℕ) = 0);
  done
}

-- The `k + 1` form of the nonzero-denominator fact, for StrictPositiveRational
-- and other (k + 1)-shaped denominators.
automatic theorem Integer.from_natural_add_one_nonzero (k : ℕ)
        : ((k + 1) : ℤ) ≠ Integer.zero := {
  k + 1 = 1 + k;
  ((1 + k) : ℤ) ≠ Integer.zero;
  done
}

-- a < b are distinct: a = b would give a + 1 ≤ a, i.e. a = (a + 1) + n for some
-- natural n, so 1 + n = 0 — impossible. (Lives here, not in Integer/order, for
-- the `one_plus_natural_nonzero` witness of the contradiction.)
theorem Integer.LessThan.distinct (a b : ℤ) (aLessThanB : a < b) : a ≠ b := {
  suppose a = b for contradiction {
    a + Integer.one ≤ b;
    a + Integer.one ≤ a as successorBoundSelf;
    choose n such that a = (a + Integer.one) + (n : ℤ)
        from successorBoundSelf;
    Integer.one + (n : ℤ)
       = ((a + Integer.one) + (n : ℤ)) - a
       = a - a
       = Integer.zero;
    ((1 + n) : ℤ)
       = Integer.one + (n : ℤ)
       = Integer.zero;
    ((1 + n) : ℤ) ≠ Integer.zero;
    done
  }
}

-- |x| ≥ 0: the absolute value is the image of a natural.
automatic theorem Integer.absolute_value_is_nonneg (x : ℤ)
        : Integer.IsNonneg(abs(x)) := {
  abs(x) = (Integer.absolute_value_natural(x) : ℤ);
  Integer.IsNonneg((Integer.absolute_value_natural(x) : ℤ));
  done
}

-- |d| ≥ 1 when d ≠ 0 (as IsNonneg(|d| − 1)): the absolute value of a nonzero
-- integer is a positive natural image, so subtracting one stays non-negative.
theorem Integer.absolute_value_minus_one_nonneg
        (d : ℤ) (dNonzero : d ≠ Integer.zero)
        : Integer.IsNonneg(abs(d) + -Integer.one) := {
  abs(d) = (Integer.absolute_value_natural(d) : ℤ);
  Integer.absolute_value_natural(d) ≠ 0 by {
      suppose Integer.absolute_value_natural(d) = 0 as absoluteNaturalZero;
      abs(d)
         = (Integer.absolute_value_natural(d) : ℤ)
         = ((0 : ℕ) : ℤ)
         = Integer.zero;
      d = Integer.zero;
      absurd(dNonzero(d = Integer.zero))
  };
  Integer.absolute_value_natural(d) = 0
    ∨ ∃ (k : ℕ). Integer.absolute_value_natural(d) = k + 1;
  ∃ (k : ℕ). Integer.absolute_value_natural(d) = k + 1 as isSuccessor;
  choose j such that Integer.absolute_value_natural(d) = j + 1 from isSuccessor;
  witness j with
      abs(d) + -Integer.one
         = (Integer.absolute_value_natural(d) : ℤ) + -Integer.one
         = ((j + 1 : ℕ) : ℤ) + -Integer.one
         = ((j : ℤ) + Integer.one) + -Integer.one
         = (j : ℤ)
}

-- The magnitude of a nonzero integer is a positive natural.
theorem Integer.absolute_value_natural_positive_of_nonzero
        (d : ℤ) (dNonzero : d ≠ Integer.zero)
        : 1 ≤ Integer.absolute_value_natural(d) := {
  Integer.absolute_value_natural(d) = 0
    ∨ ∃ (k : ℕ). Integer.absolute_value_natural(d) = k + 1;
  done by cases {
    case Integer.absolute_value_natural(d) = 0 as isZero: {
        abs(d)
           = (Integer.absolute_value_natural(d) : ℤ)
           = ((0 : ℕ) : ℤ)
           = Integer.zero;
        d = Integer.zero;
        absurd(dNonzero(d = Integer.zero))
      }
    case ∃ (k : ℕ). Integer.absolute_value_natural(d) = k + 1 as isSuccessor: {
        choose j such that Integer.absolute_value_natural(d) = j + 1 from isSuccessor;
        (1 : ℕ)
           ≤ j + 1
           = Integer.absolute_value_natural(d)
      }
  }
}

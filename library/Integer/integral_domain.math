-- Integer/integral_domain.math
--
-- ℤ is an integral domain: multiplication by a nonzero element cancels,
-- and a product of nonzero elements is nonzero. These are the facts the
-- field-of-fractions construction of Rational needs (transitivity of the
-- cross-multiplication equivalence, and that the product of two nonzero
-- denominators is again a valid denominator).
--
-- The cancellation reuses `Integer.multiply_cancel_right_by_positive_natural`:
-- a nonzero Integer is, by sign split, either a nonzero natural image
-- `(n : Integer)` or its negation `-(k : Integer)`; either way the positive
-- natural (`n` or `k`, at least one since the Integer is nonzero) is the
-- multiplier to cancel, and the negated case is bridged by `ring`.

module Integer.integral_domain

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Integer.order_multiply
import Integer.absolute_value
import Integer.absolute_value_natural
import Integer.cancellation
import Integer.sign
import Natural.add_order

-- Cancel a nonzero right factor: x·c = y·c with c ≠ 0 forces x = y.
theorem Integer.multiply_cancel_right_by_nonzero
        (x y c : Integer) (cNonzero : c ≠ Integer.zero)
        (productEquality : x * c = y * c)
        : x = y := {
  Integer.IsNonneg(c) ∨ ∃ (k : Natural). c = -(k : Integer)
      by Integer.sign_split;
  done by cases {
    case Integer.IsNonneg(c) as cNonneg: {
        choose n such that c = (n : Integer) from cNonneg;
        n ≠ 0 by {
          suppose n = 0 as nIsZero;
          c = (n : Integer)
            = ((0 : Natural) : Integer)
            = Integer.zero;
          done
        };
        1 ≤ n;
        x * (n : Integer)
           = x * c
           = y * c
           = y * (n : Integer);
        done by Integer.multiply_cancel_right_by_positive_natural
      }
    case ∃ (k : Natural). c = -(k : Integer) as cNegated: {
        choose k such that c = -(k : Integer) from cNegated;
        k ≠ 0 by {
          suppose k = 0 as kIsZero;
          c = -(k : Integer)
            = -((0 : Natural) : Integer)
            = Integer.zero;
          done
        };
        1 ≤ k;
        x * (k : Integer)
           = -(x * -(k : Integer))
           = -(x * c)
           = -(y * c)
           = -(y * -(k : Integer))
           = y * (k : Integer);
        done by Integer.multiply_cancel_right_by_positive_natural
      }
  }
}

-- 1 ≠ 0 in ℤ: the unit denominator is a valid (nonzero) denominator.
theorem Integer.one_is_nonzero : Integer.one ≠ Integer.zero := {
  suppose Integer.one = Integer.zero as oneEqualsZero;
  ((1 : Natural) : Integer) = ((0 : Natural) : Integer);
  1 = (0 : Natural);
  absurd(1 = (0 : Natural))
}

-- The product of two nonzero integers is nonzero (no zero divisors).
theorem Integer.multiply_nonzero
        (x y : Integer)
        (xNonzero : x ≠ Integer.zero) (yNonzero : y ≠ Integer.zero)
        : x * y ≠ Integer.zero := {
  suppose x * y = Integer.zero as productZero;
  x * y
     = Integer.zero
     = Integer.zero * y;
  x = Integer.zero;
  absurd(xNonzero(x = Integer.zero))
}

-- ----------------------------------------------------------------------
-- Sign helpers for the (signed-denominator) Rational order.

-- If both x and -x are nonnegative, x = 0.
theorem Integer.nonneg_and_negate_nonneg_implies_zero
        (x : Integer)
        (xNonneg : Integer.IsNonneg(x))
        (negateNonneg : Integer.IsNonneg(-x))
        : x = Integer.zero := {
  choose m such that x = (m : Integer) from xNonneg;
  choose j such that -x = (j : Integer) from negateNonneg;
  ((m + j : Natural) : Integer)
     = (m : Integer) + (j : Integer)
     = x + (j : Integer)
     = x + -x
     = ((0 : Natural) : Integer);
  m + j = 0;
  m = 0;
  x
     = (m : Integer)
     = ((0 : Natural) : Integer)
     = Integer.zero
}

-- Cancel a positive factor from a nonnegativity: if a·p ≥ 0 with p ≥ 0 and
-- p ≠ 0 (so p > 0), then a ≥ 0.
theorem Integer.IsNonneg_of_product_with_positive
        (a p : Integer)
        (productNonneg : Integer.IsNonneg(a * p))
        (pNonneg : Integer.IsNonneg(p))
        (pNonzero : p ≠ Integer.zero)
        : Integer.IsNonneg(a) := {
  Integer.IsNonneg(a) ∨ ∃ (k : Natural). a = -(k : Integer)
      by Integer.sign_split;
  done by cases {
    case Integer.IsNonneg(a) as aNonneg: aNonneg
    case ∃ (k : Natural). a = -(k : Integer) as aNegated: {
        choose k such that a = -(k : Integer) from aNegated;
        Integer.IsNonneg((k : Integer));
        Integer.IsNonneg((k : Integer) * p);
        a * p
           = -(k : Integer) * p
           = -((k : Integer) * p)   as productForm;
        Integer.IsNonneg(-((k : Integer) * p)) by substituting productForm;
        (k : Integer) * p = Integer.zero;
        (k : Integer) * p
           = Integer.zero
           = Integer.zero * p;
        (k : Integer) = Integer.zero
            by Integer.multiply_cancel_right_by_nonzero;
        a
           = -(k : Integer)
           = -(Integer.zero)
           = Integer.zero       as aIsZero;
        done by substituting aIsZero
    }
  }
}

-- ----------------------------------------------------------------------
-- Absolute value and nonzero-ness (for |n/d| = |n|/|d| on Rational).

-- |x| = 0 forces x = 0.
theorem Integer.absolute_value_eq_zero_implies_zero
        (x : Integer) (absoluteValueZero : abs(x) = Integer.zero)
        : x = Integer.zero := {
  Integer.IsNonneg(x) ∨ ∃ (k : Natural). x = -(k : Integer)
      by Integer.sign_split;
  done by cases {
    case Integer.IsNonneg(x) as xNonneg: {
        choose k such that x = (k : Integer) from xNonneg;
        x
           = (k : Integer)
           = abs((k : Integer))
           = abs(x)
           = Integer.zero
      }
    case ∃ (k : Natural). x = -(k : Integer) as xNegated: {
        choose k such that x = -(k : Integer) from xNegated;
        (k : Integer)
           = abs(-(k : Integer))
           = Integer.zero;
        x
           = -(k : Integer)
           = -(Integer.zero)
           = Integer.zero
      }
  }
}

-- |x| ≠ 0 when x ≠ 0.
theorem Integer.absolute_value_nonzero
        (x : Integer) (xNonzero : x ≠ Integer.zero)
        : abs(x) ≠ Integer.zero := {
  suppose abs(x) = Integer.zero as absoluteValueZero;
  x = Integer.zero;
  absurd(xNonzero(x = Integer.zero))
}

-- The image of a nonzero natural is a valid (nonzero) denominator: the
-- common case for denominators built from positive naturals.
theorem Integer.from_natural_nonzero (k : Natural) (nonzero : ¬(k = 0))
        : (k : Integer) ≠ Integer.zero := {
  suppose (k : Integer) = Integer.zero as castZero;
  ((k : Natural) : Integer)
     = Integer.zero
     = ((0 : Natural) : Integer);
  k = (0 : Natural) as kZero;
  nonzero(kZero)
}

-- The same fact in `1 + n` form, so consumers never need to spell the
-- constructor in fraction denominators (`1 + k` is never zero — its left
-- summand `1` is not).
theorem Integer.one_plus_natural_nonzero (k : Natural)
        : ((1 + k) : Integer) ≠ Integer.zero := {
  ¬((1 + k : Natural) = 0)
      by (isZero : (1 + k : Natural) = 0) ↦ {
           (1 : Natural) = 0 as oneZero;
           absurd(oneZero)
         };
  done
}

-- The `k + 1` form of the nonzero-denominator fact, for StrictPositiveRational
-- and other (k + 1)-shaped denominators.
automatic theorem Integer.from_natural_add_one_nonzero (k : Natural)
        : ((k + 1) : Integer) ≠ Integer.zero := {
  k + 1 = 1 + k as kAddOne;
  ((1 + k) : Integer) ≠ Integer.zero;
  done by substituting kAddOne
}

-- a < b are distinct: a = b would give a + 1 ≤ a, i.e. a = (a + 1) + n for some
-- natural n, so 1 + n = 0 — impossible. (Lives here, not in Integer/order, for
-- the `one_plus_natural_nonzero` witness of the contradiction.)
theorem Integer.LessThan.distinct (a b : Integer) (aLessThanB : a < b) : a ≠ b := {
  suppose a = b for contradiction {
    a + Integer.one ≤ b;
    a + Integer.one ≤ a by substituting (a = b) as successorBoundSelf;
    choose n such that a = (a + Integer.one) + (n : Integer) as chooseEquation
        from successorBoundSelf;
    Integer.one + (n : Integer)
       = ((a + Integer.one) + (n : Integer)) - a
       = a - a   by substituting chooseEquation
       = Integer.zero
       as sumZero;
    ((1 + n) : Integer)
       = ((1 : Natural) : Integer) + ((n : Natural) : Integer)
       = Integer.one + (n : Integer)
       = Integer.zero by sumZero;
    ((1 + n) : Integer) ≠ Integer.zero;
    done
  }
}

-- |x| ≥ 0: the absolute value is the image of a natural.
automatic theorem Integer.absolute_value_is_nonneg (x : Integer)
        : Integer.IsNonneg(abs(x)) := {
  abs(x) = (Integer.absolute_value_natural(x) : Integer) as imageForm;
  Integer.IsNonneg((Integer.absolute_value_natural(x) : Integer));
  done by substituting imageForm
}

-- |d| ≥ 1 when d ≠ 0 (as IsNonneg(|d| − 1)): the absolute value of a nonzero
-- integer is a positive natural image, so subtracting one stays non-negative.
theorem Integer.absolute_value_minus_one_nonneg
        (d : Integer) (dNonzero : d ≠ Integer.zero)
        : Integer.IsNonneg(abs(d) + -Integer.one) := {
  abs(d) = (Integer.absolute_value_natural(d) : Integer);
  Integer.absolute_value_natural(d) ≠ 0 by {
      suppose Integer.absolute_value_natural(d) = 0 as absoluteNaturalZero;
      abs(d)
         = (Integer.absolute_value_natural(d) : Integer)
         = ((0 : Natural) : Integer)
         = Integer.zero;
      d = Integer.zero;
      absurd(dNonzero(d = Integer.zero))
  } as absoluteNaturalNonzero;
  Integer.absolute_value_natural(d) = 0
    ∨ ∃ (k : Natural). Integer.absolute_value_natural(d) = k + 1
      by Natural.zero_or_add_one;
  done by cases {
    case Integer.absolute_value_natural(d) = 0 as isZero: absurd(absoluteNaturalNonzero(isZero))
    case ∃ (k : Natural). Integer.absolute_value_natural(d) = k + 1 as isSuccessor: {
        choose j such that Integer.absolute_value_natural(d) = j + 1 from isSuccessor;
        witness j with
            abs(d) + -Integer.one
               = (Integer.absolute_value_natural(d) : Integer) + -Integer.one
               = ((j + 1 : Natural) : Integer) + -Integer.one
               = ((j : Integer) + Integer.one) + -Integer.one
                     by Natural.to_integer.add_one_preserves
               = (j : Integer)
      }
  }
}

-- The magnitude of a nonzero integer is a positive natural.
theorem Integer.absolute_value_natural_positive_of_nonzero
        (d : Integer) (dNonzero : d ≠ Integer.zero)
        : 1 ≤ Integer.absolute_value_natural(d) := {
  Integer.absolute_value_natural(d) = 0
    ∨ ∃ (k : Natural). Integer.absolute_value_natural(d) = k + 1
      by Natural.zero_or_add_one;
  done by cases {
    case Integer.absolute_value_natural(d) = 0 as isZero: {
        abs(d)
           = (Integer.absolute_value_natural(d) : Integer)
           = ((0 : Natural) : Integer)
           = Integer.zero;
        d = Integer.zero;
        absurd(dNonzero(d = Integer.zero))
      }
    case ∃ (k : Natural). Integer.absolute_value_natural(d) = k + 1 as isSuccessor: {
        choose j such that Integer.absolute_value_natural(d) = j + 1 from isSuccessor;
        (1 : Natural)
           ≤ j + 1                                by Natural.one_le_add_one
           = Integer.absolute_value_natural(d)
      }
  }
}

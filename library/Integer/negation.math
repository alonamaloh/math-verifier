-- Integer/negation.math
--
-- Negation and subtraction on Integer. Negation swaps the components
-- of a representative (`(a, b)` becomes `(b, a)`, i.e. the difference
-- `a - b` becomes `b - a`). Subtraction is defined the usual way:
-- `x - y := x + (-y)`. With negation the additive monoid from
-- Integer/ring.math becomes a commutative group; we close with
-- `add_negate_left` / `add_negate_right` (the inverse identities).

module Integer.negation

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Integer.basics
import Integer.addition
import Integer.ring

-- ----------------------------------------------------------------------
-- Negation on representatives: swap components.
definition Integer.negate_representatives
        : IntegerRepresentative → IntegerRepresentative
  | IntegerRepresentative.make(a, b) =>
      IntegerRepresentative.make(b, a)

-- Respect: if `(a, b) ~ (a', b')` then `(b, a) ~ (b', a')`. Both
-- equivalence statements unfold to the same Natural-level equation
-- modulo `Equality.symmetry`.
theorem Integer.negate_respects
        : ∀ (rep1 rep2 : IntegerRepresentative).
          IntegerEquivalent(rep1, rep2)
          → IntegerEquivalent(
                Integer.negate_representatives(rep1),
                Integer.negate_representatives(rep2))
  | IntegerRepresentative.make(a, b),
    IntegerRepresentative.make(aPrime, bPrime),
    eq =>
      done since Equality.symmetry

-- ----------------------------------------------------------------------
-- Negation on Integer: negate the representative; well-defined because
-- negation respects the difference-pair equivalence.
definition Integer.negate : Integer → Integer
  by representatives rep ↦ Quotient.class_of(Integer.negate_representatives(rep))
  well_defined by Integer.negate_respects

-- ----------------------------------------------------------------------
-- Subtraction: x − y = x + (−y).
definition Integer.subtract (x y : Integer) : Integer :=
  x + -y

-- ----------------------------------------------------------------------
-- Inverse identities: x + (−x) = 0 and (−x) + x = 0.

-- Natural-level kernel: at rep (a, b) the LHS reduces to mk(make(b + a,
-- a + b)) and Integer.zero is mk(make(zero, zero)). Equivalence
-- requires (b + a) + zero = (a + b) + zero, which reduces to b + a =
-- a + b via add_zero on both sides.
theorem Integer.add_negate_left_natural (a b : Natural)
        : (b + a) + 0 = (a + b) + 0 :=
  calc (b + a) + 0
     = b + a
     = a + b
     = (a + b) + 0

theorem Integer.add_negate_left (x : Integer)
        : -x + x = Integer.zero :=
  by_representatives x as ⟨a, b⟩ =>
      Integer.add_negate_left_natural(a, b)

-- Right inverse: derived via commutativity.
theorem Integer.add_negate_right (x : Integer)
        : x + -x = Integer.zero :=
  calc x + -x
     = -x + x
     = Integer.zero

-- Operator overload: `-` on Integers routes here.
operator (-) on (Integer, Integer) := Integer.subtract

-- Integer/order_multiply.math
--
-- Order interacts with multiplication by a Natural image: it is monotone,
-- and cancellable when the multiplier is positive. These are the two facts
-- the Gaussian Euclidean-division bound needs (scale the remainder bound by
-- N(b), then cancel N(b)² to land at 2·N(ρ) ≤ N(β)).
--
-- `x ≤ y` on ℤ is `∃n. y = x + (n:ℤ)`, which is equivalent to — but not
-- definitionally equal to — `IsNonneg(y − x)`; the two bridge lemmas below
-- move between the forms so the non-negativity machinery can be reused.

module Integer.order_multiply

import Logic.basics
import Logic.exists
import Logic.sum
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.cancellation
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.embedding
import Integer.order
import Integer.sign
import Integer.sum_of_squares

-- The product of two non-negative integers is non-negative.
automatic theorem Integer.multiply_nonneg (a b : ℤ)
        (aNonneg : Integer.IsNonneg(a)) (bNonneg : Integer.IsNonneg(b))
        : Integer.IsNonneg(a * b) := {
  choose j such that a = (j : ℤ) from aNonneg;
  choose k such that b = (k : ℤ) from bNonneg;
  witness j * k with
      a * b
         = (j : ℤ) * (k : ℤ)
         = ((j * k : ℕ) : ℤ)
}

-- x ≤ y ⟹ y − x is non-negative.
theorem Integer.nonneg_difference_of_le (x y : ℤ) (xLeY : x ≤ y)
        : Integer.IsNonneg(y - x) := {
  choose n such that y = x + (n : ℤ) from xLeY;
  witness n with
      y - x
         = (x + (n : ℤ)) - x
         = (n : ℤ)
}

-- y − x non-negative ⟹ x ≤ y.
theorem Integer.le_of_nonneg_difference (x y : ℤ) (differenceNonneg : Integer.IsNonneg(y - x))
        : x ≤ y := {
  choose n such that y - x = (n : ℤ) from differenceNonneg;
  witness n with
      y
         = (y - x) + x
         = (n : ℤ) + x
         = x + (n : ℤ)
}

-- Multiplying both sides by a Natural image preserves ≤.
theorem Integer.multiply_le_by_natural (m : ℕ) (x y : ℤ) (xLeY : x ≤ y)
        : (m : ℤ) * x ≤ (m : ℤ) * y := {
  Integer.IsNonneg((m : ℤ));
  Integer.IsNonneg(y - x);
  Integer.IsNonneg((m : ℤ) * (y - x));
  Integer.IsNonneg((m : ℤ) * y - (m : ℤ) * x);
  done
}

-- Cancelling a positive Natural multiplier reflects ≤.
theorem Integer.cancel_le_by_natural_positive (m : ℕ) (mPositive : 1 ≤ m)
        (x y : ℤ) (productLe : (m : ℤ) * x ≤ (m : ℤ) * y) : x ≤ y := {
  Integer.IsNonneg((m : ℤ) * y - (m : ℤ) * x);
  Integer.IsNonneg((m : ℤ) * (y - x));
  Integer.IsNonneg(y - x) ∨ ∃ (k : ℕ). (y - x) = -(k : ℤ)
      by Integer.sign_split;
  done by cases {
    case Integer.IsNonneg(y - x) as nonnegative: done
    case ∃ (k : ℕ). (y - x) = -(k : ℤ) as negative: {
        choose k such that y - x = -(k : ℤ) from negative;
        (m : ℤ) * (y - x)
                  = (m : ℤ) * (-(k : ℤ))
                  = -((m : ℤ) * (k : ℤ))
                  = -((m * k : ℕ) : ℤ);
        Integer.IsNonneg(-((m * k : ℕ) : ℤ));
        choose j such that -((m * k : ℕ) : ℤ) = (j : ℤ);
        ((m * k + j : ℕ) : ℤ)
                  = ((m * k : ℕ) : ℤ) + (j : ℤ)
                  = ((m * k : ℕ) : ℤ) + (-((m * k : ℕ) : ℤ))
                  = Integer.zero;
        m * k + j = 0;
        m * k = 0;
        k * m = m * k = 0;
        k = 0 by Natural.multiply_equals_zero_with_positive_right;
        y - x
                  = -(k : ℤ)
                  = -((0 : ℕ) : ℤ)
                  = Integer.zero;
        Integer.IsNonneg(y - x);
        done
      }
  }
}

-- An Integer square is nonnegative.
automatic theorem Integer.square_IsNonneg (x : ℤ)
        : Integer.IsNonneg(Integer.multiply(x, x)) := {
  Integer.IsNonneg(x) ∨ ∃ (k : ℕ). x = -(k : ℤ)
      by Integer.sign_split;
  done by cases {
    case Integer.IsNonneg(x):
        done
    case ∃ (k : ℕ). x = -(k : ℤ) as negativeEvidence: {
        choose k such that x = -(k : ℤ) from negativeEvidence;
        Integer.IsNonneg((k : ℤ));
        Integer.IsNonneg(Integer.multiply((k : ℤ), (k : ℤ)));
        done
      }
  }
}


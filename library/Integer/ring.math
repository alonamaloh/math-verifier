-- Integer/ring.math
--
-- Commutative-semiring identities on Integer: add and multiply each are
-- commutative, associative, with identity element; distributivity
-- holds on both sides. Together these say Integer is a commutative
-- semiring (the additional negation in Integer/negation.math makes it a
-- commutative ring).
--
-- Each law drops to representatives, where both sides reduce to concrete
-- difference pairs; the equivalence of those pairs is a cross-addition
-- equation between Natural polynomials — a pure ring identity, stated as
-- a claim and closed by `done`. The symmetric companions
-- (add_identity_right, distributivity_right, …) are derived from their
-- primal partner plus commutativity.

module Integer.ring

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Integer.basics
import Integer.addition
import Integer.multiplication

-- ======================================================================
-- Addition
-- ======================================================================

-- At reps (a, b), (c, d) both sides reduce to mk(make(a + c, b + d)) and
-- mk(make(c + a, d + b)); the cross-equation shuffles via commutativity.
automatic theorem Integer.add_commutative (x y : Integer)
        : x + y = y + x :=
  by_representatives x as ⟨a, b⟩, y as ⟨c, d⟩ => {
    claim (a + c) + (d + b) = (b + d) + (c + a);
    done
  }

automatic theorem Integer.add_associative (x y z : Integer)
        : x + y + z = x + (y + z) :=
  by_representatives x as ⟨a, b⟩, y as ⟨c, d⟩, z as ⟨e, f⟩ => {
    claim ((a + c) + e) + (b + (d + f)) = ((b + d) + f) + (a + (c + e));
    done
  }

-- add(zero, mk(make(a, b))) reduces definitionally to mk(make(0 + a,
-- 0 + b)); `zero_add` collapses both components to the identity.
automatic theorem Integer.add_identity_left (x : Integer)
        : Integer.zero + x = x :=
  by_representatives x as ⟨a, b⟩ =>
      done by substituting Natural.zero_add

automatic theorem Integer.add_identity_right (x : Integer)
        : x + Integer.zero = x :=
  calc x + Integer.zero
     = Integer.zero + x
     = x

-- ======================================================================
-- Multiplication
-- ======================================================================

-- At reps (a, b), (c, d) both sides reduce to mk(make(a*c + b*d,
-- a*d + b*c)) and mk(make(c*a + d*b, c*b + d*a)); each term reshuffles
-- via commutativity.
automatic theorem Integer.multiply_commutative (x y : Integer)
        : x * y = y * x :=
  by_representatives x as ⟨a, b⟩, y as ⟨c, d⟩ => {
    claim (a * c + b * d) + (c * b + d * a) = (a * d + b * c) + (c * a + d * b);
    done
  }

-- one * mk(make(a, b)) reduces to mk(make(1*a + 0*b, 1*b + 0*a)); the
-- cross-equation simplifies to a + b = b + a.
automatic theorem Integer.multiply_identity_left (x : Integer)
        : Integer.one * x = x :=
  by_representatives x as ⟨a, b⟩ => {
    claim (1 * a + 0 * b) + b = (1 * b + 0 * a) + a;
    done
  }

automatic theorem Integer.multiply_identity_right (x : Integer)
        : x * Integer.one = x :=
  calc x * Integer.one
     = Integer.one * x
     = x

-- ======================================================================
-- Distributivity
-- ======================================================================

-- At reps (a, b), (c, d), (e, f): x*(y+z) and x*y + x*z reduce to
-- difference pairs whose cross-equation expands by left-distributivity.
automatic theorem Integer.distributivity_left (x y z : Integer)
        : x * (y + z) = x * y + x * z :=
  by_representatives x as ⟨a, b⟩, y as ⟨c, d⟩, z as ⟨e, f⟩ => {
    claim (a * (c + e) + b * (d + f)) + ((a * d + b * c) + (a * f + b * e))
        = (a * (d + f) + b * (c + e)) + ((a * c + b * d) + (a * e + b * f));
    done
  }

automatic theorem Integer.distributivity_right (x y z : Integer)
        : (x + y) * z = x * z + y * z :=
  calc (x + y) * z
     = z * (x + y)
     = z * x + z * y
     = x * z + y * z

-- ======================================================================
-- Multiplication associativity
-- ======================================================================

-- At reps (a, b), (c, d), (e, f): (x*y)*z and x*(y*z) reduce to
-- difference pairs whose cross-equation is a degree-three ring identity.
automatic theorem Integer.multiply_associative (x y z : Integer)
        : x * y * z = x * (y * z) :=
  by_representatives x as ⟨a, b⟩, y as ⟨c, d⟩, z as ⟨e, f⟩ => {
    claim ((a * c + b * d) * e + (a * d + b * c) * f) + (a * (c * f + d * e) + b * (c * e + d * f))
        = ((a * c + b * d) * f + (a * d + b * c) * e) + (a * (c * e + d * f) + b * (c * f + d * e));
    done
  }

-- Integer/algebra.math
--
-- Extra arithmetic identities on Integer that combine multiplication
-- with the additive group structure: zero is absorbing for
-- multiplication, multiplication respects negation, and distributivity
-- extends over subtraction. Plus a handy cancellation lemma —
-- `subtract_left_add` — that says `a − b = c` whenever `a = b + c`.

module Integer.algebra

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.ring
import Integer.negation

-- ----------------------------------------------------------------------
-- Zero is absorbing for multiplication.
--
-- At rep (a, b): Integer.zero · mk(make(a, b)) reduces (via two
-- Quotient.lift kernel rules + multiply_representatives) to
-- mk(make(0·a + 0·b, 0·b + 0·a)) = mk(make(0 + 0, 0 + 0)) = mk(make(0,
-- 0)) — all by definitional reduction since multiply and add reduce on
-- their first arguments when that argument is `zero`.

theorem Integer.multiply_zero_left_at_representative
        : (rep : IntegerRepresentative)
          → Integer.zero * Quotient.mk(
                        IntegerRepresentative, IntegerEquivalent, rep) = Integer.zero
  | IntegerRepresentative.make(a, b) =>
      reflexivity(Integer, Integer.zero)

theorem Integer.multiply_zero_left (x : Integer)
        : Integer.zero * x = Integer.zero :=
  Quotient.induct(
      function (x : Integer) =>
          Integer.zero * x = Integer.zero,
      Integer.multiply_zero_left_at_representative,
      x)

theorem Integer.multiply_zero_right (x : Integer)
        : x * Integer.zero = Integer.zero :=
  Equality.transitivity(
      Integer,
      x * Integer.zero,
      Integer.zero * x,
      Integer.zero,
      Integer.multiply_commutative(x, Integer.zero),
      Integer.multiply_zero_left(x))

-- ----------------------------------------------------------------------
-- Multiplication respects negation.
--
-- At reps (a, b), (c, d):
--   a · negate(b) = mk(make(a, b)) · mk(make(d, c))
--                 = mk(make(a·d + b·c, a·c + b·d))
--   negate(a · b) = negate(mk(make(a·c + b·d, a·d + b·c)))
--                 = mk(make(a·d + b·c, a·c + b·d))
-- Both reduce to the same representative — leaf is reflexivity.

theorem Integer.multiply_negate_right_at_representatives
        : (rep1 rep2 : IntegerRepresentative)
          → Quotient.mk(
                        IntegerRepresentative, IntegerEquivalent, rep1) * -Quotient.mk(
                            IntegerRepresentative, IntegerEquivalent, rep2) = -(Quotient.mk(
                            IntegerRepresentative, IntegerEquivalent, rep1) * Quotient.mk(
                            IntegerRepresentative, IntegerEquivalent, rep2))
  | IntegerRepresentative.make(a, b),
    IntegerRepresentative.make(c, d) =>
      reflexivity(Integer,
          Quotient.mk(
              IntegerRepresentative, IntegerEquivalent,
              IntegerRepresentative.make(a * d + b * c, a * c + b * d)))

theorem Integer.multiply_negate_right_after_first
        (rep1 : IntegerRepresentative) (y : Integer)
        : Quotient.mk(
                      IntegerRepresentative, IntegerEquivalent, rep1) * -y = -(Quotient.mk(
                          IntegerRepresentative, IntegerEquivalent, rep1) * y) :=
  Quotient.induct(
      function (y : Integer) =>
          Quotient.mk(
                      IntegerRepresentative, IntegerEquivalent, rep1) * -y = -(Quotient.mk(
                          IntegerRepresentative, IntegerEquivalent, rep1) * y),
      function (rep2 : IntegerRepresentative) =>
          Integer.multiply_negate_right_at_representatives(rep1, rep2),
      y)

theorem Integer.multiply_negate_right (x y : Integer)
        : x * -y = -(x * y) :=
  Quotient.induct(
      function (x : Integer) =>
          x * -y = -(x * y),
      function (rep1 : IntegerRepresentative) =>
          Integer.multiply_negate_right_after_first(rep1, y),
      x)

-- Left companion via commutativity.
theorem Integer.multiply_negate_left (x y : Integer)
        : -x * y = -(x * y) :=
  calc -x * y
     = y * -x
     = -(y * x)   by Integer.multiply_negate_right(y, x)
     = -(x * y)

-- ----------------------------------------------------------------------
-- Distributivity over subtraction.
--
-- a · (b − c) = a · (b + (−c))            [definitional: subtract → add+negate]
--             = a · b + a · (−c)          [distributivity_left]
--             = a · b + (−(a · c))         [multiply_negate_right]
--             = a · b − a · c             [definitional: subtract = add+negate, reversed]

theorem Integer.distributivity_left_over_subtract (x y z : Integer)
        : x * (y - z) = x * y - x * z :=
  -- `y - z` ≡ `y + -z` and `x * y - x * z` ≡ `x * y + -(x * z)`
  -- definitionally, so the only real step is distributing and then
  -- pushing the negation out of the second summand.
  calc x * (y + -z)
     = x * y + x * -z      by Integer.distributivity_left(x, y, -z)
     = x * y + -(x * z)
            by rewrite(Integer.multiply_negate_right(x, z))

theorem Integer.distributivity_right_over_subtract (x y z : Integer)
        : (x - y) * z = x * z - y * z :=
  calc (x + -y) * z
     = x * z + -y * z      by Integer.distributivity_right(x, -y, z)
     = x * z + -(y * z)
            by rewrite(Integer.multiply_negate_left(y, z))

-- ----------------------------------------------------------------------
-- Cancellation: if a = b + c then a − b = c. The proof reshapes
-- (b + c) + (−b) into c + (b + (−b)) = c + 0 = c via the additive-
-- group laws.

theorem Integer.subtract_left_add (a b c : Integer)
        (decomposition : a = b + c)
        : a - b = c :=
  -- `a - b` ≡ `a + -b` definitionally; reshape via decomposition,
  -- commute, reassociate, cancel.
  calc a + -b
     = b + c + -b
     = c + b + -b
     = c + (b + -b)
     = c + Integer.zero    by rewrite(Integer.add_negate_right(b))
     = c

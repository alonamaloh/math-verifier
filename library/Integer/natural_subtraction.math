-- Integer/natural_subtraction.math
--
-- Honest subtraction and negation on Natural: the result lives in the
-- smallest closure where the operation is total — the integers. So
-- `4 - 5` is `-1` (no truncation lie, no proof obligation), and once
-- the expression is in ℤ, `-` is a genuine ring operation that `ring`
-- understands. These definitions live above ℤ in the import graph,
-- not in the foundational Natural/ modules.

module Integer.natural_subtraction

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Integer.basics
import Integer.addition
import Integer.ring
import Integer.negation
import Integer.embedding

definition Natural.subtract (a b : ℕ) : ℤ :=
  (a : ℤ) - (b : ℤ)

operator (-) on (Natural, Natural) := Natural.subtract

-- The characterising lemma: `a - b` is the difference class. Consumers
-- reason about honest subtraction through this boundary equation (plus
-- `Integer.difference_equal` and the subtraction witnesses), never by
-- reducing through the quotient.
automatic theorem Natural.subtract_from_difference (a b : ℕ)
        : a - b = Integer.from_difference(a, b) :=
  done by substituting Natural.zero_add unfolding ℤ

definition Natural.negate (n : ℕ) : ℤ :=
  -(n : ℤ)

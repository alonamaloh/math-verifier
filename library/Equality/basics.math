-- Equality/basics.math
--
-- Propositional equality. Universe-polymorphic; bare `Type` introduces
-- an auto-bound universe parameter, and references to other polymorphic
-- declarations let the elaborator infer their universe arguments from
-- the value-argument types.

module Equality.basics

inductive Equality (A : Type) (x : A) : A → Proposition where
  | reflexivity : x = x

-- Symmetry: if x = y, then y = x. By pattern matching on the equality:
-- the only case is reflexivity, where y is forced to be x, so the
-- result type collapses to x = x, which reflexivity proves.
theorem Equality.symmetry {A : Type} (x y : A)
        : x = y → y = x
  | reflexivity => reflexivity(x)

-- Transitivity: if x = y and y = z, then x = z. Pattern-match on the
-- SECOND equality (yEqualsZ): when it's reflexivity, z is forced to y,
-- so the result type x = z becomes x = y — and
-- the first equality xEqualsY is a proof of exactly that.
theorem Equality.transitivity {A : Type} (x y z : A)
        (xEqualsY : x = y)
        : y = z → x = z
  | reflexivity => xEqualsY

-- Congruence: if x = y, then f(x) = f(y). Pattern-match: the only case
-- is reflexivity, where y is forced to x and so f(y) = f(x).
theorem Equality.congruence {A : Type} {B : Type} (f : A → B) (x y : A)
        : x = y → f(x) = f(y)
  | reflexivity => reflexivity(f(x))

-- Transport along an equality, for Proposition-valued predicates:
-- given `x = y` and `P(x)`, conclude `P(y)`. Useful for rewriting
-- the goal of a proof along a previously-established equality.
theorem Equality.transport_proposition
        {A : Type} (P : A → Proposition)
        (x y : A)
        (equalityProof : x = y)
        (proofAtX : P(x))
        : P(y) :=
  Equality_recursor(
    A, x,
    function (rightEnd : A) (_ : x = rightEnd) => P(rightEnd),
    proofAtX,
    y,
    equalityProof)

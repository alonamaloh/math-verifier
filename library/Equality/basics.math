-- Equality/basics.math
--
-- Propositional equality. Universe-polymorphic; bare `Type` introduces
-- an auto-bound universe parameter, and references to other polymorphic
-- declarations let the elaborator infer their universe arguments from
-- the value-argument types.

module Equality.basics

inductive Equality (A : Type) (x : A) : A → Proposition where
  | reflexivity : Equality(A, x, x)

-- Symmetry: if x = y, then y = x. Proved by the J principle, which is
-- what the kernel-generated Equality_recursor encodes.
theorem Equality.symmetry
        (A : Type) (x y : A) (equalityProof : Equality(A, x, y))
        : Equality(A, y, x) :=
  Equality_recursor(
    A, x,
    fun (someY : A) (_ : Equality(A, x, someY)) => Equality(A, someY, x),
    reflexivity(x),
    y,
    equalityProof)

-- Transitivity: if x = y and y = z, then x = z. Recurse on the second
-- equality with motive λ someZ _. Equality(A, x, someZ).
theorem Equality.transitivity
        (A : Type) (x y z : A)
        (xEqualsY : Equality(A, x, y))
        (yEqualsZ : Equality(A, y, z))
        : Equality(A, x, z) :=
  Equality_recursor(
    A, y,
    fun (someZ : A) (_ : Equality(A, y, someZ)) => Equality(A, x, someZ),
    xEqualsY,
    z,
    yEqualsZ)

-- Congruence: if x = y, then f(x) = f(y).
theorem Equality.congruence
        (A : Type) (B : Type) (f : A → B)
        (x y : A) (equalityProof : Equality(A, x, y))
        : Equality(B, f(x), f(y)) :=
  Equality_recursor(
    A, x,
    fun (someY : A) (_ : Equality(A, x, someY))
        => Equality(B, f(x), f(someY)),
    reflexivity(f(x)),
    y,
    equalityProof)

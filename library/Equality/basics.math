-- Equality/basics.math
--
-- Propositional equality. Universe-polymorphic; bare `Type` introduces
-- an auto-bound universe parameter, and references to other polymorphic
-- declarations let the elaborator infer their universe arguments from
-- the value-argument types.

module Equality.basics

inductive Equality (A : Type) (x : A) : A → Prop where
  | reflexivity : Equality(A, x, x)

-- Symmetry: if x = y, then y = x. J-principle proof.
theorem Equality.symmetry
        (A : Type) (x y : A) (h : Equality(A, x, y))
        : Equality(A, y, x) :=
  Equality_recursor(
    A, x,
    fun (y' : A) (_ : Equality(A, x, y')) => Equality(A, y', x),
    reflexivity(x),
    y,
    h)

-- Transitivity: if x = y and y = z, then x = z. Recurse on the second
-- equality with motive λ z' _. Equality(A, x, z').
theorem Equality.transitivity
        (A : Type) (x y z : A)
        (hxy : Equality(A, x, y)) (hyz : Equality(A, y, z))
        : Equality(A, x, z) :=
  Equality_recursor(
    A, y,
    fun (z' : A) (_ : Equality(A, y, z')) => Equality(A, x, z'),
    hxy,
    z,
    hyz)

-- Congruence: if x = y, then f(x) = f(y).
theorem Equality.congruence
        (A : Type) (B : Type) (f : A → B)
        (x y : A) (h : Equality(A, x, y))
        : Equality(B, f(x), f(y)) :=
  Equality_recursor(
    A, x,
    fun (y' : A) (_ : Equality(A, x, y')) => Equality(B, f(x), f(y')),
    reflexivity(f(x)),
    y,
    h)

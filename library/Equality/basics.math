-- Equality/basics.math
--
-- Propositional equality. Universe-polymorphic; bare `Type` introduces
-- an auto-bound universe parameter, and references to other polymorphic
-- declarations let the elaborator infer their universe arguments from
-- the value-argument types.

module Equality.basics

inductive Equality (A : Type) (x : A) : A → Proposition where
  | reflexivity : x = x

-- Symmetry, transitivity, and congruence are the identity-type eliminator
-- (the J-rule) in three costumes — the foundational boundary that
-- `by substituting`, calc, and `ring`/`field` are all built on, so they
-- cannot themselves reason by substitution. Rather than expose the raw
-- recursor at the surface, we take them as axioms (HOL-style: no one audits
-- `x = x`). Being Proposition-valued, they are defeq-safe under the kernel's
-- proof irrelevance — their non-reduction is invisible.
axiom Equality.symmetry : ∀ {A : Type} (x y : A). x = y → y = x

axiom Equality.transitivity : ∀ {A : Type} (x y z : A). x = y → y = z → x = z

axiom Equality.congruence
    : ∀ {A : Type} {B : Type} (f : A → B) (x y : A). x = y → f(x) = f(y)

-- Transport along an equality, for Proposition-valued predicates:
-- given `x = y` and `P(x)`, conclude `P(y)`. Useful for rewriting
-- the goal of a proof along a previously-established equality.
theorem Equality.transport_proposition
        {A : Type} (P : A → Proposition)
        (x y : A)
        (equalityProof : x = y)
        (proofAtX : P(x))
        : P(y) :=
  Equality_recursor(
    A, x,
    (rightEnd : A) (_ : x = rightEnd) ↦ P(rightEnd),
    proofAtX,
    y,
    equalityProof)

-- ComplexNumber/real_positivity.math
--
-- Squares are nonnegative — built up Integer → Rational → Real, since
-- ℝ's order layer is additive-only — and the consequence that −1 is not
-- a square in ℝ. This is the positivity fact that makes x²+1 have no
-- real root, hence be irreducible over ℝ (ComplexNumber/irreducible).

module ComplexNumber.real_positivity

import Logic.basics
import Logic.exists
import Logic.sum
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.order
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.instances
import Integer.order
import Integer.sign
import Integer.order_multiply
import Integer.embedding
import Algebra.ring
import Algebra.ring_lemmas
import Rational.basics
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.instances
import Rational.order
import Rational.positive
import Rational.linearity
import Rational.order_arithmetic
import Real.interface

-- −1 is not nonnegative in ℝ (else 1 = 0).
theorem Real.negate_one_not_IsNonneg
        : ¬(Real.IsNonneg(Real.negate(Real.one))) :=
  (negateOneIsNonneg : Real.IsNonneg(Real.negate(Real.one))) ↦ {
    Real.multiply(Real.one, Real.one) = Real.one as oneIsSquare;
    Real.IsNonneg(Real.multiply(Real.one, Real.one));
    Real.IsNonneg(Real.one) by substituting oneIsSquare as oneIsNonneg;
    Real.zero_not_equal_one(
        calc Real.zero
           = Real.one
               by Real.IsNonneg_and_negate_IsNonneg_implies_zero(Real.one,
                         oneIsNonneg, negateOneIsNonneg))
  }

-- Hence −1 has no real square root: no t with t² = −1.
theorem Real.no_square_root_of_negate_one (t : Real)
        : ¬(Real.multiply(t, t) = Real.negate(Real.one)) :=
  (squareEqualsNegateOne : Real.multiply(t, t) = Real.negate(Real.one)) ↦
    Real.negate_one_not_IsNonneg(
        rewrite(squareEqualsNegateOne, Real.square_IsNonneg(t)))

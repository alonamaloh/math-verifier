import ComplexNumber.exponential
import ComplexNumber.conjugation

-- ----------------------------------------------------------------------
-- The coordinates of i·x: (0, x).

theorem ComplexNumber.realPart_i_from_real (x : ℝ)
        : ComplexNumber.realPart(ComplexNumber.i * ComplexNumber.from_real(x))
          = Real.zero :=
  ComplexNumber.realPart(ComplexNumber.i * ComplexNumber.from_real(x))
     = ComplexNumber.realPart(ComplexNumber.i)
           * ComplexNumber.realPart(ComplexNumber.from_real(x))
       - ComplexNumber.imaginaryPart(ComplexNumber.i)
             * ComplexNumber.imaginaryPart(ComplexNumber.from_real(x))
           by ComplexNumber.realPart_multiply
     = Real.zero * ComplexNumber.realPart(ComplexNumber.from_real(x))
       - ComplexNumber.imaginaryPart(ComplexNumber.i)
             * ComplexNumber.imaginaryPart(ComplexNumber.from_real(x))
           by ComplexNumber.realPart_i
     = Real.zero * ComplexNumber.realPart(ComplexNumber.from_real(x))
       - ComplexNumber.imaginaryPart(ComplexNumber.i) * Real.zero
           by ComplexNumber.imaginaryPart_from_real
     = Real.zero
           by ring

theorem ComplexNumber.imaginaryPart_i_from_real (x : ℝ)
        : ComplexNumber.imaginaryPart(ComplexNumber.i * ComplexNumber.from_real(x))
          = x :=
  ComplexNumber.imaginaryPart(ComplexNumber.i * ComplexNumber.from_real(x))
     = ComplexNumber.realPart(ComplexNumber.i)
           * ComplexNumber.imaginaryPart(ComplexNumber.from_real(x))
       + ComplexNumber.imaginaryPart(ComplexNumber.i)
             * ComplexNumber.realPart(ComplexNumber.from_real(x))
           by ComplexNumber.imaginaryPart_multiply
     = Real.zero
           * ComplexNumber.imaginaryPart(ComplexNumber.from_real(x))
       + ComplexNumber.imaginaryPart(ComplexNumber.i)
             * ComplexNumber.realPart(ComplexNumber.from_real(x))
           by ComplexNumber.realPart_i
     = Real.zero
           * ComplexNumber.imaginaryPart(ComplexNumber.from_real(x))
       + Real.one * ComplexNumber.realPart(ComplexNumber.from_real(x))
           by ComplexNumber.imaginaryPart_i
     = Real.zero
           * ComplexNumber.imaginaryPart(ComplexNumber.from_real(x))
       + Real.one * x
           by ComplexNumber.realPart_from_real
     = x
           by ring

-- ----------------------------------------------------------------------
-- The one-step recurrence for the coordinates of the powers of i·x.

theorem ComplexNumber.realPart_imaginaryAxis_power_one_plus (x : ℝ) (k : ℕ)
        : ComplexNumber.realPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + k))
          = -(x * ComplexNumber.imaginaryPart(
                      (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)) := {
  ComplexNumber.realPart(ComplexNumber.i * ComplexNumber.from_real(x))
      = Real.zero
      by ComplexNumber.realPart_i_from_real as reZero;
  ComplexNumber.imaginaryPart(ComplexNumber.i * ComplexNumber.from_real(x))
      = x
      by ComplexNumber.imaginaryPart_i_from_real as imX;
  ComplexNumber.realPart(
           (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + k))
     = ComplexNumber.realPart(
           (ComplexNumber.i * ComplexNumber.from_real(x))
           * (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)
     = ComplexNumber.realPart(ComplexNumber.i * ComplexNumber.from_real(x))
           * ComplexNumber.realPart(
                 (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)
       - ComplexNumber.imaginaryPart(ComplexNumber.i * ComplexNumber.from_real(x))
             * ComplexNumber.imaginaryPart(
                   (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)
     = Real.zero
           * ComplexNumber.realPart(
                 (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)
       - ComplexNumber.imaginaryPart(ComplexNumber.i * ComplexNumber.from_real(x))
             * ComplexNumber.imaginaryPart(
                   (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)
           by substituting reZero
     = Real.zero
           * ComplexNumber.realPart(
                 (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)
       - x * ComplexNumber.imaginaryPart(
                 (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)
           by substituting imX
     = -(x * ComplexNumber.imaginaryPart(
                 (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k))
           by ring
}

theorem ComplexNumber.imaginaryPart_imaginaryAxis_power_one_plus
        (x : ℝ) (k : ℕ)
        : ComplexNumber.imaginaryPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + k))
          = x * ComplexNumber.realPart(
                    (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k) := {
  ComplexNumber.realPart(ComplexNumber.i * ComplexNumber.from_real(x))
      = Real.zero
      by ComplexNumber.realPart_i_from_real as reZero;
  ComplexNumber.imaginaryPart(ComplexNumber.i * ComplexNumber.from_real(x))
      = x
      by ComplexNumber.imaginaryPart_i_from_real as imX;
  ComplexNumber.imaginaryPart(
           (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + k))
     = ComplexNumber.imaginaryPart(
           (ComplexNumber.i * ComplexNumber.from_real(x))
           * (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)
     = ComplexNumber.realPart(ComplexNumber.i * ComplexNumber.from_real(x))
           * ComplexNumber.imaginaryPart(
                 (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)
       + ComplexNumber.imaginaryPart(ComplexNumber.i * ComplexNumber.from_real(x))
             * ComplexNumber.realPart(
                   (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)
     = Real.zero
           * ComplexNumber.imaginaryPart(
                 (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)
       + ComplexNumber.imaginaryPart(ComplexNumber.i * ComplexNumber.from_real(x))
             * ComplexNumber.realPart(
                   (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)
           by substituting reZero
     = Real.zero
           * ComplexNumber.imaginaryPart(
                 (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)
       + x * ComplexNumber.realPart(
                 (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)
           by substituting imX
     = x * ComplexNumber.realPart(
               (ComplexNumber.i * ComplexNumber.from_real(x)) ^ k)
           by ring
}

-- ----------------------------------------------------------------------
-- The closed forms along the 4-cycle, proved together by induction on
-- m (each step applies the recurrence twice: 2m → 2m+1 → 2m+2).
theorem ComplexNumber.imaginaryAxis_power_coordinates (x : ℝ)
        (n : ℕ)
        : ComplexNumber.realPart(
                    (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (2 * n))
                  = (-(x * x)) ^ n ∧ ComplexNumber.imaginaryPart(
                    (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (2 * n))
                  = Real.zero ∧ ComplexNumber.realPart(
                    (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + 2 * n))
                  = Real.zero ∧ ComplexNumber.imaginaryPart(
                    (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + 2 * n))
                  = x * (-(x * x)) ^ n :=
  by induction on n with IH {
    case 0: {
      ComplexNumber.realPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (2 * 0))
          = (-(x * x)) ^ 0
          by {
            2 * 0 = 0 as twoTimesZero;
            ComplexNumber.realPart(
                     (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (2 * 0))
               = ComplexNumber.realPart(
                     (ComplexNumber.i * ComplexNumber.from_real(x)) ^ 0)
                     by twoTimesZero
               = ComplexNumber.realPart(
                     RingModulo.one(Real.polynomial_commutative_ring,
                         Complex.definingPolynomial))
               = ComplexNumber.realPart(ComplexNumber.from_real(Real.one))
               = Real.one
               = (-(x * x)) ^ 0
          };
      ComplexNumber.imaginaryPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (2 * 0))
          = Real.zero
          by {
            2 * 0 = 0 as twoTimesZero;
            ComplexNumber.imaginaryPart(
                     (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (2 * 0))
               = ComplexNumber.imaginaryPart(
                     (ComplexNumber.i * ComplexNumber.from_real(x)) ^ 0)
                     by twoTimesZero
               = ComplexNumber.imaginaryPart(
                     RingModulo.one(Real.polynomial_commutative_ring,
                         Complex.definingPolynomial))
               = ComplexNumber.imaginaryPart(ComplexNumber.from_real(Real.one))
               = Real.zero
          };
      ComplexNumber.realPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ 1)
          = Real.zero
          by {
            ComplexNumber.realPart(
                     (ComplexNumber.i * ComplexNumber.from_real(x)) ^ 1)
               = ComplexNumber.realPart(
                     (ComplexNumber.i * ComplexNumber.from_real(x))
                     * RingModulo.one(Real.polynomial_commutative_ring,
                           Complex.definingPolynomial))
               = ComplexNumber.realPart(ComplexNumber.i * ComplexNumber.from_real(x))
                     by RingModulo.multiply_identity_right
               = Real.zero
          };
      ComplexNumber.imaginaryPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ 1)
          = x * (-(x * x)) ^ 0
          by {
            ComplexNumber.imaginaryPart(
                     (ComplexNumber.i * ComplexNumber.from_real(x)) ^ 1)
               = ComplexNumber.imaginaryPart(
                     (ComplexNumber.i * ComplexNumber.from_real(x))
                     * RingModulo.one(Real.polynomial_commutative_ring,
                           Complex.definingPolynomial))
               = ComplexNumber.imaginaryPart(ComplexNumber.i * ComplexNumber.from_real(x))
                     by RingModulo.multiply_identity_right
               = x
               = x * Real.one
               = x * (-(x * x)) ^ 0
          };
      done
    }
    case 1 + m: {
      ComplexNumber.realPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (2 * m))
          = (-(x * x)) ^ m
        ∧ ComplexNumber.imaginaryPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (2 * m))
          = Real.zero
        ∧ ComplexNumber.realPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + 2 * m))
          = Real.zero
        ∧ ComplexNumber.imaginaryPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + 2 * m))
          = x * (-(x * x)) ^ m
          by IH;
      ComplexNumber.realPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + 2 * m))
          = Real.zero as oddRealAt;
      ComplexNumber.imaginaryPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + 2 * m))
          = x * (-(x * x)) ^ m as oddImaginaryAt;
      2 * (1 + m) = 1 + (1 + 2 * m) as indexEven;
      -- 2(m+1): realPart = −x·im((ix)^{2m+1}) = −x·(x·(−x²)^m) = (−x²)^{m+1}.
      ComplexNumber.realPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (2 * (1 + m)))
          = ComplexNumber.realPart(
                (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + (1 + 2 * m)))
                by indexEven
          = -(x * ComplexNumber.imaginaryPart(
                      (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + 2 * m)))
                by ComplexNumber.realPart_imaginaryAxis_power_one_plus
          = -(x * (x * (-(x * x)) ^ m))
                by oddImaginaryAt
          = -(x * x) * (-(x * x)) ^ m
                by ring
          = (-(x * x)) ^ (1 + m)
          as evenReal;
      -- 2(m+1): imaginaryPart = x·re((ix)^{2m+1}) = x·0 = 0.
      ComplexNumber.imaginaryPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (2 * (1 + m)))
          = ComplexNumber.imaginaryPart(
                (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + (1 + 2 * m)))
                by indexEven
          = x * ComplexNumber.realPart(
                    (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + 2 * m))
                by ComplexNumber.imaginaryPart_imaginaryAxis_power_one_plus
          = x * Real.zero
                by oddRealAt
          = Real.zero
          as evenImaginary;
      -- 2(m+1)+1: realPart = −x·im((ix)^{2m+2}) = −x·0 = 0.
      ComplexNumber.realPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + 2 * (1 + m)))
          = -(x * ComplexNumber.imaginaryPart(
                      (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (2 * (1 + m))))
                by ComplexNumber.realPart_imaginaryAxis_power_one_plus
          = -(x * Real.zero)
                by evenImaginary
          = Real.zero;
      -- 2(m+1)+1: imaginaryPart = x·re((ix)^{2m+2}) = x·(−x²)^{m+1}.
      ComplexNumber.imaginaryPart(
              (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (1 + 2 * (1 + m)))
          = x * ComplexNumber.realPart(
                    (ComplexNumber.i * ComplexNumber.from_real(x)) ^ (2 * (1 + m)))
                by ComplexNumber.imaginaryPart_imaginaryAxis_power_one_plus
          = x * (-(x * x)) ^ (1 + m)
                by evenReal;
      done
    }
  }

-- ComplexNumber/triangle_inequality.math
--
-- The triangle inequality |z + w| ≤ |z| + |w|. The coordinates of a sum
-- add componentwise, so |z + w|² expands to |z|² + |w|² plus twice the
-- real inner product re(z)·re(w) + im(z)·im(w); the inner product is
-- bounded by |z|·|w| (two-variable Cauchy–Schwarz, via the Lagrange
-- identity (ac + bd)² + (ad − bc)² = (a² + b²)(c² + d²)), and comparing
-- squares finishes.

module ComplexNumber.triangle_inequality

import Logic.basics
import Logic.exists
import Logic.product
import Logic.quotient
import Logic.excluded_middle
import axioms
import Equality.basics
import Natural.basics
import Natural.order
import Integer.basics
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.halve
import Rational.positive
import Rational.linearity
import Rational.minimum
import Rational.reciprocal
import Rational.reciprocal_function
import Rational.archimedean
import Set.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Real.interface
import Polynomial.basics
import Polynomial.addition
import Polynomial.multiplication
import RingModulo.basics
import RingModulo.operations
import ComplexNumber.basics
import ComplexNumber.coordinates
import ComplexNumber.coordinate_homomorphism
import ComplexNumber.defining_polynomial_vanishes
import ComplexNumber.coordinate_map
import ComplexNumber.coordinate_multiplicative
import ComplexNumber.reconstruction
import ComplexNumber.of_coordinates
import ComplexNumber.modulus

-- ----------------------------------------------------------------------
-- Two-variable Cauchy–Schwarz: the real inner product of the coordinate
-- pairs is at most |z|·|w|.

theorem ComplexNumber.inner_product_bound (z w : ComplexNumber)
        : ComplexNumber.realPart(z) * ComplexNumber.realPart(w)
              + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(w)
          ≤ ComplexNumber.modulus(z) * ComplexNumber.modulus(w) := {
  -- |z|² and |w|², instantiated.
  ComplexNumber.modulus(z) * ComplexNumber.modulus(z)
      = ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
        + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z)
      by ComplexNumber.modulus_squares as zSquares;
  ComplexNumber.modulus(w) * ComplexNumber.modulus(w)
      = ComplexNumber.realPart(w) * ComplexNumber.realPart(w)
        + ComplexNumber.imaginaryPart(w) * ComplexNumber.imaginaryPart(w)
      by ComplexNumber.modulus_squares as wSquares;
  -- (|z|·|w|)² is the product of the two square sums.
  (ComplexNumber.modulus(z) * ComplexNumber.modulus(w))
      * (ComplexNumber.modulus(z) * ComplexNumber.modulus(w))
     = (ComplexNumber.modulus(z) * ComplexNumber.modulus(z))
           * (ComplexNumber.modulus(w) * ComplexNumber.modulus(w))
     = (ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
            + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z))
           * (ComplexNumber.modulus(w) * ComplexNumber.modulus(w))
           by zSquares
     = (ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
            + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z))
           * (ComplexNumber.realPart(w) * ComplexNumber.realPart(w)
                  + ComplexNumber.imaginaryPart(w) * ComplexNumber.imaginaryPart(w))
           by wSquares
     as productSquares;
  -- The discarded Lagrange term is a square.
  Real.IsNonneg(
      (ComplexNumber.realPart(z) * ComplexNumber.imaginaryPart(w)
           - ComplexNumber.imaginaryPart(z) * ComplexNumber.realPart(w))
      * (ComplexNumber.realPart(z) * ComplexNumber.imaginaryPart(w)
             - ComplexNumber.imaginaryPart(z) * ComplexNumber.realPart(w)));
  Real.zero
      ≤ (ComplexNumber.realPart(z) * ComplexNumber.imaginaryPart(w)
             - ComplexNumber.imaginaryPart(z) * ComplexNumber.realPart(w))
        * (ComplexNumber.realPart(z) * ComplexNumber.imaginaryPart(w)
               - ComplexNumber.imaginaryPart(z) * ComplexNumber.realPart(w))
      by Real.LessOrEqual_zero_of_IsNonneg;
  -- The squares compare: Lagrange's identity absorbs the cross term.
  (ComplexNumber.realPart(z) * ComplexNumber.realPart(w)
       + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(w))
      * (ComplexNumber.realPart(z) * ComplexNumber.realPart(w)
             + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(w))
     = (ComplexNumber.realPart(z) * ComplexNumber.realPart(w)
            + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(w))
           * (ComplexNumber.realPart(z) * ComplexNumber.realPart(w)
                  + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(w))
           + Real.zero
     ≤ (ComplexNumber.realPart(z) * ComplexNumber.realPart(w)
            + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(w))
           * (ComplexNumber.realPart(z) * ComplexNumber.realPart(w)
                  + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(w))
           + (ComplexNumber.realPart(z) * ComplexNumber.imaginaryPart(w)
                  - ComplexNumber.imaginaryPart(z) * ComplexNumber.realPart(w))
                 * (ComplexNumber.realPart(z) * ComplexNumber.imaginaryPart(w)
                        - ComplexNumber.imaginaryPart(z) * ComplexNumber.realPart(w))
           by Real.add_preserves_LessOrEqual_left
     = (ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
            + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z))
           * (ComplexNumber.realPart(w) * ComplexNumber.realPart(w)
                  + ComplexNumber.imaginaryPart(w) * ComplexNumber.imaginaryPart(w))
     = (ComplexNumber.modulus(z) * ComplexNumber.modulus(w))
           * (ComplexNumber.modulus(z) * ComplexNumber.modulus(w))
           by productSquares;
  -- |z|·|w| is nonnegative, so comparing squares compares the numbers.
  Real.zero ≤ ComplexNumber.modulus(z) by ComplexNumber.modulus_nonneg;
  Real.zero ≤ ComplexNumber.modulus(w) by ComplexNumber.modulus_nonneg;
  Real.IsNonneg(ComplexNumber.modulus(z));
  Real.IsNonneg(ComplexNumber.modulus(w));
  Real.IsNonneg(ComplexNumber.modulus(z) * ComplexNumber.modulus(w));
  Real.zero ≤ ComplexNumber.modulus(z) * ComplexNumber.modulus(w) by Real.LessOrEqual_zero_of_IsNonneg;
  done by Real.LessOrEqual_of_square_LessOrEqual
}

-- ----------------------------------------------------------------------
-- The triangle inequality.

theorem ComplexNumber.modulus_triangle (z w : ComplexNumber)
        : ComplexNumber.modulus(z + w)
          ≤ ComplexNumber.modulus(z) + ComplexNumber.modulus(w) := {
  -- The coordinates of z + w, instantiated.
  ComplexNumber.realPart(z + w)
      = ComplexNumber.realPart(z) + ComplexNumber.realPart(w) as realSum;
  ComplexNumber.imaginaryPart(z + w)
      = ComplexNumber.imaginaryPart(z) + ComplexNumber.imaginaryPart(w) as imaginarySum;
  -- |z|² and |w|², instantiated.
  ComplexNumber.modulus(z) * ComplexNumber.modulus(z)
      = ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
        + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z)
      by ComplexNumber.modulus_squares as zSquares;
  ComplexNumber.modulus(w) * ComplexNumber.modulus(w)
      = ComplexNumber.realPart(w) * ComplexNumber.realPart(w)
        + ComplexNumber.imaginaryPart(w) * ComplexNumber.imaginaryPart(w)
      by ComplexNumber.modulus_squares as wSquares;
  -- Twice the inner product is at most twice |z|·|w|.
  ComplexNumber.realPart(z) * ComplexNumber.realPart(w)
      + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(w)
      ≤ ComplexNumber.modulus(z) * ComplexNumber.modulus(w)
      by ComplexNumber.inner_product_bound;
  (ComplexNumber.realPart(z) * ComplexNumber.realPart(w)
       + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(w))
      + (ComplexNumber.realPart(z) * ComplexNumber.realPart(w)
             + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(w))
    ≤ ComplexNumber.modulus(z) * ComplexNumber.modulus(w)
          + (ComplexNumber.realPart(z) * ComplexNumber.realPart(w)
                 + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(w))
          by Real.add_preserves_LessOrEqual
    ≤ ComplexNumber.modulus(z) * ComplexNumber.modulus(w)
          + ComplexNumber.modulus(z) * ComplexNumber.modulus(w)
          by Real.add_preserves_LessOrEqual_left;
  -- (|z| + |w|)², expanded into coordinates.
  (ComplexNumber.modulus(z) + ComplexNumber.modulus(w))
      * (ComplexNumber.modulus(z) + ComplexNumber.modulus(w))
    = ComplexNumber.modulus(z) * ComplexNumber.modulus(z)
          + ComplexNumber.modulus(w) * ComplexNumber.modulus(w)
          + (ComplexNumber.modulus(z) * ComplexNumber.modulus(w)
                 + ComplexNumber.modulus(z) * ComplexNumber.modulus(w))
    = (ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
           + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z))
          + ComplexNumber.modulus(w) * ComplexNumber.modulus(w)
          + (ComplexNumber.modulus(z) * ComplexNumber.modulus(w)
                 + ComplexNumber.modulus(z) * ComplexNumber.modulus(w))
          by zSquares
    = (ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
           + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z))
          + (ComplexNumber.realPart(w) * ComplexNumber.realPart(w)
                 + ComplexNumber.imaginaryPart(w) * ComplexNumber.imaginaryPart(w))
          + (ComplexNumber.modulus(z) * ComplexNumber.modulus(w)
                 + ComplexNumber.modulus(z) * ComplexNumber.modulus(w))
          by wSquares
      as expandedSquare;
  -- |z + w|² ≤ (|z| + |w|)²: expand, bound the cross term, regroup.
  ComplexNumber.modulus(z + w) * ComplexNumber.modulus(z + w)
     = ComplexNumber.realPart(z + w) * ComplexNumber.realPart(z + w)
           + ComplexNumber.imaginaryPart(z + w) * ComplexNumber.imaginaryPart(z + w)
           by ComplexNumber.modulus_squares
     = (ComplexNumber.realPart(z) + ComplexNumber.realPart(w))
           * (ComplexNumber.realPart(z) + ComplexNumber.realPart(w))
           + ComplexNumber.imaginaryPart(z + w) * ComplexNumber.imaginaryPart(z + w)
           by realSum
     = (ComplexNumber.realPart(z) + ComplexNumber.realPart(w))
           * (ComplexNumber.realPart(z) + ComplexNumber.realPart(w))
           + (ComplexNumber.imaginaryPart(z) + ComplexNumber.imaginaryPart(w))
                 * (ComplexNumber.imaginaryPart(z) + ComplexNumber.imaginaryPart(w))
           by imaginarySum
     = (ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
            + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z))
           + (ComplexNumber.realPart(w) * ComplexNumber.realPart(w)
                  + ComplexNumber.imaginaryPart(w) * ComplexNumber.imaginaryPart(w))
           + ((ComplexNumber.realPart(z) * ComplexNumber.realPart(w)
                   + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(w))
              + (ComplexNumber.realPart(z) * ComplexNumber.realPart(w)
                     + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(w)))
     ≤ (ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
            + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z))
           + (ComplexNumber.realPart(w) * ComplexNumber.realPart(w)
                  + ComplexNumber.imaginaryPart(w) * ComplexNumber.imaginaryPart(w))
           + (ComplexNumber.modulus(z) * ComplexNumber.modulus(w)
                  + ComplexNumber.modulus(z) * ComplexNumber.modulus(w))
           by Real.add_preserves_LessOrEqual_left
     = (ComplexNumber.modulus(z) + ComplexNumber.modulus(w))
           * (ComplexNumber.modulus(z) + ComplexNumber.modulus(w))
           by expandedSquare;
  -- |z| + |w| is nonnegative, so comparing squares compares the numbers.
  Real.zero ≤ ComplexNumber.modulus(z) by ComplexNumber.modulus_nonneg;
  Real.zero ≤ ComplexNumber.modulus(w) by ComplexNumber.modulus_nonneg;
  Real.IsNonneg(ComplexNumber.modulus(z));
  Real.IsNonneg(ComplexNumber.modulus(w));
  Real.IsNonneg(ComplexNumber.modulus(z) + ComplexNumber.modulus(w));
  Real.zero ≤ ComplexNumber.modulus(z) + ComplexNumber.modulus(w) by Real.LessOrEqual_zero_of_IsNonneg;
  done by Real.LessOrEqual_of_square_LessOrEqual
}

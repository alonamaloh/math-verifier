-- ComplexNumber/field.math
--
-- ℂ is a field. This is the general F[x]/(f)-is-a-field theorem
-- (Polynomial.quotient_is_field) instantiated at F = ℝ and f = x²+1,
-- using that ℝ is a field (commutativity + inverse existence) and that
-- x²+1 is irreducible over ℝ (ComplexNumber.modulus_irreducible).

module ComplexNumber.field

import Logic.basics
import Logic.exists
import Equality.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.field
import Real.basics
import Real.multiplication
import Real.algebra
import Real.instances
import Real.field
import Polynomial.basics
import Polynomial.instances
import Polynomial.irreducible
import Polynomial.quotient_field
import RingModulo.basics
import RingModulo.operations
import RingModulo.ring
import RingModulo.instances
import ComplexNumber.basics
import ComplexNumber.irreducible

theorem ComplexNumber.is_field
        : IsField(
              ComplexNumber,
              RingModulo.add,
              RingModulo.zero(Real.polynomial_ring, Complex.modulus),
              RingModulo.negate(Real.polynomial_ring, Complex.modulus),
              RingModulo.multiply(Real.polynomial_ring,
                  Real.polynomial_ring_commutative, Complex.modulus),
              RingModulo.one(Real.polynomial_ring, Complex.modulus)) :=
  Polynomial.quotient_is_field(Real.ring, Real.multiply_commutative,
      Real.reciprocal_exists_for_nonzero, Complex.modulus,
      Complex.modulus_irreducible)

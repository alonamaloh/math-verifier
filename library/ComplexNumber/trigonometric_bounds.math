-- ----------------------------------------------------------------------
-- Summing a series in pairs: the first 2N terms grouped two at a time.
theorem Real.partialSum_pair (s : ℕ → ℝ) (N : ℕ)
        : Real.partialSum(s, 2 * N)
          = Real.partialSum(
                (m : ℕ) ↦ s(2 * m) + s(1 + 2 * m), N) :=
  by induction on N with IH {
    case base: {
        2 * 0 = 0 as twoTimesZero;
        Real.partialSum(s, 2 * 0)
           = Real.partialSum(s, 0)    by twoTimesZero
           = Real.partialSum(
                 (m : ℕ) ↦ s(2 * m) + s(1 + 2 * m), 0)
      }
    case step(p): {
        2 * (1 + p) = 1 + (1 + 2 * p) as indexStep;
        Real.partialSum(s, 2 * (1 + p))
           = Real.partialSum(s, 1 + (1 + 2 * p))
                 by indexStep
           = Real.partialSum(s, 1 + 2 * p) + s(1 + 2 * p)
                 by Real.partialSum_add_one
           = (Real.partialSum(s, 2 * p) + s(2 * p)) + s(1 + 2 * p)
                 by Real.partialSum_add_one
           = Real.partialSum(
                 (m : ℕ) ↦ s(2 * m) + s(1 + 2 * m), p)
             + (s(2 * p) + s(1 + 2 * p))
                 by IH
           = Real.partialSum(
                 (m : ℕ) ↦ s(2 * m) + s(1 + 2 * m),
                 1 + p)
                 by Real.partialSum_add_one
      }
  }

-- ----------------------------------------------------------------------
-- Even and odd powers of a negation: (−y)^{2m} = y^{2m} and
-- (−y)^{2m+1} = −(y^{2m+1}). Proved together by induction on m (each
-- step multiplies by −y twice). This carries the alternating sign of
-- the cosine/sine coefficients: (−x²)^m flips sign with the parity of m.
theorem Real.power_negate_parity (y : ℝ)
        (n : ℕ)
        : (-y) ^ (2 * n) = y ^ (2 * n) ∧ (-y) ^ (1 + 2 * n) = -(y ^ (1 + 2 * n)) :=
  by induction on n with IH {
    case 0: {
      2 * 0 = 0 as twoTimesZero;
      (-y) ^ (2 * 0)
                = (-y) ^ 0        by twoTimesZero
                = Real.one
                = y ^ 0
                = y ^ (2 * 0)     by twoTimesZero;
      (-y) ^ (1 + 2 * 0) = -(y ^ (1 + 2 * 0))
          by {
            1 + 2 * 0 = 1 as onePlusTwoTimesZero;
            (-y) ^ (1 + 2 * 0)
               = (-y) ^ 1               by onePlusTwoTimesZero
               = (-y) * (-y) ^ 0
               = (-y) * Real.one
               = -(y * Real.one)
               = -(y * y ^ 0)
               = -(y ^ 1)
               = -(y ^ (1 + 2 * 0))
                     by onePlusTwoTimesZero
          };
      done by And.introduction
    }
    case 1 + m: {
      (-y) ^ (2 * m) = y ^ (2 * m)
          ∧ (-y) ^ (1 + 2 * m) = -(y ^ (1 + 2 * m))
          by IH;
      (-y) ^ (2 * m) = y ^ (2 * m) as evenAt;
      (-y) ^ (1 + 2 * m) = -(y ^ (1 + 2 * m));
      2 * (1 + m) = 1 + (1 + 2 * m) as indexEven;
      1 + 2 * (1 + m) = 1 + (1 + (1 + 2 * m)) as indexOdd;
      (-y) ^ (2 * (1 + m))
                = (-y) ^ (1 + (1 + 2 * m))
                      by indexEven
                = (-y) * (-y) ^ (1 + 2 * m)
                      by Real.power_add_one
                = (-y) * ((-y) * (-y) ^ (2 * m))
                      by Real.power_add_one
                = (-y) * ((-y) * y ^ (2 * m))
                      by evenAt
                = y * (y * y ^ (2 * m))
                      by ring
                = y * y ^ (1 + 2 * m)
                      by Real.power_add_one
                = y ^ (1 + (1 + 2 * m))
                      by Real.power_add_one
                = y ^ (2 * (1 + m))
                      by indexEven;
      (-y) ^ (1 + 2 * (1 + m))
                = (-y) ^ (1 + (1 + (1 + 2 * m)))
                      by indexOdd
                = (-y) * (-y) ^ (1 + (1 + 2 * m))
                      by Real.power_add_one
                = (-y) * ((-y) * (-y) ^ (1 + 2 * m))
                      by Real.power_add_one
                = (-y) * ((-y) * ((-y) * (-y) ^ (2 * m)))
                      by Real.power_add_one
                = (-y) * ((-y) * ((-y) * y ^ (2 * m)))
                      by evenAt
                = -(y * (y * (y * y ^ (2 * m))))
                      by ring
                = -(y * (y * y ^ (1 + 2 * m)))
                      by Real.power_add_one
                = -(y * y ^ (1 + (1 + 2 * m)))
                      by Real.power_add_one
                = -(y ^ (1 + (1 + (1 + 2 * m))))
                      by Real.power_add_one
                = -(y ^ (1 + 2 * (1 + m)))
                      by indexOdd;
      done by And.introduction
    }
  }

-- The two projections, as standalone facts.
theorem Real.power_negate_even (y : ℝ) (m : ℕ)
        : (-y) ^ (2 * m) = y ^ (2 * m) := {
  (-y) ^ (2 * m) = y ^ (2 * m)
      ∧ (-y) ^ (1 + 2 * m) = -(y ^ (1 + 2 * m))
      by Real.power_negate_parity;
  done
}

theorem Real.power_negate_odd (y : ℝ) (m : ℕ)
        : (-y) ^ (1 + 2 * m) = -(y ^ (1 + 2 * m)) := {
  (-y) ^ (2 * m) = y ^ (2 * m)
      ∧ (-y) ^ (1 + 2 * m) = -(y ^ (1 + 2 * m))
      by Real.power_negate_parity;
  done
}

-- ----------------------------------------------------------------------
-- The even subsequence of a convergent sequence converges to the same
-- limit (2N grows past any threshold, since N ≤ 2N).
theorem Real.SequenceConverges.subsequence_double
        (s : ℕ → ℝ) (limit : ℝ)
        (converges : Real.SequenceConverges(s, limit))
        : Real.SequenceConverges((N : ℕ) ↦ s(2 * N), limit) :=
  (ε : ℝ) (εPositive : ε > 0) ↦ {
    choose threshold such that ∀ (m : ℕ). threshold ≤ m → abs(s(m) - limit) < ε
        as close from converges(ε, εPositive);
    witness threshold with
        (N : ℕ) (aboveThreshold : threshold ≤ N) ↦ {
          threshold ≤ 2 * N
              by {
                N ≤ N + N;
                2 * N = N + N as twoN;
                N ≤ 2 * N by substituting twoN;
                done
              };
          done by close
        }
  }

-- ----------------------------------------------------------------------
-- The cosine series, regrouped onto its even terms. The odd terms
-- Re(term_{2m+1}) vanish, so cos x is the limit of Σ_m Re(term_{2m}).
theorem Real.cosine_paired_series_converges (x : ℝ)
        : Real.SequenceConverges(
              Real.partialSum(
                  (m : ℕ) ↦
                      ComplexNumber.realPart(
                          ComplexNumber.exponentialTerm(
                              ComplexNumber.i * ComplexNumber.from_real(x),
                              2 * m))),
              cos(x)) := {
  -- The full series converges to cos x; so does its even subsequence.
  Real.SequenceConverges(
            Real.partialSum(
                (k : ℕ) ↦
                    ComplexNumber.realPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x), k))),
            cos(x))
      by Real.cosine_series_converges;
  Real.SequenceConverges(
            (N : ℕ) ↦
                Real.partialSum(
                    (k : ℕ) ↦
                        ComplexNumber.realPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), k)),
                    2 * N),
            cos(x))
      by Real.SequenceConverges.subsequence_double as evenSubsequence;
  -- Each 2N-cut sums in pairs, and each pair drops to its even term.
  ∀ (N : ℕ).
        Real.partialSum(
              (k : ℕ) ↦
                  ComplexNumber.realPart(
                      ComplexNumber.exponentialTerm(
                          ComplexNumber.i * ComplexNumber.from_real(x), k)),
              2 * N)
          = Real.partialSum(
                (m : ℕ) ↦
                    ComplexNumber.realPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x), 2 * m)),
                N)
      by (N : ℕ) ↦
           Real.partialSum(
                    (k : ℕ) ↦
                        ComplexNumber.realPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), k)),
                    2 * N)
              = Real.partialSum(
                    (m : ℕ) ↦
                        ComplexNumber.realPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))
                        + ComplexNumber.realPart(
                              ComplexNumber.exponentialTerm(
                                  ComplexNumber.i * ComplexNumber.from_real(x),
                                  1 + 2 * m)),
                    N)
                    by Real.partialSum_pair
              = Real.partialSum(
                    (m : ℕ) ↦
                        ComplexNumber.realPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), 2 * m)),
                    N)
                    by Real.partialSum_pointwise(pointwiseEqual := (m : ℕ) ↦ {
                             1 + 2 * m = 2 * m + 1 as oddIndexForm;
                             ComplexNumber.realPart(
                                       ComplexNumber.exponentialTerm(
                                           ComplexNumber.i * ComplexNumber.from_real(x),
                                           1 + 2 * m))
                                   = ComplexNumber.realPart(
                                         ComplexNumber.exponentialTerm(
                                             ComplexNumber.i * ComplexNumber.from_real(x),
                                             2 * m + 1))
                                         by oddIndexForm
                                   = Real.zero
                                         by Real.cosine_term_odd(x, m) as oddVanishes;
                             ComplexNumber.realPart(
                                      ComplexNumber.exponentialTerm(
                                          ComplexNumber.i * ComplexNumber.from_real(x),
                                          2 * m))
                                  + ComplexNumber.realPart(
                                        ComplexNumber.exponentialTerm(
                                            ComplexNumber.i * ComplexNumber.from_real(x),
                                            1 + 2 * m))
                                = ComplexNumber.realPart(
                                      ComplexNumber.exponentialTerm(
                                          ComplexNumber.i * ComplexNumber.from_real(x),
                                          2 * m))
                                  + Real.zero
                                    by oddVanishes
                                = ComplexNumber.realPart(
                                      ComplexNumber.exponentialTerm(
                                          ComplexNumber.i * ComplexNumber.from_real(x),
                                          2 * m))
                           }) as pairsCollapse;
  done by Real.SequenceConverges.of_pointwise(
              s := (N : ℕ) ↦
                  Real.partialSum(
                      (k : ℕ) ↦
                          ComplexNumber.realPart(
                              ComplexNumber.exponentialTerm(
                                  ComplexNumber.i * ComplexNumber.from_real(x), k)),
                      2 * N),
              t := Real.partialSum(
                  (m : ℕ) ↦
                      ComplexNumber.realPart(
                          ComplexNumber.exponentialTerm(
                              ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))),
              limit := cos(x),
              pointwiseEqual := pairsCollapse, sConverges := evenSubsequence)
}

-- ----------------------------------------------------------------------
-- The sine series, regrouped onto its odd terms. The even terms
-- Im(term_{2m}) vanish, so sin x is the limit of Σ_m Im(term_{2m+1}).
theorem Real.sine_paired_series_converges (x : ℝ)
        : Real.SequenceConverges(
              Real.partialSum(
                  (m : ℕ) ↦
                      ComplexNumber.imaginaryPart(
                          ComplexNumber.exponentialTerm(
                              ComplexNumber.i * ComplexNumber.from_real(x),
                              1 + 2 * m))),
              sin(x)) := {
  Real.SequenceConverges(
            Real.partialSum(
                (k : ℕ) ↦
                    ComplexNumber.imaginaryPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x), k))),
            sin(x))
      by Real.sine_series_converges;
  Real.SequenceConverges(
            (N : ℕ) ↦
                Real.partialSum(
                    (k : ℕ) ↦
                        ComplexNumber.imaginaryPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), k)),
                    2 * N),
            sin(x))
      by Real.SequenceConverges.subsequence_double as evenSubsequence;
  ∀ (N : ℕ).
        Real.partialSum(
              (k : ℕ) ↦
                  ComplexNumber.imaginaryPart(
                      ComplexNumber.exponentialTerm(
                          ComplexNumber.i * ComplexNumber.from_real(x), k)),
              2 * N)
          = Real.partialSum(
                (m : ℕ) ↦
                    ComplexNumber.imaginaryPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x),
                            1 + 2 * m)),
                N)
      by (N : ℕ) ↦
           Real.partialSum(
                    (k : ℕ) ↦
                        ComplexNumber.imaginaryPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), k)),
                    2 * N)
              = Real.partialSum(
                    (m : ℕ) ↦
                        ComplexNumber.imaginaryPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))
                        + ComplexNumber.imaginaryPart(
                              ComplexNumber.exponentialTerm(
                                  ComplexNumber.i * ComplexNumber.from_real(x),
                                  1 + 2 * m)),
                    N)
                    by Real.partialSum_pair
              = Real.partialSum(
                    (m : ℕ) ↦
                        ComplexNumber.imaginaryPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x),
                                1 + 2 * m)),
                    N)
                    by Real.partialSum_pointwise(pointwiseEqual := (m : ℕ) ↦ {
                             ComplexNumber.imaginaryPart(
                                       ComplexNumber.exponentialTerm(
                                           ComplexNumber.i * ComplexNumber.from_real(x),
                                           2 * m))
                                   = Real.zero
                                 by Real.sine_term_even as evenVanishes;
                             ComplexNumber.imaginaryPart(
                                      ComplexNumber.exponentialTerm(
                                          ComplexNumber.i * ComplexNumber.from_real(x),
                                          2 * m))
                                  + ComplexNumber.imaginaryPart(
                                        ComplexNumber.exponentialTerm(
                                            ComplexNumber.i * ComplexNumber.from_real(x),
                                            1 + 2 * m))
                                = Real.zero
                                  + ComplexNumber.imaginaryPart(
                                        ComplexNumber.exponentialTerm(
                                            ComplexNumber.i * ComplexNumber.from_real(x),
                                            1 + 2 * m))
                                    by evenVanishes
                                = ComplexNumber.imaginaryPart(
                                      ComplexNumber.exponentialTerm(
                                          ComplexNumber.i * ComplexNumber.from_real(x),
                                          1 + 2 * m))
                           }) as pairsCollapse;
  done by Real.SequenceConverges.of_pointwise(
              s := (N : ℕ) ↦
                  Real.partialSum(
                      (k : ℕ) ↦
                          ComplexNumber.imaginaryPart(
                              ComplexNumber.exponentialTerm(
                                  ComplexNumber.i * ComplexNumber.from_real(x), k)),
                      2 * N),
              t := Real.partialSum(
                  (m : ℕ) ↦
                      ComplexNumber.imaginaryPart(
                          ComplexNumber.exponentialTerm(
                              ComplexNumber.i * ComplexNumber.from_real(x),
                              1 + 2 * m))),
              limit := sin(x),
              pointwiseEqual := pairsCollapse, sConverges := evenSubsequence)
}

-- ----------------------------------------------------------------------
-- Factorial is monotone: a ≤ b ⟹ a! ≤ b!. Each step multiplies by a
-- factor ≥ 1, so a! ≤ (a+1)!; the general case chains those.
theorem Natural.factorial_le_one_plus (n : ℕ)
        : n! ≤ (1 + n)! := {
  1 ≤ 1 + n;
  n! * 1 ≤ n! * (1 + n) as scaled;
  n!
     = n! * 1
     ≤ n! * (1 + n)
           by scaled
     = (1 + n) * n!
     = (1 + n)!
           by Natural.factorial_add_one
}

-- a! ≤ (k + a)!, by induction on the gap k (each step a factorial-le-one_plus).
theorem Natural.factorial_le_add (a : ℕ) (k : ℕ)
        : a! ≤ (k + a)! :=
  by induction on k with IH {
    case 0: {
        a! ≤ a!;
        done by substituting Natural.zero_add
      }
    case 1 + p: {
        a! ≤ (p + a)!
            by IH;
        (p + a)!
              ≤ (1 + (p + a))!
            by Natural.factorial_le_one_plus;
        a! ≤ (1 + (p + a))!
            by Natural.LessOrEqual.transitive;
        1 + (p + a) = (1 + p) + a;
        a! ≤ ((1 + p) + a)!;
        done by substituting Natural.one_add
      }
  }

theorem Natural.factorial_monotone (a b : ℕ) (aLeB : a ≤ b)
        : a! ≤ b! := {
  choose k such that b = k + a as bEqual from Natural.le_to_add;
  a! ≤ (k + a)!
      by Natural.factorial_le_add;
  done by substituting bEqual
}

-- ----------------------------------------------------------------------
-- The exponential coefficients 1/k! decrease: i ≤ j ⟹ 1/j! ≤ 1/i!
-- (factorial monotone, then reciprocal antitone, carried across the
-- ℚ → ℝ casts).
theorem Real.exponentialCoefficient_antitone (i j : ℕ) (iLeqJ : i ≤ j)
        : Real.exponentialCoefficient(j) ≤ Real.exponentialCoefficient(i) := {
  i! ≤ j! by Natural.factorial_monotone;
  (i! : ℝ) ≤ (j! : ℝ) by Real.from_natural.LessOrEqual_preserves;
  (i! : ℝ) > 0 by Real.factorial_cast_positive;
  (j! : ℝ) > 0 by Real.factorial_cast_positive;
  (i! : ℝ) ≠ 0;
  (j! : ℝ) ≠ 0;
  done by Real.one_divide_antitone
}

-- ----------------------------------------------------------------------
-- Every natural is even or odd: n = 2j or n = 2j+1.
theorem Natural.even_or_odd (n : ℕ)
        : ∃ (j : ℕ). n = 2 * j ∨ n = 1 + 2 * j :=
  by induction on n with IH {
    case 0: {
        (0 : ℕ) = 2 * 0 as base;
        witness 0 with Or.introduceLeft(base)
      }
    case 1 + p: {
        choose j such that p = 2 * j ∨ p = 1 + 2 * j from IH;
        done by cases {
          case p = 2 * j as pEven:
              witness j with Or.introduceRight({ 1 + (2 * j) = 1 + 2 * j })
          case p = 1 + 2 * j as pOdd:
              witness (1 + j) with Or.introduceLeft({ 1 + (1 + 2 * j) = 2 * (1 + j) })
        }
      }
  }

-- ----------------------------------------------------------------------
-- Partial sums of an "alternating, decreasing-magnitude" series stay
-- non-positive when the leading (even-indexed) terms are ≤ 0 and each
-- consecutive pair sums to ≤ 0. The even and odd cuts are handled
-- together by induction on the pair index.
theorem Real.partialSum_nonpositive_paired (g : ℕ → ℝ)
        (leadNonpositive : ∀ (j : ℕ). g(2 * j) ≤ Real.zero)
        (pairNonpositive
            : ∀ (j : ℕ). g(2 * j) + g(1 + 2 * j) ≤ Real.zero)
        (n : ℕ)
        : Real.partialSum(g, 2 * n) ≤ Real.zero ∧ Real.partialSum(g, 1 + 2 * n) ≤ Real.zero :=
  by induction on n with IH {
    case 0: {
      Real.partialSum(g, 2 * 0) ≤ Real.zero;
      Real.partialSum(g, 1 + 2 * 0)
                = Real.partialSum(g, 2 * 0) + g(2 * 0)
                      by Real.partialSum_add_one
                = Real.zero + g(2 * 0)
                = g(2 * 0)
                ≤ Real.zero
                      by leadNonpositive(0);
      done
    }
    case 1 + j: {
      Real.partialSum(g, 2 * j) ≤ Real.zero
          ∧ Real.partialSum(g, 1 + 2 * j) ≤ Real.zero
          by IH;
      2 * (1 + j) = 1 + (1 + 2 * j) as indexEven;
      g(2 * j) + g(1 + 2 * j) ≤ Real.zero;
      Real.partialSum(g, 2 * (1 + j))
                = Real.partialSum(g, 1 + (1 + 2 * j))
                      by indexEven
                = Real.partialSum(g, 1 + 2 * j) + g(1 + 2 * j)
                      by Real.partialSum_add_one
                = (Real.partialSum(g, 2 * j) + g(2 * j)) + g(1 + 2 * j)
                      by Real.partialSum_add_one
                = Real.partialSum(g, 2 * j) + (g(2 * j) + g(1 + 2 * j))
                      by ring
                ≤ Real.zero + (g(2 * j) + g(1 + 2 * j))
                      by Real.add_preserves_LessOrEqual
                ≤ Real.zero + Real.zero
                      by Real.add_preserves_LessOrEqual_left
                = Real.zero;
      g(2 * (1 + j)) ≤ Real.zero;
      Real.partialSum(g, 1 + 2 * (1 + j))
                = Real.partialSum(g, 2 * (1 + j)) + g(2 * (1 + j))
                      by Real.partialSum_add_one
                ≤ Real.zero + g(2 * (1 + j))
                      by Real.add_preserves_LessOrEqual
                ≤ Real.zero + Real.zero
                      by Real.add_preserves_LessOrEqual_left
                = Real.zero;
      done
    }
  }

-- … hence non-positive at every cut (split n by parity).
theorem Real.partialSum_nonpositive (g : ℕ → ℝ)
        (leadNonpositive : ∀ (j : ℕ). g(2 * j) ≤ Real.zero)
        (pairNonpositive
            : ∀ (j : ℕ). g(2 * j) + g(1 + 2 * j) ≤ Real.zero)
        (n : ℕ)
        : Real.partialSum(g, n) ≤ Real.zero := {
  choose j such that n = 2 * j ∨ n = 1 + 2 * j from Natural.even_or_odd;
  Real.partialSum(g, 2 * j) ≤ Real.zero
      ∧ Real.partialSum(g, 1 + 2 * j) ≤ Real.zero
      by Real.partialSum_nonpositive_paired;
  Real.partialSum(g, 2 * j) ≤ Real.zero as evenPaired;
  Real.partialSum(g, 1 + 2 * j) ≤ Real.zero as oddPaired;
  done by cases {
    case n = 2 * j as nEven:
        Real.partialSum(g, n)
           = Real.partialSum(g, 2 * j)    by nEven
           ≤ Real.zero                    by evenPaired
    case n = 1 + 2 * j as nOdd:
        Real.partialSum(g, n)
           = Real.partialSum(g, 1 + 2 * j)    by nOdd
           ≤ Real.zero                        by oddPaired
  }
}

-- ----------------------------------------------------------------------
-- The mirror: partial sums stay NON-NEGATIVE when the even-indexed
-- terms are ≥ 0 and each consecutive pair sums to ≥ 0 (apply the
-- non-positive lemma to −g, which negates the partial sums).
theorem Real.partialSum_nonnegative (g : ℕ → ℝ)
        (leadNonnegative : ∀ (j : ℕ). Real.zero ≤ g(2 * j))
        (pairNonnegative
            : ∀ (j : ℕ). Real.zero ≤ g(2 * j) + g(1 + 2 * j))
        (n : ℕ)
        : Real.zero ≤ Real.partialSum(g, n) := {
  ∀ (j : ℕ). -g(2 * j) ≤ Real.zero
      by (j : ℕ) ↦
           -g(2 * j)
              ≤ -Real.zero
                    by Real.LessOrEqual.negate
              = Real.zero;
  ∀ (j : ℕ). -g(2 * j) + -g(1 + 2 * j) ≤ Real.zero
      by (j : ℕ) ↦
           -g(2 * j) + -g(1 + 2 * j)
              = -(g(2 * j) + g(1 + 2 * j))
              ≤ -Real.zero
                    by Real.LessOrEqual.negate
              = Real.zero;
  Real.partialSum((k : ℕ) ↦ -g(k), n) ≤ Real.zero;
  -Real.partialSum(g, n) ≤ Real.zero
      by {
        Real.partialSum((k : ℕ) ↦ -g(k), n) = -Real.partialSum(g, n);
        done by substituting (Real.partialSum((k : ℕ) ↦ -g(k), n)
                                  = -Real.partialSum(g, n))
      };
  Real.zero
     = -Real.zero
     ≤ -(-Real.partialSum(g, n))
           by Real.LessOrEqual.negate
     = Real.partialSum(g, n)
}

-- ----------------------------------------------------------------------
-- Powers of one are one.
theorem Real.power_one (n : ℕ) : Real.one ^ n = Real.one :=
  by induction on n with IH {
    case base: done
    case step(p):
        Real.one ^ (1 + p)
           = Real.one * Real.one ^ p
                 by Real.power_add_one
           = Real.one * Real.one    by IH
           = Real.one
  }

-- ----------------------------------------------------------------------
-- The cosine coefficient c_m = Re of the (2m)-th term of exp(ix): the
-- non-vanishing terms of the cosine series.
definition Real.cosineCoefficient (x : ℝ) (m : ℕ) : ℝ :=
  ComplexNumber.realPart(
      ComplexNumber.exponentialTerm(
          ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))

-- At x = 1 it is ±1/(2m)!: the coefficient times (−1)^m.
theorem Real.cosineCoefficient_one_value (m : ℕ)
        : Real.cosineCoefficient(Real.one, m)
          = Real.exponentialCoefficient(2 * m) * (-Real.one) ^ m :=
  Real.cosineCoefficient(Real.one, m)
     = Real.exponentialCoefficient(2 * m) * (-(Real.one * Real.one)) ^ m
           by Real.cosine_term_even
     = Real.exponentialCoefficient(2 * m) * (-Real.one) ^ m
           by substituting (ring : Real.one * Real.one = Real.one)

-- 1/k! is non-negative.
theorem Real.exponentialCoefficient_nonneg (k : ℕ)
        : Real.zero ≤ Real.exponentialCoefficient(k) := {
  (k! : ℝ) > 0 by Real.factorial_cast_positive;
  (k! : ℝ) ≠ 0;
  1 / (k! : ℝ) > 0 by Real.divide_positive;
  1 / (k! : ℝ) ≥ 0;
  done
}

-- The even-indexed coefficient is +1/(4j)! ≥ 0.
theorem Real.cosineCoefficient_one_even (j : ℕ)
        : Real.cosineCoefficient(Real.one, 2 * j)
          = Real.exponentialCoefficient(2 * (2 * j)) := {
  (-Real.one) ^ (2 * j)
            = Real.one ^ (2 * j)
                  by Real.power_negate_even
            = Real.one as signOne;
  Real.cosineCoefficient(Real.one, 2 * j)
     = Real.exponentialCoefficient(2 * (2 * j)) * (-Real.one) ^ (2 * j)
     = Real.exponentialCoefficient(2 * (2 * j)) * Real.one
           by signOne
     = Real.exponentialCoefficient(2 * (2 * j))
}

-- The odd-indexed coefficient is −1/(2(2j+1))! ≤ 0.
theorem Real.cosineCoefficient_one_odd (j : ℕ)
        : Real.cosineCoefficient(Real.one, 1 + 2 * j)
          = -Real.exponentialCoefficient(2 * (1 + 2 * j)) := {
  (-Real.one) ^ (1 + 2 * j)
            = -(Real.one ^ (1 + 2 * j))
            = -Real.one
                  by Real.power_one as signNegOne;
  Real.cosineCoefficient(Real.one, 1 + 2 * j)
     = Real.exponentialCoefficient(2 * (1 + 2 * j))
           * (-Real.one) ^ (1 + 2 * j)
     = Real.exponentialCoefficient(2 * (1 + 2 * j)) * (-Real.one)
           by signNegOne
     = -Real.exponentialCoefficient(2 * (1 + 2 * j))
           by ring
}

-- ----------------------------------------------------------------------
-- The cosine series at x = 1, summed from index 3 on, never adds
-- anything positive: cos 1 ≤ S₃ = 1 − 1/2 + 1/24.
theorem Real.cosine_one_upper_bound
        : cos(Real.one)
          ≤ Real.partialSum(Real.cosineCoefficient(Real.one), 3) := {
  -- Lead terms (odd index 3 + 2k) are −1/(…)! ≤ 0.
  ∀ (k : ℕ). Real.cosineCoefficient(Real.one, 3 + 2 * k) ≤ Real.zero
      by (k : ℕ) ↦ {
           (3 : ℕ) + 2 * k = 1 + 2 * (1 + k) as oddIndex;
           Real.cosineCoefficient(Real.one, 3 + 2 * k)
                     = Real.cosineCoefficient(Real.one, 1 + 2 * (1 + k))
                           by oddIndex
                     = -Real.exponentialCoefficient(
                            2 * (1 + 2 * (1 + k))) as ccValue;
           Real.zero
                 ≤ Real.exponentialCoefficient(2 * (1 + 2 * (1 + k)));
           Real.cosineCoefficient(Real.one, 3 + 2 * k)
              = -Real.exponentialCoefficient(2 * (1 + 2 * (1 + k)))
                    by ccValue
              ≤ -Real.zero
                    by Real.LessOrEqual.negate
              = Real.zero
         };
  -- Each consecutive pair (odd then even) sums to ≤ 0 (magnitudes shrink).
  ∀ (k : ℕ).
        Real.cosineCoefficient(Real.one, 3 + 2 * k)
              + Real.cosineCoefficient(Real.one, 3 + (1 + 2 * k))
          ≤ Real.zero
      by (k : ℕ) ↦ {
           (3 : ℕ) + 2 * k = 1 + 2 * (1 + k) as oddIndex;
           (3 : ℕ) + (1 + 2 * k) = 2 * (1 + (1 + k)) as evenIndex;
           Real.cosineCoefficient(Real.one, 3 + 2 * k)
                     = Real.cosineCoefficient(Real.one, 1 + 2 * (1 + k))
                           by oddIndex
                     = -Real.exponentialCoefficient(
                            2 * (1 + 2 * (1 + k))) as oddValue;
           Real.cosineCoefficient(Real.one, 3 + (1 + 2 * k))
                     = Real.cosineCoefficient(Real.one, 2 * (1 + (1 + k)))
                           by evenIndex
                     = Real.exponentialCoefficient(2 * (2 * (1 + (1 + k))));
           2 * (1 + 2 * (1 + k))
                 ≤ 2 * (2 * (1 + (1 + k)))
               by {
                 2 * (2 * (1 + (1 + k)))
                             = 2 * (1 + 2 * (1 + k)) + 2
                     by ring as gap;
                 2 * (1 + 2 * (1 + k))
                       ≤ 2 * (1 + 2 * (1 + k)) + 2;
                 done by substituting gap
               };
           Real.exponentialCoefficient(2 * (2 * (1 + (1 + k))))
                 ≤ Real.exponentialCoefficient(2 * (1 + 2 * (1 + k)));
           Real.cosineCoefficient(Real.one, 3 + 2 * k)
                    + Real.cosineCoefficient(Real.one, 3 + (1 + 2 * k))
              = -Real.exponentialCoefficient(2 * (1 + 2 * (1 + k)))
                + Real.exponentialCoefficient(2 * (2 * (1 + (1 + k))))
                    by oddValue
              = -Real.exponentialCoefficient(2 * (1 + 2 * (1 + k)))
                + Real.exponentialCoefficient(2 * (2 * (1 + (1 + k))))
              ≤ -Real.exponentialCoefficient(2 * (1 + 2 * (1 + k)))
                + Real.exponentialCoefficient(2 * (1 + 2 * (1 + k)))
                    by Real.add_preserves_LessOrEqual_left
              = Real.zero
         };
  -- Hence the tail from index 3 is non-positive, and every partial sum
  -- past 3 stays ≤ S₃.
  ∀ (M : ℕ). 3 ≤ M
        → Real.partialSum(Real.cosineCoefficient(Real.one), M)
          ≤ Real.partialSum(Real.cosineCoefficient(Real.one), 3)
      by (M : ℕ) (threeLeqM : 3 ≤ M) ↦ {
           choose r such that M = r + 3 as mEqual from Natural.le_to_add;
           Real.partialSum(
                     (j : ℕ) ↦ Real.cosineCoefficient(Real.one, 3 + j), r)
                 ≤ Real.zero;
           Real.partialSum(Real.cosineCoefficient(Real.one), M)
                     = Real.partialSum(Real.cosineCoefficient(Real.one), r + 3)
                           by mEqual
                     = Real.partialSum(Real.cosineCoefficient(Real.one), 3)
                       + Real.partialSum(
                             (j : ℕ) ↦ Real.cosineCoefficient(Real.one, 3 + j),
                             r)
                           by Real.partialSum_split as splitForm;
           Real.partialSum(Real.cosineCoefficient(Real.one), M)
              = Real.partialSum(Real.cosineCoefficient(Real.one), 3)
                + Real.partialSum(
                      (j : ℕ) ↦ Real.cosineCoefficient(Real.one, 3 + j), r)
                    by splitForm
              ≤ Real.partialSum(Real.cosineCoefficient(Real.one), 3) + Real.zero
                    by Real.add_preserves_LessOrEqual_left
              = Real.partialSum(Real.cosineCoefficient(Real.one), 3)
         };
  Real.SequenceConverges(Real.partialSum(Real.cosineCoefficient(Real.one)), cos(Real.one));
  done by Real.SequenceConverges.le_of_eventually_le
}

-- ----------------------------------------------------------------------
-- The matching lower bracket: summed from index 2 on, the cosine series
-- adds nothing negative, so cos 1 ≥ S₂ = 1 − 1/2 = 1/2.
theorem Real.cosine_one_lower_bound
        : Real.partialSum(Real.cosineCoefficient(Real.one), 2)
          ≤ cos(Real.one) := {
  ∀ (k : ℕ). Real.zero ≤ Real.cosineCoefficient(Real.one, 2 + 2 * k)
      by (k : ℕ) ↦ {
           (2 : ℕ) + 2 * k = 2 * (1 + k) as evenIndex;
           Real.cosineCoefficient(Real.one, 2 + 2 * k)
                     = Real.cosineCoefficient(Real.one, 2 * (1 + k))
                           by evenIndex
                     = Real.exponentialCoefficient(2 * (2 * (1 + k))) as ccValue;
           Real.zero ≤ Real.exponentialCoefficient(2 * (2 * (1 + k)));
           done by substituting ccValue
         };
  ∀ (k : ℕ).
        Real.zero
          ≤ Real.cosineCoefficient(Real.one, 2 + 2 * k)
                + Real.cosineCoefficient(Real.one, 2 + (1 + 2 * k))
      by (k : ℕ) ↦ {
           (2 : ℕ) + 2 * k = 2 * (1 + k) as evenIndex;
           (2 : ℕ) + (1 + 2 * k) = 1 + 2 * (1 + k) as oddIndex;
           Real.cosineCoefficient(Real.one, 2 + 2 * k)
                     = Real.cosineCoefficient(Real.one, 2 * (1 + k))
                           by evenIndex
                     = Real.exponentialCoefficient(2 * (2 * (1 + k))) as evenValue;
           Real.cosineCoefficient(Real.one, 2 + (1 + 2 * k))
                     = Real.cosineCoefficient(Real.one, 1 + 2 * (1 + k))
                           by oddIndex
                     = -Real.exponentialCoefficient(
                            2 * (1 + 2 * (1 + k))) as oddValue;
           2 * (2 * (1 + k)) ≤ 2 * (1 + 2 * (1 + k))
               by {
                 2 * (1 + 2 * (1 + k))
                             = 2 * (2 * (1 + k)) + 2
                     by ring as gap;
                 2 * (2 * (1 + k)) ≤ 2 * (2 * (1 + k)) + 2;
                 done by substituting gap
               };
           Real.exponentialCoefficient(2 * (1 + 2 * (1 + k)))
                 ≤ Real.exponentialCoefficient(2 * (2 * (1 + k)));
           -Real.exponentialCoefficient(2 * (2 * (1 + k)))
                 ≤ -Real.exponentialCoefficient(2 * (1 + 2 * (1 + k)))
               by Real.LessOrEqual.negate;
           Real.zero
              = Real.exponentialCoefficient(2 * (2 * (1 + k)))
                + -Real.exponentialCoefficient(2 * (2 * (1 + k)))
              ≤ Real.exponentialCoefficient(2 * (2 * (1 + k)))
                + -Real.exponentialCoefficient(2 * (1 + 2 * (1 + k)))
                    by Real.add_preserves_LessOrEqual_left
              = Real.cosineCoefficient(Real.one, 2 + 2 * k)
                + -Real.exponentialCoefficient(2 * (1 + 2 * (1 + k)))
                    by evenValue
              = Real.cosineCoefficient(Real.one, 2 + 2 * k)
                + Real.cosineCoefficient(Real.one, 2 + (1 + 2 * k))
                    by oddValue
         };
  ∀ (M : ℕ). 2 ≤ M
        → Real.partialSum(Real.cosineCoefficient(Real.one), 2)
          ≤ Real.partialSum(Real.cosineCoefficient(Real.one), M)
      by (M : ℕ) (twoLeqM : 2 ≤ M) ↦ {
           choose r such that M = r + 2 as mEqual from Natural.le_to_add;
           Real.zero
                 ≤ Real.partialSum(
                       (j : ℕ) ↦ Real.cosineCoefficient(Real.one, 2 + j), r)
               by Real.partialSum_nonnegative;
           Real.partialSum(Real.cosineCoefficient(Real.one), M)
                     = Real.partialSum(Real.cosineCoefficient(Real.one), r + 2)
                           by mEqual
                     = Real.partialSum(Real.cosineCoefficient(Real.one), 2)
                       + Real.partialSum(
                             (j : ℕ) ↦ Real.cosineCoefficient(Real.one, 2 + j),
                             r)
                           by Real.partialSum_split as splitForm;
           Real.partialSum(Real.cosineCoefficient(Real.one), 2)
              = Real.partialSum(Real.cosineCoefficient(Real.one), 2) + Real.zero
                    by ring
              ≤ Real.partialSum(Real.cosineCoefficient(Real.one), 2)
                + Real.partialSum(
                      (j : ℕ) ↦ Real.cosineCoefficient(Real.one, 2 + j), r)
                    by Real.add_preserves_LessOrEqual_left
              = Real.partialSum(Real.cosineCoefficient(Real.one), M)
                    by splitForm
         };
  Real.SequenceConverges(Real.partialSum(Real.cosineCoefficient(Real.one)), cos(Real.one));
  done by Real.SequenceConverges.ge_of_eventually_ge
}

-- ----------------------------------------------------------------------
-- Double angle: cos 2 = 2·cos²1 − 1 (cosine_add at (1,1), with sin²
-- eliminated by sin² + cos² = 1).
theorem Real.cosine_double
        : cos(Real.one + Real.one)
          = (Real.one + Real.one) * (cos(Real.one) * cos(Real.one)) - Real.one := {
  cos(Real.one) * cos(Real.one) + sin(Real.one) * sin(Real.one) = Real.one
      by Real.pythagorean_identity as pythagorean;
  sin(Real.one) * sin(Real.one) = Real.one - cos(Real.one) * cos(Real.one)
      by linear_combination(pythagorean) as sinSquare;
  cos(Real.one + Real.one)
     = cos(Real.one) * cos(Real.one) - sin(Real.one) * sin(Real.one)
     = cos(Real.one) * cos(Real.one)
       - (Real.one - cos(Real.one) * cos(Real.one))
           by substituting sinSquare
     = (Real.one + Real.one) * (cos(Real.one) * cos(Real.one)) - Real.one
           by ring
}

-- ----------------------------------------------------------------------
-- A strict natural inequality a < b casts to a strict inequality between
-- the reals (a : ℝ) < (b : ℝ): cast the weak (a + 1 ≤ b) leg through ℚ,
-- and bridge a < a + 1 by adding a real one.
theorem Real.from_natural_LessThan (a b : ℕ) (aLessThanB : a < b)
        : (a : ℝ) < (b : ℝ) := {
  a + 1 ≤ b by Natural.add_one_le_of_lt;
  (a + 1 : ℚ) ≤ (b : ℚ)
      by Rational.from_natural.LessOrEqual_preserves;
  (a + 1 : ℝ) ≤ (b : ℝ)
      by Rational.to_real.LessOrEqual_preserves;
  (a + 1 : ℝ)
            = (a : ℝ) + (1 : ℝ)
                  by Real.from_natural.add_preserves
            = (a : ℝ) + Real.one as aPlusOneReal;
  Real.zero < Real.one;
  (a : ℝ)
            = (a : ℝ) + Real.zero
            < (a : ℝ) + Real.one
                  by Real.add_left_preserves_LessThan
            = (a + 1 : ℝ)
                  by aPlusOneReal;
  done by Real.LessThan.transitive_right;
}

-- ----------------------------------------------------------------------
-- cos 2 < 0. The whole reduction (cos 1 bracketed between S₂ and S₃, and
-- cos 2 = 2·cos²1 − 1) is in place; what remains is the arithmetic
-- 2·S₃² < 1. Writing EC k := 1/k!, with EC 0 = 1 and 2·EC 2 = 1, the
-- brackets collapse to S₂ = EC 2 (≥ 0) and S₃ = EC 2 + EC 4, so it comes
-- down to 2·EC 4 + 2·EC 4² < EC 2 — and that follows from 4·EC 4 < EC 2,
-- which is 8 < 24 in disguise (4·factorial 2 < factorial 4).
theorem Real.cosine_two_negative : cos(Real.one + Real.one) < Real.zero := {
  let d2 : ℝ := (2! : ℝ);
  let d4 : ℝ := (4! : ℝ);
  let four : ℝ := (4 : ℝ);
  let a : ℝ := (4 * 2! : ℝ);

  -- EC 0 = 1/0! = 1.
  (0! : ℝ) = 1 as factorialZero;
  Real.exponentialCoefficient(0)
            = 1 / (0! : ℝ)
            = 1 / (1 : ℝ)      by substituting factorialZero
            = Real.one            by field as ec0;

  -- The reciprocal relations dₖ · EC k = 1: k! cancels its own reciprocal.
  (2! : ℝ) ≠ 0;
  d2 * Real.exponentialCoefficient(2)
            = (2! : ℝ) * (1 / (2! : ℝ))
            = Real.one            by field as relation2;
  (4! : ℝ) ≠ 0;
  d4 * Real.exponentialCoefficient(4)
            = (4! : ℝ) * (1 / (4! : ℝ))
            = Real.one            by field as relation4;

  -- Real values of the natural casts: d2 = 2, four = 4.
  (1 : ℝ) = Real.one;
  (2 : ℝ)
            = (1 + 1 : ℝ)
            = (1 : ℝ) + (1 : ℝ)
                  by Real.from_natural.add_preserves
            = Real.one + (1 : ℝ)
            = Real.one + Real.one as twoNatReal;
  1!
            = (1 + 0) * 0!
            = 1 as factorialOne;
  2!
            = (1 + 1) * 1!
            = (1 + 1) * 1
                  by substituting factorialOne
            = 2 as factorialTwo;
  d2
            = (2! : ℝ)
            = (2 : ℝ)
                  by substituting factorialTwo
            = Real.one + Real.one
                  by twoNatReal as d2Value;
  four
            = (4 : ℝ)
            = (2 + 2 : ℝ)
                  by substituting (ring : (4 : ℕ) = 2 + 2)
            = (2 : ℝ) + (2 : ℝ)
            = (Real.one + Real.one) + (2 : ℝ)
                  by twoNatReal
            = (Real.one + Real.one) + (Real.one + Real.one)
                  by twoNatReal
            = Real.one + Real.one + Real.one + Real.one as fourValue;
  -- The crux relation 2·EC 2 = 1.
  (Real.one + Real.one) * Real.exponentialCoefficient(2)
            = d2 * Real.exponentialCoefficient(2)
                  by d2Value
            = Real.one
                  by relation2 as twoEC2;
  -- 1 − EC 2 = EC 2, the other face of 2·EC 2 = 1.
  Real.one - Real.exponentialCoefficient(2) = Real.exponentialCoefficient(2)
      by linear_combination(Real.zero - twoEC2) as oneMinusEC2;

  -- The three leading cosine coefficients at x = 1. Each is an instance
  -- of cosineCoefficient_one_even/odd; we bridge the index into the
  -- lemma's 2·j / 2·(2·j) shape with `ring` (the citation matcher does
  -- not reduce the multiplications on its own).
  Real.cosineCoefficient(Real.one, 0)
            = Real.cosineCoefficient(Real.one, 2 * 0)
                  by (ring : (0 : ℕ) = 2 * 0)
            = Real.exponentialCoefficient(2 * (2 * 0))
            = Real.exponentialCoefficient(0)
                  by (ring : (2 : ℕ) * (2 * 0) = 0) as cc0;
  Real.cosineCoefficient(Real.one, 1)
            = Real.cosineCoefficient(Real.one, 1 + 2 * 0)
                  by (ring : (1 : ℕ) = 1 + 2 * 0)
            = -Real.exponentialCoefficient(2 * (1 + 2 * 0))
            = -Real.exponentialCoefficient(2)
                  by (ring : (2 : ℕ) * (1 + 2 * 0) = 2) as cc1;
  Real.cosineCoefficient(Real.one, 2)
            = Real.cosineCoefficient(Real.one, 2 * 1)
                  by (ring : (2 : ℕ) = 2 * 1)
            = Real.exponentialCoefficient(2 * (2 * 1))
            = Real.exponentialCoefficient(4)
                  by (ring : (2 : ℕ) * (2 * 1) = 4) as cc2;

  -- S₂ = EC 2 ≥ 0, so cos 1 ≥ 0.
  Real.partialSum(Real.cosineCoefficient(Real.one), 2)
            = (Real.zero + Real.cosineCoefficient(Real.one, 0 + 0))
              + Real.cosineCoefficient(Real.one, 0 + 1)
            = (Real.zero + Real.cosineCoefficient(Real.one, 0))
              + Real.cosineCoefficient(Real.one, 0 + 1)
                  by (0 + 0 = 0)
            = (Real.zero + Real.cosineCoefficient(Real.one, 0))
              + Real.cosineCoefficient(Real.one, 1)
                  by (0 + 1 = 1)
            = (Real.zero + Real.exponentialCoefficient(0))
              + Real.cosineCoefficient(Real.one, 1)
                  by cc0
            = (Real.zero + Real.exponentialCoefficient(0))
              + (-Real.exponentialCoefficient(2))
                  by cc1
            = (Real.zero + Real.one) + (-Real.exponentialCoefficient(2))
                  by ec0
            = Real.one - Real.exponentialCoefficient(2)
                  by ring
            = Real.exponentialCoefficient(2)
                  by oneMinusEC2 as s2Value;
  Real.zero
            ≤ Real.exponentialCoefficient(2)
                  by Real.exponentialCoefficient_nonneg
            = Real.partialSum(Real.cosineCoefficient(Real.one), 2) as s2Nonneg;
  Real.zero
            ≤ Real.partialSum(Real.cosineCoefficient(Real.one), 2)
                  by s2Nonneg
            ≤ cos(Real.one)
                  by Real.cosine_one_lower_bound;

  -- S₃ = S₂ + cc(1,2) = EC 2 + EC 4, and cos 1 ≤ S₃. The last term is
  -- rewritten with `substituting` (a syntactic replacement) rather than a
  -- calc diff-step: cosineCoefficient(1,2) unfolds to a degree-4 complex
  -- power whose fully-reduced normal form is enormous, and any defeq that
  -- materialises it (e.g. comparing it against EC 4) costs gigabytes.
  Real.exponentialCoefficient(2) + Real.cosineCoefficient(Real.one, 2)
        = Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)
      by substituting cc2 as thirdTermValue;
  Real.partialSum(Real.cosineCoefficient(Real.one), 3)
            = Real.partialSum(Real.cosineCoefficient(Real.one), 2)
              + Real.cosineCoefficient(Real.one, 0 + 2)
            = Real.partialSum(Real.cosineCoefficient(Real.one), 2)
              + Real.cosineCoefficient(Real.one, 2)
                  by (0 + 2 = 2)
            = Real.exponentialCoefficient(2) + Real.cosineCoefficient(Real.one, 2)
                  by s2Value
            = Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)
                  by thirdTermValue as s3Value;
  -- cos 1 ≤ S₃, with S₃ collapsed to EC 2 + EC 4 once (single rewrite —
  -- partialSum never enters a product, where a failed rewrite would send
  -- the prover normalising cosineCoefficient).
  cos(Real.one)
            ≤ Real.partialSum(Real.cosineCoefficient(Real.one), 3)
                  by Real.cosine_one_upper_bound
            = Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)
                  by s3Value;

  -- Positivity facts about EC 2, EC 4.
  Real.zero < Real.exponentialCoefficient(2)
      by { (2! : ℝ) > 0 by Real.factorial_cast_positive;
           (2! : ℝ) ≠ 0;
           done by Real.divide_positive };
  Real.zero < Real.exponentialCoefficient(4)
      by { (4! : ℝ) > 0 by Real.factorial_cast_positive;
           (4! : ℝ) ≠ 0;
           done by Real.divide_positive };
  Real.zero < Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4);
  Real.zero ≤ Real.exponentialCoefficient(4);
  Real.exponentialCoefficient(4)
            ≤ Real.exponentialCoefficient(0)
                  by Real.exponentialCoefficient_antitone
            = Real.one
                  by ec0;
  -- EC 4² ≤ EC 4 (EC 4 ≤ 1).
  Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4)
            ≤ Real.one * Real.exponentialCoefficient(4)
                  by Real.LessOrEqual.multiply_monotone_nonneg
            = Real.exponentialCoefficient(4);

  -- 4·EC 4 < EC 2, via multiplying 4·d2 < d4 by the positive EC 2·EC 4.
  3!
            = 3 * 2!
            = 3 * 2
                  by substituting factorialTwo
            = 6
                  by ring as factorialThree;
  4!
            = 4 * 3!
            = 4 * 6
                  by substituting factorialThree
            = 24
                  by ring;
  4 * 2! + 1
            = 4 * 2 + 1
                  by substituting factorialTwo
            = (9 : ℕ)
                  by ring
            ≤ 15 + 9
                  by Natural.less_or_equal_add_left
            = (24 : ℕ)
                  by ring
            = 4!;
  4 * 2! < 4!
      by Natural.lt_of_add_one_le;
  a < d4
      by Real.from_natural_LessThan;
  a = four * d2 as aMultForm;
  a * (Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4))
        < d4 * (Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4))
      by Real.LessThan.multiply_by_positive_right as productStrict;
  a * (Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4))
        = four * Real.exponentialCoefficient(4)
      by linear_combination(
             (Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4)) * aMultForm
             + four * Real.exponentialCoefficient(4) * relation2) as lhsForm;
  d4 * (Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4))
        = Real.exponentialCoefficient(2)
      by linear_combination(Real.exponentialCoefficient(2) * relation4) as rhsForm;
  four * Real.exponentialCoefficient(4)
            = a * (Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4))
                  by lhsForm
            < d4 * (Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4))
                  by productStrict
            = Real.exponentialCoefficient(2)
                  by rhsForm;

  -- 2·EC 4 + 2·EC 4² ≤ 4·EC 4 < EC 2.
  Real.IsNonneg(Real.one + Real.one)
      by { Real.zero < Real.one;
           Real.zero
                     = Real.zero + Real.zero
                           by ring
                     < Real.one + Real.one
                           by Real.LessThan.add_strict_strict;
           Real.zero ≤ Real.one + Real.one by Real.LessThan.weaken;
           done by Real.IsNonneg_of_LessOrEqual_zero };
  (Real.one + Real.one)
                  * (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4))
            = (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4))
                  * (Real.one + Real.one)
            ≤ Real.exponentialCoefficient(4) * (Real.one + Real.one)
                  by Real.LessOrEqual.multiply_by_nonneg_right
            = (Real.one + Real.one) * Real.exponentialCoefficient(4);
  (Real.one + Real.one) * Real.exponentialCoefficient(4)
                + (Real.one + Real.one)
                    * (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4))
            ≤ (Real.one + Real.one) * Real.exponentialCoefficient(4)
              + (Real.one + Real.one) * Real.exponentialCoefficient(4)
                  by Real.add_preserves_LessOrEqual_left
            = (Real.one + Real.one + Real.one + Real.one)
                  * Real.exponentialCoefficient(4)
                  by ring
            = four * Real.exponentialCoefficient(4)
                  by fourValue;
  (Real.one + Real.one) * Real.exponentialCoefficient(4)
          + (Real.one + Real.one)
              * (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4))
        < Real.exponentialCoefficient(2)
      by Real.LessThan.transitive_left;

  -- Abbreviate the bound B := EC 2 + EC 4 (= S₃). 2·B² = EC 2 + (2·EC 4 +
  -- 2·EC 4²) < EC 2 + EC 2 = 1, using 2·EC 2 = 1 for both equalities.
  (Real.one + Real.one)
            * ((Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
               * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)))
        = Real.exponentialCoefficient(2)
          + ((Real.one + Real.one) * Real.exponentialCoefficient(4)
             + (Real.one + Real.one)
                 * (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4)))
      by linear_combination(
             (Real.exponentialCoefficient(2)
              + (Real.one + Real.one) * Real.exponentialCoefficient(4))
             * twoEC2) as boundSquare;
  (Real.one + Real.one)
                  * ((Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
                     * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)))
            = Real.exponentialCoefficient(2)
              + ((Real.one + Real.one) * Real.exponentialCoefficient(4)
                 + (Real.one + Real.one)
                     * (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4)))
                  by boundSquare
            < Real.exponentialCoefficient(2) + Real.exponentialCoefficient(2)
                  by Real.add_left_preserves_LessThan
            = (Real.one + Real.one) * Real.exponentialCoefficient(2)
                  by ring
            = Real.one
                  by twoEC2 as twoBoundSquareLessOne;

  -- cos²1 ≤ B², hence 2·cos²1 ≤ 2·B² < 1.
  cos(Real.one) * cos(Real.one)
        ≤ (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
          * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
      by Real.LessOrEqual.multiply_monotone_nonneg;
  (Real.one + Real.one) * (cos(Real.one) * cos(Real.one))
            = (cos(Real.one) * cos(Real.one)) + (cos(Real.one) * cos(Real.one))
                  by ring
            ≤ ((Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
               * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)))
              + (cos(Real.one) * cos(Real.one))
                  by Real.add_preserves_LessOrEqual
            ≤ ((Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
               * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)))
              + ((Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
                 * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)))
                  by Real.add_preserves_LessOrEqual_left
            = (Real.one + Real.one)
                  * ((Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
                     * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)))
                  by ring
            < Real.one
                  by twoBoundSquareLessOne;

  -- cos 2 = 2·cos²1 − 1 < 1 − 1 = 0.
  cos(Real.one + Real.one)
     = (Real.one + Real.one) * (cos(Real.one) * cos(Real.one)) - Real.one
           by Real.cosine_double
     < Real.one - Real.one
           by Real.add_preserves_LessThan
     = Real.zero
           by ring
}

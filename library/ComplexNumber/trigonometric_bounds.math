-- ----------------------------------------------------------------------
-- Summing a series in pairs: the first 2N terms grouped two at a time.
theorem Real.partialSum_pair (s : Natural → Real) (N : Natural)
        : Real.partialSum(s, 2 * N)
          = Real.partialSum(
                (m : Natural) ↦ s(2 * m) + s(successor(2 * m)), N) :=
  by_induction on N with IH {
    case zero: {
        claim twoTimesZero : 2 * 0 = 0;
        calc Real.partialSum(s, 2 * 0)
           = Real.partialSum(s, 0)    by twoTimesZero
           = Real.partialSum(
                 (m : Natural) ↦ s(2 * m) + s(successor(2 * m)), 0)
      }
    case successor(p): {
        claim indexStep : 2 * successor(p) = successor(successor(2 * p)) by ring;
        calc Real.partialSum(s, 2 * successor(p))
           = Real.partialSum(s, successor(successor(2 * p)))
                 by indexStep
           = (Real.partialSum(s, 2 * p) + s(2 * p)) + s(successor(2 * p))
           = (Real.partialSum(
                  (m : Natural) ↦ s(2 * m) + s(successor(2 * m)), p)
              + s(2 * p))
             + s(successor(2 * p))
                 since IH
           = Real.partialSum(
                 (m : Natural) ↦ s(2 * m) + s(successor(2 * m)), p)
             + (s(2 * p) + s(successor(2 * p)))
                 by ring
           = Real.partialSum(
                 (m : Natural) ↦ s(2 * m) + s(successor(2 * m)),
                 successor(p))
      }
  }

-- ----------------------------------------------------------------------
-- Even and odd powers of a negation: (−y)^{2m} = y^{2m} and
-- (−y)^{2m+1} = −(y^{2m+1}). Proved together by induction on m (each
-- step multiplies by −y twice). This carries the alternating sign of
-- the cosine/sine coefficients: (−x²)^m flips sign with the parity of m.
theorem Real.power_negate_parity (y : Real)
        : (m : Natural)
          → And(
                Real.power(-y, 2 * m) = Real.power(y, 2 * m),
                Real.power(-y, successor(2 * m)) = -(Real.power(y, successor(2 * m))))
  | zero => {
      claim twoTimesZero : 2 * 0 = 0;
      claim evenPart
          : Real.power(-y, 2 * 0) = Real.power(y, 2 * 0)
          by calc Real.power(-y, 2 * 0)
                = Real.power(-y, 0)        by twoTimesZero
                = Real.one
                = Real.power(y, 0)
                = Real.power(y, 2 * 0)     by twoTimesZero;
      claim oddPart
          : Real.power(-y, successor(2 * 0))
            = -(Real.power(y, successor(2 * 0)))
          by {
            claim succTwoTimesZero : successor(2 * 0) = 1;
            calc Real.power(-y, successor(2 * 0))
               = Real.power(-y, 1)               by succTwoTimesZero
               = (-y) * Real.power(-y, 0)
               = (-y) * Real.one
               = -(y * Real.one)
                     by ring
               = -(y * Real.power(y, 0))
               = -(Real.power(y, 1))
               = -(Real.power(y, successor(2 * 0)))
                     by succTwoTimesZero
          };
      done by And.introduction(evenPart, oddPart)
    }
  | successor(m) => {
      obtain ⟨evenAt, oddAt⟩ from Real.power_negate_parity(y, m);
      claim indexEven : 2 * successor(m) = successor(successor(2 * m)) by ring;
      claim indexOdd
          : successor(2 * successor(m))
            = successor(successor(successor(2 * m)))
          by ring;
      claim evenPart
          : Real.power(-y, 2 * successor(m)) = Real.power(y, 2 * successor(m))
          by calc Real.power(-y, 2 * successor(m))
                = Real.power(-y, successor(successor(2 * m)))
                      by indexEven
                = (-y) * ((-y) * Real.power(-y, 2 * m))
                = (-y) * ((-y) * Real.power(y, 2 * m))
                      since evenAt
                = y * (y * Real.power(y, 2 * m))
                      by ring
                = Real.power(y, successor(successor(2 * m)))
                = Real.power(y, 2 * successor(m))
                      by indexEven;
      claim oddPart
          : Real.power(-y, successor(2 * successor(m)))
            = -(Real.power(y, successor(2 * successor(m))))
          by calc Real.power(-y, successor(2 * successor(m)))
                = Real.power(-y, successor(successor(successor(2 * m))))
                      by indexOdd
                = (-y) * ((-y) * ((-y) * Real.power(-y, 2 * m)))
                = (-y) * ((-y) * ((-y) * Real.power(y, 2 * m)))
                      since evenAt
                = -(y * (y * (y * Real.power(y, 2 * m))))
                      by ring
                = -(Real.power(y, successor(successor(successor(2 * m)))))
                = -(Real.power(y, successor(2 * successor(m))))
                      by indexOdd;
      done by And.introduction(evenPart, oddPart)
    }

-- The two projections, as standalone facts.
theorem Real.power_negate_even (y : Real) (m : Natural)
        : Real.power(-y, 2 * m) = Real.power(y, 2 * m) := {
  obtain ⟨evenPart, _⟩ from Real.power_negate_parity(y, m);
  done
}

theorem Real.power_negate_odd (y : Real) (m : Natural)
        : Real.power(-y, successor(2 * m)) = -(Real.power(y, successor(2 * m))) := {
  obtain ⟨_, oddPart⟩ from Real.power_negate_parity(y, m);
  done
}

-- ----------------------------------------------------------------------
-- The even subsequence of a convergent sequence converges to the same
-- limit (2N grows past any threshold, since N ≤ 2N).
theorem Real.SequenceConverges.subsequence_double
        (s : Natural → Real) (limit : Real)
        (converges : Real.SequenceConverges(s, limit))
        : Real.SequenceConverges((N : Natural) ↦ s(2 * N), limit) :=
  (epsilon : Rational) (epsilonPositive : Rational.zero < epsilon) ↦ {
    obtain ⟨threshold, close⟩ from converges(epsilon, epsilonPositive);
    witness threshold with
        (N : Natural) (aboveThreshold : threshold ≤ N) ↦ {
          claim doubleAbove : threshold ≤ 2 * N
              by {
                claim N ≤ N + N since Natural.less_or_equal_add_right;
                claim twoN : 2 * N = N + N by ring;
                claim N ≤ 2 * N by substituting twoN;
                done since LessOrEqual.transitive
              };
          done by close(2 * N, doubleAbove)
        }
  }

-- ----------------------------------------------------------------------
-- The cosine series, regrouped onto its even terms. The odd terms
-- Re(term_{2m+1}) vanish, so cos x is the limit of Σ_m Re(term_{2m}).
theorem Real.cosine_paired_series_converges (x : Real)
        : Real.SequenceConverges(
              Real.partialSum(
                  (m : Natural) ↦
                      ComplexNumber.realPart(
                          ComplexNumber.exponentialTerm(
                              ComplexNumber.i * ComplexNumber.from_real(x),
                              2 * m))),
              cos(x)) := {
  -- The full series converges to cos x; so does its even subsequence.
  claim fullConverges
      : Real.SequenceConverges(
            Real.partialSum(
                (k : Natural) ↦
                    ComplexNumber.realPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x), k))),
            cos(x))
      by Real.cosine_series_converges(x);
  claim evenSubsequence
      : Real.SequenceConverges(
            (N : Natural) ↦
                Real.partialSum(
                    (k : Natural) ↦
                        ComplexNumber.realPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), k)),
                    2 * N),
            cos(x))
      by Real.SequenceConverges.subsequence_double(
             Real.partialSum(
                 (k : Natural) ↦
                     ComplexNumber.realPart(
                         ComplexNumber.exponentialTerm(
                             ComplexNumber.i * ComplexNumber.from_real(x), k))),
             cos(x), fullConverges);
  -- Each 2N-cut sums in pairs, and each pair drops to its even term.
  claim pairsCollapse
      : (N : Natural)
        → Real.partialSum(
              (k : Natural) ↦
                  ComplexNumber.realPart(
                      ComplexNumber.exponentialTerm(
                          ComplexNumber.i * ComplexNumber.from_real(x), k)),
              2 * N)
          = Real.partialSum(
                (m : Natural) ↦
                    ComplexNumber.realPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x), 2 * m)),
                N)
      by (N : Natural) ↦
           calc Real.partialSum(
                    (k : Natural) ↦
                        ComplexNumber.realPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), k)),
                    2 * N)
              = Real.partialSum(
                    (m : Natural) ↦
                        ComplexNumber.realPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))
                        + ComplexNumber.realPart(
                              ComplexNumber.exponentialTerm(
                                  ComplexNumber.i * ComplexNumber.from_real(x),
                                  successor(2 * m))),
                    N)
                    by Real.partialSum_pair(
                           (k : Natural) ↦
                               ComplexNumber.realPart(
                                   ComplexNumber.exponentialTerm(
                                       ComplexNumber.i * ComplexNumber.from_real(x), k)),
                           N)
              = Real.partialSum(
                    (m : Natural) ↦
                        ComplexNumber.realPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), 2 * m)),
                    N)
                    by Real.partialSum_pointwise(
                           (m : Natural) ↦
                               ComplexNumber.realPart(
                                   ComplexNumber.exponentialTerm(
                                       ComplexNumber.i * ComplexNumber.from_real(x),
                                       2 * m))
                               + ComplexNumber.realPart(
                                     ComplexNumber.exponentialTerm(
                                         ComplexNumber.i * ComplexNumber.from_real(x),
                                         successor(2 * m))),
                           (m : Natural) ↦
                               ComplexNumber.realPart(
                                   ComplexNumber.exponentialTerm(
                                       ComplexNumber.i * ComplexNumber.from_real(x),
                                       2 * m)),
                           (m : Natural) ↦ {
                             claim oddVanishes
                                 : ComplexNumber.realPart(
                                       ComplexNumber.exponentialTerm(
                                           ComplexNumber.i * ComplexNumber.from_real(x),
                                           successor(2 * m)))
                                   = Real.zero
                                 by Real.cosine_term_odd(x, m);
                             calc ComplexNumber.realPart(
                                      ComplexNumber.exponentialTerm(
                                          ComplexNumber.i * ComplexNumber.from_real(x),
                                          2 * m))
                                  + ComplexNumber.realPart(
                                        ComplexNumber.exponentialTerm(
                                            ComplexNumber.i * ComplexNumber.from_real(x),
                                            successor(2 * m)))
                                = ComplexNumber.realPart(
                                      ComplexNumber.exponentialTerm(
                                          ComplexNumber.i * ComplexNumber.from_real(x),
                                          2 * m))
                                  + Real.zero
                                    since oddVanishes
                                = ComplexNumber.realPart(
                                      ComplexNumber.exponentialTerm(
                                          ComplexNumber.i * ComplexNumber.from_real(x),
                                          2 * m))
                                    by ring
                           },
                           N);
  done by Real.SequenceConverges.of_pointwise(
              (N : Natural) ↦
                  Real.partialSum(
                      (k : Natural) ↦
                          ComplexNumber.realPart(
                              ComplexNumber.exponentialTerm(
                                  ComplexNumber.i * ComplexNumber.from_real(x), k)),
                      2 * N),
              Real.partialSum(
                  (m : Natural) ↦
                      ComplexNumber.realPart(
                          ComplexNumber.exponentialTerm(
                              ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))),
              cos(x),
              pairsCollapse, evenSubsequence)
}

-- ----------------------------------------------------------------------
-- The sine series, regrouped onto its odd terms. The even terms
-- Im(term_{2m}) vanish, so sin x is the limit of Σ_m Im(term_{2m+1}).
theorem Real.sine_paired_series_converges (x : Real)
        : Real.SequenceConverges(
              Real.partialSum(
                  (m : Natural) ↦
                      ComplexNumber.imaginaryPart(
                          ComplexNumber.exponentialTerm(
                              ComplexNumber.i * ComplexNumber.from_real(x),
                              successor(2 * m)))),
              sin(x)) := {
  claim fullConverges
      : Real.SequenceConverges(
            Real.partialSum(
                (k : Natural) ↦
                    ComplexNumber.imaginaryPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x), k))),
            sin(x))
      by Real.sine_series_converges(x);
  claim evenSubsequence
      : Real.SequenceConverges(
            (N : Natural) ↦
                Real.partialSum(
                    (k : Natural) ↦
                        ComplexNumber.imaginaryPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), k)),
                    2 * N),
            sin(x))
      by Real.SequenceConverges.subsequence_double(
             Real.partialSum(
                 (k : Natural) ↦
                     ComplexNumber.imaginaryPart(
                         ComplexNumber.exponentialTerm(
                             ComplexNumber.i * ComplexNumber.from_real(x), k))),
             sin(x), fullConverges);
  claim pairsCollapse
      : (N : Natural)
        → Real.partialSum(
              (k : Natural) ↦
                  ComplexNumber.imaginaryPart(
                      ComplexNumber.exponentialTerm(
                          ComplexNumber.i * ComplexNumber.from_real(x), k)),
              2 * N)
          = Real.partialSum(
                (m : Natural) ↦
                    ComplexNumber.imaginaryPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x),
                            successor(2 * m))),
                N)
      by (N : Natural) ↦
           calc Real.partialSum(
                    (k : Natural) ↦
                        ComplexNumber.imaginaryPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), k)),
                    2 * N)
              = Real.partialSum(
                    (m : Natural) ↦
                        ComplexNumber.imaginaryPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))
                        + ComplexNumber.imaginaryPart(
                              ComplexNumber.exponentialTerm(
                                  ComplexNumber.i * ComplexNumber.from_real(x),
                                  successor(2 * m))),
                    N)
                    by Real.partialSum_pair(
                           (k : Natural) ↦
                               ComplexNumber.imaginaryPart(
                                   ComplexNumber.exponentialTerm(
                                       ComplexNumber.i * ComplexNumber.from_real(x), k)),
                           N)
              = Real.partialSum(
                    (m : Natural) ↦
                        ComplexNumber.imaginaryPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x),
                                successor(2 * m))),
                    N)
                    by Real.partialSum_pointwise(
                           (m : Natural) ↦
                               ComplexNumber.imaginaryPart(
                                   ComplexNumber.exponentialTerm(
                                       ComplexNumber.i * ComplexNumber.from_real(x),
                                       2 * m))
                               + ComplexNumber.imaginaryPart(
                                     ComplexNumber.exponentialTerm(
                                         ComplexNumber.i * ComplexNumber.from_real(x),
                                         successor(2 * m))),
                           (m : Natural) ↦
                               ComplexNumber.imaginaryPart(
                                   ComplexNumber.exponentialTerm(
                                       ComplexNumber.i * ComplexNumber.from_real(x),
                                       successor(2 * m))),
                           (m : Natural) ↦ {
                             claim evenVanishes
                                 : ComplexNumber.imaginaryPart(
                                       ComplexNumber.exponentialTerm(
                                           ComplexNumber.i * ComplexNumber.from_real(x),
                                           2 * m))
                                   = Real.zero
                                 by Real.sine_term_even(x, m);
                             calc ComplexNumber.imaginaryPart(
                                      ComplexNumber.exponentialTerm(
                                          ComplexNumber.i * ComplexNumber.from_real(x),
                                          2 * m))
                                  + ComplexNumber.imaginaryPart(
                                        ComplexNumber.exponentialTerm(
                                            ComplexNumber.i * ComplexNumber.from_real(x),
                                            successor(2 * m)))
                                = Real.zero
                                  + ComplexNumber.imaginaryPart(
                                        ComplexNumber.exponentialTerm(
                                            ComplexNumber.i * ComplexNumber.from_real(x),
                                            successor(2 * m)))
                                    since evenVanishes
                                = ComplexNumber.imaginaryPart(
                                      ComplexNumber.exponentialTerm(
                                          ComplexNumber.i * ComplexNumber.from_real(x),
                                          successor(2 * m)))
                                    by ring
                           },
                           N);
  done by Real.SequenceConverges.of_pointwise(
              (N : Natural) ↦
                  Real.partialSum(
                      (k : Natural) ↦
                          ComplexNumber.imaginaryPart(
                              ComplexNumber.exponentialTerm(
                                  ComplexNumber.i * ComplexNumber.from_real(x), k)),
                      2 * N),
              Real.partialSum(
                  (m : Natural) ↦
                      ComplexNumber.imaginaryPart(
                          ComplexNumber.exponentialTerm(
                              ComplexNumber.i * ComplexNumber.from_real(x),
                              successor(2 * m)))),
              sin(x),
              pairsCollapse, evenSubsequence)
}

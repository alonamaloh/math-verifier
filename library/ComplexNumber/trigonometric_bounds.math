-- ComplexNumber/trigonometric_bounds.math
--
-- Regrouping the cosine and sine series onto their non-vanishing terms.
-- The series for cos x has Re(term_{2m+1}) = 0, so summing in pairs and
-- passing to the even subsequence collapses it to Σ_m Re(term_{2m})
-- (and likewise sin x = Σ_m Im(term_{2m+1})). This is the bridge from
-- the full exponential series to the alternating series of the π bounds.

module ComplexNumber.trigonometric_bounds


-- ----------------------------------------------------------------------
-- Summing a series in pairs: the first 2N terms grouped two at a time.
theorem Real.partialSum_pair (s : Natural → Real) (N : Natural)
        : Real.partialSum(s, 2 * N)
          = Real.partialSum(
                (m : Natural) ↦ s(2 * m) + s(successor(2 * m)), N) :=
  by_induction on N with IH {
    case zero: {
        claim twoTimesZero : 2 * 0 = 0;
        calc Real.partialSum(s, 2 * 0)
           = Real.partialSum(s, 0)    by twoTimesZero
           = Real.partialSum(
                 (m : Natural) ↦ s(2 * m) + s(successor(2 * m)), 0)
      }
    case successor(p): {
        claim indexStep : 2 * successor(p) = successor(successor(2 * p)) by ring;
        calc Real.partialSum(s, 2 * successor(p))
           = Real.partialSum(s, successor(successor(2 * p)))
                 by indexStep
           = Real.partialSum(s, 1 + (1 + 2 * p))
                 by substituting Natural.one_add
           = Real.partialSum(s, 1 + 2 * p) + s(1 + 2 * p)
                 by Real.partialSum_add_one
           = (Real.partialSum(s, 2 * p) + s(2 * p)) + s(1 + 2 * p)
                 by Real.partialSum_add_one
           = (Real.partialSum(s, 2 * p) + s(2 * p)) + s(successor(2 * p))
                 by substituting Natural.one_add
           = (Real.partialSum(
                  (m : Natural) ↦ s(2 * m) + s(successor(2 * m)), p)
              + s(2 * p))
             + s(successor(2 * p))
                 since IH
           = Real.partialSum(
                 (m : Natural) ↦ s(2 * m) + s(successor(2 * m)), p)
             + (s(2 * p) + s(successor(2 * p)))
                 by ring
           = Real.partialSum(
                 (m : Natural) ↦ s(2 * m) + s(successor(2 * m)),
                 1 + p)
                 by Real.partialSum_add_one
           = Real.partialSum(
                 (m : Natural) ↦ s(2 * m) + s(successor(2 * m)),
                 successor(p))
                 by substituting Natural.one_add
      }
  }

-- ----------------------------------------------------------------------
-- Even and odd powers of a negation: (−y)^{2m} = y^{2m} and
-- (−y)^{2m+1} = −(y^{2m+1}). Proved together by induction on m (each
-- step multiplies by −y twice). This carries the alternating sign of
-- the cosine/sine coefficients: (−x²)^m flips sign with the parity of m.
theorem Real.power_negate_parity (y : Real)
        : ∀ (m : Natural).
          Real.power(-y, 2 * m) = Real.power(y, 2 * m) ∧ Real.power(-y, successor(2 * m)) = -(Real.power(y, successor(2 * m)))
  | zero => {
      claim twoTimesZero : 2 * 0 = 0;
      claim evenPart
          : Real.power(-y, 2 * 0) = Real.power(y, 2 * 0)
          by calc Real.power(-y, 2 * 0)
                = Real.power(-y, 0)        by twoTimesZero
                = Real.one
                = Real.power(y, 0)
                = Real.power(y, 2 * 0)     by twoTimesZero;
      claim oddPart
          : Real.power(-y, successor(2 * 0))
            = -(Real.power(y, successor(2 * 0)))
          by {
            claim succTwoTimesZero : successor(2 * 0) = 1;
            calc Real.power(-y, successor(2 * 0))
               = Real.power(-y, 1)               by succTwoTimesZero
               = (-y) * Real.power(-y, 0)
               = (-y) * Real.one
               = -(y * Real.one)
                     by ring
               = -(y * Real.power(y, 0))
               = -(Real.power(y, 1))
               = -(Real.power(y, successor(2 * 0)))
                     by succTwoTimesZero
          };
      done by And.introduction(evenPart, oddPart)
    }
  | successor(m) => {
      obtain ⟨evenAt, oddAt⟩ from Real.power_negate_parity(y, m);
      claim indexEven : 2 * successor(m) = successor(successor(2 * m)) by ring;
      claim indexOdd
          : successor(2 * successor(m))
            = successor(successor(successor(2 * m)))
          by ring;
      claim evenPart
          : Real.power(-y, 2 * successor(m)) = Real.power(y, 2 * successor(m))
          by calc Real.power(-y, 2 * successor(m))
                = Real.power(-y, successor(successor(2 * m)))
                      by indexEven
                = (-y) * ((-y) * Real.power(-y, 2 * m))
                = (-y) * ((-y) * Real.power(y, 2 * m))
                      since evenAt
                = y * (y * Real.power(y, 2 * m))
                      by ring
                = Real.power(y, successor(successor(2 * m)))
                = Real.power(y, 2 * successor(m))
                      by indexEven;
      claim oddPart
          : Real.power(-y, successor(2 * successor(m)))
            = -(Real.power(y, successor(2 * successor(m))))
          by calc Real.power(-y, successor(2 * successor(m)))
                = Real.power(-y, successor(successor(successor(2 * m))))
                      by indexOdd
                = (-y) * ((-y) * ((-y) * Real.power(-y, 2 * m)))
                = (-y) * ((-y) * ((-y) * Real.power(y, 2 * m)))
                      since evenAt
                = -(y * (y * (y * Real.power(y, 2 * m))))
                      by ring
                = -(Real.power(y, successor(successor(successor(2 * m)))))
                = -(Real.power(y, successor(2 * successor(m))))
                      by indexOdd;
      done by And.introduction(evenPart, oddPart)
    }

-- The two projections, as standalone facts.
theorem Real.power_negate_even (y : Real) (m : Natural)
        : Real.power(-y, 2 * m) = Real.power(y, 2 * m) := {
  obtain ⟨evenPart, _⟩ from Real.power_negate_parity(y, m);
  done
}

theorem Real.power_negate_odd (y : Real) (m : Natural)
        : Real.power(-y, successor(2 * m)) = -(Real.power(y, successor(2 * m))) := {
  obtain ⟨_, oddPart⟩ from Real.power_negate_parity(y, m);
  done
}

-- ----------------------------------------------------------------------
-- The even subsequence of a convergent sequence converges to the same
-- limit (2N grows past any threshold, since N ≤ 2N).
theorem Real.SequenceConverges.subsequence_double
        (s : Natural → Real) (limit : Real)
        (converges : Real.SequenceConverges(s, limit))
        : Real.SequenceConverges((N : Natural) ↦ s(2 * N), limit) :=
  (ε : Real) (εPositive : ε > 0) ↦ {
    obtain ⟨threshold, close⟩ from converges(ε, εPositive);
    witness threshold with
        (N : Natural) (aboveThreshold : threshold ≤ N) ↦ {
          claim doubleAbove : threshold ≤ 2 * N
              by {
                claim N ≤ N + N since Natural.less_or_equal_add_right;
                claim twoN : 2 * N = N + N by ring;
                claim N ≤ 2 * N by substituting twoN;
                done since Natural.LessOrEqual.transitive
              };
          done by close(2 * N, doubleAbove)
        }
  }

-- ----------------------------------------------------------------------
-- The cosine series, regrouped onto its even terms. The odd terms
-- Re(term_{2m+1}) vanish, so cos x is the limit of Σ_m Re(term_{2m}).
theorem Real.cosine_paired_series_converges (x : Real)
        : Real.SequenceConverges(
              Real.partialSum(
                  (m : Natural) ↦
                      ComplexNumber.realPart(
                          ComplexNumber.exponentialTerm(
                              ComplexNumber.i * ComplexNumber.from_real(x),
                              2 * m))),
              cos(x)) := {
  -- The full series converges to cos x; so does its even subsequence.
  claim fullConverges
      : Real.SequenceConverges(
            Real.partialSum(
                (k : Natural) ↦
                    ComplexNumber.realPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x), k))),
            cos(x))
      by Real.cosine_series_converges(x);
  claim evenSubsequence
      : Real.SequenceConverges(
            (N : Natural) ↦
                Real.partialSum(
                    (k : Natural) ↦
                        ComplexNumber.realPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), k)),
                    2 * N),
            cos(x))
      by Real.SequenceConverges.subsequence_double(
             Real.partialSum(
                 (k : Natural) ↦
                     ComplexNumber.realPart(
                         ComplexNumber.exponentialTerm(
                             ComplexNumber.i * ComplexNumber.from_real(x), k))),
             cos(x), fullConverges);
  -- Each 2N-cut sums in pairs, and each pair drops to its even term.
  claim pairsCollapse
      : ∀ (N : Natural).
        Real.partialSum(
              (k : Natural) ↦
                  ComplexNumber.realPart(
                      ComplexNumber.exponentialTerm(
                          ComplexNumber.i * ComplexNumber.from_real(x), k)),
              2 * N)
          = Real.partialSum(
                (m : Natural) ↦
                    ComplexNumber.realPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x), 2 * m)),
                N)
      by (N : Natural) ↦
           calc Real.partialSum(
                    (k : Natural) ↦
                        ComplexNumber.realPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), k)),
                    2 * N)
              = Real.partialSum(
                    (m : Natural) ↦
                        ComplexNumber.realPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))
                        + ComplexNumber.realPart(
                              ComplexNumber.exponentialTerm(
                                  ComplexNumber.i * ComplexNumber.from_real(x),
                                  successor(2 * m))),
                    N)
                    by Real.partialSum_pair(
                           (k : Natural) ↦
                               ComplexNumber.realPart(
                                   ComplexNumber.exponentialTerm(
                                       ComplexNumber.i * ComplexNumber.from_real(x), k)),
                           N)
              = Real.partialSum(
                    (m : Natural) ↦
                        ComplexNumber.realPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), 2 * m)),
                    N)
                    by Real.partialSum_pointwise(
                           (m : Natural) ↦
                               ComplexNumber.realPart(
                                   ComplexNumber.exponentialTerm(
                                       ComplexNumber.i * ComplexNumber.from_real(x),
                                       2 * m))
                               + ComplexNumber.realPart(
                                     ComplexNumber.exponentialTerm(
                                         ComplexNumber.i * ComplexNumber.from_real(x),
                                         successor(2 * m))),
                           (m : Natural) ↦
                               ComplexNumber.realPart(
                                   ComplexNumber.exponentialTerm(
                                       ComplexNumber.i * ComplexNumber.from_real(x),
                                       2 * m)),
                           (m : Natural) ↦ {
                             claim oddVanishes
                                 : ComplexNumber.realPart(
                                       ComplexNumber.exponentialTerm(
                                           ComplexNumber.i * ComplexNumber.from_real(x),
                                           successor(2 * m)))
                                   = Real.zero
                                 by Real.cosine_term_odd(x, m);
                             calc ComplexNumber.realPart(
                                      ComplexNumber.exponentialTerm(
                                          ComplexNumber.i * ComplexNumber.from_real(x),
                                          2 * m))
                                  + ComplexNumber.realPart(
                                        ComplexNumber.exponentialTerm(
                                            ComplexNumber.i * ComplexNumber.from_real(x),
                                            successor(2 * m)))
                                = ComplexNumber.realPart(
                                      ComplexNumber.exponentialTerm(
                                          ComplexNumber.i * ComplexNumber.from_real(x),
                                          2 * m))
                                  + Real.zero
                                    since oddVanishes
                                = ComplexNumber.realPart(
                                      ComplexNumber.exponentialTerm(
                                          ComplexNumber.i * ComplexNumber.from_real(x),
                                          2 * m))
                                    by ring
                           },
                           N);
  done by Real.SequenceConverges.of_pointwise(
              (N : Natural) ↦
                  Real.partialSum(
                      (k : Natural) ↦
                          ComplexNumber.realPart(
                              ComplexNumber.exponentialTerm(
                                  ComplexNumber.i * ComplexNumber.from_real(x), k)),
                      2 * N),
              Real.partialSum(
                  (m : Natural) ↦
                      ComplexNumber.realPart(
                          ComplexNumber.exponentialTerm(
                              ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))),
              cos(x),
              pairsCollapse, evenSubsequence)
}

-- ----------------------------------------------------------------------
-- The sine series, regrouped onto its odd terms. The even terms
-- Im(term_{2m}) vanish, so sin x is the limit of Σ_m Im(term_{2m+1}).
theorem Real.sine_paired_series_converges (x : Real)
        : Real.SequenceConverges(
              Real.partialSum(
                  (m : Natural) ↦
                      ComplexNumber.imaginaryPart(
                          ComplexNumber.exponentialTerm(
                              ComplexNumber.i * ComplexNumber.from_real(x),
                              successor(2 * m)))),
              sin(x)) := {
  claim fullConverges
      : Real.SequenceConverges(
            Real.partialSum(
                (k : Natural) ↦
                    ComplexNumber.imaginaryPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x), k))),
            sin(x))
      by Real.sine_series_converges(x);
  claim evenSubsequence
      : Real.SequenceConverges(
            (N : Natural) ↦
                Real.partialSum(
                    (k : Natural) ↦
                        ComplexNumber.imaginaryPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), k)),
                    2 * N),
            sin(x))
      by Real.SequenceConverges.subsequence_double(
             Real.partialSum(
                 (k : Natural) ↦
                     ComplexNumber.imaginaryPart(
                         ComplexNumber.exponentialTerm(
                             ComplexNumber.i * ComplexNumber.from_real(x), k))),
             sin(x), fullConverges);
  claim pairsCollapse
      : ∀ (N : Natural).
        Real.partialSum(
              (k : Natural) ↦
                  ComplexNumber.imaginaryPart(
                      ComplexNumber.exponentialTerm(
                          ComplexNumber.i * ComplexNumber.from_real(x), k)),
              2 * N)
          = Real.partialSum(
                (m : Natural) ↦
                    ComplexNumber.imaginaryPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x),
                            successor(2 * m))),
                N)
      by (N : Natural) ↦
           calc Real.partialSum(
                    (k : Natural) ↦
                        ComplexNumber.imaginaryPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), k)),
                    2 * N)
              = Real.partialSum(
                    (m : Natural) ↦
                        ComplexNumber.imaginaryPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))
                        + ComplexNumber.imaginaryPart(
                              ComplexNumber.exponentialTerm(
                                  ComplexNumber.i * ComplexNumber.from_real(x),
                                  successor(2 * m))),
                    N)
                    by Real.partialSum_pair(
                           (k : Natural) ↦
                               ComplexNumber.imaginaryPart(
                                   ComplexNumber.exponentialTerm(
                                       ComplexNumber.i * ComplexNumber.from_real(x), k)),
                           N)
              = Real.partialSum(
                    (m : Natural) ↦
                        ComplexNumber.imaginaryPart(
                            ComplexNumber.exponentialTerm(
                                ComplexNumber.i * ComplexNumber.from_real(x),
                                successor(2 * m))),
                    N)
                    by Real.partialSum_pointwise(
                           (m : Natural) ↦
                               ComplexNumber.imaginaryPart(
                                   ComplexNumber.exponentialTerm(
                                       ComplexNumber.i * ComplexNumber.from_real(x),
                                       2 * m))
                               + ComplexNumber.imaginaryPart(
                                     ComplexNumber.exponentialTerm(
                                         ComplexNumber.i * ComplexNumber.from_real(x),
                                         successor(2 * m))),
                           (m : Natural) ↦
                               ComplexNumber.imaginaryPart(
                                   ComplexNumber.exponentialTerm(
                                       ComplexNumber.i * ComplexNumber.from_real(x),
                                       successor(2 * m))),
                           (m : Natural) ↦ {
                             claim evenVanishes
                                 : ComplexNumber.imaginaryPart(
                                       ComplexNumber.exponentialTerm(
                                           ComplexNumber.i * ComplexNumber.from_real(x),
                                           2 * m))
                                   = Real.zero
                                 by Real.sine_term_even(x, m);
                             calc ComplexNumber.imaginaryPart(
                                      ComplexNumber.exponentialTerm(
                                          ComplexNumber.i * ComplexNumber.from_real(x),
                                          2 * m))
                                  + ComplexNumber.imaginaryPart(
                                        ComplexNumber.exponentialTerm(
                                            ComplexNumber.i * ComplexNumber.from_real(x),
                                            successor(2 * m)))
                                = Real.zero
                                  + ComplexNumber.imaginaryPart(
                                        ComplexNumber.exponentialTerm(
                                            ComplexNumber.i * ComplexNumber.from_real(x),
                                            successor(2 * m)))
                                    since evenVanishes
                                = ComplexNumber.imaginaryPart(
                                      ComplexNumber.exponentialTerm(
                                          ComplexNumber.i * ComplexNumber.from_real(x),
                                          successor(2 * m)))
                                    by ring
                           },
                           N);
  done by Real.SequenceConverges.of_pointwise(
              (N : Natural) ↦
                  Real.partialSum(
                      (k : Natural) ↦
                          ComplexNumber.imaginaryPart(
                              ComplexNumber.exponentialTerm(
                                  ComplexNumber.i * ComplexNumber.from_real(x), k)),
                      2 * N),
              Real.partialSum(
                  (m : Natural) ↦
                      ComplexNumber.imaginaryPart(
                          ComplexNumber.exponentialTerm(
                              ComplexNumber.i * ComplexNumber.from_real(x),
                              successor(2 * m)))),
              sin(x),
              pairsCollapse, evenSubsequence)
}

-- ----------------------------------------------------------------------
-- Factorial is monotone: a ≤ b ⟹ a! ≤ b!. Each step multiplies by a
-- factor ≥ 1, so a! ≤ (a+1)!; the general case chains those.
theorem Natural.factorial_le_succ (n : Natural)
        : Natural.factorial(n) ≤ Natural.factorial(successor(n)) := {
  claim oneLeSucc : 1 ≤ successor(n);
  claim scaled
      : Natural.factorial(n) * 1 ≤ Natural.factorial(n) * successor(n)
      by Natural.multiply_monotone_left(
             Natural.factorial(n), 1, successor(n), oneLeSucc);
  calc Natural.factorial(n)
     = Natural.factorial(n) * 1
           by ring
     ≤ Natural.factorial(n) * successor(n)
           since scaled
     = successor(n) * Natural.factorial(n)
           by ring
     = Natural.factorial(successor(n))
}

-- a! ≤ (k + a)!, by induction on the gap k (each step a factorial-le-succ).
theorem Natural.factorial_le_add (a : Natural)
        : ∀ (k : Natural). Natural.factorial(a) ≤ Natural.factorial(k + a)
  | zero => {
      claim Natural.factorial(a) ≤ Natural.factorial(a)
          by Natural.LessOrEqual.reflexive;
      done by substituting Natural.zero_add(a)
    }
  | successor(p) => {
      claim Natural.factorial(a) ≤ Natural.factorial(p + a)
          by Natural.factorial_le_add(a, p);
      claim Natural.factorial(p + a)
            ≤ Natural.factorial(successor(p + a))
          by Natural.factorial_le_succ(p + a);
      done since Natural.LessOrEqual.transitive
    }

theorem Natural.factorial_monotone (a b : Natural) (aLeB : a ≤ b)
        : Natural.factorial(a) ≤ Natural.factorial(b) := {
  obtain ⟨k, bEqual⟩ from Natural.le_to_add(a, b, aLeB);
  claim Natural.factorial(a) ≤ Natural.factorial(k + a)
      by Natural.factorial_le_add(a, k);
  done by substituting bEqual
}

-- ----------------------------------------------------------------------
-- The exponential coefficients 1/k! decrease: i ≤ j ⟹ 1/j! ≤ 1/i!
-- (factorial monotone, then reciprocal antitone, carried across the
-- ℚ → ℝ casts).
theorem Real.exponentialCoefficient_antitone (i j : Natural) (iLeqJ : i ≤ j)
        : Real.exponentialCoefficient(j) ≤ Real.exponentialCoefficient(i) := {
  claim factorialLe : Natural.factorial(i) ≤ Natural.factorial(j)
      by Natural.factorial_monotone(i, j, iLeqJ);
  claim castLe
      : (Natural.factorial(i) : Rational) ≤ (Natural.factorial(j) : Rational)
      by Rational.from_natural_le_preserves(
             Natural.factorial(i), Natural.factorial(j), factorialLe);
  claim iPositive : Rational.zero < (Natural.factorial(i) : Rational)
      since Rational.factorial_cast_positive;
  claim recipLe
      : Rational.reciprocal_function((Natural.factorial(j) : Rational))
        ≤ Rational.reciprocal_function((Natural.factorial(i) : Rational))
      by Rational.reciprocal_function_antitone(
             (Natural.factorial(i) : Rational),
             (Natural.factorial(j) : Rational),
             iPositive, castLe);
  done by Rational.to_real.LessOrEqual_preserves(
              Rational.reciprocal_function((Natural.factorial(j) : Rational)),
              Rational.reciprocal_function((Natural.factorial(i) : Rational)),
              recipLe)
}

-- ----------------------------------------------------------------------
-- Every natural is even or odd: n = 2j or n = 2j+1.
theorem Natural.even_or_odd
        : ∀ (n : Natural). ∃ (j : Natural). n = 2 * j ∨ n = successor(2 * j)
  | zero => {
      claim base : (0 : Natural) = 2 * 0;
      witness 0 with Or.introduceLeft(base)
    }
  | successor(p) => {
      obtain ⟨j, disjunction⟩ from Natural.even_or_odd(p);
      cases disjunction {
        | Or.introduceLeft(pEven) => {
            claim oddEq : successor(p) = successor(2 * j) by substituting pEven;
            witness j with Or.introduceRight(oddEq)
          }
        | Or.introduceRight(pOdd) => {
            claim evenEq : successor(p) = 2 * successor(j)
                by calc successor(p)
                      = successor(successor(2 * j))    by substituting pOdd
                      = 2 * successor(j)               by ring;
            witness successor(j) with Or.introduceLeft(evenEq)
          }
      }
    }

-- ----------------------------------------------------------------------
-- Partial sums of an "alternating, decreasing-magnitude" series stay
-- non-positive when the leading (even-indexed) terms are ≤ 0 and each
-- consecutive pair sums to ≤ 0. The even and odd cuts are handled
-- together by induction on the pair index.
theorem Real.partialSum_nonpositive_paired (g : Natural → Real)
        (leadNonpositive : ∀ (j : Natural). g(2 * j) ≤ Real.zero)
        (pairNonpositive
            : ∀ (j : Natural). g(2 * j) + g(successor(2 * j)) ≤ Real.zero)
        : ∀ (j : Natural).
          Real.partialSum(g, 2 * j) ≤ Real.zero ∧ Real.partialSum(g, successor(2 * j)) ≤ Real.zero
  | zero => {
      claim evenZero : Real.partialSum(g, 2 * 0) ≤ Real.zero;
      claim oddZero : Real.partialSum(g, successor(2 * 0)) ≤ Real.zero
          by calc Real.partialSum(g, successor(2 * 0))
                = Real.partialSum(g, 2 * 0) + g(2 * 0)
                = Real.zero + g(2 * 0)
                = g(2 * 0)
                      by ring
                ≤ Real.zero
                      by leadNonpositive(0);
      done by And.introduction(evenZero, oddZero)
    }
  | successor(j) => {
      obtain ⟨evenAt, oddAt⟩
          from Real.partialSum_nonpositive_paired(
                   g, leadNonpositive, pairNonpositive, j);
      claim indexEven : 2 * successor(j) = successor(successor(2 * j)) by ring;
      claim g(2 * j) + g(successor(2 * j)) ≤ Real.zero
          by pairNonpositive(j);
      claim evenStep : Real.partialSum(g, 2 * successor(j)) ≤ Real.zero
          by calc Real.partialSum(g, 2 * successor(j))
                = Real.partialSum(g, successor(successor(2 * j)))
                      by indexEven
                = Real.partialSum(g, successor(2 * j)) + g(successor(2 * j))
                = (Real.partialSum(g, 2 * j) + g(2 * j)) + g(successor(2 * j))
                = Real.partialSum(g, 2 * j) + (g(2 * j) + g(successor(2 * j)))
                      by ring
                ≤ Real.zero + (g(2 * j) + g(successor(2 * j)))
                      since Real.add_preserves_LessOrEqual
                ≤ Real.zero + Real.zero
                      since Real.add_preserves_LessOrEqual_left
                = Real.zero
                      by ring;
      claim g(2 * successor(j)) ≤ Real.zero
          by leadNonpositive(successor(j));
      claim oddStep : Real.partialSum(g, successor(2 * successor(j))) ≤ Real.zero
          by calc Real.partialSum(g, successor(2 * successor(j)))
                = Real.partialSum(g, 2 * successor(j)) + g(2 * successor(j))
                ≤ Real.zero + g(2 * successor(j))
                      since Real.add_preserves_LessOrEqual
                ≤ Real.zero + Real.zero
                      since Real.add_preserves_LessOrEqual_left
                = Real.zero
                      by ring;
      done by And.introduction(evenStep, oddStep)
    }

-- … hence non-positive at every cut (split n by parity).
theorem Real.partialSum_nonpositive (g : Natural → Real)
        (leadNonpositive : ∀ (j : Natural). g(2 * j) ≤ Real.zero)
        (pairNonpositive
            : ∀ (j : Natural). g(2 * j) + g(successor(2 * j)) ≤ Real.zero)
        (n : Natural)
        : Real.partialSum(g, n) ≤ Real.zero := {
  obtain ⟨j, disjunction⟩ from Natural.even_or_odd(n);
  obtain ⟨evenPaired, oddPaired⟩
      from Real.partialSum_nonpositive_paired(
               g, leadNonpositive, pairNonpositive, j);
  cases disjunction {
    | Or.introduceLeft(nEven) =>
        calc Real.partialSum(g, n)
           = Real.partialSum(g, 2 * j)    by nEven
           ≤ Real.zero                    by evenPaired
    | Or.introduceRight(nOdd) =>
        calc Real.partialSum(g, n)
           = Real.partialSum(g, successor(2 * j))    by nOdd
           ≤ Real.zero                               by oddPaired
  }
}

-- ----------------------------------------------------------------------
-- The mirror: partial sums stay NON-NEGATIVE when the even-indexed
-- terms are ≥ 0 and each consecutive pair sums to ≥ 0 (apply the
-- non-positive lemma to −g, which negates the partial sums).
theorem Real.partialSum_nonnegative (g : Natural → Real)
        (leadNonnegative : ∀ (j : Natural). Real.zero ≤ g(2 * j))
        (pairNonnegative
            : ∀ (j : Natural). Real.zero ≤ g(2 * j) + g(successor(2 * j)))
        (n : Natural)
        : Real.zero ≤ Real.partialSum(g, n) := {
  claim negLead : ∀ (j : Natural). -g(2 * j) ≤ Real.zero
      by (j : Natural) ↦
           calc -g(2 * j)
              ≤ -Real.zero
                    by Real.LessOrEqual.negate(Real.zero, g(2 * j), leadNonnegative(j))
              = Real.zero
                    by ring;
  claim negPair
      : ∀ (j : Natural). -g(2 * j) + -g(successor(2 * j)) ≤ Real.zero
      by (j : Natural) ↦
           calc -g(2 * j) + -g(successor(2 * j))
              = -(g(2 * j) + g(successor(2 * j)))
                    by ring
              ≤ -Real.zero
                    by Real.LessOrEqual.negate(
                           Real.zero, g(2 * j) + g(successor(2 * j)),
                           pairNonnegative(j))
              = Real.zero
                    by ring;
  claim Real.partialSum((k : Natural) ↦ -g(k), n) ≤ Real.zero
      by Real.partialSum_nonpositive((k : Natural) ↦ -g(k), negLead, negPair, n);
  claim negated : -Real.partialSum(g, n) ≤ Real.zero
      by {
        claim Real.partialSum((k : Natural) ↦ -g(k), n) = -Real.partialSum(g, n)
            by Real.partialSum_negate(g, n);
        done by substituting (Real.partialSum((k : Natural) ↦ -g(k), n)
                                  = -Real.partialSum(g, n))
      };
  calc Real.zero
     = -Real.zero
           by ring
     ≤ -(-Real.partialSum(g, n))
           by Real.LessOrEqual.negate(-Real.partialSum(g, n), Real.zero, negated)
     = Real.partialSum(g, n)
           by ring
}

-- ----------------------------------------------------------------------
-- Powers of one are one.
theorem Real.power_one (n : Natural) : Real.power(Real.one, n) = Real.one :=
  by_induction on n with IH {
    case zero: done
    case successor(p):
        calc Real.power(Real.one, successor(p))
           = Real.one * Real.power(Real.one, p)
           = Real.one * Real.one    since IH
           = Real.one               by ring
  }

-- ----------------------------------------------------------------------
-- The cosine coefficient c_m = Re of the (2m)-th term of exp(ix): the
-- non-vanishing terms of the cosine series.
definition Real.cosineCoefficient (x : Real) (m : Natural) : Real :=
  ComplexNumber.realPart(
      ComplexNumber.exponentialTerm(
          ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))

-- At x = 1 it is ±1/(2m)!: the coefficient times (−1)^m.
theorem Real.cosineCoefficient_one_value (m : Natural)
        : Real.cosineCoefficient(Real.one, m)
          = Real.exponentialCoefficient(2 * m) * Real.power(-Real.one, m) :=
  calc Real.cosineCoefficient(Real.one, m)
     = Real.exponentialCoefficient(2 * m) * Real.power(-(Real.one * Real.one), m)
           by Real.cosine_term_even(Real.one, m)
     = Real.exponentialCoefficient(2 * m) * Real.power(-Real.one, m)
           by substituting (ring : Real.one * Real.one = Real.one)

-- 1/k! is non-negative.
theorem Real.exponentialCoefficient_nonneg (k : Natural)
        : Real.zero ≤ Real.exponentialCoefficient(k) := {
  claim Rational.zero < (Natural.factorial(k) : Rational)
      since Rational.factorial_cast_positive;
  claim Rational.zero
        < Rational.reciprocal_function((Natural.factorial(k) : Rational))
      since Rational.reciprocal_function_positive_of_positive;
  claim Real.zero
        < (Rational.reciprocal_function((Natural.factorial(k) : Rational)) : Real)
      since Rational.to_real.positive_preserves;
  done since Real.LessThan.weaken
}

-- The even-indexed coefficient is +1/(4j)! ≥ 0.
theorem Real.cosineCoefficient_one_even (j : Natural)
        : Real.cosineCoefficient(Real.one, 2 * j)
          = Real.exponentialCoefficient(2 * (2 * j)) := {
  claim signOne : Real.power(-Real.one, 2 * j) = Real.one
      by calc Real.power(-Real.one, 2 * j)
            = Real.power(Real.one, 2 * j)
                  by Real.power_negate_even(Real.one, j)
            = Real.one
                  by Real.power_one(2 * j);
  calc Real.cosineCoefficient(Real.one, 2 * j)
     = Real.exponentialCoefficient(2 * (2 * j)) * Real.power(-Real.one, 2 * j)
           by Real.cosineCoefficient_one_value(2 * j)
     = Real.exponentialCoefficient(2 * (2 * j)) * Real.one
           since signOne
     = Real.exponentialCoefficient(2 * (2 * j))
           by ring
}

-- The odd-indexed coefficient is −1/(2(2j+1))! ≤ 0.
theorem Real.cosineCoefficient_one_odd (j : Natural)
        : Real.cosineCoefficient(Real.one, successor(2 * j))
          = -Real.exponentialCoefficient(2 * successor(2 * j)) := {
  claim signNegOne : Real.power(-Real.one, successor(2 * j)) = -Real.one
      by calc Real.power(-Real.one, successor(2 * j))
            = -(Real.power(Real.one, successor(2 * j)))
                  by Real.power_negate_odd(Real.one, j)
            = -Real.one
                  by Real.power_one(successor(2 * j));
  calc Real.cosineCoefficient(Real.one, successor(2 * j))
     = Real.exponentialCoefficient(2 * successor(2 * j))
           * Real.power(-Real.one, successor(2 * j))
           by Real.cosineCoefficient_one_value(successor(2 * j))
     = Real.exponentialCoefficient(2 * successor(2 * j)) * (-Real.one)
           since signNegOne
     = -Real.exponentialCoefficient(2 * successor(2 * j))
           by ring
}

-- ----------------------------------------------------------------------
-- The cosine series at x = 1, summed from index 3 on, never adds
-- anything positive: cos 1 ≤ S₃ = 1 − 1/2 + 1/24.
theorem Real.cosine_one_upper_bound
        : cos(Real.one)
          ≤ Real.partialSum(Real.cosineCoefficient(Real.one), 3) := {
  -- Lead terms (odd index 3 + 2k) are −1/(…)! ≤ 0.
  claim leadNonpositive
      : ∀ (k : Natural). Real.cosineCoefficient(Real.one, 3 + 2 * k) ≤ Real.zero
      by (k : Natural) ↦ {
           claim oddIndex : (3 : Natural) + 2 * k = successor(2 * successor(k))
               by ring;
           claim ccValue
               : Real.cosineCoefficient(Real.one, 3 + 2 * k)
                 = -Real.exponentialCoefficient(2 * successor(2 * successor(k)))
               by calc Real.cosineCoefficient(Real.one, 3 + 2 * k)
                     = Real.cosineCoefficient(Real.one, successor(2 * successor(k)))
                           by oddIndex
                     = -Real.exponentialCoefficient(
                            2 * successor(2 * successor(k)))
                           by Real.cosineCoefficient_one_odd(successor(k));
           claim ecNonneg
               : Real.zero
                 ≤ Real.exponentialCoefficient(2 * successor(2 * successor(k)))
               by Real.exponentialCoefficient_nonneg(
                      2 * successor(2 * successor(k)));
           calc Real.cosineCoefficient(Real.one, 3 + 2 * k)
              = -Real.exponentialCoefficient(2 * successor(2 * successor(k)))
                    since ccValue
              ≤ -Real.zero
                    by Real.LessOrEqual.negate(
                           Real.zero,
                           Real.exponentialCoefficient(
                               2 * successor(2 * successor(k))),
                           ecNonneg)
              = Real.zero
                    by ring
         };
  -- Each consecutive pair (odd then even) sums to ≤ 0 (magnitudes shrink).
  claim pairNonpositive
      : ∀ (k : Natural).
        Real.cosineCoefficient(Real.one, 3 + 2 * k)
              + Real.cosineCoefficient(Real.one, 3 + successor(2 * k))
          ≤ Real.zero
      by (k : Natural) ↦ {
           claim oddIndex : (3 : Natural) + 2 * k = successor(2 * successor(k))
               by ring;
           claim evenIndex
               : (3 : Natural) + successor(2 * k) = 2 * successor(successor(k))
               by ring;
           claim oddValue
               : Real.cosineCoefficient(Real.one, 3 + 2 * k)
                 = -Real.exponentialCoefficient(2 * successor(2 * successor(k)))
               by calc Real.cosineCoefficient(Real.one, 3 + 2 * k)
                     = Real.cosineCoefficient(Real.one, successor(2 * successor(k)))
                           by oddIndex
                     = -Real.exponentialCoefficient(
                            2 * successor(2 * successor(k)))
                           by Real.cosineCoefficient_one_odd(successor(k));
           claim evenValue
               : Real.cosineCoefficient(Real.one, 3 + successor(2 * k))
                 = Real.exponentialCoefficient(2 * (2 * successor(successor(k))))
               by calc Real.cosineCoefficient(Real.one, 3 + successor(2 * k))
                     = Real.cosineCoefficient(Real.one, 2 * successor(successor(k)))
                           by evenIndex
                     = Real.exponentialCoefficient(2 * (2 * successor(successor(k))))
                           by Real.cosineCoefficient_one_even(successor(successor(k)));
           claim indexLe
               : 2 * successor(2 * successor(k))
                 ≤ 2 * (2 * successor(successor(k)))
               by {
                 claim gap : 2 * (2 * successor(successor(k)))
                             = 2 * successor(2 * successor(k)) + 2
                     by ring;
                 claim 2 * successor(2 * successor(k))
                       ≤ 2 * successor(2 * successor(k)) + 2
                     since Natural.less_or_equal_add_right;
                 done by substituting gap
               };
           claim Real.exponentialCoefficient(2 * (2 * successor(successor(k))))
                 ≤ Real.exponentialCoefficient(2 * successor(2 * successor(k)))
               by Real.exponentialCoefficient_antitone(
                      2 * successor(2 * successor(k)),
                      2 * (2 * successor(successor(k))),
                      indexLe);
           calc Real.cosineCoefficient(Real.one, 3 + 2 * k)
                    + Real.cosineCoefficient(Real.one, 3 + successor(2 * k))
              = -Real.exponentialCoefficient(2 * successor(2 * successor(k)))
                + Real.exponentialCoefficient(2 * (2 * successor(successor(k))))
                    since oddValue
              = -Real.exponentialCoefficient(2 * successor(2 * successor(k)))
                + Real.exponentialCoefficient(2 * (2 * successor(successor(k))))
                    since evenValue
              ≤ -Real.exponentialCoefficient(2 * successor(2 * successor(k)))
                + Real.exponentialCoefficient(2 * successor(2 * successor(k)))
                    since Real.add_preserves_LessOrEqual_left
              = Real.zero
                    by ring
         };
  -- Hence the tail from index 3 is non-positive, and every partial sum
  -- past 3 stays ≤ S₃.
  claim eventuallyBelow
      : ∀ (M : Natural). 3 ≤ M
        → Real.partialSum(Real.cosineCoefficient(Real.one), M)
          ≤ Real.partialSum(Real.cosineCoefficient(Real.one), 3)
      by (M : Natural) (threeLeqM : 3 ≤ M) ↦ {
           obtain ⟨r, mEqual⟩ from Natural.le_to_add(3, M, threeLeqM);
           claim Real.partialSum(
                     (j : Natural) ↦ Real.cosineCoefficient(Real.one, 3 + j), r)
                 ≤ Real.zero
               by Real.partialSum_nonpositive(
                      (j : Natural) ↦ Real.cosineCoefficient(Real.one, 3 + j),
                      leadNonpositive, pairNonpositive, r);
           claim splitForm
               : Real.partialSum(Real.cosineCoefficient(Real.one), M)
                 = Real.partialSum(Real.cosineCoefficient(Real.one), 3)
                   + Real.partialSum(
                         (j : Natural) ↦ Real.cosineCoefficient(Real.one, 3 + j), r)
               by calc Real.partialSum(Real.cosineCoefficient(Real.one), M)
                     = Real.partialSum(Real.cosineCoefficient(Real.one), r + 3)
                           by mEqual
                     = Real.partialSum(Real.cosineCoefficient(Real.one), 3)
                       + Real.partialSum(
                             (j : Natural) ↦ Real.cosineCoefficient(Real.one, 3 + j),
                             r)
                           by Real.partialSum_split(
                                  Real.cosineCoefficient(Real.one), 3, r);
           calc Real.partialSum(Real.cosineCoefficient(Real.one), M)
              = Real.partialSum(Real.cosineCoefficient(Real.one), 3)
                + Real.partialSum(
                      (j : Natural) ↦ Real.cosineCoefficient(Real.one, 3 + j), r)
                    since splitForm
              ≤ Real.partialSum(Real.cosineCoefficient(Real.one), 3) + Real.zero
                    since Real.add_preserves_LessOrEqual_left
              = Real.partialSum(Real.cosineCoefficient(Real.one), 3)
                    by ring
         };
  done by Real.SequenceConverges.le_of_eventually_le(
              Real.partialSum(Real.cosineCoefficient(Real.one)),
              cos(Real.one),
              Real.partialSum(Real.cosineCoefficient(Real.one), 3),
              Real.cosine_paired_series_converges(Real.one),
              3, eventuallyBelow)
}

-- ----------------------------------------------------------------------
-- The matching lower bracket: summed from index 2 on, the cosine series
-- adds nothing negative, so cos 1 ≥ S₂ = 1 − 1/2 = 1/2.
theorem Real.cosine_one_lower_bound
        : Real.partialSum(Real.cosineCoefficient(Real.one), 2)
          ≤ cos(Real.one) := {
  claim leadNonnegative
      : ∀ (k : Natural). Real.zero ≤ Real.cosineCoefficient(Real.one, 2 + 2 * k)
      by (k : Natural) ↦ {
           claim evenIndex : (2 : Natural) + 2 * k = 2 * successor(k) by ring;
           claim ccValue
               : Real.cosineCoefficient(Real.one, 2 + 2 * k)
                 = Real.exponentialCoefficient(2 * (2 * successor(k)))
               by calc Real.cosineCoefficient(Real.one, 2 + 2 * k)
                     = Real.cosineCoefficient(Real.one, 2 * successor(k))
                           by evenIndex
                     = Real.exponentialCoefficient(2 * (2 * successor(k)))
                           by Real.cosineCoefficient_one_even(successor(k));
           claim Real.zero ≤ Real.exponentialCoefficient(2 * (2 * successor(k)))
               by Real.exponentialCoefficient_nonneg(2 * (2 * successor(k)));
           done by substituting ccValue
         };
  claim pairNonnegative
      : ∀ (k : Natural).
        Real.zero
          ≤ Real.cosineCoefficient(Real.one, 2 + 2 * k)
                + Real.cosineCoefficient(Real.one, 2 + successor(2 * k))
      by (k : Natural) ↦ {
           claim evenIndex : (2 : Natural) + 2 * k = 2 * successor(k) by ring;
           claim oddIndex
               : (2 : Natural) + successor(2 * k) = successor(2 * successor(k))
               by ring;
           claim evenValue
               : Real.cosineCoefficient(Real.one, 2 + 2 * k)
                 = Real.exponentialCoefficient(2 * (2 * successor(k)))
               by calc Real.cosineCoefficient(Real.one, 2 + 2 * k)
                     = Real.cosineCoefficient(Real.one, 2 * successor(k))
                           by evenIndex
                     = Real.exponentialCoefficient(2 * (2 * successor(k)))
                           by Real.cosineCoefficient_one_even(successor(k));
           claim oddValue
               : Real.cosineCoefficient(Real.one, 2 + successor(2 * k))
                 = -Real.exponentialCoefficient(2 * successor(2 * successor(k)))
               by calc Real.cosineCoefficient(Real.one, 2 + successor(2 * k))
                     = Real.cosineCoefficient(Real.one, successor(2 * successor(k)))
                           by oddIndex
                     = -Real.exponentialCoefficient(
                            2 * successor(2 * successor(k)))
                           by Real.cosineCoefficient_one_odd(successor(k));
           claim indexLe
               : 2 * (2 * successor(k)) ≤ 2 * successor(2 * successor(k))
               by {
                 claim gap : 2 * successor(2 * successor(k))
                             = 2 * (2 * successor(k)) + 2
                     by ring;
                 claim 2 * (2 * successor(k)) ≤ 2 * (2 * successor(k)) + 2
                     since Natural.less_or_equal_add_right;
                 done by substituting gap
               };
           claim ecLe
               : Real.exponentialCoefficient(2 * successor(2 * successor(k)))
                 ≤ Real.exponentialCoefficient(2 * (2 * successor(k)))
               by Real.exponentialCoefficient_antitone(
                      2 * (2 * successor(k)),
                      2 * successor(2 * successor(k)),
                      indexLe);
           claim -Real.exponentialCoefficient(2 * (2 * successor(k)))
                 ≤ -Real.exponentialCoefficient(2 * successor(2 * successor(k)))
               by Real.LessOrEqual.negate(
                      Real.exponentialCoefficient(2 * successor(2 * successor(k))),
                      Real.exponentialCoefficient(2 * (2 * successor(k))),
                      ecLe);
           calc Real.zero
              = Real.exponentialCoefficient(2 * (2 * successor(k)))
                + -Real.exponentialCoefficient(2 * (2 * successor(k)))
                    by ring
              ≤ Real.exponentialCoefficient(2 * (2 * successor(k)))
                + -Real.exponentialCoefficient(2 * successor(2 * successor(k)))
                    since Real.add_preserves_LessOrEqual_left
              = Real.cosineCoefficient(Real.one, 2 + 2 * k)
                + -Real.exponentialCoefficient(2 * successor(2 * successor(k)))
                    since evenValue
              = Real.cosineCoefficient(Real.one, 2 + 2 * k)
                + Real.cosineCoefficient(Real.one, 2 + successor(2 * k))
                    since oddValue
         };
  claim eventuallyAbove
      : ∀ (M : Natural). 2 ≤ M
        → Real.partialSum(Real.cosineCoefficient(Real.one), 2)
          ≤ Real.partialSum(Real.cosineCoefficient(Real.one), M)
      by (M : Natural) (twoLeqM : 2 ≤ M) ↦ {
           obtain ⟨r, mEqual⟩ from Natural.le_to_add(2, M, twoLeqM);
           claim Real.zero
                 ≤ Real.partialSum(
                       (j : Natural) ↦ Real.cosineCoefficient(Real.one, 2 + j), r)
               by Real.partialSum_nonnegative(
                      (j : Natural) ↦ Real.cosineCoefficient(Real.one, 2 + j),
                      leadNonnegative, pairNonnegative, r);
           claim splitForm
               : Real.partialSum(Real.cosineCoefficient(Real.one), M)
                 = Real.partialSum(Real.cosineCoefficient(Real.one), 2)
                   + Real.partialSum(
                         (j : Natural) ↦ Real.cosineCoefficient(Real.one, 2 + j), r)
               by calc Real.partialSum(Real.cosineCoefficient(Real.one), M)
                     = Real.partialSum(Real.cosineCoefficient(Real.one), r + 2)
                           by mEqual
                     = Real.partialSum(Real.cosineCoefficient(Real.one), 2)
                       + Real.partialSum(
                             (j : Natural) ↦ Real.cosineCoefficient(Real.one, 2 + j),
                             r)
                           by Real.partialSum_split(
                                  Real.cosineCoefficient(Real.one), 2, r);
           calc Real.partialSum(Real.cosineCoefficient(Real.one), 2)
              = Real.partialSum(Real.cosineCoefficient(Real.one), 2) + Real.zero
                    by ring
              ≤ Real.partialSum(Real.cosineCoefficient(Real.one), 2)
                + Real.partialSum(
                      (j : Natural) ↦ Real.cosineCoefficient(Real.one, 2 + j), r)
                    since Real.add_preserves_LessOrEqual_left
              = Real.partialSum(Real.cosineCoefficient(Real.one), M)
                    since splitForm
         };
  done by Real.SequenceConverges.ge_of_eventually_ge(
              Real.partialSum(Real.cosineCoefficient(Real.one)),
              cos(Real.one),
              Real.partialSum(Real.cosineCoefficient(Real.one), 2),
              Real.cosine_paired_series_converges(Real.one),
              2, eventuallyAbove)
}

-- ----------------------------------------------------------------------
-- Double angle: cos 2 = 2·cos²1 − 1 (cosine_add at (1,1), with sin²
-- eliminated by sin² + cos² = 1).
theorem Real.cosine_double
        : cos(Real.one + Real.one)
          = (Real.one + Real.one) * (cos(Real.one) * cos(Real.one)) - Real.one := {
  claim addForm
      : cos(Real.one + Real.one)
        = cos(Real.one) * cos(Real.one) - sin(Real.one) * sin(Real.one)
      by Real.cosine_add(Real.one, Real.one);
  claim pythagorean
      : cos(Real.one) * cos(Real.one) + sin(Real.one) * sin(Real.one) = Real.one
      by Real.pythagorean_identity(Real.one);
  claim sinSquare
      : sin(Real.one) * sin(Real.one) = Real.one - cos(Real.one) * cos(Real.one)
      by linear_combination(pythagorean);
  calc cos(Real.one + Real.one)
     = cos(Real.one) * cos(Real.one) - sin(Real.one) * sin(Real.one)
           by addForm
     = cos(Real.one) * cos(Real.one)
       - (Real.one - cos(Real.one) * cos(Real.one))
           by substituting sinSquare
     = (Real.one + Real.one) * (cos(Real.one) * cos(Real.one)) - Real.one
           by ring
}

-- ----------------------------------------------------------------------
-- A strict natural inequality, presented as successor(a) ≤ b, casts to a
-- strict inequality between the reals (a : ℝ) < (b : ℝ): cast the weak
-- (successor a ≤ b) leg through ℚ, and bridge a < successor(a) by adding
-- a real one.
theorem Real.from_natural_LessThan (a b : Natural) (succLeqB : successor(a) ≤ b)
        : (a : Real) < (b : Real) := {
  claim castLeq : (successor(a) : Real) ≤ (b : Real)
      by Rational.to_real.LessOrEqual_preserves(
             (successor(a) : Rational), (b : Rational),
             Rational.from_natural_le_preserves(successor(a), b, succLeqB));
  claim successorAsAdd : successor(a) = a + 1;
  claim successorReal : (successor(a) : Real) = (a : Real) + Real.one
      by calc (successor(a) : Real)
            = (a + 1 : Real)
                  by successorAsAdd
            = (a : Real) + (1 : Real)
                  by Real.from_natural_add_preserves(a, 1)
            = (a : Real) + Real.one
                  by Real.from_natural_one_preserves;
  claim zeroLessOne : Real.zero < Real.one
      by Rational.to_real.positive_preserves(Rational.one, Rational.zero_less_one);
  claim aLessSuccessor : (a : Real) < (successor(a) : Real)
      by calc (a : Real)
            = (a : Real) + Real.zero
                  by ring
            < (a : Real) + Real.one
                  by Real.add_left_preserves_LessThan(
                         Real.zero, Real.one, (a : Real), zeroLessOne)
            = (successor(a) : Real)
                  by successorReal;
  done by Real.LessThan.transitive_right(
              (a : Real), (successor(a) : Real), (b : Real),
              aLessSuccessor, castLeq)
}

-- ----------------------------------------------------------------------
-- cos 2 < 0. The whole reduction (cos 1 bracketed between S₂ and S₃, and
-- cos 2 = 2·cos²1 − 1) is in place; what remains is the arithmetic
-- 2·S₃² < 1. Writing EC k := 1/k!, with EC 0 = 1 and 2·EC 2 = 1, the
-- brackets collapse to S₂ = EC 2 (≥ 0) and S₃ = EC 2 + EC 4, so it comes
-- down to 2·EC 4 + 2·EC 4² < EC 2 — and that follows from 4·EC 4 < EC 2,
-- which is 8 < 24 in disguise (4·factorial 2 < factorial 4).
theorem Real.cosine_two_negative : cos(Real.one + Real.one) < Real.zero := {
  let d2 : Real := (Natural.factorial(2) : Real);
  let d4 : Real := (Natural.factorial(4) : Real);
  let four : Real := (4 : Real);
  let a : Real := (4 * Natural.factorial(2) : Real);

  -- EC 0 = 1.
  claim factorialZeroOne : (Natural.factorial(0) : Rational) = Rational.one;
  claim ec0 : Real.exponentialCoefficient(0) = Real.one
      by calc Real.exponentialCoefficient(0)
            = (Rational.reciprocal_function((Natural.factorial(0) : Rational)) : Real)
            = (Rational.reciprocal_function(Rational.one) : Real)
                  by factorialZeroOne
            = (Rational.one : Real)
                  by Rational.reciprocal_function_one
            = Real.one;

  -- The reciprocal relations dₖ · EC k = 1 (factorial cancels its
  -- reciprocal across the ℚ → ℝ cast).
  claim q2nonzero : ¬((Natural.factorial(2) : Rational) = Rational.zero)
      by { claim Rational.zero < (Natural.factorial(2) : Rational)
               by Rational.factorial_cast_positive(2);
           done since Rational.nonzero_of_positive };
  claim recip2
      : (Natural.factorial(2) : Rational)
            * Rational.reciprocal_function((Natural.factorial(2) : Rational))
        = Rational.one
      by Rational.reciprocal_function_multiplies(
             (Natural.factorial(2) : Rational), q2nonzero);
  claim relation2 : d2 * Real.exponentialCoefficient(2) = Real.one
      by calc d2 * Real.exponentialCoefficient(2)
            = d2 * (Rational.reciprocal_function((Natural.factorial(2) : Rational)) : Real)
            = (((Natural.factorial(2) : Rational)
                  * Rational.reciprocal_function((Natural.factorial(2) : Rational))) : Real)
                  by Rational.to_real.multiply_preserves(
                         (Natural.factorial(2) : Rational),
                         Rational.reciprocal_function((Natural.factorial(2) : Rational)))
            = (Rational.one : Real)
                  by recip2
            = Real.one;
  claim q4nonzero : ¬((Natural.factorial(4) : Rational) = Rational.zero)
      by { claim Rational.zero < (Natural.factorial(4) : Rational)
               by Rational.factorial_cast_positive(4);
           done since Rational.nonzero_of_positive };
  claim recip4
      : (Natural.factorial(4) : Rational)
            * Rational.reciprocal_function((Natural.factorial(4) : Rational))
        = Rational.one
      by Rational.reciprocal_function_multiplies(
             (Natural.factorial(4) : Rational), q4nonzero);
  claim relation4 : d4 * Real.exponentialCoefficient(4) = Real.one
      by calc d4 * Real.exponentialCoefficient(4)
            = d4 * (Rational.reciprocal_function((Natural.factorial(4) : Rational)) : Real)
            = (((Natural.factorial(4) : Rational)
                  * Rational.reciprocal_function((Natural.factorial(4) : Rational))) : Real)
                  by Rational.to_real.multiply_preserves(
                         (Natural.factorial(4) : Rational),
                         Rational.reciprocal_function((Natural.factorial(4) : Rational)))
            = (Rational.one : Real)
                  by recip4
            = Real.one;

  -- Real values of the natural casts: d2 = 2, four = 4.
  claim natOneReal : (1 : Real) = Real.one
      by Real.from_natural_one_preserves;
  claim twoNatReal : (2 : Real) = Real.one + Real.one
      by calc (2 : Real)
            = (1 + 1 : Real)
            = (1 : Real) + (1 : Real)
                  by Real.from_natural_add_preserves(1, 1)
            = Real.one + (1 : Real)
                  by natOneReal
            = Real.one + Real.one
                  by natOneReal;
  claim factorialOne : Natural.factorial(1) = 1
      by calc Natural.factorial(1)
            = (1 + 0) * Natural.factorial(0)
            = 1;
  claim factorialTwo : Natural.factorial(2) = 2
      by calc Natural.factorial(2)
            = (1 + 1) * Natural.factorial(1)
            = (1 + 1) * 1
                  by substituting factorialOne
            = 2;
  claim d2Value : d2 = Real.one + Real.one
      by calc d2
            = (Natural.factorial(2) : Real)
            = (2 : Real)
                  by substituting factorialTwo
            = Real.one + Real.one
                  by twoNatReal;
  claim fourValue : four = Real.one + Real.one + Real.one + Real.one
      by calc four
            = (4 : Real)
            = (2 + 2 : Real)
                  by substituting (ring : (4 : Natural) = 2 + 2)
            = (2 : Real) + (2 : Real)
                  by Real.from_natural_add_preserves(2, 2)
            = (Real.one + Real.one) + (2 : Real)
                  by twoNatReal
            = (Real.one + Real.one) + (Real.one + Real.one)
                  by twoNatReal
            = Real.one + Real.one + Real.one + Real.one
                  by ring;
  -- The crux relation 2·EC 2 = 1.
  claim twoEC2 : (Real.one + Real.one) * Real.exponentialCoefficient(2) = Real.one
      by calc (Real.one + Real.one) * Real.exponentialCoefficient(2)
            = d2 * Real.exponentialCoefficient(2)
                  by d2Value
            = Real.one
                  by relation2;
  -- 1 − EC 2 = EC 2, the other face of 2·EC 2 = 1.
  claim oneMinusEC2
      : Real.one - Real.exponentialCoefficient(2) = Real.exponentialCoefficient(2)
      by linear_combination(Real.zero - twoEC2);

  -- The three leading cosine coefficients at x = 1. Each is an instance
  -- of cosineCoefficient_one_even/odd; we bridge the index into the
  -- lemma's 2·j / 2·(2·j) shape with `ring` (the citation matcher does
  -- not reduce the multiplications on its own).
  claim cc0 : Real.cosineCoefficient(Real.one, 0) = Real.exponentialCoefficient(0)
      by calc Real.cosineCoefficient(Real.one, 0)
            = Real.cosineCoefficient(Real.one, 2 * 0)
                  by (ring : (0 : Natural) = 2 * 0)
            = Real.exponentialCoefficient(2 * (2 * 0))
                  by Real.cosineCoefficient_one_even(0)
            = Real.exponentialCoefficient(0)
                  by (ring : (2 : Natural) * (2 * 0) = 0);
  claim cc1 : Real.cosineCoefficient(Real.one, 1) = -Real.exponentialCoefficient(2)
      by calc Real.cosineCoefficient(Real.one, 1)
            = Real.cosineCoefficient(Real.one, successor(2 * 0))
                  by (ring : (1 : Natural) = successor(2 * 0))
            = -Real.exponentialCoefficient(2 * successor(2 * 0))
                  by Real.cosineCoefficient_one_odd(0)
            = -Real.exponentialCoefficient(2)
                  by (ring : (2 : Natural) * successor(2 * 0) = 2);
  claim cc2 : Real.cosineCoefficient(Real.one, 2) = Real.exponentialCoefficient(4)
      by calc Real.cosineCoefficient(Real.one, 2)
            = Real.cosineCoefficient(Real.one, 2 * 1)
                  by (ring : (2 : Natural) = 2 * 1)
            = Real.exponentialCoefficient(2 * (2 * 1))
                  by Real.cosineCoefficient_one_even(1)
            = Real.exponentialCoefficient(4)
                  by (ring : (2 : Natural) * (2 * 1) = 4);

  -- S₂ = EC 2 ≥ 0, so cos 1 ≥ 0.
  claim s2Value
      : Real.partialSum(Real.cosineCoefficient(Real.one), 2)
        = Real.exponentialCoefficient(2)
      by calc Real.partialSum(Real.cosineCoefficient(Real.one), 2)
            = (Real.zero + Real.cosineCoefficient(Real.one, 0 + 0))
              + Real.cosineCoefficient(Real.one, 0 + 1)
            = (Real.zero + Real.cosineCoefficient(Real.one, 0))
              + Real.cosineCoefficient(Real.one, 0 + 1)
                  by (0 + 0 = 0)
            = (Real.zero + Real.cosineCoefficient(Real.one, 0))
              + Real.cosineCoefficient(Real.one, 1)
                  by (0 + 1 = 1)
            = (Real.zero + Real.exponentialCoefficient(0))
              + Real.cosineCoefficient(Real.one, 1)
                  by cc0
            = (Real.zero + Real.exponentialCoefficient(0))
              + (-Real.exponentialCoefficient(2))
                  by cc1
            = (Real.zero + Real.one) + (-Real.exponentialCoefficient(2))
                  by ec0
            = Real.one - Real.exponentialCoefficient(2)
                  by ring
            = Real.exponentialCoefficient(2)
                  by oneMinusEC2;
  claim s2Nonneg : Real.zero ≤ Real.partialSum(Real.cosineCoefficient(Real.one), 2)
      by calc Real.zero
            ≤ Real.exponentialCoefficient(2)
                  by Real.exponentialCoefficient_nonneg(2)
            = Real.partialSum(Real.cosineCoefficient(Real.one), 2);
  claim cos1Nonneg : Real.zero ≤ cos(Real.one)
      by calc Real.zero
            ≤ Real.partialSum(Real.cosineCoefficient(Real.one), 2)
                  by s2Nonneg
            ≤ cos(Real.one)
                  by Real.cosine_one_lower_bound;

  -- S₃ = S₂ + cc(1,2) = EC 2 + EC 4, and cos 1 ≤ S₃. The last term is
  -- rewritten with `substituting` (a syntactic replacement) rather than a
  -- calc diff-step: cosineCoefficient(1,2) unfolds to a degree-4 complex
  -- power whose fully-reduced normal form is enormous, and any defeq that
  -- materialises it (e.g. comparing it against EC 4) costs gigabytes.
  claim thirdTermValue
      : Real.exponentialCoefficient(2) + Real.cosineCoefficient(Real.one, 2)
        = Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)
      by substituting cc2;
  claim s3Value
      : Real.partialSum(Real.cosineCoefficient(Real.one), 3)
        = Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)
      by calc Real.partialSum(Real.cosineCoefficient(Real.one), 3)
            = Real.partialSum(Real.cosineCoefficient(Real.one), 2)
              + Real.cosineCoefficient(Real.one, 0 + 2)
            = Real.partialSum(Real.cosineCoefficient(Real.one), 2)
              + Real.cosineCoefficient(Real.one, 2)
                  by (0 + 2 = 2)
            = Real.exponentialCoefficient(2) + Real.cosineCoefficient(Real.one, 2)
                  by s2Value
            = Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)
                  by thirdTermValue;
  -- cos 1 ≤ S₃, with S₃ collapsed to EC 2 + EC 4 once (single rewrite —
  -- partialSum never enters a product, where a failed rewrite would send
  -- the prover normalising cosineCoefficient).
  claim cos1Upper
      : cos(Real.one)
        ≤ Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)
      by calc cos(Real.one)
            ≤ Real.partialSum(Real.cosineCoefficient(Real.one), 3)
                  by Real.cosine_one_upper_bound
            = Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)
                  by s3Value;

  -- Positivity facts about EC 2, EC 4.
  claim ec2Positive : Real.zero < Real.exponentialCoefficient(2)
      by { claim Rational.zero < (Natural.factorial(2) : Rational)
               by Rational.factorial_cast_positive(2);
           claim Rational.zero
                 < Rational.reciprocal_function((Natural.factorial(2) : Rational))
               since Rational.reciprocal_function_positive_of_positive;
           done since Rational.to_real.positive_preserves };
  claim ec4Positive : Real.zero < Real.exponentialCoefficient(4)
      by { claim Rational.zero < (Natural.factorial(4) : Rational)
               by Rational.factorial_cast_positive(4);
           claim Rational.zero
                 < Rational.reciprocal_function((Natural.factorial(4) : Rational))
               since Rational.reciprocal_function_positive_of_positive;
           done since Rational.to_real.positive_preserves };
  claim productPositive
      : Real.zero < Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4)
      by Real.multiply_positive(
             Real.exponentialCoefficient(2), Real.exponentialCoefficient(4),
             ec2Positive, ec4Positive);
  claim ec4Nonneg : Real.zero ≤ Real.exponentialCoefficient(4)
      by Real.exponentialCoefficient_nonneg(4);
  claim ec4LeOne : Real.exponentialCoefficient(4) ≤ Real.one
      by calc Real.exponentialCoefficient(4)
            ≤ Real.exponentialCoefficient(0)
                  by Real.exponentialCoefficient_antitone(0, 4, Natural.zero_least(4))
            = Real.one
                  by ec0;
  -- EC 4² ≤ EC 4 (EC 4 ≤ 1).
  claim Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4)
        ≤ Real.exponentialCoefficient(4)
      by calc Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4)
            ≤ Real.one * Real.exponentialCoefficient(4)
                  by Real.LessOrEqual.multiply_monotone_nonneg(
                         Real.exponentialCoefficient(4), Real.one,
                         Real.exponentialCoefficient(4), Real.exponentialCoefficient(4),
                         ec4LeOne,
                         Real.LessOrEqual.reflexive(Real.exponentialCoefficient(4)),
                         ec4Nonneg, ec4Nonneg)
            = Real.exponentialCoefficient(4)
                  by ring;

  -- 4·EC 4 < EC 2, via multiplying 4·d2 < d4 by the positive EC 2·EC 4.
  claim factorialThree : Natural.factorial(3) = 6
      by calc Natural.factorial(3)
            = 3 * Natural.factorial(2)
            = 3 * 2
                  by substituting factorialTwo
            = 6
                  by ring;
  claim factorialFour : Natural.factorial(4) = 24
      by calc Natural.factorial(4)
            = 4 * Natural.factorial(3)
            = 4 * 6
                  by substituting factorialThree
            = 24
                  by ring;
  claim natBound : successor(4 * Natural.factorial(2)) ≤ Natural.factorial(4)
      by calc successor(4 * Natural.factorial(2))
            = successor(4 * 2)
                  by substituting factorialTwo
            = (9 : Natural)
                  by ring
            ≤ 15 + 9
                  by Natural.less_or_equal_add_left(9, 15)
            = (24 : Natural)
                  by ring
            = Natural.factorial(4)
                  by substituting factorialFour;
  claim aLessD4 : a < d4
      by Real.from_natural_LessThan(4 * Natural.factorial(2), Natural.factorial(4), natBound);
  claim aMultForm : a = four * d2
      by Real.from_natural_multiply_preserves(4, Natural.factorial(2));
  claim productStrict
      : a * (Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4))
        < d4 * (Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4))
      by Real.LessThan.multiply_by_positive_right(
             a, d4,
             Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4),
             aLessD4, productPositive);
  claim lhsForm
      : a * (Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4))
        = four * Real.exponentialCoefficient(4)
      by linear_combination(
             (Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4)) * aMultForm
             + four * Real.exponentialCoefficient(4) * relation2);
  claim rhsForm
      : d4 * (Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4))
        = Real.exponentialCoefficient(2)
      by linear_combination(Real.exponentialCoefficient(2) * relation4);
  claim fourEC4Less
      : four * Real.exponentialCoefficient(4) < Real.exponentialCoefficient(2)
      by calc four * Real.exponentialCoefficient(4)
            = a * (Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4))
                  by lhsForm
            < d4 * (Real.exponentialCoefficient(2) * Real.exponentialCoefficient(4))
                  by productStrict
            = Real.exponentialCoefficient(2)
                  by rhsForm;

  -- 2·EC 4 + 2·EC 4² ≤ 4·EC 4 < EC 2.
  claim Real.IsNonneg(Real.one + Real.one)
      by { claim Real.zero < Real.one
               by { claim Real.zero < (Rational.one : Real)
                        by Rational.to_real.positive_preserves(
                               Rational.one, Rational.zero_less_one);
                    done };
           claim Real.zero < Real.one + Real.one
               by calc Real.zero
                     = Real.zero + Real.zero
                           by ring
                     < Real.one + Real.one
                           since Real.LessThan.add_strict_strict;
           claim Real.zero ≤ Real.one + Real.one since Real.LessThan.weaken;
           done since Real.IsNonneg_of_LessOrEqual_zero };
  claim twoEC4SquareLe
      : (Real.one + Real.one) * (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4))
        ≤ (Real.one + Real.one) * Real.exponentialCoefficient(4)
      by calc (Real.one + Real.one)
                  * (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4))
            = (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4))
                  * (Real.one + Real.one)
                  by ring
            ≤ Real.exponentialCoefficient(4) * (Real.one + Real.one)
                  since Real.LessOrEqual.multiply_by_nonneg_right
            = (Real.one + Real.one) * Real.exponentialCoefficient(4)
                  by ring;
  claim keyLe
      : (Real.one + Real.one) * Real.exponentialCoefficient(4)
          + (Real.one + Real.one)
              * (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4))
        ≤ four * Real.exponentialCoefficient(4)
      by calc (Real.one + Real.one) * Real.exponentialCoefficient(4)
                + (Real.one + Real.one)
                    * (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4))
            ≤ (Real.one + Real.one) * Real.exponentialCoefficient(4)
              + (Real.one + Real.one) * Real.exponentialCoefficient(4)
                  by Real.add_preserves_LessOrEqual_left(
                         (Real.one + Real.one)
                             * (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4)),
                         (Real.one + Real.one) * Real.exponentialCoefficient(4),
                         (Real.one + Real.one) * Real.exponentialCoefficient(4),
                         twoEC4SquareLe)
            = (Real.one + Real.one + Real.one + Real.one)
                  * Real.exponentialCoefficient(4)
                  by ring
            = four * Real.exponentialCoefficient(4)
                  by fourValue;
  claim keyBound
      : (Real.one + Real.one) * Real.exponentialCoefficient(4)
          + (Real.one + Real.one)
              * (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4))
        < Real.exponentialCoefficient(2)
      by Real.LessThan.transitive_left(
             (Real.one + Real.one) * Real.exponentialCoefficient(4)
                 + (Real.one + Real.one)
                     * (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4)),
             four * Real.exponentialCoefficient(4),
             Real.exponentialCoefficient(2),
             keyLe, fourEC4Less);

  -- Abbreviate the bound B := EC 2 + EC 4 (= S₃). 2·B² = EC 2 + (2·EC 4 +
  -- 2·EC 4²) < EC 2 + EC 2 = 1, using 2·EC 2 = 1 for both equalities.
  claim boundSquare
      : (Real.one + Real.one)
            * ((Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
               * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)))
        = Real.exponentialCoefficient(2)
          + ((Real.one + Real.one) * Real.exponentialCoefficient(4)
             + (Real.one + Real.one)
                 * (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4)))
      by linear_combination(
             (Real.exponentialCoefficient(2)
              + (Real.one + Real.one) * Real.exponentialCoefficient(4))
             * twoEC2);
  claim twoBoundSquareLessOne
      : (Real.one + Real.one)
            * ((Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
               * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)))
        < Real.one
      by calc (Real.one + Real.one)
                  * ((Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
                     * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)))
            = Real.exponentialCoefficient(2)
              + ((Real.one + Real.one) * Real.exponentialCoefficient(4)
                 + (Real.one + Real.one)
                     * (Real.exponentialCoefficient(4) * Real.exponentialCoefficient(4)))
                  by boundSquare
            < Real.exponentialCoefficient(2) + Real.exponentialCoefficient(2)
                  by Real.add_left_preserves_LessThan(
                         (Real.one + Real.one) * Real.exponentialCoefficient(4)
                             + (Real.one + Real.one)
                                 * (Real.exponentialCoefficient(4)
                                    * Real.exponentialCoefficient(4)),
                         Real.exponentialCoefficient(2),
                         Real.exponentialCoefficient(2),
                         keyBound)
            = (Real.one + Real.one) * Real.exponentialCoefficient(2)
                  by ring
            = Real.one
                  by twoEC2;

  -- cos²1 ≤ B², hence 2·cos²1 ≤ 2·B² < 1.
  claim cosSquareLe
      : cos(Real.one) * cos(Real.one)
        ≤ (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
          * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
      by Real.LessOrEqual.multiply_monotone_nonneg(
             cos(Real.one),
             Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4),
             cos(Real.one),
             Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4),
             cos1Upper, cos1Upper, cos1Nonneg, cos1Nonneg);
  claim twoCosSquareLessOne
      : (Real.one + Real.one) * (cos(Real.one) * cos(Real.one)) < Real.one
      by calc (Real.one + Real.one) * (cos(Real.one) * cos(Real.one))
            = (cos(Real.one) * cos(Real.one)) + (cos(Real.one) * cos(Real.one))
                  by ring
            ≤ ((Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
               * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)))
              + (cos(Real.one) * cos(Real.one))
                  by Real.add_preserves_LessOrEqual(
                         cos(Real.one) * cos(Real.one),
                         (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
                             * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)),
                         cos(Real.one) * cos(Real.one),
                         cosSquareLe)
            ≤ ((Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
               * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)))
              + ((Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
                 * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)))
                  by Real.add_preserves_LessOrEqual_left(
                         cos(Real.one) * cos(Real.one),
                         (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
                             * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)),
                         (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
                             * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)),
                         cosSquareLe)
            = (Real.one + Real.one)
                  * ((Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4))
                     * (Real.exponentialCoefficient(2) + Real.exponentialCoefficient(4)))
                  by ring
            < Real.one
                  by twoBoundSquareLessOne;

  -- cos 2 = 2·cos²1 − 1 < 1 − 1 = 0.
  calc cos(Real.one + Real.one)
     = (Real.one + Real.one) * (cos(Real.one) * cos(Real.one)) - Real.one
           by Real.cosine_double
     < Real.one - Real.one
           by Real.add_preserves_LessThan(
                  (Real.one + Real.one) * (cos(Real.one) * cos(Real.one)),
                  Real.one, -Real.one, twoCosSquareLessOne)
     = Real.zero
           by ring
}

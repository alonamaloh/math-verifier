import ComplexNumber.trigonometry

-- ----------------------------------------------------------------------
-- exp(i·x) times its conjugate is 1: the conjugate is exp(−i·x), and
-- the functional equation collapses the product to exp(0).
theorem ComplexNumber.exponential_imaginary_times_conjugate (x : Real)
        : exp(ComplexNumber.i * ComplexNumber.from_real(x))
          * ComplexNumber.conjugate(exp(ComplexNumber.i * ComplexNumber.from_real(x)))
          = RingModulo.one(Real.polynomial_commutative_ring,
                Complex.definingPolynomial) := {
  claim conjugateExponential
      : ComplexNumber.conjugate(exp(ComplexNumber.i * ComplexNumber.from_real(x)))
        = exp(-(ComplexNumber.i * ComplexNumber.from_real(x)))
      by calc ComplexNumber.conjugate(
                  exp(ComplexNumber.i * ComplexNumber.from_real(x)))
            = exp(ComplexNumber.conjugate(
                      ComplexNumber.i * ComplexNumber.from_real(x)))
                  by ComplexNumber.exponential_conjugate(
                         ComplexNumber.i * ComplexNumber.from_real(x))
            = exp(-(ComplexNumber.i * ComplexNumber.from_real(x)))
                  by ComplexNumber.conjugate_i_times_from_real(x);
  calc exp(ComplexNumber.i * ComplexNumber.from_real(x))
           * ComplexNumber.conjugate(exp(ComplexNumber.i * ComplexNumber.from_real(x)))
     = exp(ComplexNumber.i * ComplexNumber.from_real(x))
       * exp(-(ComplexNumber.i * ComplexNumber.from_real(x)))
           by conjugateExponential
     = exp(ComplexNumber.i * ComplexNumber.from_real(x)
           + -(ComplexNumber.i * ComplexNumber.from_real(x)))
           by ComplexNumber.exponential_add(
                  ComplexNumber.i * ComplexNumber.from_real(x),
                  -(ComplexNumber.i * ComplexNumber.from_real(x)))
     = exp(RingModulo.zero(Real.polynomial_commutative_ring,
               Complex.definingPolynomial))
           by substituting
               (ring : ComplexNumber.i * ComplexNumber.from_real(x)
                           + -(ComplexNumber.i * ComplexNumber.from_real(x))
                   = RingModulo.zero(Real.polynomial_commutative_ring,
                         Complex.definingPolynomial))
     = RingModulo.one(Real.polynomial_commutative_ring,
           Complex.definingPolynomial)
           by ComplexNumber.exponential_zero
}

-- ----------------------------------------------------------------------
-- The Pythagorean identity: cos²x + sin²x = 1 — the real part of
-- exp(i·x)·conj(exp(i·x)) = 1, computed through the coordinates.
theorem Real.pythagorean_identity (x : Real)
        : cos(x) * cos(x) + sin(x) * sin(x) = Real.one := {
  claim productExpansion
      : ComplexNumber.realPart(
            exp(ComplexNumber.i * ComplexNumber.from_real(x))
            * ComplexNumber.conjugate(
                  exp(ComplexNumber.i * ComplexNumber.from_real(x))))
        = cos(x) * cos(x) + sin(x) * sin(x)
      by calc ComplexNumber.realPart(
                  exp(ComplexNumber.i * ComplexNumber.from_real(x))
                  * ComplexNumber.conjugate(
                        exp(ComplexNumber.i * ComplexNumber.from_real(x))))
            = ComplexNumber.realPart(exp(ComplexNumber.i * ComplexNumber.from_real(x)))
                  * ComplexNumber.realPart(
                        ComplexNumber.conjugate(
                            exp(ComplexNumber.i * ComplexNumber.from_real(x))))
              - ComplexNumber.imaginaryPart(
                    exp(ComplexNumber.i * ComplexNumber.from_real(x)))
                    * ComplexNumber.imaginaryPart(
                          ComplexNumber.conjugate(
                              exp(ComplexNumber.i * ComplexNumber.from_real(x))))
            = ComplexNumber.realPart(exp(ComplexNumber.i * ComplexNumber.from_real(x)))
                  * ComplexNumber.realPart(
                        exp(ComplexNumber.i * ComplexNumber.from_real(x)))
              - ComplexNumber.imaginaryPart(
                    exp(ComplexNumber.i * ComplexNumber.from_real(x)))
                    * ComplexNumber.imaginaryPart(
                          ComplexNumber.conjugate(
                              exp(ComplexNumber.i * ComplexNumber.from_real(x))))
                  by ComplexNumber.realPart_conjugate(
                         exp(ComplexNumber.i * ComplexNumber.from_real(x)))
            = ComplexNumber.realPart(exp(ComplexNumber.i * ComplexNumber.from_real(x)))
                  * ComplexNumber.realPart(
                        exp(ComplexNumber.i * ComplexNumber.from_real(x)))
              - ComplexNumber.imaginaryPart(
                    exp(ComplexNumber.i * ComplexNumber.from_real(x)))
                    * (-ComplexNumber.imaginaryPart(
                           exp(ComplexNumber.i * ComplexNumber.from_real(x))))
                  by ComplexNumber.imaginaryPart_conjugate(
                         exp(ComplexNumber.i * ComplexNumber.from_real(x)))
            = ComplexNumber.realPart(exp(ComplexNumber.i * ComplexNumber.from_real(x)))
                  * ComplexNumber.realPart(
                        exp(ComplexNumber.i * ComplexNumber.from_real(x)))
              + ComplexNumber.imaginaryPart(
                    exp(ComplexNumber.i * ComplexNumber.from_real(x)))
                    * ComplexNumber.imaginaryPart(
                          exp(ComplexNumber.i * ComplexNumber.from_real(x)))
                  by ring;
  claim oneRealPart
      : ComplexNumber.realPart(
            RingModulo.one(Real.polynomial_commutative_ring,
                Complex.definingPolynomial))
        = Real.one
      by calc ComplexNumber.realPart(
                  RingModulo.one(Real.polynomial_commutative_ring,
                      Complex.definingPolynomial))
            = ComplexNumber.realPart(ComplexNumber.from_real(Real.one))
            = Real.one;
  calc cos(x) * cos(x) + sin(x) * sin(x)
     = ComplexNumber.realPart(
           exp(ComplexNumber.i * ComplexNumber.from_real(x))
           * ComplexNumber.conjugate(
                 exp(ComplexNumber.i * ComplexNumber.from_real(x))))
           by productExpansion
     = ComplexNumber.realPart(
           RingModulo.one(Real.polynomial_commutative_ring,
               Complex.definingPolynomial))
           by ComplexNumber.exponential_imaginary_times_conjugate(x)
     = Real.one
           by oneRealPart
}

-- ----------------------------------------------------------------------
-- |exp(i·x)| = 1: the exponential of a purely imaginary number lies on
-- the unit circle (its modulus squares to cos²x + sin²x = 1).
theorem ComplexNumber.modulus_exponential_imaginary (x : Real)
        : abs(exp(ComplexNumber.i * ComplexNumber.from_real(x)))
          = Real.one := {
  claim abs(exp(ComplexNumber.i * ComplexNumber.from_real(x)))
            * abs(exp(ComplexNumber.i * ComplexNumber.from_real(x)))
        = Real.one
      by calc abs(exp(ComplexNumber.i * ComplexNumber.from_real(x)))
                  * abs(
                        exp(ComplexNumber.i * ComplexNumber.from_real(x)))
            = ComplexNumber.realPart(exp(ComplexNumber.i * ComplexNumber.from_real(x)))
                  * ComplexNumber.realPart(
                        exp(ComplexNumber.i * ComplexNumber.from_real(x)))
              + ComplexNumber.imaginaryPart(
                    exp(ComplexNumber.i * ComplexNumber.from_real(x)))
                    * ComplexNumber.imaginaryPart(
                          exp(ComplexNumber.i * ComplexNumber.from_real(x)))
                  by ComplexNumber.modulus_squares
            = cos(x) * cos(x) + sin(x) * sin(x)
            = Real.one
                  by Real.pythagorean_identity(x);
  claim Real.zero ≤ abs(exp(ComplexNumber.i * ComplexNumber.from_real(x)));
  claim Rational.zero < Rational.one;
  claim Real.zero < Rational.one;
  claim Real.zero ≤ Real.one;
  claim Real.one * Real.one = Real.one;
  done by Real.square_root_unique
}

-- ----------------------------------------------------------------------
-- The functional equation along the imaginary axis, ready for the
-- addition formulas: exp(i·(x+y)) = exp(i·x)·exp(i·y).
theorem ComplexNumber.exponential_imaginary_add (x y : Real)
        : exp(ComplexNumber.i * ComplexNumber.from_real(x + y))
          = exp(ComplexNumber.i * ComplexNumber.from_real(x))
            * exp(ComplexNumber.i * ComplexNumber.from_real(y)) := {
  claim imaginaryInputSplits
      : ComplexNumber.i * ComplexNumber.from_real(x + y)
        = ComplexNumber.i * ComplexNumber.from_real(x)
          + ComplexNumber.i * ComplexNumber.from_real(y)
      by calc ComplexNumber.i * ComplexNumber.from_real(x + y)
            = ComplexNumber.i
              * (ComplexNumber.from_real(x) + ComplexNumber.from_real(y))
            = ComplexNumber.i * ComplexNumber.from_real(x)
              + ComplexNumber.i * ComplexNumber.from_real(y);
  calc exp(ComplexNumber.i * ComplexNumber.from_real(x + y))
     = exp(ComplexNumber.i * ComplexNumber.from_real(x)
           + ComplexNumber.i * ComplexNumber.from_real(y))
           by imaginaryInputSplits
     = exp(ComplexNumber.i * ComplexNumber.from_real(x))
       * exp(ComplexNumber.i * ComplexNumber.from_real(y))
           by ComplexNumber.exponential_add(
                  ComplexNumber.i * ComplexNumber.from_real(x),
                  ComplexNumber.i * ComplexNumber.from_real(y))
}

-- ----------------------------------------------------------------------
-- The addition formulas: take the coordinates of
-- exp(i·(x+y)) = exp(i·x)·exp(i·y).

theorem Real.cosine_add (x y : Real)
        : cos(x + y) = cos(x) * cos(y) - sin(x) * sin(y) :=
  calc cos(x + y)
     = ComplexNumber.realPart(exp(ComplexNumber.i * ComplexNumber.from_real(x + y)))
     = ComplexNumber.realPart(
           exp(ComplexNumber.i * ComplexNumber.from_real(x))
           * exp(ComplexNumber.i * ComplexNumber.from_real(y)))
           by ComplexNumber.exponential_imaginary_add(x, y)
     = ComplexNumber.realPart(exp(ComplexNumber.i * ComplexNumber.from_real(x)))
           * ComplexNumber.realPart(exp(ComplexNumber.i * ComplexNumber.from_real(y)))
       - ComplexNumber.imaginaryPart(exp(ComplexNumber.i * ComplexNumber.from_real(x)))
             * ComplexNumber.imaginaryPart(
                   exp(ComplexNumber.i * ComplexNumber.from_real(y)))
     = cos(x) * cos(y) - sin(x) * sin(y)

theorem Real.sine_add (x y : Real)
        : sin(x + y) = sin(x) * cos(y) + cos(x) * sin(y) :=
  calc sin(x + y)
     = ComplexNumber.imaginaryPart(
           exp(ComplexNumber.i * ComplexNumber.from_real(x + y)))
     = ComplexNumber.imaginaryPart(
           exp(ComplexNumber.i * ComplexNumber.from_real(x))
           * exp(ComplexNumber.i * ComplexNumber.from_real(y)))
           by ComplexNumber.exponential_imaginary_add(x, y)
     = ComplexNumber.realPart(exp(ComplexNumber.i * ComplexNumber.from_real(x)))
           * ComplexNumber.imaginaryPart(
                 exp(ComplexNumber.i * ComplexNumber.from_real(y)))
       + ComplexNumber.imaginaryPart(
             exp(ComplexNumber.i * ComplexNumber.from_real(x)))
             * ComplexNumber.realPart(exp(ComplexNumber.i * ComplexNumber.from_real(y)))
     = cos(x) * sin(y) + sin(x) * cos(y)
     = sin(x) * cos(y) + cos(x) * sin(y)

import ComplexNumber.modulus_bounds
import ComplexNumber.completeness
import ComplexNumber.limits
import ComplexNumber.exponential
import ComplexNumber.series

-- ----------------------------------------------------------------------
-- The definition, and its coordinates.

definition ComplexNumber.conjugate (z : ℂ) : ℂ :=
  ComplexNumber.ofCoordinates(
      Re(z), -Im(z))

-- `conj` is the short name used in formulas; `ComplexNumber.conjugate` stays
-- the canonical name that carries the lemmas below (they apply to `conj`
-- unchanged, since `overload` makes the two the same function).
overload conj := ComplexNumber.conjugate

theorem ComplexNumber.realPart_conjugate (z : ℂ)
        : Re(conj(z))
          = Re(z) :=
  by ComplexNumber.realPart_ofCoordinates

theorem ComplexNumber.imaginaryPart_conjugate (z : ℂ)
        : Im(conj(z))
          = -Im(z) :=
  by ComplexNumber.imaginaryPart_ofCoordinates

-- ----------------------------------------------------------------------
-- Conjugation is a ring homomorphism: every law is a coordinate
-- computation plus real ring algebra.

theorem ComplexNumber.conjugate_add (z w : ℂ)
        : conj(z + w)
          = conj(z) + conj(w) := {
  Re(conj(z + w))
      = Re(z + w)
      = Re(z) + Re(w)
      = Re(conj(z)) + Re(w)            by ComplexNumber.realPart_conjugate
      = Re(conj(z)) + Re(conj(w))      by ComplexNumber.realPart_conjugate
      = Re(conj(z) + conj(w));
  Im(conj(z + w))
      = -Im(z + w)
      = -(Im(z) + Im(w))               by ComplexNumber.imaginaryPart_add
      = -Im(z) + -Im(w)
      = Im(conj(z)) + -Im(w)           by ComplexNumber.imaginaryPart_conjugate
      = Im(conj(z)) + Im(conj(w))      by ComplexNumber.imaginaryPart_conjugate
      = Im(conj(z) + conj(w));
  done by ComplexNumber.eq_of_coordinates
}

theorem ComplexNumber.conjugate_multiply (z w : ℂ)
        : conj(z * w)
          = conj(z) * conj(w) := {
  Re(conj(z) * conj(w))
        = Re(conj(z))
              * Re(conj(w))
          - Im(conj(z))
                * Im(conj(w))
      by ComplexNumber.realPart_multiply;
  Im(
            conj(z) * conj(w))
        = Re(conj(z))
              * Im(conj(w))
          + Im(conj(z))
                * Re(conj(w));
  Re(conj(z * w))
      = Re(z * w)
      = Re(z) * Re(w)
        - Im(z) * Im(w)
      = Re(z) * Re(w)
        - (-Im(z)) * (-Im(w))
            by ring
      = Re(conj(z))
            * Re(w)
        - (-Im(z)) * (-Im(w))
            by ComplexNumber.realPart_conjugate
      = Re(conj(z))
            * Re(conj(w))
        - (-Im(z)) * (-Im(w))
            by ComplexNumber.realPart_conjugate
      = Re(conj(z))
            * Re(conj(w))
        - Im(conj(z))
              * (-Im(w))
            by ComplexNumber.imaginaryPart_conjugate
      = Re(conj(z))
            * Re(conj(w))
        - Im(conj(z))
              * Im(conj(w))
            by ComplexNumber.imaginaryPart_conjugate
      = Re(
            conj(z) * conj(w));
  Im(conj(z * w))
      = -Im(z * w)
      = -(Re(z) * Im(w)
          + Im(z) * Re(w))
            by ComplexNumber.imaginaryPart_multiply
      = Re(z) * (-Im(w))
        + (-Im(z)) * Re(w)
            by ring
      = Re(conj(z))
            * (-Im(w))
        + (-Im(z)) * Re(w)
            by ComplexNumber.realPart_conjugate
      = Re(conj(z))
            * Im(conj(w))
        + (-Im(z)) * Re(w)
            by ComplexNumber.imaginaryPart_conjugate
      = Re(conj(z))
            * Im(conj(w))
        + Im(conj(z))
              * Re(w)
            by ComplexNumber.imaginaryPart_conjugate
      = Re(conj(z))
            * Im(conj(w))
        + Im(conj(z))
              * Re(conj(w))
            by ComplexNumber.realPart_conjugate
      = Im(
            conj(z) * conj(w));
  done by ComplexNumber.eq_of_coordinates
}

-- Conjugation fixes the embedded reals (their imaginary part is 0,
-- and −0 = 0).
theorem ComplexNumber.conjugate_from_real (r : ℝ)
        : conj((r : ℂ))
          = (r : ℂ) := {
  Re(conj((r : ℂ)))
      = Re((r : ℂ));
  Im(
          conj((r : ℂ)))
      = -Im((r : ℂ))
      = -(0 : ℝ)
      = 0
      = Im((r : ℂ));
  done by ComplexNumber.eq_of_coordinates
}

theorem ComplexNumber.conjugate_zero
        : conj((0 : ℂ)) = (0 : ℂ) :=
  done by ComplexNumber.conjugate_from_real

theorem ComplexNumber.conjugate_one
        : conj((1 : ℂ)) = (1 : ℂ) :=
  done by ComplexNumber.conjugate_from_real

-- ----------------------------------------------------------------------
-- The imaginary unit: its coordinates are (0, 1), so conjugation
-- negates it — and with it every purely imaginary number i·x.

automatic theorem ComplexNumber.realPart_i
        : Re(ComplexNumber.i) = 0 :=
  Re(ComplexNumber.i)
     = (0 : ℝ) - 0
     = 0

automatic theorem ComplexNumber.imaginaryPart_i
        : Im(ComplexNumber.i) = 1 :=
  Im(ComplexNumber.i)
     = (1 : ℝ) - 0
     = 1

theorem ComplexNumber.conjugate_i
        : conj(ComplexNumber.i) = -ComplexNumber.i := {
  Re(conj(ComplexNumber.i))
      = Re(ComplexNumber.i)
      = 0
            by ComplexNumber.realPart_i
      = -(0 : ℝ)
      = -Re(ComplexNumber.i)
            by ComplexNumber.realPart_i
      = Re(-ComplexNumber.i)
            by ComplexNumber.realPart_negate;
  Im(conj(ComplexNumber.i))
      = -Im(ComplexNumber.i)
      = Im(-ComplexNumber.i);
  done by ComplexNumber.eq_of_coordinates
}

theorem ComplexNumber.conjugate_i_times_from_real (x : ℝ)
        : conj(ComplexNumber.i * (x : ℂ))
          = -(ComplexNumber.i * (x : ℂ)) :=
  conj(ComplexNumber.i * (x : ℂ))
     = conj(ComplexNumber.i)
       * conj((x : ℂ))
           by ComplexNumber.conjugate_multiply
     = (-ComplexNumber.i) * conj((x : ℂ))
           by ComplexNumber.conjugate_i
     = (-ComplexNumber.i) * (x : ℂ)
           by ComplexNumber.conjugate_from_real
     = -(ComplexNumber.i * (x : ℂ))

-- Conjugation distributes over powers.
theorem ComplexNumber.conjugate_power (z : ℂ) (n : ℕ)
        : conj(z ^ n)
          = conj(z) ^ n :=
  by induction on n with IH {
    case n = 0: done by ComplexNumber.conjugate_one
    case n = 1 + k for some k:
        conj(z * z ^ k)
           = conj(z) * conj(z ^ k)
           = conj(z) * conj(z) ^ k
               by IH
  }

-- Conjugation distributes over partial sums.
theorem ComplexNumber.conjugate_partialSum (s : ℕ → ℂ) (n : ℕ)
        : conj(ComplexNumber.partialSum(s, n))
          = ComplexNumber.partialSum(
                (k : ℕ) ↦ conj(s(k)), n) :=
  by induction on n with IH {
    case n = 0: done by ComplexNumber.conjugate_zero
    case n = 1 + m for some m:
        conj(ComplexNumber.partialSum(s, m) + s(m))
           = conj(ComplexNumber.partialSum(s, m))
             + conj(s(m))
           = ComplexNumber.partialSum(
                 (k : ℕ) ↦ conj(s(k)), m)
             + conj(s(m))
               by IH
  }

-- Conjugation carries the exponential series at z termwise to the
-- series at conjugate(z): the coefficient is an embedded real, which
-- conjugation fixes.
theorem ComplexNumber.conjugate_exponentialTerm (z : ℂ) (k : ℕ)
        : conj(ComplexNumber.exponentialTerm(z, k))
          = ComplexNumber.exponentialTerm(conj(z), k) := {
  let coefficient : ℝ := 1 / (k! : ℝ);
  conj(ComplexNumber.exponentialTerm(z, k))
     = conj(
           (coefficient : ℂ) * z ^ k)
     = conj((coefficient : ℂ))
       * conj(z ^ k)
     = (coefficient : ℂ)
       * conj(z ^ k)
           by ComplexNumber.conjugate_from_real
     = (coefficient : ℂ)
       * conj(z) ^ k
           by ComplexNumber.conjugate_power
}

-- ----------------------------------------------------------------------
-- Conjugation carries limits to limits (its coordinates are the
-- coordinates and their negation, and both pass to the limit).
theorem ComplexNumber.SequenceConverges.conjugate
        (s : ℕ → ℂ) (limit : ℂ)
        (converges : ComplexNumber.SequenceConverges(s, limit))
        : ComplexNumber.SequenceConverges(
              (n : ℕ) ↦ conj(s(n)),
              conj(limit)) := {
  Real.SequenceConverges(
          (n : ℕ) ↦ Re(s(n)),
          Re(limit))
      by ComplexNumber.SequenceConverges.realPart as realConverges;
  Real.SequenceConverges(
          (n : ℕ) ↦ Im(s(n)),
          Im(limit))
      by ComplexNumber.SequenceConverges.imaginaryPart as imaginaryConverges;
  Real.SequenceConverges(
          (n : ℕ) ↦ -Im(s(n)),
          -Im(limit))
      by Real.SequenceConverges.negate(
             (n : ℕ) ↦ Im(s(n)),
             Im(limit), imaginaryConverges)
      as negatedImaginaryConverges;
  ∀ (n : ℕ).
      Re(s(n))
        = Re(conj(s(n)))
      by (n : ℕ) ↦ {
           Re(conj(s(n)))
                 = Re(s(n));
           done
         } as realPointwise;
  ∀ (n : ℕ).
      -Im(s(n))
        = Im(conj(s(n)))
      by (n : ℕ) ↦ {
           Im(conj(s(n)))
                 = -Im(s(n));
           done
         } as imaginaryPointwise;
  Re(limit)
      = Re(conj(limit)) as limitRealPart;
  -Im(limit)
      = Im(conj(limit)) as limitImaginaryPart;
  Real.SequenceConverges(
          (n : ℕ) ↦ Re(conj(s(n))),
          Re(conj(limit)))
      by {
        Real.SequenceConverges(
                  (n : ℕ) ↦
                      Re(conj(s(n))),
                  Re(limit))
            by Real.SequenceConverges.of_pointwise(
                   (n : ℕ) ↦ Re(s(n)),
                   (n : ℕ) ↦
                       Re(conj(s(n))),
                   Re(limit),
                   realPointwise, realConverges);
        done by substituting limitRealPart
      };
  Real.SequenceConverges(
          (n : ℕ) ↦
              Im(conj(s(n))),
          Im(conj(limit)))
      by {
        Real.SequenceConverges(
                  (n : ℕ) ↦
                      Im(conj(s(n))),
                  -Im(limit))
            by Real.SequenceConverges.of_pointwise(
                   (n : ℕ) ↦ -Im(s(n)),
                   (n : ℕ) ↦
                       Im(conj(s(n))),
                   -Im(limit),
                   imaginaryPointwise, negatedImaginaryConverges);
        done by substituting limitImaginaryPart
      };
  done by ComplexNumber.SequenceConverges.of_coordinates
}

-- ----------------------------------------------------------------------
-- The exponential commutes with conjugation: conjugating the partial
-- sums of the series at z gives the partial sums of the series at
-- conjugate(z), and conjugation carries the limit exp(z) along.
theorem ComplexNumber.exponential_conjugate (z : ℂ)
        : ComplexNumber.exponential(conj(z))
          = conj(ComplexNumber.exponential(z)) := {
  ComplexNumber.SequenceConverges(
          (n : ℕ) ↦
              conj(
                  ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z), n)),
          conj(ComplexNumber.exponential(z)))
      by ComplexNumber.SequenceConverges.conjugate(
             ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z)),
             ComplexNumber.exponential(z),
             ComplexNumber.exponential_converges(z))
      as conjugatedSumsConverge;
  ∀ (n : ℕ).
      conj(
            ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z), n))
        = ComplexNumber.partialSum(
              ComplexNumber.exponentialTerm(conj(z)), n)
      by (n : ℕ) ↦
           conj(
                    ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z), n))
              = ComplexNumber.partialSum(
                    (k : ℕ) ↦
                        conj(ComplexNumber.exponentialTerm(z, k)),
                    n)
              = ComplexNumber.partialSum(
                    ComplexNumber.exponentialTerm(conj(z)), n)
                    by ComplexNumber.partialSum_pointwise(
                           (k : ℕ) ↦
                               conj(
                                   ComplexNumber.exponentialTerm(z, k)),
                           ComplexNumber.exponentialTerm(conj(z)),
                           (k : ℕ) ↦ {
                             conj(
                                       ComplexNumber.exponentialTerm(z, k))
                                   = ComplexNumber.exponentialTerm(
                                         conj(z), k);
                             done
                           },
                           n)
      as pointwiseConjugate;
  ComplexNumber.SequenceConverges(
          ComplexNumber.partialSum(
              ComplexNumber.exponentialTerm(conj(z))),
          conj(ComplexNumber.exponential(z)))
      by ComplexNumber.SequenceConverges.of_pointwise(
             (n : ℕ) ↦
                 conj(
                     ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z), n)),
             ComplexNumber.partialSum(
                 ComplexNumber.exponentialTerm(conj(z))),
             conj(ComplexNumber.exponential(z)),
             pointwiseConjugate, conjugatedSumsConverge);
  ComplexNumber.SequenceConverges(
          ComplexNumber.partialSum(
              ComplexNumber.exponentialTerm(conj(z))),
          ComplexNumber.exponential(conj(z)))
      by ComplexNumber.exponential_converges(conj(z));
  done by ComplexNumber.SequenceConverges.unique
}

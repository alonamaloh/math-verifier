-- ComplexNumber/conjugation.math
--
-- Complex conjugation: conjugate(z) is the complex number with
-- coordinates (re z, −im z). It is a ring homomorphism (it preserves
-- 0, 1, sums and products — every law a coordinate computation plus
-- real ring algebra), it fixes the embedded reals, and it commutes
-- with the exponential: exp(conjugate z) = conjugate(exp z), because
-- conjugation carries the series at z termwise to the series at
-- conjugate(z) and carries limits to limits.

module ComplexNumber.conjugation


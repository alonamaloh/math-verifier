-- ComplexNumber/modulus.math
--
-- The modulus (absolute value) of a complex number: |z| = √(re² + im²),
-- an honest Real-valued function — the coordinates come from the
-- coordinate bridge, the square root from definite description.

module ComplexNumber.modulus

import Logic.basics
import Logic.exists
import Logic.product
import Logic.quotient
import Logic.excluded_middle

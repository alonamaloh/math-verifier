-- ----------------------------------------------------------------------
-- The square sum re² + im² is nonnegative, so its square root is
-- honest.
theorem ComplexNumber.square_sum_nonneg (z : ComplexNumber)
        : Real.zero
          ≤ ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
            + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z) := {
  claim Real.IsNonneg(
            ComplexNumber.realPart(z) * ComplexNumber.realPart(z))
      by Real.square_IsNonneg;
  claim Real.IsNonneg(
            ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z))
      by Real.square_IsNonneg;
  claim Real.IsNonneg(
            ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
            + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z))
      by Real.IsNonneg.add;
  claim Real.zero
          ≤ ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
            + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z)
      by Real.LessOrEqual_zero_of_IsNonneg;
  done
}

-- ----------------------------------------------------------------------
-- |z| = √(re² + im²).
definition ComplexNumber.modulus (z : ComplexNumber) : Real :=
  Real.square_root(
      ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
      + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z),
      ComplexNumber.square_sum_nonneg(z))

-- |z| is the absolute value on ℂ; `abs` dispatches to it by carrier
-- (alongside the Real/Rational/Integer absolute values).
overload abs := ComplexNumber.modulus

theorem ComplexNumber.modulus_nonneg (z : ComplexNumber)
        : Real.zero ≤ ComplexNumber.modulus(z) :=
  Real.square_root_nonneg(
      ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
      + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z),
      ComplexNumber.square_sum_nonneg(z))

-- |z|² = re² + im², the characterising equation.
theorem ComplexNumber.modulus_squares (z : ComplexNumber)
        : ComplexNumber.modulus(z) * ComplexNumber.modulus(z)
          = ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
            + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z) :=
  Real.square_root_squares(
      ComplexNumber.realPart(z) * ComplexNumber.realPart(z)
      + ComplexNumber.imaginaryPart(z) * ComplexNumber.imaginaryPart(z),
      ComplexNumber.square_sum_nonneg(z))

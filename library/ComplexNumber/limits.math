-- ComplexNumber/limits.math
--
-- The algebra of limits on ℂ. The two coordinate projections carry a
-- convergent ℂ-sequence to convergent real sequences (each coordinate
-- of the difference is bounded by the modulus), and conversely
-- coordinate-wise convergence reassembles through the coordinate bound
-- |z| ≤ |re z| + |im z| with an ε/2 budget per coordinate. Sums are
-- handled directly with the triangle inequality; negation and products
-- ride the bridge: their coordinates are real combinations of the
-- coordinates, and the real algebra of limits does the work.

module ComplexNumber.limits

import Logic.basics
import Logic.exists
import Logic.product
import Logic.quotient
import Logic.excluded_middle
import axioms
import Equality.basics
import Natural.basics
import Natural.order
import Natural.maximum
import Integer.basics
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.halve
import Rational.positive
import Rational.linearity
import Rational.minimum
import Rational.reciprocal
import Rational.reciprocal_function
import Rational.archimedean
import Set.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Real.interface
import Polynomial.basics
import Polynomial.addition
import Polynomial.negation
import Polynomial.multiplication
import RingModulo.basics
import RingModulo.operations
import ComplexNumber.basics
import ComplexNumber.coordinates
import ComplexNumber.coordinate_homomorphism
import ComplexNumber.defining_polynomial_vanishes
import ComplexNumber.coordinate_map
import ComplexNumber.coordinate_multiplicative
import ComplexNumber.reconstruction
import ComplexNumber.of_coordinates
import ComplexNumber.coordinate_negate
import ComplexNumber.modulus
import ComplexNumber.modulus_multiplicative
import ComplexNumber.triangle_inequality
import ComplexNumber.modulus_bounds
import ComplexNumber.completeness

-- ----------------------------------------------------------------------
-- The bridge, outward: a convergent ℂ-sequence converges in each
-- coordinate (the coordinate of the difference is the difference of the
-- coordinates, and it is bounded by the modulus).

theorem ComplexNumber.SequenceConverges.realPart
        (s : Natural → ComplexNumber) (limit : ComplexNumber)
        (converges : ComplexNumber.SequenceConverges(s, limit))
        : Real.SequenceConverges(
              (n : Natural) ↦ ComplexNumber.realPart(s(n)),
              ComplexNumber.realPart(limit)) :=
  (ε : Real) (εPositive : ε > 0) ↦ {
    choose threshold as close from converges(ε, εPositive);
    witness threshold with
        (m : Natural) (aboveThreshold : threshold ≤ m) ↦ {
          ComplexNumber.realPart(s(m) - limit)
              = ComplexNumber.realPart(s(m)) - ComplexNumber.realPart(limit) as differencePart;
          abs(ComplexNumber.realPart(s(m)) - ComplexNumber.realPart(limit))
             = abs(ComplexNumber.realPart(s(m) - limit))
                   by differencePart
             ≤ abs(s(m) - limit)
                   by ComplexNumber.realPart_bound
             < ε
                   by close(m, aboveThreshold)
        }
  }

theorem ComplexNumber.SequenceConverges.imaginaryPart
        (s : Natural → ComplexNumber) (limit : ComplexNumber)
        (converges : ComplexNumber.SequenceConverges(s, limit))
        : Real.SequenceConverges(
              (n : Natural) ↦ ComplexNumber.imaginaryPart(s(n)),
              ComplexNumber.imaginaryPart(limit)) :=
  (ε : Real) (εPositive : ε > 0) ↦ {
    choose threshold as close from converges(ε, εPositive);
    witness threshold with
        (m : Natural) (aboveThreshold : threshold ≤ m) ↦ {
          ComplexNumber.imaginaryPart(s(m) - limit)
              = ComplexNumber.imaginaryPart(s(m)) - ComplexNumber.imaginaryPart(limit) as differencePart;
          abs(ComplexNumber.imaginaryPart(s(m)) - ComplexNumber.imaginaryPart(limit))
             = abs(ComplexNumber.imaginaryPart(s(m) - limit))
                   by differencePart
             ≤ abs(s(m) - limit)
                   by ComplexNumber.imaginaryPart_bound
             < ε
                   by close(m, aboveThreshold)
        }
  }

-- ----------------------------------------------------------------------
-- The bridge, inward: coordinate-wise convergence to the coordinates of
-- a limit reassembles, with an ε/2 budget per coordinate.

theorem ComplexNumber.SequenceConverges.of_coordinates
        (s : Natural → ComplexNumber) (limit : ComplexNumber)
        (realConverges
            : Real.SequenceConverges(
                  (n : Natural) ↦ ComplexNumber.realPart(s(n)),
                  ComplexNumber.realPart(limit)))
        (imaginaryConverges
            : Real.SequenceConverges(
                  (n : Natural) ↦ ComplexNumber.imaginaryPart(s(n)),
                  ComplexNumber.imaginaryPart(limit)))
        : ComplexNumber.SequenceConverges(s, limit) :=
  (ε : Real) (εPositive : ε > 0) ↦ {
    (2 : Real) > 0;
    (2 : Real) ≠ 0;
    ε / 2 > 0 as halfPositive;
    choose realThreshold as realClose
        from realConverges(ε / 2, halfPositive);
    choose imaginaryThreshold as imaginaryClose
        from imaginaryConverges(ε / 2, halfPositive);
    witness Natural.maximum(realThreshold, imaginaryThreshold) with
        (m : Natural)
        (aboveMaximum : Natural.maximum(realThreshold, imaginaryThreshold) ≤ m) ↦ {
          realThreshold ≤ m by Natural.le_through_max_left as realAbove;
          imaginaryThreshold ≤ m by Natural.le_through_max_right as imaginaryAbove;
          abs(ComplexNumber.realPart(s(m)) - ComplexNumber.realPart(limit))
                < ε / 2
              by realClose(m, realAbove);
          abs(ComplexNumber.imaginaryPart(s(m)) - ComplexNumber.imaginaryPart(limit))
                < ε / 2
              by imaginaryClose(m, imaginaryAbove);
          ComplexNumber.realPart(s(m) - limit)
              = ComplexNumber.realPart(s(m)) - ComplexNumber.realPart(limit) as realDifference;
          ComplexNumber.imaginaryPart(s(m) - limit)
              = ComplexNumber.imaginaryPart(s(m)) - ComplexNumber.imaginaryPart(limit) as imaginaryDifference;
          abs(s(m) - limit)
             ≤ abs(ComplexNumber.realPart(s(m) - limit))
               + abs(ComplexNumber.imaginaryPart(s(m) - limit))
                   by ComplexNumber.modulus_coordinate_bound
             = abs(ComplexNumber.realPart(s(m)) - ComplexNumber.realPart(limit))
               + abs(ComplexNumber.imaginaryPart(s(m) - limit))
                   by realDifference
             = abs(ComplexNumber.realPart(s(m)) - ComplexNumber.realPart(limit))
               + abs(ComplexNumber.imaginaryPart(s(m)) - ComplexNumber.imaginaryPart(limit))
                   by imaginaryDifference
             < ε / 2 + ε / 2
                   by Real.LessThan.add_strict_strict
             = ε
        }
  }

-- ----------------------------------------------------------------------
-- Convergence only reads the terms.
theorem ComplexNumber.SequenceConverges.of_pointwise
        (s t : Natural → ComplexNumber) (limit : ComplexNumber)
        (pointwiseEqual : ∀ (n : Natural). s(n) = t(n))
        (sConverges : ComplexNumber.SequenceConverges(s, limit))
        : ComplexNumber.SequenceConverges(t, limit) :=
  (ε : Real) (εPositive : ε > 0) ↦ {
    choose threshold as close from sConverges(ε, εPositive);
    witness threshold with
        (m : Natural) (aboveThreshold : threshold ≤ m) ↦
          abs(t(m) - limit)
             = abs(s(m) - limit)    by pointwiseEqual(m)
             < ε              by close(m, aboveThreshold)
  }

-- ----------------------------------------------------------------------
-- Sum of limits: each summand within ε/2 puts the sum within ε.
theorem ComplexNumber.SequenceConverges.add
        (s t : Natural → ComplexNumber) (sLimit tLimit : ComplexNumber)
        (sConverges : ComplexNumber.SequenceConverges(s, sLimit))
        (tConverges : ComplexNumber.SequenceConverges(t, tLimit))
        : ComplexNumber.SequenceConverges(
              (n : Natural) ↦ s(n) + t(n), sLimit + tLimit) :=
  (ε : Real) (εPositive : ε > 0) ↦ {
    (2 : Real) > 0;
    (2 : Real) ≠ 0;
    ε / 2 > 0 as halfPositive;
    choose sThreshold as sClose
        from sConverges(ε / 2, halfPositive);
    choose tThreshold as tClose
        from tConverges(ε / 2, halfPositive);
    witness Natural.maximum(sThreshold, tThreshold) with
        (m : Natural)
        (aboveMaximum : Natural.maximum(sThreshold, tThreshold) ≤ m) ↦ {
          sThreshold ≤ m by Natural.le_through_max_left as sAbove;
          tThreshold ≤ m by Natural.le_through_max_right as tAbove;
          abs(s(m) - sLimit) < ε / 2
              by sClose(m, sAbove);
          abs(t(m) - tLimit) < ε / 2
              by tClose(m, tAbove);
          abs((s(m) + t(m)) - (sLimit + tLimit))
             = abs((s(m) - sLimit) + (t(m) - tLimit))
                   by substituting
                       (ring : (s(m) + t(m)) - (sLimit + tLimit)
                           = (s(m) - sLimit) + (t(m) - tLimit))
             ≤ abs(s(m) - sLimit)
               + abs(t(m) - tLimit)
                   by ComplexNumber.modulus_triangle
             < ε / 2 + ε / 2
                   by Real.LessThan.add_strict_strict
             = ε
        }
  }

-- ----------------------------------------------------------------------
-- Negating a sequence negates its limit: the coordinates negate, and
-- the real algebra carries them.
theorem ComplexNumber.SequenceConverges.negate
        (s : Natural → ComplexNumber) (sLimit : ComplexNumber)
        (sConverges : ComplexNumber.SequenceConverges(s, sLimit))
        : ComplexNumber.SequenceConverges((n : Natural) ↦ -s(n), -sLimit) := {
  Real.SequenceConverges(
      (n : Natural) ↦ ComplexNumber.realPart(s(n)),
      ComplexNumber.realPart(sLimit))
      by ComplexNumber.SequenceConverges.realPart;
  Real.SequenceConverges(
      (n : Natural) ↦ ComplexNumber.imaginaryPart(s(n)),
      ComplexNumber.imaginaryPart(sLimit))
      by ComplexNumber.SequenceConverges.imaginaryPart;
  Real.SequenceConverges(
      (n : Natural) ↦ -ComplexNumber.realPart(s(n)),
      -ComplexNumber.realPart(sLimit))
      by Real.SequenceConverges.negate(s := (n : Natural) ↦ ComplexNumber.realPart(s(n)));
  Real.SequenceConverges(
      (n : Natural) ↦ -ComplexNumber.imaginaryPart(s(n)),
      -ComplexNumber.imaginaryPart(sLimit))
      by Real.SequenceConverges.negate(s := (n : Natural) ↦ ComplexNumber.imaginaryPart(s(n)));
  ∀ (n : Natural).
      -ComplexNumber.realPart(s(n)) = ComplexNumber.realPart(-s(n))
      by (n : Natural) ↦ {
           ComplexNumber.realPart(-s(n)) = -ComplexNumber.realPart(s(n));
           done
         } as realPointwise;
  ∀ (n : Natural).
      -ComplexNumber.imaginaryPart(s(n)) = ComplexNumber.imaginaryPart(-s(n))
      by (n : Natural) ↦ {
           ComplexNumber.imaginaryPart(-s(n)) = -ComplexNumber.imaginaryPart(s(n));
           done
         } as imaginaryPointwise;
  -ComplexNumber.realPart(sLimit) = ComplexNumber.realPart(-sLimit) as limitRealPart;
  -ComplexNumber.imaginaryPart(sLimit) = ComplexNumber.imaginaryPart(-sLimit) as limitImaginaryPart;
  Real.SequenceConverges(
      (n : Natural) ↦ ComplexNumber.realPart(-s(n)),
      ComplexNumber.realPart(-sLimit))
      by {
        Real.SequenceConverges(
            (n : Natural) ↦ ComplexNumber.realPart(-s(n)),
            -ComplexNumber.realPart(sLimit))
            by Real.SequenceConverges.of_pointwise(pointwiseEqual := realPointwise);
        done by substituting limitRealPart
      };
  Real.SequenceConverges(
      (n : Natural) ↦ ComplexNumber.imaginaryPart(-s(n)),
      ComplexNumber.imaginaryPart(-sLimit))
      by {
        Real.SequenceConverges(
            (n : Natural) ↦ ComplexNumber.imaginaryPart(-s(n)),
            -ComplexNumber.imaginaryPart(sLimit))
            by Real.SequenceConverges.of_pointwise(pointwiseEqual := imaginaryPointwise);
        done by substituting limitImaginaryPart
      };
  done by ComplexNumber.SequenceConverges.of_coordinates
}

-- ----------------------------------------------------------------------
-- Product of limits, through the coordinates: the coordinates of a
-- product are the real combinations re·re′ − im·im′ and re·im′ + im·re′
-- of the coordinates, and each combination converges by the real
-- algebra of limits.
theorem ComplexNumber.SequenceConverges.multiply
        (s t : Natural → ComplexNumber) (sLimit tLimit : ComplexNumber)
        (sConverges : ComplexNumber.SequenceConverges(s, sLimit))
        (tConverges : ComplexNumber.SequenceConverges(t, tLimit))
        : ComplexNumber.SequenceConverges(
              (n : Natural) ↦ s(n) * t(n), sLimit * tLimit) := {
  -- The four coordinate sequences converge.
  Real.SequenceConverges(
      (n : Natural) ↦ ComplexNumber.realPart(s(n)),
      ComplexNumber.realPart(sLimit))
      by ComplexNumber.SequenceConverges.realPart;
  Real.SequenceConverges(
      (n : Natural) ↦ ComplexNumber.imaginaryPart(s(n)),
      ComplexNumber.imaginaryPart(sLimit))
      by ComplexNumber.SequenceConverges.imaginaryPart;
  Real.SequenceConverges(
      (n : Natural) ↦ ComplexNumber.realPart(t(n)),
      ComplexNumber.realPart(tLimit))
      by ComplexNumber.SequenceConverges.realPart;
  Real.SequenceConverges(
      (n : Natural) ↦ ComplexNumber.imaginaryPart(t(n)),
      ComplexNumber.imaginaryPart(tLimit))
      by ComplexNumber.SequenceConverges.imaginaryPart;
  -- The real coordinate of the product: re·re′ − im·im′.
  Real.SequenceConverges(
      (n : Natural) ↦ ComplexNumber.realPart(s(n)) * ComplexNumber.realPart(t(n)),
      ComplexNumber.realPart(sLimit) * ComplexNumber.realPart(tLimit))
      by Real.SequenceConverges.multiply(
             s := (n : Natural) ↦ ComplexNumber.realPart(s(n)),
             t := (n : Natural) ↦ ComplexNumber.realPart(t(n)));
  Real.SequenceConverges(
      (n : Natural) ↦
          ComplexNumber.imaginaryPart(s(n)) * ComplexNumber.imaginaryPart(t(n)),
      ComplexNumber.imaginaryPart(sLimit) * ComplexNumber.imaginaryPart(tLimit))
      by Real.SequenceConverges.multiply(
             s := (n : Natural) ↦ ComplexNumber.imaginaryPart(s(n)),
             t := (n : Natural) ↦ ComplexNumber.imaginaryPart(t(n)));
  Real.SequenceConverges(
      (n : Natural) ↦
          -(ComplexNumber.imaginaryPart(s(n)) * ComplexNumber.imaginaryPart(t(n))),
      -(ComplexNumber.imaginaryPart(sLimit) * ComplexNumber.imaginaryPart(tLimit)))
      by Real.SequenceConverges.negate(
             s := (n : Natural) ↦
                 ComplexNumber.imaginaryPart(s(n)) * ComplexNumber.imaginaryPart(t(n)));
  Real.SequenceConverges(
      (n : Natural) ↦
          ComplexNumber.realPart(s(n)) * ComplexNumber.realPart(t(n))
          + -(ComplexNumber.imaginaryPart(s(n)) * ComplexNumber.imaginaryPart(t(n))),
      ComplexNumber.realPart(sLimit) * ComplexNumber.realPart(tLimit)
      + -(ComplexNumber.imaginaryPart(sLimit) * ComplexNumber.imaginaryPart(tLimit)))
      by Real.SequenceConverges.add(
             s := (n : Natural) ↦ ComplexNumber.realPart(s(n)) * ComplexNumber.realPart(t(n)),
             t := (n : Natural) ↦
                 -(ComplexNumber.imaginaryPart(s(n)) * ComplexNumber.imaginaryPart(t(n))));
  ∀ (n : Natural).
      ComplexNumber.realPart(s(n)) * ComplexNumber.realPart(t(n))
            + -(ComplexNumber.imaginaryPart(s(n)) * ComplexNumber.imaginaryPart(t(n)))
        = ComplexNumber.realPart(s(n) * t(n))
      by (n : Natural) ↦ {
           ComplexNumber.realPart(s(n) * t(n))
                 = ComplexNumber.realPart(s(n)) * ComplexNumber.realPart(t(n))
                   - ComplexNumber.imaginaryPart(s(n)) * ComplexNumber.imaginaryPart(t(n));
           done
         } as realPointwise;
  ComplexNumber.realPart(sLimit) * ComplexNumber.realPart(tLimit)
        + -(ComplexNumber.imaginaryPart(sLimit) * ComplexNumber.imaginaryPart(tLimit))
    = ComplexNumber.realPart(sLimit * tLimit)
      by {
        ComplexNumber.realPart(sLimit * tLimit)
              = ComplexNumber.realPart(sLimit) * ComplexNumber.realPart(tLimit)
                - ComplexNumber.imaginaryPart(sLimit) * ComplexNumber.imaginaryPart(tLimit);
        done
      } as limitRealPart;
  Real.SequenceConverges(
      (n : Natural) ↦ ComplexNumber.realPart(s(n) * t(n)),
      ComplexNumber.realPart(sLimit * tLimit))
      by {
        Real.SequenceConverges(
            (n : Natural) ↦ ComplexNumber.realPart(s(n) * t(n)),
            ComplexNumber.realPart(sLimit) * ComplexNumber.realPart(tLimit)
            + -(ComplexNumber.imaginaryPart(sLimit)
                    * ComplexNumber.imaginaryPart(tLimit)))
            by Real.SequenceConverges.of_pointwise(pointwiseEqual := realPointwise);
        done by substituting limitRealPart
      };
  -- The imaginary coordinate of the product: re·im′ + im·re′.
  Real.SequenceConverges(
      (n : Natural) ↦
          ComplexNumber.realPart(s(n)) * ComplexNumber.imaginaryPart(t(n)),
      ComplexNumber.realPart(sLimit) * ComplexNumber.imaginaryPart(tLimit))
      by Real.SequenceConverges.multiply(
             s := (n : Natural) ↦ ComplexNumber.realPart(s(n)),
             t := (n : Natural) ↦ ComplexNumber.imaginaryPart(t(n)));
  Real.SequenceConverges(
      (n : Natural) ↦
          ComplexNumber.imaginaryPart(s(n)) * ComplexNumber.realPart(t(n)),
      ComplexNumber.imaginaryPart(sLimit) * ComplexNumber.realPart(tLimit))
      by Real.SequenceConverges.multiply(
             s := (n : Natural) ↦ ComplexNumber.imaginaryPart(s(n)),
             t := (n : Natural) ↦ ComplexNumber.realPart(t(n)));
  Real.SequenceConverges(
      (n : Natural) ↦
          ComplexNumber.realPart(s(n)) * ComplexNumber.imaginaryPart(t(n))
          + ComplexNumber.imaginaryPart(s(n)) * ComplexNumber.realPart(t(n)),
      ComplexNumber.realPart(sLimit) * ComplexNumber.imaginaryPart(tLimit)
      + ComplexNumber.imaginaryPart(sLimit) * ComplexNumber.realPart(tLimit))
      by Real.SequenceConverges.add(
             s := (n : Natural) ↦
                 ComplexNumber.realPart(s(n)) * ComplexNumber.imaginaryPart(t(n)),
             t := (n : Natural) ↦
                 ComplexNumber.imaginaryPart(s(n)) * ComplexNumber.realPart(t(n)));
  ∀ (n : Natural).
      ComplexNumber.realPart(s(n)) * ComplexNumber.imaginaryPart(t(n))
            + ComplexNumber.imaginaryPart(s(n)) * ComplexNumber.realPart(t(n))
        = ComplexNumber.imaginaryPart(s(n) * t(n))
      by (n : Natural) ↦ {
           ComplexNumber.imaginaryPart(s(n) * t(n))
                 = ComplexNumber.realPart(s(n)) * ComplexNumber.imaginaryPart(t(n))
                   + ComplexNumber.imaginaryPart(s(n)) * ComplexNumber.realPart(t(n));
           done
         } as imaginaryPointwise;
  ComplexNumber.realPart(sLimit) * ComplexNumber.imaginaryPart(tLimit)
        + ComplexNumber.imaginaryPart(sLimit) * ComplexNumber.realPart(tLimit)
    = ComplexNumber.imaginaryPart(sLimit * tLimit) as limitImaginaryPart;
  Real.SequenceConverges(
      (n : Natural) ↦ ComplexNumber.imaginaryPart(s(n) * t(n)),
      ComplexNumber.imaginaryPart(sLimit * tLimit))
      by {
        Real.SequenceConverges(
            (n : Natural) ↦ ComplexNumber.imaginaryPart(s(n) * t(n)),
            ComplexNumber.realPart(sLimit) * ComplexNumber.imaginaryPart(tLimit)
            + ComplexNumber.imaginaryPart(sLimit) * ComplexNumber.realPart(tLimit))
            by Real.SequenceConverges.of_pointwise(pointwiseEqual := imaginaryPointwise);
        done by substituting limitImaginaryPart
      };
  done by ComplexNumber.SequenceConverges.of_coordinates
}

-- ----------------------------------------------------------------------
-- The squeeze at zero: a ℂ-sequence dominated in modulus by a real
-- sequence that vanishes also vanishes.
theorem ComplexNumber.SequenceConverges.squeeze_zero
        (v : Natural → ComplexNumber) (u : Natural → Real)
        (dominated : ∀ (n : Natural). abs(v(n)) ≤ u(n))
        (uVanishes : Real.SequenceConverges(u, Real.zero))
        : ComplexNumber.SequenceConverges(
              v,
              RingModulo.zero(Real.polynomial_commutative_ring,
                  Complex.definingPolynomial)) :=
  (ε : Real) (εPositive : ε > 0) ↦ {
    let zero : ComplexNumber :=
        RingModulo.zero(Real.polynomial_commutative_ring,
            Complex.definingPolynomial);
    choose threshold as close from uVanishes(ε, εPositive);
    witness threshold with
        (m : Natural) (aboveThreshold : threshold ≤ m) ↦ {
          u(m) ≤ abs(u(m)) by Real.LessOrEqual_absolute_value;
          abs(v(m) - zero)
             = abs(v(m))
                   by substituting (ring : v(m) - zero = v(m))
             ≤ u(m)
                   by dominated(m)
             ≤ abs(u(m))
             = abs(u(m) - Real.zero)
                   by substituting (ring : u(m) - Real.zero = u(m))
             < ε
                   by close(m, aboveThreshold)
        }
  }

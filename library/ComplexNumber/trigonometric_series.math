-- ----------------------------------------------------------------------
-- A real scalar (embedded) pulls out of the coordinates of a product.

theorem ComplexNumber.realPart_from_real_multiply (r : Real) (w : ComplexNumber)
        : ComplexNumber.realPart(ComplexNumber.from_real(r) * w)
          = r * ComplexNumber.realPart(w) :=
  calc ComplexNumber.realPart(ComplexNumber.from_real(r) * w)
     = ComplexNumber.realPart(ComplexNumber.from_real(r)) * ComplexNumber.realPart(w)
       - ComplexNumber.imaginaryPart(ComplexNumber.from_real(r))
             * ComplexNumber.imaginaryPart(w)
           by ComplexNumber.realPart_multiply(ComplexNumber.from_real(r), w)
     = r * ComplexNumber.realPart(w)
       - ComplexNumber.imaginaryPart(ComplexNumber.from_real(r))
             * ComplexNumber.imaginaryPart(w)
           by ComplexNumber.realPart_from_real(r)
     = r * ComplexNumber.realPart(w) - Real.zero * ComplexNumber.imaginaryPart(w)
           by ComplexNumber.imaginaryPart_from_real(r)
     = r * ComplexNumber.realPart(w)
           by ring

theorem ComplexNumber.imaginaryPart_from_real_multiply (r : Real) (w : ComplexNumber)
        : ComplexNumber.imaginaryPart(ComplexNumber.from_real(r) * w)
          = r * ComplexNumber.imaginaryPart(w) :=
  calc ComplexNumber.imaginaryPart(ComplexNumber.from_real(r) * w)
     = ComplexNumber.realPart(ComplexNumber.from_real(r)) * ComplexNumber.imaginaryPart(w)
       + ComplexNumber.imaginaryPart(ComplexNumber.from_real(r))
             * ComplexNumber.realPart(w)
           by ComplexNumber.imaginaryPart_multiply(ComplexNumber.from_real(r), w)
     = r * ComplexNumber.imaginaryPart(w)
       + ComplexNumber.imaginaryPart(ComplexNumber.from_real(r))
             * ComplexNumber.realPart(w)
           by ComplexNumber.realPart_from_real(r)
     = r * ComplexNumber.imaginaryPart(w) + Real.zero * ComplexNumber.realPart(w)
           by ComplexNumber.imaginaryPart_from_real(r)
     = r * ComplexNumber.imaginaryPart(w)
           by ring

-- ----------------------------------------------------------------------
-- The k-th term of the cosine/sine series: Re/Im of the k-th term of
-- exp(ix), with the real coefficient 1/k! pulled out.

-- The coefficient that the term carries (1/k!, embedded into ℝ).
definition Real.exponentialCoefficient (k : Natural) : Real :=
  (Rational.reciprocal_function((Natural.factorial(k) : Rational)) : Real)

theorem ComplexNumber.realPart_exponentialTerm_imaginaryAxis (x : Real) (k : Natural)
        : ComplexNumber.realPart(
              ComplexNumber.exponentialTerm(
                  ComplexNumber.i * ComplexNumber.from_real(x), k))
          = Real.exponentialCoefficient(k)
            * ComplexNumber.realPart(
                  ComplexNumber.power(ComplexNumber.i * ComplexNumber.from_real(x), k)) :=
  ComplexNumber.realPart_from_real_multiply(
      Real.exponentialCoefficient(k),
      ComplexNumber.power(ComplexNumber.i * ComplexNumber.from_real(x), k))

theorem ComplexNumber.imaginaryPart_exponentialTerm_imaginaryAxis (x : Real) (k : Natural)
        : ComplexNumber.imaginaryPart(
              ComplexNumber.exponentialTerm(
                  ComplexNumber.i * ComplexNumber.from_real(x), k))
          = Real.exponentialCoefficient(k)
            * ComplexNumber.imaginaryPart(
                  ComplexNumber.power(ComplexNumber.i * ComplexNumber.from_real(x), k)) :=
  ComplexNumber.imaginaryPart_from_real_multiply(
      Real.exponentialCoefficient(k),
      ComplexNumber.power(ComplexNumber.i * ComplexNumber.from_real(x), k))

-- ----------------------------------------------------------------------
-- The even/odd evaluations, from the i-power 4-cycle.

-- Re(term_{2m}) = (1/(2m)!)·(−x²)^m.
theorem Real.cosine_term_even (x : Real) (m : Natural)
        : ComplexNumber.realPart(
              ComplexNumber.exponentialTerm(
                  ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))
          = Real.exponentialCoefficient(2 * m) * Real.power(-(x * x), m) := {
  obtain ⟨evenReal, _⟩
      from ComplexNumber.imaginaryAxis_power_coordinates(x, m);
  calc ComplexNumber.realPart(
           ComplexNumber.exponentialTerm(
               ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))
     = Real.exponentialCoefficient(2 * m)
       * ComplexNumber.realPart(
             ComplexNumber.power(ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))
           by ComplexNumber.realPart_exponentialTerm_imaginaryAxis(x, 2 * m)
     = Real.exponentialCoefficient(2 * m) * Real.power(-(x * x), m)
           since evenReal
}

-- Re(term_{2m+1}) = 0.
theorem Real.cosine_term_odd (x : Real) (m : Natural)
        : ComplexNumber.realPart(
              ComplexNumber.exponentialTerm(
                  ComplexNumber.i * ComplexNumber.from_real(x), (2 * m + 1)))
          = Real.zero := {
  obtain ⟨_, rest⟩ from ComplexNumber.imaginaryAxis_power_coordinates(x, m);
  obtain ⟨_, rest2⟩ from rest;
  obtain ⟨oddReal, _⟩ from rest2;
  calc ComplexNumber.realPart(
           ComplexNumber.exponentialTerm(
               ComplexNumber.i * ComplexNumber.from_real(x), (2 * m + 1)))
     = Real.exponentialCoefficient((2 * m + 1))
       * ComplexNumber.realPart(
             ComplexNumber.power(
                 ComplexNumber.i * ComplexNumber.from_real(x), (2 * m + 1)))
           by ComplexNumber.realPart_exponentialTerm_imaginaryAxis(x, (2 * m + 1))
     = Real.exponentialCoefficient((2 * m + 1)) * Real.zero
           since oddReal
     = Real.zero
           by ring
}

-- Im(term_{2m}) = 0.
theorem Real.sine_term_even (x : Real) (m : Natural)
        : ComplexNumber.imaginaryPart(
              ComplexNumber.exponentialTerm(
                  ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))
          = Real.zero := {
  obtain ⟨_, rest⟩ from ComplexNumber.imaginaryAxis_power_coordinates(x, m);
  obtain ⟨evenImaginary, _⟩ from rest;
  calc ComplexNumber.imaginaryPart(
           ComplexNumber.exponentialTerm(
               ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))
     = Real.exponentialCoefficient(2 * m)
       * ComplexNumber.imaginaryPart(
             ComplexNumber.power(ComplexNumber.i * ComplexNumber.from_real(x), 2 * m))
           by ComplexNumber.imaginaryPart_exponentialTerm_imaginaryAxis(x, 2 * m)
     = Real.exponentialCoefficient(2 * m) * Real.zero
           since evenImaginary
     = Real.zero
           by ring
}

-- Im(term_{2m+1}) = (1/(2m+1)!)·x·(−x²)^m.
theorem Real.sine_term_odd (x : Real) (m : Natural)
        : ComplexNumber.imaginaryPart(
              ComplexNumber.exponentialTerm(
                  ComplexNumber.i * ComplexNumber.from_real(x), (2 * m + 1)))
          = Real.exponentialCoefficient((2 * m + 1)) * (x * Real.power(-(x * x), m)) := {
  obtain ⟨_, rest⟩ from ComplexNumber.imaginaryAxis_power_coordinates(x, m);
  obtain ⟨_, rest2⟩ from rest;
  obtain ⟨_, oddImaginary⟩ from rest2;
  calc ComplexNumber.imaginaryPart(
           ComplexNumber.exponentialTerm(
               ComplexNumber.i * ComplexNumber.from_real(x), (2 * m + 1)))
     = Real.exponentialCoefficient((2 * m + 1))
       * ComplexNumber.imaginaryPart(
             ComplexNumber.power(
                 ComplexNumber.i * ComplexNumber.from_real(x), (2 * m + 1)))
           by ComplexNumber.imaginaryPart_exponentialTerm_imaginaryAxis(
                  x, (2 * m + 1))
     = Real.exponentialCoefficient((2 * m + 1)) * (x * Real.power(-(x * x), m))
           since oddImaginary
}

-- ----------------------------------------------------------------------
-- cos and sin as the limits of their real series. Re/Im commute with
-- the convergent partial sums of exp(ix): the real partial sums of
-- Re(term) converge to Re(exp(ix)) = cos x.

theorem Real.cosine_series_converges (x : Real)
        : Real.SequenceConverges(
              Real.partialSum(
                  (k : Natural) ↦
                      ComplexNumber.realPart(
                          ComplexNumber.exponentialTerm(
                              ComplexNumber.i * ComplexNumber.from_real(x), k))),
              cos(x)) := {
  claim complexConverges
      : ComplexNumber.SequenceConverges(
            ComplexNumber.partialSum(
                ComplexNumber.exponentialTerm(
                    ComplexNumber.i * ComplexNumber.from_real(x))),
            ComplexNumber.exponential(ComplexNumber.i * ComplexNumber.from_real(x)))
      by ComplexNumber.exponential_converges(
             ComplexNumber.i * ComplexNumber.from_real(x));
  claim realPartConverges
      : Real.SequenceConverges(
            (n : Natural) ↦
                ComplexNumber.realPart(
                    ComplexNumber.partialSum(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x)),
                        n)),
            ComplexNumber.realPart(
                ComplexNumber.exponential(
                    ComplexNumber.i * ComplexNumber.from_real(x))))
      by ComplexNumber.SequenceConverges.realPart(
             ComplexNumber.partialSum(
                 ComplexNumber.exponentialTerm(
                     ComplexNumber.i * ComplexNumber.from_real(x))),
             ComplexNumber.exponential(ComplexNumber.i * ComplexNumber.from_real(x)),
             complexConverges);
  claim pointwise
      : ∀ (n : Natural).
        ComplexNumber.realPart(
              ComplexNumber.partialSum(
                  ComplexNumber.exponentialTerm(
                      ComplexNumber.i * ComplexNumber.from_real(x)),
                  n))
          = Real.partialSum(
                (k : Natural) ↦
                    ComplexNumber.realPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x), k)),
                n)
      by (n : Natural) ↦
           ComplexNumber.realPart_partialSum(
               ComplexNumber.exponentialTerm(
                   ComplexNumber.i * ComplexNumber.from_real(x)),
               n);
  -- cos x is exactly Re(exp(ix)) by definition.
  claim Real.SequenceConverges(
            Real.partialSum(
                (k : Natural) ↦
                    ComplexNumber.realPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x), k))),
            ComplexNumber.realPart(
                ComplexNumber.exponential(
                    ComplexNumber.i * ComplexNumber.from_real(x))))
      by Real.SequenceConverges.of_pointwise(
             (n : Natural) ↦
                 ComplexNumber.realPart(
                     ComplexNumber.partialSum(
                         ComplexNumber.exponentialTerm(
                             ComplexNumber.i * ComplexNumber.from_real(x)),
                         n)),
             Real.partialSum(
                 (k : Natural) ↦
                     ComplexNumber.realPart(
                         ComplexNumber.exponentialTerm(
                             ComplexNumber.i * ComplexNumber.from_real(x), k))),
             ComplexNumber.realPart(
                 ComplexNumber.exponential(
                     ComplexNumber.i * ComplexNumber.from_real(x))),
             pointwise, realPartConverges);
  done
}

theorem Real.sine_series_converges (x : Real)
        : Real.SequenceConverges(
              Real.partialSum(
                  (k : Natural) ↦
                      ComplexNumber.imaginaryPart(
                          ComplexNumber.exponentialTerm(
                              ComplexNumber.i * ComplexNumber.from_real(x), k))),
              sin(x)) := {
  claim complexConverges
      : ComplexNumber.SequenceConverges(
            ComplexNumber.partialSum(
                ComplexNumber.exponentialTerm(
                    ComplexNumber.i * ComplexNumber.from_real(x))),
            ComplexNumber.exponential(ComplexNumber.i * ComplexNumber.from_real(x)))
      by ComplexNumber.exponential_converges(
             ComplexNumber.i * ComplexNumber.from_real(x));
  claim imaginaryPartConverges
      : Real.SequenceConverges(
            (n : Natural) ↦
                ComplexNumber.imaginaryPart(
                    ComplexNumber.partialSum(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x)),
                        n)),
            ComplexNumber.imaginaryPart(
                ComplexNumber.exponential(
                    ComplexNumber.i * ComplexNumber.from_real(x))))
      by ComplexNumber.SequenceConverges.imaginaryPart(
             ComplexNumber.partialSum(
                 ComplexNumber.exponentialTerm(
                     ComplexNumber.i * ComplexNumber.from_real(x))),
             ComplexNumber.exponential(ComplexNumber.i * ComplexNumber.from_real(x)),
             complexConverges);
  claim pointwise
      : ∀ (n : Natural).
        ComplexNumber.imaginaryPart(
              ComplexNumber.partialSum(
                  ComplexNumber.exponentialTerm(
                      ComplexNumber.i * ComplexNumber.from_real(x)),
                  n))
          = Real.partialSum(
                (k : Natural) ↦
                    ComplexNumber.imaginaryPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x), k)),
                n)
      by (n : Natural) ↦
           ComplexNumber.imaginaryPart_partialSum(
               ComplexNumber.exponentialTerm(
                   ComplexNumber.i * ComplexNumber.from_real(x)),
               n);
  claim Real.SequenceConverges(
            Real.partialSum(
                (k : Natural) ↦
                    ComplexNumber.imaginaryPart(
                        ComplexNumber.exponentialTerm(
                            ComplexNumber.i * ComplexNumber.from_real(x), k))),
            ComplexNumber.imaginaryPart(
                ComplexNumber.exponential(
                    ComplexNumber.i * ComplexNumber.from_real(x))))
      by Real.SequenceConverges.of_pointwise(
             (n : Natural) ↦
                 ComplexNumber.imaginaryPart(
                     ComplexNumber.partialSum(
                         ComplexNumber.exponentialTerm(
                             ComplexNumber.i * ComplexNumber.from_real(x)),
                         n)),
             Real.partialSum(
                 (k : Natural) ↦
                     ComplexNumber.imaginaryPart(
                         ComplexNumber.exponentialTerm(
                             ComplexNumber.i * ComplexNumber.from_real(x), k))),
             ComplexNumber.imaginaryPart(
                 ComplexNumber.exponential(
                     ComplexNumber.i * ComplexNumber.from_real(x))),
             pointwise, imaginaryPartConverges);
  done
}

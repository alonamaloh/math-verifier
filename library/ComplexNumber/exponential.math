-- ComplexNumber/exponential.math
--
-- The complex exponential: exp(z) = Σ zᵏ/k!, as the limit of the
-- partial sums. The series is dominated in modulus by the REAL
-- exponential series at |z|, so its partial sums are Cauchy, and ℂ is
-- complete; the limit function comes from definite description through
-- uniqueness of limits.

module ComplexNumber.exponential

import Logic.basics
import Logic.exists
import Logic.product
import Logic.quotient
import Logic.excluded_middle
import axioms
import Equality.basics

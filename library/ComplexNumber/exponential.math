-- ----------------------------------------------------------------------
-- Coordinates of the embedding and of zero (all definitional through
-- the coordinate recursion, up to a trailing −0).

automatic theorem ComplexNumber.realPart_from_real (r : ℝ)
        : ComplexNumber.realPart(ComplexNumber.from_real(r)) = r :=
  ComplexNumber.realPart(ComplexNumber.from_real(r))
     = r - Real.zero
     = r

automatic theorem ComplexNumber.imaginaryPart_from_real (r : ℝ)
        : ComplexNumber.imaginaryPart(ComplexNumber.from_real(r)) = Real.zero := {
  done
}

theorem ComplexNumber.realPart_zero
        : ComplexNumber.realPart(
              RingModulo.zero(Real.polynomial_commutative_ring,
                  Complex.definingPolynomial))
          = Real.zero := {
  done
}

theorem ComplexNumber.imaginaryPart_zero
        : ComplexNumber.imaginaryPart(
              RingModulo.zero(Real.polynomial_commutative_ring,
                  Complex.definingPolynomial))
          = Real.zero := {
  done
}

-- ----------------------------------------------------------------------
-- Moduli computed through the coordinates: equal coordinates give equal
-- moduli, and the embedding carries |·| to the real absolute value.

theorem ComplexNumber.modulus_zero
        : ComplexNumber.modulus(
              RingModulo.zero(Real.polynomial_commutative_ring,
                  Complex.definingPolynomial))
          = Real.zero := {
  ComplexNumber.realPart(
            RingModulo.zero(Real.polynomial_commutative_ring,
                Complex.definingPolynomial))
        = Real.zero;
  ComplexNumber.modulus(RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial))
      * ComplexNumber.modulus(RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial))
    = ComplexNumber.realPart(RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial))
          * ComplexNumber.realPart(RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial))
      + ComplexNumber.imaginaryPart(RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial))
            * ComplexNumber.imaginaryPart(RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial))
    = Real.zero * Real.zero + Real.zero * Real.zero
    = Real.zero;
  Real.zero
        ≤ ComplexNumber.modulus(
              RingModulo.zero(Real.polynomial_commutative_ring,
                  Complex.definingPolynomial));
  Real.zero ≤ Real.zero;
  Real.zero * Real.zero = Real.zero;
  done by Real.square_root_unique
}

theorem ComplexNumber.modulus_from_real (r : ℝ)
        : ComplexNumber.modulus(ComplexNumber.from_real(r)) = abs(r) := {
  ComplexNumber.realPart(ComplexNumber.from_real(r)) = r as realCoordinate;
  ComplexNumber.modulus(ComplexNumber.from_real(r)) * ComplexNumber.modulus(ComplexNumber.from_real(r))
    = ComplexNumber.realPart(ComplexNumber.from_real(r)) * ComplexNumber.realPart(ComplexNumber.from_real(r))
      + ComplexNumber.imaginaryPart(ComplexNumber.from_real(r)) * ComplexNumber.imaginaryPart(ComplexNumber.from_real(r))
    = r * r + Real.zero * Real.zero
          by realCoordinate
    = r * r;
  abs(r) * abs(r) = r * r;
  Real.zero ≤ ComplexNumber.modulus(ComplexNumber.from_real(r));
  Real.zero ≤ abs(r);
  done by Real.square_root_unique
}

-- Swapping the operands of a difference does not change the modulus
-- (the coordinate squares agree).
theorem ComplexNumber.modulus_subtract_swap (z w : ℂ)
        : ComplexNumber.modulus(z - w) = ComplexNumber.modulus(w - z) := {
  ComplexNumber.realPart(z - w)
        = ComplexNumber.realPart(z) - ComplexNumber.realPart(w) as zwReal;
  ComplexNumber.imaginaryPart(z - w)
        = ComplexNumber.imaginaryPart(z) - ComplexNumber.imaginaryPart(w) as zwImaginary;
  ComplexNumber.realPart(w - z)
        = ComplexNumber.realPart(w) - ComplexNumber.realPart(z) as wzReal;
  ComplexNumber.imaginaryPart(w - z)
        = ComplexNumber.imaginaryPart(w) - ComplexNumber.imaginaryPart(z) as wzImaginary;
  ComplexNumber.modulus(z - w) * ComplexNumber.modulus(z - w)
    = ComplexNumber.realPart(z - w) * ComplexNumber.realPart(z - w)
      + ComplexNumber.imaginaryPart(z - w) * ComplexNumber.imaginaryPart(z - w)
          by ComplexNumber.modulus_squares
    = (ComplexNumber.realPart(z) - ComplexNumber.realPart(w))
          * (ComplexNumber.realPart(z) - ComplexNumber.realPart(w))
      + ComplexNumber.imaginaryPart(z - w) * ComplexNumber.imaginaryPart(z - w)
          by zwReal
    = (ComplexNumber.realPart(z) - ComplexNumber.realPart(w))
          * (ComplexNumber.realPart(z) - ComplexNumber.realPart(w))
      + (ComplexNumber.imaginaryPart(z) - ComplexNumber.imaginaryPart(w))
            * (ComplexNumber.imaginaryPart(z) - ComplexNumber.imaginaryPart(w))
          by zwImaginary
    = (ComplexNumber.realPart(w) - ComplexNumber.realPart(z))
          * (ComplexNumber.realPart(w) - ComplexNumber.realPart(z))
      + (ComplexNumber.imaginaryPart(w) - ComplexNumber.imaginaryPart(z))
            * (ComplexNumber.imaginaryPart(w) - ComplexNumber.imaginaryPart(z))
          by ring
    = ComplexNumber.realPart(w - z) * ComplexNumber.realPart(w - z)
      + (ComplexNumber.imaginaryPart(w) - ComplexNumber.imaginaryPart(z))
            * (ComplexNumber.imaginaryPart(w) - ComplexNumber.imaginaryPart(z))
          by wzReal
    = ComplexNumber.realPart(w - z) * ComplexNumber.realPart(w - z)
      + ComplexNumber.imaginaryPart(w - z) * ComplexNumber.imaginaryPart(w - z)
          by wzImaginary;
  ComplexNumber.modulus(w - z) * ComplexNumber.modulus(w - z)
        = ComplexNumber.realPart(w - z) * ComplexNumber.realPart(w - z)
          + ComplexNumber.imaginaryPart(w - z) * ComplexNumber.imaginaryPart(w - z)
      by ComplexNumber.modulus_squares;
  Real.zero ≤ ComplexNumber.modulus(z - w) by ComplexNumber.modulus_nonneg;
  Real.zero ≤ ComplexNumber.modulus(w - z) by ComplexNumber.modulus_nonneg;
  done by Real.square_root_unique
}

-- ----------------------------------------------------------------------
-- Partial sums in ℂ, and their coordinates.

definition ComplexNumber.partialSum (s : ℕ → ℂ)
        : ℕ → ℂ
  | 0 =>
      RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial)
  | 1 + n => RingModulo.add(ComplexNumber.partialSum(s, n), s(n))

-- The recursion characterised in `1 + n` form, so consumers step the
-- index without naming the raw constructor.
theorem ComplexNumber.partialSum_add_one (s : ℕ → ℂ) (n : ℕ)
        : ComplexNumber.partialSum(s, 1 + n) = ComplexNumber.partialSum(s, n) + s(n) :=
  done by substituting Natural.one_add

theorem ComplexNumber.realPart_partialSum (s : ℕ → ℂ)
        (n : ℕ)
        : ComplexNumber.realPart(ComplexNumber.partialSum(s, n))
          = Real.partialSum(
                (k : ℕ) ↦ ComplexNumber.realPart(s(k)), n) :=
  by induction on n with IH {
    case base: done
    case step(n):
        ComplexNumber.realPart(ComplexNumber.partialSum(s, 1 + n))
           = ComplexNumber.realPart(ComplexNumber.partialSum(s, n) + s(n))
                 by ComplexNumber.partialSum_add_one
           = ComplexNumber.realPart(ComplexNumber.partialSum(s, n))
             + ComplexNumber.realPart(s(n))
           = Real.partialSum((k : ℕ) ↦ ComplexNumber.realPart(s(k)), n)
             + ComplexNumber.realPart(s(n))
                 by IH
           = Real.partialSum((k : ℕ) ↦ ComplexNumber.realPart(s(k)), 1 + n)
                 by Real.partialSum_add_one
  }

theorem ComplexNumber.imaginaryPart_partialSum (s : ℕ → ℂ)
        (n : ℕ)
        : ComplexNumber.imaginaryPart(ComplexNumber.partialSum(s, n))
          = Real.partialSum(
                (k : ℕ) ↦ ComplexNumber.imaginaryPart(s(k)), n) :=
  by induction on n with IH {
    case base: done
    case step(n):
        ComplexNumber.imaginaryPart(ComplexNumber.partialSum(s, 1 + n))
           = ComplexNumber.imaginaryPart(ComplexNumber.partialSum(s, n) + s(n))
                 by ComplexNumber.partialSum_add_one
           = ComplexNumber.imaginaryPart(ComplexNumber.partialSum(s, n))
             + ComplexNumber.imaginaryPart(s(n))
           = Real.partialSum((k : ℕ) ↦ ComplexNumber.imaginaryPart(s(k)), n)
             + ComplexNumber.imaginaryPart(s(n))
                 by IH
           = Real.partialSum((k : ℕ) ↦ ComplexNumber.imaginaryPart(s(k)), 1 + n)
                 by Real.partialSum_add_one
  }

-- Splitting a ℂ partial sum at a cut, through the coordinates.
theorem ComplexNumber.partialSum_split (s : ℕ → ℂ)
        (n c : ℕ)
        : ComplexNumber.partialSum(s, c + n)
          = ComplexNumber.partialSum(s, n)
            + ComplexNumber.partialSum((j : ℕ) ↦ s(n + j), c) := {
  ComplexNumber.realPart(ComplexNumber.partialSum(s, c + n))
    = Real.partialSum((k : ℕ) ↦ ComplexNumber.realPart(s(k)), c + n)
    = Real.partialSum((k : ℕ) ↦ ComplexNumber.realPart(s(k)), n)
      + Real.partialSum((j : ℕ) ↦ ComplexNumber.realPart(s(n + j)), c)
          by Real.partialSum_split
    = ComplexNumber.realPart(ComplexNumber.partialSum(s, n))
      + Real.partialSum((j : ℕ) ↦ ComplexNumber.realPart(s(n + j)), c)
          by ComplexNumber.realPart_partialSum
    = ComplexNumber.realPart(ComplexNumber.partialSum(s, n))
      + ComplexNumber.realPart(ComplexNumber.partialSum((j : ℕ) ↦ s(n + j), c))
          by ComplexNumber.realPart_partialSum
    = ComplexNumber.realPart(
          ComplexNumber.partialSum(s, n)
          + ComplexNumber.partialSum((j : ℕ) ↦ s(n + j), c));
  ComplexNumber.imaginaryPart(ComplexNumber.partialSum(s, c + n))
    = Real.partialSum((k : ℕ) ↦ ComplexNumber.imaginaryPart(s(k)), c + n)
    = Real.partialSum((k : ℕ) ↦ ComplexNumber.imaginaryPart(s(k)), n)
      + Real.partialSum((j : ℕ) ↦ ComplexNumber.imaginaryPart(s(n + j)), c)
          by Real.partialSum_split
    = ComplexNumber.imaginaryPart(ComplexNumber.partialSum(s, n))
      + Real.partialSum((j : ℕ) ↦ ComplexNumber.imaginaryPart(s(n + j)), c)
          by ComplexNumber.imaginaryPart_partialSum
    = ComplexNumber.imaginaryPart(ComplexNumber.partialSum(s, n))
      + ComplexNumber.imaginaryPart(ComplexNumber.partialSum((j : ℕ) ↦ s(n + j), c))
          by ComplexNumber.imaginaryPart_partialSum
    = ComplexNumber.imaginaryPart(
          ComplexNumber.partialSum(s, n)
          + ComplexNumber.partialSum((j : ℕ) ↦ s(n + j), c));
  done by ComplexNumber.eq_of_coordinates
}

-- Adding then subtracting cancels.
theorem ComplexNumber.add_cancel_left (u v : ℂ)
        : (u + v) - u = v := ring

-- The modulus of a partial sum is at most the real partial sum of the
-- moduli (the triangle inequality, summed).
theorem ComplexNumber.modulus_partialSum_le (s : ℕ → ℂ)
        (n : ℕ)
        : ComplexNumber.modulus(ComplexNumber.partialSum(s, n))
          ≤ Real.partialSum((k : ℕ) ↦ ComplexNumber.modulus(s(k)), n) :=
  by induction on n with IH {
    case base: {
        ComplexNumber.modulus(ComplexNumber.partialSum(s, 0)) = Real.zero
            by ComplexNumber.modulus_zero;
        Real.zero ≤ Real.zero;
        done
      }
    case step(n): {
        ComplexNumber.modulus(ComplexNumber.partialSum(s, n))
              ≤ Real.partialSum((k : ℕ) ↦ ComplexNumber.modulus(s(k)), n)
            by IH;
        ComplexNumber.modulus(ComplexNumber.partialSum(s, 1 + n))
           = ComplexNumber.modulus(ComplexNumber.partialSum(s, n) + s(n))
               by ComplexNumber.partialSum_add_one
           ≤ ComplexNumber.modulus(ComplexNumber.partialSum(s, n))
             + ComplexNumber.modulus(s(n))
               by ComplexNumber.modulus_triangle
           ≤ Real.partialSum((k : ℕ) ↦ ComplexNumber.modulus(s(k)), n)
             + ComplexNumber.modulus(s(n))
               by Real.add_preserves_LessOrEqual
           = Real.partialSum((k : ℕ) ↦ ComplexNumber.modulus(s(k)), 1 + n)
               by Real.partialSum_add_one
      }
  }

-- ----------------------------------------------------------------------
-- A series dominated in modulus by a real series with Cauchy partial
-- sums has Cauchy partial sums (any window is squeezed below the
-- matching real window).
theorem ComplexNumber.series_dominated_cauchy
        (t : ℕ → ℂ) (b : ℕ → ℝ)
        (domination : ∀ (k : ℕ). ComplexNumber.modulus(t(k)) ≤ b(k))
        (boundCauchy : Real.SequenceIsCauchy(Real.partialSum(b)))
        : ComplexNumber.SequenceIsCauchy(ComplexNumber.partialSum(t)) :=
  (ε : ℝ)
  (εPositive : ε > 0) ↦ {
    choose N as tailClose from boundCauchy(ε, εPositive);
    ∀ (i j : ℕ). N ≤ i → N ≤ j → i ≤ j
            → ComplexNumber.modulus(
                  ComplexNumber.partialSum(t, j) - ComplexNumber.partialSum(t, i))
              < ε
        by {
          take i : ℕ; take j : ℕ;
          take iInTail : N ≤ i; take jInTail : N ≤ j;
          take iLeqJ : i ≤ j;
          choose c from Natural.subtraction_witness(i, j, iLeqJ);
          j = i + c
            = c + i as jAsSum;
          ComplexNumber.partialSum(t, j)
            = ComplexNumber.partialSum(t, c + i)    by jAsSum
            = ComplexNumber.partialSum(t, i) + ComplexNumber.partialSum((k : ℕ) ↦ t(i + k), c)
                  by ComplexNumber.partialSum_split as splitT;
          Real.partialSum(b, j)
            = Real.partialSum(b, c + i)    by jAsSum
            = Real.partialSum(b, i) + Real.partialSum((k : ℕ) ↦ b(i + k), c)
                  by Real.partialSum_split as splitB;
          ComplexNumber.partialSum(t, j) - ComplexNumber.partialSum(t, i)
            = (ComplexNumber.partialSum(t, i) + ComplexNumber.partialSum((k : ℕ) ↦ t(i + k), c))
              - ComplexNumber.partialSum(t, i)
                  by splitT
            = ComplexNumber.partialSum((k : ℕ) ↦ t(i + k), c) as tWindowValue;
          Real.partialSum((k : ℕ) ↦ b(i + k), c)
            = (Real.partialSum(b, i) + Real.partialSum((k : ℕ) ↦ b(i + k), c)) - Real.partialSum(b, i)
                  by ring
            = Real.partialSum(b, j) - Real.partialSum(b, i)
                  by splitB as bWindowValue;
          ComplexNumber.modulus(ComplexNumber.partialSum((k : ℕ) ↦ t(i + k), c))
            ≤ Real.partialSum((k : ℕ) ↦ ComplexNumber.modulus(t(i + k)), c)
                  by ComplexNumber.modulus_partialSum_le
            ≤ Real.partialSum((k : ℕ) ↦ b(i + k), c)
                  by Real.partialSum_le_pointwise(
                         (k : ℕ) ↦ ComplexNumber.modulus(t(i + k)),
                         (k : ℕ) ↦ b(i + k), c,
                         (k : ℕ) (_ : k < c) ↦
                           domination(i + k)) as tWindowBound;
          Real.partialSum(b, j) - Real.partialSum(b, i)
            ≤ abs(Real.partialSum(b, j) - Real.partialSum(b, i))
                  by Real.LessOrEqual_absolute_value
            < ε
                  by tailClose(j, i, jInTail, iInTail) as bWindowBelow;
          ComplexNumber.modulus(
                   ComplexNumber.partialSum(t, j) - ComplexNumber.partialSum(t, i))
             = ComplexNumber.modulus(
                   ComplexNumber.partialSum((k : ℕ) ↦ t(i + k), c))
                   by tWindowValue
             ≤ Real.partialSum((k : ℕ) ↦ b(i + k), c)
                   by tWindowBound
             = Real.partialSum(b, j) - Real.partialSum(b, i)
                   by bWindowValue
             < ε
                   by bWindowBelow
        } as oneSided;
    witness N with
        (m n : ℕ) (mInTail : N ≤ m) (nInTail : N ≤ n) ↦ {
          m ≤ n ∨ n ≤ m by Natural.totality_of_less_or_equal;
          done by cases {
            case m ≤ n as mLeqN: {
                ComplexNumber.modulus(
                            ComplexNumber.partialSum(t, n)
                            - ComplexNumber.partialSum(t, m))
                        < ε
                    by oneSided;
                ComplexNumber.modulus(
                            ComplexNumber.partialSum(t, m)
                            - ComplexNumber.partialSum(t, n))
                        = ComplexNumber.modulus(
                              ComplexNumber.partialSum(t, n)
                              - ComplexNumber.partialSum(t, m))
                    by ComplexNumber.modulus_subtract_swap as swapped;
                ComplexNumber.modulus(
                         ComplexNumber.partialSum(t, m) - ComplexNumber.partialSum(t, n))
                   = ComplexNumber.modulus(
                         ComplexNumber.partialSum(t, n) - ComplexNumber.partialSum(t, m))
                         by swapped
                   < ε
              }
            case n ≤ m as nLeqM: {
                done by oneSided
              }
          }
        }
  }

-- ----------------------------------------------------------------------
-- Uniqueness of limits in ℂ, and the limit function.

-- Two complex numbers whose difference vanishes are equal.
theorem ComplexNumber.eq_of_subtract_zero (z w : ℂ)
        (differenceZero
            : z - w = RingModulo.zero(Real.polynomial_commutative_ring,
                          Complex.definingPolynomial))
        : z = w :=
  z
     = (z - w) + w
           by ring
     = RingModulo.zero(Real.polynomial_commutative_ring,
           Complex.definingPolynomial) + w
           by differenceZero
     = w

-- A complex number with arbitrarily small modulus is zero.
theorem ComplexNumber.eq_zero_of_modulus_less_than_all_positive
        (u : ℂ)
        (hypothesis : ∀ (ε : ℝ). ε > 0 →
                          ComplexNumber.modulus(u) < ε)
        : u = RingModulo.zero(Real.polynomial_commutative_ring,
                  Complex.definingPolynomial) := {
  ∀ (ε : ℝ). ε > 0
        → abs(ComplexNumber.realPart(u)) < ε
      by (ε : ℝ) (εPositive : ε > 0) ↦ {
           abs(ComplexNumber.realPart(u)) ≤ ComplexNumber.modulus(u)
               by ComplexNumber.realPart_bound;
           ComplexNumber.modulus(u) < ε
               by hypothesis;
           done by Real.LessThan.transitive_left
         };
  ∀ (ε : ℝ). ε > 0
        → abs(ComplexNumber.imaginaryPart(u)) < ε
      by (ε : ℝ) (εPositive : ε > 0) ↦ {
           abs(ComplexNumber.imaginaryPart(u)) ≤ ComplexNumber.modulus(u)
               by ComplexNumber.imaginaryPart_bound;
           ComplexNumber.modulus(u) < ε
               by hypothesis;
           done by Real.LessThan.transitive_left
         };
  ComplexNumber.realPart(u) = Real.zero
      by Real.eq_of_absolute_value_less_than_all_positive_real;
  ComplexNumber.imaginaryPart(u) = Real.zero
      by Real.eq_of_absolute_value_less_than_all_positive_real;
  ComplexNumber.realPart(
            RingModulo.zero(Real.polynomial_commutative_ring,
                Complex.definingPolynomial))
        = Real.zero;
  ComplexNumber.imaginaryPart(
            RingModulo.zero(Real.polynomial_commutative_ring,
                Complex.definingPolynomial))
        = Real.zero;
  done by ComplexNumber.eq_of_coordinates
}

theorem ComplexNumber.SequenceConverges.unique
        (s : ℕ → ℂ)
        (limit1 limit2 : ℂ)
        (converges1 : ComplexNumber.SequenceConverges(s, limit1))
        (converges2 : ComplexNumber.SequenceConverges(s, limit2))
        : limit1 = limit2 := {
  ∀ (ε : ℝ). ε > 0
        → ComplexNumber.modulus(limit1 - limit2) < ε
      by (ε : ℝ) (εPositive : ε > 0) ↦ {
           (2 : ℝ) > 0;
           (2 : ℝ) ≠ 0;
           ε / 2 > 0 as halfPositive;
           choose threshold1 as close1 from converges1(ε / 2, halfPositive);
           choose threshold2 as close2 from converges2(ε / 2, halfPositive);
           threshold1 ≤ Natural.maximum(threshold1, threshold2);
           threshold2 ≤ Natural.maximum(threshold1, threshold2);
           ComplexNumber.modulus(
                     s(Natural.maximum(threshold1, threshold2)) - limit1)
                 < ε / 2
               by close1;
           ComplexNumber.modulus(
                     s(Natural.maximum(threshold1, threshold2)) - limit2)
                 < ε / 2
               by close2;
           limit1 - limit2
                 = (limit1 - s(Natural.maximum(threshold1, threshold2)))
                   + (s(Natural.maximum(threshold1, threshold2)) - limit2)
               by ring as differenceSplits;
           ComplexNumber.modulus(
                     limit1 - s(Natural.maximum(threshold1, threshold2)))
                 = ComplexNumber.modulus(
                       s(Natural.maximum(threshold1, threshold2)) - limit1)
               by ComplexNumber.modulus_subtract_swap as swapFirst;
           ComplexNumber.modulus(limit1 - limit2)
              = ComplexNumber.modulus(
                    (limit1 - s(Natural.maximum(threshold1, threshold2)))
                    + (s(Natural.maximum(threshold1, threshold2)) - limit2))
                    by differenceSplits
              ≤ ComplexNumber.modulus(
                    limit1 - s(Natural.maximum(threshold1, threshold2)))
                + ComplexNumber.modulus(
                      s(Natural.maximum(threshold1, threshold2)) - limit2)
                    by ComplexNumber.modulus_triangle
              = ComplexNumber.modulus(
                    s(Natural.maximum(threshold1, threshold2)) - limit1)
                + ComplexNumber.modulus(
                      s(Natural.maximum(threshold1, threshold2)) - limit2)
                    by swapFirst
              < ε / 2 + ε / 2
                    by Real.LessThan.add_strict_strict
              = ε
         };
  limit1 - limit2
        = RingModulo.zero(Real.polynomial_commutative_ring,
              Complex.definingPolynomial)
      by ComplexNumber.eq_zero_of_modulus_less_than_all_positive;
  done
}

-- THE limit of a convergent ℂ-sequence, by definite description.
definition ComplexNumber.limit (s : ℕ → ℂ)
        (convergent : ComplexNumber.SequenceConvergent(s)) : ℂ :=
  Logic.the(
      ℂ,
      (candidate : ℂ) ↦ ComplexNumber.SequenceConverges(s, candidate),
      convergent,
      (a b : ℂ)
      (aIsLimit : ComplexNumber.SequenceConverges(s, a))
      (bIsLimit : ComplexNumber.SequenceConverges(s, b)) ↦
        ComplexNumber.SequenceConverges.unique(s, a, b, aIsLimit, bIsLimit))

theorem ComplexNumber.limit_converges (s : ℕ → ℂ)
        (convergent : ComplexNumber.SequenceConvergent(s))
        : ComplexNumber.SequenceConverges(s, ComplexNumber.limit(s, convergent)) :=
  Logic.the_satisfies(
      ℂ,
      (candidate : ℂ) ↦ ComplexNumber.SequenceConverges(s, candidate),
      convergent,
      (a b : ℂ)
      (aIsLimit : ComplexNumber.SequenceConverges(s, a))
      (bIsLimit : ComplexNumber.SequenceConverges(s, b)) ↦
        ComplexNumber.SequenceConverges.unique(s, a, b, aIsLimit, bIsLimit))

-- ----------------------------------------------------------------------
-- Powers and the exponential series in ℂ.

definition ComplexNumber.power (base : ℂ) : ℕ → ℂ
  | 0 =>
      RingModulo.one(Real.polynomial_commutative_ring, Complex.definingPolynomial)
  | 1 + n => RingModulo.multiply(base, ComplexNumber.power(base, n))

operator (^) on (ComplexNumber, Natural) := ComplexNumber.power

theorem ComplexNumber.modulus_one
        : ComplexNumber.modulus((1 : ℂ)) = 1 := {
  Real.zero ≤ Real.one;
  Real.IsNonneg(Real.one);
  ComplexNumber.modulus((1 : ℂ))
     = abs(Real.one)
     = Real.one
}

-- |zⁿ| = |z|ⁿ.
theorem ComplexNumber.modulus_power (z : ℂ) (n : ℕ)
        : ComplexNumber.modulus(z ^ n)
          = ComplexNumber.modulus(z) ^ n :=
  by induction on n with IH {
    case base: {
        ComplexNumber.modulus(z ^ 0) = Real.one
            by ComplexNumber.modulus_one;
        done
      }
    case step(n):
        ComplexNumber.modulus(z ^ (1 + n))
           = ComplexNumber.modulus(z * z ^ n)
           = ComplexNumber.modulus(z)
             * ComplexNumber.modulus(z ^ n)
           = ComplexNumber.modulus(z) * ComplexNumber.modulus(z) ^ n
                 by IH
           = ComplexNumber.modulus(z) ^ (1 + n)
  }

-- The k-th term of the exponential series at z: (1/k!) · zᵏ, with the
-- real coefficient embedded.
definition ComplexNumber.exponentialTerm (z : ℂ) (k : ℕ)
        : ℂ :=
  (1 / (k! : ℝ) : ℂ) * z ^ k

-- Its modulus is exactly the real exponential term at |z|.
theorem ComplexNumber.modulus_exponentialTerm (z : ℂ) (k : ℕ)
        : ComplexNumber.modulus(ComplexNumber.exponentialTerm(z, k))
          = Real.exponentialTerm(ComplexNumber.modulus(z), k) := {
  (k! : ℝ) > 0;
  (k! : ℝ) ≠ 0;
  1 / (k! : ℝ) ≥ 0;
  Real.IsNonneg(1 / (k! : ℝ));
  ComplexNumber.modulus((1 / (k! : ℝ) : ℂ) * z ^ k)
     = ComplexNumber.modulus((1 / (k! : ℝ) : ℂ)) * ComplexNumber.modulus(z ^ k)
     = abs(1 / (k! : ℝ)) * ComplexNumber.modulus(z ^ k)
           by ComplexNumber.modulus_from_real
     = (1 / (k! : ℝ)) * ComplexNumber.modulus(z ^ k)
           by Real.absolute_value_when_nonneg
     = (1 / (k! : ℝ)) * ComplexNumber.modulus(z) ^ k
           by ComplexNumber.modulus_power
}

-- ----------------------------------------------------------------------
-- Convergence: the series at z is dominated in modulus by the real
-- exponential series at |z|, which converges; ℂ is complete.
theorem ComplexNumber.exponential_series_convergent (z : ℂ)
        : ComplexNumber.SequenceConvergent(
              ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z))) := {
  Real.SequenceConvergent(
            Real.partialSum(Real.exponentialTerm(ComplexNumber.modulus(z))))
      by Real.exponential_series_convergent;
  Real.SequenceIsCauchy(
            Real.partialSum(Real.exponentialTerm(ComplexNumber.modulus(z))))
      by Real.converges_implies_cauchy as realSeriesCauchy;
  ∀ (k : ℕ).
        ComplexNumber.modulus(ComplexNumber.exponentialTerm(z, k))
          ≤ Real.exponentialTerm(ComplexNumber.modulus(z), k)
      by (k : ℕ) ↦ {
           ComplexNumber.modulus(ComplexNumber.exponentialTerm(z, k))
                 = Real.exponentialTerm(ComplexNumber.modulus(z), k) as sameValue;
           ComplexNumber.modulus(ComplexNumber.exponentialTerm(z, k))
                 ≤ ComplexNumber.modulus(ComplexNumber.exponentialTerm(z, k));
           done by substituting sameValue
         };
  ComplexNumber.SequenceIsCauchy(
            ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z)))
      by ComplexNumber.series_dominated_cauchy(boundCauchy := realSeriesCauchy);
  done by ComplexNumber.cauchy_sequence_converges
}

-- ----------------------------------------------------------------------
-- The complex exponential, and its defining convergence.
definition ComplexNumber.exponential (z : ℂ) : ℂ :=
  ComplexNumber.limit(
      ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z)),
      ComplexNumber.exponential_series_convergent(z))

overload exp := ComplexNumber.exponential

theorem ComplexNumber.exponential_converges (z : ℂ)
        : ComplexNumber.SequenceConverges(
              ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z)),
              ComplexNumber.exponential(z)) :=
  ComplexNumber.limit_converges(
      ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z)),
      ComplexNumber.exponential_series_convergent(z))

-- ----------------------------------------------------------------------
-- exp(0) = 1, mirroring the Real proof: from index 1 on, every partial
-- sum is exactly 1 — the head term is 1/0! · 0⁰ = 1 and every later
-- term carries a factor 0^(k+1) = 0. (The prover settles both term
-- computations from the definitions; the induction carries the tail.)
theorem ComplexNumber.exponential_zero
        : exp((0 : ℂ)) = (1 : ℂ) := {
  let z : ℂ := (0 : ℂ);
  z = RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial)
      by ComplexNumber.from_real.zero_preserves as zIsRepZero;
  -- From index 1 on every term vanishes: the (k+1)-th carries a factor z = 0.
  ∀ (k : ℕ). ComplexNumber.exponentialTerm(z, k + 1) = z
      by {
        take k : ℕ;
        z ^ (k + 1)
           = z * z ^ k
           = z                by substituting zIsRepZero
           as powerVanishes;
        ComplexNumber.exponentialTerm(z, k + 1)
           = (1 / ((k + 1)! : ℝ) : ℂ) * z ^ (k + 1)
           = (1 / ((k + 1)! : ℝ) : ℂ) * z    by powerVanishes
           = z                                   by substituting zIsRepZero
      } as termSuccessor;
  -- The head term is 1/0! · z⁰ = 1, so every partial sum from index 1 on is 1.
  ∀ (p : ℕ). ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z), p + 1) = (1 : ℂ)
      by by induction on p with IH {
           case base: {
               ComplexNumber.exponentialTerm(z, 0) = (1 : ℂ)
                   by {
                     (0! : ℝ) = 1 as factorialZero;
                     1 / (0! : ℝ)
                         = 1 / (1 : ℝ)   by substituting factorialZero
                         = 1                by field
                         as reciprocalOne;
                     ComplexNumber.exponentialTerm(z, 0)
                        = (1 / (0! : ℝ) : ℂ) * z ^ 0
                        = (1 : ℂ) * (1 : ℂ)   by substituting reciprocalOne
                        = (1 : ℂ)
                   } as firstTermIsOne;
               ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z), 1)
                  = z + ComplexNumber.exponentialTerm(z, 0)
                        by substituting zIsRepZero
                  = z + (1 : ℂ)          by substituting firstTermIsOne
                  = (1 : ℂ)              by substituting zIsRepZero
             }
           case step(q):
               ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z), (1 + q) + 1)
                  = ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z), 1 + (q + 1))
                        by ((1 + q) + 1 = 1 + (q + 1))
                  = ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z), q + 1)
                    + ComplexNumber.exponentialTerm(z, q + 1)
                        by ComplexNumber.partialSum_add_one
                  = (1 : ℂ) + ComplexNumber.exponentialTerm(z, q + 1)   by IH
                  = (1 : ℂ) + z                                          by termSuccessor(q)
                  = (1 : ℂ)                                              by substituting zIsRepZero
         } as tailConstant;
  ComplexNumber.SequenceConverges(
              ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z)), (1 : ℂ))
      by {
        take ε : ℝ;
        take εPositive : ε > 0;
        witness 1 with
            (m : ℕ) (oneBelow : 1 ≤ m) ↦ {
              choose c from Natural.subtraction_witness(1, m, oneBelow);
              ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z), m)
                = ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z), c + 1)
                      by (m = c + 1)
                = (1 : ℂ)                by tailConstant(c);
              ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z), m) - (1 : ℂ)
                = (1 : ℂ) - (1 : ℂ)
                = z                      by substituting zIsRepZero;
              ComplexNumber.modulus(
                       ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z), m) - (1 : ℂ))
                 = ComplexNumber.modulus(z)
                 = abs((0 : ℝ))       by ComplexNumber.modulus_from_real
                 = Real.zero
                 < ε
            }
      };
  done by ComplexNumber.SequenceConverges.unique(
              converges1 := ComplexNumber.exponential_converges(z))
}

-- ----------------------------------------------------------------------
-- The definitions: the two coordinates of exp(i·x). (cos/sin/exp/Re/Im
-- are the standard mathematical names, registered as overloads of the
-- fully-spelled definitions.)

definition Real.cosine (x : Real) : Real :=
  Re(exp(ComplexNumber.i * ComplexNumber.from_real(x)))

definition Real.sine (x : Real) : Real :=
  Im(exp(ComplexNumber.i * ComplexNumber.from_real(x)))

overload cos := Real.cosine
overload sin := Real.sine

-- ----------------------------------------------------------------------
-- Euler's formula: exp(i·x) = cos(x) + i·sin(x). With cosine and sine
-- DEFINED as the coordinates of exp(i·x), this is the coordinate
-- reconstruction z = Re(z) + i·Im(z), nothing more.
theorem ComplexNumber.euler_formula (x : Real)
        : exp(ComplexNumber.i * ComplexNumber.from_real(x))
          = ComplexNumber.from_real(cos(x))
            + ComplexNumber.i * ComplexNumber.from_real(sin(x)) := {
  done by ComplexNumber.reconstruct
}

-- ----------------------------------------------------------------------
-- The values at 0, through exp(0) = 1: i·0 = 0, so cos(0) + i·sin(0)
-- = exp(0) = 1, whose coordinates are (1, 0).

theorem ComplexNumber.i_times_from_real_zero
        : ComplexNumber.i * ComplexNumber.from_real(Real.zero)
          = RingModulo.zero(Real.polynomial_commutative_ring,
                Complex.definingPolynomial) :=
  calc ComplexNumber.i * ComplexNumber.from_real(Real.zero)
     = ComplexNumber.i
       * RingModulo.zero(Real.polynomial_commutative_ring,
             Complex.definingPolynomial)
           by substituting ComplexNumber.from_real_zero
     = RingModulo.zero(Real.polynomial_commutative_ring,
           Complex.definingPolynomial)

theorem Real.cosine_zero : cos(Real.zero) = Real.one :=
  calc cos(Real.zero)
     = Re(exp(RingModulo.zero(Real.polynomial_commutative_ring,
                  Complex.definingPolynomial)))
           by ComplexNumber.i_times_from_real_zero
     = Re(RingModulo.one(Real.polynomial_commutative_ring,
              Complex.definingPolynomial))
           by ComplexNumber.exponential_zero
     = Re(ComplexNumber.from_real(Real.one))
     = Real.one

theorem Real.sine_zero : sin(Real.zero) = Real.zero :=
  calc sin(Real.zero)
     = Im(exp(RingModulo.zero(Real.polynomial_commutative_ring,
                  Complex.definingPolynomial)))
           by ComplexNumber.i_times_from_real_zero
     = Im(RingModulo.one(Real.polynomial_commutative_ring,
              Complex.definingPolynomial))
           by ComplexNumber.exponential_zero
     = Im(ComplexNumber.from_real(Real.one))
     = Real.zero

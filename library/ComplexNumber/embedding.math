-- ComplexNumber/embedding.math
--
-- The imaginary unit i (the class of x), its defining relation i² = −1,
-- and the embedding ℝ ↪ ℂ sending a real number to the class of the
-- constant polynomial. The embedding preserves 0, 1, +, ·; injectivity
-- (a genuine embedding) is in ComplexNumber/field.math, where the degree
-- machinery is available.

module ComplexNumber.embedding

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.monus
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.group
import Algebra.group_lemmas
import Real.interface
import Polynomial.basics
import Polynomial.addition
import Polynomial.multiplication
import Polynomial.multiply_laws
import Polynomial.instances
import Polynomial.degree
import Polynomial.multiply_coefficient
import Polynomial.monomial
import Polynomial.units
import RingModulo.basics
import RingModulo.operations
import RingModulo.ring
import RingModulo.instances
import ComplexNumber.basics

-- ----------------------------------------------------------------------
-- The imaginary unit and i² = −1.

definition ComplexNumber.i : ℂ :=
  RingModulo.make(Real.polynomial_commutative_ring, Complex.definingPolynomial, Complex.x)

-- i² + 1 = 0: the left side is the class of x²+1 = the modulus, which is
-- zero in the quotient. (Holds by the modulus's definition reducing
-- through the lifts; the proof is just `modulus_is_zero`.)
theorem ComplexNumber.i_squared_plus_one
        : ComplexNumber.i * ComplexNumber.i
              + RingModulo.one(Real.polynomial_commutative_ring, Complex.definingPolynomial)
          = RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial) :=
  RingModulo.modulus_is_zero(Real.polynomial_commutative_ring, Complex.definingPolynomial)

-- i² = −1. Subtract 1 from i² + 1 = 0; `ring` does the regrouping.
theorem ComplexNumber.i_squared
        : ComplexNumber.i * ComplexNumber.i
          = - RingModulo.one(Real.polynomial_commutative_ring, Complex.definingPolynomial) :=
  ComplexNumber.i * ComplexNumber.i
     = (ComplexNumber.i * ComplexNumber.i
            + RingModulo.one(Real.polynomial_commutative_ring, Complex.definingPolynomial))
       - RingModulo.one(Real.polynomial_commutative_ring, Complex.definingPolynomial)
           by ring
     = RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial)
       - RingModulo.one(Real.polynomial_commutative_ring, Complex.definingPolynomial)
           by ComplexNumber.i_squared_plus_one
     = - RingModulo.one(Real.polynomial_commutative_ring, Complex.definingPolynomial)

-- ----------------------------------------------------------------------
-- Constant-polynomial lemmas (the algebra behind the embedding).

-- The constant polynomials add coefficientwise. At index 0 both sides read
-- a + b; at any other index both are 0 (the monomials are off-degree).
-- (The coefficient bookkeeping mixes `Ring.add(Real.ring, …)` from
-- `coefficientOf_add` with surface `Real.add`, so the off-degree citations
-- keep their explicit arguments — the dual spelling defeats argument-free
-- congruence inference.)
theorem Complex.constant_add (a b : ℝ)
        : Polynomial.monomial(Real.ring, a, 0) + Polynomial.monomial(Real.ring, b, 0)
          = Polynomial.monomial(Real.ring, a + b, 0) :=
  Polynomial.equal_of_coefficientOf_equal(Real.ring,
      Polynomial.monomial(Real.ring, a, 0) + Polynomial.monomial(Real.ring, b, 0),
      Polynomial.monomial(Real.ring, a + b, 0),
      (i : ℕ) ↦
        done by cases {
          case i = 0:
              Polynomial.coefficientOf(Real.ring,
                       Polynomial.monomial(Real.ring, a, 0) + Polynomial.monomial(Real.ring, b, 0), 0)
                 = Real.add(
                       Polynomial.coefficientOf(Real.ring, Polynomial.monomial(Real.ring, a, 0), 0),
                       Polynomial.coefficientOf(Real.ring, Polynomial.monomial(Real.ring, b, 0), 0))
                 = a + b
                 = Polynomial.coefficientOf(Real.ring, Polynomial.monomial(Real.ring, a + b, 0), 0)
          otherwise as indexNotZero:
              Polynomial.coefficientOf(Real.ring,
                       Polynomial.monomial(Real.ring, a, 0) + Polynomial.monomial(Real.ring, b, 0), i)
                 = Real.add(
                       Polynomial.coefficientOf(Real.ring, Polynomial.monomial(Real.ring, a, 0), i),
                       Polynomial.coefficientOf(Real.ring, Polynomial.monomial(Real.ring, b, 0), i))
                 = Real.add(Real.zero, Real.zero)
                 = Real.zero
                 = Polynomial.coefficientOf(Real.ring, Polynomial.monomial(Real.ring, a + b, 0), i)
                       by Polynomial.coefficientOf_monomial_off(Real.ring, a + b, 0, i, indexNotZero)
        })

-- The constant polynomials multiply coefficientwise — exactly the general
-- degree-0 monomial product.
theorem Complex.constant_multiply (a b : ℝ)
        : Polynomial.monomial(Real.ring, a, 0) * Polynomial.monomial(Real.ring, b, 0)
          = Polynomial.monomial(Real.ring, a * b, 0) :=
  Polynomial.monomial_zero_multiply(Real.ring, a, b)

-- The constant polynomial 0 is the zero polynomial.
theorem Complex.constant_zero
        : Polynomial.monomial(Real.ring, Real.zero, 0) = Polynomial.zero(Real.ring) :=
  Polynomial.equal_of_coefficientOf_equal(Real.ring,
      Polynomial.monomial(Real.ring, Real.zero, 0), Polynomial.zero(Real.ring),
      (i : ℕ) ↦
        done by cases {
          case i = 0: {
              Polynomial.coefficientOf(Real.ring, Polynomial.monomial(Real.ring, Real.zero, 0), 0)
                 = Polynomial.coefficientOf(Real.ring, Polynomial.zero(Real.ring), 0)
            }
          otherwise:
              Polynomial.coefficientOf(Real.ring, Polynomial.monomial(Real.ring, Real.zero, 0), i)
                 = Real.zero
                 = Polynomial.coefficientOf(Real.ring, Polynomial.zero(Real.ring), i)
        })

-- ----------------------------------------------------------------------
-- The embedding ℝ ↪ ℂ.

definition ComplexNumber.from_real (a : ℝ) : ℂ :=
  RingModulo.make(Real.polynomial_commutative_ring, Complex.definingPolynomial,
      Polynomial.monomial(Real.ring, a, 0))

-- The embedding is the canonical coercion ℝ ↪ ℂ, so a real `a` reads as the
-- complex number `(a : ℂ)` — no `from_real` at call sites. Composes with the
-- ℕ → ℤ → ℚ → ℝ tower.
coercion (Real, ComplexNumber) := ComplexNumber.from_real

-- 1 ↦ 1 (the constant polynomial 1 is literally Polynomial.one).
theorem ComplexNumber.from_real.one_preserves
        : ComplexNumber.from_real(Real.one)
          = RingModulo.one(Real.polynomial_commutative_ring, Complex.definingPolynomial) :=
  reflexivity(ℂ, RingModulo.one(Real.polynomial_commutative_ring, Complex.definingPolynomial))

-- 0 ↦ 0.
theorem ComplexNumber.from_real.zero_preserves
        : ComplexNumber.from_real(Real.zero)
          = RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial) :=
  Complex.constant_zero

-- Preserves addition. Both sides are the class of a constant polynomial:
-- the constants add coefficientwise (constant_add), and the class of a sum
-- is the sum of the classes (definitionally, since RingModulo.add acts on
-- representatives).
theorem ComplexNumber.from_real.add_preserves (a b : ℝ)
        : ComplexNumber.from_real(a + b)
          = ComplexNumber.from_real(a) + ComplexNumber.from_real(b) :=
  ComplexNumber.from_real(a + b)
     = RingModulo.make(Real.polynomial_commutative_ring, Complex.definingPolynomial,
           Polynomial.monomial(Real.ring, a + b, 0))
     = RingModulo.make(Real.polynomial_commutative_ring, Complex.definingPolynomial,
           (Polynomial.monomial(Real.ring, a, 0) + Polynomial.monomial(Real.ring, b, 0)))
           by Complex.constant_add
     = ComplexNumber.from_real(a) + ComplexNumber.from_real(b)

-- Preserves multiplication (same shape: constant_multiply, then class of a
-- product is the product of the classes).
theorem ComplexNumber.from_real.multiply_preserves (a b : ℝ)
        : ComplexNumber.from_real(a * b)
          = ComplexNumber.from_real(a) * ComplexNumber.from_real(b) :=
  ComplexNumber.from_real(a * b)
     = RingModulo.make(Real.polynomial_commutative_ring, Complex.definingPolynomial,
           Polynomial.monomial(Real.ring, a * b, 0))
     = RingModulo.make(Real.polynomial_commutative_ring, Complex.definingPolynomial,
           (Polynomial.monomial(Real.ring, a, 0) * Polynomial.monomial(Real.ring, b, 0)))
           by Complex.constant_multiply
     = ComplexNumber.from_real(a) * ComplexNumber.from_real(b)

-- Preserves negation: from_real(−a) and −from_real(a) both cancel
-- from_real(a).
theorem ComplexNumber.from_real.negate_preserves (a : ℝ)
        : ComplexNumber.from_real(-a) = RingModulo.negate(ComplexNumber.from_real(a)) := {
  -a + a = Real.zero as negateCancels;
  ComplexNumber.from_real(-a) + ComplexNumber.from_real(a)
              = ComplexNumber.from_real(-a + a)
                    by ComplexNumber.from_real.add_preserves
              = ComplexNumber.from_real(Real.zero)
                    by substituting negateCancels
              = RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial)
                    by ComplexNumber.from_real.zero_preserves
      as sumZero;
  ComplexNumber.from_real(-a)
     = (ComplexNumber.from_real(-a) + ComplexNumber.from_real(a))
         - ComplexNumber.from_real(a)   by ring
     = RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial)
         - ComplexNumber.from_real(a)   by substituting sumZero
     = RingModulo.negate(ComplexNumber.from_real(a))   by ring
}

-- Subtraction through the embedding, assembled from the additive and
-- negation halves (mirror of Integer.to_rational.subtract_preserves).
theorem ComplexNumber.from_real.subtract_preserves (a b : ℝ)
        : ComplexNumber.from_real(a - b)
          = ComplexNumber.from_real(a) - ComplexNumber.from_real(b) :=
  ComplexNumber.from_real(a - b)
     = ComplexNumber.from_real(a) + ComplexNumber.from_real(-b)
           by ComplexNumber.from_real.add_preserves
     = ComplexNumber.from_real(a) + RingModulo.negate(ComplexNumber.from_real(b))
           by ComplexNumber.from_real.negate_preserves
     = ComplexNumber.from_real(a) - ComplexNumber.from_real(b)

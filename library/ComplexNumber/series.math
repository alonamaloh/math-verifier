-- ----------------------------------------------------------------------
-- Partial sums only see the terms' values.
theorem ComplexNumber.partialSum_pointwise
        (s sequencePrime : Natural → ComplexNumber)
        (pointwiseEqual : ∀ (k : Natural). s(k) = sequencePrime(k))
        (n : Natural)
        : ComplexNumber.partialSum(s, n) = ComplexNumber.partialSum(sequencePrime, n) :=
  by induction on n with IH {
    case base: done
    case step(predecessor):
        ComplexNumber.partialSum(s, 1 + predecessor)
           = ComplexNumber.partialSum(s, predecessor) + s(predecessor)
           = ComplexNumber.partialSum(sequencePrime, predecessor) + s(predecessor)
                 by IH
           = ComplexNumber.partialSum(sequencePrime, predecessor)
             + sequencePrime(predecessor)
                 by pointwiseEqual(predecessor)
           = ComplexNumber.partialSum(sequencePrime, 1 + predecessor)
  }

-- The bounded variant: agreement below the cut is enough (the terms at
-- or above n are never read).
theorem ComplexNumber.partialSum_pointwise_below
        (s sequencePrime : Natural → ComplexNumber)
        : ∀ (n : Natural).
          (∀ (k : Natural). successor(k) ≤ n → s(k) = sequencePrime(k))
          → ComplexNumber.partialSum(s, n) = ComplexNumber.partialSum(sequencePrime, n)
  | zero =>
      (pointwiseEqual : ∀ (k : Natural). successor(k) ≤ 0
           → s(k) = sequencePrime(k)) ↦
        done
  | successor(predecessor) =>
      (pointwiseEqual : ∀ (k : Natural). successor(k) ≤ successor(predecessor)
           → s(k) = sequencePrime(k)) ↦ {
        ComplexNumber.partialSum(s, predecessor)
            = ComplexNumber.partialSum(sequencePrime, predecessor)
            by ComplexNumber.partialSum_pointwise_below(s, sequencePrime, predecessor,
                   (k : Natural) (kBelow : successor(k) ≤ predecessor) ↦ {
                     predecessor ≤ successor(predecessor);
                     successor(k) ≤ successor(predecessor);
                     done by pointwiseEqual(k, (successor(k) ≤ successor(predecessor)))
                   }) as tailEqual;
        successor(predecessor) ≤ successor(predecessor);
        s(predecessor) = sequencePrime(predecessor) as headEqual;
        ComplexNumber.partialSum(s, successor(predecessor))
           = ComplexNumber.partialSum(s, predecessor) + s(predecessor)
           = ComplexNumber.partialSum(sequencePrime, predecessor) + s(predecessor)
                 by tailEqual
           = ComplexNumber.partialSum(sequencePrime, predecessor)
             + sequencePrime(predecessor)
                 by headEqual
      }

-- ----------------------------------------------------------------------
-- Linearity of partial sums.
theorem ComplexNumber.partialSum_add (s t : Natural → ComplexNumber) (n : Natural)
        : ComplexNumber.partialSum((k : Natural) ↦ s(k) + t(k), n)
          = ComplexNumber.partialSum(s, n) + ComplexNumber.partialSum(t, n) :=
  by induction on n with IH {
    case base: {
        let zero : ComplexNumber :=
            RingModulo.zero(Real.polynomial_commutative_ring,
                Complex.definingPolynomial);
        ComplexNumber.partialSum((k : Natural) ↦ s(k) + t(k), 0)
           = zero
           = zero + zero
      }
    case step(predecessor):
        ComplexNumber.partialSum((k : Natural) ↦ s(k) + t(k), 1 + predecessor)
           = ComplexNumber.partialSum((k : Natural) ↦ s(k) + t(k), predecessor)
             + (s(predecessor) + t(predecessor))
                 by ComplexNumber.partialSum_add_one
           = (ComplexNumber.partialSum(s, predecessor)
              + ComplexNumber.partialSum(t, predecessor))
             + (s(predecessor) + t(predecessor))
                 by IH
           = (ComplexNumber.partialSum(s, predecessor) + s(predecessor))
             + (ComplexNumber.partialSum(t, predecessor) + t(predecessor))
           = ComplexNumber.partialSum(s, 1 + predecessor)
             + ComplexNumber.partialSum(t, 1 + predecessor)
                 by substituting ComplexNumber.partialSum_add_one
  }

theorem ComplexNumber.partialSum_scale
        (c : ComplexNumber) (s : Natural → ComplexNumber) (n : Natural)
        : ComplexNumber.partialSum((k : Natural) ↦ c * s(k), n)
          = c * ComplexNumber.partialSum(s, n) :=
  by induction on n with IH {
    case base: {
        let zero : ComplexNumber :=
            RingModulo.zero(Real.polynomial_commutative_ring,
                Complex.definingPolynomial);
        ComplexNumber.partialSum((k : Natural) ↦ c * s(k), 0)
           = zero
           = c * zero
      }
    case step(predecessor):
        ComplexNumber.partialSum((k : Natural) ↦ c * s(k), 1 + predecessor)
           = ComplexNumber.partialSum((k : Natural) ↦ c * s(k), predecessor)
             + c * s(predecessor)
                 by ComplexNumber.partialSum_add_one
           = c * ComplexNumber.partialSum(s, predecessor) + c * s(predecessor)
                 by IH
           = c * (ComplexNumber.partialSum(s, predecessor) + s(predecessor))
           = c * ComplexNumber.partialSum(s, 1 + predecessor)
                 by substituting ComplexNumber.partialSum_add_one
  }

-- Negating every term negates the sum.
theorem ComplexNumber.partialSum_negate (s : Natural → ComplexNumber) (n : Natural)
        : ComplexNumber.partialSum((k : Natural) ↦ -s(k), n)
          = -ComplexNumber.partialSum(s, n) :=
  by induction on n with IH {
    case base: {
        let zero : ComplexNumber :=
            RingModulo.zero(Real.polynomial_commutative_ring,
                Complex.definingPolynomial);
        ComplexNumber.partialSum((k : Natural) ↦ -s(k), 0)
           = zero
           = -zero
      }
    case step(predecessor):
        ComplexNumber.partialSum((k : Natural) ↦ -s(k), 1 + predecessor)
           = ComplexNumber.partialSum((k : Natural) ↦ -s(k), predecessor)
             + -s(predecessor)
                 by ComplexNumber.partialSum_add_one
           = -ComplexNumber.partialSum(s, predecessor) + -s(predecessor)
                 by IH
           = -(ComplexNumber.partialSum(s, predecessor) + s(predecessor))
           = -ComplexNumber.partialSum(s, 1 + predecessor)
                 by substituting ComplexNumber.partialSum_add_one
  }

-- Sums subtract termwise.
theorem ComplexNumber.partialSum_subtract (s t : Natural → ComplexNumber) (n : Natural)
        : ComplexNumber.partialSum((k : Natural) ↦ s(k) - t(k), n)
          = ComplexNumber.partialSum(s, n) - ComplexNumber.partialSum(t, n) :=
  by induction on n with IH {
    case base: {
        let zero : ComplexNumber :=
            RingModulo.zero(Real.polynomial_commutative_ring,
                Complex.definingPolynomial);
        ComplexNumber.partialSum((k : Natural) ↦ s(k) - t(k), 0)
           = zero
           = zero - zero
      }
    case step(predecessor):
        ComplexNumber.partialSum((k : Natural) ↦ s(k) - t(k), 1 + predecessor)
           = ComplexNumber.partialSum((k : Natural) ↦ s(k) - t(k), predecessor)
             + (s(predecessor) - t(predecessor))
                 by ComplexNumber.partialSum_add_one
           = (ComplexNumber.partialSum(s, predecessor)
              - ComplexNumber.partialSum(t, predecessor))
             + (s(predecessor) - t(predecessor))
                 by IH
           = (ComplexNumber.partialSum(s, predecessor) + s(predecessor))
             - (ComplexNumber.partialSum(t, predecessor) + t(predecessor))
           = ComplexNumber.partialSum(s, 1 + predecessor)
             - ComplexNumber.partialSum(t, 1 + predecessor)
                 by substituting ComplexNumber.partialSum_add_one
  }

-- Scaling on the right (a common factor behind every term).
theorem ComplexNumber.partialSum_scale_right
        (s : Natural → ComplexNumber) (c : ComplexNumber) (n : Natural)
        : ComplexNumber.partialSum((k : Natural) ↦ s(k) * c, n)
          = ComplexNumber.partialSum(s, n) * c :=
  by induction on n with IH {
    case base: {
        let zero : ComplexNumber :=
            RingModulo.zero(Real.polynomial_commutative_ring,
                Complex.definingPolynomial);
        ComplexNumber.partialSum((k : Natural) ↦ s(k) * c, 0)
           = zero
           = zero * c
      }
    case step(predecessor):
        ComplexNumber.partialSum((k : Natural) ↦ s(k) * c, 1 + predecessor)
           = ComplexNumber.partialSum((k : Natural) ↦ s(k) * c, predecessor)
             + s(predecessor) * c
                 by ComplexNumber.partialSum_add_one
           = ComplexNumber.partialSum(s, predecessor) * c + s(predecessor) * c
                 by IH
           = (ComplexNumber.partialSum(s, predecessor) + s(predecessor)) * c
           = ComplexNumber.partialSum(s, 1 + predecessor) * c
                 by substituting ComplexNumber.partialSum_add_one
  }

-- ----------------------------------------------------------------------
-- A window of a ℂ-sum is bounded in modulus by the same window of the
-- real series of moduli: |S(w+m) − S(m)| ≤ Sabs(w+m) − Sabs(m).
theorem ComplexNumber.partialSum_window_bound
        (b : Natural → ComplexNumber) (m w : Natural)
        : abs(
              ComplexNumber.partialSum(b, w + m) - ComplexNumber.partialSum(b, m))
          ≤ Real.partialSum((k : Natural) ↦ abs(b(k)), w + m)
            - Real.partialSum((k : Natural) ↦ abs(b(k)), m) := {
  ComplexNumber.partialSum(b, w + m)
      = ComplexNumber.partialSum(b, m)
        + ComplexNumber.partialSum((j : Natural) ↦ b(m + j), w)
      by ComplexNumber.partialSum_split as signedSplit;
  Real.partialSum((k : Natural) ↦ abs(b(k)), w + m)
      = Real.partialSum((k : Natural) ↦ abs(b(k)), m)
        + Real.partialSum((j : Natural) ↦ abs(b(m + j)), w)
      by Real.partialSum_split as absSplit;
  abs(
           ComplexNumber.partialSum(b, w + m) - ComplexNumber.partialSum(b, m))
     = abs(
           (ComplexNumber.partialSum(b, m)
                + ComplexNumber.partialSum((j : Natural) ↦ b(m + j), w))
           - ComplexNumber.partialSum(b, m))
           by signedSplit
     = abs(ComplexNumber.partialSum((j : Natural) ↦ b(m + j), w))
     ≤ Real.partialSum((j : Natural) ↦ abs(b(m + j)), w)
           by ComplexNumber.modulus_partialSum_le
     = (Real.partialSum((k : Natural) ↦ abs(b(k)), m)
            + Real.partialSum((j : Natural) ↦ abs(b(m + j)), w))
       - Real.partialSum((k : Natural) ↦ abs(b(k)), m)
     = Real.partialSum((k : Natural) ↦ abs(b(k)), w + m)
       - Real.partialSum((k : Natural) ↦ abs(b(k)), m)
           by absSplit
}

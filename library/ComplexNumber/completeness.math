-- ComplexNumber/completeness.math
--
-- ℂ is complete. Convergence and the Cauchy property are defined with
-- the modulus exactly as on ℝ (rational tolerances); the coordinate
-- bounds |re| ≤ |z| ≤ |re| + |im| squeeze a ℂ-Cauchy sequence into two
-- real Cauchy coordinate sequences, each converges by the completeness
-- of ℝ, and the coordinate limits reassemble through `ofCoordinates`
-- with an ε/2 budget per coordinate.

module ComplexNumber.completeness


-- ComplexNumber/exponential_addition.math
--
-- The functional equation of the complex exponential:
-- exp(z + w) = exp(z) · exp(w). The chain mirrors the real one
-- (Real/exponential_addition.math): the binomial theorem splits the
-- k-th term of the series at z + w into the k-th Cauchy-product
-- diagonal of the series at z and at w (the coefficient identity
-- C(k, i)/k! = 1/i!·1/(k−i)! is the same rational fact), and Mertens'
-- theorem — with the modulus playing the role of the absolute value,
-- and the dominating absolute series staying REAL — identifies the
-- limit of the triangle sums with the product of the limits.

module ComplexNumber.exponential_addition

import Logic.basics
import Logic.exists
import Logic.product
import Logic.quotient
import Logic.excluded_middle
import axioms
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Natural.maximum
import Natural.compare
import Natural.subtraction
import Natural.monus
import Natural.binomial
import Natural.factorial
import Integer.basics
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.halve
import Rational.positive
import Rational.linearity
import Rational.minimum
import Rational.reciprocal
import Rational.archimedean
import Set.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Real.interface
import Polynomial.basics
import Polynomial.addition
import Polynomial.negation
import Polynomial.multiplication
import Polynomial.monomial
import RingModulo.basics
import RingModulo.operations
import ComplexNumber.basics
import ComplexNumber.coordinates
import ComplexNumber.coordinate_homomorphism
import ComplexNumber.defining_polynomial_vanishes
import ComplexNumber.coordinate_map
import ComplexNumber.coordinate_multiplicative
import ComplexNumber.reconstruction
import ComplexNumber.of_coordinates
import ComplexNumber.coordinate_negate
import ComplexNumber.embedding
import ComplexNumber.modulus
import ComplexNumber.modulus_multiplicative
import ComplexNumber.triangle_inequality
import ComplexNumber.modulus_bounds
import ComplexNumber.completeness
import ComplexNumber.limits
import ComplexNumber.exponential
import ComplexNumber.series
import ComplexNumber.binomial_theorem

-- ----------------------------------------------------------------------
-- The k-th exponential term at z + w is the k-th Cauchy-product
-- diagonal of the two series. The coefficient identity is
-- Real.binomial_reciprocal_split, carried into ℂ through the embedding.
theorem ComplexNumber.exponentialTerm_binomial_split
        (z w : ℂ) (k : Natural)
        : ComplexNumber.exponentialTerm(z + w, k)
          = ComplexNumber.partialSum(
                (i : Natural) ↦
                    ComplexNumber.exponentialTerm(z, i)
                    * ComplexNumber.exponentialTerm(w, Natural.monus(k, i)),
                1 + k) := {
  -- Each summand below the cut: fold the coefficient into the two
  -- reciprocal factorials.
  (i : Natural) → successor(i) ≤ 1 + k
        → (1 / (k! : Real) : ℂ)
              * (ComplexNumber.binomialCoefficient(k, i)
                     * (z ^ i * w ^ Natural.monus(k, i)))
          = ComplexNumber.exponentialTerm(z, i)
            * ComplexNumber.exponentialTerm(w, Natural.monus(k, i))
      by (i : Natural) (iBelow : successor(i) ≤ 1 + k) ↦ {
           let recipK : Real := 1 / (k! : Real);
           i ≤ k by Natural.successor_le_cancel;
           choose d such that k = i + d from Natural.subtraction_witness;
           i + d = k as kJoin;
           Natural.monus(k, i) = d
               by {
                 Natural.monus(i + d, i) = d;
                 done by substituting kJoin
               } as monusCollapse;
           let recipI : Real := 1 / (i! : Real);
           let recipD : Real := 1 / (d! : Real);
           recipK * ((Natural.binomial(k, i) : Rational) : Real)
                 = recipI * recipD
               by {
                 recipK * ((Natural.binomial(k, i) : Rational) : Real)
                     = (1 / ((i + d)! : Real)) * (Natural.binomial(i + d, i) : Real)
                           by kJoin
                     = (1 / (i! : Real)) * (1 / (d! : Real))
                           by Real.binomial_reciprocal_split
               } as coefficientSplitCast;
           (recipK : ℂ)
                    * (ComplexNumber.binomialCoefficient(k, i)
                           * (z ^ i * w ^ Natural.monus(k, i)))
              = (recipK : ℂ)
                    * (ComplexNumber.binomialCoefficient(k, i)
                           * (z ^ i * w ^ d))
                    by monusCollapse
              = (recipK : ℂ)
                    * ((((Natural.binomial(k, i) : Rational) : Real) : ℂ)
                           * (z ^ i * w ^ d))
              = ((recipK : ℂ)
                     * (((Natural.binomial(k, i) : Rational) : Real) : ℂ))
                    * (z ^ i * w ^ d)
              = (recipK * ((Natural.binomial(k, i) : Rational) : Real) : ℂ)
                    * (z ^ i * w ^ d)
                    by ComplexNumber.from_real_multiply
              = (recipI * recipD : ℂ)
                    * (z ^ i * w ^ d)
                    by coefficientSplitCast
              = ((recipI : ℂ) * (recipD : ℂ))
                    * (z ^ i * w ^ d)
                    by ComplexNumber.from_real_multiply
              = ((recipI : ℂ) * z ^ i)
                    * ((recipD : ℂ) * w ^ d)
              = ComplexNumber.exponentialTerm(z, i) * ComplexNumber.exponentialTerm(w, d)
              = ComplexNumber.exponentialTerm(z, i)
                    * ComplexNumber.exponentialTerm(w, Natural.monus(k, i))
                    by monusCollapse
         };
  -- Scale the binomial expansion through the sum and rewrite each term.
  ComplexNumber.exponentialTerm(z + w, k)
     = (1 / (k! : Real) : ℂ)
           * (z + w) ^ k
     = (1 / (k! : Real) : ℂ)
           * ComplexNumber.partialSum(
                 (i : Natural) ↦
                     ComplexNumber.binomialCoefficient(k, i)
                     * (z ^ i * w ^ Natural.monus(k, i)),
                 1 + k)
           by ComplexNumber.binomial_theorem
     = ComplexNumber.partialSum(
           (i : Natural) ↦
               (1 / (k! : Real) : ℂ)
               * (ComplexNumber.binomialCoefficient(k, i)
                      * (z ^ i * w ^ Natural.monus(k, i))),
           1 + k)
           by ComplexNumber.partialSum_scale
     = ComplexNumber.partialSum(
           (i : Natural) ↦
               ComplexNumber.exponentialTerm(z, i)
               * ComplexNumber.exponentialTerm(w, Natural.monus(k, i)),
           1 + k)
}

-- ----------------------------------------------------------------------
-- Exchanging the order of summation over the triangle: summing the
-- Cauchy-product diagonals through row n equals weighting each a(i) by
-- the partial sum of b up to n − i.
theorem ComplexNumber.cauchy_product_exchange (a b : Natural → ℂ) (n : Natural)
        : ComplexNumber.partialSum(
              (k : Natural) ↦
                  ComplexNumber.partialSum(
                      (i : Natural) ↦ a(i) * b(Natural.monus(k, i)), 1 + k),
              n)
          = ComplexNumber.partialSum(
                (i : Natural) ↦
                    a(i) * ComplexNumber.partialSum(b, Natural.monus(n, i)),
                n) :=
  by induction on n with IH {
    case zero: done
    case successor(p): {
      let zero : ℂ :=
          RingModulo.zero(Real.polynomial_commutative_ring,
              Complex.definingPolynomial);
      ComplexNumber.partialSum(
                (k : Natural) ↦
                    ComplexNumber.partialSum(
                        (i : Natural) ↦ a(i) * b(Natural.monus(k, i)), 1 + k),
                p)
            = ComplexNumber.partialSum(
                  (i : Natural) ↦
                      a(i) * ComplexNumber.partialSum(b, Natural.monus(p, i)),
                  p)
          by IH as exchangeTail;
      -- Padding the weighted row-p sum with its vanishing head:
      -- a(p)·B(p − p) = a(p)·B(0) = 0.
      Natural.monus(p, p) = 0 as monusDiagonal;
      ComplexNumber.partialSum(
                      (i : Natural) ↦
                          a(i) * ComplexNumber.partialSum(b, Natural.monus(p, i)),
                      successor(p))
                = ComplexNumber.partialSum(
                      (i : Natural) ↦
                          a(i) * ComplexNumber.partialSum(b, Natural.monus(p, i)),
                      p)
                  + a(p) * ComplexNumber.partialSum(b, Natural.monus(p, p))
                = ComplexNumber.partialSum(
                      (i : Natural) ↦
                          a(i) * ComplexNumber.partialSum(b, Natural.monus(p, i)),
                      p)
                  + a(p) * ComplexNumber.partialSum(b, 0)
                      by monusDiagonal
                = ComplexNumber.partialSum(
                      (i : Natural) ↦
                          a(i) * ComplexNumber.partialSum(b, Natural.monus(p, i)),
                      p)
                  + a(p) * zero
                = ComplexNumber.partialSum(
                      (i : Natural) ↦
                          a(i) * ComplexNumber.partialSum(b, Natural.monus(p, i)),
                      p) as headPadding;
      -- Below the cut, peeling the successor off n − i absorbs one
      -- diagonal term into each weight.
      (i : Natural) → successor(i) ≤ successor(p)
            → a(i) * ComplexNumber.partialSum(b, Natural.monus(p, i))
                  + a(i) * b(Natural.monus(p, i))
              = a(i) * ComplexNumber.partialSum(b, Natural.monus(successor(p), i))
          by (i : Natural) (iBelow : successor(i) ≤ successor(p)) ↦ {
               i ≤ p;
               Natural.monus(successor(p), i) = successor(Natural.monus(p, i)) as monusStep;
               a(i) * ComplexNumber.partialSum(b, Natural.monus(p, i))
                        + a(i) * b(Natural.monus(p, i))
                  = a(i) * (ComplexNumber.partialSum(b, Natural.monus(p, i))
                                + b(Natural.monus(p, i)))
                  = a(i) * ComplexNumber.partialSum(b, successor(Natural.monus(p, i)))
                  = a(i) * ComplexNumber.partialSum(b, Natural.monus(successor(p), i))
                        by monusStep
             };
      ComplexNumber.partialSum(
               (k : Natural) ↦
                   ComplexNumber.partialSum(
                       (i : Natural) ↦ a(i) * b(Natural.monus(k, i)), 1 + k),
               successor(p))
         = ComplexNumber.partialSum(
               (k : Natural) ↦
                   ComplexNumber.partialSum(
                       (i : Natural) ↦ a(i) * b(Natural.monus(k, i)), 1 + k),
               p)
           + ComplexNumber.partialSum(
                 (i : Natural) ↦ a(i) * b(Natural.monus(p, i)), 1 + p)
         = ComplexNumber.partialSum(
               (i : Natural) ↦
                   a(i) * ComplexNumber.partialSum(b, Natural.monus(p, i)),
               p)
           + ComplexNumber.partialSum(
                 (i : Natural) ↦ a(i) * b(Natural.monus(p, i)), 1 + p)
               by exchangeTail
         = ComplexNumber.partialSum(
               (i : Natural) ↦
                   a(i) * ComplexNumber.partialSum(b, Natural.monus(p, i)),
               successor(p))
           + ComplexNumber.partialSum(
                 (i : Natural) ↦ a(i) * b(Natural.monus(p, i)), successor(p))
               by headPadding
         = ComplexNumber.partialSum(
               (i : Natural) ↦
                   a(i) * ComplexNumber.partialSum(b, Natural.monus(p, i))
                   + a(i) * b(Natural.monus(p, i)),
               successor(p))
               by ComplexNumber.partialSum_add
         = ComplexNumber.partialSum(
               (i : Natural) ↦
                   a(i) * ComplexNumber.partialSum(b, Natural.monus(successor(p), i)),
               successor(p))
               by ComplexNumber.partialSum_pointwise_below
    }
  }

-- ----------------------------------------------------------------------
-- The square-minus-triangle gap, dominated by the same gap of the real
-- absolute series: |A(n)·B(n) − T(n)| ≤ Aabs(n)·Babs(n) − Tabs(n).
theorem ComplexNumber.cauchy_product_difference_bound
        (a b : Natural → ℂ) (n : Natural)
        : abs(
              ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n)
                  - ComplexNumber.partialSum(
                        (k : Natural) ↦
                            ComplexNumber.partialSum(
                                (i : Natural) ↦ a(i) * b(Natural.monus(k, i)),
                                1 + k),
                        n))
          ≤ Real.partialSum((k : Natural) ↦ abs(a(k)), n)
                * Real.partialSum((k : Natural) ↦ abs(b(k)), n)
            - Real.partialSum(
                  (k : Natural) ↦
                      Real.partialSum(
                          (i : Natural) ↦
                              abs(a(i))
                              * abs(b(Natural.monus(k, i))),
                          1 + k),
                  n) := {
  let aModulus : Natural → Real := (k : Natural) ↦ abs(a(k));
  let bModulus : Natural → Real := (k : Natural) ↦ abs(b(k));
  Real.partialSum(
            (k : Natural) ↦
                Real.partialSum(
                    (i : Natural) ↦ aModulus(i) * bModulus(Natural.monus(k, i)),
                    1 + k),
            n)
        = Real.partialSum(
              (i : Natural) ↦
                  aModulus(i) * Real.partialSum(bModulus, Natural.monus(n, i)),
              n)
      by Real.cauchy_product_exchange as absExchange;
  ComplexNumber.partialSum(
            (i : Natural) ↦ a(i) * ComplexNumber.partialSum(b, n), n)
        = ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n) as signedScale;
  Real.partialSum(
            (i : Natural) ↦ aModulus(i) * Real.partialSum(bModulus, n), n)
        = Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n) as absScale;
  -- Each weighted window of B is dominated by the weighted window of Babs.
  (i : Natural) → successor(i) ≤ n
        → abs(
              a(i) * ComplexNumber.partialSum(b, n)
                  - a(i) * ComplexNumber.partialSum(b, Natural.monus(n, i)))
          ≤ aModulus(i) * Real.partialSum(bModulus, n)
            - aModulus(i) * Real.partialSum(bModulus, Natural.monus(n, i))
      by (i : Natural) (iBelow : successor(i) ≤ n) ↦ {
           i ≤ n;
           choose e such that n = i + e from Natural.subtraction_witness;
           i + e = n as nJoin;
           Natural.monus(n, i) = e
               by {
                 Natural.monus(i + e, i) = e;
                 done by substituting nJoin
               } as monusCollapse;
           abs(
                     ComplexNumber.partialSum(b, n) - ComplexNumber.partialSum(b, e))
                 ≤ Real.partialSum(bModulus, n) - Real.partialSum(bModulus, e)
               by {
                 abs(
                           ComplexNumber.partialSum(b, i + e)
                           - ComplexNumber.partialSum(b, e))
                       ≤ Real.partialSum(bModulus, i + e)
                         - Real.partialSum(bModulus, e)
                     by ComplexNumber.partialSum_window_bound;
                 done by substituting nJoin
               };
           Real.zero ≤ aModulus(i) by ComplexNumber.modulus_nonneg(a(i));
           Real.IsNonneg(aModulus(i));
           abs(
                    a(i) * ComplexNumber.partialSum(b, n)
                    - a(i) * ComplexNumber.partialSum(b, Natural.monus(n, i)))
              = abs(
                    a(i) * ComplexNumber.partialSum(b, n)
                    - a(i) * ComplexNumber.partialSum(b, e))
                    by monusCollapse
              = abs(
                    a(i)
                    * (ComplexNumber.partialSum(b, n) - ComplexNumber.partialSum(b, e)))
                    by substituting
                        (ring : a(i) * (ComplexNumber.partialSum(b, n)
                                            - ComplexNumber.partialSum(b, e))
                            = a(i) * ComplexNumber.partialSum(b, n)
                              - a(i) * ComplexNumber.partialSum(b, e))
              = abs(a(i))
                * abs(
                      ComplexNumber.partialSum(b, n) - ComplexNumber.partialSum(b, e))
              = abs(
                    ComplexNumber.partialSum(b, n) - ComplexNumber.partialSum(b, e))
                * abs(a(i))
                    by ring
              = abs(
                    ComplexNumber.partialSum(b, n) - ComplexNumber.partialSum(b, e))
                * aModulus(i)
              ≤ (Real.partialSum(bModulus, n) - Real.partialSum(bModulus, e))
                    * aModulus(i)
                    by Real.LessOrEqual.multiply_by_nonneg_right
              = aModulus(i) * Real.partialSum(bModulus, n)
                - aModulus(i) * Real.partialSum(bModulus, e)
              = aModulus(i) * Real.partialSum(bModulus, n)
                - aModulus(i) * Real.partialSum(bModulus, Natural.monus(n, i))
                    by monusCollapse
         } as diagonalModulusBound;
  abs(
           ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n)
               - ComplexNumber.partialSum(
                     (k : Natural) ↦
                         ComplexNumber.partialSum(
                             (i : Natural) ↦ a(i) * b(Natural.monus(k, i)),
                             1 + k),
                     n))
     = abs(
           ComplexNumber.partialSum(
               (i : Natural) ↦ a(i) * ComplexNumber.partialSum(b, n), n)
           - ComplexNumber.partialSum(
                 (i : Natural) ↦
                     a(i) * ComplexNumber.partialSum(b, Natural.monus(n, i)),
                 n))
           by signedScale
     = abs(
           ComplexNumber.partialSum(
               (i : Natural) ↦
                   a(i) * ComplexNumber.partialSum(b, n)
                   - a(i) * ComplexNumber.partialSum(b, Natural.monus(n, i)),
               n))
           by ComplexNumber.partialSum_subtract
     ≤ Real.partialSum(
           (i : Natural) ↦
               abs(
                   a(i) * ComplexNumber.partialSum(b, n)
                   - a(i) * ComplexNumber.partialSum(b, Natural.monus(n, i))),
           n)
           by ComplexNumber.modulus_partialSum_le
     ≤ Real.partialSum(
           (i : Natural) ↦
               aModulus(i) * Real.partialSum(bModulus, n)
               - aModulus(i) * Real.partialSum(bModulus, Natural.monus(n, i)),
           n)
           by Real.partialSum_le_pointwise(
                  (i : Natural) ↦
                      abs(
                          a(i) * ComplexNumber.partialSum(b, n)
                          - a(i) * ComplexNumber.partialSum(b, Natural.monus(n, i))),
                  (i : Natural) ↦
                      aModulus(i) * Real.partialSum(bModulus, n)
                      - aModulus(i) * Real.partialSum(bModulus, Natural.monus(n, i)),
                  n,
                  (j : Natural) (jLessN : j < n) ↦
                      diagonalModulusBound(j, Natural.successor_le_of_lt(j, n, jLessN)))
     = Real.partialSum(
           (i : Natural) ↦ aModulus(i) * Real.partialSum(bModulus, n), n)
       - Real.partialSum(
             (i : Natural) ↦
                 aModulus(i) * Real.partialSum(bModulus, Natural.monus(n, i)),
             n)
           by Real.partialSum_subtract
     = Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n)
       - Real.partialSum(
             (i : Natural) ↦
                 aModulus(i) * Real.partialSum(bModulus, Natural.monus(n, i)),
             n)
           by absScale
     = Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n)
       - Real.partialSum(
             (k : Natural) ↦
                 Real.partialSum(
                     (i : Natural) ↦ aModulus(i) * bModulus(Natural.monus(k, i)),
                     1 + k),
             n)
           by absExchange
}

-- ----------------------------------------------------------------------
-- Mertens for absolutely convergent series, on ℂ: the triangle sums of
-- the Cauchy product converge to the product of the limits. The square
-- converges there by the product of limits; the square-minus-triangle
-- gap is dominated by the gap of the REAL absolute series, and the
-- absolute triangle and square share one limit because
-- Tabs(n) ≤ Sabs(n) ≤ Tabs(n + n).
theorem ComplexNumber.cauchy_product_converges
        (a b : Natural → ℂ)
        (aLimit bLimit : ℂ)
        (aAbsoluteLimit bAbsoluteLimit : Real)
        (aConverges
            : ComplexNumber.SequenceConverges(ComplexNumber.partialSum(a), aLimit))
        (bConverges
            : ComplexNumber.SequenceConverges(ComplexNumber.partialSum(b), bLimit))
        (aAbsolutelyConverges
            : Real.SequenceConverges(
                  Real.partialSum((k : Natural) ↦ abs(a(k))),
                  aAbsoluteLimit))
        (bAbsolutelyConverges
            : Real.SequenceConverges(
                  Real.partialSum((k : Natural) ↦ abs(b(k))),
                  bAbsoluteLimit))
        : ComplexNumber.SequenceConverges(
              ComplexNumber.partialSum(
                  (k : Natural) ↦
                      ComplexNumber.partialSum(
                          (i : Natural) ↦ a(i) * b(Natural.monus(k, i)),
                          1 + k)),
              aLimit * bLimit) := {
  let complexZero : ℂ :=
      RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial);
  let aModulus : Natural → Real := (k : Natural) ↦ abs(a(k));
  let bModulus : Natural → Real := (k : Natural) ↦ abs(b(k));
  let signedDiagonal : Natural → ℂ :=
      (k : Natural) ↦
          ComplexNumber.partialSum(
              (i : Natural) ↦ a(i) * b(Natural.monus(k, i)), 1 + k);
  let absoluteDiagonal : Natural → Real :=
      (k : Natural) ↦
          Real.partialSum(
              (l : Natural) ↦ aModulus(l) * bModulus(Natural.monus(k, l)), 1 + k);
  -- The squares converge, signed and absolute.
  ComplexNumber.SequenceConverges(
            (n : Natural) ↦
                ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n),
            aLimit * bLimit)
      by ComplexNumber.SequenceConverges.multiply(
             s := ComplexNumber.partialSum(a), t := ComplexNumber.partialSum(b),
             sConverges := aConverges, tConverges := bConverges) as productConverges;
  Real.SequenceConverges(
            (n : Natural) ↦
                Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n),
            aAbsoluteLimit * bAbsoluteLimit)
      by Real.SequenceConverges.multiply(
             s := Real.partialSum(aModulus), t := Real.partialSum(bModulus),
             sConverges := aAbsolutelyConverges,
             tConverges := bAbsolutelyConverges) as absoluteProductConverges;
  -- The absolute triangle sums are monotone in n.
  (i : Natural) → Real.zero ≤ aModulus(i)
      by (i : Natural) ↦ ComplexNumber.modulus_nonneg(a(i));
  (i : Natural) → Real.zero ≤ bModulus(i)
      by (i : Natural) ↦ ComplexNumber.modulus_nonneg(b(i));
  ∀ (k : Natural). Real.zero ≤ absoluteDiagonal(k)
      by (k : Natural) ↦
           Real.partialSum_nonneg(
               (l : Natural) ↦ aModulus(l) * bModulus(Natural.monus(k, l)),
               1 + k,
               (j : Natural) ↦ {
                 Real.zero ≤ aModulus(j);
                 Real.zero ≤ bModulus(Natural.monus(k, j))
                     by ComplexNumber.modulus_nonneg(b(Natural.monus(k, j)));
                 Real.IsNonneg(aModulus(j))
                     by Real.IsNonneg_of_LessOrEqual_zero;
                 Real.IsNonneg(bModulus(Natural.monus(k, j)));
                 Real.IsNonneg(aModulus(j) * bModulus(Natural.monus(k, j)));
                 done by Real.LessOrEqual_zero_of_IsNonneg
               }) as absoluteDiagonalNonneg;
  ∀ (i j : Natural). i ≤ j
        → Real.partialSum(absoluteDiagonal, i) ≤ Real.partialSum(absoluteDiagonal, j)
      by (i j : Natural) (iLeqJ : i ≤ j) ↦
           Real.partialSum_monotone_of_nonneg(
               absoluteDiagonal, absoluteDiagonalNonneg, i, j, iLeqJ) as absoluteTriangleMonotone;
  -- The absolute square sits below its limit (it is monotone), and the
  -- absolute triangle sits below the absolute square.
  ∀ (n : Natural).
        Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n)
          ≤ aAbsoluteLimit * bAbsoluteLimit
      by (n : Natural) ↦
           Real.SequenceConverges.ge_of_eventually_ge(
               (m : Natural) ↦
                   Real.partialSum(aModulus, m) * Real.partialSum(bModulus, m),
               aAbsoluteLimit * bAbsoluteLimit,
               Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n),
               absoluteProductConverges,
               n,
               (m : Natural) (nLeqM : n ≤ m) ↦ {
                 Real.zero ≤ Real.partialSum(aModulus, n)
                     by Real.partialSum_nonneg;
                 Real.zero ≤ Real.partialSum(bModulus, n)
                     by Real.partialSum_nonneg;
                 Real.partialSum(aModulus, n) ≤ Real.partialSum(aModulus, m)
                     by Real.partialSum_monotone_of_nonneg;
                 Real.partialSum(bModulus, n) ≤ Real.partialSum(bModulus, m)
                     by Real.partialSum_monotone_of_nonneg;
                 Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n)
                       ≤ Real.partialSum(aModulus, m) * Real.partialSum(bModulus, m)
                     by Real.LessOrEqual.multiply_monotone_nonneg;
                 done
               });
  ∀ (n : Natural).
        Real.partialSum(absoluteDiagonal, n)
          ≤ Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n)
      by (n : Natural) ↦ {
           (i : Natural) → successor(i) ≤ n
                 → aModulus(i) * Real.partialSum(bModulus, Natural.monus(n, i))
                   ≤ aModulus(i) * Real.partialSum(bModulus, n)
               by (i : Natural) (iBelow : successor(i) ≤ n) ↦ {
                    i ≤ n
                        by Natural.less_or_equal_predecessor_less_or_equal;
                    choose e such that n = i + e
                        from Natural.subtraction_witness;
                    Natural.monus(n, i) ≤ n;
                    Real.partialSum(bModulus, Natural.monus(n, i))
                          ≤ Real.partialSum(bModulus, n)
                        by Real.partialSum_monotone_of_nonneg;
                    Real.zero ≤ aModulus(i) by ComplexNumber.modulus_nonneg(a(i));
                    Real.IsNonneg(aModulus(i));
                    aModulus(i) * Real.partialSum(bModulus, Natural.monus(n, i))
                       = Real.partialSum(bModulus, Natural.monus(n, i)) * aModulus(i)
                       ≤ Real.partialSum(bModulus, n) * aModulus(i)
                             by Real.LessOrEqual.multiply_by_nonneg_right
                       = aModulus(i) * Real.partialSum(bModulus, n)
                  } as diagonalPointwiseBound;
           Real.partialSum(absoluteDiagonal, n)
              = Real.partialSum(
                    (i : Natural) ↦
                        aModulus(i) * Real.partialSum(bModulus, Natural.monus(n, i)),
                    n)
                    by Real.cauchy_product_exchange
              ≤ Real.partialSum(
                    (i : Natural) ↦ aModulus(i) * Real.partialSum(bModulus, n),
                    n)
                    by Real.partialSum_le_pointwise(
                           (i : Natural) ↦
                               aModulus(i) * Real.partialSum(bModulus, Natural.monus(n, i)),
                           (i : Natural) ↦ aModulus(i) * Real.partialSum(bModulus, n),
                           n,
                           (j : Natural) (jLessN : j < n) ↦
                               diagonalPointwiseBound(j,
                                   Natural.successor_le_of_lt(j, n, jLessN)))
              = Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n)
         };
  -- The absolute triangle converges (monotone, bounded by the absolute
  -- square's limit) …
  ∀ (n : Natural).
        Real.partialSum(absoluteDiagonal, n) ≤ aAbsoluteLimit * bAbsoluteLimit
      by (n : Natural) ↦ {
           Real.partialSum(absoluteDiagonal, n)
                 ≤ Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n);
           Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n)
                 ≤ aAbsoluteLimit * bAbsoluteLimit;
           Real.partialSum(absoluteDiagonal, n)
                 ≤ aAbsoluteLimit * bAbsoluteLimit;
           done
         } as absoluteTriangleBounded;
  choose triangleAbsoluteLimit such that Real.SequenceConverges(Real.partialSum(absoluteDiagonal), triangleAbsoluteLimit)
      as absoluteTriangleConverges
      from Real.monotone_bounded_converges;
  -- … to the SAME limit as the absolute square, because
  -- Sabs(n) ≤ Tabs(n + n).
  ∀ (n : Natural).
        Real.partialSum(absoluteDiagonal, n) ≤ triangleAbsoluteLimit
      by (n : Natural) ↦
           Real.SequenceConverges.ge_of_eventually_ge(
               Real.partialSum(absoluteDiagonal),
               triangleAbsoluteLimit,
               Real.partialSum(absoluteDiagonal, n),
               absoluteTriangleConverges,
               n,
               (m : Natural) (nLeqM : n ≤ m) ↦
                 absoluteTriangleMonotone(n, m, nLeqM));
  ∀ (n : Natural).
        Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n)
          ≤ Real.partialSum(absoluteDiagonal, n + n)
      by (n : Natural) ↦ {
           (i : Natural) → successor(i) ≤ n
                 → aModulus(i) * Real.partialSum(bModulus, n)
                   ≤ aModulus(i)
                     * Real.partialSum(bModulus, Natural.monus(n + n, i))
               by (i : Natural) (iBelow : successor(i) ≤ n) ↦ {
                    i ≤ n
                        by Natural.less_or_equal_predecessor_less_or_equal;
                    choose e such that n = i + e as nSplit
                        from Natural.subtraction_witness;
                    n + n
                        = (i + e) + n    by nSplit
                        = i + (e + n);
                    Natural.monus(n + n, i) = e + n
                        by {
                          Natural.monus(i + (e + n), i) = e + n;
                          i + (e + n) = n + n;
                          done by substituting (i + (e + n) = n + n)
                        } as monusStretch;
                    n ≤ Natural.monus(n + n, i)
                        by {
                          n ≤ n + e by Natural.less_or_equal_add_right;
                          n + e = e + n;
                          n ≤ e + n;
                          done by substituting monusStretch
                        };
                    Real.partialSum(bModulus, n)
                          ≤ Real.partialSum(bModulus, Natural.monus(n + n, i))
                        by Real.partialSum_monotone_of_nonneg;
                    Real.zero ≤ aModulus(i) by ComplexNumber.modulus_nonneg(a(i));
                    Real.IsNonneg(aModulus(i));
                    aModulus(i) * Real.partialSum(bModulus, n)
                       = Real.partialSum(bModulus, n) * aModulus(i)
                       ≤ Real.partialSum(bModulus, Natural.monus(n + n, i))
                             * aModulus(i)
                             by Real.LessOrEqual.multiply_by_nonneg_right
                       = aModulus(i)
                         * Real.partialSum(bModulus, Natural.monus(n + n, i))
                  } as stretchedPointwiseBound;
           (i : Natural)
                 → Real.zero
                   ≤ aModulus(i)
                     * Real.partialSum(bModulus, Natural.monus(n + n, i))
               by (i : Natural) ↦ {
                    Real.zero ≤ aModulus(i);
                    Real.zero
                          ≤ Real.partialSum(bModulus, Natural.monus(n + n, i))
                        by Real.partialSum_nonneg;
                    Real.IsNonneg(aModulus(i));
                    Real.IsNonneg(
                              Real.partialSum(bModulus, Natural.monus(n + n, i)));
                    Real.IsNonneg(
                              aModulus(i)
                              * Real.partialSum(bModulus, Natural.monus(n + n, i)))
                        by Real.IsNonneg.multiply;
                    done by Real.LessOrEqual_zero_of_IsNonneg
                  };
           n ≤ n + n;
           Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n)
              = Real.partialSum(
                    (i : Natural) ↦ aModulus(i) * Real.partialSum(bModulus, n),
                    n)
              ≤ Real.partialSum(
                    (i : Natural) ↦
                        aModulus(i)
                        * Real.partialSum(bModulus, Natural.monus(n + n, i)),
                    n)
                    by Real.partialSum_le_pointwise(
                           (i : Natural) ↦ aModulus(i) * Real.partialSum(bModulus, n),
                           (i : Natural) ↦
                               aModulus(i)
                               * Real.partialSum(bModulus, Natural.monus(n + n, i)),
                           n,
                           (j : Natural) (jLessN : j < n) ↦
                               stretchedPointwiseBound(j,
                                   Natural.successor_le_of_lt(j, n, jLessN)))
              ≤ Real.partialSum(
                    (i : Natural) ↦
                        aModulus(i)
                        * Real.partialSum(bModulus, Natural.monus(n + n, i)),
                    n + n)
                    by Real.partialSum_monotone_of_nonneg
              = Real.partialSum(absoluteDiagonal, n + n)
                    by Real.cauchy_product_exchange
         };
  -- The two absolute limits agree.
  triangleAbsoluteLimit ≤ aAbsoluteLimit * bAbsoluteLimit
      by Real.SequenceConverges.le_of_eventually_le(
             s := Real.partialSum(absoluteDiagonal),
             converges := absoluteTriangleConverges,
             N := 0,
             tailBelow := (m : Natural) (_ : 0 ≤ m) ↦ absoluteTriangleBounded(m));
  aAbsoluteLimit * bAbsoluteLimit ≤ triangleAbsoluteLimit
      by Real.SequenceConverges.le_of_eventually_le(
             s := (n : Natural) ↦
                 Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n),
             converges := absoluteProductConverges,
             N := 0,
             tailBelow := (m : Natural) (_ : 0 ≤ m) ↦ {
               Real.partialSum(aModulus, m) * Real.partialSum(bModulus, m)
                     ≤ Real.partialSum(absoluteDiagonal, m + m);
               Real.partialSum(absoluteDiagonal, m + m)
                     ≤ triangleAbsoluteLimit;
               Real.partialSum(aModulus, m) * Real.partialSum(bModulus, m)
                     ≤ triangleAbsoluteLimit;
               done
             });
  aAbsoluteLimit * bAbsoluteLimit = triangleAbsoluteLimit
      by Real.LessOrEqual.antisymmetric as limitsAgree;
  -- The absolute gap vanishes …
  Real.SequenceConverges(
            (n : Natural) ↦ -Real.partialSum(absoluteDiagonal, n),
            -triangleAbsoluteLimit)
      by Real.SequenceConverges.negate(
             s := Real.partialSum(absoluteDiagonal),
             sConverges := absoluteTriangleConverges) as negatedTriangleConverges;
  Real.SequenceConverges(
            (n : Natural) ↦
                Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n)
                + -Real.partialSum(absoluteDiagonal, n),
            aAbsoluteLimit * bAbsoluteLimit + -triangleAbsoluteLimit)
      by Real.SequenceConverges.add(
             s := (n : Natural) ↦
                 Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n),
             t := (n : Natural) ↦ -Real.partialSum(absoluteDiagonal, n),
             sConverges := absoluteProductConverges,
             tConverges := negatedTriangleConverges);
  aAbsoluteLimit * bAbsoluteLimit + -triangleAbsoluteLimit
        = triangleAbsoluteLimit + -triangleAbsoluteLimit
              by limitsAgree
        = Real.zero;
  Real.SequenceConverges(
            (n : Natural) ↦
                Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n)
                - Real.partialSum(absoluteDiagonal, n),
            Real.zero)
      by {
        Real.zero = aAbsoluteLimit * bAbsoluteLimit + -triangleAbsoluteLimit;
        done by substituting
            (Real.zero = aAbsoluteLimit * bAbsoluteLimit + -triangleAbsoluteLimit)
      } as gapVanishes;
  -- … so the signed gap vanishes by the squeeze.
  ∀ (n : Natural).
        abs(
              ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n)
                  - ComplexNumber.partialSum(signedDiagonal, n))
          ≤ Real.partialSum(aModulus, n) * Real.partialSum(bModulus, n)
            - Real.partialSum(absoluteDiagonal, n)
      by (n : Natural) ↦ ComplexNumber.cauchy_product_difference_bound(a, b, n);
  ComplexNumber.SequenceConverges(
            (n : Natural) ↦
                ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n)
                - ComplexNumber.partialSum(signedDiagonal, n),
            complexZero)
      by ComplexNumber.SequenceConverges.squeeze_zero(
             uVanishes := gapVanishes) as signedGapVanishes;
  -- Triangle = square − (square − triangle).
  ComplexNumber.SequenceConverges(
            (n : Natural) ↦
                -(ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n)
                  - ComplexNumber.partialSum(signedDiagonal, n)),
            -complexZero)
      by ComplexNumber.SequenceConverges.negate(
             s := (n : Natural) ↦
                 ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n)
                 - ComplexNumber.partialSum(signedDiagonal, n),
             sConverges := signedGapVanishes) as negatedSignedGapConverges;
  ComplexNumber.SequenceConverges(
            (n : Natural) ↦
                ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n)
                + -(ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n)
                    - ComplexNumber.partialSum(signedDiagonal, n)),
            aLimit * bLimit + -complexZero)
      by ComplexNumber.SequenceConverges.add(
             s := (n : Natural) ↦
                 ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n),
             t := (n : Natural) ↦
                 -(ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n)
                   - ComplexNumber.partialSum(signedDiagonal, n)),
             sConverges := productConverges,
             tConverges := negatedSignedGapConverges);
  aLimit * bLimit = aLimit * bLimit + -complexZero as limitSimplifies;
  ComplexNumber.SequenceConverges(
            (n : Natural) ↦
                ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n)
                + -(ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n)
                    - ComplexNumber.partialSum(signedDiagonal, n)),
            aLimit * bLimit)
      by substituting limitSimplifies as assembledAtProduct;
  ∀ (n : Natural).
        ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n)
              + -(ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n)
                  - ComplexNumber.partialSum(signedDiagonal, n))
          = ComplexNumber.partialSum(signedDiagonal, n)
      by (n : Natural) ↦ {
           ComplexNumber.partialSum(a, n) * ComplexNumber.partialSum(b, n)
                     + -(ComplexNumber.partialSum(a, n)
                             * ComplexNumber.partialSum(b, n)
                         - ComplexNumber.partialSum(signedDiagonal, n))
                 = ComplexNumber.partialSum(signedDiagonal, n);
           done
         };
  done by ComplexNumber.SequenceConverges.of_pointwise(
              t := ComplexNumber.partialSum(signedDiagonal),
              sConverges := assembledAtProduct)
}

-- ----------------------------------------------------------------------
-- The functional equation: exp(z + w) = exp(z) · exp(w). The partial
-- sums of the series at z + w ARE the Cauchy-product triangle sums
-- (termwise, by the binomial split), those converge to the product of
-- the limits by Mertens — the dominating absolute series is the REAL
-- exponential series at the modulus — and limits are unique.
theorem ComplexNumber.exponential_add (z w : ℂ)
        : ComplexNumber.exponential(z + w)
          = ComplexNumber.exponential(z) * ComplexNumber.exponential(w) := {
  -- The absolute series converge: the modulus of the k-th term IS the
  -- real exponential term at the modulus.
  choose zAbsoluteLimit such that Real.SequenceConverges(Real.partialSum(Real.exponentialTerm(abs(z))), zAbsoluteLimit)
      as zRealConverges from Real.exponential_series_convergent;
  choose wAbsoluteLimit such that Real.SequenceConverges(Real.partialSum(Real.exponentialTerm(abs(w))), wAbsoluteLimit)
      as wRealConverges from Real.exponential_series_convergent;
  ∀ (n : Natural).
        Real.partialSum(Real.exponentialTerm(abs(z)), n)
          = Real.partialSum(
                (k : Natural) ↦
                    abs(ComplexNumber.exponentialTerm(z, k)),
                n)
      by (n : Natural) ↦
           Real.partialSum_pointwise(
               Real.exponentialTerm(abs(z)),
               (k : Natural) ↦
                   abs(ComplexNumber.exponentialTerm(z, k)),
               (k : Natural) ↦ {
                 abs(ComplexNumber.exponentialTerm(z, k))
                       = Real.exponentialTerm(abs(z), k)
                     by ComplexNumber.modulus_exponentialTerm;
                 done
               },
               n);
  ∀ (n : Natural).
        Real.partialSum(Real.exponentialTerm(abs(w)), n)
          = Real.partialSum(
                (k : Natural) ↦
                    abs(ComplexNumber.exponentialTerm(w, k)),
                n)
      by (n : Natural) ↦
           Real.partialSum_pointwise(
               Real.exponentialTerm(abs(w)),
               (k : Natural) ↦
                   abs(ComplexNumber.exponentialTerm(w, k)),
               (k : Natural) ↦ {
                 abs(ComplexNumber.exponentialTerm(w, k))
                       = Real.exponentialTerm(abs(w), k)
                     by ComplexNumber.modulus_exponentialTerm;
                 done
               },
               n);
  Real.SequenceConverges(
            Real.partialSum(
                (k : Natural) ↦
                    abs(ComplexNumber.exponentialTerm(z, k))),
            zAbsoluteLimit)
      by Real.SequenceConverges.of_pointwise(
             s := Real.partialSum(Real.exponentialTerm(abs(z))),
             t := Real.partialSum(
                 (k : Natural) ↦
                     abs(ComplexNumber.exponentialTerm(z, k))),
             sConverges := zRealConverges) as zAbsolutelyConverges;
  Real.SequenceConverges(
            Real.partialSum(
                (k : Natural) ↦
                    abs(ComplexNumber.exponentialTerm(w, k))),
            wAbsoluteLimit)
      by Real.SequenceConverges.of_pointwise(
             s := Real.partialSum(Real.exponentialTerm(abs(w))),
             t := Real.partialSum(
                 (k : Natural) ↦
                     abs(ComplexNumber.exponentialTerm(w, k))),
             sConverges := wRealConverges) as wAbsolutelyConverges;
  -- The signed series converge to the two exponentials.
  ComplexNumber.SequenceConverges(
            ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z)),
            ComplexNumber.exponential(z))
      by ComplexNumber.exponential_converges;
  ComplexNumber.SequenceConverges(
            ComplexNumber.partialSum(ComplexNumber.exponentialTerm(w)),
            ComplexNumber.exponential(w))
      by ComplexNumber.exponential_converges;
  -- Mertens: the triangle sums converge to the product.
  ComplexNumber.SequenceConverges(
            ComplexNumber.partialSum(
                (k : Natural) ↦
                    ComplexNumber.partialSum(
                        (i : Natural) ↦
                            ComplexNumber.exponentialTerm(z, i)
                            * ComplexNumber.exponentialTerm(w, Natural.monus(k, i)),
                        1 + k)),
            ComplexNumber.exponential(z) * ComplexNumber.exponential(w))
      by ComplexNumber.cauchy_product_converges(
             aAbsolutelyConverges := zAbsolutelyConverges,
             bAbsolutelyConverges := wAbsolutelyConverges) as triangleConverges;
  -- The triangle sums ARE the partial sums of the series at z + w.
  ∀ (n : Natural).
        ComplexNumber.partialSum(
              (k : Natural) ↦
                  ComplexNumber.partialSum(
                      (i : Natural) ↦
                          ComplexNumber.exponentialTerm(z, i)
                          * ComplexNumber.exponentialTerm(w, Natural.monus(k, i)),
                      1 + k),
              n)
          = ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z + w), n)
      by (n : Natural) ↦
           ComplexNumber.partialSum_pointwise(
               (k : Natural) ↦
                   ComplexNumber.partialSum(
                       (i : Natural) ↦
                           ComplexNumber.exponentialTerm(z, i)
                           * ComplexNumber.exponentialTerm(w, Natural.monus(k, i)),
                       1 + k),
               ComplexNumber.exponentialTerm(z + w),
               (k : Natural) ↦ {
                 ComplexNumber.exponentialTerm(z + w, k)
                       = ComplexNumber.partialSum(
                             (i : Natural) ↦
                                 ComplexNumber.exponentialTerm(z, i)
                                 * ComplexNumber.exponentialTerm(w,
                                       Natural.monus(k, i)),
                             1 + k)
                     by ComplexNumber.exponentialTerm_binomial_split;
                 done
               },
               n);
  ComplexNumber.SequenceConverges(
            ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z + w)),
            ComplexNumber.exponential(z) * ComplexNumber.exponential(w))
      by ComplexNumber.SequenceConverges.of_pointwise(
             s := ComplexNumber.partialSum(
                 (k : Natural) ↦
                     ComplexNumber.partialSum(
                         (i : Natural) ↦
                             ComplexNumber.exponentialTerm(z, i)
                             * ComplexNumber.exponentialTerm(w, Natural.monus(k, i)),
                         1 + k)),
             t := ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z + w)),
             sConverges := triangleConverges);
  ComplexNumber.SequenceConverges(
            ComplexNumber.partialSum(ComplexNumber.exponentialTerm(z + w)),
            ComplexNumber.exponential(z + w))
      by ComplexNumber.exponential_converges;
  done by ComplexNumber.SequenceConverges.unique
}

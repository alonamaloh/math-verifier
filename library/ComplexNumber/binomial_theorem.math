-- ComplexNumber/binomial_theorem.math
--
-- The binomial theorem on ℂ (Freek #44), as an instance of the generic
-- commutative-ring theorem `CommutativeRing.binomial_theorem`. As on ℝ,
-- the work is three bridges between ℂ's native operations and the
-- bundled-ring ones at `ComplexNumber.ring_bundle`: powers, the finite
-- sum, and the Natural coefficient (embedded ℕ → ℚ → ℝ → ℂ).

module ComplexNumber.binomial_theorem

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.monus
import Natural.binomial
import Natural.one_plus_induction
import Rational.basics
import Rational.embedding
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.ring_power
import Algebra.ring_from_natural
import Algebra.ring_summation
import Algebra.binomial
import Real.interface
import RingModulo.ring
import ComplexNumber.basics
import ComplexNumber.embedding
import ComplexNumber.reconstruction
import ComplexNumber.exponential
import ComplexNumber.series

-- The binomial coefficient C(n, k) as a complex number, embedded ℚ → ℝ → ℂ.
definition ComplexNumber.binomialCoefficient (n k : Natural) : ComplexNumber :=
  ComplexNumber.from_real(((Natural.binomial(n, k) : Rational) : Real))

-- ℂ as a bundled commutative ring (commutativity from the quotient base).
definition ComplexNumber.commutative_ring : CommutativeRing :=
  CommutativeRing.make(ComplexNumber.ring_bundle,
      RingModulo.multiply_commutative(Real.polynomial_commutative_ring,
          Complex.definingPolynomial))

-- The `1 + n` recursion unfold for ℂ's power.
theorem ComplexNumber.power_add_one (x : ComplexNumber) (n : Natural)
        : ComplexNumber.power(x, 1 + n) = x * ComplexNumber.power(x, n) :=
  done by substituting Natural.one_add

-- Bridge 1: the bundled-ring power at `ComplexNumber.ring_bundle` is ℂ's.
theorem ComplexNumber.power_eq_ring_power (x : ComplexNumber) (n : Natural)
        : Ring.power(ComplexNumber.ring_bundle, x, n) = ComplexNumber.power(x, n) :=
  by induction on n with IH {
    case base: done
    case step(k):
        calc Ring.power(ComplexNumber.ring_bundle, x, 1 + k)
           = x * Ring.power(ComplexNumber.ring_bundle, x, k)
           = x * ComplexNumber.power(x, k)                     by IH
           = ComplexNumber.power(x, 1 + k)
  }

-- Bridge 2: the bundled-ring sum is ℂ's partial sum over 1+n terms.
theorem ComplexNumber.partialSum_eq_ring_sum (f : Natural → ComplexNumber) (n : Natural)
        : Ring.Sum(ComplexNumber.ring_bundle, f, n) = ComplexNumber.partialSum(f, 1 + n) :=
  by induction on n with IH {
    case base:
        calc Ring.Sum(ComplexNumber.ring_bundle, f, 0)
           = f(0)
           = Ring.add(ComplexNumber.partialSum(f, 0), f(0))
           = ComplexNumber.partialSum(f, 1 + 0)               by ComplexNumber.partialSum_add_one
    case step(k):
        calc Ring.Sum(ComplexNumber.ring_bundle, f, 1 + k)
           = Ring.add(Ring.Sum(ComplexNumber.ring_bundle, f, k), f(1 + k))
                 by Ring.Sum.add_one(ComplexNumber.ring_bundle, f, k)
           = Ring.add(ComplexNumber.partialSum(f, 1 + k), f(1 + k))   by substituting IH
           = ComplexNumber.partialSum(f, 1 + (1 + k))                 by ComplexNumber.partialSum_add_one
  }

-- Bridge 3: the ring's Natural map is the ℕ → ℚ → ℝ → ℂ coefficient cast.
theorem ComplexNumber.from_natural_eq_ring_from_natural (m : Natural)
        : Ring.from_natural(ComplexNumber.ring_bundle, m)
          = ComplexNumber.from_real(((m : Rational) : Real)) :=
  by induction on m with IH {
    case base:
        calc Ring.from_natural(ComplexNumber.ring_bundle, 0)
           = ComplexNumber.from_real(Real.zero)               by ComplexNumber.from_real_zero
           = ComplexNumber.from_real(((0 : Rational) : Real))
    case step(k):
        calc Ring.from_natural(ComplexNumber.ring_bundle, 1 + k)
           = Ring.from_natural(ComplexNumber.ring_bundle, 1) + Ring.from_natural(ComplexNumber.ring_bundle, k)
           = Ring.one(ComplexNumber.ring_bundle) + Ring.from_natural(ComplexNumber.ring_bundle, k)
           = ComplexNumber.from_real(Real.one) + Ring.from_natural(ComplexNumber.ring_bundle, k)
           = ComplexNumber.from_real(Real.one)
             + ComplexNumber.from_real(((k : Rational) : Real))  by IH
           = ComplexNumber.from_real(Real.one + ((k : Rational) : Real))
           = ComplexNumber.from_real(((1 : Rational) : Real) + ((k : Rational) : Real))
           = ComplexNumber.from_real((((1 + k : Natural) : Rational) : Real))
                 by Real.from_natural_add_preserves
  }

-- The bundled-ring general term at ℂ is ℂ's binomial summand.
theorem ComplexNumber.binomialTerm_cast (a b : ComplexNumber) (n k : Natural)
        : Ring.binomialTerm(ComplexNumber.ring_bundle, a, b, n, k)
          = ComplexNumber.binomialCoefficient(n, k)
            * (ComplexNumber.power(a, k) * ComplexNumber.power(b, Natural.monus(n, k))) :=
  calc Ring.binomialTerm(ComplexNumber.ring_bundle, a, b, n, k)
     = Ring.from_natural(ComplexNumber.ring_bundle, Natural.binomial(n, k))
       * (Ring.power(ComplexNumber.ring_bundle, a, k)
          * Ring.power(ComplexNumber.ring_bundle, b, Natural.monus(n, k)))
     = ComplexNumber.binomialCoefficient(n, k)
       * (Ring.power(ComplexNumber.ring_bundle, a, k)
          * Ring.power(ComplexNumber.ring_bundle, b, Natural.monus(n, k)))
           by substituting ComplexNumber.from_natural_eq_ring_from_natural
     = ComplexNumber.binomialCoefficient(n, k)
       * (ComplexNumber.power(a, k) * ComplexNumber.power(b, Natural.monus(n, k)))
           by substituting ComplexNumber.power_eq_ring_power

-- ----------------------------------------------------------------------
-- Freek #44 on ℂ.
theorem ComplexNumber.binomial_theorem (a b : ComplexNumber) (n : Natural)
        : ComplexNumber.power(a + b, n)
          = ComplexNumber.partialSum(
                (k : Natural) ↦
                    ComplexNumber.binomialCoefficient(n, k)
                    * (ComplexNumber.power(a, k)
                       * ComplexNumber.power(b, Natural.monus(n, k))),
                1 + n) :=
  calc ComplexNumber.power(a + b, n)
     = Ring.power(ComplexNumber.ring_bundle, a + b, n)
           by ComplexNumber.power_eq_ring_power
     = Ring.Sum(ComplexNumber.ring_bundle,
           (k : Natural) ↦ Ring.binomialTerm(ComplexNumber.ring_bundle, a, b, n, k), n)
           by CommutativeRing.binomial_theorem(c := ComplexNumber.commutative_ring)
     = ComplexNumber.partialSum(
           (k : Natural) ↦ Ring.binomialTerm(ComplexNumber.ring_bundle, a, b, n, k), 1 + n)
           by ComplexNumber.partialSum_eq_ring_sum
     = ComplexNumber.partialSum(
           (k : Natural) ↦
               ComplexNumber.binomialCoefficient(n, k)
               * (ComplexNumber.power(a, k) * ComplexNumber.power(b, Natural.monus(n, k))),
           1 + n)
           by ComplexNumber.partialSum_pointwise(
                  pointwiseEqual := (k : Natural) ↦ ComplexNumber.binomialTerm_cast(a, b, n, k))

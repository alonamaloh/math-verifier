-- Polynomial/multiply_coefficient.math
--
-- The convolution formula for coefficients of a product, lifted to the
-- quotient: the k-th coefficient of p·q is Σ_{i=0}^{k} p_i · q_{k−i}.
-- Lifts Polynomial.nth_multiply through Quotient.induct_two.

module Polynomial.multiply_coefficient

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.monus
import Algebra.ring
import Algebra.ring_bundle
import Polynomial.basics
import Polynomial.multiplication
import Algebra.ring_summation
import Polynomial.degree

theorem Polynomial.coefficientOf_multiply (r : Ring)
        (p q : Polynomial(Ring.carrier(r), Ring.zero(r))) (k : ℕ)
        : (p * q)[k] = Ring.Sum(r, (i : ℕ) ↦ (p[i] * q[k ∸ i]), k) :=
  by_representatives p as a, q as b =>
      Polynomial.nth_multiply(r, a, b, k)

-- The constant term of a product is the product of the constant terms:
-- the convolution at index 0 has the single summand i = 0.
theorem Polynomial.coefficientOf_multiply_zero (r : Ring)
        (p q : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : (p * q)[0] = p[0] * q[0] :=
  (p * q)[0]
     = Ring.Sum(r, (i : ℕ) ↦ (p[i] * q[0 ∸ i]), 0)   by Polynomial.coefficientOf_multiply
     = p[0] * q[0 ∸ 0]                                by Ring.Sum.base
     = p[0] * q[0]

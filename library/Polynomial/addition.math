-- Polynomial/addition.math
--
-- Addition of polynomials over a bundled ring `r : Ring`. Coefficient
-- lists are added position-by-position; where one list runs out, the
-- other's coefficients carry through (correct because the missing
-- coefficients read as `Ring.zero(r)`, and `Ring.zero_add` /
-- `Ring.add_zero` absorb them). The bridge lemma `nth_add` says the
-- i-th coefficient of a sum is the sum of the i-th coefficients — the
-- one fact every downstream proof needs, and the place the bundled
-- ring's flattened laws pay off.

module Polynomial.addition

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Algebra.ring_bundle
import Polynomial.basics

-- The i-th coefficient of a coefficient list (zero past the end),
-- specialized to a bundled ring's carrier and zero. An abbreviation
-- that keeps the statements below readable.
definition Polynomial.coefficient {r : Ring}
        (p : Polynomial.Coefficients(Ring.carrier(r))) (index : Natural)
        : Ring.carrier(r) :=
  Polynomial.nth(Ring.carrier(r), Ring.zero(r), p, index)

-- Position-wise addition of coefficient lists. Recurses on the first
-- list; the second is split inside the cons case so a shorter list's
-- tail carries through unchanged.
definition Polynomial.Coefficients.add (r : Ring)
        : Polynomial.Coefficients(Ring.carrier(r))
          → Polynomial.Coefficients(Ring.carrier(r))
          → Polynomial.Coefficients(Ring.carrier(r))
  | Polynomial.Coefficients.nil, ys => ys
  | Polynomial.Coefficients.cons(a, restA), ys =>
      cases ys {
        | Polynomial.Coefficients.nil =>
            Polynomial.Coefficients.cons(Ring.carrier(r), a, restA)
        | Polynomial.Coefficients.cons(b, restB) =>
            Polynomial.Coefficients.cons(Ring.carrier(r),
                (a + b),
                Polynomial.Coefficients.add(r, restA, restB))
      }

-- Bridge: the i-th coefficient of p + q is the ring-sum of the i-th
-- coefficients. Structural recursion on the first list, with q and the
-- index universally quantified (the recursion calls itself at the tail
-- with a different q and index, so they cannot be fixed parameters).
-- The two base cases are exactly where `Ring.zero_add` / `Ring.add_zero`
-- absorb the missing coefficient.
theorem Polynomial.nth_add (r : Ring)
        : (p q : Polynomial.Coefficients(Ring.carrier(r)))
          → ∀ (index : Natural).
          Polynomial.coefficient(r, Polynomial.Coefficients.add(r, p, q), index)
            = (Polynomial.coefficient(r, p, index) + Polynomial.coefficient(r, q, index))
  | Polynomial.Coefficients.nil, q, index =>
      -- p + q = q and coefficient(nil, i) = 0, so the claim is
      -- coefficient(q, i) = 0 + coefficient(q, i).
      Equality.symmetry(?, ?,
          Ring.zero_add(r, Polynomial.coefficient(r, q, index)))
  | Polynomial.Coefficients.cons(a, restA), q, index =>
      cases q {
        | Polynomial.Coefficients.nil =>
            -- p + nil = p and coefficient(nil, i) = 0, so the claim is
            -- coefficient(p, i) = coefficient(p, i) + 0.
            Equality.symmetry(?, ?,
                Ring.add_zero(r,
                    Polynomial.coefficient(r,
                        Polynomial.Coefficients.cons(Ring.carrier(r), a, restA),
                        index)))
        | Polynomial.Coefficients.cons(b, restB) =>
            cases index {
              | zero =>
                  reflexivity(Ring.carrier(r), (a + b))
              | successor(predecessor) =>
                  Polynomial.nth_add(r, restA, restB, predecessor)
            }
      }

-- Coefficient-list addition respects the equivalence: equal-as-functions
-- inputs give equal-as-functions outputs. Pointwise in the index via
-- `nth_add` and the two hypotheses.
theorem Polynomial.Coefficients.add_respects (r : Ring)
        (p pPrime q qPrime : Polynomial.Coefficients(Ring.carrier(r)))
        (firstEqual
            : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r), p, pPrime))
        (secondEqual
            : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r), q, qPrime))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.add(r, p, q),
              Polynomial.Coefficients.add(r, pPrime, qPrime)) :=
  (index : Natural) ↦
      Polynomial.coefficient(r, Polynomial.Coefficients.add(r, p, q), index)
         = (Polynomial.coefficient(r, p, index) + Polynomial.coefficient(r, q, index))
         = (Polynomial.coefficient(r, pPrime, index) + Polynomial.coefficient(r, q, index))
               by firstEqual(index)
         = (Polynomial.coefficient(r, pPrime, index) + Polynomial.coefficient(r, qPrime, index))
               by secondEqual(index)
         = Polynomial.coefficient(r, Polynomial.Coefficients.add(r, pPrime, qPrime), index)

-- ----------------------------------------------------------------------
-- Lift coefficient-list addition to the quotient. Two lifts (one per
-- argument), mirroring Integer.add / IntegerMod.add. Short Quotient
-- forms throughout — relation/type inference recovers T, R, U from the
-- expected `Polynomial(...)` type and the respect proofs.

-- Add the coefficient-list representatives; well-defined in each argument
-- because Coefficients.add respects extensional equality (reflexivity on
-- the held-fixed side).
definition Polynomial.add {r : Ring}
        : Polynomial(Ring.carrier(r), Ring.zero(r))
          → Polynomial(Ring.carrier(r), Ring.zero(r))
          → Polynomial(Ring.carrier(r), Ring.zero(r))
  by representatives a, b ↦
       Polynomial.make(Ring.carrier(r), Ring.zero(r),
           Polynomial.Coefficients.add(r, a, b))
  well_defined by
    (a a' b : Polynomial.Coefficients(Ring.carrier(r)))
        (firstEqual
            : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r), a, a')) ↦
        Polynomial.Coefficients.add_respects(r, a, a', b, b, firstEqual,
            Polynomial.ExtensionallyEqual.reflexive(Ring.carrier(r), Ring.zero(r), b)),
    (a b b' : Polynomial.Coefficients(Ring.carrier(r)))
        (secondEqual
            : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r), b, b')) ↦
        Polynomial.Coefficients.add_respects(r, a, a, b, b',
            Polynomial.ExtensionallyEqual.reflexive(Ring.carrier(r), Ring.zero(r), a),
            secondEqual)

-- Operator overload: `p + q` over `Polynomial(...)` dispatches on the
-- `Polynomial` type head, recovering the implicit ring from the operands.
operator (+) on (Polynomial, Polynomial) := Polynomial.add

-- Polynomial/addition.math
--
-- Addition of polynomials over a bundled ring `r : Ring`. Coefficient
-- lists are added position-by-position; where one list runs out, the
-- other's coefficients carry through (correct because the missing
-- coefficients read as `Ring.zero(r)`, and `Ring.zero_add` /
-- `Ring.add_zero` absorb them). The bridge lemma `nth_add` says the
-- i-th coefficient of a sum is the sum of the i-th coefficients — the
-- one fact every downstream proof needs, and the place the bundled
-- ring's flattened laws pay off.

module Polynomial.addition

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.one_plus_induction
import Algebra.ring_bundle
import Polynomial.basics

-- The i-th coefficient of a coefficient list (zero past the end),
-- specialized to a bundled ring's carrier and zero. An abbreviation
-- that keeps the statements below readable.
definition Polynomial.coefficient {r : Ring}
        (p : Polynomial.Coefficients(Ring.carrier(r))) (index : ℕ)
        : Ring.carrier(r) :=
  Polynomial.nth(Ring.carrier(r), Ring.zero(r), p, index)

-- Coefficient lists index like their quotient: `coeffs[k]` is the k-th
-- entry, zero past the end.
operator ([]) on (Polynomial.Coefficients, Natural) := Polynomial.coefficient

-- Position-wise addition of coefficient lists. Recurses on the first
-- list, pairing its head with the head of the second and its tail with
-- the tail; where the second runs out, `head` reads 0 and `tail` stays
-- nil, so the first list's remaining coefficients carry through.
definition Polynomial.Coefficients.add {r : Ring}
        : Polynomial.Coefficients(Ring.carrier(r))
          → Polynomial.Coefficients(Ring.carrier(r))
          → Polynomial.Coefficients(Ring.carrier(r))
  | Polynomial.Coefficients.nil, ys => ys
  | Polynomial.Coefficients.cons(a, restA), ys =>
      Polynomial.Coefficients.cons(Ring.carrier(r),
          (a + Polynomial.Coefficients.head(Ring.carrier(r), Ring.zero(r), ys)),
          Polynomial.Coefficients.add(r, restA,
              Polynomial.Coefficients.tail(Ring.carrier(r), ys)))

-- Coefficient lists add like their quotient: `xs + ys` position-wise.
operator (+) on (Polynomial.Coefficients, Polynomial.Coefficients) := Polynomial.Coefficients.add

-- The equivalence the polynomial quotient divides by, at a bundled
-- ring: equal coefficients at every index (trailing zeros invisible).
-- The ring-specialized wrapper exists so `≈` can recover `{r}` from the
-- operands — `ExtensionallyEqual` itself takes the zero coefficient as
-- a value argument, which no operand type determines.
definition Polynomial.Coefficients.Equivalent {r : Ring}
        (p q : Polynomial.Coefficients(Ring.carrier(r))) : Proposition :=
  Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r), p, q)

-- Coefficient lists compare with `≈`: `xs ≈ ys` is extensional equality.
operator (≈) on (Polynomial.Coefficients, Polynomial.Coefficients) := Polynomial.Coefficients.Equivalent

-- Right identity: adding the empty list changes nothing. At a cons the
-- head reads 0 (absorbed by `Ring.add_zero`) and the tail recursion peels
-- the list; `add(nil, ys) = ys` is the left identity, definitional.
theorem Polynomial.Coefficients.add_nil_right (r : Ring)
        (p : Polynomial.Coefficients(Ring.carrier(r)))
        : (p + Polynomial.Coefficients.nil(Ring.carrier(r))) = p :=
  by induction on p with IH {
    case Polynomial.Coefficients.nil:
        reflexivity(Polynomial.Coefficients(Ring.carrier(r)), Polynomial.Coefficients.nil(Ring.carrier(r)))
    case Polynomial.Coefficients.cons(a, restA):
        Polynomial.Coefficients.cons(Ring.carrier(r), (a + Ring.zero(r)), (restA + Polynomial.Coefficients.nil(Ring.carrier(r))))
           = Polynomial.Coefficients.cons(Ring.carrier(r), a, (restA + Polynomial.Coefficients.nil(Ring.carrier(r))))
           = Polynomial.Coefficients.cons(Ring.carrier(r), a, restA)   by substituting IH
  }

-- Bridge: the i-th coefficient of p + q is the ring-sum of the i-th
-- coefficients. Structural recursion on the first list, with q and the
-- index universally quantified (the recursion calls itself at the tail
-- with a different q and index, so they cannot be fixed parameters).
-- At the nil list `nth_nil` supplies the absorbed zero coefficient; the
-- index split reads the head (`nth_cons_zero`) or drops to the tails
-- (`nth_cons_one_plus` / `nth_one_plus`), where the recursion applies.
theorem Polynomial.nth_add (r : Ring)
        (p : Polynomial.Coefficients(Ring.carrier(r)))
        : (q : Polynomial.Coefficients(Ring.carrier(r)))
          → ∀ (index : ℕ).
          (p + q)[index]
            = (p[index] + q[index]) :=
  by induction on p with IH {
    case Polynomial.Coefficients.nil:
        (q : Polynomial.Coefficients(Ring.carrier(r))) (index : ℕ) ↦ {
          Polynomial.Coefficients.nil(Ring.carrier(r))[index] = Ring.zero(r)   by Polynomial.nth_nil;
          (Polynomial.Coefficients.nil(Ring.carrier(r)) + q)[index]
             = q[index]
             = Ring.zero(r) + q[index]
             = Polynomial.Coefficients.nil(Ring.carrier(r))[index] + q[index]
        }
    case Polynomial.Coefficients.cons(a, restA):
        (q : Polynomial.Coefficients(Ring.carrier(r))) (index : ℕ) ↦ {
          let tail : Polynomial.Coefficients(Ring.carrier(r)) := Polynomial.Coefficients.tail(Ring.carrier(r), q);
          let cell : Polynomial.Coefficients(Ring.carrier(r)) := Polynomial.Coefficients.cons(Ring.carrier(r), a, restA);
          done by cases {
            case index = 0: done
            case index = 1 + j for some j: {
                cell[1 + j] = restA[j]   by Polynomial.nth_cons_one_plus;
                q[1 + j] = tail[j]   by Polynomial.nth_one_plus;
                (cell + q)[1 + j]
                   = (restA + tail)[j]   by Polynomial.nth_cons_one_plus
                   = (restA[j] + tail[j])   by IH(tail, j)
                   = (cell[1 + j] + q[1 + j])   by substitution
              }
          }
        }
  }

-- Coefficient-list addition respects the equivalence: equal-as-functions
-- inputs give equal-as-functions outputs. Pointwise in the index via
-- `nth_add` and the two hypotheses.
theorem Polynomial.Coefficients.add_respects (r : Ring)
        (p pPrime q qPrime : Polynomial.Coefficients(Ring.carrier(r)))
        (firstEqual : p ≈ pPrime) (secondEqual : q ≈ qPrime)
        : (p + q) ≈ (pPrime + qPrime) :=
  (index : ℕ) ↦
      (p + q)[index]
         = (p[index] + q[index])
         = (pPrime[index] + q[index])   by firstEqual(index)
         = (pPrime[index] + qPrime[index])   by secondEqual(index)
         = (pPrime + qPrime)[index]

-- ----------------------------------------------------------------------
-- Lift coefficient-list addition to the quotient. Two lifts (one per
-- argument), mirroring Integer.add / IntegerMod.add. Short Quotient
-- forms throughout — relation/type inference recovers T, R, U from the
-- expected `Polynomial(...)` type and the respect proofs.

-- Add the coefficient-list representatives; well-defined in each argument
-- because Coefficients.add respects extensional equality (reflexivity on
-- the held-fixed side).
definition Polynomial.add {r : Ring}
        : Polynomial(Ring.carrier(r), Ring.zero(r))
          → Polynomial(Ring.carrier(r), Ring.zero(r))
          → Polynomial(Ring.carrier(r), Ring.zero(r))
  by representatives a, b ↦
       Polynomial.make(Ring.carrier(r), Ring.zero(r), (a + b))
  well_defined by
    (a a' b : Polynomial.Coefficients(Ring.carrier(r))) (firstEqual : a ≈ a') ↦
        Polynomial.Coefficients.add_respects(r, a, a', b, b, firstEqual,
            Polynomial.ExtensionallyEqual.reflexive(Ring.carrier(r), Ring.zero(r), b)),
    (a b b' : Polynomial.Coefficients(Ring.carrier(r))) (secondEqual : b ≈ b') ↦
        Polynomial.Coefficients.add_respects(r, a, a, b, b',
            Polynomial.ExtensionallyEqual.reflexive(Ring.carrier(r), Ring.zero(r), a),
            secondEqual)

-- Operator overload: `p + q` over `Polynomial(...)` dispatches on the
-- `Polynomial` type head, recovering the implicit ring from the operands.
operator (+) on (Polynomial, Polynomial) := Polynomial.add

-- Polynomial/negation.math
--
-- The zero polynomial and negation, over a bundled ring `r : Ring`.
-- Negation maps each coefficient through `Ring.negate`; its bridge
-- lemma `nth_negate` says the i-th coefficient of −p is the negation of
-- the i-th coefficient of p (the empty-list base case is where
-- `Ring.negate_zero` is needed). Negation respects the equivalence, so
-- it lifts to `Polynomial.negate`.

module Polynomial.negation

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Algebra.ring_bundle
import Polynomial.basics
import Polynomial.addition

-- The zero polynomial: the empty coefficient list. Its coefficient at
-- every index is `Ring.zero(r)` definitionally.
definition Polynomial.zero (r : Ring) : Polynomial(Ring.carrier(r), Ring.zero(r)) :=
  Polynomial.make(Ring.carrier(r), Ring.zero(r),
      Polynomial.Coefficients.nil(Ring.carrier(r)))

-- The coefficient list of the one polynomial: the single entry
-- `Ring.one(r)` — names the `cons(one, nil)` wall the rep-level
-- multiplicative-identity statements otherwise spell out.
definition Polynomial.Coefficients.one {r : Ring}
        : Polynomial.Coefficients(Ring.carrier(r)) :=
  Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
      Polynomial.Coefficients.nil(Ring.carrier(r)))

-- The one polynomial: the single coefficient `Ring.one(r)`.
definition Polynomial.one (r : Ring) : Polynomial(Ring.carrier(r), Ring.zero(r)) :=
  Polynomial.make(Ring.carrier(r), Ring.zero(r), Polynomial.Coefficients.one(r))

-- Coefficient-wise negation.
definition Polynomial.Coefficients.negate {r : Ring}
        : Polynomial.Coefficients(Ring.carrier(r))
          → Polynomial.Coefficients(Ring.carrier(r))
  | Polynomial.Coefficients.nil =>
      Polynomial.Coefficients.nil(Ring.carrier(r))
  | Polynomial.Coefficients.cons(a, rest) =>
      Polynomial.Coefficients.cons(Ring.carrier(r),
          (- a),
          Polynomial.Coefficients.negate(r, rest))

-- Bridge: the i-th coefficient of −p is the negation of the i-th
-- coefficient of p. The nil case needs `Ring.negate_zero`.
theorem Polynomial.nth_negate (r : Ring)
        (p : Polynomial.Coefficients(Ring.carrier(r)))
        : ∀ (index : Natural).
          (- p)[index]
            = (- p[index]) :=
  by induction on p with IH {
    case Polynomial.Coefficients.nil:
        (index : Natural) ↦
          (- Polynomial.Coefficients.nil(Ring.carrier(r)))[index]
             = Ring.zero(r)                                             by Polynomial.nth_nil
             = (- Ring.zero(r))                                         by Ring.negate_zero
             = (- Polynomial.Coefficients.nil(Ring.carrier(r))[index])  by substituting Polynomial.nth_nil
    case Polynomial.Coefficients.cons(a, rest):
        (index : Natural) ↦
          done by cases {
            case index = 0: reflexivity(Ring.carrier(r), (- a))
            case index = 1 + predecessor for some predecessor:
                (- Polynomial.Coefficients.cons(Ring.carrier(r), a, rest))[1 + predecessor]
                   = (- rest)[predecessor]
                   = (- rest[predecessor])   by IH(predecessor)
                   = (- Polynomial.Coefficients.cons(Ring.carrier(r), a, rest)[1 + predecessor])
          }
  }

-- Negation respects the equivalence (pointwise via the bridge).
theorem Polynomial.Coefficients.negate_respects (r : Ring)
        (p pPrime : Polynomial.Coefficients(Ring.carrier(r))) (equal : p ≈ pPrime)
        : (- p) ≈ (- pPrime) :=
  (index : Natural) ↦
      (- p)[index]
         = (- p[index])
         = (- pPrime[index])   by equal(index)
         = (- pPrime)[index]

-- Lift to the quotient. A single lift (negation is unary).
definition Polynomial.negate {r : Ring}
        : Polynomial(Ring.carrier(r), Ring.zero(r))
          → Polynomial(Ring.carrier(r), Ring.zero(r))
  by representatives p ↦
       Polynomial.make(Ring.carrier(r), Ring.zero(r), (- p))
  well_defined by (p pPrime : Polynomial.Coefficients(Ring.carrier(r))) (equal : p ≈ pPrime) ↦
          Polynomial.Coefficients.negate_respects(r, p, pPrime, equal)

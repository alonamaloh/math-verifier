-- Polynomial/division.math
--
-- Division with remainder for polynomials over a field, stated
-- existentially: for any dividend g and a divisor f whose leading
-- coefficient (at index degreeF) is invertible,
--   ∃ q rem. g = q·f + rem  ∧  deg(rem) < degreeF.
--
-- Because everything is existential we never build an inverse function:
-- the single invertibility witness for f's leading coefficient is
-- enough. The algorithm is the schoolbook one — repeatedly subtract
-- (leadingCoeff(g)·leadingCoeff(f)⁻¹)·x^{deg g − degreeF}·f to kill the
-- top term — run as an induction on the "excess" e in the degree bound
-- degreeF + e. At excess 0 the dividend is already below degreeF and is
-- its own remainder; each successor step kills one leading term and
-- recurses with the excess reduced by one.

module Polynomial.division

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.subtraction
import Natural.arithmetic
import Natural.monus
import Natural.decide
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Polynomial.basics
import Polynomial.addition
import Polynomial.negation
import Polynomial.additive_group
import Polynomial.multiplication
import Polynomial.multiply_laws
import Polynomial.instances
import Polynomial.degree
import Polynomial.multiply_coefficient
import Polynomial.division_support
import Polynomial.monomial

-- ----------------------------------------------------------------------
-- Every polynomial has SOME degree bound: the length of any
-- representative list works, since coefficients past the end are zero.

definition Polynomial.Coefficients.length (R : Type(0))
        : Polynomial.Coefficients(R) → Natural
  | Polynomial.Coefficients.nil => 0
  | Polynomial.Coefficients.cons(c, rest) =>
      successor(Polynomial.Coefficients.length(R, rest))

theorem Polynomial.coefficient_vanishes_beyond_length (r : Ring)
        : (p : Polynomial.Coefficients(Ring.carrier(r))) → (i : Natural)
          → Polynomial.Coefficients.length(Ring.carrier(r), p) ≤ i
          → Polynomial.coefficient(p, i) = Ring.zero(r)
  | Polynomial.Coefficients.nil =>
      (i : Natural) (lengthLessOrEqual : 0 ≤ i) ↦
          reflexivity(Ring.carrier(r), Ring.zero(r))
  | Polynomial.Coefficients.cons(coefficientValue, rest) =>
      (i : Natural)
               (lengthLessOrEqual
                   : successor(Polynomial.Coefficients.length(Ring.carrier(r), rest)) ≤ i) ↦
          cases i refining lengthLessOrEqual {
            | zero =>
                absurd(Natural.not_less_or_equal_successor_zero(
                    Polynomial.Coefficients.length(Ring.carrier(r), rest),
                    lengthLessOrEqual))
            | successor(iPredecessor) =>
                Polynomial.coefficient_vanishes_beyond_length(r, rest, iPredecessor,
                    Natural.successor_le_successor_invert(
                        Polynomial.Coefficients.length(Ring.carrier(r), rest),
                        iPredecessor, lengthLessOrEqual))
          }

theorem Polynomial.exists_degree_bound (r : Ring)
        (g : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : ∃ (n : Natural). Polynomial.DegreeLessThan(r, g, n) :=
  cases g { | coefficients =>
    witness Polynomial.Coefficients.length(Ring.carrier(r), coefficients) with
        (i : Natural)
                 (lengthLessOrEqual
                     : Polynomial.Coefficients.length(Ring.carrier(r), coefficients) ≤ i) ↦
            Polynomial.coefficient_vanishes_beyond_length(r, coefficients, i,
                lengthLessOrEqual) }

-- ----------------------------------------------------------------------
-- The division step, run as an induction on the excess `e` of the bound
-- degreeF + e.

theorem Polynomial.divide_by_excess (r : Ring)
        (commutativity
            : (x y : Ring.carrier(r)) → (x * y) = (y * x))
        (f : Polynomial(Ring.carrier(r), Ring.zero(r)))
        (degreeF : Natural)
        (fDegreeBound : Polynomial.DegreeLessThan(r, f, successor(degreeF)))
        (leadingInverseValue : Ring.carrier(r))
        (leadingInverseEquation
            : (Polynomial.coefficientOf(f, degreeF) * leadingInverseValue) = Ring.one(r))
        (e : Natural)
        : (dividend : Polynomial(Ring.carrier(r), Ring.zero(r)))
          → Polynomial.DegreeLessThan(r, dividend, degreeF + e)
          → ∃ (quotient remainder : Polynomial(Ring.carrier(r), Ring.zero(r))).
              dividend = Polynomial.add(r, Polynomial.multiply(r, quotient, f), remainder)
              ∧ Polynomial.DegreeLessThan(r, remainder, degreeF) :=
  by_induction on e with IH {
    case zero:
      (dividend : Polynomial(Ring.carrier(r), Ring.zero(r)))
               (dividendBound : Polynomial.DegreeLessThan(r, dividend, degreeF + 0)) ↦ {
        claim multiplyZero
            : Polynomial.multiply(r, Polynomial.zero(r), f) = Polynomial.zero(r)
            by Ring.zero_multiply_left(Polynomial.ring(r), f);
        ⟨Polynomial.zero(r), dividend,
         Equality.symmetry(
             calc Polynomial.add(r, Polynomial.multiply(r, Polynomial.zero(r), f), dividend)
                = Polynomial.add(r, Polynomial.zero(r), dividend)
                = dividend),
         rewrite(Natural.add_zero(degreeF), dividendBound)⟩
      }
    case successor(ePredecessor):
      (dividend : Polynomial(Ring.carrier(r), Ring.zero(r)))
               (dividendBound
                   : Polynomial.DegreeLessThan(r, dividend, degreeF + successor(ePredecessor))) ↦ {
        claim dividendBoundSuccessor
            : Polynomial.DegreeLessThan(r, dividend, successor(degreeF + ePredecessor))
            by rewrite(Natural.add_successor(degreeF, ePredecessor), dividendBound);
        let leadingCoefficient : Ring.carrier(r) :=
            Polynomial.coefficientOf(dividend, degreeF + ePredecessor);
        let quotientStep : Polynomial(Ring.carrier(r), Ring.zero(r)) :=
            Polynomial.monomial(r, (leadingCoefficient * leadingInverseValue),
                ePredecessor);
        let stepProduct : Polynomial(Ring.carrier(r), Ring.zero(r)) :=
            Polynomial.multiply(r, quotientStep, f);
        let residual : Polynomial(Ring.carrier(r), Ring.zero(r)) :=
            Polynomial.add(r, dividend, Polynomial.negate(r, stepProduct));

        -- The inverse from the other side (the ring is commutative).
        claim inverseLeadingEquation
            : (leadingInverseValue * Polynomial.coefficientOf(f, degreeF))
              = Ring.one(r)
            by calc (leadingInverseValue * Polynomial.coefficientOf(f, degreeF))
                  = (Polynomial.coefficientOf(f, degreeF) * leadingInverseValue)
                        by commutativity(leadingInverseValue, Polynomial.coefficientOf(f, degreeF))
                  = Ring.one(r);

        -- The step product agrees with the dividend at every index ≥ the
        -- top index (degreeF + ePredecessor): at the top index both equal
        -- the leading coefficient; strictly above, both vanish.
        claim productAgreesWithDividend
            : (i : Natural) → degreeF + ePredecessor ≤ i
              → Polynomial.coefficientOf(stepProduct, i)
                = Polynomial.coefficientOf(dividend, i)
            by (i : Natural) (topLessOrEqual : degreeF + ePredecessor ≤ i) ↦
                decide i = degreeF + ePredecessor {
                  | yes indexIsTop =>
                      calc Polynomial.coefficientOf(stepProduct, i)
                         = Polynomial.coefficientOf(stepProduct, degreeF + ePredecessor)
                         = ((leadingCoefficient * leadingInverseValue) * Polynomial.coefficientOf(f, Natural.monus(degreeF + ePredecessor, ePredecessor)))
                               by Polynomial.coefficientOf_monomial_multiply(r,
                                      (leadingCoefficient * leadingInverseValue),
                                      f, ePredecessor, degreeF + ePredecessor,
                                      Natural.less_or_equal_add_left(ePredecessor, degreeF))
                         = ((leadingCoefficient * leadingInverseValue) * Polynomial.coefficientOf(f, degreeF))
                         = (leadingCoefficient * (leadingInverseValue * Polynomial.coefficientOf(f, degreeF)))
                         = (leadingCoefficient * Ring.one(r))
                         = leadingCoefficient
                         = Polynomial.coefficientOf(dividend, degreeF + ePredecessor)
                         = Polynomial.coefficientOf(dividend, i)
                  | no indexNotTop => {
                      claim successorLessOrEqual : successor(degreeF + ePredecessor) ≤ i
                          by Natural.less_or_equal_not_equal_successor(
                                 degreeF + ePredecessor, i, topLessOrEqual, indexNotTop);
                      claim predecessorLessOrEqualI : ePredecessor ≤ i
                          by LessOrEqual.transitive(ePredecessor, degreeF + ePredecessor, i,
                                 Natural.less_or_equal_predecessor_less_or_equal(
                                     degreeF + ePredecessor, i, successorLessOrEqual),
                                 Natural.less_or_equal_add_left(ePredecessor, degreeF));
                      claim stepZero : Polynomial.coefficientOf(stepProduct, i) = Ring.zero(r)
                          by calc Polynomial.coefficientOf(stepProduct, i)
                                = ((leadingCoefficient * leadingInverseValue) * Polynomial.coefficientOf(f, Natural.monus(i, ePredecessor)))
                                      by Polynomial.coefficientOf_monomial_multiply
                                = ((leadingCoefficient * leadingInverseValue) * Ring.zero(r))
                                      by fDegreeBound(Natural.monus(i, ePredecessor),
                                             Natural.degree_bound_helper(degreeF, ePredecessor, i,
                                                 successorLessOrEqual))
                                = Ring.zero(r);
                      calc Polynomial.coefficientOf(stepProduct, i)
                         = Ring.zero(r)
                         = Polynomial.coefficientOf(dividend, i)
                               by Equality.symmetry(
                                      dividendBoundSuccessor(i, successorLessOrEqual))
                    }
                };

        -- Hence the residual drops below the top index.
        claim residualBound
            : Polynomial.DegreeLessThan(r, residual, degreeF + ePredecessor)
            by (i : Natural) (topLessOrEqual : degreeF + ePredecessor ≤ i) ↦
                calc Polynomial.coefficientOf(residual, i)
                   = (Polynomial.coefficientOf(dividend, i) + Polynomial.coefficientOf(Polynomial.negate(r, stepProduct), i))
                         by Polynomial.coefficientOf_add
                   = (Polynomial.coefficientOf(dividend, i) + Ring.negate(r, Polynomial.coefficientOf(stepProduct, i)))
                   = (Polynomial.coefficientOf(dividend, i) + Ring.negate(r, Polynomial.coefficientOf(dividend, i)))
                         by productAgreesWithDividend(i, topLessOrEqual)
                   = Ring.zero(r);

        obtain ⟨quotientRest, remainderRest, restEquation, remainderRestBound⟩
            from IH(residual, residualBound);

        claim reconstruct : Polynomial.add(r, stepProduct, residual) = dividend
            by calc Polynomial.add(r, stepProduct,
                        Polynomial.add(r, dividend, Polynomial.negate(r, stepProduct)))
                  = Polynomial.add(r, Polynomial.add(r, stepProduct, dividend),
                        Polynomial.negate(r, stepProduct))
                  = Polynomial.add(r, Polynomial.add(r, dividend, stepProduct),
                        Polynomial.negate(r, stepProduct))
                  = Polynomial.add(r, dividend,
                        Polynomial.add(r, stepProduct, Polynomial.negate(r, stepProduct)))
                  = Polynomial.add(r, dividend, Polynomial.zero(r))
                  = dividend;

        ⟨Polynomial.add(r, quotientStep, quotientRest), remainderRest,
         calc dividend
            = Polynomial.add(r, stepProduct, residual)
            = Polynomial.add(r, stepProduct,
                  Polynomial.add(r, Polynomial.multiply(r, quotientRest, f), remainderRest))
            = Polynomial.add(r,
                  Polynomial.add(r, stepProduct, Polynomial.multiply(r, quotientRest, f)),
                  remainderRest)
            = Polynomial.add(r,
                  Polynomial.multiply(r, Polynomial.add(r, quotientStep, quotientRest), f),
                  remainderRest)
                  by Equality.symmetry(Polynomial.multiply_distributivity_right(r,
                         quotientStep, quotientRest, f)),
         remainderRestBound⟩
      }
  }

-- ----------------------------------------------------------------------
-- Division with remainder: pick any degree bound for the dividend and
-- run the excess induction.

theorem Polynomial.division_with_remainder (r : Ring)
        (commutativity
            : (x y : Ring.carrier(r)) → (x * y) = (y * x))
        (f : Polynomial(Ring.carrier(r), Ring.zero(r)))
        (degreeF : Natural)
        (fDegreeBound : Polynomial.DegreeLessThan(r, f, successor(degreeF)))
        (leadingInverse
            : ∃ (inverse : Ring.carrier(r)).
                (Polynomial.coefficientOf(f, degreeF) * inverse) = Ring.one(r))
        (g : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : ∃ (quotient remainder : Polynomial(Ring.carrier(r), Ring.zero(r))).
            g = Polynomial.add(r, Polynomial.multiply(r, quotient, f), remainder)
            ∧ Polynomial.DegreeLessThan(r, remainder, degreeF) := {
  obtain ⟨leadingInverseValue, leadingInverseEquation⟩ from leadingInverse;
  obtain ⟨bound, gBound⟩ from Polynomial.exists_degree_bound(r, g);
  Polynomial.divide_by_excess(r, commutativity, f, degreeF, fDegreeBound,
      leadingInverseValue, leadingInverseEquation, bound, g,
      Polynomial.DegreeLessThan.weaken(r, g, bound, degreeF + bound,
          Natural.less_or_equal_add_left(bound, degreeF), gBound))
}

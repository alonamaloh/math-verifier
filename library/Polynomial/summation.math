-- Polynomial/summation.math
--
-- A finite summation operator `Sum(r, f, n) = f(0) + f(1) + … + f(n)`
-- over a bundled ring, with the two lemmas the convolution bridge for
-- polynomial multiplication needs: the sum of the zero function is
-- zero, and the "peel the first term" reindexing
--   Σ_{i=0}^{n+1} f(i) = f(0) + Σ_{j=0}^{n} f(j+1).

module Polynomial.summation

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Algebra.ring_bundle

-- Σ_{i=0}^{n} f(i). Recurses on the upper bound, adding the new top
-- term on the right.
definition Polynomial.Sum (r : Ring) (f : Natural → Ring.carrier(r))
        : Natural → Ring.carrier(r)
  | zero          => f(0)
  | successor(k)  => Ring.add(r, Polynomial.Sum(r, f, k), f(successor(k)))

-- The sum of the constant-zero function is zero.
theorem Polynomial.Sum.zero (r : Ring) (n : Natural)
        : Polynomial.Sum(r, function (i : Natural) => Ring.zero(r), n)
          = Ring.zero(r) :=
  by_induction on n with IH {
    case zero: reflexivity(Ring.carrier(r), Ring.zero(r))
    case successor(k):
        calc Polynomial.Sum(r, function (i : Natural) => Ring.zero(r), successor(k))
           = Ring.add(r,
                 Polynomial.Sum(r, function (i : Natural) => Ring.zero(r), k),
                 Ring.zero(r))
                 by reflexivity(Ring.carrier(r),
                        Ring.add(r,
                            Polynomial.Sum(r, function (i : Natural) => Ring.zero(r), k),
                            Ring.zero(r)))
           = Ring.add(r, Ring.zero(r), Ring.zero(r))   by IH
           = Ring.zero(r)   by Ring.zero_add(r, Ring.zero(r))
  }

-- Peel the first term: Σ_{i=0}^{n+1} f(i) = f(0) + Σ_{j=0}^{n} f(j+1).
-- The workhorse for the convolution recursion (it exposes the i=0
-- term and reindexes the rest to start from the tail of the list).
theorem Polynomial.Sum.shift (r : Ring) (f : Natural → Ring.carrier(r))
        (n : Natural)
        : Polynomial.Sum(r, f, successor(n))
          = Ring.add(r, f(0),
                Polynomial.Sum(r, function (j : Natural) => f(successor(j)), n)) :=
  by_induction on n with IH {
    case zero:
        reflexivity(Ring.carrier(r), Ring.add(r, f(0), f(successor(0))))
    case successor(k):
        calc Polynomial.Sum(r, f, successor(successor(k)))
           = Ring.add(r, Polynomial.Sum(r, f, successor(k)), f(successor(successor(k))))
                 by reflexivity(Ring.carrier(r),
                        Ring.add(r, Polynomial.Sum(r, f, successor(k)),
                            f(successor(successor(k)))))
           = Ring.add(r,
                 Ring.add(r, f(0),
                     Polynomial.Sum(r, function (j : Natural) => f(successor(j)), k)),
                 f(successor(successor(k))))
                 by IH
           = Ring.add(r, f(0),
                 Ring.add(r,
                     Polynomial.Sum(r, function (j : Natural) => f(successor(j)), k),
                     f(successor(successor(k)))))
                 by Ring.add_associative(r, f(0),
                        Polynomial.Sum(r, function (j : Natural) => f(successor(j)), k),
                        f(successor(successor(k))))
           = Ring.add(r, f(0),
                 Polynomial.Sum(r, function (j : Natural) => f(successor(j)), successor(k)))
                 by reflexivity(Ring.carrier(r),
                        Ring.add(r, f(0),
                            Polynomial.Sum(r, function (j : Natural) => f(successor(j)), successor(k))))
  }

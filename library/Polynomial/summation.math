-- Polynomial/summation.math
--
-- A finite summation operator `Sum(r, f, n) = f(0) + f(1) + … + f(n)`
-- over a bundled ring, with the two lemmas the convolution bridge for
-- polynomial multiplication needs: the sum of the zero function is
-- zero, and the "peel the first term" reindexing
--   Σ_{i=0}^{n+1} f(i) = f(0) + Σ_{j=0}^{n} f(j+1).

module Polynomial.summation

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.monus
import Algebra.ring_bundle

-- Σ_{i=0}^{n} f(i). Recurses on the upper bound, adding the new top
-- term on the right.
definition Polynomial.Sum (r : Ring) (f : Natural → Ring.carrier(r))
        : Natural → Ring.carrier(r)
  | zero          => f(0)
  | successor(k)  => Ring.add(r, Polynomial.Sum(r, f, k), f(successor(k)))

-- The sum of the constant-zero function is zero.
theorem Polynomial.Sum.zero (r : Ring) (n : Natural)
        : Polynomial.Sum(r, function (i : Natural) => Ring.zero(r), n)
          = Ring.zero(r) :=
  by_induction on n with IH {
    case zero: reflexivity(Ring.carrier(r), Ring.zero(r))
    case successor(k):
        calc Polynomial.Sum(r, function (i : Natural) => Ring.zero(r), successor(k))
           = Ring.add(r,
                 Polynomial.Sum(r, function (i : Natural) => Ring.zero(r), k),
                 Ring.zero(r))
                 by reflexivity(Ring.carrier(r),
                        Ring.add(r,
                            Polynomial.Sum(r, function (i : Natural) => Ring.zero(r), k),
                            Ring.zero(r)))
           = Ring.add(r, Ring.zero(r), Ring.zero(r))   by IH
           = Ring.zero(r)   by Ring.zero_add(r, Ring.zero(r))
  }

-- Pointwise-equal functions have equal sums.
theorem Polynomial.Sum.extensional (r : Ring)
        (f g : Natural → Ring.carrier(r))
        (pointwise : (i : Natural) → f(i) = g(i))
        (n : Natural)
        : Polynomial.Sum(r, f, n) = Polynomial.Sum(r, g, n) :=
  by_induction on n with IH {
    case zero: pointwise(0)
    case successor(k):
        calc Polynomial.Sum(r, f, successor(k))
           = Ring.add(r, Polynomial.Sum(r, f, k), f(successor(k)))
                 by reflexivity(Ring.carrier(r),
                        Ring.add(r, Polynomial.Sum(r, f, k), f(successor(k))))
           = Ring.add(r, Polynomial.Sum(r, g, k), f(successor(k)))   by IH
           = Ring.add(r, Polynomial.Sum(r, g, k), g(successor(k)))   by pointwise(successor(k))
           = Polynomial.Sum(r, g, successor(k))
                 by reflexivity(Ring.carrier(r),
                        Ring.add(r, Polynomial.Sum(r, g, k), g(successor(k))))
  }

-- Peel the first term: Σ_{i=0}^{n+1} f(i) = f(0) + Σ_{j=0}^{n} f(j+1).
-- The workhorse for the convolution recursion (it exposes the i=0
-- term and reindexes the rest to start from the tail of the list).
theorem Polynomial.Sum.shift (r : Ring) (f : Natural → Ring.carrier(r))
        (n : Natural)
        : Polynomial.Sum(r, f, successor(n))
          = Ring.add(r, f(0),
                Polynomial.Sum(r, function (j : Natural) => f(successor(j)), n)) :=
  by_induction on n with IH {
    case zero:
        reflexivity(Ring.carrier(r), Ring.add(r, f(0), f(successor(0))))
    case successor(k):
        calc Polynomial.Sum(r, f, successor(successor(k)))
           = Ring.add(r, Polynomial.Sum(r, f, successor(k)), f(successor(successor(k))))
                 by reflexivity(Ring.carrier(r),
                        Ring.add(r, Polynomial.Sum(r, f, successor(k)),
                            f(successor(successor(k)))))
           = Ring.add(r,
                 Ring.add(r, f(0),
                     Polynomial.Sum(r, function (j : Natural) => f(successor(j)), k)),
                 f(successor(successor(k))))
                 by IH
           = Ring.add(r, f(0),
                 Ring.add(r,
                     Polynomial.Sum(r, function (j : Natural) => f(successor(j)), k),
                     f(successor(successor(k)))))
                 by Ring.add_associative(r, f(0),
                        Polynomial.Sum(r, function (j : Natural) => f(successor(j)), k),
                        f(successor(successor(k))))
           = Ring.add(r, f(0),
                 Polynomial.Sum(r, function (j : Natural) => f(successor(j)), successor(k)))
                 by reflexivity(Ring.carrier(r),
                        Ring.add(r, f(0),
                            Polynomial.Sum(r, function (j : Natural) => f(successor(j)), successor(k))))
  }

-- Σ (f+g) = Σ f + Σ g. The successor step rearranges with the
-- four-term swap on the bundle.
theorem Polynomial.Sum.add (r : Ring) (f g : Natural → Ring.carrier(r))
        (n : Natural)
        : Polynomial.Sum(r, function (i : Natural) => Ring.add(r, f(i), g(i)), n)
          = Ring.add(r, Polynomial.Sum(r, f, n), Polynomial.Sum(r, g, n)) :=
  by_induction on n with IH {
    case zero: reflexivity(Ring.carrier(r), Ring.add(r, f(0), g(0)))
    case successor(k):
        calc Polynomial.Sum(r, function (i : Natural) => Ring.add(r, f(i), g(i)), successor(k))
           = Ring.add(r,
                 Polynomial.Sum(r, function (i : Natural) => Ring.add(r, f(i), g(i)), k),
                 Ring.add(r, f(successor(k)), g(successor(k))))
                 by reflexivity(Ring.carrier(r),
                        Ring.add(r,
                            Polynomial.Sum(r, function (i : Natural) => Ring.add(r, f(i), g(i)), k),
                            Ring.add(r, f(successor(k)), g(successor(k)))))
           = Ring.add(r,
                 Ring.add(r, Polynomial.Sum(r, f, k), Polynomial.Sum(r, g, k)),
                 Ring.add(r, f(successor(k)), g(successor(k))))
                 by IH
           = Ring.add(r,
                 Ring.add(r, Polynomial.Sum(r, f, k), f(successor(k))),
                 Ring.add(r, Polynomial.Sum(r, g, k), g(successor(k))))
                 by Ring.add_four_swap(r,
                        Polynomial.Sum(r, f, k), Polynomial.Sum(r, g, k),
                        f(successor(k)), g(successor(k)))
           = Ring.add(r, Polynomial.Sum(r, f, successor(k)), Polynomial.Sum(r, g, successor(k)))
                 by reflexivity(Ring.carrier(r),
                        Ring.add(r, Polynomial.Sum(r, f, successor(k)),
                            Polynomial.Sum(r, g, successor(k))))
  }

-- Pull a left constant through the sum: c · Σ f = Σ (c · f).
theorem Polynomial.Sum.scale_left (r : Ring) (c : Ring.carrier(r))
        (f : Natural → Ring.carrier(r)) (n : Natural)
        : Ring.multiply(r, c, Polynomial.Sum(r, f, n))
          = Polynomial.Sum(r, function (i : Natural) => Ring.multiply(r, c, f(i)), n) :=
  by_induction on n with IH {
    case zero: reflexivity(Ring.carrier(r), Ring.multiply(r, c, f(0)))
    case successor(k):
        calc Ring.multiply(r, c, Polynomial.Sum(r, f, successor(k)))
           = Ring.multiply(r, c, Ring.add(r, Polynomial.Sum(r, f, k), f(successor(k))))
                 by reflexivity(Ring.carrier(r),
                        Ring.multiply(r, c, Ring.add(r, Polynomial.Sum(r, f, k), f(successor(k)))))
           = Ring.add(r,
                 Ring.multiply(r, c, Polynomial.Sum(r, f, k)),
                 Ring.multiply(r, c, f(successor(k))))
                 by Ring.distributivity_left(r, c, Polynomial.Sum(r, f, k), f(successor(k)))
           = Ring.add(r,
                 Polynomial.Sum(r, function (i : Natural) => Ring.multiply(r, c, f(i)), k),
                 Ring.multiply(r, c, f(successor(k))))
                 by IH
           = Polynomial.Sum(r, function (i : Natural) => Ring.multiply(r, c, f(i)), successor(k))
                 by reflexivity(Ring.carrier(r),
                        Ring.add(r,
                            Polynomial.Sum(r, function (i : Natural) => Ring.multiply(r, c, f(i)), k),
                            Ring.multiply(r, c, f(successor(k)))))
  }

-- Pull a right constant through the sum: (Σ f) · c = Σ (f · c).
theorem Polynomial.Sum.scale_right (r : Ring)
        (f : Natural → Ring.carrier(r)) (c : Ring.carrier(r)) (n : Natural)
        : Ring.multiply(r, Polynomial.Sum(r, f, n), c)
          = Polynomial.Sum(r, function (i : Natural) => Ring.multiply(r, f(i), c), n) :=
  by_induction on n with IH {
    case zero: reflexivity(Ring.carrier(r), Ring.multiply(r, f(0), c))
    case successor(k):
        calc Ring.multiply(r, Polynomial.Sum(r, f, successor(k)), c)
           = Ring.multiply(r, Ring.add(r, Polynomial.Sum(r, f, k), f(successor(k))), c)
                 by reflexivity(Ring.carrier(r),
                        Ring.multiply(r, Ring.add(r, Polynomial.Sum(r, f, k), f(successor(k))), c))
           = Ring.add(r,
                 Ring.multiply(r, Polynomial.Sum(r, f, k), c),
                 Ring.multiply(r, f(successor(k)), c))
                 by Ring.distributivity_right(r, Polynomial.Sum(r, f, k), f(successor(k)), c)
           = Ring.add(r,
                 Polynomial.Sum(r, function (i : Natural) => Ring.multiply(r, f(i), c), k),
                 Ring.multiply(r, f(successor(k)), c))
                 by IH
           = Polynomial.Sum(r, function (i : Natural) => Ring.multiply(r, f(i), c), successor(k))
                 by reflexivity(Ring.carrier(r),
                        Ring.add(r,
                            Polynomial.Sum(r, function (i : Natural) => Ring.multiply(r, f(i), c), k),
                            Ring.multiply(r, f(successor(k)), c)))
  }

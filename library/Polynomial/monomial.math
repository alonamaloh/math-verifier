-- Polynomial/monomial.math
--
-- Monomials c·x^j and the one fact division needs about them: the
-- coefficient of (c·x^j)·p. By convolution the k-th coefficient is a
-- sum that is supported at the single index i = j (the only place the
-- monomial is nonzero), so it collapses (Sum.single_point) to
--   ((c·x^j)·p)[k] = c · p[k − j]   (j ≤ k).
-- This is exactly the "leading-term killer" the division step subtracts.

module Polynomial.monomial

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.monus
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Polynomial.basics
import Polynomial.addition
import Polynomial.multiplication
import Algebra.ring_summation
import Polynomial.degree
import Polynomial.multiply_coefficient
import Polynomial.division_support

-- The coefficient list of c·x^j: j zeros followed by c.
definition Polynomial.Coefficients.monomial (r : Ring) (c : Ring.carrier(r))
        : ℕ → Polynomial.Coefficients(Ring.carrier(r))
  | 0 =>
      Polynomial.Coefficients.cons(Ring.carrier(r), c,
          Polynomial.Coefficients.nil(Ring.carrier(r)))
  | 1 + k =>
      Polynomial.Coefficients.cons(Ring.carrier(r), Ring.zero(r),
          Polynomial.Coefficients.monomial(r, c, k))

-- The recursion in `1 + n` form: one more zero coefficient prepended.
theorem Polynomial.Coefficients.monomial_one_plus (r : Ring) (c : Ring.carrier(r)) (k : ℕ)
        : Polynomial.Coefficients.monomial(r, c, 1 + k)
          = Polynomial.Coefficients.cons(Ring.carrier(r), Ring.zero(r),
                Polynomial.Coefficients.monomial(r, c, k)) :=
  done by substituting Natural.one_add

-- Coefficient of the monomial list at its own degree is c.
theorem Polynomial.coefficient_monomial_at (r : Ring) (c : Ring.carrier(r))
        (j : ℕ)
        : Polynomial.Coefficients.monomial(r, c, j)[j] = c :=
  by induction on j with IH {
    case base: reflexivity(Ring.carrier(r), c)
    case step(k):
        Polynomial.Coefficients.monomial(r, c, 1 + k)[1 + k]
           = Polynomial.Coefficients.cons(Ring.carrier(r), Ring.zero(r), Polynomial.Coefficients.monomial(r, c, k))[1 + k]
               by Polynomial.Coefficients.monomial_one_plus
           = Polynomial.Coefficients.monomial(r, c, k)[k]
               by Polynomial.coefficient_cons_one_plus
           = c
               by IH
  }

-- Coefficient of the monomial list off its degree is zero.
theorem Polynomial.coefficient_monomial_off (r : Ring) (c : Ring.carrier(r))
        (j : ℕ)
        : ∀ (i : ℕ). ¬(i = j)
          → Polynomial.Coefficients.monomial(r, c, j)[i] = Ring.zero(r) :=
  by induction on j with IH {
    case base:
      (i : ℕ) (notEqual : ¬(i = 0)) ↦
          done by cases {
            case i = 0 as iEqualsZero: absurd(notEqual(iEqualsZero))
            case i = 1 + iPredecessor for some (iPredecessor : ℕ) as iEqualsOnePlus:
                Polynomial.Coefficients.monomial(r, c, 0)[i]
                   = Polynomial.Coefficients.monomial(r, c, 0)[1 + iPredecessor]
                         by substituting iEqualsOnePlus
                   = Polynomial.Coefficients.nil(Ring.carrier(r))[iPredecessor]
                         by Polynomial.coefficient_cons_one_plus
                   = Ring.zero(r)
          }
    case step(k):
      (i : ℕ) (notEqual : ¬(i = 1 + k)) ↦
          done by cases {
            case i = 0 as iEqualsZero:
                Polynomial.Coefficients.monomial(r, c, 1 + k)[i]
                   = Polynomial.Coefficients.monomial(r, c, 1 + k)[0]
                         by substituting iEqualsZero
                   = Polynomial.Coefficients.cons(Ring.carrier(r), Ring.zero(r), Polynomial.Coefficients.monomial(r, c, k))[0]
                         by Polynomial.Coefficients.monomial_one_plus
                   = Ring.zero(r)
            case i = 1 + iPredecessor for some (iPredecessor : ℕ) as iEqualsOnePlus:
                Polynomial.Coefficients.monomial(r, c, 1 + k)[i]
                   = Polynomial.Coefficients.monomial(r, c, 1 + k)[1 + iPredecessor]
                         by substituting iEqualsOnePlus
                   = Polynomial.Coefficients.cons(Ring.carrier(r), Ring.zero(r),
                         Polynomial.Coefficients.monomial(r, c, k))[1 + iPredecessor]
                         by Polynomial.Coefficients.monomial_one_plus
                   = Polynomial.Coefficients.monomial(r, c, k)[iPredecessor]
                         by Polynomial.coefficient_cons_one_plus
                   = Ring.zero(r)
                         by IH(iPredecessor,
                                (predecessorEqual : iPredecessor = k) ↦
                                    notEqual({
                                      i = 1 + iPredecessor   by iEqualsOnePlus
                                        = 1 + k              by substituting predecessorEqual
                                    }))
          }
  }

-- The monomial c·x^j, as a polynomial.
definition Polynomial.monomial (r : Ring) (c : Ring.carrier(r)) (j : ℕ)
        : Polynomial(Ring.carrier(r), Ring.zero(r)) :=
  Polynomial.make(Ring.carrier(r), Ring.zero(r),
      Polynomial.Coefficients.monomial(r, c, j))

-- Its coefficients, at the quotient level (definitional through the lift).
theorem Polynomial.coefficientOf_monomial_at (r : Ring) (c : Ring.carrier(r))
        (j : ℕ)
        : Polynomial.monomial(r, c, j)[j] = c :=
  Polynomial.coefficient_monomial_at(r, c, j)

theorem Polynomial.coefficientOf_monomial_off (r : Ring) (c : Ring.carrier(r))
        (j i : ℕ) (notEqual : ¬(i = j))
        : Polynomial.monomial(r, c, j)[i] = Ring.zero(r) :=
  Polynomial.coefficient_monomial_off(r, c, j, i, notEqual)

-- The coefficient of (c·x^j)·p: the convolution collapses to a single
-- term because the monomial vanishes off index j.
theorem Polynomial.coefficientOf_monomial_multiply (r : Ring) (c : Ring.carrier(r))
        (p : Polynomial(Ring.carrier(r), Ring.zero(r))) (j k : ℕ)
        (jLessOrEqualK : j ≤ k)
        : (Polynomial.monomial(r, c, j) * p)[k] = (c * p[k ∸ j]) :=
  (Polynomial.monomial(r, c, j) * p)[k]
     = Ring.Sum(r, (i : ℕ) ↦ (Polynomial.monomial(r, c, j)[i] * p[k ∸ i]), k)
           by Polynomial.coefficientOf_multiply
     = (Polynomial.monomial(r, c, j)[j] * p[k ∸ j])
           by Ring.Sum.single_point(r,
                  (i : ℕ) ↦ (Polynomial.monomial(r, c, j)[i] * p[k ∸ i]),
                  j, k, jLessOrEqualK,
                  (i : ℕ) (indexNotJ : ¬(i = j)) ↦
                      (Polynomial.monomial(r, c, j)[i] * p[k ∸ i])
                         = (Ring.zero(r) * p[k ∸ i])
                               by Polynomial.coefficientOf_monomial_off(r, c, j, i, indexNotJ)
                         = Ring.zero(r))
     = (c * p[k ∸ j])

-- Polynomial/multiplication.math
--
-- Multiplication of polynomials over a bundled ring. Built from two
-- helpers on coefficient lists:
--   * `scale(a, q)` multiplies every coefficient of q by a (on the
--     left) — the i-th coefficient is `a · q_i`;
--   * `shift(q)` multiplies by x (prepends a zero coefficient).
-- Then `(a + x·restA) · q = a·q + x·(restA·q)`, the standard recursion:
--   multiply(cons(a, restA), q) = scale(a, q) + shift(multiply(restA, q)).
--
-- This file sets up the operations and their coefficient (`nth`)
-- bridges. The convolution bridge for the full product, the respect
-- proof, the lift to `Polynomial.multiply`, and the ring laws build on
-- these.

module Polynomial.multiplication

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.monus
import Algebra.ring_bundle
import Polynomial.basics
import Polynomial.addition
import Algebra.ring_summation

-- ----------------------------------------------------------------------
-- Scaling: multiply every coefficient by `a` on the left.

definition Polynomial.Coefficients.scale (r : Ring) (a : Ring.carrier(r))
        : Polynomial.Coefficients(Ring.carrier(r))
          → Polynomial.Coefficients(Ring.carrier(r))
  | Polynomial.Coefficients.nil =>
      Polynomial.Coefficients.nil(Ring.carrier(r))
  | Polynomial.Coefficients.cons(c, rest) =>
      Polynomial.Coefficients.cons(Ring.carrier(r),
          (a * c),
          Polynomial.Coefficients.scale(r, a, rest))

-- Bridge: the i-th coefficient of `scale(a, p)` is `a · p_i`. The nil
-- case needs `Ring.multiply_zero_right` (a · 0 = 0).
theorem Polynomial.nth_scale (r : Ring) (a : Ring.carrier(r))
        (p : Polynomial.Coefficients(Ring.carrier(r)))
        : ∀ (index : Natural).
          Polynomial.coefficient(r, Polynomial.Coefficients.scale(r, a, p), index)
            = (a * Polynomial.coefficient(r, p, index)) :=
  by induction on p with IH {
    case Polynomial.Coefficients.nil:
        (index : Natural) ↦
            Polynomial.coefficient(r, Polynomial.Coefficients.scale(r, a, Polynomial.Coefficients.nil(Ring.carrier(r))), index)
               = Ring.zero(r)
               = (a * Ring.zero(r))   by Ring.multiply_zero_right
               = (a * Polynomial.coefficient(r, Polynomial.Coefficients.nil(Ring.carrier(r)), index))
    case Polynomial.Coefficients.cons(c, rest):
        (index : Natural) ↦
            done by cases {
              case index = 0:
                  Polynomial.coefficient(r, Polynomial.Coefficients.scale(r, a, Polynomial.Coefficients.cons(Ring.carrier(r), c, rest)), 0)
                     = (a * Polynomial.coefficient(r, Polynomial.Coefficients.cons(Ring.carrier(r), c, rest), 0))
              case index = successor(predecessor) for some predecessor: {
                  Polynomial.coefficient(r, Polynomial.Coefficients.scale(r, a, rest), predecessor)
                     = (a * Polynomial.coefficient(r, rest, predecessor))
                         by IH
                }
            }
  }

-- ----------------------------------------------------------------------
-- Shifting: multiply by x (prepend a zero coefficient).

definition Polynomial.Coefficients.shift (r : Ring)
        (p : Polynomial.Coefficients(Ring.carrier(r)))
        : Polynomial.Coefficients(Ring.carrier(r)) :=
  Polynomial.Coefficients.cons(Ring.carrier(r), Ring.zero(r), p)

-- Bridges: the 0-th coefficient of a shift is zero (definitional); the
-- (1+j)-th is the j-th of the original (via the Natural.one_add bridge).
theorem Polynomial.nth_shift_zero (r : Ring)
        (p : Polynomial.Coefficients(Ring.carrier(r)))
        : Polynomial.coefficient(r, Polynomial.Coefficients.shift(r, p), 0)
          = Ring.zero(r) :=
  Polynomial.coefficient(r, Polynomial.Coefficients.shift(r, p), 0)
     = Ring.zero(r)

theorem Polynomial.nth_shift_one_plus (r : Ring)
        (p : Polynomial.Coefficients(Ring.carrier(r))) (j : Natural)
        : Polynomial.coefficient(r, Polynomial.Coefficients.shift(r, p), 1 + j)
          = Polynomial.coefficient(r, p, j) :=
  Polynomial.coefficient(r, Polynomial.Coefficients.shift(r, p), 1 + j)
     = Polynomial.coefficient(r, p, j)

-- ----------------------------------------------------------------------
-- Multiplication of coefficient lists: the standard recursion
-- (a + x·restA) · q = a·q + x·(restA·q).

definition Polynomial.Coefficients.multiply (r : Ring)
        : Polynomial.Coefficients(Ring.carrier(r))
          → Polynomial.Coefficients(Ring.carrier(r))
          → Polynomial.Coefficients(Ring.carrier(r))
  | Polynomial.Coefficients.nil, q =>
      Polynomial.Coefficients.nil(Ring.carrier(r))
  | Polynomial.Coefficients.cons(a, restA), q =>
      Polynomial.Coefficients.add(r,
          Polynomial.Coefficients.scale(r, a, q),
          Polynomial.Coefficients.shift(r,
              Polynomial.Coefficients.multiply(r, restA, q)))

-- Bridge: the (1+j)-th coefficient of `cons(a, rest)` is the j-th
-- coefficient of `rest`. The 0-th case (= a) is definitional; this one
-- needs the Natural.one_add bridge, since `Polynomial.nth`'s pattern
-- match peels the constructor form, not the opaque `1 + j`.
theorem Polynomial.coefficient_cons_one_plus (r : Ring) (a : Ring.carrier(r))
        (rest : Polynomial.Coefficients(Ring.carrier(r))) (j : Natural)
        : Polynomial.coefficient(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, rest), 1 + j)
          = Polynomial.coefficient(r, rest, j) :=
  Polynomial.coefficient(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, rest), 1 + j)
     = Polynomial.coefficient(r, rest, j)

-- ----------------------------------------------------------------------
-- The convolution bridge: the k-th coefficient of a product is
-- Σ_{i=0}^{k} p_i · q_{k-i}. By induction on the first list, then a split
-- on k; the `convolution_zero` / `convolution_shift` sum identities carry
-- the index arithmetic (k+1−(j+1) = k−j).
theorem Polynomial.nth_multiply (r : Ring)
        (p q : Polynomial.Coefficients(Ring.carrier(r)))
        : ∀ (k : Natural).
          Polynomial.coefficient(r, Polynomial.Coefficients.multiply(r, p, q), k)
            = Ring.Sum(r,
                  (i : Natural) ↦
                      (Polynomial.coefficient(r, p, i) * Polynomial.coefficient(r, q, Natural.monus(k, i))),
                  k) :=
  by induction on p with IH {
    case Polynomial.Coefficients.nil:
      (k : Natural) ↦
      Polynomial.coefficient(r, Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.nil(Ring.carrier(r)), q), k)
         = Ring.zero(r)
         = Ring.Sum(r, (i : Natural) ↦ Ring.zero(r), k)
             by Ring.Sum.zero
         = Ring.Sum(r,
               (i : Natural) ↦
                   (Polynomial.coefficient(r, Polynomial.Coefficients.nil(Ring.carrier(r)), i) * Polynomial.coefficient(r, q, Natural.monus(k, i))),
               k)
             by (i : Natural) ↦
                 Ring.zero(r)
                    = (Ring.zero(r) * Polynomial.coefficient(r, q, Natural.monus(k, i)))
                    = (Polynomial.coefficient(r, Polynomial.Coefficients.nil(Ring.carrier(r)), i)
                           * Polynomial.coefficient(r, q, Natural.monus(k, i)))
    case Polynomial.Coefficients.cons(a, restA):
      (k : Natural) ↦
      done by cases {
        case k = 0:
              Polynomial.coefficient(r, Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, restA), q), 0)
                 = (Polynomial.coefficient(r, Polynomial.Coefficients.scale(r, a, q), 0) + Polynomial.coefficient(r, Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, restA, q)), 0))
                     by Polynomial.nth_add
                 = ((a * Polynomial.coefficient(r, q, 0)) + Polynomial.coefficient(r, Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, restA, q)), 0))
                 = ((a * Polynomial.coefficient(r, q, 0)) + Ring.zero(r))
                 = (a * Polynomial.coefficient(r, q, 0))
                 = Ring.Sum(r,
                       (i : Natural) ↦
                           (Polynomial.coefficient(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, restA), i) * Polynomial.coefficient(r, q, Natural.monus(0, i))),
                       0)
                     by Ring.Sum.convolution_zero(
                            A := (i : Natural) ↦ Polynomial.coefficient(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, restA), i),
                            B := (m : Natural) ↦ Polynomial.coefficient(r, q, m))
        case k = 1 + predecessor for some predecessor: {
            Polynomial.coefficient(r, Polynomial.Coefficients.multiply(r, restA, q), predecessor)
                  = Ring.Sum(r,
                        (j : Natural) ↦
                            (Polynomial.coefficient(r, restA, j) * Polynomial.coefficient(r, q, Natural.monus(predecessor, j))),
                        predecessor)
                by IH;

            Ring.Sum(r,
                  (j : Natural) ↦
                      (Polynomial.coefficient(r, restA, j) * Polynomial.coefficient(r, q, Natural.monus(predecessor, j))),
                  predecessor)
                = Ring.Sum(r,
                      (j : Natural) ↦
                          (Polynomial.coefficient(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, restA), 1 + j) * Polynomial.coefficient(r, q, Natural.monus(predecessor, j))),
                      predecessor)
              by Ring.Sum.extensional(r,
                     (j : Natural) ↦ (Polynomial.coefficient(r, restA, j) * Polynomial.coefficient(r, q, Natural.monus(predecessor, j))),
                     (j : Natural) ↦ (Polynomial.coefficient(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, restA), 1 + j) * Polynomial.coefficient(r, q, Natural.monus(predecessor, j))),
                     (j : Natural) ↦
                         { (Polynomial.coefficient(r, restA, j) * Polynomial.coefficient(r, q, Natural.monus(predecessor, j)))
                               = (Polynomial.coefficient(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, restA), 1 + j) * Polynomial.coefficient(r, q, Natural.monus(predecessor, j)))
                               by substituting Polynomial.coefficient_cons_one_plus },
                     predecessor) as tailReindex;

              Polynomial.coefficient(r, Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, restA), q), 1 + predecessor)
                 = (Polynomial.coefficient(r, Polynomial.Coefficients.scale(r, a, q), 1 + predecessor) + Polynomial.coefficient(r, Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, restA, q)), 1 + predecessor))
                     by Polynomial.nth_add
                 = ((a * Polynomial.coefficient(r, q, 1 + predecessor)) + Polynomial.coefficient(r, Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, restA, q)), 1 + predecessor))
                 = ((a * Polynomial.coefficient(r, q, 1 + predecessor)) + Polynomial.coefficient(r, Polynomial.Coefficients.multiply(r, restA, q), predecessor))
                     by Polynomial.nth_shift_one_plus
                 = ((a * Polynomial.coefficient(r, q, 1 + predecessor)) + Ring.Sum(r,
                           (j : Natural) ↦
                               (Polynomial.coefficient(r, restA, j) * Polynomial.coefficient(r, q, Natural.monus(predecessor, j))),
                           predecessor))
                 = ((a * Polynomial.coefficient(r, q, 1 + predecessor)) + Ring.Sum(r,
                           (j : Natural) ↦
                               (Polynomial.coefficient(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, restA), 1 + j) * Polynomial.coefficient(r, q, Natural.monus(predecessor, j))),
                           predecessor))
                     by substituting tailReindex
                 = Ring.Sum(r,
                       (i : Natural) ↦
                           (Polynomial.coefficient(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, restA), i) * Polynomial.coefficient(r, q, Natural.monus(1 + predecessor, i))),
                       1 + predecessor)
                     by Ring.Sum.convolution_shift(
                            A := (i : Natural) ↦ Polynomial.coefficient(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, restA), i),
                            B := (m : Natural) ↦ Polynomial.coefficient(r, q, m),
                            k := predecessor);
              done by substituting Natural.one_add
          }
      }
  }

-- ----------------------------------------------------------------------
-- Multiplication respects the equivalence in both arguments at once:
-- the bridge expresses each coefficient purely through the coefficient
-- functions, so equal-as-functions inputs give equal sums.
theorem Polynomial.Coefficients.multiply_respects (r : Ring)
        (p pPrime q qPrime : Polynomial.Coefficients(Ring.carrier(r)))
        (firstEqual
            : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r), p, pPrime))
        (secondEqual
            : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r), q, qPrime))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.multiply(r, p, q),
              Polynomial.Coefficients.multiply(r, pPrime, qPrime)) :=
  (k : Natural) ↦
      Polynomial.coefficient(r, Polynomial.Coefficients.multiply(r, p, q), k)
         = Ring.Sum(r,
               (i : Natural) ↦
                   (Polynomial.coefficient(r, p, i) * Polynomial.coefficient(r, q, Natural.monus(k, i))),
               k)
               by Polynomial.nth_multiply
         = Ring.Sum(r,
               (i : Natural) ↦
                   (Polynomial.coefficient(r, pPrime, i) * Polynomial.coefficient(r, qPrime, Natural.monus(k, i))),
               k)
               by ((i : Natural) ↦
                          (Polynomial.coefficient(r, p, i) * Polynomial.coefficient(r, q, Natural.monus(k, i)))
                             = (Polynomial.coefficient(r, pPrime, i) * Polynomial.coefficient(r, q, Natural.monus(k, i)))
                                   by firstEqual(i)
                             = (Polynomial.coefficient(r, pPrime, i) * Polynomial.coefficient(r, qPrime, Natural.monus(k, i)))
                                   by secondEqual(Natural.monus(k, i)))
         = Polynomial.coefficient(r, Polynomial.Coefficients.multiply(r, pPrime, qPrime), k)
               by Polynomial.nth_multiply

-- ----------------------------------------------------------------------
-- Lift to the quotient (two lifts, as for addition).

-- Multiply the coefficient-list representatives; well-defined in each
-- argument because Coefficients.multiply respects extensional equality.
definition Polynomial.multiply {r : Ring}
        : Polynomial(Ring.carrier(r), Ring.zero(r))
          → Polynomial(Ring.carrier(r), Ring.zero(r))
          → Polynomial(Ring.carrier(r), Ring.zero(r))
  by representatives a, b ↦
       Polynomial.make(Ring.carrier(r), Ring.zero(r),
           Polynomial.Coefficients.multiply(r, a, b))
  well_defined by
    (a a' b : Polynomial.Coefficients(Ring.carrier(r)))
        (firstEqual
            : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r), a, a')) ↦
        ({ Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r), b, b)
               by Polynomial.ExtensionallyEqual.reflexive;
           done by Polynomial.Coefficients.multiply_respects
         } : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
                 Polynomial.Coefficients.multiply(r, a, b),
                 Polynomial.Coefficients.multiply(r, a', b))),
    (a b b' : Polynomial.Coefficients(Ring.carrier(r)))
        (secondEqual
            : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r), b, b')) ↦
        ({ Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r), a, a)
               by Polynomial.ExtensionallyEqual.reflexive;
           done by Polynomial.Coefficients.multiply_respects
         } : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
                 Polynomial.Coefficients.multiply(r, a, b),
                 Polynomial.Coefficients.multiply(r, a, b')))

-- Operator overload: `p * q` over `Polynomial(...)` dispatches on the
-- `Polynomial` type head, recovering the implicit ring from the operands.
operator (*) on (Polynomial, Polynomial) := Polynomial.multiply

-- Polynomial/multiply_laws.math
--
-- The multiplicative ring laws for polynomials over a bundled ring:
-- the two distributivity laws, the multiplicative identities, and
-- associativity. Each is proved first at the coefficient-list level as
-- an `ExtensionallyEqual` (a per-index identity established through the
-- convolution bridge `nth_multiply` and the `Sum` algebra), then lifted
-- to `Polynomial.*` by `Quotient.induct` + `make_equal_of_coefficients_equal`.

module Polynomial.multiply_laws

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.monus
import Algebra.ring_bundle
import Polynomial.basics
import Polynomial.addition
import Polynomial.negation
import Polynomial.additive_group
import Polynomial.summation
import Polynomial.multiplication

-- ----------------------------------------------------------------------
-- Left distributivity: p · (q + s) = p·q + p·s, at the coefficient
-- level. Proved in the "expanded ⇒ folded" direction (all forward
-- congruences) and reflected with a final symmetry.

theorem Polynomial.Coefficients.multiply_distributivity_left (r : Ring)
        (p q s : Polynomial.Coefficients(Ring.carrier(r)))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.multiply(r, p, Polynomial.Coefficients.add(r, q, s)),
              Polynomial.Coefficients.add(r,
                  Polynomial.Coefficients.multiply(r, p, q),
                  Polynomial.Coefficients.multiply(r, p, s))) :=
  (k : Natural) ↦
      calc Polynomial.coefficient(Polynomial.Coefficients.add(r,
                       Polynomial.Coefficients.multiply(r, p, q),
                       Polynomial.Coefficients.multiply(r, p, s)), k)
             = (Polynomial.coefficient(Polynomial.Coefficients.multiply(r, p, q), k) + Polynomial.coefficient(Polynomial.Coefficients.multiply(r, p, s), k))
             = (Polynomial.Sum(r, (i : Natural) ↦ (Polynomial.coefficient(p, i) * Polynomial.coefficient(q, Natural.monus(k, i))), k) + Polynomial.coefficient(Polynomial.Coefficients.multiply(r, p, s), k))
                   by Polynomial.nth_multiply(r, p, q, k)
             = (Polynomial.Sum(r, (i : Natural) ↦ (Polynomial.coefficient(p, i) * Polynomial.coefficient(q, Natural.monus(k, i))), k) + Polynomial.Sum(r, (i : Natural) ↦ (Polynomial.coefficient(p, i) * Polynomial.coefficient(s, Natural.monus(k, i))), k))
                   by Polynomial.nth_multiply(r, p, s, k)
             = Polynomial.Sum(r,
                   (i : Natural) ↦
                       ((Polynomial.coefficient(p, i) * Polynomial.coefficient(q, Natural.monus(k, i))) + (Polynomial.coefficient(p, i) * Polynomial.coefficient(s, Natural.monus(k, i)))), k)
                   by Polynomial.Sum.add(r,
                              (i : Natural) ↦
                                  (Polynomial.coefficient(p, i) * Polynomial.coefficient(q, Natural.monus(k, i))),
                              (i : Natural) ↦
                                  (Polynomial.coefficient(p, i) * Polynomial.coefficient(s, Natural.monus(k, i))),
                              k)
             = Polynomial.Sum(r,
                   (i : Natural) ↦
                       (Polynomial.coefficient(p, i) * (Polynomial.coefficient(q, Natural.monus(k, i)) + Polynomial.coefficient(s, Natural.monus(k, i)))), k)
                   by ((i : Natural) ↦
                          Ring.distributivity_left(r, Polynomial.coefficient(p, i),
                                  Polynomial.coefficient(q, Natural.monus(k, i)),
                                  Polynomial.coefficient(s, Natural.monus(k, i))))
             = Polynomial.Sum(r,
                   (i : Natural) ↦
                       (Polynomial.coefficient(p, i) * Polynomial.coefficient(Polynomial.Coefficients.add(r, q, s), Natural.monus(k, i))), k)
                   by ((i : Natural) ↦
                          congruenceOf(
                              (w : Ring.carrier(r)) ↦
                                  (Polynomial.coefficient(p, i) * w),
                              Polynomial.nth_add(r, q, s, Natural.monus(k, i))))
             = Polynomial.coefficient(Polynomial.Coefficients.multiply(r, p, Polynomial.Coefficients.add(r, q, s)), k)
                   by Polynomial.nth_multiply(r, p, Polynomial.Coefficients.add(r, q, s), k)

theorem Polynomial.multiply_distributivity_left (r : Ring)
        (x y z : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : Polynomial.multiply(r, x, Polynomial.add(r, y, z))
          = Polynomial.add(r, Polynomial.multiply(r, x, y), Polynomial.multiply(r, x, z)) :=
  by_representatives x as p, y as q, z as s =>
      Polynomial.make_equal_of_coefficients_equal(r,
          Polynomial.Coefficients.multiply(r, p, Polynomial.Coefficients.add(r, q, s)),
          Polynomial.Coefficients.add(r,
              Polynomial.Coefficients.multiply(r, p, q),
              Polynomial.Coefficients.multiply(r, p, s)),
          Polynomial.Coefficients.multiply_distributivity_left(r, p, q, s))

-- ----------------------------------------------------------------------
-- Right distributivity: (p + q) · s = p·s + q·s.

theorem Polynomial.Coefficients.multiply_distributivity_right (r : Ring)
        (p q s : Polynomial.Coefficients(Ring.carrier(r)))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.add(r, p, q), s),
              Polynomial.Coefficients.add(r,
                  Polynomial.Coefficients.multiply(r, p, s),
                  Polynomial.Coefficients.multiply(r, q, s))) :=
  (k : Natural) ↦
      calc Polynomial.coefficient(Polynomial.Coefficients.add(r,
                       Polynomial.Coefficients.multiply(r, p, s),
                       Polynomial.Coefficients.multiply(r, q, s)), k)
             = (Polynomial.coefficient(Polynomial.Coefficients.multiply(r, p, s), k) + Polynomial.coefficient(Polynomial.Coefficients.multiply(r, q, s), k))
             = (Polynomial.Sum(r, (i : Natural) ↦ (Polynomial.coefficient(p, i) * Polynomial.coefficient(s, Natural.monus(k, i))), k) + Polynomial.coefficient(Polynomial.Coefficients.multiply(r, q, s), k))
                   by Polynomial.nth_multiply(r, p, s, k)
             = (Polynomial.Sum(r, (i : Natural) ↦ (Polynomial.coefficient(p, i) * Polynomial.coefficient(s, Natural.monus(k, i))), k) + Polynomial.Sum(r, (i : Natural) ↦ (Polynomial.coefficient(q, i) * Polynomial.coefficient(s, Natural.monus(k, i))), k))
                   by Polynomial.nth_multiply(r, q, s, k)
             = Polynomial.Sum(r,
                   (i : Natural) ↦
                       ((Polynomial.coefficient(p, i) * Polynomial.coefficient(s, Natural.monus(k, i))) + (Polynomial.coefficient(q, i) * Polynomial.coefficient(s, Natural.monus(k, i)))), k)
                   by Polynomial.Sum.add(r,
                              (i : Natural) ↦
                                  (Polynomial.coefficient(p, i) * Polynomial.coefficient(s, Natural.monus(k, i))),
                              (i : Natural) ↦
                                  (Polynomial.coefficient(q, i) * Polynomial.coefficient(s, Natural.monus(k, i))),
                              k)
             = Polynomial.Sum(r,
                   (i : Natural) ↦
                       ((Polynomial.coefficient(p, i) + Polynomial.coefficient(q, i)) * Polynomial.coefficient(s, Natural.monus(k, i))), k)
                   by ((i : Natural) ↦
                              Ring.distributivity_right(r, Polynomial.coefficient(p, i),
                                      Polynomial.coefficient(q, i),
                                      Polynomial.coefficient(s, Natural.monus(k, i))))
             = Polynomial.Sum(r,
                   (i : Natural) ↦
                       (Polynomial.coefficient(Polynomial.Coefficients.add(r, p, q), i) * Polynomial.coefficient(s, Natural.monus(k, i))), k)
                   by ((i : Natural) ↦
                              congruenceOf(
                                  (w : Ring.carrier(r)) ↦
                                      (w * Polynomial.coefficient(s, Natural.monus(k, i))),
                                  Polynomial.nth_add(r, p, q, i)))
             = Polynomial.coefficient(Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.add(r, p, q), s), k)
                   by Polynomial.nth_multiply(r, Polynomial.Coefficients.add(r, p, q), s, k)

theorem Polynomial.multiply_distributivity_right (r : Ring)
        (x y z : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : Polynomial.multiply(r, Polynomial.add(r, x, y), z)
          = Polynomial.add(r, Polynomial.multiply(r, x, z), Polynomial.multiply(r, y, z)) :=
  by_representatives x as p, y as q, z as s =>
      Polynomial.make_equal_of_coefficients_equal(r,
          Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.add(r, p, q), s),
          Polynomial.Coefficients.add(r,
              Polynomial.Coefficients.multiply(r, p, s),
              Polynomial.Coefficients.multiply(r, q, s)),
          Polynomial.Coefficients.multiply_distributivity_right(r, p, q, s))

-- ----------------------------------------------------------------------
-- Multiplicative identities. The coefficient list of 1 is [one]; the
-- left identity is structural (1·p = scale(one, p) + shift(nil·p), and
-- scale(one,·) is the identity coefficient-wise while the shift adds
-- only zeros).

theorem Polynomial.Coefficients.nth_cons_zero_nil (r : Ring) (k : Natural)
        : Polynomial.coefficient(Polynomial.Coefficients.cons(Ring.carrier(r), Ring.zero(r),
                  Polynomial.Coefficients.nil(Ring.carrier(r))), k)
          = Ring.zero(r) :=
  cases k {
    | zero => reflexivity(Ring.carrier(r), Ring.zero(r))
    | successor(j) => reflexivity(Ring.carrier(r), Ring.zero(r))
  }

theorem Polynomial.Coefficients.multiply_one_left (r : Ring)
        (p : Polynomial.Coefficients(Ring.carrier(r)))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.multiply(r,
                  Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                      Polynomial.Coefficients.nil(Ring.carrier(r))),
                  p),
              p) :=
  (k : Natural) ↦
      calc Polynomial.coefficient(Polynomial.Coefficients.multiply(r,
                   Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                       Polynomial.Coefficients.nil(Ring.carrier(r))), p), k)
         = (Polynomial.coefficient(Polynomial.Coefficients.scale(r, Ring.one(r), p), k) + Polynomial.coefficient(Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.nil(Ring.carrier(r)), p)), k))
               by Polynomial.nth_add
         = ((Ring.one(r) * Polynomial.coefficient(p, k)) + Polynomial.coefficient(Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.nil(Ring.carrier(r)), p)), k))
         = (Polynomial.coefficient(p, k) + Polynomial.coefficient(Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.nil(Ring.carrier(r)), p)), k))
         = (Polynomial.coefficient(p, k) + Ring.zero(r))
         = Polynomial.coefficient(p, k)

theorem Polynomial.multiply_one_left (r : Ring)
        (x : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : Polynomial.multiply(r, Polynomial.one(r), x) = x :=
  cases x { | p =>
    Polynomial.make_equal_of_coefficients_equal(r,
        Polynomial.Coefficients.multiply(r,
            Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                Polynomial.Coefficients.nil(Ring.carrier(r))),
            p),
        p,
        Polynomial.Coefficients.multiply_one_left(r, p)) }

-- ----------------------------------------------------------------------
-- Right identity: p · 1 = p. By recursion on p (multiplication recurses
-- on its first argument). At each step the coefficient of 1 is `one` at
-- index 0 and zero beyond, so the head becomes a·one = a and the tail
-- is the inductive hypothesis.

theorem Polynomial.Coefficients.multiply_one_right (r : Ring)
        : (p : Polynomial.Coefficients(Ring.carrier(r)))
          → Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
                Polynomial.Coefficients.multiply(r, p,
                    Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                        Polynomial.Coefficients.nil(Ring.carrier(r)))),
                p)
  | Polynomial.Coefficients.nil =>
      (k : Natural) ↦
          reflexivity(Ring.carrier(r),
              Polynomial.coefficient(Polynomial.Coefficients.nil(Ring.carrier(r)), k))
  | Polynomial.Coefficients.cons(a, rest) =>
      (k : Natural) ↦
          cases k {
            | zero =>
                calc Polynomial.coefficient(Polynomial.Coefficients.multiply(r,
                             Polynomial.Coefficients.cons(Ring.carrier(r), a, rest),
                             Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                 Polynomial.Coefficients.nil(Ring.carrier(r)))), 0)
                   = (Polynomial.coefficient(Polynomial.Coefficients.scale(r, a, Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r), Polynomial.Coefficients.nil(Ring.carrier(r)))), 0) + Polynomial.coefficient(Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, rest, Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r), Polynomial.Coefficients.nil(Ring.carrier(r))))), 0))
                   = ((a * Ring.one(r)) + Ring.zero(r))
                   = (a + Ring.zero(r))
                   = a
            | successor(j) =>
                calc Polynomial.coefficient(Polynomial.Coefficients.multiply(r,
                             Polynomial.Coefficients.cons(Ring.carrier(r), a, rest),
                             Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                 Polynomial.Coefficients.nil(Ring.carrier(r)))), successor(j))
                   = (Polynomial.coefficient(Polynomial.Coefficients.scale(r, a, Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r), Polynomial.Coefficients.nil(Ring.carrier(r)))), successor(j)) + Polynomial.coefficient(Polynomial.Coefficients.multiply(r, rest, Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r), Polynomial.Coefficients.nil(Ring.carrier(r)))), j))
                         by Polynomial.nth_add(r,
                                Polynomial.Coefficients.scale(r, a,
                                    Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                        Polynomial.Coefficients.nil(Ring.carrier(r)))),
                                Polynomial.Coefficients.shift(r,
                                    Polynomial.Coefficients.multiply(r, rest,
                                        Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                            Polynomial.Coefficients.nil(Ring.carrier(r))))), successor(j))
                   = ((a * Ring.zero(r)) + Polynomial.coefficient(Polynomial.Coefficients.multiply(r, rest, Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r), Polynomial.Coefficients.nil(Ring.carrier(r)))), j))
                         by Polynomial.nth_scale(r, a,
                                Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                    Polynomial.Coefficients.nil(Ring.carrier(r))), successor(j))
                   = (Ring.zero(r) + Polynomial.coefficient(Polynomial.Coefficients.multiply(r, rest, Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r), Polynomial.Coefficients.nil(Ring.carrier(r)))), j))
                   = Polynomial.coefficient(Polynomial.Coefficients.multiply(r, rest,
                             Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                 Polynomial.Coefficients.nil(Ring.carrier(r)))), j)
                   = Polynomial.coefficient(rest, j)
                         by Polynomial.Coefficients.multiply_one_right(r, rest, j)
          }

theorem Polynomial.multiply_one_right (r : Ring)
        (x : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : Polynomial.multiply(r, x, Polynomial.one(r)) = x :=
  cases x { | p =>
    Polynomial.make_equal_of_coefficients_equal(r,
        Polynomial.Coefficients.multiply(r, p,
            Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                Polynomial.Coefficients.nil(Ring.carrier(r)))),
        p,
        Polynomial.Coefficients.multiply_one_right(r, p)) }

-- ----------------------------------------------------------------------
-- Helpers for associativity (structural induction on the first list).

-- Shift respects the equivalence.
theorem Polynomial.Coefficients.shift_respects (r : Ring)
        (x y : Polynomial.Coefficients(Ring.carrier(r)))
        (equal : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r), x, y))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.shift(r, x), Polynomial.Coefficients.shift(r, y)) :=
  (k : Natural) ↦
      cases k {
        | zero => reflexivity(Ring.carrier(r), Ring.zero(r))
        | successor(j) => equal(j)
      }

-- (a·q)·s = a·(q·s):  multiply(scale(a, q), s) ~ scale(a, multiply(q, s)).
theorem Polynomial.Coefficients.scale_multiply (r : Ring) (a : Ring.carrier(r))
        (q s : Polynomial.Coefficients(Ring.carrier(r)))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.scale(r, a, q), s),
              Polynomial.Coefficients.scale(r, a, Polynomial.Coefficients.multiply(r, q, s))) :=
  (k : Natural) ↦
      calc Polynomial.coefficient(Polynomial.Coefficients.scale(r, a, Polynomial.Coefficients.multiply(r, q, s)), k)
             = (a * Polynomial.coefficient(Polynomial.Coefficients.multiply(r, q, s), k))
             = (a * Polynomial.Sum(r, (i : Natural) ↦ (Polynomial.coefficient(q, i) * Polynomial.coefficient(s, Natural.monus(k, i))), k))
                   by Polynomial.nth_multiply(r, q, s, k)
             = Polynomial.Sum(r,
                   (i : Natural) ↦
                       (a * (Polynomial.coefficient(q, i) * Polynomial.coefficient(s, Natural.monus(k, i)))), k)
                   by Polynomial.Sum.scale_left
             = Polynomial.Sum(r,
                   (i : Natural) ↦
                       ((a * Polynomial.coefficient(q, i)) * Polynomial.coefficient(s, Natural.monus(k, i))), k)
                   by ((i : Natural) ↦
                              Ring.multiply_associative(r, a, Polynomial.coefficient(q, i),
                                      Polynomial.coefficient(s, Natural.monus(k, i))))
             = Polynomial.Sum(r,
                   (i : Natural) ↦
                       (Polynomial.coefficient(Polynomial.Coefficients.scale(r, a, q), i) * Polynomial.coefficient(s, Natural.monus(k, i))), k)
                   by ((i : Natural) ↦
                              congruenceOf(
                                  (w : Ring.carrier(r)) ↦
                                      (w * Polynomial.coefficient(s, Natural.monus(k, i))),
                                  Polynomial.nth_scale(r, a, q, i)))
             = Polynomial.coefficient(Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.scale(r, a, q), s), k)
                   by Polynomial.nth_multiply(r, Polynomial.Coefficients.scale(r, a, q), s, k)

-- (x·y)·s = x·(y·s) when x = shift(·):  multiply(shift(y), s) ~ shift(multiply(y, s)).
theorem Polynomial.Coefficients.shift_multiply (r : Ring)
        (y s : Polynomial.Coefficients(Ring.carrier(r)))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.shift(r, y), s),
              Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, y, s))) :=
  (k : Natural) ↦
      cases k {
        | zero =>
            calc Polynomial.coefficient(Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.shift(r, y), s), 0)
               = (Polynomial.coefficient(Polynomial.Coefficients.shift(r, y), 0) * Polynomial.coefficient(s, Natural.monus(0, 0)))
                   by Polynomial.nth_multiply
               = (Ring.zero(r) * Polynomial.coefficient(s, Natural.monus(0, 0)))
               = Ring.zero(r)
               = Polynomial.coefficient(Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, y, s)), 0)
        | successor(predecessor) =>
            
              calc Polynomial.coefficient(Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.shift(r, y), s), successor(predecessor))
                 = Polynomial.Sum(r,
                       (i : Natural) ↦
                           (Polynomial.coefficient(Polynomial.Coefficients.shift(r, y), i) * Polynomial.coefficient(s, Natural.monus(successor(predecessor), i))), successor(predecessor))
                     by Polynomial.nth_multiply
                 = ((Polynomial.coefficient(Polynomial.Coefficients.shift(r, y), 0) * Polynomial.coefficient(s, Natural.monus(successor(predecessor), 0))) + Polynomial.Sum(r, (j : Natural) ↦ (Polynomial.coefficient(Polynomial.Coefficients.shift(r, y), successor(j)) * Polynomial.coefficient(s, Natural.monus(successor(predecessor), successor(j)))), predecessor))
                     by Polynomial.Sum.shift
                 = ((Ring.zero(r) * Polynomial.coefficient(s, successor(predecessor))) + Polynomial.Sum(r, (j : Natural) ↦ (Polynomial.coefficient(y, j) * Polynomial.coefficient(s, Natural.monus(predecessor, j))), predecessor))
                 = (Ring.zero(r) + Polynomial.Sum(r, (j : Natural) ↦ (Polynomial.coefficient(y, j) * Polynomial.coefficient(s, Natural.monus(predecessor, j))), predecessor))
                 = Polynomial.Sum(r,
                       (j : Natural) ↦
                           (Polynomial.coefficient(y, j) * Polynomial.coefficient(s, Natural.monus(predecessor, j))), predecessor)
                 = Polynomial.coefficient(Polynomial.Coefficients.multiply(r, y, s), predecessor)
                     by Polynomial.nth_multiply(r, y, s, predecessor)
                 = Polynomial.coefficient(Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, y, s)), successor(predecessor))
      }

-- ----------------------------------------------------------------------
-- Associativity, by recursion on the first list. On `cons(a, restA)`:
--   (cons(a,restA)·q)·s
--     = (scale(a,q) + shift(restA·q))·s
--     = scale(a,q)·s + shift(restA·q)·s          [right distributivity]
--     = scale(a, q·s) + shift((restA·q)·s)       [scale_multiply, shift_multiply]
--     = scale(a, q·s) + shift(restA·(q·s))       [IH, through shift]
--     = cons(a,restA)·(q·s).

theorem Polynomial.Coefficients.multiply_assoc (r : Ring)
        : (p q s : Polynomial.Coefficients(Ring.carrier(r)))
          → Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
                Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.multiply(r, p, q), s),
                Polynomial.Coefficients.multiply(r, p, Polynomial.Coefficients.multiply(r, q, s)))
  | Polynomial.Coefficients.nil, q, s =>
      (k : Natural) ↦
          reflexivity(Ring.carrier(r),
              Polynomial.coefficient(Polynomial.Coefficients.nil(Ring.carrier(r)), k))
  | Polynomial.Coefficients.cons(a, restA), q, s => {
      claim inductiveHypothesis
          : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
                Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.multiply(r, restA, q), s),
                Polynomial.Coefficients.multiply(r, restA, Polynomial.Coefficients.multiply(r, q, s)))
          by Polynomial.Coefficients.multiply_assoc(r, restA, q, s);
      (k : Natural) ↦
          calc Polynomial.coefficient(Polynomial.Coefficients.multiply(r,
                       Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, restA), q), s), k)
             = Polynomial.coefficient(Polynomial.Coefficients.add(r,
                       Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.scale(r, a, q), s),
                       Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, restA, q)), s)), k)
                   by Polynomial.Coefficients.multiply_distributivity_right(r,
                          Polynomial.Coefficients.scale(r, a, q),
                          Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, restA, q)),
                          s, k)
             = (Polynomial.coefficient(Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.scale(r, a, q), s), k) + Polynomial.coefficient(Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, restA, q)), s), k))
             = (Polynomial.coefficient(Polynomial.Coefficients.scale(r, a, Polynomial.Coefficients.multiply(r, q, s)), k) + Polynomial.coefficient(Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, restA, q)), s), k))
                   by Polynomial.Coefficients.scale_multiply(r, a, q, s, k)
             = (Polynomial.coefficient(Polynomial.Coefficients.scale(r, a, Polynomial.Coefficients.multiply(r, q, s)), k) + Polynomial.coefficient(Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.multiply(r, restA, q), s)), k))
                   by Polynomial.Coefficients.shift_multiply(r, Polynomial.Coefficients.multiply(r, restA, q), s, k)
             = (Polynomial.coefficient(Polynomial.Coefficients.scale(r, a, Polynomial.Coefficients.multiply(r, q, s)), k) + Polynomial.coefficient(Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, restA, Polynomial.Coefficients.multiply(r, q, s))), k))
                   by Polynomial.Coefficients.shift_respects(r,
                          Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.multiply(r, restA, q), s),
                          Polynomial.Coefficients.multiply(r, restA, Polynomial.Coefficients.multiply(r, q, s)),
                          inductiveHypothesis, k)
             = Polynomial.coefficient(Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, restA), Polynomial.Coefficients.multiply(r, q, s)), k)
                   by Polynomial.nth_add(r,
                              Polynomial.Coefficients.scale(r, a, Polynomial.Coefficients.multiply(r, q, s)),
                              Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, restA, Polynomial.Coefficients.multiply(r, q, s))), k)
    }

theorem Polynomial.multiply_associative (r : Ring)
        (x y z : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : Polynomial.multiply(r, Polynomial.multiply(r, x, y), z)
          = Polynomial.multiply(r, x, Polynomial.multiply(r, y, z)) :=
  by_representatives x as p, y as q, z as s =>
      Polynomial.make_equal_of_coefficients_equal(r,
          Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.multiply(r, p, q), s),
          Polynomial.Coefficients.multiply(r, p, Polynomial.Coefficients.multiply(r, q, s)),
          Polynomial.Coefficients.multiply_assoc(r, p, q, s))

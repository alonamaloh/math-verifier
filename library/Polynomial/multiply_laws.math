-- Polynomial/multiply_laws.math
--
-- The multiplicative ring laws for polynomials over a bundled ring:
-- the two distributivity laws, the multiplicative identities, and
-- associativity. Each is proved first at the coefficient-list level as
-- an `ExtensionallyEqual` (a per-index identity established through the
-- convolution bridge `nth_multiply` and the `Sum` algebra), then lifted
-- to `Polynomial.*` by `Quotient.induct` + `make_equal_of_coefficients_equal`.

module Polynomial.multiply_laws

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.monus
import Algebra.ring_bundle
import Polynomial.basics
import Polynomial.addition
import Polynomial.negation
import Polynomial.additive_group
import Algebra.ring_summation
import Polynomial.multiplication

-- ----------------------------------------------------------------------
-- Left distributivity: p · (q + s) = p·q + p·s, at the coefficient
-- level. Proved in the "expanded ⇒ folded" direction (all forward
-- congruences) and reflected with a final symmetry.

theorem Polynomial.Coefficients.multiply_distributivity_left (r : Ring)
        (p q s : Polynomial.Coefficients(Ring.carrier(r)))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.multiply(r, p, Polynomial.Coefficients.add(r, q, s)),
              Polynomial.Coefficients.add(r,
                  Polynomial.Coefficients.multiply(r, p, q),
                  Polynomial.Coefficients.multiply(r, p, s))) :=
  (k : ℕ) ↦
      Polynomial.Coefficients.add(r, Polynomial.Coefficients.multiply(r, p, q), Polynomial.Coefficients.multiply(r, p, s))[k]
             = (Polynomial.Coefficients.multiply(r, p, q)[k] + Polynomial.Coefficients.multiply(r, p, s)[k])
             = (Ring.Sum(r, (i : ℕ) ↦ (p[i] * q[Natural.monus(k, i)]), k) + Polynomial.Coefficients.multiply(r, p, s)[k])
                   by Polynomial.nth_multiply
             = (Ring.Sum(r, (i : ℕ) ↦ (p[i] * q[Natural.monus(k, i)]), k)
                    + Ring.Sum(r, (i : ℕ) ↦ (p[i] * s[Natural.monus(k, i)]), k))
                   by Polynomial.nth_multiply
             = Ring.Sum(r, (i : ℕ) ↦ ((p[i] * q[Natural.monus(k, i)]) + (p[i] * s[Natural.monus(k, i)])), k)
                   by Ring.Sum.add
             = Ring.Sum(r, (i : ℕ) ↦ (p[i] * (q[Natural.monus(k, i)] + s[Natural.monus(k, i)])), k)
                   by ((i : ℕ) ↦
                          { (p[i] * q[Natural.monus(k, i)]) + (p[i] * s[Natural.monus(k, i)])
                             = (p[i] * (q[Natural.monus(k, i)] + s[Natural.monus(k, i)]))
                                   by Ring.distributivity_left })
             = Ring.Sum(r, (i : ℕ) ↦ (p[i] * Polynomial.Coefficients.add(r, q, s)[Natural.monus(k, i)]), k)
                   by ((i : ℕ) ↦
                          { (p[i] * (q[Natural.monus(k, i)] + s[Natural.monus(k, i)]))
                             = (p[i] * Polynomial.Coefficients.add(r, q, s)[Natural.monus(k, i)])
                                   by Polynomial.nth_add })
             = Polynomial.Coefficients.multiply(r, p, Polynomial.Coefficients.add(r, q, s))[k]
                   by Polynomial.nth_multiply

theorem Polynomial.multiply_distributivity_left (r : Ring)
        (x y z : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : (x * (y + z))
          = ((x * y) + (x * z)) :=
  by_representatives x as p, y as q, z as s => {
      Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
          Polynomial.Coefficients.multiply(r, p, Polynomial.Coefficients.add(r, q, s)),
          Polynomial.Coefficients.add(r,
              Polynomial.Coefficients.multiply(r, p, q),
              Polynomial.Coefficients.multiply(r, p, s)))
        by Polynomial.Coefficients.multiply_distributivity_left;
      done by Polynomial.make_equal_of_coefficients_equal
  }

-- ----------------------------------------------------------------------
-- Right distributivity: (p + q) · s = p·s + q·s.

theorem Polynomial.Coefficients.multiply_distributivity_right (r : Ring)
        (p q s : Polynomial.Coefficients(Ring.carrier(r)))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.add(r, p, q), s),
              Polynomial.Coefficients.add(r,
                  Polynomial.Coefficients.multiply(r, p, s),
                  Polynomial.Coefficients.multiply(r, q, s))) :=
  (k : ℕ) ↦
      Polynomial.Coefficients.add(r, Polynomial.Coefficients.multiply(r, p, s), Polynomial.Coefficients.multiply(r, q, s))[k]
             = (Polynomial.Coefficients.multiply(r, p, s)[k] + Polynomial.Coefficients.multiply(r, q, s)[k])
             = (Ring.Sum(r, (i : ℕ) ↦ (p[i] * s[Natural.monus(k, i)]), k) + Polynomial.Coefficients.multiply(r, q, s)[k])
                   by Polynomial.nth_multiply
             = (Ring.Sum(r, (i : ℕ) ↦ (p[i] * s[Natural.monus(k, i)]), k)
                    + Ring.Sum(r, (i : ℕ) ↦ (q[i] * s[Natural.monus(k, i)]), k))
                   by Polynomial.nth_multiply
             = Ring.Sum(r, (i : ℕ) ↦ ((p[i] * s[Natural.monus(k, i)]) + (q[i] * s[Natural.monus(k, i)])), k)
                   by Ring.Sum.add
             = Ring.Sum(r, (i : ℕ) ↦ ((p[i] + q[i]) * s[Natural.monus(k, i)]), k)
                   by ((i : ℕ) ↦
                          { (p[i] * s[Natural.monus(k, i)]) + (q[i] * s[Natural.monus(k, i)])
                             = ((p[i] + q[i]) * s[Natural.monus(k, i)])
                                   by Ring.distributivity_right })
             = Ring.Sum(r, (i : ℕ) ↦ (Polynomial.Coefficients.add(r, p, q)[i] * s[Natural.monus(k, i)]), k)
                   by ((i : ℕ) ↦
                          { ((p[i] + q[i]) * s[Natural.monus(k, i)])
                             = (Polynomial.Coefficients.add(r, p, q)[i] * s[Natural.monus(k, i)])
                                   by Polynomial.nth_add })
             = Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.add(r, p, q), s)[k]
                   by Polynomial.nth_multiply

theorem Polynomial.multiply_distributivity_right (r : Ring)
        (x y z : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : ((x + y) * z)
          = ((x * z) + (y * z)) :=
  by_representatives x as p, y as q, z as s => {
      Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
          Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.add(r, p, q), s),
          Polynomial.Coefficients.add(r,
              Polynomial.Coefficients.multiply(r, p, s),
              Polynomial.Coefficients.multiply(r, q, s)))
        by Polynomial.Coefficients.multiply_distributivity_right;
      done by Polynomial.make_equal_of_coefficients_equal
  }

-- ----------------------------------------------------------------------
-- Multiplicative identities. The coefficient list of 1 is [one]; the
-- left identity is structural (1·p = scale(one, p) + shift(nil·p), and
-- scale(one,·) is the identity coefficient-wise while the shift adds
-- only zeros).

theorem Polynomial.Coefficients.nth_cons_zero_nil (r : Ring) (k : ℕ)
        : Polynomial.Coefficients.cons(Ring.carrier(r), Ring.zero(r), Polynomial.Coefficients.nil(Ring.carrier(r)))[k]
          = Ring.zero(r) :=
  done by cases {
    case k = 0: reflexivity(Ring.carrier(r), Ring.zero(r))
    case k = 1 + j for some j:
        Polynomial.Coefficients.cons(Ring.carrier(r), Ring.zero(r), Polynomial.Coefficients.nil(Ring.carrier(r)))[1 + j]
           = Polynomial.Coefficients.nil(Ring.carrier(r))[j]   by Polynomial.nth_cons_one_plus
           = Ring.zero(r)                                      by Polynomial.nth_nil
  }

automatic theorem Polynomial.Coefficients.multiply_one_left (r : Ring)
        (p : Polynomial.Coefficients(Ring.carrier(r)))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.multiply(r,
                  Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                      Polynomial.Coefficients.nil(Ring.carrier(r))),
                  p),
              p) :=
  (k : ℕ) ↦
      Polynomial.Coefficients.multiply(r,
              Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r), Polynomial.Coefficients.nil(Ring.carrier(r))), p)[k]
         = (Polynomial.Coefficients.scale(r, Ring.one(r), p)[k]
                + Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.nil(Ring.carrier(r)), p))[k])
               by Polynomial.nth_add
         = ((Ring.one(r) * p[k])
                + Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.nil(Ring.carrier(r)), p))[k])
         = (p[k]
                + Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.nil(Ring.carrier(r)), p))[k])
         = (p[k] + Ring.zero(r))
         = p[k]

theorem Polynomial.multiply_one_left (r : Ring)
        (x : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : (Polynomial.one(r) * x) = x :=
  by_representatives x as p => {
    Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
        Polynomial.Coefficients.multiply(r,
            Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                Polynomial.Coefficients.nil(Ring.carrier(r))),
            p),
        p)
      by Polynomial.Coefficients.multiply_one_left;
    done by Polynomial.make_equal_of_coefficients_equal
  }

-- ----------------------------------------------------------------------
-- Right identity: p · 1 = p. By induction on p (multiplication recurses
-- on its first argument). At each step the coefficient of 1 is `one` at
-- index 0 and zero beyond, so the head becomes a·one = a and the tail
-- is the inductive hypothesis.

theorem Polynomial.Coefficients.multiply_one_right (r : Ring)
        (p : Polynomial.Coefficients(Ring.carrier(r)))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.multiply(r, p,
                  Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                      Polynomial.Coefficients.nil(Ring.carrier(r)))),
              p) :=
  by induction on p with IH {
    case Polynomial.Coefficients.nil:
        (k : ℕ) ↦
            reflexivity(Ring.carrier(r), Polynomial.Coefficients.nil(Ring.carrier(r))[k])
    case Polynomial.Coefficients.cons(a, rest):
        (k : ℕ) ↦
            done by cases {
              case k = 0:
                  Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, rest),
                          Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r), Polynomial.Coefficients.nil(Ring.carrier(r))))[0]
                     = (Polynomial.Coefficients.scale(r, a,
                                Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r), Polynomial.Coefficients.nil(Ring.carrier(r))))[0]
                            + Polynomial.Coefficients.shift(r,
                                  Polynomial.Coefficients.multiply(r, rest,
                                      Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                          Polynomial.Coefficients.nil(Ring.carrier(r)))))[0])
                     = ((a * Ring.one(r)) + Ring.zero(r))
                     = (a + Ring.zero(r))
                     = a
              case k = 1 + j for some j: {
                  Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, rest),
                          Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r), Polynomial.Coefficients.nil(Ring.carrier(r))))[1 + j]
                     = (Polynomial.Coefficients.scale(r, a,
                                Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                    Polynomial.Coefficients.nil(Ring.carrier(r))))[1 + j]
                            + Polynomial.Coefficients.shift(r,
                                  Polynomial.Coefficients.multiply(r, rest,
                                      Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                          Polynomial.Coefficients.nil(Ring.carrier(r)))))[1 + j])
                           by Polynomial.nth_add
                     = ((a * Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                Polynomial.Coefficients.nil(Ring.carrier(r)))[1 + j])
                            + Polynomial.Coefficients.shift(r,
                                  Polynomial.Coefficients.multiply(r, rest,
                                      Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                          Polynomial.Coefficients.nil(Ring.carrier(r)))))[1 + j])
                           by Polynomial.nth_scale
                     = ((a * Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                Polynomial.Coefficients.nil(Ring.carrier(r)))[1 + j])
                            + Polynomial.Coefficients.multiply(r, rest,
                                  Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                      Polynomial.Coefficients.nil(Ring.carrier(r))))[j])
                           by Polynomial.nth_shift_one_plus
                     = ((a * Polynomial.Coefficients.nil(Ring.carrier(r))[j])
                            + Polynomial.Coefficients.multiply(r, rest,
                                  Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                      Polynomial.Coefficients.nil(Ring.carrier(r))))[j])
                           by Polynomial.coefficient_cons_one_plus
                     = ((a * Ring.zero(r))
                            + Polynomial.Coefficients.multiply(r, rest,
                                  Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                      Polynomial.Coefficients.nil(Ring.carrier(r))))[j])
                     = (Ring.zero(r)
                            + Polynomial.Coefficients.multiply(r, rest,
                                  Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                      Polynomial.Coefficients.nil(Ring.carrier(r))))[j])
                     = Polynomial.Coefficients.multiply(r, rest,
                               Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                                   Polynomial.Coefficients.nil(Ring.carrier(r))))[j]
                     = rest[j]
                           by IH(j);
                  done by substituting Natural.one_add
                }
            }
  }

theorem Polynomial.multiply_one_right (r : Ring)
        (x : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : (x * Polynomial.one(r)) = x :=
  by_representatives x as p => {
    Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
        Polynomial.Coefficients.multiply(r, p,
            Polynomial.Coefficients.cons(Ring.carrier(r), Ring.one(r),
                Polynomial.Coefficients.nil(Ring.carrier(r)))),
        p)
      by Polynomial.Coefficients.multiply_one_right;
    done by Polynomial.make_equal_of_coefficients_equal
  }

-- ----------------------------------------------------------------------
-- Helpers for associativity (structural induction on the first list).

-- Shift respects the equivalence.
theorem Polynomial.Coefficients.shift_respects (r : Ring)
        (x y : Polynomial.Coefficients(Ring.carrier(r)))
        (equal : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r), x, y))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.shift(r, x), Polynomial.Coefficients.shift(r, y)) :=
  (k : ℕ) ↦
      done by cases {
        case k = 0: reflexivity(Ring.carrier(r), Ring.zero(r))
        case k = 1 + j for some j: {
            x[j] = y[j] by equal(j);
            done by substituting Natural.one_add
          }
      }

-- (a·q)·s = a·(q·s):  multiply(scale(a, q), s) ~ scale(a, multiply(q, s)).
theorem Polynomial.Coefficients.scale_multiply (r : Ring) (a : Ring.carrier(r))
        (q s : Polynomial.Coefficients(Ring.carrier(r)))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.scale(r, a, q), s),
              Polynomial.Coefficients.scale(r, a, Polynomial.Coefficients.multiply(r, q, s))) :=
  (k : ℕ) ↦
      Polynomial.Coefficients.scale(r, a, Polynomial.Coefficients.multiply(r, q, s))[k]
             = (a * Polynomial.Coefficients.multiply(r, q, s)[k])
             = (a * Ring.Sum(r, (i : ℕ) ↦ (q[i] * s[Natural.monus(k, i)]), k))
                   by Polynomial.nth_multiply
             = Ring.Sum(r, (i : ℕ) ↦ (a * (q[i] * s[Natural.monus(k, i)])), k)
                   by Ring.Sum.scale_left
             = Ring.Sum(r, (i : ℕ) ↦ ((a * q[i]) * s[Natural.monus(k, i)]), k)
                   by ((i : ℕ) ↦
                          { (a * (q[i] * s[Natural.monus(k, i)]))
                             = ((a * q[i]) * s[Natural.monus(k, i)])
                                   by Ring.multiply_associative })
             = Ring.Sum(r, (i : ℕ) ↦ (Polynomial.Coefficients.scale(r, a, q)[i] * s[Natural.monus(k, i)]), k)
                   by ((i : ℕ) ↦
                          { ((a * q[i]) * s[Natural.monus(k, i)])
                             = (Polynomial.Coefficients.scale(r, a, q)[i] * s[Natural.monus(k, i)])
                                   by Polynomial.nth_scale })
             = Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.scale(r, a, q), s)[k]
                   by Polynomial.nth_multiply

-- (x·y)·s = x·(y·s) when x = shift(·):  multiply(shift(y), s) ~ shift(multiply(y, s)).
theorem Polynomial.Coefficients.shift_multiply (r : Ring)
        (y s : Polynomial.Coefficients(Ring.carrier(r)))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.shift(r, y), s),
              Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, y, s))) :=
  (k : ℕ) ↦
      done by cases {
        case k = 0:
            Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.shift(r, y), s)[0]
               = Ring.Sum(r, (i : ℕ) ↦ (Polynomial.Coefficients.shift(r, y)[i] * s[Natural.monus(0, i)]), 0)
                   by Polynomial.nth_multiply
               = (Polynomial.Coefficients.shift(r, y)[0] * s[Natural.monus(0, 0)])
                   by Ring.Sum.base
               = (Ring.zero(r) * s[Natural.monus(0, 0)])
               = Ring.zero(r)
               = Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, y, s))[0]
        case k = 1 + predecessor for some predecessor: {
              Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.shift(r, y), s)[1 + predecessor]
                 = Ring.Sum(r,
                       (i : ℕ) ↦
                           (Polynomial.Coefficients.shift(r, y)[i] * s[Natural.monus(1 + predecessor, i)]), 1 + predecessor)
                     by Polynomial.nth_multiply
                 = ((Polynomial.Coefficients.shift(r, y)[0] * s[1 + predecessor])
                        + Ring.Sum(r,
                              (j : ℕ) ↦ (Polynomial.Coefficients.shift(r, y)[1 + j] * s[Natural.monus(predecessor, j)]), predecessor))
                     by Ring.Sum.convolution_shift(r,
                            (i : ℕ) ↦ Polynomial.Coefficients.shift(r, y)[i],
                            (m : ℕ) ↦ s[m],
                            predecessor)
                 = ((Ring.zero(r) * s[1 + predecessor])
                        + Ring.Sum(r,
                              (j : ℕ) ↦ (Polynomial.Coefficients.shift(r, y)[1 + j] * s[Natural.monus(predecessor, j)]), predecessor))
                 = (Ring.zero(r)
                        + Ring.Sum(r,
                              (j : ℕ) ↦ (Polynomial.Coefficients.shift(r, y)[1 + j] * s[Natural.monus(predecessor, j)]), predecessor))
                 = Ring.Sum(r, (j : ℕ) ↦ (Polynomial.Coefficients.shift(r, y)[1 + j] * s[Natural.monus(predecessor, j)]), predecessor)
                 = Ring.Sum(r, (j : ℕ) ↦ (y[j] * s[Natural.monus(predecessor, j)]), predecessor)
                     by Ring.Sum.extensional(r,
                            (j : ℕ) ↦ (Polynomial.Coefficients.shift(r, y)[1 + j] * s[Natural.monus(predecessor, j)]),
                            (j : ℕ) ↦ (y[j] * s[Natural.monus(predecessor, j)]),
                            (j : ℕ) ↦
                                { (Polynomial.Coefficients.shift(r, y)[1 + j] * s[Natural.monus(predecessor, j)])
                                      = (y[j] * s[Natural.monus(predecessor, j)])
                                      by substituting Polynomial.nth_shift_one_plus },
                            predecessor)
                 = Polynomial.Coefficients.multiply(r, y, s)[predecessor]
                     by Polynomial.nth_multiply
                 = Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, y, s))[1 + predecessor]
                     by Polynomial.nth_shift_one_plus;
              done by substituting Natural.one_add
          }
      }

-- ----------------------------------------------------------------------
-- Associativity, by induction on the first list. On `cons(a, restA)`:
--   (cons(a,restA)·q)·s
--     = (scale(a,q) + shift(restA·q))·s
--     = scale(a,q)·s + shift(restA·q)·s          [right distributivity]
--     = scale(a, q·s) + shift((restA·q)·s)       [scale_multiply, shift_multiply]
--     = scale(a, q·s) + shift(restA·(q·s))       [IH, through shift]
--     = cons(a,restA)·(q·s).

theorem Polynomial.Coefficients.multiply_assoc (r : Ring)
        (p q s : Polynomial.Coefficients(Ring.carrier(r)))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.multiply(r, p, q), s),
              Polynomial.Coefficients.multiply(r, p, Polynomial.Coefficients.multiply(r, q, s))) :=
  by induction on p with inductiveHypothesis {
    case Polynomial.Coefficients.nil:
        (k : ℕ) ↦
            reflexivity(Ring.carrier(r), Polynomial.Coefficients.nil(Ring.carrier(r))[k])
    case Polynomial.Coefficients.cons(a, restA):
        (k : ℕ) ↦
            Polynomial.Coefficients.multiply(r,
                    Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.cons(Ring.carrier(r), a, restA), q), s)[k]
               = Polynomial.Coefficients.add(r,
                         Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.scale(r, a, q), s),
                         Polynomial.Coefficients.multiply(r,
                             Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, restA, q)), s))[k]
                     by Polynomial.Coefficients.multiply_distributivity_right(r,
                            Polynomial.Coefficients.scale(r, a, q),
                            Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, restA, q)),
                            s, k)
               = (Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.scale(r, a, q), s)[k]
                      + Polynomial.Coefficients.multiply(r,
                            Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, restA, q)), s)[k])
               = (Polynomial.Coefficients.scale(r, a, Polynomial.Coefficients.multiply(r, q, s))[k]
                      + Polynomial.Coefficients.multiply(r,
                            Polynomial.Coefficients.shift(r, Polynomial.Coefficients.multiply(r, restA, q)), s)[k])
                     by Polynomial.Coefficients.scale_multiply(r, a, q, s, k)
               = (Polynomial.Coefficients.scale(r, a, Polynomial.Coefficients.multiply(r, q, s))[k]
                      + Polynomial.Coefficients.shift(r,
                            Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.multiply(r, restA, q), s))[k])
                     by Polynomial.Coefficients.shift_multiply(r, Polynomial.Coefficients.multiply(r, restA, q), s, k)
               = (Polynomial.Coefficients.scale(r, a, Polynomial.Coefficients.multiply(r, q, s))[k]
                      + Polynomial.Coefficients.shift(r,
                            Polynomial.Coefficients.multiply(r, restA, Polynomial.Coefficients.multiply(r, q, s)))[k])
                     by Polynomial.Coefficients.shift_respects(r,
                            Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.multiply(r, restA, q), s),
                            Polynomial.Coefficients.multiply(r, restA, Polynomial.Coefficients.multiply(r, q, s)),
                            inductiveHypothesis, k)
               = Polynomial.Coefficients.multiply(r,
                         Polynomial.Coefficients.cons(Ring.carrier(r), a, restA), Polynomial.Coefficients.multiply(r, q, s))[k]
                     by Polynomial.nth_add
  }

automatic theorem Polynomial.multiply_associative (r : Ring)
        (x y z : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : ((x * y) * z)
          = (x * (y * z)) :=
  by_representatives x as p, y as q, z as s => {
      Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
          Polynomial.Coefficients.multiply(r, Polynomial.Coefficients.multiply(r, p, q), s),
          Polynomial.Coefficients.multiply(r, p, Polynomial.Coefficients.multiply(r, q, s)))
        by Polynomial.Coefficients.multiply_assoc;
      done by Polynomial.make_equal_of_coefficients_equal
  }

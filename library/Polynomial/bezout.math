-- Polynomial/bezout.math
--
-- The Euclidean algorithm for polynomials over a field, producing a
-- gcd together with its Bézout combination:
--   ∀ x y. ∃ m a b. m = a·x + b·y ∧ m | x ∧ m | y.
-- Run as strong induction on a degree bound for the second argument y:
-- if y = 0 the gcd is x; otherwise divide x by y (its leading
-- coefficient is invertible because the ring is a field), giving
-- x = q·y + rem with deg rem < deg y, recurse on (y, rem), and
-- back-substitute the Bézout coefficients.
--
-- The field structure enters only as the inverse-existence hypothesis
-- (every nonzero element is invertible) plus commutativity.

module Polynomial.bezout

import axioms
import Logic.basics
import Logic.exists
import Logic.sum
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.subtraction
import Natural.decide
import Natural.add_order
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Algebra.ring_divisibility
import Polynomial.basics
import Polynomial.addition
import Polynomial.negation
import Polynomial.additive_group
import Polynomial.multiplication
import Polynomial.multiply_laws
import Polynomial.commutative
import Polynomial.instances
import Polynomial.degree
import Polynomial.division
import Polynomial.degree_function

-- ----------------------------------------------------------------------
-- Polynomial-level wrappers for the abstract ring negate-multiply laws.

theorem Polynomial.multiply_negate_left (r : Ring)
        (a b : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : ((- a) * b)
          = (- (a * b)) :=
  Ring.multiply_negate_left(
      Ring.carrier(Polynomial.ring(r)), Ring.add,
      Ring.zero(Polynomial.ring(r)), Ring.negate,
      Ring.multiply, Ring.one(Polynomial.ring(r)),
      Ring.is_ring(Polynomial.ring(r)), a, b)

theorem Polynomial.multiply_negate_right (r : Ring)
        (a b : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : (a * (- b))
          = (- (a * b)) :=
  Ring.multiply_negate_right(
      Ring.carrier(Polynomial.ring(r)), Ring.add,
      Ring.zero(Polynomial.ring(r)), Ring.negate,
      Ring.multiply, Ring.one(Polynomial.ring(r)),
      Ring.is_ring(Polynomial.ring(r)), a, b)

-- add(a, add(b, c)) = add(b, add(a, c)).
theorem Polynomial.add_swap_first (r : Ring)
        (a b c : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : (a + (b + c))
          = (b + (a + c)) :=
  calc (a + (b + c))
     = ((a + b) + c)
     = ((b + a) + c)
     = (b + (a + c))

-- ----------------------------------------------------------------------
-- ¬(bound ≤ dy) is what guarantees the recursion shrinks; package the
-- Natural step ¬(bound ≤ dy) ⟹ successor(dy) ≤ bound.

theorem Natural.not_le_implies_successor_le (bound dy : Natural)
        (notLessOrEqual : ¬(bound ≤ dy))
        : successor(dy) ≤ bound :=
  cases Natural.totality_of_less_or_equal(successor(dy), bound) {
    | Or.introduceLeft(successorLessOrEqual) => successorLessOrEqual
    | Or.introduceRight(boundLessOrEqualSuccessor) =>
        decide bound = successor(dy) {
          | yes boundIsSuccessor => {
              claim successorLessOrEqualBound : successor(dy) ≤ bound
                  by substituting boundIsSuccessor;
              successorLessOrEqualBound
            }
          | no boundNotSuccessor =>
              absurd(notLessOrEqual(
                  Natural.less_or_equal_successor_not_equal(bound, dy,
                      boundLessOrEqualSuccessor, boundNotSuccessor)))
        }
  }

-- ----------------------------------------------------------------------
-- The Euclidean algorithm with Bézout coefficients.

theorem Polynomial.gcd_bezout (r : Ring)
        (commutativity
            : (x y : Ring.carrier(r)) → (x * y) = (y * x))
        (inverseExistence
            : (x : Ring.carrier(r)) → ¬(x = Ring.zero(r))
                → ∃ (inverse : Ring.carrier(r)). (x * inverse) = Ring.one(r))
        (bound : Natural)
        : (y : Polynomial(Ring.carrier(r), Ring.zero(r)))
          → Polynomial.DegreeLessThan(r, y, bound)
          → (x : Polynomial(Ring.carrier(r), Ring.zero(r)))
          → ∃ (m a b : Polynomial(Ring.carrier(r), Ring.zero(r))).
              m = ((a * x) + (b * y))
              ∧ Ring.divides(Polynomial.ring(r), m, x)
              ∧ Ring.divides(Polynomial.ring(r), m, y) :=
  Natural.strong_induction(
    (degreeBoundVariable : Natural) ↦
        (y : Polynomial(Ring.carrier(r), Ring.zero(r)))
        → Polynomial.DegreeLessThan(r, y, degreeBoundVariable)
        → (x : Polynomial(Ring.carrier(r), Ring.zero(r)))
        → ∃ (m a b : Polynomial(Ring.carrier(r), Ring.zero(r))).
            m = ((a * x) + (b * y))
            ∧ Ring.divides(Polynomial.ring(r), m, x)
            ∧ Ring.divides(Polynomial.ring(r), m, y),
    (subject : Natural)
             (IH : (k : Natural) → successor(k) ≤ subject
                   → (y : Polynomial(Ring.carrier(r), Ring.zero(r)))
                     → Polynomial.DegreeLessThan(r, y, k)
                     → (x : Polynomial(Ring.carrier(r), Ring.zero(r)))
                     → ∃ (m a b : Polynomial(Ring.carrier(r), Ring.zero(r))).
                         m = ((a * x) + (b * y))
                         ∧ Ring.divides(Polynomial.ring(r), m, x)
                         ∧ Ring.divides(Polynomial.ring(r), m, y)) ↦
        (y : Polynomial(Ring.carrier(r), Ring.zero(r)))
                 (yBound : Polynomial.DegreeLessThan(r, y, subject))
                 (x : Polynomial(Ring.carrier(r), Ring.zero(r))) ↦
        decide y = Polynomial.zero(r) {
          | yes yIsZero => {
              claim yIsRingZero : Ring.zero(Polynomial.ring(r)) = y
                  by yIsZero;
              -- gcd = x: x = 1·x + 0·y, x | x, x | 0 = y.
              ⟨x, Polynomial.one(r), Polynomial.zero(r),
               calc x
                  = (Polynomial.one(r) * x)
                  = ((Polynomial.one(r) * x) + Polynomial.zero(r))
                  = ((Polynomial.one(r) * x) + (Polynomial.zero(r) * y))
                        by Ring.zero_multiply_left(Polynomial.ring(r), y),
               Ring.divides_reflexive(Polynomial.ring(r), x),
               rewrite(yIsRingZero, Ring.divides_zero(Polynomial.ring(r), x))⟩
            }
          | no yNotZero => {
              obtain ⟨degreeY, yDegreeBound, leadingNonzero⟩
                  from Polynomial.exists_degree_of_nonzero(r, y, yNotZero);
              claim successorDegreeLessOrEqualBound : successor(degreeY) ≤ subject
                  by Natural.not_le_implies_successor_le(subject, degreeY,
                         (boundLessOrEqual : subject ≤ degreeY) ↦
                             leadingNonzero(yBound(degreeY, boundLessOrEqual)));
              obtain ⟨quotient, remainder, divisionEquation, remainderBound⟩
                  from Polynomial.division_with_remainder(r, commutativity, y, degreeY,
                           yDegreeBound,
                           inverseExistence(Polynomial.coefficientOf(r, y, degreeY),
                               leadingNonzero),
                           x);
              -- divisionEquation : x = quotient·y + remainder.
              obtain ⟨m, aRest, bRest, restEquation, mDividesY, mDividesRemainder⟩
                  from IH(degreeY, successorDegreeLessOrEqualBound, remainder, remainderBound, y);
              -- restEquation : m = aRest·y + bRest·remainder.
              calc (x + (- (quotient * y)))
                         = (((quotient * y) + remainder) + (- (quotient * y)))
                         = ((remainder + (quotient * y)) + (- (quotient * y)))
                         = (remainder + ((quotient * y) + (- (quotient * y))))
                         = (remainder + Polynomial.zero(r))
                         = remainder as remainderEquation;

              claim mDividesQuotientY
                  : Ring.divides(Polynomial.ring(r), m,
                        (quotient * y))
                  by Ring.divides_multiply_left(Polynomial.ring(r),
                         Polynomial.multiply_commutative(r, commutativity),
                         m, y, quotient, mDividesY);
              claim mDividesX : Ring.divides(Polynomial.ring(r), m, x)
                  by rewrite(Equality.symmetry(divisionEquation),
                         Ring.divides_add(Polynomial.ring(r), m,
                             (quotient * y), remainder,
                             mDividesQuotientY, mDividesRemainder));

              ⟨m, bRest,
               (aRest + (- (bRest * quotient))),
               calc m
                  = ((aRest * y) + (bRest * remainder))
                  = ((aRest * y) + (bRest * (x + (- (quotient * y)))))
                  = ((aRest * y) + ((bRest * x) + (bRest * (- (quotient * y)))))
                  = ((aRest * y) + ((bRest * x) + (- (bRest * (quotient * y)))))
                  = ((bRest * x) + ((aRest * y) + (- (bRest * (quotient * y)))))
                  = ((bRest * x) + ((aRest * y) + (- ((bRest * quotient) * y))))
                  = ((bRest * x) + ((aRest * y) + ((- (bRest * quotient)) * y)))
                  = ((bRest * x) + ((aRest + (- (bRest * quotient))) * y)),
               mDividesX,
               mDividesY⟩
            }
        },
    bound)

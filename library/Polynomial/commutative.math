-- Polynomial/commutative.math
--
-- Commutativity of polynomial multiplication when the coefficient ring
-- is commutative, and the resulting IsCommutativeRing instance. The
-- convolution Σ_{i=0}^{k} p_i·q_{k-i} is symmetric in p and q: reflect
-- the sum (Sum.reverse), use the involution monus(k, monus(k,i)) = i on
-- the summation range, and commute the ring product.

module Polynomial.commutative

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.monus
import Natural.subtraction
import Algebra.monoid
import Algebra.ring
import Algebra.ring_bundle
import Polynomial.basics
import Polynomial.addition
import Polynomial.negation
import Polynomial.additive_group
import Algebra.ring_summation
import Polynomial.multiplication
import Polynomial.multiply_laws
import Polynomial.instances

-- ----------------------------------------------------------------------
-- Natural arithmetic helpers for the reflection.

theorem Natural.monus_add_cancel_left (a : Natural)
        : ∀ (b : Natural). Natural.monus(a + b, a) = b :=
  by induction on a with IH {
    case 0:
        (b : Natural) ↦ { done by Natural.monus_zero }
    case 1 + predecessor:
        (b : Natural) ↦
          Natural.monus((1 + predecessor) + b, 1 + predecessor)
             = Natural.monus(1 + (predecessor + b), 1 + predecessor)
                 by Natural.add_associative
             = Natural.monus(predecessor + b, predecessor)
                 by Natural.monus_one_plus_one_plus
             = b
                 by IH(b)
  }

theorem Natural.monus_add_involution (i d : Natural)
        : Natural.monus(i + d, Natural.monus(i + d, i)) = i :=
  Natural.monus(i + d, Natural.monus(i + d, i))
     = Natural.monus(i + d, d)
     = Natural.monus(d + i, d)
     = i

theorem Natural.monus_monus_self (k i : Natural) (h : i ≤ k)
        : Natural.monus(k, Natural.monus(k, i)) = i := {
  choose d such that k = i + d as decomposition from Natural.subtraction_witness;
  -- rewrite k throughout, then it's the monus/add involution.
  Natural.monus(k, Natural.monus(k, i))
     = Natural.monus(i + d, Natural.monus(i + d, i))   by substituting decomposition
     = i                                                by Natural.monus_add_involution
}

-- Sum respects pointwise equality on the summation range 0..n.
theorem Ring.Sum.extensional_range (r : Ring)
        (f g : Natural → Ring.carrier(r)) (n : Natural)
        (h : ∀ (i : Natural). i ≤ n → f(i) = g(i))
        : Ring.Sum(r, f, n) = Ring.Sum(r, g, n) :=
  by induction on n with IH {
    case base:
        Ring.Sum(r, f, 0)
           = f(0)
           = g(0)               by h(0, Natural.LessOrEqual.reflexive)
           = Ring.Sum(r, g, 0)
    case step(k): {
        ∀ (i : Natural). i ≤ k → f(i) = g(i) by {
            take i : Natural;
            suppose i ≤ k as smaller;
            i ≤ 1 + k;
            done
          };
        Ring.Sum(r, f, 1 + k)
           = (Ring.Sum(r, f, k) + f(1 + k))
           = (Ring.Sum(r, g, k) + f(1 + k))
               by IH
           = (Ring.Sum(r, g, k) + g(1 + k))
               by h(1 + k, Natural.LessOrEqual.reflexive)
           = Ring.Sum(r, g, 1 + k)
      }
  }

-- Register the range-restricted variant too: a `Sum(r,f,n) = Sum(r,g,n)`
-- step also closes from `(i) => i ≤ n => f(i) = g(i)`. The elaborator
-- tries Sum.extensional first (fails on the 2-binder lambda) then this.
congruence_under_binder Ring.Sum := Ring.Sum.extensional_range

-- ----------------------------------------------------------------------
-- Sum reflection: Σ_{i=0}^{n} f(i) = Σ_{i=0}^{n} f(n−i).

theorem Ring.Sum.reverse (r : Ring) (f : Natural → Ring.carrier(r))
        (n : Natural)
        : Ring.Sum(r, f, n)
          = Ring.Sum(r, (i : Natural) ↦ f(Natural.monus(n, i)), n) :=
  by induction on n with IH {
    case base:
        Ring.Sum(r, f, 0)
           = f(0)
           = f(Natural.monus(0, 0))
           = Ring.Sum(r, (i : Natural) ↦ f(Natural.monus(0, i)), 0)   by substituting Ring.Sum.base
    case step(k): {
        Ring.Sum(r, (i : Natural) ↦ f(Natural.monus(k, i)), k)
              = Ring.Sum(r,
                    (i : Natural) ↦ f(Natural.monus(1 + k, 1 + i)), k)
          by Ring.Sum.extensional_range(r,
                 (i : Natural) ↦ f(Natural.monus(k, i)),
                 (i : Natural) ↦ f(Natural.monus(1 + k, 1 + i)),
                 k,
                 (i : Natural) (_ : i ≤ k) ↦
                     { f(Natural.monus(k, i))
                        = f(Natural.monus(1 + k, 1 + i))
                            by substituting Natural.monus_one_plus_one_plus }) as tailReindex;
        Ring.Sum(r, f, 1 + k)
           = (Ring.Sum(r, f, k) + f(1 + k))
           = (f(1 + k) + Ring.Sum(r, f, k))
           = (f(1 + k)
              + Ring.Sum(r, (i : Natural) ↦ f(Natural.monus(k, i)), k))
           = (f(Natural.monus(1 + k, 0))
              + Ring.Sum(r, (i : Natural) ↦ f(Natural.monus(k, i)), k))
               by substituting Natural.monus_one_plus_zero
           = (f(Natural.monus(1 + k, 0))
              + Ring.Sum(r,
                    (i : Natural) ↦ f(Natural.monus(1 + k, 1 + i)), k))
               by substituting tailReindex
           = Ring.Sum(r, (i : Natural) ↦ f(Natural.monus(1 + k, i)), 1 + k)
               by Ring.Sum.shift_one_plus
  }
  }

-- ----------------------------------------------------------------------
-- Commutativity of the convolution when the ring is commutative.

theorem Polynomial.Coefficients.multiply_commutative (r : Ring)
        (ringCommutative : ∀ (x y : Ring.carrier(r)). (x * y) = (y * x))
        (p q : Polynomial.Coefficients(Ring.carrier(r)))
        : Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
              Polynomial.Coefficients.multiply(r, p, q),
              Polynomial.Coefficients.multiply(r, q, p)) :=
  (k : Natural) ↦
      Polynomial.coefficient(Polynomial.Coefficients.multiply(r, p, q), k)
         = Ring.Sum(r,
               (i : Natural) ↦
                   (Polynomial.coefficient(p, i) * Polynomial.coefficient(q, Natural.monus(k, i))), k)
               by Polynomial.nth_multiply
         = Ring.Sum(r,
               (i : Natural) ↦
                   (Polynomial.coefficient(p, Natural.monus(k, i)) * Polynomial.coefficient(q, Natural.monus(k, Natural.monus(k, i)))), k)
               by Ring.Sum.reverse
         = Ring.Sum(r,
               (i : Natural) ↦
                   (Polynomial.coefficient(q, i) * Polynomial.coefficient(p, Natural.monus(k, i))), k)
               by ((i : Natural) (smaller : i ≤ k) ↦
                      (Polynomial.coefficient(p, Natural.monus(k, i)) * Polynomial.coefficient(q, Natural.monus(k, Natural.monus(k, i))))
                         = (Polynomial.coefficient(p, Natural.monus(k, i)) * Polynomial.coefficient(q, i))
                         = (Polynomial.coefficient(q, i) * Polynomial.coefficient(p, Natural.monus(k, i)))
                               by ringCommutative(Polynomial.coefficient(p, Natural.monus(k, i)),
                                      Polynomial.coefficient(q, i)))
         = Polynomial.coefficient(Polynomial.Coefficients.multiply(r, q, p), k)
               by Polynomial.nth_multiply

theorem Polynomial.multiply_commutative (r : Ring)
        (ringCommutative : ∀ (x y : Ring.carrier(r)). (x * y) = (y * x))
        (x y : Polynomial(Ring.carrier(r), Ring.zero(r)))
        : (x * y) = (y * x) :=
  by_representatives x as p, y as q => {
      Polynomial.ExtensionallyEqual(Ring.carrier(r), Ring.zero(r),
          Polynomial.Coefficients.multiply(r, p, q),
          Polynomial.Coefficients.multiply(r, q, p))
              by Polynomial.Coefficients.multiply_commutative as coefficientsCommute;
      done by Polynomial.make_equal_of_coefficients_equal(equal := coefficientsCommute)
  }

-- The polynomial ring over a commutative ring is commutative.
theorem Polynomial.is_commutative_ring (r : Ring)
        (ringCommutative : ∀ (x y : Ring.carrier(r)). (x * y) = (y * x))
        : IsCommutativeRing(Polynomial(Ring.carrier(r), Ring.zero(r)),
              Polynomial.add, Polynomial.zero(r), Polynomial.negate,
              Polynomial.multiply, Polynomial.one(r)) :=
  {
      IsRing(Polynomial(Ring.carrier(r), Ring.zero(r)),
             Polynomial.add, Polynomial.zero(r), Polynomial.negate,
             Polynomial.multiply, Polynomial.one(r))
          by Polynomial.is_ring;
      (∀ (x y : Polynomial(Ring.carrier(r), Ring.zero(r))). (x * y) = (y * x))
          by Polynomial.multiply_commutative;
      done
  }

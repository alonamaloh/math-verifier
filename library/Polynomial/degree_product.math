-- Polynomial/degree_product.math
--
-- Degree of a product over a field: deg(a·b) = deg a + deg b. The key
-- fact is that the top coefficient of the product is the product of the
-- top coefficients — which is nonzero because a field has no zero
-- divisors. Below the top, the convolution vanishes term by term.
--
-- `HasDegree(p, d)` packages "degree exactly d": coefficients vanish
-- above d and the coefficient at d is nonzero.

module Polynomial.degree_product

import Logic.basics
import Logic.excluded_middle
import Logic.exists
import Logic.sum
import Equality.basics
import Natural.basics
import Natural.classical_decidable
import Natural.peano
import Natural.order
import Natural.subtraction
import Natural.arithmetic
import Natural.monus
import Natural.add_order
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Polynomial.basics
import Polynomial.multiplication
import Algebra.ring_summation
import Polynomial.instances
import Polynomial.degree
import Polynomial.multiply_coefficient
import Polynomial.division_support

-- i ≤ m or m < i.
theorem Natural.le_or_successor_le (i m : Natural)
        : i ≤ m ∨ successor(m) ≤ i := {
  i ≤ m ∨ m ≤ i;
  done by cases {
    case i ≤ m: done
    case m ≤ i:
        done by cases {
          case i = m: done
          otherwise: {
              successor(m) ≤ i;
              done
          }
        }
  }
}

-- Degree exactly d.
definition Polynomial.HasDegree (r : Ring)
        (p : Polynomial(Ring.carrier(r), Ring.zero(r))) (d : Natural) : Proposition :=
  Polynomial.DegreeLessThan(r, p, successor(d))
  ∧ ¬(Polynomial.coefficientOf(p, d) = Ring.zero(r))

-- A field has no zero divisors: x ≠ 0 and x·y = 0 force y = 0.
theorem Ring.field_no_zero_divisors (r : Ring)
        (commutativity
            : ∀ (x y : Ring.carrier(r)). (x * y) = (y * x))
        (inverseExistence
            : ∀ (x : Ring.carrier(r)). ¬(x = Ring.zero(r))
                → ∃ (inverse : Ring.carrier(r)). (x * inverse) = Ring.one(r))
        (x y : Ring.carrier(r))
        (xNonzero : ¬(x = Ring.zero(r)))
        (productZero : (x * y) = Ring.zero(r))
        : y = Ring.zero(r) := {
  choose xInverse such that (x * xInverse) = Ring.one(r) from inverseExistence(x, xNonzero);
  (xInverse * x)
            = (x * xInverse)   by commutativity(xInverse, x)
            = Ring.one(r);
  y
     = (Ring.one(r) * y)
     = ((xInverse * x) * y)
     = (xInverse * (x * y))
     = (xInverse * Ring.zero(r))
     = Ring.zero(r)
}

-- Top coefficient of a product: coefficientOf(a·b, m+n) = coeff(a,m)·coeff(b,n).
theorem Polynomial.coefficientOf_product_at_sum (r : Ring)
        (a b : Polynomial(Ring.carrier(r), Ring.zero(r))) (m n : Natural)
        (aBound : Polynomial.DegreeLessThan(r, a, successor(m)))
        (bBound : Polynomial.DegreeLessThan(r, b, successor(n)))
        : Polynomial.coefficientOf((a * b), m + n)
          = (Polynomial.coefficientOf(a, m) * Polynomial.coefficientOf(b, n)) := {
  m ≤ m + n;
  ∀ (i : Natural). ¬(i = m)
      → (Polynomial.coefficientOf(a, i) * Polynomial.coefficientOf(b, Natural.monus(m + n, i)))
          = Ring.zero(r)
      by (i : Natural) (indexNotM : ¬(i = m)) ↦ {
           i ≤ m ∨ m ≤ i;
           done by cases {
             -- i ≤ m: the b-index m+n−i ≥ n+1, so coeff(b,·) = 0.
             case i ≤ m: {
                 m ≠ i by indexNotM;
                 successor(i) ≤ m;
                 successor(n + i)
                       = n + successor(i)
                       ≤ n + m
                       = m + n;
                 successor(n) ≤ Natural.monus(m + n, i) by Natural.degree_bound_helper as degreeBound;
                 (Polynomial.coefficientOf(a, i) * Polynomial.coefficientOf(b, Natural.monus(m + n, i)))
                    = (Polynomial.coefficientOf(a, i) * Ring.zero(r))
                          by bBound(Natural.monus(m + n, i), degreeBound)
                    = Ring.zero(r)
               }
             -- m < i: coeff(a,i) = 0.
             case m ≤ i: {
                 successor(m) ≤ i as successorMLessOrEqualI;
                 (Polynomial.coefficientOf(a, i) * Polynomial.coefficientOf(b, Natural.monus(m + n, i)))
                    = (Ring.zero(r) * Polynomial.coefficientOf(b, Natural.monus(m + n, i)))
                          by aBound(i, successorMLessOrEqualI)
                    = Ring.zero(r)
               }
           }
         };
  Polynomial.coefficientOf((a * b), m + n)
     = Ring.Sum(r,
           (i : Natural) ↦
               (Polynomial.coefficientOf(a, i) * Polynomial.coefficientOf(b, Natural.monus(m + n, i))),
           m + n)
     = (Polynomial.coefficientOf(a, m) * Polynomial.coefficientOf(b, Natural.monus(m + n, m)))
           by Ring.Sum.single_point
     = (Polynomial.coefficientOf(a, m) * Polynomial.coefficientOf(b, n))
}

-- A product has degree < (m+n)+1 when the factors are bounded by m+1, n+1.
theorem Polynomial.product_DegreeLessThan (r : Ring)
        (a b : Polynomial(Ring.carrier(r), Ring.zero(r))) (m n : Natural)
        (aBound : Polynomial.DegreeLessThan(r, a, successor(m)))
        (bBound : Polynomial.DegreeLessThan(r, b, successor(n)))
        : Polynomial.DegreeLessThan(r, (a * b), successor(m + n)) :=
  (k : Natural) (successorMNLessOrEqualK : successor(m + n) ≤ k) ↦ {
    ∀ (i : Natural). i ≤ k
        → (Polynomial.coefficientOf(a, i) * Polynomial.coefficientOf(b, Natural.monus(k, i)))
            = Ring.zero(r)
        by (i : Natural) (iLessOrEqualK : i ≤ k) ↦ {
             i ≤ m ∨ successor(m) ≤ i;
             done by cases {
               case i ≤ m: {
                   n + i ≤ n + m = m + n;
                   successor(n + i) ≤ successor(m + n) ≤ k;
                   successor(n) ≤ Natural.monus(k, i) by Natural.degree_bound_helper as degreeBound;
                   (Polynomial.coefficientOf(a, i) * Polynomial.coefficientOf(b, Natural.monus(k, i)))
                      = (Polynomial.coefficientOf(a, i) * Ring.zero(r))
                            by bBound(Natural.monus(k, i), degreeBound)
                      = Ring.zero(r)
                 }
               case successor(m) ≤ i as successorMLessOrEqualI:
                   (Polynomial.coefficientOf(a, i) * Polynomial.coefficientOf(b, Natural.monus(k, i)))
                      = (Ring.zero(r) * Polynomial.coefficientOf(b, Natural.monus(k, i)))
                            by aBound(i, successorMLessOrEqualI)
                      = Ring.zero(r)
             }
           };
    Polynomial.coefficientOf((a * b), k)
       = Ring.Sum(r,
             (i : Natural) ↦
                 (Polynomial.coefficientOf(a, i) * Polynomial.coefficientOf(b, Natural.monus(k, i))),
             k)
       = Ring.zero(r)
  }

-- Degree of a product is the sum of degrees (over a field).
theorem Polynomial.HasDegree_product (r : Ring)
        (commutativity
            : ∀ (x y : Ring.carrier(r)). (x * y) = (y * x))
        (inverseExistence
            : ∀ (x : Ring.carrier(r)). ¬(x = Ring.zero(r))
                → ∃ (inverse : Ring.carrier(r)). (x * inverse) = Ring.one(r))
        (a b : Polynomial(Ring.carrier(r), Ring.zero(r))) (m n : Natural)
        (aDegree : Polynomial.HasDegree(r, a, m))
        (bDegree : Polynomial.HasDegree(r, b, n))
        : Polynomial.HasDegree(r, (a * b), m + n) := {
  let ⟨aBound, aLeadingNonzero⟩ := aDegree;
  let ⟨bBound, bLeadingNonzero⟩ := bDegree;
  Polynomial.DegreeLessThan(r, (a * b), successor(m + n)) by Polynomial.product_DegreeLessThan;
  ¬(Polynomial.coefficientOf((a * b), m + n) = Ring.zero(r))
      by (topZero : Polynomial.coefficientOf((a * b), m + n) = Ring.zero(r)) ↦ {
          -- coeff(a,m)·coeff(b,n) is the top coefficient of a·b, which is 0;
          -- a is nonzero there, so (no zero divisors) b is zero at n.
          (Polynomial.coefficientOf(a, m) * Polynomial.coefficientOf(b, n))
                = Polynomial.coefficientOf((a * b), m + n)
                = Ring.zero(r);
          Polynomial.coefficientOf(b, n) = Ring.zero(r) by Ring.field_no_zero_divisors as leadingZero;
          bLeadingNonzero(leadingZero)
      };
  done
}

-- Degree is unique.
theorem Polynomial.HasDegree_unique (r : Ring)
        (p : Polynomial(Ring.carrier(r), Ring.zero(r))) (d e : Natural)
        (dDegree : Polynomial.HasDegree(r, p, d))
        (eDegree : Polynomial.HasDegree(r, p, e))
        : d = e := {
  let ⟨dBound, dNonzero⟩ := dDegree;
  let ⟨eBound, eNonzero⟩ := eDegree;
  d ≤ e ∨ e ≤ d;
  done by cases {
    case d ≤ e: {
        suppose d ≠ e as dNotEqualsE for contradiction {
            e ≠ d by dNotEqualsE;
            successor(d) ≤ e;
            Polynomial.coefficientOf(p, e) = Ring.zero(r);
            done
        };
        done
      }
    case e ≤ d: {
        suppose d ≠ e as dNotEqualsE for contradiction {
            successor(e) ≤ d;
            Polynomial.coefficientOf(p, d) = Ring.zero(r);
            done
        };
        done
      }
  }
}

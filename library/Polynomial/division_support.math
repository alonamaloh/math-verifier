-- Polynomial/division_support.math
--
-- Arithmetic and summation lemmas needed by the polynomial division
-- algorithm (Polynomial/division.math). Two groups:
--
--   * Small Natural facts the standard library happens not to carry yet
--     (successor-≤ inversion, ¬(successor(m) ≤ m), the monus/add cancel
--     law, the ≤-successor split).
--   * `Polynomial.Sum.single_point`: a sum whose summand vanishes off a
--     single index j (with j ≤ n) collapses to its value at j. This is
--     what turns the convolution for a monomial times a polynomial into
--     a single product.

module Polynomial.division_support

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.subtraction
import Natural.arithmetic
import Natural.monus
import Natural.decide
import Algebra.ring
import Algebra.ring_bundle
import Polynomial.summation
import Polynomial.commutative

-- ----------------------------------------------------------------------
-- Small Natural facts.

-- successor(a) ≤ successor(b) implies a ≤ b. Read off the subtraction
-- witness: successor(b) = successor(a) + c = successor(a + c), peel.
theorem Natural.successor_le_successor_invert (a b : Natural)
        (lessOrEqual : successor(a) ≤ successor(b))
        : a ≤ b := {
  obtain ⟨c, equation⟩
      from Natural.subtraction_witness(successor(a), successor(b), lessOrEqual);
  claim bEquation : b = a + c
      by Natural.successor_injective(b, a + c, equation);
  rewrite(Equality.symmetry(bEquation), Natural.less_or_equal_add_right(a, c))
}

-- x ≠ successor(x + c): a number is never its own successor-plus-more.
theorem Natural.not_equal_successor_add
        : (x c : Natural) → ¬(x = successor(x + c))
  | zero, c =>
      Natural.zero_not_successor(0 + c)
  | successor(k), c =>
      function (equation : successor(k) = successor(successor(k) + c)) =>
          Natural.not_equal_successor_add(k, c,
              Natural.successor_injective(k, successor(k + c), equation))

-- ¬(successor(m) ≤ m): nothing is ≤ its own predecessor.
theorem Natural.not_successor_less_or_equal_self (m : Natural)
        (lessOrEqual : successor(m) ≤ m)
        : False := {
  obtain ⟨c, equation⟩
      from Natural.subtraction_witness(successor(m), m, lessOrEqual);
  Natural.not_equal_successor_add(m, c, equation)
}

-- j ≤ successor(m) and j ≠ successor(m) force j ≤ m.
theorem Natural.less_or_equal_successor_not_equal (j m : Natural)
        (lessOrEqual : j ≤ successor(m))
        (notEqual : ¬(j = successor(m)))
        : j ≤ m := {
  obtain ⟨c, equation⟩
      from Natural.subtraction_witness(j, successor(m), lessOrEqual);
  cases c refining equation {
    | zero =>
        absurd(notEqual(Equality.symmetry(
            calc successor(m)
               = j + 0      by equation
               = j          by Natural.add_zero(j))))
    | successor(cPredecessor) => {
        claim mEquation : m = j + cPredecessor
            by Natural.successor_injective(m, j + cPredecessor,
                   calc successor(m)
                      = j + successor(cPredecessor)   by equation
                      = successor(j + cPredecessor)   by Natural.add_successor(j, cPredecessor));
        rewrite(Equality.symmetry(mEquation),
                Natural.less_or_equal_add_right(j, cPredecessor))
      }
  }
}

-- ----------------------------------------------------------------------
-- Single-point summation.

-- A sum whose summand vanishes everywhere on 0..n is zero.
theorem Polynomial.Sum.vanishes_below (r : Ring)
        (h : Natural → Ring.carrier(r)) (n : Natural)
        (vanish : (i : Natural) → i ≤ n → h(i) = Ring.zero(r))
        : Polynomial.Sum(r, h, n) = Ring.zero(r) :=
  calc Polynomial.Sum(r, h, n)
     = Polynomial.Sum(r, function (i : Natural) => Ring.zero(r), n)
           by Polynomial.Sum.extensional_range(r, h,
                  function (i : Natural) => Ring.zero(r), n, vanish)
     = Ring.zero(r)
           by Polynomial.Sum.zero(r, n)

-- A sum whose summand vanishes off a single index j ≤ n equals h(j).
theorem Polynomial.Sum.single_point (r : Ring)
        (h : Natural → Ring.carrier(r)) (j : Natural) (n : Natural)
        : j ≤ n
          → ((i : Natural) → ¬(i = j) → h(i) = Ring.zero(r))
          → Polynomial.Sum(r, h, n) = h(j) :=
  by_induction on n with IH {
    case zero:
      function (jLessOrEqualZero : j ≤ 0)
               (vanish : (i : Natural) → ¬(i = j) → h(i) = Ring.zero(r)) => {
        claim jEqualsZero : j = 0
            by Natural.less_or_equal_zero_implies_equals_zero(j, jLessOrEqualZero);
        congruenceOf(h, Equality.symmetry(jEqualsZero))
      }
    case successor(m):
      function (jLessOrEqualSuccessor : j ≤ successor(m))
               (vanish : (i : Natural) → ¬(i = j) → h(i) = Ring.zero(r)) =>
          decide j = successor(m) {
            | yes jEqualsSuccessor => {
                claim sumBelow : Polynomial.Sum(r, h, m) = Ring.zero(r)
                    by Polynomial.Sum.vanishes_below(r, h, m,
                           function (i : Natural) (iLessOrEqualM : i ≤ m) =>
                               vanish(i, function (iEqualsJ : i = j) =>
                                   Natural.not_successor_less_or_equal_self(m,
                                       rewrite(Equality.transitivity(iEqualsJ, jEqualsSuccessor),
                                               iLessOrEqualM))));
                calc Polynomial.Sum(r, h, successor(m))
                   = Ring.add(r, Polynomial.Sum(r, h, m), h(successor(m)))
                         by reflexivity(Ring.carrier(r),
                                Ring.add(r, Polynomial.Sum(r, h, m), h(successor(m))))
                   = Ring.add(r, Ring.zero(r), h(successor(m)))
                         by sumBelow
                   = h(successor(m))
                         by Ring.zero_add(r, h(successor(m)))
                   = h(j)
                         by congruenceOf(h, Equality.symmetry(jEqualsSuccessor))
              }
            | no jNotEqualsSuccessor => {
                claim jLessOrEqualM : j ≤ m
                    by Natural.less_or_equal_successor_not_equal(j, m,
                           jLessOrEqualSuccessor, jNotEqualsSuccessor);
                claim successorVanishes : h(successor(m)) = Ring.zero(r)
                    by vanish(successor(m),
                           function (successorEqualsJ : successor(m) = j) =>
                               jNotEqualsSuccessor(Equality.symmetry(successorEqualsJ)));
                calc Polynomial.Sum(r, h, successor(m))
                   = Ring.add(r, Polynomial.Sum(r, h, m), h(successor(m)))
                         by reflexivity(Ring.carrier(r),
                                Ring.add(r, Polynomial.Sum(r, h, m), h(successor(m))))
                   = Ring.add(r, h(j), h(successor(m)))
                         by IH(jLessOrEqualM, vanish)
                   = Ring.add(r, h(j), Ring.zero(r))
                         by successorVanishes
                   = h(j)
                         by Ring.add_zero(r, h(j))
              }
          }
  }

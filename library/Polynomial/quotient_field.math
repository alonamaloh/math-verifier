-- Polynomial/quotient_field.math
--
-- F[x]/(f) is a field when f is irreducible and F is a field. This is
-- RingModulo(Polynomial.commutative_ring(F), f); the two facts beyond a
-- commutative ring are 0 ≠ 1 (else f | 1, making f a unit) and
-- invertibility of every nonzero class (Bézout: f ∤ g gives a·f + b·g =
-- 1, so the class of b inverts the class of g). It mirrors
-- IntegerMod/field.math with Bézout-for-polynomials in place of
-- Bézout-for-integers.
--
-- The quotient is indexed by the bundled commutative ring
-- `Polynomial.commutative_ring(r, commutativity)`; commutativity is
-- carried by that bundle, so `RingModulo.multiply` (and `*`) recover it
-- from the operand type rather than taking it as an argument. The base-
-- ring-level facts (`Ring.CongruentModulo`, `RingModulo.equivalence`,
-- `Ring.divides`, `Ring.carrier`) remain stated over the plain ring
-- `Polynomial.ring(r)` = `CommutativeRing.ring(...)`.

module Polynomial.quotient_field

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.ring_divisibility
import Algebra.ring_difference
import Algebra.field
import Polynomial.basics
import Polynomial.addition
import Polynomial.negation
import Polynomial.additive_group
import Polynomial.multiplication
import Polynomial.multiply_laws
import Polynomial.commutative
import Polynomial.instances
import Polynomial.bezout
import Polynomial.irreducible
import RingModulo.basics
import RingModulo.operations
import RingModulo.ring
import RingModulo.instances

-- F[x] as a bundled commutative ring — the base of the quotient.
definition Polynomial.commutative_ring (r : Ring)
        (commutativity
            : (x y : Ring.carrier(r)) → (x * y) = (y * x))
        : CommutativeRing :=
  CommutativeRing.make(Polynomial.ring(r),
      Polynomial.multiply_commutative(r, commutativity))

-- From f | (g·h − 1), the class of h inverts the class of g.
theorem Polynomial.quotient_inverse_from_witness (r : Ring)
        (commutativity
            : ∀ (x y : Ring.carrier(r)). (x * y) = (y * x))
        (f g h : Polynomial(Ring.carrier(r), Ring.zero(r)))
        (witnessDivides
            : Ring.divides(Polynomial.ring(r), f,
                  ((g * h) + (- Polynomial.one(r)))))
        : RingModulo.multiply(
              RingModulo.make(Polynomial.commutative_ring(r, commutativity), f, g),
              RingModulo.make(Polynomial.commutative_ring(r, commutativity), f, h))
          = RingModulo.one(Polynomial.commutative_ring(r, commutativity), f) :=
  Quotient.sound(
      Ring.carrier(Polynomial.ring(r)), Ring.CongruentModulo(Polynomial.ring(r), f),
      (g * h), Polynomial.one(r), witnessDivides)

-- Equal classes are congruent representatives.
theorem Polynomial.quotient_congruent_of_make_equal (r : Ring)
        (commutativity
            : ∀ (x y : Ring.carrier(r)). (x * y) = (y * x))
        (f g h : Polynomial(Ring.carrier(r), Ring.zero(r)))
        (makeEquality
            : RingModulo.make(Polynomial.commutative_ring(r, commutativity), f, g)
              = RingModulo.make(Polynomial.commutative_ring(r, commutativity), f, h))
        : Ring.CongruentModulo(Polynomial.ring(r), f, g, h) :=
  Quotient.exact(
      Ring.carrier(Polynomial.ring(r)), Ring.CongruentModulo(Polynomial.ring(r), f),
      RingModulo.equivalence(Polynomial.ring(r), f), g, h, makeEquality)

-- 0 ≠ 1 in F[x]/(f): otherwise f | 1, making f a unit.
theorem Polynomial.quotient_zero_not_one (r : Ring)
        (commutativity
            : ∀ (x y : Ring.carrier(r)). (x * y) = (y * x))
        (f : Polynomial(Ring.carrier(r), Ring.zero(r)))
        (fIrreducible : Polynomial.IsIrreducible(r, f))
        : ¬(RingModulo.zero(Polynomial.commutative_ring(r, commutativity), f)
            = RingModulo.one(Polynomial.commutative_ring(r, commutativity), f)) :=
  (zeroEqualsOne
              : RingModulo.zero(Polynomial.commutative_ring(r, commutativity), f)
                = RingModulo.one(Polynomial.commutative_ring(r, commutativity), f)) ↦ {
    let ⟨fNotUnit, _⟩ := fIrreducible;
    -- [1] = [0] (symmetric), so f | (1 − 0) = 1, i.e. f is a unit.
    claim congruentOneZero
        : Ring.divides(Polynomial.ring(r), f,
              (Polynomial.one(r) + (- Polynomial.zero(r))))
        by Polynomial.quotient_congruent_of_make_equal(r, commutativity, f,
               Polynomial.one(r), Polynomial.zero(r), Equality.symmetry(zeroEqualsOne));
    -- congruentOneZero : f | (one + (−zero)); simplify the difference to one.
    calc (Polynomial.one(r) + (- Polynomial.zero(r)))
              = (Polynomial.one(r) + Polynomial.zero(r))
              = Polynomial.one(r) as differenceIsOne;
    fNotUnit(rewrite(differenceIsOne, congruentOneZero))
  }

-- Invertibility at a representative: a nonzero class [g] has an inverse.
theorem Polynomial.quotient_invertible_at_representative (r : Ring)
        (commutativity
            : ∀ (x y : Ring.carrier(r)). (x * y) = (y * x))
        (inverseExistence
            : ∀ (x : Ring.carrier(r)). ¬(x = Ring.zero(r))
                → ∃ (inverse : Ring.carrier(r)). (x * inverse) = Ring.one(r))
        (f : Polynomial(Ring.carrier(r), Ring.zero(r)))
        (fIrreducible : Polynomial.IsIrreducible(r, f))
        (g : Polynomial(Ring.carrier(r), Ring.zero(r)))
        (notZero
            : ¬(RingModulo.make(Polynomial.commutative_ring(r, commutativity), f, g)
                = RingModulo.zero(Polynomial.commutative_ring(r, commutativity), f)))
        : ∃ (y : RingModulo(Polynomial.commutative_ring(r, commutativity), f)).
            RingModulo.multiply(
                RingModulo.make(Polynomial.commutative_ring(r, commutativity), f, g), y)
            = RingModulo.one(Polynomial.commutative_ring(r, commutativity), f) := {
        -- A nonzero class means f ∤ g.
        claim notDivides : ¬(Ring.divides(Polynomial.ring(r), f, g))
            by (fDividesG : Ring.divides(Polynomial.ring(r), f, g)) ↦
                 notZero(
                     Quotient.sound(
                         Ring.carrier(Polynomial.ring(r)),
                         Ring.CongruentModulo(Polynomial.ring(r), f),
                         g, Polynomial.zero(r),
                         rewrite(Equality.symmetry(
                                     calc (g + (- Polynomial.zero(r)))
                                        = (g + Polynomial.zero(r))
                                        = g),
                                 fDividesG)));
        obtain ⟨coefficientF, coefficientG, bezoutEquation⟩
            from Polynomial.bezout_one_of_irreducible(r, commutativity, inverseExistence,
                     f, fIrreducible, g, notDivides);
        -- bezoutEquation : coefficientF·f + coefficientG·g = 1.
        -- The class of coefficientG inverts the class of g: f | (g·coefficientG − 1).
        ⟨RingModulo.make(Polynomial.commutative_ring(r, commutativity), f, coefficientG),
         Polynomial.quotient_inverse_from_witness(r, commutativity, f, g, coefficientG,
             ⟨(- coefficientF),
              calc ((g * coefficientG) + (- Polynomial.one(r)))
                 = ((coefficientG * g) + (- Polynomial.one(r)))
                 = ((coefficientG * g) + (- ((coefficientF * f) + (coefficientG * g))))
                 = ((coefficientG * g) + ((- (coefficientF * f)) + (- (coefficientG * g))))
                       by Ring.negate_add_distribute(Polynomial.ring(r),
                              (coefficientF * f),
                              (coefficientG * g))
                 = ((- (coefficientF * f)) + ((coefficientG * g) + (- (coefficientG * g))))
                 = ((- (coefficientF * f)) + Polynomial.zero(r))
                 = (- (coefficientF * f))
                 = ((- coefficientF) * f)
                 = (f * (- coefficientF))⟩)⟩
}

-- Every nonzero class is invertible: induct to a representative.
theorem Polynomial.quotient_nonzero_invertible (r : Ring)
        (commutativity
            : ∀ (x y : Ring.carrier(r)). (x * y) = (y * x))
        (inverseExistence
            : ∀ (x : Ring.carrier(r)). ¬(x = Ring.zero(r))
                → ∃ (inverse : Ring.carrier(r)). (x * inverse) = Ring.one(r))
        (f : Polynomial(Ring.carrier(r), Ring.zero(r)))
        (fIrreducible : Polynomial.IsIrreducible(r, f))
        (x : RingModulo(Polynomial.commutative_ring(r, commutativity), f))
        : ¬(x = RingModulo.zero(Polynomial.commutative_ring(r, commutativity), f))
          → ∃ (y : RingModulo(Polynomial.commutative_ring(r, commutativity), f)).
              RingModulo.multiply(x, y)
              = RingModulo.one(Polynomial.commutative_ring(r, commutativity), f) :=
  cases x { | g =>
      (notZero
           : ¬(RingModulo.make(Polynomial.commutative_ring(r, commutativity), f, g)
               = RingModulo.zero(Polynomial.commutative_ring(r, commutativity), f))) ↦
          Polynomial.quotient_invertible_at_representative(r, commutativity,
              inverseExistence, f, fIrreducible, g, notZero) }

-- F[x]/(f) is a field.
theorem Polynomial.quotient_is_field (r : Ring)
        (commutativity
            : ∀ (x y : Ring.carrier(r)). (x * y) = (y * x))
        (inverseExistence
            : ∀ (x : Ring.carrier(r)). ¬(x = Ring.zero(r))
                → ∃ (inverse : Ring.carrier(r)). (x * inverse) = Ring.one(r))
        (f : Polynomial(Ring.carrier(r), Ring.zero(r)))
        (fIrreducible : Polynomial.IsIrreducible(r, f))
        : IsField(
              RingModulo(Polynomial.commutative_ring(r, commutativity), f),
              RingModulo.add,
              RingModulo.zero(Polynomial.commutative_ring(r, commutativity), f),
              RingModulo.negate,
              RingModulo.multiply,
              RingModulo.one(Polynomial.commutative_ring(r, commutativity), f)) :=
  ⟨RingModulo.is_commutative_ring(Polynomial.commutative_ring(r, commutativity), f),
   Polynomial.quotient_zero_not_one(r, commutativity, f, fIrreducible),
   Polynomial.quotient_nonzero_invertible(r, commutativity, inverseExistence, f, fIrreducible)⟩

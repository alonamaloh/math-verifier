-- Polynomial/basics.math
--
-- Polynomials over an arbitrary type R with a distinguished zero,
-- represented as finite coefficient lists (low degree first) modulo
-- "agrees as a coefficient function". A raw list
-- `cons(a0, cons(a1, … nil))` stands for a0 + a1·x + …; two lists are
-- identified exactly when they have the same coefficient at every
-- index (reading past the end as the zero coefficient), so trailing
-- zeros are quotiented away — `[a0]` and `[a0, 0]` are the same
-- polynomial. This makes `Polynomial(R, zero)` a genuine quotient type
-- on which equality is the kernel's `=`, the same pattern used for
-- ℤ / ℚ / ℝ / IntegerMod.
--
-- Only R's zero is needed to form the type and its equivalence; the
-- ring operations (add, multiply, …) enter later, where the
-- polynomial arithmetic is defined.

module Polynomial.basics

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.one_plus_induction

-- Finite coefficient list, low degree first.
inductive Polynomial.Coefficients (R : Type(0)) : Type(0) where
  | Polynomial.Coefficients.nil  : Polynomial.Coefficients(R)
  | Polynomial.Coefficients.cons
      : R → Polynomial.Coefficients(R) → Polynomial.Coefficients(R)

-- The head coefficient (zero past the end of the list) and the tail.
definition Polynomial.Coefficients.head (R : Type(0)) (zeroCoefficient : R)
        : Polynomial.Coefficients(R) → R
  | Polynomial.Coefficients.nil        => zeroCoefficient
  | Polynomial.Coefficients.cons(c, _) => c

definition Polynomial.Coefficients.tail (R : Type(0))
        : Polynomial.Coefficients(R) → Polynomial.Coefficients(R)
  | Polynomial.Coefficients.nil           => Polynomial.Coefficients.nil(R)
  | Polynomial.Coefficients.cons(_, rest) => rest

-- The coefficient at a given index, reading past the end of the list as
-- the zero coefficient. Recurses on the INDEX: entry 0 is the head, and
-- entry 1 + p of a list is entry p of its tail. Because the index drives
-- the recursion, `nth(cons(c, rest), 0)` reduces to `c` (head of a cons)
-- definitionally — the reduction low-degree coefficient proofs rely on.
definition Polynomial.nthFromIndex (R : Type(0)) (zeroCoefficient : R)
        : ℕ → Polynomial.Coefficients(R) → R
  | 0,     coeffs => Polynomial.Coefficients.head(R, zeroCoefficient, coeffs)
  | 1 + p, coeffs =>
      Polynomial.nthFromIndex(R, zeroCoefficient, p, Polynomial.Coefficients.tail(R, coeffs))

definition Polynomial.nth (R : Type(0)) (zeroCoefficient : R)
        (coeffs : Polynomial.Coefficients(R)) (index : ℕ) : R :=
  Polynomial.nthFromIndex(R, zeroCoefficient, index, coeffs)

-- Past the end: every entry of the empty list is the zero coefficient.
-- (Recursing on the index, the tail of nil stays nil at each step.)
theorem Polynomial.nth_nil (R : Type(0)) (zeroCoefficient : R) (index : ℕ)
        : Polynomial.nth(R, zeroCoefficient, Polynomial.Coefficients.nil(R), index)
            = zeroCoefficient :=
  by induction on index with IH {
    case base: done
    case step(p):
        Polynomial.nth(R, zeroCoefficient, Polynomial.Coefficients.nil(R), 1 + p)
           = Polynomial.nth(R, zeroCoefficient, Polynomial.Coefficients.nil(R), p)
           = zeroCoefficient by IH
  }

-- Reading the head: the 0-th entry of cons(c, rest) is c.
theorem Polynomial.nth_cons_zero (R : Type(0)) (zeroCoefficient : R)
        (c : R) (rest : Polynomial.Coefficients(R))
        : Polynomial.nth(R, zeroCoefficient, Polynomial.Coefficients.cons(R, c, rest), 0) = c :=
  done

-- The (1 + j)-th entry of any list is the j-th entry of its tail
-- (`Natural.add` is opaque, so `1 + j` is not definitionally the
-- constructor; bridge via `one_add`).
theorem Polynomial.nth_one_plus (R : Type(0)) (zeroCoefficient : R)
        (coeffs : Polynomial.Coefficients(R)) (j : ℕ)
        : Polynomial.nth(R, zeroCoefficient, coeffs, 1 + j)
          = Polynomial.nth(R, zeroCoefficient, Polynomial.Coefficients.tail(R, coeffs), j) :=
  done

-- Reading past the head: the (1 + j)-th entry of cons(c, rest) is the
-- j-th entry of rest — the tail of a cons.
theorem Polynomial.nth_cons_one_plus (R : Type(0)) (zeroCoefficient : R)
        (c : R) (rest : Polynomial.Coefficients(R)) (j : ℕ)
        : Polynomial.nth(R, zeroCoefficient, Polynomial.Coefficients.cons(R, c, rest), 1 + j)
          = Polynomial.nth(R, zeroCoefficient, rest, j) :=
  Polynomial.nth(R, zeroCoefficient, Polynomial.Coefficients.cons(R, c, rest), 1 + j)
     = Polynomial.nth(R, zeroCoefficient, Polynomial.Coefficients.tail(R, Polynomial.Coefficients.cons(R, c, rest)), j)
     = Polynomial.nth(R, zeroCoefficient, rest, j)

-- Two coefficient lists represent the same polynomial when they agree
-- at every index (trailing zeros become invisible).
definition Polynomial.ExtensionallyEqual (R : Type(0)) (zeroCoefficient : R)
        (p q : Polynomial.Coefficients(R)) : Proposition :=
  (index : ℕ) →
      Polynomial.nth(R, zeroCoefficient, p, index)
      = Polynomial.nth(R, zeroCoefficient, q, index)

-- The relation is an equivalence: each property is pointwise in the
-- index, inherited from equality on R.
theorem Polynomial.ExtensionallyEqual.reflexive (R : Type(0))
        (zeroCoefficient : R) (p : Polynomial.Coefficients(R))
        : Polynomial.ExtensionallyEqual(R, zeroCoefficient, p, p) :=
  (index : ℕ) ↦
      reflexivity(R, Polynomial.nth(R, zeroCoefficient, p, index))

theorem Polynomial.ExtensionallyEqual.symmetric (R : Type(0))
        (zeroCoefficient : R) (p q : Polynomial.Coefficients(R))
        (extensionallyEqual
            : Polynomial.ExtensionallyEqual(R, zeroCoefficient, p, q))
        : Polynomial.ExtensionallyEqual(R, zeroCoefficient, q, p) :=
  (index : ℕ) ↦
      Equality.symmetry(?, ?, extensionallyEqual(index))

theorem Polynomial.ExtensionallyEqual.transitive (R : Type(0))
        (zeroCoefficient : R) (p q r : Polynomial.Coefficients(R))
        (firstEqual
            : Polynomial.ExtensionallyEqual(R, zeroCoefficient, p, q))
        (secondEqual
            : Polynomial.ExtensionallyEqual(R, zeroCoefficient, q, r))
        : Polynomial.ExtensionallyEqual(R, zeroCoefficient, p, r) :=
  (index : ℕ) ↦
      Equality.transitivity(?, ?, ?, firstEqual(index), secondEqual(index))

-- Polynomials over R: coefficient lists modulo the equivalence.
definition Polynomial (R : Type(0)) (zeroCoefficient : R) : Type(0) :=
  Quotient(Polynomial.Coefficients(R),
           Polynomial.ExtensionallyEqual(R, zeroCoefficient))

-- The class of a coefficient list.
definition Polynomial.make (R : Type(0)) (zeroCoefficient : R)
        (coefficients : Polynomial.Coefficients(R))
        : Polynomial(R, zeroCoefficient) :=
  Quotient.class_of(coefficients)

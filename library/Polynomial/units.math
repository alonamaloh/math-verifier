-- Polynomial/units.math
--
-- Units of a polynomial ring over a field: the degree-0 (nonzero
-- constant) polynomials. The key lemma `degree_zero_is_unit` is what
-- lets an irreducibility proof conclude "a degree-0 factor is a unit".

module Polynomial.units

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.monus
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Algebra.ring_divisibility
import Polynomial.basics
import Polynomial.addition
import Polynomial.multiplication
import Polynomial.multiply_laws
import Polynomial.instances
import Polynomial.degree
import Polynomial.multiply_coefficient
import Polynomial.monomial
import Polynomial.division
import Polynomial.degree_function
import Polynomial.bezout
import Polynomial.irreducible
import Polynomial.degree_product

-- Product of constant polynomials: monomial(a,0)·monomial(b,0) = monomial(a·b,0).
theorem Polynomial.monomial_zero_multiply (r : Ring) (a b : Ring.carrier(r))
        : Polynomial.multiply(r, Polynomial.monomial(r, a, 0),
              Polynomial.monomial(r, b, 0))
          = Polynomial.monomial(r, Ring.multiply(r, a, b), 0) :=
  Polynomial.equal_of_coefficientOf_equal(r,
      Polynomial.multiply(r, Polynomial.monomial(r, a, 0), Polynomial.monomial(r, b, 0)),
      Polynomial.monomial(r, Ring.multiply(r, a, b), 0),
      function (i : Natural) =>
        decide i = 0 {
          | yes indexZero =>
              calc Polynomial.coefficientOf(r,
                       Polynomial.multiply(r, Polynomial.monomial(r, a, 0),
                           Polynomial.monomial(r, b, 0)), i)
                 = Polynomial.coefficientOf(r,
                       Polynomial.multiply(r, Polynomial.monomial(r, a, 0),
                           Polynomial.monomial(r, b, 0)), 0)
                       by congruenceOf(
                              function (t : Natural) =>
                                  Polynomial.coefficientOf(r,
                                      Polynomial.multiply(r, Polynomial.monomial(r, a, 0),
                                          Polynomial.monomial(r, b, 0)), t),
                              indexZero)
                 = Ring.multiply(r, a,
                       Polynomial.coefficientOf(r, Polynomial.monomial(r, b, 0),
                           Natural.monus(0, 0)))
                       by Polynomial.coefficientOf_monomial_multiply(r, a,
                              Polynomial.monomial(r, b, 0), 0, 0, Natural.zero_least(0))
                 = Ring.multiply(r, a,
                       Polynomial.coefficientOf(r, Polynomial.monomial(r, b, 0), 0))
                       by congruenceOf(
                              function (t : Natural) =>
                                  Ring.multiply(r, a,
                                      Polynomial.coefficientOf(r, Polynomial.monomial(r, b, 0), t)),
                              Natural.monus_zero(0))
                 = Ring.multiply(r, a, b)
                       by Polynomial.coefficientOf_monomial_at(r, b, 0)
                 = Polynomial.coefficientOf(r,
                       Polynomial.monomial(r, Ring.multiply(r, a, b), 0), 0)
                       by Equality.symmetry(
                              Polynomial.coefficientOf_monomial_at(r, Ring.multiply(r, a, b), 0))
                 = Polynomial.coefficientOf(r,
                       Polynomial.monomial(r, Ring.multiply(r, a, b), 0), i)
                       by congruenceOf(
                              function (t : Natural) =>
                                  Polynomial.coefficientOf(r,
                                      Polynomial.monomial(r, Ring.multiply(r, a, b), 0), t),
                              Equality.symmetry(indexZero))
          | no indexNotZero =>
              calc Polynomial.coefficientOf(r,
                       Polynomial.multiply(r, Polynomial.monomial(r, a, 0),
                           Polynomial.monomial(r, b, 0)), i)
                 = Ring.multiply(r, a,
                       Polynomial.coefficientOf(r, Polynomial.monomial(r, b, 0),
                           Natural.monus(i, 0)))
                       by Polynomial.coefficientOf_monomial_multiply(r, a,
                              Polynomial.monomial(r, b, 0), 0, i, Natural.zero_least(i))
                 = Ring.multiply(r, a,
                       Polynomial.coefficientOf(r, Polynomial.monomial(r, b, 0), i))
                       by congruenceOf(
                              function (t : Natural) =>
                                  Ring.multiply(r, a,
                                      Polynomial.coefficientOf(r, Polynomial.monomial(r, b, 0), t)),
                              Natural.monus_zero(i))
                 = Ring.multiply(r, a, Ring.zero(r))
                       by Polynomial.coefficientOf_monomial_off(r, b, 0, i, indexNotZero)
                 = Ring.zero(r)
                       by Ring.multiply_zero_right(r, a)
                 = Polynomial.coefficientOf(r,
                       Polynomial.monomial(r, Ring.multiply(r, a, b), 0), i)
                       by Equality.symmetry(
                              Polynomial.coefficientOf_monomial_off(r,
                                  Ring.multiply(r, a, b), 0, i, indexNotZero))
        })

-- A degree-0 polynomial (nonzero constant) over a field is a unit.
theorem Polynomial.degree_zero_is_unit (r : Ring)
        (inverseExistence
            : (x : Ring.carrier(r)) → ¬(x = Ring.zero(r))
                → ∃ (inverse : Ring.carrier(r)). Ring.multiply(r, x, inverse) = Ring.one(r))
        (p : Polynomial(Ring.carrier(r), Ring.zero(r)))
        (pDegree : Polynomial.HasDegree(r, p, 0))
        : Polynomial.IsUnit(r, p) := {
  let ⟨pBound, pNonzero⟩ := pDegree;
  obtain ⟨inverse, inverseEquation⟩
      from inverseExistence(Polynomial.coefficientOf(r, p, 0), pNonzero);
  claim pIsConstant
      : p = Polynomial.monomial(r, Polynomial.coefficientOf(r, p, 0), 0)
      by Polynomial.equal_of_coefficientOf_equal(r, p,
             Polynomial.monomial(r, Polynomial.coefficientOf(r, p, 0), 0),
             function (i : Natural) =>
               decide i = 0 {
                 | yes indexZero =>
                     calc Polynomial.coefficientOf(r, p, i)
                        = Polynomial.coefficientOf(r, p, 0)
                              by congruenceOf(
                                     function (t : Natural) =>
                                         Polynomial.coefficientOf(r, p, t),
                                     indexZero)
                        = Polynomial.coefficientOf(r,
                              Polynomial.monomial(r, Polynomial.coefficientOf(r, p, 0), 0), 0)
                              by Equality.symmetry(
                                     Polynomial.coefficientOf_monomial_at(r,
                                         Polynomial.coefficientOf(r, p, 0), 0))
                        = Polynomial.coefficientOf(r,
                              Polynomial.monomial(r, Polynomial.coefficientOf(r, p, 0), 0), i)
                              by congruenceOf(
                                     function (t : Natural) =>
                                         Polynomial.coefficientOf(r,
                                             Polynomial.monomial(r,
                                                 Polynomial.coefficientOf(r, p, 0), 0), t),
                                     Equality.symmetry(indexZero))
                 | no indexNotZero =>
                     calc Polynomial.coefficientOf(r, p, i)
                        = Ring.zero(r)
                              by pBound(i,
                                     Natural.less_or_equal_not_equal_successor(0, i,
                                         Natural.zero_least(i), indexNotZero))
                        = Polynomial.coefficientOf(r,
                              Polynomial.monomial(r, Polynomial.coefficientOf(r, p, 0), 0), i)
                              by Equality.symmetry(
                                     Polynomial.coefficientOf_monomial_off(r,
                                         Polynomial.coefficientOf(r, p, 0), 0, i, indexNotZero))
               });
  ⟨Polynomial.monomial(r, inverse, 0),
   calc Polynomial.one(r)
      = Polynomial.monomial(r, Ring.one(r), 0)
            by reflexivity(Polynomial(Ring.carrier(r), Ring.zero(r)),
                   Polynomial.monomial(r, Ring.one(r), 0))
      = Polynomial.monomial(r,
            Ring.multiply(r, Polynomial.coefficientOf(r, p, 0), inverse), 0)
            by congruenceOf(
                   function (t : Ring.carrier(r)) => Polynomial.monomial(r, t, 0),
                   Equality.symmetry(inverseEquation))
      = Polynomial.multiply(r,
            Polynomial.monomial(r, Polynomial.coefficientOf(r, p, 0), 0),
            Polynomial.monomial(r, inverse, 0))
            by Equality.symmetry(
                   Polynomial.monomial_zero_multiply(r,
                       Polynomial.coefficientOf(r, p, 0), inverse))
      = Polynomial.multiply(r, p, Polynomial.monomial(r, inverse, 0))
            by congruenceOf(
                   function (t : Polynomial(Ring.carrier(r), Ring.zero(r))) =>
                       Polynomial.multiply(r, t, Polynomial.monomial(r, inverse, 0)),
                   Equality.symmetry(pIsConstant))⟩
}

-- Polynomial/units.math
--
-- Units of a polynomial ring over a field: the degree-0 (nonzero
-- constant) polynomials. The key lemma `degree_zero_is_unit` is what
-- lets an irreducibility proof conclude "a degree-0 factor is a unit".

module Polynomial.units

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.monus
import Natural.add_order
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Algebra.ring_divisibility
import Polynomial.basics
import Polynomial.addition
import Polynomial.multiplication
import Polynomial.multiply_laws
import Polynomial.instances
import Polynomial.degree
import Polynomial.multiply_coefficient
import Polynomial.monomial
import Polynomial.division
import Polynomial.degree_function
import Polynomial.bezout
import Polynomial.irreducible
import Polynomial.degree_product

-- Product of constant polynomials: monomial(a,0)·monomial(b,0) = monomial(a·b,0).
theorem Polynomial.monomial_zero_multiply (r : Ring) (a b : Ring.carrier(r))
        : (Polynomial.monomial(r, a, 0) * Polynomial.monomial(r, b, 0))
          = Polynomial.monomial(r, (a * b), 0) := {
  claim factorThrough
      : ∀ (k : Natural).
          (a * Polynomial.coefficientOf(r, Polynomial.monomial(r, b, 0), k))
          = Polynomial.coefficientOf(r, Polynomial.monomial(r, (a * b), 0), k)
      by (k : Natural) ↦ cases k {
        | zero =>
            calc (a * Polynomial.coefficientOf(r, Polynomial.monomial(r, b, 0), 0))
               = (a * b)
                     by Polynomial.coefficientOf_monomial_at(r, b, 0)
               = Polynomial.coefficientOf(r, Polynomial.monomial(r, (a * b), 0), 0)
                     by Polynomial.coefficientOf_monomial_at(r, (a * b), 0)
        | successor(m) => {
            claim successor(m) ≠ 0 by Natural.successor_not_zero;
            calc (a * Polynomial.coefficientOf(r, Polynomial.monomial(r, b, 0), successor(m)))
               = (a * Ring.zero(r))
                     by Polynomial.coefficientOf_monomial_off(r, b, 0, successor(m), (successor(m) ≠ 0))
               = Ring.zero(r)
                     by Ring.multiply_zero_right(r, a)
               = Polynomial.coefficientOf(r, Polynomial.monomial(r, (a * b), 0), successor(m))
                     by Polynomial.coefficientOf_monomial_off(r, (a * b), 0, successor(m), (successor(m) ≠ 0))
          }
      };
  Polynomial.equal_of_coefficientOf_equal(r,
      (Polynomial.monomial(r, a, 0) * Polynomial.monomial(r, b, 0)),
      Polynomial.monomial(r, (a * b), 0),
      (k : Natural) ↦
          calc Polynomial.coefficientOf(r,
                   (Polynomial.monomial(r, a, 0) * Polynomial.monomial(r, b, 0)), k)
             = (a * Polynomial.coefficientOf(r, Polynomial.monomial(r, b, 0), Natural.monus(k, 0)))
                   by Polynomial.coefficientOf_monomial_multiply(r, a,
                          Polynomial.monomial(r, b, 0), 0, k, (0 ≤ k))
             = (a * Polynomial.coefficientOf(r, Polynomial.monomial(r, b, 0), k))
                   by Natural.monus_zero(k)
             = Polynomial.coefficientOf(r, Polynomial.monomial(r, (a * b), 0), k)
                   by factorThrough(k))
}

-- A degree-0 polynomial (nonzero constant) over a field is a unit.
theorem Polynomial.degree_zero_is_unit (r : Ring)
        (inverseExistence
            : ∀ (x : Ring.carrier(r)). ¬(x = Ring.zero(r))
                → ∃ (inverse : Ring.carrier(r)). (x * inverse) = Ring.one(r))
        (p : Polynomial(Ring.carrier(r), Ring.zero(r)))
        (pDegree : Polynomial.HasDegree(r, p, 0))
        : Polynomial.IsUnit(r, p) := {
  let ⟨pBound, pNonzero⟩ := pDegree;
  obtain ⟨inverse, inverseEquation⟩
      from inverseExistence(Polynomial.coefficientOf(r, p, 0), pNonzero);
  claim p = Polynomial.monomial(r, Polynomial.coefficientOf(r, p, 0), 0)
      by Polynomial.equal_of_coefficientOf_equal(r, p,
             Polynomial.monomial(r, Polynomial.coefficientOf(r, p, 0), 0),
             (k : Natural) ↦ cases k {
               | zero =>
                   calc Polynomial.coefficientOf(r, p, 0)
                      = Polynomial.coefficientOf(r,
                            Polynomial.monomial(r, Polynomial.coefficientOf(r, p, 0), 0), 0)
                            by Polynomial.coefficientOf_monomial_at(r,
                                   Polynomial.coefficientOf(r, p, 0), 0)
               | successor(m) => {
                   claim successor(0) ≤ successor(m);
                   claim successor(m) ≠ 0 by Natural.successor_not_zero;
                   calc Polynomial.coefficientOf(r, p, successor(m))
                      = Ring.zero(r)
                            by pBound(successor(m), (successor(0) ≤ successor(m)))
                      = Polynomial.coefficientOf(r,
                            Polynomial.monomial(r, Polynomial.coefficientOf(r, p, 0), 0),
                            successor(m))
                            by Polynomial.coefficientOf_monomial_off(r,
                                   Polynomial.coefficientOf(r, p, 0), 0, successor(m),
                                   (successor(m) ≠ 0))
                 }
             });
  ⟨Polynomial.monomial(r, inverse, 0),
   calc Polynomial.one(r)
      = Polynomial.monomial(r, Ring.one(r), 0)
      = Polynomial.monomial(r,
            (Polynomial.coefficientOf(r, p, 0) * inverse), 0)
      = (Polynomial.monomial(r, Polynomial.coefficientOf(r, p, 0), 0) * Polynomial.monomial(r, inverse, 0))
      = (p * Polynomial.monomial(r, inverse, 0))⟩
}

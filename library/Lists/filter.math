-- Lists/filter.math
--
-- `List.filter(P, l)`: the sublist of elements satisfying `P`. The
-- decision is classical (`Logic.classical_decidable`), so `P` can be any
-- proposition; the price is that `filter` does not compute on concrete
-- lists — all reasoning goes through the characterizing equations below
-- (`List.filter_prepend_positive`/`_negative`) plus the four
-- characterising lemmas (membership in both directions, and
-- distinctness).
--
-- Each proof case-splits on the head's decision with
-- `claim by cases { case P(head): … otherwise: … }`, rewriting the
-- goal's `filter(P, prepend(head, tail))` — on both sides of an
-- implication — through the characterizing equation to the kept
-- (`prepend(head, …)`) or dropped (tail-only) form; recursion on `tail`
-- is written as an ordinary self-call inside the arms.

module Lists.filter

import axioms
import Logic.basics
import Natural.classical_decidable
import Equality.basics
import Lists.list
import Lists.map
import Lists.append
import Lists.distinct

definition List.filter {A : Type(0)} (P : A → Proposition) : List(A) → List(A)
  | List.empty => List.empty(A)
  | List.prepend(head, tail) =>
      if P(head) then List.prepend(A, head, List.filter(P, tail)) else List.filter(P, tail)

-- The characterizing equations: filtering a prepend either keeps the
-- head (when P holds) or drops it (when P fails). They are instances of
-- the generic conditional equations (Logic.if_positive / if_negative);
-- every consumer below reasons propositionally through them, never
-- re-deciding P(head).
theorem List.filter_prepend_positive (A : Type(0)) (P : A → Proposition) (head : A) (tail : List(A)) (holds : P(head))
        : List.filter(P, List.prepend(A, head, tail)) = List.prepend(A, head, List.filter(P, tail)) :=
  by Logic.if_positive

theorem List.filter_prepend_negative (A : Type(0)) (P : A → Proposition) (head : A) (tail : List(A)) (fails : ¬P(head))
        : List.filter(P, List.prepend(A, head, tail)) = List.filter(P, tail) :=
  by Logic.if_negative

-- ----------------------------------------------------------------------
-- Membership: x ∈ filter(P, l) exactly when x ∈ l and P(x).

-- A member of the filtered list is a member of the original.
theorem List.filter_member_subset (A : Type(0)) (P : A → Proposition) (x : A) (list : List(A))
        : x ∈ List.filter(P, list)
          → x ∈ list :=
  by induction on list with IH {
    case List.empty:
        (mem : x ∈ List.empty(A)) ↦ mem
    case List.prepend(head, tail):
        done by cases {
          case P(head): {
              -- The head was kept: the membership is in the prepend form.
              suppose x ∈ List.filter(P, List.prepend(A, head, tail)) as mem;
              x ∈ List.prepend(A, head, List.filter(P, tail))
                  by substituting List.filter_prepend_positive;
              x = head ∨ x ∈ List.filter(P, tail)
                  by List.member_prepend_invert;
              done by cases {
                case x = head: {
                    head ∈ List.prepend(A, head, tail);
                    x ∈ List.prepend(A, head, tail);
                    done
                  }
                case x ∈ List.filter(P, tail) as memberFilteredTail:
                    List.member.there(A, x, head, tail, IH(memberFilteredTail))
              }
            }
          otherwise: {
              -- The head was dropped: the membership is already in the tail.
              suppose x ∈ List.filter(P, List.prepend(A, head, tail)) as mem;
              x ∈ List.filter(P, tail)
                  by substituting List.filter_prepend_negative as memberFilteredTail;
              List.member.there(A, x, head, tail, IH(memberFilteredTail))
            }
        }
  }

-- A member of the filtered list satisfies the predicate.
theorem List.filter_member_property (A : Type(0)) (P : A → Proposition) (x : A) (list : List(A))
        : x ∈ List.filter(P, list)
          → P(x) :=
  by induction on list with IH {
    case List.empty:
        (mem : x ∈ List.empty(A)) ↦
            absurd(List.no_member_empty(A, x, mem))
    case List.prepend(head, tail):
        done by cases {
          case P(head) as propertyWitness: {
              suppose x ∈ List.filter(P, List.prepend(A, head, tail)) as mem;
              x ∈ List.prepend(A, head, List.filter(P, tail))
                  by substituting List.filter_prepend_positive;
              x = head ∨ x ∈ List.filter(P, tail)
                  by List.member_prepend_invert;
              done by cases {
                case x = head: {
                    -- x is the kept head, and the decision carries P(head).
                    P(x);
                    done
                  }
                case x ∈ List.filter(P, tail) as memberFilteredTail:
                    IH(memberFilteredTail)
              }
            }
          otherwise: {
              suppose x ∈ List.filter(P, List.prepend(A, head, tail)) as mem;
              x ∈ List.filter(P, tail)
                  by substituting List.filter_prepend_negative as memberFilteredTail;
              IH(memberFilteredTail)
            }
        }
  }

-- Conversely, a member of the original that satisfies the predicate
-- survives the filter.
theorem List.filter_member_complete (A : Type(0)) (P : A → Proposition) (x : A) (list : List(A))
        : x ∈ list
          → P(x)
          → x ∈ List.filter(P, list) :=
  by induction on list with IH {
    case List.empty:
        (mem : x ∈ List.empty(A))
        (property : P(x)) ↦
            absurd(List.no_member_empty(A, x, mem))
    case List.prepend(head, tail):
        done by cases {
          case P(head) as propertyWitness: {
              suppose x ∈ List.prepend(A, head, tail) as mem;
              suppose P(x) as property;
              -- The head is kept: place x in the prepend form.
              x = head ∨ x ∈ tail
                  by List.member_prepend_invert;
              x ∈ List.prepend(A, head, List.filter(P, tail))
                  by cases {
                    case x = head: {
                        head ∈ List.prepend(A, head, List.filter(P, tail));
                        x ∈ List.prepend(A, head, List.filter(P, tail));
                        done
                      }
                    case x ∈ tail as memberTail:
                        List.member.there(A, x, head, List.filter(P, tail),
                            IH(memberTail, property))
                  };
              List.filter(P, List.prepend(A, head, tail)) = List.prepend(A, head, List.filter(P, tail))
                  by List.filter_prepend_positive;
              done
            }
          otherwise as propertyFails: {
              suppose x ∈ List.prepend(A, head, tail) as mem;
              suppose P(x) as property;
              -- The head is dropped: x must sit in the filtered tail.
              x = head ∨ x ∈ tail
                  by List.member_prepend_invert;
              x ∈ List.filter(P, tail)
                  by cases {
                    case x = head: {
                        -- x is the dropped head, yet P(x) holds — absurd.
                        P(head) as propertyAtHead;
                        absurd(propertyFails(propertyAtHead))
                      }
                    case x ∈ tail as memberTail:
                        IH(memberTail, property)
                  };
              List.filter(P, List.prepend(A, head, tail)) = List.filter(P, tail)
                  by List.filter_prepend_negative;
              done
            }
        }
  }

-- ----------------------------------------------------------------------
-- Filtering a distinct list stays distinct (a sublist of a distinct list).
theorem List.filter_distinct (A : Type(0)) (P : A → Proposition) (list : List(A))
        : List.Distinct(A, list)
          → List.Distinct(A, List.filter(P, list)) :=
  by induction on list with IH {
    case List.empty:
        (distinct : List.Distinct(A, List.empty(A))) ↦ distinct
    case List.prepend(head, tail):
        done by cases {
          case P(head): {
              suppose List.Distinct(A, List.prepend(A, head, tail)) as distinct;
              ¬(head ∈ tail)
                  by List.Distinct.head_not_member as headNotInTail;
              List.Distinct(A, tail)
                  by List.Distinct.tail_distinct as tailDistinct;
              ¬(head ∈ List.filter(P, tail))
                  by (innerMember : head ∈ List.filter(P, tail)) ↦ {
                      head ∈ tail as headInTail;
                      headNotInTail(headInTail)
                    } as headNotInFilteredTail;
              List.Distinct(A, List.prepend(A, head, List.filter(P, tail)))
                  by List.Distinct.prepend(A, head, List.filter(P, tail),
                        headNotInFilteredTail,
                        IH(tailDistinct));
              List.filter(P, List.prepend(A, head, tail)) = List.prepend(A, head, List.filter(P, tail))
                  by List.filter_prepend_positive;
              done
            }
          otherwise: {
              suppose List.Distinct(A, List.prepend(A, head, tail)) as distinct;
              List.Distinct(A, tail)
                  by List.Distinct.tail_distinct as tailDistinct;
              List.Distinct(A, List.filter(P, tail))
                  by IH(tailDistinct);
              List.filter(P, List.prepend(A, head, tail)) = List.filter(P, tail)
                  by List.filter_prepend_negative;
              done
            }
        }
  }

-- ----------------------------------------------------------------------
-- Filtering distributes over append, and a filter that keeps nothing is
-- empty.

theorem List.filter_append (A : Type(0)) (P : A → Proposition) (second first : List(A))
        : List.filter(P, List.append(first, second))
          = List.append(List.filter(P, first), List.filter(P, second)) :=
  by induction on first with IH {
    case List.empty: done
    case List.prepend(head, tail):
        done by cases {
          case P(head) as holds: {
              List.filter(P, List.prepend(A, head, tail)) = List.prepend(A, head, List.filter(P, tail))
                  by List.filter_prepend_positive as headKept;
              List.filter(P, List.append(List.prepend(A, head, tail), second))
                 = List.filter(P, List.prepend(A, head, List.append(tail, second)))
                 = List.prepend(A, head, List.filter(P, List.append(tail, second)))
                       by List.filter_prepend_positive
                 = List.prepend(A, head, List.append(List.filter(P, tail), List.filter(P, second)))
                       by substituting IH
                 = List.append(List.prepend(A, head, List.filter(P, tail)), List.filter(P, second))
                 = List.append(List.filter(P, List.prepend(A, head, tail)), List.filter(P, second))
                       by substituting headKept;
              done
            }
          otherwise as fails: {
              List.filter(P, List.prepend(A, head, tail)) = List.filter(P, tail)
                  by List.filter_prepend_negative as headDropped;
              List.filter(P, List.append(List.prepend(A, head, tail), second))
                 = List.filter(P, List.prepend(A, head, List.append(tail, second)))
                 = List.filter(P, List.append(tail, second))
                       by List.filter_prepend_negative
                 = List.append(List.filter(P, tail), List.filter(P, second))
                       by IH
                 = List.append(List.filter(P, List.prepend(A, head, tail)), List.filter(P, second))
                       by substituting headDropped;
              done
            }
        }
  }

theorem List.filter_none (A : Type(0)) (P : A → Proposition) (list : List(A))
        (noneHold : ∀ (x : A). x ∈ list → ¬P(x))
        : List.filter(P, list) = List.empty(A) :=
  by induction on list with IH {
    case List.empty: done
    case List.prepend(head, tail): {
        head ∈ List.prepend(A, head, tail);
        ¬P(head) by noneHold;
        ∀ (x : A). x ∈ tail → ¬P(x)
            by (x : A) (memberTail : x ∈ tail) ↦ {
                x ∈ List.prepend(A, head, tail);
                done by noneHold
              };
        List.filter(P, List.prepend(A, head, tail))
           = List.filter(P, tail)   by List.filter_prepend_negative
           = List.empty(A)          by IH;
        done
      }
  }

-- Filtering a mapped list is mapping the filter of the pulled-back
-- predicate: filter(P, map(f, l)) = map(f, filter(P ∘ f, l)).
theorem List.filter_map (A B : Type(0)) (P : B → Proposition) (f : A → B) (list : List(A))
        : List.filter(P, List.map(f, list))
          = List.map(f, List.filter((x : A) ↦ P(f(x)), list)) :=
  by induction on list with IH {
    case List.empty: done
    case List.prepend(head, tail):
        done by cases {
          case P(f(head)) as holds: {
              List.filter((x : A) ↦ P(f(x)), List.prepend(A, head, tail))
                 = List.prepend(A, head, List.filter((x : A) ↦ P(f(x)), tail))
                 by List.filter_prepend_positive as headKept;
              List.filter(P, List.map(f, List.prepend(A, head, tail)))
                 = List.filter(P, List.prepend(B, f(head), List.map(f, tail)))
                 = List.prepend(B, f(head), List.filter(P, List.map(f, tail)))
                       by List.filter_prepend_positive
                 = List.prepend(B, f(head), List.map(f, List.filter((x : A) ↦ P(f(x)), tail)))
                       by substituting IH
                 = List.map(f, List.prepend(A, head, List.filter((x : A) ↦ P(f(x)), tail)))
                 = List.map(f, List.filter((x : A) ↦ P(f(x)), List.prepend(A, head, tail)))
                       by substituting headKept;
              done
            }
          otherwise as fails: {
              List.filter((x : A) ↦ P(f(x)), List.prepend(A, head, tail))
                 = List.filter((x : A) ↦ P(f(x)), tail)
                 by List.filter_prepend_negative as headDropped;
              List.filter(P, List.map(f, List.prepend(A, head, tail)))
                 = List.filter(P, List.prepend(B, f(head), List.map(f, tail)))
                 = List.filter(P, List.map(f, tail))
                       by List.filter_prepend_negative
                 = List.map(f, List.filter((x : A) ↦ P(f(x)), tail))
                       by IH
                 = List.map(f, List.filter((x : A) ↦ P(f(x)), List.prepend(A, head, tail)))
                       by substituting headDropped;
              done
            }
        }
  }

-- Lists/remove.math
--
-- `List.remove(x, l)`: `l` with the FIRST occurrence of `x` dropped. The
-- head/`x` comparison is classical (`Logic.classical_decidable`), so this
-- applies to any element type; like `filter`, `remove` does not compute on
-- concrete lists — reasoning goes through the two characterizing equations
-- (`remove_prepend_equal`/`_unequal`) and the member/length/distinctness
-- lemmas below. The reusable "drop one element" companion of `filter`, built
-- for the involution-pairing sum-zero lemma (Stage H brick 6c).

module Lists.remove

import axioms
import Logic.basics
import Natural.classical_decidable
import Natural.basics
import Natural.order
import Equality.basics
import Lists.list
import Lists.distinct
import Lists.length

definition List.remove (A : Type(0)) (x : A) : List(A) → List(A)
  | List.empty => List.empty(A)
  | List.prepend(head, tail) =>
      if head = x then tail else List.prepend(A, head, List.remove(A, x, tail))

-- Infix set-minus: `l ∖ x` is `l` with the first occurrence of `x` dropped.
-- The carrier is implicit (recovered from `l`), and the operands read in the
-- mathematician's order (list on the left, removed element on the right).
definition List.removeFrom {A : Type(0)} (list : List(A)) (x : A) : List(A) :=
  List.remove(A, x, list)

operator (∖) on (List, _) := List.removeFrom

-- ── Characterizing equations (the opaque boundary) ────────────────────
theorem List.remove_prepend_equal (A : Type(0)) (x head : A) (tail : List(A)) (equal : head = x)
        : List.remove(A, x, List.prepend(A, head, tail)) = tail :=
  by Logic.if_positive

theorem List.remove_prepend_unequal (A : Type(0)) (x head : A) (tail : List(A)) (unequal : ¬(head = x))
        : List.remove(A, x, List.prepend(A, head, tail))
          = List.prepend(A, head, List.remove(A, x, tail)) :=
  by Logic.if_negative

-- ── Membership ────────────────────────────────────────────────────────

-- A member of `remove(x, l)` is a member of `l`.
theorem List.remove_member_subset (A : Type(0)) (x y : A) (list : List(A))
        : List.member(A, y, List.remove(A, x, list))
          → List.member(A, y, list) :=
  by induction on list with IH {
    case List.empty:
        (mem : List.member(A, y, List.remove(A, x, List.empty(A)))) ↦ mem
    case List.prepend(head, tail): {
        head = x ∨ ¬(head = x) by Logic.excluded_middle;
        done by cases {
          case head = x as headEqualsX: {
              suppose List.member(A, y, List.remove(A, x, List.prepend(A, x, tail))) as mem;
              List.member(A, y, tail) by substituting List.remove_prepend_equal as memTail;
              List.member.there(A, y, x, tail, memTail)
            }
          case ¬(head = x) as headNeqX: {
              suppose List.member(A, y, List.remove(A, x, List.prepend(A, head, tail))) as mem;
              List.member(A, y, List.prepend(A, head, List.remove(A, x, tail)))
                  by substituting List.remove_prepend_unequal;
              y = head ∨ List.member(A, y, List.remove(A, x, tail))
                  by List.member_prepend_invert;
              done by cases {
                case y = head as yHead: {
                    List.member(A, y, List.prepend(A, head, tail));
                    done
                  }
                case List.member(A, y, List.remove(A, x, tail)) as memRemTail:
                    List.member.there(A, y, head, tail, IH(memRemTail))
              }
            }
        }
      }
  }

-- Conversely, a member of `l` other than `x` survives the removal.
theorem List.remove_member_complete (A : Type(0)) (x y : A) (list : List(A))
        : List.member(A, y, list)
          → ¬(y = x)
          → List.member(A, y, List.remove(A, x, list)) :=
  by induction on list with IH {
    case List.empty:
        (mem : List.member(A, y, List.empty(A))) (neq : ¬(y = x)) ↦
            absurd(List.no_member_empty(A, y, mem))
    case List.prepend(head, tail):
        (mem : List.member(A, y, List.prepend(A, head, tail))) (neq : ¬(y = x)) ↦ {
          head = x ∨ ¬(head = x) by Logic.excluded_middle;
          done by cases {
            case head = x as headEqualsX: {
                y = head ∨ List.member(A, y, tail) by List.member_prepend_invert;
                List.member(A, y, tail)
                    by cases {
                      case y = head as yHead: {
                          y = head = x as yEqualsX;
                          absurd(neq(yEqualsX))
                        }
                      case List.member(A, y, tail) as memberTail: memberTail
                    };
                done by substituting List.remove_prepend_equal
              }
            case ¬(head = x) as headNeqX: {
                y = head ∨ List.member(A, y, tail) by List.member_prepend_invert;
                List.member(A, y, List.prepend(A, head, List.remove(A, x, tail)))
                    by cases {
                      case y = head as yHead: {
                          List.member(A, head, List.prepend(A, head, List.remove(A, x, tail)));
                          List.member(A, y, List.prepend(A, head, List.remove(A, x, tail)))
                              by substituting yHead;
                          done
                        }
                      case List.member(A, y, tail) as memberTail:
                          List.member.there(A, y, head, List.remove(A, x, tail),
                              IH(memberTail, neq))
                    };
                done by substituting List.remove_prepend_unequal
              }
          }
        }
  }

-- In a distinct list, removing `x` leaves nothing equal to `x`.
theorem List.remove_member_ne (A : Type(0)) (x y : A) (list : List(A))
        : List.Distinct(A, list)
          → List.member(A, y, List.remove(A, x, list))
          → ¬(y = x) :=
  by induction on list with IH {
    case List.empty:
        (distinct : List.Distinct(A, List.empty(A)))
        (mem : List.member(A, y, List.remove(A, x, List.empty(A)))) ↦
            absurd(List.no_member_empty(A, y, mem))
    case List.prepend(head, tail):
        (distinct : List.Distinct(A, List.prepend(A, head, tail)))
        (mem : List.member(A, y, List.remove(A, x, List.prepend(A, head, tail)))) ↦ {
          ¬(List.member(A, head, tail)) by List.Distinct.head_not_member as headNotInTail;
          List.Distinct(A, tail) by List.Distinct.tail_distinct as tailDistinct;
          head = x ∨ ¬(head = x) by Logic.excluded_middle;
          done by cases {
            case head = x as headEqualsX: {
                List.member(A, y, tail) by substituting List.remove_prepend_equal;
                (yEqualsX : y = x) ↦ {
                    y = x = head as yEqualsHead;
                    List.member(A, head, tail) by substituting yEqualsHead as memHead;
                    headNotInTail(memHead)
                  }
              }
            case ¬(head = x) as headNeqX: {
                List.member(A, y, List.prepend(A, head, List.remove(A, x, tail)))
                    by substituting List.remove_prepend_unequal;
                y = head ∨ List.member(A, y, List.remove(A, x, tail))
                    by List.member_prepend_invert;
                done by cases {
                  case y = head as yHead: {
                      (yEqualsX : y = x) ↦ {
                          head = y = x as headEqualsX;
                          headNeqX(headEqualsX)
                        }
                    }
                  case List.member(A, y, List.remove(A, x, tail)) as memRemTail:
                      IH(tailDistinct, memRemTail)
                }
              }
          }
        }
  }

-- ── Distinctness ──────────────────────────────────────────────────────

-- Removal preserves distinctness.
theorem List.remove_distinct (A : Type(0)) (x : A) (list : List(A))
        : List.Distinct(A, list) → List.Distinct(A, List.remove(A, x, list)) :=
  by induction on list with IH {
    case List.empty:
        (distinct : List.Distinct(A, List.empty(A))) ↦ distinct
    case List.prepend(head, tail):
        (distinct : List.Distinct(A, List.prepend(A, head, tail))) ↦ {
          ¬(List.member(A, head, tail)) by List.Distinct.head_not_member as headNotInTail;
          List.Distinct(A, tail) by List.Distinct.tail_distinct as tailDistinct;
          head = x ∨ ¬(head = x) by Logic.excluded_middle;
          done by cases {
            case head = x as headEqualsX:
                done by substituting List.remove_prepend_equal
            case ¬(head = x) as headNeqX: {
                List.Distinct(A, List.remove(A, x, tail)) by IH(tailDistinct) as remTailDistinct;
                ¬(List.member(A, head, List.remove(A, x, tail)))
                    by (memHead : List.member(A, head, List.remove(A, x, tail))) ↦ {
                        List.member(A, head, tail) by List.remove_member_subset as headInTail;
                        headNotInTail(headInTail)
                      } as headNotInRemTail;
                List.Distinct(A, List.prepend(A, head, List.remove(A, x, tail)))
                    by List.Distinct.prepend(A, head, List.remove(A, x, tail),
                           headNotInRemTail, remTailDistinct);
                done by substituting List.remove_prepend_unequal
              }
          }
        }
  }

-- ── Length ────────────────────────────────────────────────────────────

-- Removing a member drops the length by one.
theorem List.length_remove_member (A : Type(0)) (x : A) (list : List(A))
        : List.member(A, x, list)
          → List.length(A, list) = 1 + List.length(A, List.remove(A, x, list)) :=
  by induction on list with IH {
    case List.empty:
        (mem : List.member(A, x, List.empty(A))) ↦
            absurd(List.no_member_empty(A, x, mem))
    case List.prepend(head, tail):
        (mem : List.member(A, x, List.prepend(A, head, tail))) ↦ {
          head = x ∨ ¬(head = x) by Logic.excluded_middle;
          done by cases {
            case head = x as headEqualsX:
                List.length(A, List.prepend(A, head, tail))
                   = 1 + List.length(A, tail)                          by List.length_prepend
                   = 1 + List.length(A, List.remove(A, x, List.prepend(A, head, tail)))
                       by substituting List.remove_prepend_equal
            case ¬(head = x) as headNeqX: {
                List.member(A, x, tail)
                    by { x = head ∨ List.member(A, x, tail) by List.member_prepend_invert;
                         done by cases {
                           case x = head as xHead: absurd(headNeqX(Equality.symmetry(xHead)))
                           case List.member(A, x, tail) as memberTail: memberTail
                         }
                       } as memTail;
                List.length(A, tail) = 1 + List.length(A, List.remove(A, x, tail))
                    by IH(memTail) as tailEq;
                List.length(A, List.prepend(A, head, tail))
                   = 1 + List.length(A, tail)                          by List.length_prepend
                   = 1 + (1 + List.length(A, List.remove(A, x, tail))) by substituting tailEq
                   = 1 + List.length(A, List.prepend(A, head, List.remove(A, x, tail)))
                       by substituting List.length_prepend
                   = 1 + List.length(A, List.remove(A, x, List.prepend(A, head, tail)))
                       by substituting List.remove_prepend_unequal
              }
          }
        }
  }

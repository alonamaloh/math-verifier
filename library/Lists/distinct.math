-- Lists/distinct.math
--
-- `List.Distinct(l)`: the elements of `l` are pairwise distinct (no
-- duplicates). A reusable predicate; here we show `range_down(n)` is
-- distinct (its head 1 + k exceeds every element of range_down(k)).

module Lists.distinct

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.order
import Natural.add_order
import Natural.arithmetic
import Lists.list
import Lists.range
import Lists.map
import Lists.permutation

inductive List.Distinct (A : Type(0)) : List(A) → Proposition where
  | List.Distinct.empty : List.Distinct(A, List.empty(A))
  | List.Distinct.prepend
      : (head : A) → (tail : List(A))
        → ¬(List.member(A, head, tail))
        → List.Distinct(A, tail)
        → List.Distinct(A, List.prepend(A, head, tail))

-- ----------------------------------------------------------------------
-- Inversion. To read the two components of `Distinct(prepend(head, tail))`
-- back off the derivation we keep the list a free variable plus an
-- equality witness (matching `Distinct` against a concrete `prepend` is
-- not allowed), then identify the parts by `prepend` injectivity.

theorem List.Distinct_invert_general (A : Type(0)) (list : List(A))
        (distinctProof : List.Distinct(A, list))
        : ∀ (head : A). ∀ (tail : List(A)).
          list = List.prepend(A, head, tail)
          → ¬(List.member(A, head, tail)) ∧ List.Distinct(A, tail) :=
  by induction on distinctProof {
    case List.Distinct.empty:
        (head : A) (tail : List(A))
        (listEquality : List.empty(A) = List.prepend(A, head, tail)) ↦ {
          -- empty = prepend is impossible: is_nonempty distinguishes them.
          List.is_nonempty(A, List.prepend(A, head, tail));
          List.is_nonempty(A, List.empty(A))
              by substituting listEquality as impossible;
          absurd(impossible)
        }
    case List.Distinct.prepend(distinctHead, distinctTail, headNotInTail, tailDistinct):
        (head : A) (tail : List(A))
        (listEquality : List.prepend(A, distinctHead, distinctTail)
                        = List.prepend(A, head, tail)) ↦ {
          distinctHead = head by List.prepend_injective_head as headEquality;
          distinctTail = tail by List.prepend_injective_tail as tailEquality;
          ¬(List.member(A, head, distinctTail))
              by substituting headEquality;
          ¬(List.member(A, head, tail))
              by substituting tailEquality as headNotMember;
          List.Distinct(A, tail)
              by substituting tailEquality as tailIsDistinct;
          And.introduction(headNotMember, tailIsDistinct)
        }
  }

-- The head of a distinct list does not recur in the tail.
theorem List.Distinct.head_not_member (A : Type(0)) (head : A) (tail : List(A))
        (distinct : List.Distinct(A, List.prepend(A, head, tail)))
        : ¬(List.member(A, head, tail)) := {
  ¬(List.member(A, head, tail)) ∧ List.Distinct(A, tail)
      by List.Distinct_invert_general(A, List.prepend(A, head, tail), distinct,
             head, tail, reflexivity(List(A), List.prepend(A, head, tail)));
  done
}

-- The tail of a distinct list is distinct.
theorem List.Distinct.tail_distinct (A : Type(0)) (head : A) (tail : List(A))
        (distinct : List.Distinct(A, List.prepend(A, head, tail)))
        : List.Distinct(A, tail) := {
  ¬(List.member(A, head, tail)) ∧ List.Distinct(A, tail)
      by List.Distinct_invert_general(A, List.prepend(A, head, tail), distinct,
             head, tail, reflexivity(List(A), List.prepend(A, head, tail)));
  done
}

-- ----------------------------------------------------------------------
-- Distinctness is invariant under permutation: rearranging a list neither
-- creates nor removes duplicates. (Stated forward; the symmetric direction
-- follows by applying it to the reversed permutation.)
theorem List.Permutation.distinct_invariant (A : Type(0)) (l1 l2 : List(A))
        (perm : List.Permutation(A, l1, l2))
        : List.Distinct(A, l1) → List.Distinct(A, l2) :=
  by induction on perm {
    case List.Permutation.empty:
        (distinct : List.Distinct(A, List.empty(A))) ↦ distinct
    case List.Permutation.skip(x, a, b, subPerm, skipInvariant):
        (distinct : List.Distinct(A, List.prepend(A, x, a))) ↦ {
          -- x does not recur in a, hence (transporting along the
          -- permutation) not in b either; the tails stay distinct.
          ¬(List.member(A, x, a))
              by List.Distinct.head_not_member as xNotInA;
          List.Distinct(A, a) by List.Distinct.tail_distinct as aDistinct;
          ¬(List.member(A, x, b))
              by List.Permutation.not_member_forward as xNotInB;
          List.Distinct.prepend(A, x, b, xNotInB, skipInvariant(aDistinct))
        }
    case List.Permutation.swap(x, y, l):
        (distinct : List.Distinct(A, List.prepend(A, x, List.prepend(A, y, l)))) ↦ {
          -- Unpack: x ∉ y::l, y ∉ l, and l is distinct.
          ¬(List.member(A, x, List.prepend(A, y, l)))
              by List.Distinct.head_not_member as xNotInYL;
          List.Distinct(A, List.prepend(A, y, l))
              by List.Distinct.tail_distinct as ylDistinct;
          ¬(List.member(A, y, l)) by List.Distinct.head_not_member as yNotInL;
          List.Distinct(A, l) by List.Distinct.tail_distinct as lDistinct;
          -- x ∉ l, since it is not even in y::l.
          ¬(List.member(A, x, l))
              by (memberXInL : List.member(A, x, l)) ↦
                  xNotInYL(List.member.there(A, x, y, l, memberXInL)) as xNotInL;
          -- y ∉ x::l: y is not x (x ∉ y::l rules the head out) and y ∉ l.
          ¬(List.member(A, y, List.prepend(A, x, l)))
              by (memberYInXL : List.member(A, y, List.prepend(A, x, l))) ↦ {
                  y = x ∨ List.member(A, y, l)
                      by List.member_prepend_invert;
                  done by cases {
                    case y = x as yEqualsX: {
                        List.member(A, y, List.prepend(A, y, l));
                        List.member(A, x, List.prepend(A, y, l))
                            by substituting yEqualsX as memberXInYL;
                        xNotInYL(memberXInYL)
                      }
                    case List.member(A, y, l) as memberYInL: yNotInL(memberYInL)
                  }
                } as yNotInXL;
          List.Distinct.prepend(A, y, List.prepend(A, x, l), yNotInXL,
              List.Distinct.prepend(A, x, l, xNotInL, lDistinct))
        }
    case List.Permutation.transitive(a, b, c, p, q, pInvariant, qInvariant):
        (distinct : List.Distinct(A, a)) ↦
          qInvariant(pInvariant(distinct))
  }

-- range_down(n) has no duplicates.
theorem List.range_down_distinct (n : Natural)
        : List.Distinct(Natural, List.range_down(n)) :=
  by induction on n with IH {
    case base: List.Distinct.empty(Natural)
    case step(predecessor): {
        ¬(List.member(Natural, 1 + predecessor,
                    List.range_down(predecessor)))
            by (mem : List.member(Natural, 1 + predecessor,
                    List.range_down(predecessor))) ↦ {
                1 + predecessor ≤ predecessor
                    by List.range_down_member_le;
                False;
                done
              } as notMember;
        List.Distinct(Natural,
                List.prepend(Natural, 1 + predecessor, List.range_down(predecessor)))
            by List.Distinct.prepend(Natural, 1 + predecessor,
                   List.range_down(predecessor), notMember, IH);
        done by substituting List.range_down_one_plus
      }
  }

-- As `map_distinct` below, but requiring injectivity only on the members
-- of the list. (k ↦ [k] mod p is not globally injective — [0] = [p] — yet
-- on the members of range_down(p−1) it is, and that is all this asks.)
theorem List.map_distinct_on (A B : Type(0)) (f : A → B) (list : List(A))
        : (∀ (x y : A). List.member(A, x, list) → List.member(A, y, list)
                 → f(x) = f(y) → x = y)
          → List.Distinct(A, list)
          → List.Distinct(B, List.map(A, B, f, list)) :=
  by induction on list with IH {
    case List.empty:
      (injectiveOnList
          : ∀ (x y : A). List.member(A, x, List.empty(A))
              → List.member(A, y, List.empty(A)) → f(x) = f(y) → x = y)
      (distinct : List.Distinct(A, List.empty(A))) ↦
        List.Distinct.empty(B)
    case List.prepend(head, tail):
      (injectiveOnList
          : ∀ (x y : A). List.member(A, x, List.prepend(A, head, tail))
              → List.member(A, y, List.prepend(A, head, tail))
              → f(x) = f(y) → x = y)
      (distinct : List.Distinct(A, List.prepend(A, head, tail))) ↦ {
        -- Restrict the injectivity hypothesis to the tail's members, and
        -- to comparisons against the head.
        ∀ (x y : A). List.member(A, x, tail) → List.member(A, y, tail)
                → f(x) = f(y) → x = y
            by (x y : A)
               (xMember : List.member(A, x, tail))
               (yMember : List.member(A, y, tail))
               (imagesEqual : f(x) = f(y)) ↦
                 injectiveOnList(x, y,
                     List.member.there(A, x, head, tail, xMember),
                     List.member.there(A, y, head, tail, yMember),
                     imagesEqual) as injectiveOnTail;
        (x : A) → List.member(A, x, tail) → f(x) = f(head) → x = head
            by (x : A)
               (xMember : List.member(A, x, tail))
               (imagesEqual : f(x) = f(head)) ↦
                 injectiveOnList(x, head,
                     List.member.there(A, x, head, tail, xMember),
                     List.member.here(A, head, tail),
                     imagesEqual);
        ¬(List.member(A, head, tail));
        List.Distinct(A, tail) as tailDistinct;
        ¬(List.member(B, f(head), List.map(A, B, f, tail)))
            by List.not_member_map_of_not_member_on as imageHeadNotInImageTail;
        List.Distinct.prepend(B, f(head), List.map(A, B, f, tail),
            imageHeadNotInImageTail,
            IH(injectiveOnTail, tailDistinct))
      }
  }

-- An injective map preserves distinctness.
theorem List.map_distinct (A B : Type(0)) (f : A → B)
        (injective : ∀ (x y : A). f(x) = f(y) → x = y)
        (list : List(A)) (distinctProof : List.Distinct(A, list))
        : List.Distinct(B, List.map(A, B, f, list)) :=
  by induction on distinctProof with IH {
    case List.Distinct.empty: List.Distinct.empty(B)
    case List.Distinct.prepend(head, tail, headNotInTail, tailDistinct):
        List.Distinct.prepend(B, f(head), List.map(A, B, f, tail),
            List.not_member_map_of_not_member(A, B, f, injective, head, tail, headNotInTail),
            IH)
  }

-- ----------------------------------------------------------------------
-- Two distinct lists of the same length, one contained in the other, are
-- permutations of each other — the finite-set "injection between equal
-- cardinalities is a bijection" fact, in list form. Extract the head of
-- l1 from l2 and recurse on the tails.
theorem List.permutation_of_distinct_inclusion (A : Type(0)) (l1 : List(A))
        : ∀ (l2 : List(A)).
          List.Distinct(A, l1)
          → List.Distinct(A, l2)
          → (∀ (x : A). List.member(A, x, l1) → List.member(A, x, l2))
          → List.length(A, l1) = List.length(A, l2)
          → List.Permutation(A, l1, l2) :=
  by induction on l1 with IH {
    case List.empty:
      (l2 : List(A))
      (distinct1 : List.Distinct(A, List.empty(A)))
      (distinct2 : List.Distinct(A, l2))
      (inclusion : ∀ (x : A). List.member(A, x, List.empty(A))
          → List.member(A, x, l2))
      (lengthEquation : List.length(A, List.empty(A)) = List.length(A, l2)) ↦
        done by cases {
          case l2 = List.empty(A): List.Permutation.empty(A)
          case l2 = List.prepend(A, head, tail) for some (head : A), (tail : List(A)): {
              -- |empty| = 0 but |prepend| = 1 + |tail|, so 0 is one more
              -- than something — absurd.
              (0 : Natural)
                  = List.length(A, List.empty(A))
                  = List.length(A, List.prepend(A, head, tail))
                  = 1 + List.length(A, tail);
              False by Natural.zero_not_one_plus as impossible;
              absurd(impossible)
            }
        }
    case List.prepend(head, tail):
      (l2 : List(A))
      (distinct1 : List.Distinct(A, List.prepend(A, head, tail)))
      (distinct2 : List.Distinct(A, l2))
      (inclusion : ∀ (x : A). List.member(A, x, List.prepend(A, head, tail))
          → List.member(A, x, l2))
      (lengthEquation
          : List.length(A, List.prepend(A, head, tail)) = List.length(A, l2)) ↦ {
        -- The head sits somewhere in l2; rotate it to the front.
        List.member(A, head, List.prepend(A, head, tail));
        List.member(A, head, l2) as headMember2;
        choose rest such that List.Permutation(A, l2, List.prepend(A, head, rest))
            from List.Permutation.extract(A, head, l2, headMember2);
        -- Distinctness on both sides, with the head removed.
        ¬(List.member(A, head, tail)) as headNotInTail;
        List.Distinct(A, tail) as tailDistinct;
        List.Distinct(A, List.prepend(A, head, rest));
        ¬(List.member(A, head, rest));
        List.Distinct(A, rest) as restDistinct;
        -- The tail is contained in the remainder: an x ∈ tail is in l2,
        -- lands in head :: rest, and is not the head (head ∉ tail).
        ∀ (x : A). List.member(A, x, tail) → List.member(A, x, rest)
            by (x : A) (xInTail : List.member(A, x, tail)) ↦ {
                List.member(A, x, List.prepend(A, head, tail));
                List.member(A, x, l2);
                List.member(A, x, List.prepend(A, head, rest))
                    by List.Permutation.member_forward;
                ¬(x = head)
                    by (xIsHead : x = head) ↦ {
                        List.member(A, head, tail)
                            by substituting xIsHead as headInTail;
                        headNotInTail(headInTail)
                      };
                done by List.member_of_prepend_not_head
              } as tailInclusion;
        -- Equal lengths after dropping the head from both.
        List.length(A, l2) = List.length(A, List.prepend(A, head, rest));
        1 + List.length(A, tail)
            = List.length(A, List.prepend(A, head, tail))
            = List.length(A, l2)
            = List.length(A, List.prepend(A, head, rest))
            = 1 + List.length(A, rest);
        List.length(A, tail) = List.length(A, rest) as restLengthEquation;
        -- Recurse on the tails and reassemble.
        List.Permutation(A, tail, rest)
            by IH(rest, tailDistinct, restDistinct, tailInclusion, restLengthEquation);
        List.Permutation(A, List.prepend(A, head, tail), List.prepend(A, head, rest));
        List.Permutation(A, List.prepend(A, head, rest), l2)
            by List.Permutation.symmetric;
        done
      }
  }

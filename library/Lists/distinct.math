-- Lists/distinct.math
--
-- `List.Distinct(l)`: the elements of `l` are pairwise distinct (no
-- duplicates). A reusable predicate; here we show `range_down(n)` is
-- distinct (its head 1 + k exceeds every element of range_down(k)).

module Lists.distinct

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.order
import Natural.add_order
import Natural.arithmetic
import Lists.list
import Lists.range
import Lists.map
import Lists.permutation

inductive List.Distinct (A : Type(0)) : List(A) → Proposition where
  | List.Distinct.empty : List.Distinct(A, List.empty(A))
  | List.Distinct.prepend
      : (head : A) → (tail : List(A))
        → ¬(List.member(A, head, tail))
        → List.Distinct(A, tail)
        → List.Distinct(A, List.prepend(A, head, tail))

-- ----------------------------------------------------------------------
-- Inversion. To read the two components of `Distinct(prepend(head, tail))`
-- back off the derivation we keep the list a free variable plus an
-- equality witness (matching `Distinct` against a concrete `prepend` is
-- not allowed), then identify the parts by `prepend` injectivity.

theorem List.Distinct_invert_general (A : Type(0)) (list : List(A))
        : List.Distinct(A, list)
          → ∀ (head : A). ∀ (tail : List(A)).
          list = List.prepend(A, head, tail)
          → ¬(List.member(A, head, tail)) ∧ List.Distinct(A, tail)
  | List.Distinct.empty =>
      (head : A) (tail : List(A))
      (listEquality : List.empty(A) = List.prepend(A, head, tail)) ↦ {
        -- empty = prepend is impossible: is_nonempty distinguishes them.
        claim List.is_nonempty(A, List.prepend(A, head, tail));
        claim impossible : List.is_nonempty(A, List.empty(A))
            by substituting listEquality;
        absurd(impossible)
      }
  | List.Distinct.prepend(distinctHead, distinctTail, headNotInTail, tailDistinct) =>
      (head : A) (tail : List(A))
      (listEquality : List.prepend(A, distinctHead, distinctTail)
                      = List.prepend(A, head, tail)) ↦ {
        claim headEquality : distinctHead = head by List.prepend_injective_head;
        claim tailEquality : distinctTail = tail by List.prepend_injective_tail;
        claim ¬(List.member(A, head, distinctTail))
            by substituting headEquality;
        claim headNotMember : ¬(List.member(A, head, tail))
            by substituting tailEquality;
        claim tailIsDistinct : List.Distinct(A, tail)
            by substituting tailEquality;
        And.introduction(headNotMember, tailIsDistinct)
      }

-- The head of a distinct list does not recur in the tail.
theorem List.Distinct.head_not_member (A : Type(0)) (head : A) (tail : List(A))
        (distinct : List.Distinct(A, List.prepend(A, head, tail)))
        : ¬(List.member(A, head, tail)) := {
  obtain ⟨headNotMember, tailDistinct⟩
      from List.Distinct_invert_general(A, List.prepend(A, head, tail), distinct,
               head, tail, reflexivity(List(A), List.prepend(A, head, tail)));
  headNotMember
}

-- The tail of a distinct list is distinct.
theorem List.Distinct.tail_distinct (A : Type(0)) (head : A) (tail : List(A))
        (distinct : List.Distinct(A, List.prepend(A, head, tail)))
        : List.Distinct(A, tail) := {
  obtain ⟨headNotMember, tailDistinct⟩
      from List.Distinct_invert_general(A, List.prepend(A, head, tail), distinct,
               head, tail, reflexivity(List(A), List.prepend(A, head, tail)));
  tailDistinct
}

-- ----------------------------------------------------------------------
-- Distinctness is invariant under permutation: rearranging a list neither
-- creates nor removes duplicates. (Stated forward; the symmetric direction
-- follows by applying it to the reversed permutation.)
theorem List.Permutation.distinct_invariant (A : Type(0)) (l1 l2 : List(A))
        : List.Permutation(A, l1, l2)
          → List.Distinct(A, l1)
          → List.Distinct(A, l2)
  | List.Permutation.empty =>
      (distinct : List.Distinct(A, List.empty(A))) ↦ distinct
  | List.Permutation.skip(x, a, b, perm) =>
      (distinct : List.Distinct(A, List.prepend(A, x, a))) ↦ {
        -- x does not recur in a, hence (transporting along the
        -- permutation) not in b either; the tails stay distinct.
        claim ¬(List.member(A, x, a))
            by List.Distinct.head_not_member;
        claim aDistinct : List.Distinct(A, a)
            by List.Distinct.tail_distinct;
        claim xNotInB : ¬(List.member(A, x, b))
            by List.Permutation.not_member_forward;
        List.Distinct.prepend(A, x, b, xNotInB,
            List.Permutation.distinct_invariant(A, a, b, perm, aDistinct))
      }
  | List.Permutation.swap(x, y, l) =>
      (distinct : List.Distinct(A, List.prepend(A, x, List.prepend(A, y, l)))) ↦ {
        -- Unpack: x ∉ y::l, y ∉ l, and l is distinct.
        claim xNotInYL : ¬(List.member(A, x, List.prepend(A, y, l)))
            by List.Distinct.head_not_member;
        claim List.Distinct(A, List.prepend(A, y, l))
            by List.Distinct.tail_distinct;
        claim yNotInL : ¬(List.member(A, y, l))
            by List.Distinct.head_not_member;
        claim lDistinct : List.Distinct(A, l)
            by List.Distinct.tail_distinct;
        -- x ∉ l, since it is not even in y::l.
        claim xNotInL : ¬(List.member(A, x, l))
            by (memberXInL : List.member(A, x, l)) ↦
                xNotInYL(List.member.there(A, x, y, l, memberXInL));
        -- y ∉ x::l: y is not x (x ∉ y::l rules the head out) and y ∉ l.
        claim yNotInXL : ¬(List.member(A, y, List.prepend(A, x, l)))
            by (memberYInXL : List.member(A, y, List.prepend(A, x, l))) ↦ {
                claim split : y = x ∨ List.member(A, y, l)
                    by List.member_prepend_invert;
                cases split {
                  | Or.introduceLeft(yEqualsX) => {
                      claim List.member(A, y, List.prepend(A, y, l))
                          by List.member.here(A, y, l);
                      claim memberXInYL : List.member(A, x, List.prepend(A, y, l))
                          by substituting yEqualsX;
                      xNotInYL(memberXInYL)
                    }
                  | Or.introduceRight(memberYInL) => yNotInL(memberYInL)
                }
              };
        List.Distinct.prepend(A, y, List.prepend(A, x, l), yNotInXL,
            List.Distinct.prepend(A, x, l, xNotInL, lDistinct))
      }
  | List.Permutation.transitive(a, b, c, p, q) =>
      (distinct : List.Distinct(A, a)) ↦
        List.Permutation.distinct_invariant(A, b, c, q,
            List.Permutation.distinct_invariant(A, a, b, p, distinct))

-- range_down(n) has no duplicates.
theorem List.range_down_distinct (n : Natural)
        : List.Distinct(Natural, List.range_down(n)) :=
  unfold Natural.add in
  by_induction on n with IH {
    case base: List.Distinct.empty(Natural)
    case step(predecessor): {
        claim notMember
            : ¬(List.member(Natural, 1 + predecessor,
                    List.range_down(predecessor)))
            by (mem : List.member(Natural, 1 + predecessor,
                    List.range_down(predecessor))) ↦ {
                claim onePlusLe : 1 + predecessor ≤ predecessor
                    since List.range_down_member_le;
                calc predecessor
                   < 1 + predecessor   by Natural.lt_one_plus
                   ≤ predecessor       by onePlusLe;
                claim False since Natural.lt_irreflexive;
                done
              };
        List.Distinct.prepend(Natural, 1 + predecessor,
            List.range_down(predecessor), notMember, IH)
      }
  }

-- As `map_distinct` below, but requiring injectivity only on the members
-- of the list. (k ↦ [k] mod p is not globally injective — [0] = [p] — yet
-- on the members of range_down(p−1) it is, and that is all this asks.)
theorem List.map_distinct_on (A B : Type(0)) (f : A → B)
        : ∀ (list : List(A)).
          (∀ (x y : A). List.member(A, x, list) → List.member(A, y, list)
                 → f(x) = f(y) → x = y)
          → List.Distinct(A, list)
          → List.Distinct(B, List.map(A, B, f, list))
  | List.empty =>
      (injectiveOnList
          : ∀ (x y : A). List.member(A, x, List.empty(A))
              → List.member(A, y, List.empty(A)) → f(x) = f(y) → x = y)
      (distinct : List.Distinct(A, List.empty(A))) ↦
        List.Distinct.empty(B)
  | List.prepend(head, tail) =>
      (injectiveOnList
          : ∀ (x y : A). List.member(A, x, List.prepend(A, head, tail))
              → List.member(A, y, List.prepend(A, head, tail))
              → f(x) = f(y) → x = y)
      (distinct : List.Distinct(A, List.prepend(A, head, tail))) ↦ {
        -- Restrict the injectivity hypothesis to the tail's members, and
        -- to comparisons against the head.
        claim injectiveOnTail
            : ∀ (x y : A). List.member(A, x, tail) → List.member(A, y, tail)
                → f(x) = f(y) → x = y
            by (x y : A)
               (xMember : List.member(A, x, tail))
               (yMember : List.member(A, y, tail))
               (imagesEqual : f(x) = f(y)) ↦
                 injectiveOnList(x, y,
                     List.member.there(A, x, head, tail, xMember),
                     List.member.there(A, y, head, tail, yMember),
                     imagesEqual);
        claim (x : A) → List.member(A, x, tail) → f(x) = f(head) → x = head
            by (x : A)
               (xMember : List.member(A, x, tail))
               (imagesEqual : f(x) = f(head)) ↦
                 injectiveOnList(x, head,
                     List.member.there(A, x, head, tail, xMember),
                     List.member.here(A, head, tail),
                     imagesEqual);
        claim ¬(List.member(A, head, tail))
            by List.Distinct.head_not_member;
        claim tailDistinct : List.Distinct(A, tail)
            by List.Distinct.tail_distinct;
        claim imageHeadNotInImageTail
            : ¬(List.member(B, f(head), List.map(A, B, f, tail)))
            by List.not_member_map_of_not_member_on;
        List.Distinct.prepend(B, f(head), List.map(A, B, f, tail),
            imageHeadNotInImageTail,
            List.map_distinct_on(A, B, f, tail, injectiveOnTail, tailDistinct))
      }

-- An injective map preserves distinctness.
theorem List.map_distinct (A B : Type(0)) (f : A → B)
        (injective : ∀ (x y : A). f(x) = f(y) → x = y)
        (list : List(A))
        : List.Distinct(A, list)
          → List.Distinct(B, List.map(A, B, f, list))
  | List.Distinct.empty => List.Distinct.empty(B)
  | List.Distinct.prepend(head, tail, headNotInTail, tailDistinct) =>
      List.Distinct.prepend(B, f(head), List.map(A, B, f, tail),
          List.not_member_map_of_not_member(A, B, f, injective, head, tail, headNotInTail),
          List.map_distinct(A, B, f, injective, tail, tailDistinct))

-- ----------------------------------------------------------------------
-- Two distinct lists of the same length, one contained in the other, are
-- permutations of each other — the finite-set "injection between equal
-- cardinalities is a bijection" fact, in list form. Extract the head of
-- l1 from l2 and recurse on the tails.
theorem List.permutation_of_distinct_inclusion (A : Type(0))
        : ∀ (l1 l2 : List(A)).
          List.Distinct(A, l1)
          → List.Distinct(A, l2)
          → (∀ (x : A). List.member(A, x, l1) → List.member(A, x, l2))
          → List.length(A, l1) = List.length(A, l2)
          → List.Permutation(A, l1, l2)
  | List.empty =>
      (l2 : List(A))
      (distinct1 : List.Distinct(A, List.empty(A)))
      (distinct2 : List.Distinct(A, l2))
      (inclusion : ∀ (x : A). List.member(A, x, List.empty(A))
          → List.member(A, x, l2))
      (lengthEquation : List.length(A, List.empty(A)) = List.length(A, l2)) ↦
        cases l2 refining lengthEquation, distinct2 {
          | List.empty => List.Permutation.empty(A)
          | List.prepend(head, tail) => {
              -- |empty| = 0 but |prepend| = 1 + |tail| ≥ 1, so 0 = |prepend|
              -- would force 1 ≤ 0 — absurd.
              calc (0 : Natural)
                 = List.length(A, List.empty(A))                 by List.length_empty
                 = List.length(A, List.prepend(A, head, tail))   by lengthEquation
                 = 1 + List.length(A, tail)                      by List.length_prepend
                as zeroEqOnePlus;
              claim oneLeOnePlus : 1 ≤ 1 + List.length(A, tail)
                  since Natural.less_or_equal_add_right;
              claim oneLeZero : 1 ≤ 0 by substituting zeroEqOnePlus;
              claim impossible : False since Natural.not_less_or_equal_successor_zero;
              absurd(impossible)
            }
        }
  | List.prepend(head, tail) =>
      (l2 : List(A))
      (distinct1 : List.Distinct(A, List.prepend(A, head, tail)))
      (distinct2 : List.Distinct(A, l2))
      (inclusion : ∀ (x : A). List.member(A, x, List.prepend(A, head, tail))
          → List.member(A, x, l2))
      (lengthEquation
          : List.length(A, List.prepend(A, head, tail)) = List.length(A, l2)) ↦ {
        -- The head sits somewhere in l2; rotate it to the front.
        claim headMember1 : List.member(A, head, List.prepend(A, head, tail))
            by List.member.here(A, head, tail);
        claim headMember2 : List.member(A, head, l2)
            by inclusion(head, headMember1);
        obtain ⟨rest, extracted⟩
            from List.Permutation.extract(A, head, l2, headMember2);
        -- Distinctness on both sides, with the head removed.
        claim headNotInTail : ¬(List.member(A, head, tail))
            since List.Distinct.head_not_member;
        claim tailDistinct : List.Distinct(A, tail)
            since List.Distinct.tail_distinct;
        claim List.Distinct(A, List.prepend(A, head, rest))
            by List.Permutation.distinct_invariant(A, l2,
                   List.prepend(A, head, rest), extracted, distinct2);
        claim ¬(List.member(A, head, rest))
            since List.Distinct.head_not_member;
        claim restDistinct : List.Distinct(A, rest)
            since List.Distinct.tail_distinct;
        -- The tail is contained in the remainder: an x ∈ tail is in l2,
        -- lands in head :: rest, and is not the head (head ∉ tail).
        claim tailInclusion
            : ∀ (x : A). List.member(A, x, tail) → List.member(A, x, rest)
            by (x : A) (xInTail : List.member(A, x, tail)) ↦ {
                claim xInList1
                    : List.member(A, x, List.prepend(A, head, tail))
                    by List.member.there(A, x, head, tail, xInTail);
                claim List.member(A, x, l2)
                    by inclusion(x, xInList1);
                claim List.member(A, x, List.prepend(A, head, rest))
                    since List.Permutation.member_forward;
                claim ¬(x = head)
                    by (xIsHead : x = head) ↦ {
                        claim headInTail : List.member(A, head, tail)
                            by substituting xIsHead;
                        headNotInTail(headInTail)
                      };
                done since List.member_of_prepend_not_head
              };
        -- Equal lengths after dropping the head from both.
        claim lengthPermuted
            : List.length(A, l2) = List.length(A, List.prepend(A, head, rest))
            since List.Permutation.length_invariant;
        claim 1 + List.length(A, tail) = 1 + List.length(A, rest)
            by calc 1 + List.length(A, tail)
                  = List.length(A, List.prepend(A, head, tail))   by List.length_prepend
                  = List.length(A, l2)                            by lengthEquation
                  = List.length(A, List.prepend(A, head, rest))   by lengthPermuted
                  = 1 + List.length(A, rest)                      by List.length_prepend;
        claim restLengthEquation : List.length(A, tail) = List.length(A, rest)
            since Natural.add_cancel_left;
        -- Recurse on the tails and reassemble.
        claim tailPermutation : List.Permutation(A, tail, rest)
            by List.permutation_of_distinct_inclusion(A, tail, rest,
                   tailDistinct, restDistinct, tailInclusion, restLengthEquation);
        claim List.Permutation(A, List.prepend(A, head, tail),
                  List.prepend(A, head, rest))
            by List.Permutation.skip(A, head, tail, rest, tailPermutation);
        claim List.Permutation(A, List.prepend(A, head, rest), l2)
            since List.Permutation.symmetric;
        done by List.Permutation.transitive(A,
                   List.prepend(A, head, tail),
                   List.prepend(A, head, rest), l2,
                   List.Permutation.skip(A, head, tail, rest, tailPermutation),
                   List.Permutation.symmetric(A, l2,
                       List.prepend(A, head, rest), extracted))
      }

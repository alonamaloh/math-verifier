-- Lists/append.math
--
-- List concatenation, with the two distribution facts any
-- product-over-a-partition argument needs: the fold-product of a
-- concatenation is the product of the two products, and `map`
-- distributes over concatenation. (Used to split the Wilson product
-- over 1..p−1 into its two halves.)

module Lists.append

import Logic.basics
import Equality.basics
import Lists.list
import Lists.map

-- Concatenation: the elements of `first` followed by those of `second`.
definition List.append (A : Type(0)) : List(A) → List(A) → List(A)
  | List.empty               => (second : List(A)) ↦ second
  | List.prepend(head, tail) => (second : List(A)) ↦
      List.prepend(A, head, List.append(A, tail, second))

-- The product of a concatenation is the product of the products.
theorem List.product_append (A : Type(0)) (multiply : A → A → A) (one : A)
        (associativity
            : ∀ (a b c : A). multiply(multiply(a, b), c) = multiply(a, multiply(b, c)))
        (identityLeft : ∀ (a : A). multiply(one, a) = a)
        (first second : List(A))
        : List.product(A, multiply, one, List.append(A, first, second))
          = multiply(List.product(A, multiply, one, first),
                     List.product(A, multiply, one, second)) :=
  by induction on first with IH {
    case List.empty:
        -- append(empty, second) is second, whose product gains a harmless
        -- leading `one` — the product of the empty prefix.
        calc List.product(A, multiply, one, List.append(A, List.empty(A), second))
           = List.product(A, multiply, one, second)
           = multiply(one, List.product(A, multiply, one, second))
                 by identityLeft(List.product(A, multiply, one, second))
    case List.prepend(head, tail):
        -- Peel the head, apply the induction hypothesis to the tail, and
        -- reassociate the head back into the first factor.
        calc List.product(A, multiply, one,
                 List.append(A, List.prepend(A, head, tail), second))
           = multiply(head,
                 List.product(A, multiply, one, List.append(A, tail, second)))
           = multiply(head,
                 multiply(List.product(A, multiply, one, tail),
                          List.product(A, multiply, one, second)))
                 by substituting IH
           = multiply(multiply(head, List.product(A, multiply, one, tail)),
                      List.product(A, multiply, one, second))
                 by associativity(head, List.product(A, multiply, one, tail),
                        List.product(A, multiply, one, second))
  }

-- `map` distributes over concatenation.
theorem List.map_append (A B : Type(0)) (f : A → B) (first second : List(A))
        : List.map(A, B, f, List.append(A, first, second))
          = List.append(B, List.map(A, B, f, first), List.map(A, B, f, second)) :=
  by induction on first with IH {
    case List.empty:
        -- Both sides reduce to map(f, second).
        calc List.map(A, B, f, List.append(A, List.empty(A), second))
           = List.append(B, List.map(A, B, f, List.empty(A)),
                 List.map(A, B, f, second))
    case List.prepend(head, tail):
        calc List.map(A, B, f, List.append(A, List.prepend(A, head, tail), second))
           = List.prepend(B, f(head),
                 List.map(A, B, f, List.append(A, tail, second)))
           = List.prepend(B, f(head),
                 List.append(B, List.map(A, B, f, tail), List.map(A, B, f, second)))
                 by substituting IH
           = List.append(B, List.map(A, B, f, List.prepend(A, head, tail)),
                 List.map(A, B, f, second))
  }

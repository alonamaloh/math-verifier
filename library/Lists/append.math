-- Lists/append.math
--
-- List concatenation, with the two distribution facts any
-- product-over-a-partition argument needs: the fold-product of a
-- concatenation is the product of the two products, and `map`
-- distributes over concatenation. (Used to split the Wilson product
-- over 1..p−1 into its two halves.)

module Lists.append

import Logic.basics
import Equality.basics
import Lists.list
import Lists.map

-- Concatenation: the elements of `first` followed by those of `second`.
definition List.append {A : Type(0)} : List(A) → List(A) → List(A)
  | List.empty               => (second : List(A)) ↦ second
  | List.prepend(head, tail) => (second : List(A)) ↦
      List.prepend(A, head, List.append(tail, second))

-- The product of a concatenation is the product of the products.
theorem List.product_append (A : Type(0)) (multiply : A → A → A) (one : A)
        (associativity
            : ∀ (a b c : A). multiply(multiply(a, b), c) = multiply(a, multiply(b, c)))
        (identityLeft : ∀ (a : A). multiply(one, a) = a)
        (first second : List(A))
        : List.product(multiply, one, List.append(first, second))
          = multiply(List.product(multiply, one, first),
                     List.product(multiply, one, second)) :=
  by induction on first with IH {
    case List.empty:
        -- append(empty, second) is second, whose product gains a harmless
        -- leading `one` — the product of the empty prefix.
        List.product(multiply, one, List.append(List.empty(A), second))
           = List.product(multiply, one, second)
           = multiply(one, List.product(multiply, one, second))
                 by identityLeft(List.product(multiply, one, second))
    case List.prepend(head, tail):
        -- Peel the head, apply the induction hypothesis to the tail, and
        -- reassociate the head back into the first factor.
        List.product(multiply, one,
                 List.append(List.prepend(A, head, tail), second))
           = multiply(head,
                 List.product(multiply, one, List.append(tail, second)))
           = multiply(head,
                 multiply(List.product(multiply, one, tail),
                          List.product(multiply, one, second)))
                 by substituting IH
           = multiply(multiply(head, List.product(multiply, one, tail)),
                      List.product(multiply, one, second))
                 by associativity(head, List.product(multiply, one, tail),
                        List.product(multiply, one, second))
  }

-- `map` distributes over concatenation.
theorem List.map_append (A B : Type(0)) (f : A → B) (first second : List(A))
        : List.map(f, List.append(first, second))
          = List.append(List.map(f, first), List.map(f, second)) :=
  by induction on first with IH {
    case List.empty:
        -- Both sides reduce to map(f, second).
        List.map(f, List.append(List.empty(A), second))
           = List.append(List.map(f, List.empty(A)),
                 List.map(f, second))
    case List.prepend(head, tail):
        List.map(f, List.append(List.prepend(A, head, tail), second))
           = List.prepend(B, f(head),
                 List.map(f, List.append(tail, second)))
           = List.prepend(B, f(head),
                 List.append(List.map(f, tail), List.map(f, second)))
                 by substituting IH
           = List.append(List.map(f, List.prepend(A, head, tail)),
                 List.map(f, second))
  }

-- ----------------------------------------------------------------------
-- Membership transports into a concatenation from either side — the facts a
-- "union over a partition" argument (e.g. enumerating a finite type by cases)
-- consumes.

theorem List.member_append_left (A : Type(0)) (element : A) (first second : List(A))
        (inFirst : element ∈ first)
        : element ∈ List.append(first, second) :=
  by induction on inFirst {
    case List.member.here(rest):
        List.member.here(A, element, List.append(rest, second))
    case List.member.there(head, tail, _, inAppendTail):
        List.member.there(A, element, head, List.append(tail, second), inAppendTail)
  }

theorem List.member_append_right (A : Type(0)) (element : A) (first second : List(A))
        (inSecond : element ∈ second)
        : element ∈ List.append(first, second) :=
  by induction on first with IH {
    case List.empty: inSecond
    case List.prepend(head, tail):
        List.member.there(A, element, head, List.append(tail, second), IH)
  }

-- Inversion: a member of a concatenation belongs to one of the two halves.
-- Induct on `first` (its `prepend` head is the only new candidate at each step);
-- the membership premise stays in the conclusion so it varies with `first`.
theorem List.member_append_invert (A : Type(0)) (element : A) (second : List(A)) (first : List(A))
        : element ∈ List.append(first, second)
          → element ∈ first ∨ element ∈ second :=
  by induction on first with IH {
    case List.empty:
        (inAppend : element ∈ List.append(List.empty(A), second)) ↦ {
          -- append(empty, second) is second, so the member is on the right.
          element ∈ second by inAppend;
          done
        }
    case List.prepend(head, tail):
        (inAppend
            : element ∈ List.append(List.prepend(A, head, tail), second)) ↦ {
          element = head ∨ element ∈ List.append(tail, second)
              by List.member_prepend_invert;
          done by cases {
            case element = head as isHead: {
                element ∈ List.prepend(A, head, tail) by List.member.here;
                done
              }
            case element ∈ List.append(tail, second) as inTailAppend: {
                element ∈ tail ∨ element ∈ second
                    by IH(inTailAppend);
                done by cases {
                  case element ∈ tail as inTail: {
                      element ∈ List.prepend(A, head, tail)
                          by List.member.there(A, element, head, tail, inTail);
                      done
                    }
                  case element ∈ second as inSecond: inSecond
                }
              }
          }
        }
  }

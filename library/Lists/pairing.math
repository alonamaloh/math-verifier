-- Lists/pairing.math
--
-- The inverse-pair collapse step behind Wilson's theorem: in a
-- commutative monoid, a list that rearranges to `prepend(x, prepend(y,
-- rest))` with `x · y = one` has the same fold-product as `rest` — the
-- pair contributes the identity and drops out. Iterating this over the
-- nonzero elements of a field (paired by inversion) collapses their
-- product down to its self-inverse fixed points.

module Lists.pairing

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.order
import Natural.add_order
import Natural.arithmetic
import Algebra.monoid
import Lists.list
import Lists.length
import Lists.permutation
import Lists.distinct

-- A list that permutes to `prepend(x, prepend(y, rest))` with `x · y =
-- one` has the same product as `rest`: the pair `{x, y}` contributes the
-- identity and drops out.
theorem List.Permutation.pair_collapse (A : Type(0))
        (multiply : A → A → A) (one : A)
        (associativity
            : ∀ (a b c : A). multiply(multiply(a, b), c) = multiply(a, multiply(b, c)))
        (commutativity : ∀ (a b : A). multiply(a, b) = multiply(b, a))
        (identityLeft : ∀ (a : A). multiply(one, a) = a)
        (x y : A) (rest list : List(A))
        (permutation
            : List.Permutation(A, list,
                  List.prepend(A, x, List.prepend(A, y, rest))))
        (pairsToOne : multiply(x, y) = one)
        : List.product(A, multiply, one, list)
          = List.product(A, multiply, one, rest) :=
  calc List.product(A, multiply, one, list)
     = List.product(A, multiply, one,
           List.prepend(A, x, List.prepend(A, y, rest)))
     = multiply(x, multiply(y, List.product(A, multiply, one, rest)))
     = multiply(multiply(x, y), List.product(A, multiply, one, rest))
           by Equality.symmetry(
                  associativity(x, y, List.product(A, multiply, one, rest)))
     = multiply(one, List.product(A, multiply, one, rest))
     = List.product(A, multiply, one, rest)
           by identityLeft(List.product(A, multiply, one, rest))

-- ----------------------------------------------------------------------
-- The full orbit collapse. A list in which every member has an inverse
-- *elsewhere* in the list multiplies out to the identity: repeatedly pull
-- a member and its partner to the front and drop the pair. This is the
-- engine of Wilson's theorem, applied there to the nonzero classes of F_p
-- other than ±1 (which are exactly the self-inverse ones).

-- z has an inverse partner elsewhere in the list: some OTHER member w
-- with z · w = one.
definition List.has_distinct_inverse_in (A : Type(0))
        (multiply : A → A → A) (one : A)
        (list : List(A)) (z : A) : Proposition :=
  ∃ (w : A). List.member(A, w, list) ∧ multiply(z, w) = one ∧ ¬(w = z)

-- Dropping an inverse pair from the front preserves the pairing property:
-- if every member of `list` has an inverse elsewhere in `list`, and `list`
-- permutes to head :: partner :: rest with head · partner = one, then every
-- member of `rest` still has its inverse inside `rest`. The partner of a
-- z ∈ rest cannot be `head` (z and partner would share the inverse `head`,
-- forcing z = partner ∉ rest) nor `partner` (z and head would share the
-- inverse `partner`, forcing z = head ∉ rest).
theorem List.paired_inverses_drop_pair (A : Type(0))
        (multiply : A → A → A) (one : A)
        (associativity
            : ∀ (a b c : A). multiply(multiply(a, b), c) = multiply(a, multiply(b, c)))
        (commutativity : ∀ (a b : A). multiply(a, b) = multiply(b, a))
        (identityLeft : ∀ (a : A). multiply(one, a) = a)
        (list : List(A)) (head partner : A) (rest : List(A))
        (listPermutation
            : List.Permutation(A, list,
                  List.prepend(A, head, List.prepend(A, partner, rest))))
        (headPairsToOne : multiply(head, partner) = one)
        (headNotInRest : ¬(List.member(A, head, rest)))
        (partnerNotInRest : ¬(List.member(A, partner, rest)))
        (paired : ∀ (z : A). List.member(A, z, list)
            → List.has_distinct_inverse_in(A, multiply, one, list, z))
        : ∀ (z : A). List.member(A, z, rest)
          → List.has_distinct_inverse_in(A, multiply, one, rest, z) :=
  (z : A) (zMemberRest : List.member(A, z, rest)) ↦ {
    -- z sits in the original list, so it has a partner w there.
    List.member(A, z,
        List.prepend(A, head, List.prepend(A, partner, rest)))
        by List.member.there;
    List.Permutation(A,
        List.prepend(A, head, List.prepend(A, partner, rest)), list)
        by List.Permutation.symmetric;
    List.member(A, z, list)
        by List.Permutation.member_forward as zMemberList;
    obtain ⟨w, wProperties⟩ from paired(z, zMemberList);
    let ⟨wMemberList, wInverseProperties⟩ := wProperties;
    let ⟨zPairsToOne, wNotZ⟩ := wInverseProperties;
    List.member(A, w,
        List.prepend(A, head, List.prepend(A, partner, rest)))
        by List.Permutation.member_forward;
    -- w ≠ head: otherwise z and partner both cancel head, so z = partner —
    -- but partner ∉ rest.
    ¬(w = head)
        by (wEqualsHead : w = head) ↦ {
            multiply(z, head) = one
                by substituting wEqualsHead;
            multiply(partner, head) = one
                by calc multiply(partner, head)
                      = multiply(head, partner)   by commutativity(head, partner)
                      = one;
            z = partner
                by shared_inverse_equal as zEqualsPartner;
            List.member(A, partner, rest)
                by substituting zEqualsPartner as partnerMemberRest;
            partnerNotInRest(partnerMemberRest)
          };
    -- w ≠ partner: otherwise z and head both cancel partner, so z = head —
    -- but head ∉ rest.
    ¬(w = partner)
        by (wEqualsPartner : w = partner) ↦ {
            multiply(z, partner) = one
                by substituting wEqualsPartner;
            z = head
                by shared_inverse_equal as zEqualsHead;
            List.member(A, head, rest)
                by substituting zEqualsHead as headMemberRest;
            headNotInRest(headMemberRest)
          };
    -- So w sits in rest, and is the required partner.
    List.member(A, w, List.prepend(A, partner, rest))
        by List.member_of_prepend_not_head;
    List.member(A, w, rest)
        by List.member_of_prepend_not_head as wMemberRest;
    witness w with
        And.introduction(wMemberRest, And.introduction(zPairsToOne, wNotZ))
  }

-- The collapse, by induction on an explicit length bound (each step
-- removes a pair, so plain structural induction does not fit).
theorem List.product_one_of_paired_inverses_bounded (A : Type(0))
        (multiply : A → A → A) (one : A)
        (associativity
            : ∀ (a b c : A). multiply(multiply(a, b), c) = multiply(a, multiply(b, c)))
        (commutativity : ∀ (a b : A). multiply(a, b) = multiply(b, a))
        (identityLeft : ∀ (a : A). multiply(one, a) = a)
        (bound : Natural)
        : ∀ (list : List(A)).
          List.length(A, list) ≤ bound
          → List.Distinct(A, list)
          → (∀ (z : A). List.member(A, z, list)
                 → List.has_distinct_inverse_in(A, multiply, one, list, z))
          → List.product(A, multiply, one, list) = one :=
  by_induction on bound with IH {
    case base: {
        take list : List(A);
        cases list {
          | List.empty => {
              suppose List.length(A, List.empty(A)) ≤ 0 as _;
              suppose List.Distinct(A, List.empty(A)) as _;
              suppose (z : A) → List.member(A, z, List.empty(A))
                  → List.has_distinct_inverse_in(A, multiply, one,
                        List.empty(A), z) as _;
              calc List.product(A, multiply, one, List.empty(A)) = one
            }
          | List.prepend(head, tail) => {
              -- A nonempty list has length ≥ 1, never ≤ 0.
              suppose List.length(A, List.prepend(A, head, tail)) ≤ 0 as lengthBound;
              suppose List.Distinct(A, List.prepend(A, head, tail)) as _;
              suppose (z : A) → List.member(A, z, List.prepend(A, head, tail))
                  → List.has_distinct_inverse_in(A, multiply, one,
                        List.prepend(A, head, tail), z) as _;
              (1 : Natural)
                 ≤ 1 + List.length(A, tail)                       by Natural.less_or_equal_add_right
                 = List.length(A, List.prepend(A, head, tail))
                 ≤ 0                                              by lengthBound;
              False; done
            }
        }
      }
    case step(boundPredecessor): {
        take list : List(A);
        cases list {
          | List.empty => {
              suppose List.length(A, List.empty(A)) ≤ 1 + boundPredecessor as _;
              suppose List.Distinct(A, List.empty(A)) as _;
              suppose (z : A) → List.member(A, z, List.empty(A))
                  → List.has_distinct_inverse_in(A, multiply, one,
                        List.empty(A), z) as _;
              calc List.product(A, multiply, one, List.empty(A)) = one
            }
          | List.prepend(head, tail) => {
              suppose List.length(A, List.prepend(A, head, tail))
                  ≤ 1 + boundPredecessor as lengthBound;
              suppose List.Distinct(A, List.prepend(A, head, tail)) as distinct;
              suppose (z : A) → List.member(A, z, List.prepend(A, head, tail))
                  → List.has_distinct_inverse_in(A, multiply, one,
                        List.prepend(A, head, tail), z) as paired;

              -- The head has a partner elsewhere in the list — in the tail.
              List.member(A, head, List.prepend(A, head, tail)) as headMember;
              obtain ⟨partner, partnerProperties⟩ from paired(head, headMember);
              let ⟨partnerMember, partnerInverseProperties⟩ := partnerProperties;
              let ⟨headPairsToOne, partnerNotHead⟩ := partnerInverseProperties;
              List.member(A, partner, tail)
                  by List.member_of_prepend_not_head as partnerInTail;

              -- Rotate the partner to the front of the tail, so the whole
              -- list permutes to head :: partner :: rest.
              obtain ⟨rest, tailPermutation⟩
                  from List.Permutation.extract(A, partner, tail, partnerInTail);
              List.Permutation(A, List.prepend(A, head, tail),
                  List.prepend(A, head, List.prepend(A, partner, rest)));

              -- The pair {head, partner} multiplies to one and drops out.
              List.product(A, multiply, one, List.prepend(A, head, tail))
                    = List.product(A, multiply, one, rest)
                  by List.Permutation.pair_collapse as productCollapse;

              -- What remains is still distinct…
              List.Distinct(A,
                  List.prepend(A, head, List.prepend(A, partner, rest)))
                  by List.Permutation.distinct_invariant;
              ¬(List.member(A, head, List.prepend(A, partner, rest)))
                  by List.Distinct.head_not_member as headNotInPartnerRest;
              List.Distinct(A, List.prepend(A, partner, rest))
                  by List.Distinct.tail_distinct;
              ¬(List.member(A, partner, rest))
                  by List.Distinct.head_not_member;
              List.Distinct(A, rest)
                  by List.Distinct.tail_distinct as restDistinct;
              ¬(List.member(A, head, rest))
                  by (memberHeadInRest : List.member(A, head, rest)) ↦
                      headNotInPartnerRest(
                          List.member.there(A, head, partner, rest,
                              memberHeadInRest));

              -- …and shorter: |list| = 2 + |rest|, so |rest| fits the
              -- smaller bound.
              List.length(A, List.prepend(A, head, tail))
                    = List.length(A,
                          List.prepend(A, head, List.prepend(A, partner, rest)));
              1 + (1 + List.length(A, rest))
                 = 1 + List.length(A, List.prepend(A, partner, rest))
                 = List.length(A, List.prepend(A, head, List.prepend(A, partner, rest)))
                 = List.length(A, List.prepend(A, head, tail))
                 ≤ 1 + boundPredecessor   by lengthBound;
              1 + List.length(A, rest) ≤ boundPredecessor as onePlusRestLe;
              List.length(A, rest)
                 ≤ 1 + List.length(A, rest)   by Natural.less_or_equal_add_left
                 ≤ boundPredecessor           by onePlusRestLe
                as restLengthBound;

              -- …and still pairs off: a member of rest keeps its partner,
              -- which can be neither head nor partner (inverses are unique,
              -- and those two pair with each other).
              ∀ (z : A). List.member(A, z, rest)
                    → List.has_distinct_inverse_in(A, multiply, one, rest, z)
                  by List.paired_inverses_drop_pair as restPaired;

              -- Conclude by the induction hypothesis on the remainder.
              List.product(A, multiply, one, List.prepend(A, head, tail))
                 = List.product(A, multiply, one, rest)   by productCollapse
                 = one
                       by IH(rest, restLengthBound, restDistinct, restPaired)
            }
        }
      }
  }

-- The clean entry point: a distinct list in which every member has an
-- inverse elsewhere in the list multiplies out to the identity.
theorem List.product_one_of_paired_inverses (A : Type(0))
        (multiply : A → A → A) (one : A)
        (associativity
            : ∀ (a b c : A). multiply(multiply(a, b), c) = multiply(a, multiply(b, c)))
        (commutativity : ∀ (a b : A). multiply(a, b) = multiply(b, a))
        (identityLeft : ∀ (a : A). multiply(one, a) = a)
        (list : List(A))
        (distinct : List.Distinct(A, list))
        (paired : ∀ (z : A). List.member(A, z, list)
            → List.has_distinct_inverse_in(A, multiply, one, list, z))
        : List.product(A, multiply, one, list) = one := {
  List.length(A, list) ≤ List.length(A, list);
  done
}

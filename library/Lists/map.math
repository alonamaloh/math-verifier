-- Lists/map.math
--
-- `List.map(f, l)` applies `f` to every element. A fundamental, reusable
-- list operation (used, among other things, to carry the integer range
-- 1..p−1 into the residues of IntegerMod(p) for Wilson's theorem).

module Lists.map

import Natural.basics
import Equality.basics
import Logic.basics
import Lists.list
import Lists.length

definition List.map (A B : Type(0)) (f : A → B) : List(A) → List(B)
  | List.empty               => List.empty(B)
  | List.prepend(head, tail) =>
      List.prepend(B, f(head), List.map(A, B, f, tail))

-- `map` preserves length.
theorem List.map_length (A B : Type(0)) (f : A → B)
        : (list : List(A))
          → List.length(B, List.map(A, B, f, list)) = List.length(A, list)
  | List.empty => reflexivity(Natural, 0)
  | List.prepend(head, tail) =>
      calc List.length(B, List.map(A, B, f, List.prepend(A, head, tail)))
         = successor(List.length(B, List.map(A, B, f, tail)))
         = successor(List.length(A, tail))
         = List.length(A, List.prepend(A, head, tail))

-- `map` carries membership forward: x ∈ l ⟹ f(x) ∈ map(f, l). (Pattern-match
-- on the member proof at definition level — `cases` on it is blocked by the
-- index-must-be-local rule, but a top-level match refines `list` fine.)
theorem List.map_member (A B : Type(0)) (f : A → B) (element : A) (list : List(A))
        : List.member(A, element, list)
          → List.member(B, f(element), List.map(A, B, f, list))
  | List.member.here(rest) =>
      List.member.here(B, f(element), List.map(A, B, f, rest))
  | List.member.there(head, rest, innerMember) =>
      List.member.there(B, f(element), f(head), List.map(A, B, f, rest),
          List.map_member(A, B, f, element, rest, innerMember))

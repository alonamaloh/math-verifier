-- Lists/map.math
--
-- `List.map(f, l)` applies `f` to every element. A fundamental, reusable
-- list operation (used, among other things, to carry the integer range
-- 1..p−1 into the residues of IntegerMod(p) for Wilson's theorem).

module Lists.map

import Natural.basics
import Equality.basics
import Logic.basics
import Lists.list
import Lists.length

definition List.map {A B : Type(0)} (f : A → B) : List(A) → List(B)
  | List.empty               => List.empty(B)
  | List.prepend(head, tail) =>
      List.prepend(B, f(head), List.map(f, tail))

-- `map` preserves length. Recursion on the list: the empty image has
-- length 0 on both sides; a prepend adds one to each (the tail equality
-- is backward-chained from this lemma on the by-less middle step).
theorem List.map_length (A B : Type(0)) (f : A → B) (list : List(A))
        : length(List.map(f, list)) = length(list) :=
  by induction on list with IH {
    case List.empty:
        length(List.map(f, List.empty(A)))
           = 0
           = length(List.empty(A))
    case List.prepend(head, tail):
        length(List.map(f, List.prepend(A, head, tail)))
           = 1 + length(List.map(f, tail))
           = 1 + length(tail)   by IH
           = length(List.prepend(A, head, tail))
  }

-- `map` carries membership forward: x ∈ l ⟹ f(x) ∈ map(f, l). Induct on the
-- membership proof; the `there` case recurses into the tail via its IH.
theorem List.map_member (A B : Type(0)) (f : A → B) (element : A) (list : List(A))
        (memberProof : element ∈ list)
        : f(element) ∈ List.map(f, list) :=
  by induction on memberProof with IH {
    case List.member.here(rest):
        List.member.here(B, f(element), List.map(f, rest))
    case List.member.there(head, rest, innerMember):
        List.member.there(B, f(element), f(head), List.map(f, rest), IH)
  }

-- Map fusion: mapping `g` then `f` is mapping their composite.
theorem List.map_map (A B C : Type(0)) (g : A → B) (f : B → C) (l : List(A))
        : List.map(f, List.map(g, l)) = List.map((x : A) ↦ f(g(x)), l) :=
  by induction on l with IH {
    case List.empty: reflexivity(List.empty(C))
    case List.prepend(head, tail):
        List.map(f, List.map(g, List.prepend(A, head, tail)))
           = List.prepend(C, f(g(head)), List.map(f, List.map(g, tail)))
           = List.prepend(C, f(g(head)), List.map((x : A) ↦ f(g(x)), tail)) by substituting IH
           = List.map((x : A) ↦ f(g(x)), List.prepend(A, head, tail))
  }

-- Inversion of map_member: a member of `map(f, l)` comes from a member of `l`.
theorem List.map_member_invert (A B : Type(0)) (f : A → B) (b : B) (list : List(A))
        : b ∈ List.map(f, list)
          → ∃ (a : A). a ∈ list ∧ (f(a) = b) :=
  by induction on list with IH {
    case List.empty:
        (mem : b ∈ List.map(f, List.empty(A))) ↦
            absurd(List.no_member_empty(B, b, mem))
    case List.prepend(head, tail):
        (mem : b ∈ List.map(f, List.prepend(A, head, tail))) ↦ {
            b = f(head) ∨ b ∈ List.map(f, tail)
                by List.member_prepend_invert;
            done by cases {
              case b = f(head) as bEqual:
                  ⟨head, And.introduction(
                      List.member.here(A, head, tail),
                      Equality.symmetry(bEqual))⟩
              case b ∈ List.map(f, tail) as memberTail: {
                  choose a such that a ∈ tail ∧ (f(a) = b)
                      from IH(memberTail);
                  a ∈ tail as aMember;
                  f(a) = b as faEqualB;
                  ⟨a, And.introduction(
                      List.member.there(A, a, head, tail, aMember),
                      faEqualB)⟩
                }
            }
          }
  }

-- If `head ∉ tail` and `f` is injective at `head` relative to the members
-- of `tail`, then `f(head) ∉ map(f, tail)`. (The local-injectivity form a
-- map like k ↦ [k] mod p — injective on 1..p−1 but not globally — needs.)
theorem List.not_member_map_of_not_member_on (A B : Type(0)) (f : A → B)
        (head : A) (tail : List(A))
        (injectiveAtHead
            : ∀ (x : A). x ∈ tail → f(x) = f(head) → x = head)
        (notMember : ¬(head ∈ tail))
        : ¬(f(head) ∈ List.map(f, tail)) :=
  (memberImage : f(head) ∈ List.map(f, tail)) ↦ {
      choose a such that a ∈ tail ∧ (f(a) = f(head))
          from List.map_member_invert(A, B, f, f(head), tail, memberImage);
      a = head as aEqualHead;
      head ∈ tail by substituting aEqualHead as headInTail;
      notMember(headInTail)
    }

-- If `head ∉ tail` and `f` is injective, then `f(head) ∉ map(f, tail)`.
theorem List.not_member_map_of_not_member (A B : Type(0)) (f : A → B)
        (injective : ∀ (x y : A). f(x) = f(y) → x = y)
        (head : A) (tail : List(A))
        (notMember : ¬(head ∈ tail))
        : ¬(f(head) ∈ List.map(f, tail)) :=
  (mem : f(head) ∈ List.map(f, tail)) ↦ {
      choose a such that a ∈ tail ∧ (f(a) = f(head))
          from List.map_member_invert(A, B, f, f(head), tail, mem);
      a = head as aEqualHead;
      head ∈ tail by substituting aEqualHead as headInTail;
      notMember(headInTail)
    }

-- Lists/map.math
--
-- `List.map(f, l)` applies `f` to every element. A fundamental, reusable
-- list operation (used, among other things, to carry the integer range
-- 1..p−1 into the residues of IntegerMod(p) for Wilson's theorem).

module Lists.map

import Natural.basics
import Equality.basics
import Logic.basics
import Lists.list
import Lists.length

definition List.map (A B : Type(0)) (f : A → B) : List(A) → List(B)
  | List.empty               => List.empty(B)
  | List.prepend(head, tail) =>
      List.prepend(B, f(head), List.map(A, B, f, tail))

-- `map` preserves length. Recursion on the list: the empty image has
-- length 0 on both sides; a prepend adds one to each (the tail equality
-- is backward-chained from this lemma on the by-less middle step).
theorem List.map_length (A B : Type(0)) (f : A → B)
        : ∀ (list : List(A)).
          List.length(B, List.map(A, B, f, list)) = List.length(A, list)
  | List.empty =>
      calc List.length(B, List.map(A, B, f, List.empty(A)))
         = 0                              by List.length_empty
         = List.length(A, List.empty(A))  by List.length_empty
  | List.prepend(head, tail) =>
      calc List.length(B, List.map(A, B, f, List.prepend(A, head, tail)))
         = 1 + List.length(B, List.map(A, B, f, tail))   by List.length_prepend
         = 1 + List.length(A, tail)
         = List.length(A, List.prepend(A, head, tail))   by List.length_prepend

-- `map` carries membership forward: x ∈ l ⟹ f(x) ∈ map(f, l). (Pattern-match
-- on the member proof at definition level — `cases` on it is blocked by the
-- index-must-be-local rule, but a top-level match refines `list` fine.)
theorem List.map_member (A B : Type(0)) (f : A → B) (element : A) (list : List(A))
        : List.member(A, element, list)
          → List.member(B, f(element), List.map(A, B, f, list))
  | List.member.here(rest) =>
      List.member.here(B, f(element), List.map(A, B, f, rest))
  | List.member.there(head, rest, innerMember) =>
      List.member.there(B, f(element), f(head), List.map(A, B, f, rest),
          List.map_member(A, B, f, element, rest, innerMember))

-- Inversion of map_member: a member of `map(f, l)` comes from a member of `l`.
theorem List.map_member_invert (A B : Type(0)) (f : A → B) (b : B)
        : ∀ (list : List(A)).
          List.member(B, b, List.map(A, B, f, list))
          → ∃ (a : A). List.member(A, a, list) ∧ (f(a) = b)
  | List.empty =>
      (mem : List.member(B, b, List.map(A, B, f, List.empty(A)))) ↦
          absurd(List.no_member_empty(B, b, mem))
  | List.prepend(head, tail) =>
      (mem : List.member(B, b, List.map(A, B, f, List.prepend(A, head, tail)))) ↦ {
          claim invert : b = f(head) ∨ List.member(B, b, List.map(A, B, f, tail))
              by List.member_prepend_invert;
          cases invert {
            | Or.introduceLeft(bEqual) =>
                ⟨head, And.introduction(
                    List.member.here(A, head, tail),
                    Equality.symmetry(bEqual))⟩
            | Or.introduceRight(memberTail) => {
                obtain ⟨a, aProperties⟩
                    from List.map_member_invert(A, B, f, b, tail, memberTail);
                let ⟨aMember, faEqualB⟩ := aProperties;
                ⟨a, And.introduction(
                    List.member.there(A, a, head, tail, aMember),
                    faEqualB)⟩
              }
          }
        }

-- If `head ∉ tail` and `f` is injective at `head` relative to the members
-- of `tail`, then `f(head) ∉ map(f, tail)`. (The local-injectivity form a
-- map like k ↦ [k] mod p — injective on 1..p−1 but not globally — needs.)
theorem List.not_member_map_of_not_member_on (A B : Type(0)) (f : A → B)
        (head : A) (tail : List(A))
        (injectiveAtHead
            : ∀ (x : A). List.member(A, x, tail) → f(x) = f(head) → x = head)
        (notMember : ¬(List.member(A, head, tail)))
        : ¬(List.member(B, f(head), List.map(A, B, f, tail))) :=
  (memberImage : List.member(B, f(head), List.map(A, B, f, tail))) ↦ {
      obtain ⟨a, aProperties⟩
          from List.map_member_invert(A, B, f, f(head), tail, memberImage);
      let ⟨aMember, faEqual⟩ := aProperties;
      claim aEqualHead : a = head by injectiveAtHead(a, aMember, faEqual);
      claim headInTail : List.member(A, head, tail) by substituting aEqualHead;
      notMember(headInTail)
    }

-- If `head ∉ tail` and `f` is injective, then `f(head) ∉ map(f, tail)`.
theorem List.not_member_map_of_not_member (A B : Type(0)) (f : A → B)
        (injective : ∀ (x y : A). f(x) = f(y) → x = y)
        (head : A) (tail : List(A))
        (notMember : ¬(List.member(A, head, tail)))
        : ¬(List.member(B, f(head), List.map(A, B, f, tail))) :=
  (mem : List.member(B, f(head), List.map(A, B, f, tail))) ↦ {
      obtain ⟨a, aProperties⟩
          from List.map_member_invert(A, B, f, f(head), tail, mem);
      let ⟨aMember, faEqual⟩ := aProperties;
      claim aEqualHead : a = head by injective(a, head, faEqual);
      claim headInTail : List.member(A, head, tail) by substituting aEqualHead;
      notMember(headInTail)
    }

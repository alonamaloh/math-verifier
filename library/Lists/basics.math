-- Lists/basics.math
--
-- Lists of natural numbers, plus their core operations: membership
-- and product. Specialised to Natural because Euclid only ever talks
-- about lists of natural numbers; universe-polymorphic lists can be
-- a future addition if a use case arises.
--
-- This module deliberately stays at the level of plain data and
-- predicates. Lemmas that need primality, ordering arithmetic, or
-- divisibility live in higher-up modules.

module Lists.basics

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.divisibility

-- Linked list of natural numbers.
inductive NaturalList : Type(0) where
  | NaturalList.empty : NaturalList
  | NaturalList.prepend : Natural → NaturalList → NaturalList

-- Membership predicate: n is in the list. Defined inductively with
-- 2 cases: n is the head, or n is in the tail.
inductive NaturalList.member (n : Natural) : NaturalList → Proposition where
  | NaturalList.member.here
      : (rest : NaturalList)
        → NaturalList.member(n, NaturalList.prepend(n, rest))
  | NaturalList.member.there
      : (head : Natural)
        → (rest : NaturalList)
        → NaturalList.member(n, rest)
        → NaturalList.member(n, NaturalList.prepend(head, rest))

-- Product of a list of naturals. Empty list has product 1; prepend takes
-- the head times the tail's product.
definition NaturalList.productOf : NaturalList → Natural
  | NaturalList.empty => 1
  | NaturalList.prepend(head, tail) => head * NaturalList.productOf(tail)

-- Any list member divides the product of the list. By induction on
-- the membership proof: the `here` case is immediate (n divides its
-- own multiple); the `there` case multiplies through with the head
-- via divides_multiple_left.
theorem NaturalList.member_divides_product
        (n : Natural) (list : NaturalList)
        (memberProof : NaturalList.member(n, list))
        : n ∣ NaturalList.productOf(list) :=
  by induction on memberProof with IH {
    case NaturalList.member.here(rest): {
        n ∣ n * NaturalList.productOf(rest);
        done
      }
    case NaturalList.member.there(head, rest, sub_h): {
        n ∣ NaturalList.productOf(rest) by IH;
        n ∣ head * NaturalList.productOf(rest) by Natural.divides_multiple_left;
        done
      }
  }

-- Discriminator: True on `prepend(_, _)`, False on `empty`. Used to
-- refute membership claims against the empty list — a `member` proof
-- always lifts to `is_nonempty`, but `is_nonempty(empty) = False`.
definition NaturalList.is_nonempty : NaturalList → Proposition
  | NaturalList.empty            => False
  | NaturalList.prepend(_, _)    => True

-- Any membership proof says its list is nonempty. The two cases each
-- have a `prepend(...)` index, where `is_nonempty` is True.
theorem NaturalList.member_implies_nonempty
        (n : Natural) (list : NaturalList)
        (memberProof : NaturalList.member(n, list))
        : NaturalList.is_nonempty(list) :=
  by induction on memberProof {
    case NaturalList.member.here(_):        True.trivial
    case NaturalList.member.there(_, _, _): True.trivial
  }

-- No element belongs to the empty list — the standard absurdity proof
-- for membership in a vacuous list.
theorem NaturalList.no_member_in_empty (n : Natural)
        : ¬NaturalList.member(n, NaturalList.empty) := {
  suppose NaturalList.member(n, NaturalList.empty) as membership;
  done by NaturalList.member_implies_nonempty
}

-- Head extractor: returns `default` on empty, else the head. Reading
-- the head back off both sides of a `prepend` equation is what gives
-- prepend-head injectivity below.
definition NaturalList.head_or (default : Natural) : NaturalList → Natural
  | NaturalList.empty            => default
  | NaturalList.prepend(head, _) => head

-- Tail extractor: returns `default` on empty, else the tail.
definition NaturalList.tail_or (default : NaturalList) : NaturalList → NaturalList
  | NaturalList.empty            => default
  | NaturalList.prepend(_, tail) => tail

-- `prepend` is injective in its head.
automatic theorem NaturalList.prepend_injective_head
        (head1 head2 : Natural) (tail1 tail2 : NaturalList)
        (equality : NaturalList.prepend(head1, tail1)
                  = NaturalList.prepend(head2, tail2))
        : head1 = head2 :=
  head1
     = NaturalList.head_or(head1, NaturalList.prepend(head1, tail1))
     = NaturalList.head_or(head1, NaturalList.prepend(head2, tail2))
     = head2

-- `prepend` is injective in its tail.
automatic theorem NaturalList.prepend_injective_tail
        (head1 head2 : Natural) (tail1 tail2 : NaturalList)
        (equality : NaturalList.prepend(head1, tail1)
                  = NaturalList.prepend(head2, tail2))
        : tail1 = tail2 :=
  tail1
     = NaturalList.tail_or(tail1, NaturalList.prepend(head1, tail1))
     = NaturalList.tail_or(tail1, NaturalList.prepend(head2, tail2))
     = tail2

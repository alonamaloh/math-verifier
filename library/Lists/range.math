-- Lists/range.math
--
-- `List.range_down(n) = [n, n−1, …, 1]`, the list of the positive integers
-- 1..n. (Descending because the `prepend` recursion is clean; order is
-- immaterial for the commutative-product / set-membership uses this is built
-- for. A general-purpose range, e.g. for Wilson's product over 1..p−1.)

module Lists.range

import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Natural.decide
import Natural.strong_recursion
import Logic.basics
import Logic.sum
import Equality.basics
import Lists.list
import Lists.length
import Lists.append

definition List.range_down : ℕ → List(ℕ)
  | 0 => List.empty(ℕ)
  | 1 + predecessor =>
      List.prepend(ℕ, 1 + predecessor, List.range_down(predecessor))

-- The recursion in `1 + n` form (`Natural.add` is opaque, so `1 + n` is
-- not definitionally the constructor; bridge via `one_add`).
theorem List.range_down_one_plus (n : ℕ)
        : List.range_down(1 + n)
          = List.prepend(ℕ, 1 + n, List.range_down(n)) :=
  done by substituting Natural.one_add

-- The ascending counterpart `range_up(n) = [0, 1, …, n−1]`, grown at the
-- tail so the fold-product reads the largest index last. That matches the
-- left-fold recursion of `Algebra.indexedAggregate`, letting the
-- list-product bridge there reassociate without commutativity.
definition List.range_up : ℕ → List(ℕ)
  | 0 => List.empty(ℕ)
  | 1 + predecessor =>
      List.append(List.range_up(predecessor),
          List.prepend(ℕ, predecessor, List.empty(ℕ)))

-- The recursion in `1 + n` form (`Natural.add` is opaque, so `1 + n` is
-- not definitionally the constructor; bridge via `one_add`).
theorem List.range_up_add_one (n : ℕ)
        : List.range_up(1 + n)
          = List.append(List.range_up(n),
                List.prepend(ℕ, n, List.empty(ℕ))) :=
  done by substituting Natural.one_add

-- `range_down(n)` has exactly n elements.
theorem List.range_down_length (n : ℕ)
        : length(List.range_down(n)) = n :=
  by induction on n with IH {
    case base:
        length(List.range_down(0))
           = 0
    case step(predecessor):
        length(List.range_down(1 + predecessor))
           = 1 + length(List.range_down(predecessor))
                 by substituting List.range_down_one_plus
           = 1 + predecessor          by substituting IH
  }

-- Completeness: every positive integer ≤ n appears in range_down(n).
-- (Induct on n with j generalised so the bound varies; the step case
-- splits j = 1 + predecessor (head) vs j ≤ predecessor (tail, by IH).)
theorem List.range_down_complete (n : ℕ)
        : ∀ (j : ℕ). 1 ≤ j → j ≤ n
          → j ∈ List.range_down(n) :=
  by induction on n with IH {
    case base: {
        take j : ℕ;
        suppose 1 ≤ j as lower;
        suppose j ≤ 0 as upper;
        1 ≤ 0;
        False;
        done
      }
    case step(predecessor): {
        take j : ℕ;
        suppose 1 ≤ j as lower;
        suppose j ≤ 1 + predecessor as upper;
        j = 1 + predecessor ∨ ¬(j = 1 + predecessor);
        done by cases {
          case j = 1 + predecessor as jEqual: {
              1 + predecessor ∈ List.prepend(ℕ, 1 + predecessor, List.range_down(predecessor))
                  by List.member.here;
              1 + predecessor ∈ List.range_down(1 + predecessor)
                  by substituting List.range_down_one_plus;
              j ∈ List.range_down(1 + predecessor)
                  by substituting jEqual;
              done
            }
          case ¬(j = 1 + predecessor) as jNotEqual: {
              j ≤ predecessor
                  by Natural.le_of_le_one_plus_of_ne;
              j ∈ List.range_down(predecessor) by IH;
              j ∈ List.prepend(ℕ, 1 + predecessor, List.range_down(predecessor))
                  by List.member.there;
              done by substituting List.range_down_one_plus
            }
        }
      }
  }

-- Every member of range_down(n) is positive (the range stops at 1).
theorem List.range_down_member_positive (n : ℕ)
        : ∀ (j : ℕ). j ∈ List.range_down(n) → 1 ≤ j :=
  by induction on n with IH {
    case base: {
        take j : ℕ;
        suppose j ∈ List.range_down(0) as mem;
        absurd(List.no_member_empty(ℕ, j, mem))
      }
    case step(predecessor): {
        take j : ℕ;
        suppose j ∈ List.range_down(1 + predecessor) as mem;
        j ∈ List.prepend(ℕ, 1 + predecessor, List.range_down(predecessor))
            by substituting List.range_down_one_plus;
        j = 1 + predecessor
              ∨ j ∈ List.range_down(predecessor)
            by List.member_prepend_invert;
        done by cases {
          case j = 1 + predecessor as jEqual: {
              1 ≤ 1 + predecessor;
              1 ≤ j by substituting jEqual;
              done
            }
          case j ∈ List.range_down(predecessor) as memberTail: IH(j, memberTail)
        }
      }
  }

-- Conversely, every member of range_down(n) is ≤ n. (Needed to show the
-- head 1 + k doesn't recur in range_down(k), i.e. distinctness.)
theorem List.range_down_member_le (n : ℕ)
        : ∀ (j : ℕ). j ∈ List.range_down(n) → j ≤ n :=
  by induction on n with IH {
    case base: {
        take j : ℕ;
        suppose j ∈ List.range_down(0) as mem;
        absurd(List.no_member_empty(ℕ, j, mem))
      }
    case step(predecessor): {
        take j : ℕ;
        suppose j ∈ List.range_down(1 + predecessor) as mem;
        j ∈ List.prepend(ℕ, 1 + predecessor, List.range_down(predecessor))
            by substituting List.range_down_one_plus;
        j = 1 + predecessor
              ∨ j ∈ List.range_down(predecessor)
            by List.member_prepend_invert;
        done by cases {
          case j = 1 + predecessor as jEqual: {
              j ≤ 1 + predecessor by substituting jEqual;
              done
            }
          case j ∈ List.range_down(predecessor) as memberTail:
              j
                 ≤ predecessor         by IH(j, memberTail)
                 ≤ 1 + predecessor
        }
      }
  }

-- Completeness for the ascending range: every value below n appears in
-- range_up(n). Induct on n; the step splits j < p (tail, by IH) vs j = p
-- (the appended top).
theorem List.range_up_complete (n : ℕ)
        : ∀ (j : ℕ). j < n → j ∈ List.range_up(n) :=
  by induction on n with IH {
    case base: {
        take j : ℕ;
        suppose j < 0 as below;
        False by Natural.not_less_than_zero(j, below);
        done
      }
    case step(predecessor): {
        take j : ℕ;
        suppose j < 1 + predecessor as below;
        j ≤ predecessor by Natural.le_of_lt_one_plus;
        j < predecessor ∨ j = predecessor;
        done by cases {
          case j < predecessor as strictlyBelow: {
              j ∈ List.range_up(predecessor) by IH(j, strictlyBelow);
              j ∈ List.append(List.range_up(predecessor), List.prepend(ℕ, predecessor, List.empty(ℕ)))
                  by List.member_append_left;
              done by substituting List.range_up_add_one
            }
          case j = predecessor as atTop: {
              predecessor ∈ List.prepend(ℕ, predecessor, List.empty(ℕ))
                  by List.member.here;
              j ∈ List.prepend(ℕ, predecessor, List.empty(ℕ))
                  by substituting atTop;
              j ∈ List.append(List.range_up(predecessor), List.prepend(ℕ, predecessor, List.empty(ℕ)))
                  by List.member_append_right;
              done by substituting List.range_up_add_one
            }
        }
      }
  }

-- Conversely, every member of range_up(n) is below n.
theorem List.range_up_member_lt (n : ℕ)
        : ∀ (j : ℕ). j ∈ List.range_up(n) → j < n :=
  by induction on n with IH {
    case base: {
        take j : ℕ;
        suppose j ∈ List.range_up(0) as mem;
        absurd(List.no_member_empty(ℕ, j, mem))
      }
    case step(predecessor): {
        take j : ℕ;
        suppose j ∈ List.range_up(1 + predecessor) as mem;
        j ∈ List.append(List.range_up(predecessor), List.prepend(ℕ, predecessor, List.empty(ℕ)))
            by substituting List.range_up_add_one;
        j ∈ List.range_up(predecessor)
              ∨ j ∈ List.prepend(ℕ, predecessor, List.empty(ℕ))
            by List.member_append_invert(ℕ, j,
                   List.prepend(ℕ, predecessor, List.empty(ℕ)),
                   List.range_up(predecessor));
        done by cases {
          case j ∈ List.range_up(predecessor) as inRange:
              j < predecessor by IH(j, inRange)
                ≤ 1 + predecessor
          case j ∈ List.prepend(ℕ, predecessor, List.empty(ℕ)) as inSingleton: {
              j = predecessor ∨ j ∈ List.empty(ℕ)
                  by List.member_prepend_invert;
              done by cases {
                case j = predecessor as atTop: {
                    j < 1 + predecessor by substituting atTop;
                    done
                  }
                case j ∈ List.empty(ℕ) as inEmpty:
                    absurd(List.no_member_empty(ℕ, j, inEmpty))
              }
            }
        }
      }
  }

-- ----------------------------------------------------------------------
-- The slice of the range above a base point:
-- `range_down_offset(base, count) = [base+count, …, base+1]`, the `count`
-- integers immediately above `base`, descending. Concatenating it with
-- `range_down(base)` recovers the full range — the splitting fact behind
-- "break the product over 1..p−1 into its two halves".

definition List.range_down_offset (base : ℕ) : ℕ → List(ℕ)
  | 0 => List.empty(ℕ)
  | 1 + predecessorCount =>
      List.prepend(ℕ, base + (1 + predecessorCount),
          List.range_down_offset(base, predecessorCount))

-- The recursion in `1 + n` form, as for `range_down`.
theorem List.range_down_offset_one_plus (base count : ℕ)
        : List.range_down_offset(base, 1 + count)
          = List.prepend(ℕ, base + (1 + count),
                List.range_down_offset(base, count)) :=
  done by substituting Natural.one_add

-- [base+count .. 1] = [base+count .. base+1] ++ [base .. 1].
theorem List.range_down_split (base count : ℕ)
        : List.range_down(base + count)
          = List.append(List.range_down_offset(base, count),
                List.range_down(base)) :=
  by induction on count with IH {
    case base:
        -- The offset slice is empty and base + 0 = base.
        List.range_down(base + 0)
           = List.range_down(base)   by (base + 0 = base)
           = List.append(List.range_down_offset(base, 0),
                 List.range_down(base))
    case step(predecessorCount):
        -- Peel the top element base + (1 + count′) off both sides.
        List.range_down(base + (1 + predecessorCount))
           = List.range_down(1 + (base + predecessorCount))
                 by (base + (1 + predecessorCount)
                     = 1 + (base + predecessorCount))
           = List.prepend(ℕ, 1 + (base + predecessorCount),
                 List.range_down(base + predecessorCount))
                 by List.range_down_one_plus
           = List.prepend(ℕ, 1 + (base + predecessorCount),
                 List.append(
                     List.range_down_offset(base, predecessorCount),
                     List.range_down(base)))
                 by substituting IH
           = List.prepend(ℕ, base + (1 + predecessorCount),
                 List.append(
                     List.range_down_offset(base, predecessorCount),
                     List.range_down(base)))
                 by (1 + (base + predecessorCount)
                     = base + (1 + predecessorCount))
           = List.append(
                 List.range_down_offset(base, 1 + predecessorCount),
                 List.range_down(base))
                 by List.range_down_offset_one_plus
  }

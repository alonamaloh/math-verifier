-- Lists/range.math
--
-- `List.range_down(n) = [n, n−1, …, 1]`, the list of the positive integers
-- 1..n. (Descending because the `prepend` recursion is clean; order is
-- immaterial for the commutative-product / set-membership uses this is built
-- for. A general-purpose range, e.g. for Wilson's product over 1..p−1.)

module Lists.range

import Natural.basics
import Natural.order
import Natural.add_order
import Natural.decide
import Natural.strong_recursion
import Logic.basics
import Logic.sum
import Equality.basics
import Lists.list
import Lists.length

definition List.range_down : Natural → List(Natural)
  | zero => List.empty(Natural)
  | successor(predecessor) =>
      List.prepend(Natural, successor(predecessor), List.range_down(predecessor))

-- `range_down(n)` has exactly n elements.
theorem List.range_down_length (n : Natural)
        : List.length(Natural, List.range_down(n)) = n :=
  by_induction on n with IH {
    case zero:
        calc List.length(Natural, List.range_down(0))
           = 0
    case successor(predecessor):
        calc List.length(Natural, List.range_down(successor(predecessor)))
           = successor(List.length(Natural, List.range_down(predecessor)))
           = successor(predecessor)   by substituting IH
  }

-- Completeness: every positive integer ≤ n appears in range_down(n).
-- (Induct on n with j generalised so the bound varies; the successor case
-- splits j = successor(predecessor) (head) vs j ≤ predecessor (tail, by IH).)
theorem List.range_down_complete (n : Natural)
        : (j : Natural) → 1 ≤ j → j ≤ n
          → List.member(Natural, j, List.range_down(n)) :=
  by_induction on n with IH {
    case zero: {
        take j : Natural;
        suppose 1 ≤ j as lower;
        suppose j ≤ 0 as upper;
        claim 1 ≤ 0
            by calc (1 : Natural)
                  ≤ j   by lower
                  ≤ 0   by upper;
        claim False by Natural.not_less_or_equal_successor_zero;
        done
      }
    case successor(predecessor): {
        take j : Natural;
        suppose 1 ≤ j as lower;
        suppose j ≤ successor(predecessor) as upper;
        claim decision : j = successor(predecessor) ∨ ¬(j = successor(predecessor))
            by Natural.decides_equality;
        cases decision {
          | Or.introduceLeft(jEqual) => {
              claim memberSucc
                  : List.member(Natural, successor(predecessor),
                        List.range_down(successor(predecessor)))
                  by List.member.here(Natural, successor(predecessor),
                         List.range_down(predecessor));
              claim List.member(Natural, j, List.range_down(successor(predecessor)))
                  by substituting jEqual;
              done
            }
          | Or.introduceRight(jNotEqual) => {
              claim jLeK : j ≤ predecessor
                  by Natural.less_or_equal_successor_not_equal;
              List.member.there(Natural, j, successor(predecessor),
                  List.range_down(predecessor), IH(j, lower, jLeK))
            }
        }
      }
  }

-- Conversely, every member of range_down(n) is ≤ n. (Needed to show the
-- head successor(k) doesn't recur in range_down(k), i.e. distinctness.)
theorem List.range_down_member_le (n : Natural)
        : (j : Natural) → List.member(Natural, j, List.range_down(n)) → j ≤ n :=
  by_induction on n with IH {
    case zero: {
        take j : Natural;
        suppose List.member(Natural, j, List.range_down(0)) as mem;
        absurd(List.no_member_empty(Natural, j, mem))
      }
    case successor(predecessor): {
        take j : Natural;
        suppose List.member(Natural, j, List.range_down(successor(predecessor))) as mem;
        claim invert
            : j = successor(predecessor)
              ∨ List.member(Natural, j, List.range_down(predecessor))
            by List.member_prepend_invert;
        cases invert {
          | Or.introduceLeft(jEqual) => {
              claim j ≤ successor(predecessor) by substituting jEqual;
              done
            }
          | Or.introduceRight(memberTail) =>
              calc j
                 ≤ predecessor             by IH(j, memberTail)
                 ≤ successor(predecessor)  by Natural.le_successor
        }
      }
  }

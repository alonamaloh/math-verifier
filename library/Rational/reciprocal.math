-- Rational/reciprocal.math
--
-- Reciprocal of a positive Rational and the ε/R construction needed
-- by the Cauchy product respect proofs. Given r > 0, we extract a
-- Natural witness `succ(k)` for the numerator and build
-- `1/r := mk(make((succ(d_r) : I), k))`. Then `r * (1/r) = 1`.

module Rational.reciprocal

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Integer.sign
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.order_arithmetic
import Rational.triangle

-- A "strictly positive Rational" packaged with its numerator
-- witness. `make(k, d) : strict_positive_rational` represents the
-- rational `succ(k)/succ(d)`.
inductive StrictPositiveRational : Type(0) where
  | StrictPositiveRational.make
      : (numeratorPredecessor : Natural)
        → (denominatorPredecessor : Natural)
        → StrictPositiveRational

-- Underlying Rational of a packaged strict positive.
definition StrictPositiveRational.value
        : StrictPositiveRational → Rational
  | StrictPositiveRational.make(k, d) =>
      Quotient.mk(RationalRepresentative.make(
                      (successor(k) : Integer), d))

-- Reciprocal of a packaged strict positive: swap numerator (succ(k))
-- and denominator (succ(d)), giving succ(d)/succ(k) = mk(make(succ(d) : I, k)).
definition StrictPositiveRational.reciprocal
        : StrictPositiveRational → Rational
  | StrictPositiveRational.make(k, d) =>
      Quotient.mk(RationalRepresentative.make(
                      (successor(d) : Integer), k))

-- Multiplicative cancellation: r * (1/r) = 1 for r = succ(k)/succ(d).
-- At reps: (succ(k) : I, d) * (succ(d) : I, k) = (succ(k) · succ(d), k + d·succ(k)).
-- We want this to equal Rational.one = (1, 0). Cross-multiply:
--   succ(k)·succ(d) · 1 = 1 · succ(k + d·succ(k))
-- LHS = succ(k)·succ(d). RHS = succ(k + d·succ(k)) = succ(k) + d·succ(k) + ?
-- Specifically succ(k + d·succ(k)) = k + d·succ(k) + 1.
-- And succ(k)·succ(d) = succ(k)·d + succ(k) = succ(k) + d·succ(k) (after commute).
-- So both sides equal succ(k) + d·succ(k) — Natural equation.
theorem StrictPositiveRational.reciprocal_multiplied (r : StrictPositiveRational)
        : StrictPositiveRational.value(r)
              * StrictPositiveRational.reciprocal(r)
          = Rational.one :=
  cases r {
    | StrictPositiveRational.make(k, d) =>
        Quotient.sound(
            RationalRepresentative, RationalEquivalent,
            RationalRepresentative.make(
                (successor(k) : Integer) * (successor(d) : Integer),
                k + d * successor(k)),
            RationalRepresentative.make(Integer.one, zero),
            -- Cross-mult equation:
            -- (succ(k)·succ(d)) · succ(zero) = 1 · succ(k + d·succ(k)).
            calc (successor(k) : Integer) * (successor(d) : Integer)
                   * (successor(zero) : Integer)
               = (successor(k) : Integer) * (successor(d) : Integer)
                      by Integer.multiply_identity_right(
                             (successor(k) : Integer)
                                 * (successor(d) : Integer))
               = (successor(k) * successor(d) : Integer)
                      by Equality.symmetry(
                             Natural.to_integer.multiply_preserves(
                                 successor(k), successor(d)))
               = (successor(k + d * successor(k)) : Integer)
                      by congruenceOf(
                             Natural.to_integer,
                             -- succ(k) * succ(d) = succ(k + d·succ(k)).
                             -- succ(k)*succ(d) = succ(k)*d + succ(k)
                             --   (Natural multiply_successor on right)
                             -- = d·succ(k) + succ(k) (commute)
                             -- = succ(k + d·succ(k)) (Natural add_successor).
                             calc successor(k) * successor(d)
                                = successor(k) + successor(k) * d
                                       by Natural.multiply_successor(
                                              successor(k), d)
                                = successor(k) + d * successor(k)
                                       by rewrite(
                                              Natural.multiply_commutative(
                                                  successor(k), d))
                                = successor(k + d * successor(k))
                                       by reflexivity(Natural,
                                              successor(k + d * successor(k))))
               = Integer.one * (successor(k + d * successor(k)) : Integer)
                      by Equality.symmetry(
                             Integer.multiply_identity_left(
                                 (successor(k + d * successor(k)) : Integer))))
  }

-- Extract a StrictPositiveRational witness from a strict-positivity
-- proof at a representative. From 0 < q and q = mk(make(n, d)), we
-- get a Natural k with n = (succ(k) : Integer); take d as the
-- denominator-minus-one to form the witness.
theorem Rational.strict_positive_witness_at_representative
        (n : Integer) (d : Natural)
        (nIsNonneg : Integer.IsNonneg(n))
        (nNonzero
           : Not(n = Integer.zero))
        : ∃ (k : Natural). n = (successor(k) : Integer) :=
  Exists.eliminate(
      Natural,
      function (a : Natural) => n = (a : Integer),
      ∃ (k : Natural). n = (successor(k) : Integer),
      function (a : Natural) (nIsImage : n = (a : Integer)) =>
        (cases a {
           | zero =>
               -- n = (zero : I) = Integer.zero, contradicts nNonzero.
               function (refinedHypothesis : n = (zero : Integer)) =>
                 False.eliminate_proposition(
                     ∃ (k : Natural). n = (successor(k) : Integer),
                     nNonzero(
                         calc n
                            = (zero : Integer)
                                   by refinedHypothesis
                            = Integer.zero
                                   by reflexivity(Integer, Integer.zero)))
           | successor(predecessor) =>
               function (refinedHypothesis
                            : n = (successor(predecessor) : Integer)) =>
                 Exists.introduce(
                     Natural,
                     function (k : Natural) =>
                         n = (successor(k) : Integer),
                     predecessor,
                     refinedHypothesis)
         } : (refinedHypothesis : n = (a : Integer))
             → ∃ (k : Natural). n = (successor(k) : Integer))(nIsImage),
      nIsNonneg)

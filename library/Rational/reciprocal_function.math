-- Rational/reciprocal_function.math
--
-- A total reciprocal function `Rational → Rational`, with junk value
-- `Rational.zero` at zero, correct (`x · reciprocal(x) = 1`) for every
-- non-zero input. With the field-of-fractions construction the inverse of a
-- nonzero rational already exists (`Rational.reciprocal_exists_for_nonzero`),
-- so we turn that existence into a function with the description operator
-- `Logic.the`, pinned by the predicate `x·y = 1 ∨ (x = 0 ∧ y = 0)`.
--
-- This unlocks Real-as-Field: the Real reciprocal Cauchy sequence builds on a
-- function-typed pointwise reciprocal, which the propositional ∃ alone can't
-- provide.

module Rational.reciprocal_function

import Logic.basics
import Logic.exists
import Logic.quotient
import axioms
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.subtraction
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Integer.sign
import Integer.absolute_value
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value
import Rational.reciprocal
import Rational.field
import Rational.order_multiplication

-- ----------------------------------------------------------------------
-- The total reciprocal as a function. With the field-of-fractions
-- construction the reciprocal of a nonzero rational already exists
-- (`Rational.reciprocal_exists_for_nonzero`); we turn that existence into
-- a function with the description operator, pinning the value by the
-- predicate
--   P(x, y) := x·y = 1  ∨  (x = 0 ∧ y = 0),
-- which holds of a unique y (the inverse when x ≠ 0, junk 0 when x = 0).

definition Rational.reciprocal_predicate (x y : Rational) : Proposition :=
  x * y = Rational.one ∨ x = Rational.zero ∧ y = Rational.zero

theorem Rational.reciprocal_exists_with_junk (x : Rational)
        : ∃ (y : Rational). Rational.reciprocal_predicate(x, y) :=
  done by cases {
    case (x = Rational.zero) as xIsZero: {
        x = Rational.zero ∧ Rational.zero = Rational.zero as junkSatisfies;
        x * Rational.zero = Rational.one
            ∨ x = Rational.zero ∧ Rational.zero = Rational.zero by junkSatisfies as atZero;
        witness Rational.zero with atZero
      }
    case Not(x = Rational.zero) as xNonzero: {
        choose y such that x * y = Rational.one
            from Rational.reciprocal_exists_for_nonzero;
        -- The inverse y satisfies the left disjunct x · y = 1.
        x * y = Rational.one ∨ x = Rational.zero ∧ y = Rational.zero as atY;
        witness y with atY
      }
  }

theorem Rational.reciprocal_unique (x : Rational)
        : ∀ (y1 y2 : Rational).
          Rational.reciprocal_predicate(x, y1)
          → Rational.reciprocal_predicate(x, y2)
          → y1 = y2 :=
  (y1 y2 : Rational)
  (predicate1 : Rational.reciprocal_predicate(x, y1))
  (predicate2 : Rational.reciprocal_predicate(x, y2)) ↦
    done by cases {
      case (x * y1 = Rational.one) as productOne1:
          done by cases {
            case (x * y2 = Rational.one) as productOne2:
                calc y1
                   = y1 * Rational.one
                   = y1 * (x * y2)
                   = (x * y1) * y2
                   = Rational.one * y2
                   = y2
            case (x = Rational.zero ∧ y2 = Rational.zero) as zeroPair2: {
                -- x = 0 forces 1 = x·y1 = 0, contradicting 0 ≠ 1.
                x = Rational.zero;
                Rational.one
                   = x * y1
                   = Rational.zero * y1
                   = Rational.zero;
                Rational.zero ≠ Rational.one as zeroNotOne;
                Rational.zero = Rational.one as zeroEqualsOne;
                absurd(zeroNotOne(zeroEqualsOne))
              }
          }
      case (x = Rational.zero ∧ y1 = Rational.zero) as zeroPair1:
          done by cases {
            case (x * y2 = Rational.one) as productOne2: {
                -- Symmetrically, x = 0 forces 1 = x·y2 = 0.
                x = Rational.zero;
                Rational.one
                   = x * y2
                   = Rational.zero * y2
                   = Rational.zero;
                Rational.zero ≠ Rational.one as zeroNotOne;
                Rational.zero = Rational.one as zeroEqualsOne;
                absurd(zeroNotOne(zeroEqualsOne))
              }
            case (x = Rational.zero ∧ y2 = Rational.zero) as zeroPair2:
                -- Both are the junk value 0.
                calc y1
                   = Rational.zero
                   = y2
          }
    }

definition Rational.reciprocal_function (x : Rational) : Rational :=
  Logic.the(
      Rational, (y : Rational) ↦ Rational.reciprocal_predicate(x, y),
      Rational.reciprocal_exists_with_junk(x),
      Rational.reciprocal_unique(x))

theorem Rational.reciprocal_function_satisfies (x : Rational)
        : Rational.reciprocal_predicate(x, Rational.reciprocal_function(x)) :=
  Logic.the_satisfies(
      Rational, (y : Rational) ↦ Rational.reciprocal_predicate(x, y),
      Rational.reciprocal_exists_with_junk(x),
      Rational.reciprocal_unique(x))

-- ----------------------------------------------------------------------
-- Multiplication correctness: for non-zero x, x · reciprocal_function(x)
-- = Rational.one (the right disjunct of the predicate is ruled out).

theorem Rational.reciprocal_function_multiplies
        (x : Rational) (xNonzero : ¬(x = Rational.zero))
        : x * Rational.reciprocal_function(x) = Rational.one :=
  {
  Rational.reciprocal_predicate(x, Rational.reciprocal_function(x));
  done by cases {
    case (x * Rational.reciprocal_function(x) = Rational.one) as productOne:
        done
    case (x = Rational.zero ∧ Rational.reciprocal_function(x) = Rational.zero) as zeroPair: {
        -- x = 0 contradicts xNonzero.
        x = Rational.zero as xIsZero;
        absurd(xNonzero(xIsZero))
      }
  }
}

-- Reciprocals are multiplicative: for nonzero a and b,
-- a⁻¹ · b⁻¹ = (a·b)⁻¹. Multiply by (a·b)·(a·b)⁻¹ = 1 and regroup so
-- each factor cancels its own reciprocal.
theorem Rational.reciprocal_function_product (a b : Rational)
        (aNonzero : ¬(a = Rational.zero)) (bNonzero : ¬(b = Rational.zero))
        : Rational.reciprocal_function(a) * Rational.reciprocal_function(b)
          = Rational.reciprocal_function(a * b) := {
  a * Rational.reciprocal_function(a) = Rational.one as aCancel;
  b * Rational.reciprocal_function(b) = Rational.one as bCancel;
  ¬(a * b = Rational.zero);
  (a * b) * Rational.reciprocal_function(a * b) = Rational.one as productCancel;
  Rational.reciprocal_function(a) * Rational.reciprocal_function(b)
     = (Rational.reciprocal_function(a) * Rational.reciprocal_function(b))
       * Rational.one
     = (Rational.reciprocal_function(a) * Rational.reciprocal_function(b))
       * ((a * b) * Rational.reciprocal_function(a * b))
           by productCancel
     = ((a * Rational.reciprocal_function(a))
        * (b * Rational.reciprocal_function(b)))
       * Rational.reciprocal_function(a * b)
           by ring
     = (Rational.one * (b * Rational.reciprocal_function(b)))
       * Rational.reciprocal_function(a * b)
           by aCancel
     = (Rational.one * Rational.one) * Rational.reciprocal_function(a * b)
           by bCancel
     = Rational.reciprocal_function(a * b)
}

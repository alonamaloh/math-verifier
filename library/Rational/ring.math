-- Rational/ring.math
--
-- Commutative-ring laws for Rational. With denominators now plain nonzero
-- integers, the combined denominator of a sum/product is `d1·d2`, so each
-- law's cross-multiplication equivalence is a pure ring identity in the
-- Integer numerators — a single reshaping calc step over representatives.

module Rational.ring

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.ring
import Integer.negation
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation

-- ======================================================================
-- Commutativity.

automatic theorem Rational.add_commutative (x y : Rational)
        : x + y = y + x :=
  by_representatives x as ⟨n_x, d_x, _⟩, y as ⟨n_y, d_y, _⟩ =>
    calc (n_x * d_y + n_y * d_x) * (d_y * d_x)
       = (n_y * d_x + n_x * d_y) * (d_x * d_y)

automatic theorem Rational.multiply_commutative (x y : Rational)
        : x * y = y * x :=
  by_representatives x as ⟨n_x, d_x, _⟩, y as ⟨n_y, d_y, _⟩ =>
    calc (n_x * n_y) * (d_y * d_x)
       = (n_y * n_x) * (d_x * d_y)

-- ======================================================================
-- Additive identity.

automatic theorem Rational.add_zero (x : Rational)
        : x + Rational.zero = x := {
  obtain RationalRepresentative.make(n, d, dNonzero) from x;
  calc (n * Integer.one + Integer.zero * d) * d
     = n * (d * Integer.one)
}

automatic theorem Rational.zero_add (x : Rational)
        : Rational.zero + x = x :=
  calc Rational.zero + x
     = x + Rational.zero
     = x

-- ======================================================================
-- Multiplicative identity.

automatic theorem Rational.multiply_one (x : Rational)
        : x * Rational.one = x := {
  obtain RationalRepresentative.make(n, d, dNonzero) from x;
  calc (n * Integer.one) * d
     = n * (d * Integer.one)
}

automatic theorem Rational.one_multiply (x : Rational)
        : Rational.one * x = x :=
  calc Rational.one * x
     = x * Rational.one
     = x

-- ======================================================================
-- Additive inverse.

automatic theorem Rational.add_negate_right (x : Rational)
        : x + -x = Rational.zero := {
  obtain RationalRepresentative.make(n, d, dNonzero) from x;
  calc (n * d + -n * d) * Integer.one
     = Integer.zero * (d * d)
}

automatic theorem Rational.add_negate_left (x : Rational)
        : -x + x = Rational.zero :=
  calc -x + x
     = x + -x
     = Rational.zero

-- Multiplicative annihilation (`0 · x = 0` and `x · 0 = 0`) is derived
-- from the IsRing instance via `Algebra.Ring.zero_multiply` /
-- `Ring.multiply_zero` in `Rational/instances.math`.

-- Rational/ring.math
--
-- Commutative-ring laws for Rational. Each law follows the standard
-- quotient pattern:
--   1. Prove an Integer-level "at_representatives" lemma stating
--      `RationalEquivalent(operation_representatives(...), ...)`. The
--      equivalence definitionally unfolds to an Integer
--      cross-multiplication, which we close with the corresponding
--      Integer law.
--   2. State the user-facing law over arbitrary Rationals. Pull
--      representatives via the `obtain Quotient.mk(rep) from x;` sugar
--      (WLOG-style), then lift the Integer-level kernel through
--      `Quotient.sound` to an `mk(_) = mk(_)` equality.

module Rational.ring

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.ring
import Integer.negation
import Integer.algebra
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation

-- ----------------------------------------------------------------------
-- Helper used by every law that crosses the denominator: lift the
-- `RationalEquivalent` cross-multiplication to a form using
-- `to_integer(succ(d1)·succ(d2))`, which the kernel produces from
-- `Rational.add_representatives` / `Rational.multiply_representatives`
-- on a destructured representative pair.

-- ======================================================================
-- Addition: commutativity.

theorem Rational.add_commutative_at_representatives
        : (rep1 rep2 : RationalRepresentative)
          → RationalEquivalent(
                Rational.add_representatives(rep1, rep2),
                Rational.add_representatives(rep2, rep1))
  | RationalRepresentative.make(n1, d1),
    RationalRepresentative.make(n2, d2) =>
      -- Goal:
      --   (n1·s_d2 + n2·s_d1) · t(succ(d1 + d2·succ(d1)))
      -- = (n2·s_d1 + n1·s_d2) · t(succ(d2 + d1·succ(d2)))
      -- where t = Natural.to_integer, s_X = t(succ(X)). The kernel
      -- reduces `successor(d_a + d_b·succ(d_a))` to `succ(d_b)·succ(d_a)`
      -- (multiply pattern picks the *first* factor's predecessor and
      -- shoves it into the second's `Natural.add`). So the equality
      -- denominators factor as `succ(d2)·succ(d1)` (LHS) and
      -- `succ(d1)·succ(d2)` (RHS). The calc then commutes the numerator
      -- and the lifted denominator.
      calc (n1 * (successor(d2) : Integer) + n2 * (successor(d1) : Integer)) * (successor(d2) * successor(d1) : Integer)
         = (n2 * (successor(d1) : Integer) + n1 * (successor(d2) : Integer)) * (successor(d2) * successor(d1) : Integer)
         = (n2 * (successor(d1) : Integer) + n1 * (successor(d2) : Integer)) * ((successor(d2) : Integer) * (successor(d1) : Integer))
         = (n2 * (successor(d1) : Integer) + n1 * (successor(d2) : Integer)) * ((successor(d1) : Integer) * (successor(d2) : Integer))
         = (n2 * (successor(d1) : Integer) + n1 * (successor(d2) : Integer)) * (successor(d1) * successor(d2) : Integer)

theorem Rational.add_commutative (x y : Rational)
        : x + y = y + x := {
  obtain Quotient.mk(rep_x) from x;
  obtain Quotient.mk(rep_y) from y;
  Quotient.sound(
      Rational.add_representatives(rep_x, rep_y),
      Rational.add_representatives(rep_y, rep_x),
      Rational.add_commutative_at_representatives(rep_x, rep_y))
}

-- ======================================================================
-- Multiplication: commutativity. Same shape as addition: commute the
-- numerator with `Integer.multiply_commutative`, then commute the
-- factored lifted denominator.

theorem Rational.multiply_commutative_at_representatives
        : (rep1 rep2 : RationalRepresentative)
          → RationalEquivalent(
                Rational.multiply_representatives(rep1, rep2),
                Rational.multiply_representatives(rep2, rep1))
  | RationalRepresentative.make(n1, d1),
    RationalRepresentative.make(n2, d2) =>
      calc n1 * n2 * (successor(d2) * successor(d1) : Integer)
         = n2 * n1 * (successor(d2) * successor(d1) : Integer)
         = n2 * n1 * ((successor(d2) : Integer) * (successor(d1) : Integer))
         = n2 * n1 * ((successor(d1) : Integer) * (successor(d2) : Integer))
         = n2 * n1 * (successor(d1) * successor(d2) : Integer)

theorem Rational.multiply_commutative (x y : Rational)
        : x * y = y * x := {
  obtain Quotient.mk(rep_x) from x;
  obtain Quotient.mk(rep_y) from y;
  Quotient.sound(
      Rational.multiply_representatives(rep_x, rep_y),
      Rational.multiply_representatives(rep_y, rep_x),
      Rational.multiply_commutative_at_representatives(rep_x, rep_y))
}

-- ======================================================================
-- Additive identity: `x + 0 = x` and `0 + x = x`.
--
-- At rep level the LHS reduces to
--   mk(make(n·s_0 + 0·s_d, 0 + d·s_0))
-- which we need to show equivalent to `make(n, d)`. The Integer
-- cross-multiplication
--   (n·s_0 + 0·s_d) · s_d  =  n · s_(0 + d·s_0)
-- collapses by `Integer.multiply_zero_left`, `Integer.add_identity_right`,
-- and the fact that `Natural.to_integer(successor(zero))` is
-- `Integer.one` definitionally; the asymmetric denominator
-- `0 + d·s_0` reduces (Natural.add on zero first arg) to `d·s_0` and
-- then needs `Natural.multiply_one` to reach `d`. We assemble all of
-- this in a single Integer-level calc.

theorem Rational.add_zero_at_representatives_natural
        (n : Integer) (d : Natural)
        : (n * (successor(0) : Integer) + Integer.zero * (successor(d) : Integer)) * (successor(d) : Integer) = n * (successor(0 + d * successor(0)) : Integer) :=
  calc (n * (successor(0) : Integer) + Integer.zero * (successor(d) : Integer)) * (successor(d) : Integer)
     = n * (successor(d) : Integer)
     = n * (successor(d * successor(0)) : Integer)

theorem Rational.add_zero (x : Rational)
        : x + Rational.zero = x := {
  obtain RationalRepresentative.make(n, d) from x;
  Quotient.sound(
      Rational.add_representatives(
          RationalRepresentative.make(n, d),
          RationalRepresentative.make(Integer.zero, 0)),
      RationalRepresentative.make(n, d),
      Rational.add_zero_at_representatives_natural(n, d))
}

-- Left identity follows from commutativity.
theorem Rational.zero_add (x : Rational)
        : Rational.zero + x = x :=
  calc Rational.zero + x
     = x + Rational.zero
     = x

-- ======================================================================
-- Multiplicative identity: `x · 1 = x` and `1 · x = x`.
--
-- At rep level the LHS reduces to
--   mk(make(n·Integer.one, d·s_0))
-- (the `0 + ` in the denominator-minus-one drops by the Natural.add
-- zero pattern). The Integer cross-multiplication
--   (n·Integer.one) · s_d  =  n · s_(d·s_0)
-- closes via `Integer.multiply_identity_right` on the LHS numerator and
-- `Natural.multiply_one(d)` on the denominator.

theorem Rational.multiply_one_at_representatives_natural
        (n : Integer) (d : Natural)
        : n * Integer.one * (successor(d) : Integer) = n * (successor(d * successor(0)) : Integer) :=
  calc n * Integer.one * (successor(d) : Integer)
     = n * (successor(d) : Integer)
     = n * (successor(d * successor(0)) : Integer)

theorem Rational.multiply_one (x : Rational)
        : x * Rational.one = x := {
  obtain RationalRepresentative.make(n, d) from x;
  Quotient.sound(
      Rational.multiply_representatives(
          RationalRepresentative.make(n, d),
          RationalRepresentative.make(Integer.one, 0)),
      RationalRepresentative.make(n, d),
      Rational.multiply_one_at_representatives_natural(n, d))
}

theorem Rational.one_multiply (x : Rational)
        : Rational.one * x = x :=
  calc Rational.one * x
     = x * Rational.one
     = x

-- ======================================================================
-- Additive inverse: `x + (−x) = 0` and `(−x) + x = 0`.
--
-- At rep level rep = make(n, d):
--   add_reps(make(n, d), make(negate(n), d))
--     = make(n·s_d + negate(n)·s_d, d + d·s_d)
-- The Integer cross-multiplication
--   (n·s_d + negate(n)·s_d) · to_int(succ(zero))  =  0 · to_int(succ(d + d·s_d))
-- collapses on the RHS by `Integer.multiply_zero_left` and on the LHS
-- by pulling out negate, `Integer.add_negate_right`, and the unit on the
-- right.

theorem Rational.add_negate_right_at_representatives_natural
        (n : Integer) (d : Natural)
        : (n * (successor(d) : Integer) + -n * (successor(d) : Integer)) * (successor(0) : Integer) = Integer.zero * (successor(d + d * successor(d)) : Integer) :=
  calc (n * (successor(d) : Integer) + -n * (successor(d) : Integer)) * (successor(0) : Integer)
     = Integer.zero * (successor(d + d * successor(d)) : Integer)

theorem Rational.add_negate_right (x : Rational)
        : x + -x = Rational.zero := {
  obtain RationalRepresentative.make(n, d) from x;
  Quotient.sound(
      Rational.add_representatives(
          RationalRepresentative.make(n, d),
          RationalRepresentative.make(-n, d)),
      RationalRepresentative.make(Integer.zero, 0),
      Rational.add_negate_right_at_representatives_natural(n, d))
}

theorem Rational.add_negate_left (x : Rational)
        : -x + x = Rational.zero :=
  calc -x + x
     = x + -x
     = Rational.zero

-- Multiplicative annihilation (`0 · x = 0` and `x · 0 = 0`) is derived
-- from the IsRing instance via `Algebra.Ring.zero_multiply` /
-- `Ring.multiply_zero` in `Rational/instances.math`. Doing it there
-- avoids restating proofs that hold for every ring; doing it AFTER the
-- foundational ring axioms (associativity, distributivity, negation)
-- are in scope is mandatory, since the abstract derivation depends on
-- them via `Rational.is_ring`.

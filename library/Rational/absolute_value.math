-- Rational/absolute_value.math
--
-- Absolute value on Rational. On representatives, replace the
-- numerator with its Integer absolute value; the denominator is
-- unchanged. The respect proof reduces to a small identity on
-- Integer absolute value.

module Rational.absolute_value

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.distance
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Integer.absolute_value
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.order

-- Representative-level absolute value: replace numerator with its
-- Integer absolute value.
definition Rational.absolute_value_at_representative
        : RationalRepresentative → Rational
  | RationalRepresentative.make(n, d) =>
      Quotient.mk(
          RationalRepresentative.make(
              Integer.absolute_value(n), d))

-- Respect: stubbed for now. The proof reduces to
--   (n1, d1) ~ (n2, d2)  i.e. n1·succ(d2) = n2·succ(d1)
--   ⇒  mk(make(|n1|, d1)) = mk(make(|n2|, d2))
-- which expands to a cross-multiplication on absolute values that
-- requires `Integer.absolute_value_multiply` and an order-aware case
-- split. Filled in during the order-lemma follow-up.
theorem Rational.absolute_value_respect
        (rep1 rep2 : RationalRepresentative)
        (equivalenceHypothesis : RationalEquivalent(rep1, rep2))
        : Rational.absolute_value_at_representative(rep1)
          = Rational.absolute_value_at_representative(rep2) := sorry

definition Rational.absolute_value (x : Rational) : Rational :=
  Quotient.lift(
      Rational.absolute_value_at_representative,
      Rational.absolute_value_respect,
      x)

-- Rational/basics.math
--
-- The rationals as the field of fractions of ℤ: equivalence classes of
-- (Integer numerator, nonzero Integer denominator) pairs under
-- cross-multiplication. A `RationalRepresentative.make(n, d, proof)` is the
-- fraction n/d, carrying a proof that the denominator `d` is nonzero — the
-- honest non-degeneracy condition (the older "denominator = predecessor + 1"
-- trick only worked because ℤ's positives are exactly the successors; it does
-- not generalise to other multiplicative sets). Two fractions are equivalent
-- iff `n1 · d2 = n2 · d1`; the proofs are irrelevant to the equivalence.
--
-- Transitivity is the substantial step: cross-multiply, reshape to
--     (n1 · d3) · d2 = (n3 · d1) · d2,
-- and cancel the common nonzero factor `d2` via
-- `Integer.multiply_cancel_right_by_nonzero` (ℤ is an integral domain).
--
-- The `Rational` type itself is **opaque**: the rest of the library reasons
-- about rationals through the boundary lemmas published here
-- (`Rational.fraction_equal` and its converse), never by unfolding the
-- quotient. How the rationals are built is an implementation detail behind
-- that boundary — exactly as `Integer` seals its own quotient.

module Rational.basics

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.extensionality
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.ring
import Integer.cancellation
import Integer.integral_domain

-- ----------------------------------------------------------------------
-- Representatives and the equivalence relation.

inductive RationalRepresentative : Type(0) where
  | RationalRepresentative.make
      : Integer → (denominator : Integer) → denominator ≠ Integer.zero
        → RationalRepresentative

-- (n1, d1) ~ (n2, d2) iff n1 · d2 = n2 · d1 in Integer. The nonzero proofs
-- play no part in the relation.
definition RationalEquivalent
        : RationalRepresentative → RationalRepresentative → Proposition
  | RationalRepresentative.make(n1, d1, _),
    RationalRepresentative.make(n2, d2, _) =>
      n1 * d2 = n2 * d1

-- ----------------------------------------------------------------------
-- Reflexivity is just reflexivity of Integer equality.

theorem RationalEquivalent.reflexive
        : ∀ (representative : RationalRepresentative).
          RationalEquivalent(representative, representative)
  | RationalRepresentative.make(n, d, _) =>
      done

-- ----------------------------------------------------------------------
-- Symmetry is just symmetry of Integer equality after destructuring
-- both representatives.

theorem RationalEquivalent.symmetric
        : ∀ (x y : RationalRepresentative).
          RationalEquivalent(x, y)
          → RationalEquivalent(y, x)
  | RationalRepresentative.make(n1, d1, _),
    RationalRepresentative.make(n2, d2, _),
    equivalenceHypothesis =>
      done by equivalenceHypothesis

-- ----------------------------------------------------------------------
-- Transitivity: from n1·d2 = n2·d1 and n2·d3 = n3·d2, derive n1·d3 = n3·d1.
-- Multiply the goal out by the common nonzero factor d2 and cancel it: both
-- sides reshape (by ring) through the shared product n2·d1·d3.

theorem RationalEquivalent.transitive
        : ∀ (x y z : RationalRepresentative).
          RationalEquivalent(x, y)
          → RationalEquivalent(y, z)
          → RationalEquivalent(x, z)
  | RationalRepresentative.make(n1, d1, _),
    RationalRepresentative.make(n2, d2, d2Nonzero),
    RationalRepresentative.make(n3, d3, _),
    firstEquivalence, secondEquivalence => {
      calc (n1 * d3) * d2
         = (n1 * d2) * d3
         = (n2 * d1) * d3   by firstEquivalence
         = (n2 * d3) * d1
         = (n3 * d2) * d1   by secondEquivalence
         = (n3 * d1) * d2;
      done by Integer.multiply_cancel_right_by_nonzero
  }

-- ----------------------------------------------------------------------
-- The Rational type and canonical constants.
-- Opaque — the quotient structure is sealed behind the boundary lemmas.

opaque definition Rational : Type(0) :=
  Quotient(RationalRepresentative, RationalEquivalent)

-- The equivalence bundled as an `IsEquivalenceRelation`, registered as
-- the canonical instance — `Quotient.equal_implies_equivalent(x, y, mkEquality)` then
-- recovers reflexivity / symmetry / transitivity automatically.
definition Rational.equivalence
        : IsEquivalenceRelation(RationalRepresentative, RationalEquivalent) := {
  claim ∀ (x : RationalRepresentative). RationalEquivalent(x, x)
      by RationalEquivalent.reflexive;
  claim ∀ (x y : RationalRepresentative). RationalEquivalent(x, y) → RationalEquivalent(y, x)
      by RationalEquivalent.symmetric;
  claim ∀ (x y z : RationalRepresentative).
          RationalEquivalent(x, y) → RationalEquivalent(y, z) → RationalEquivalent(x, z)
      by RationalEquivalent.transitive;
  done
}

instance Rational.equivalence

-- The canonical introduction form: the class of the fraction n / d, given a
-- proof that d is nonzero. Registered as a `construction` so proofs read
-- `Rational.fraction(n, d, proof)` instead of the raw `Quotient.class_of`. The
-- `unfold Rational` pierces the opaque type once, here at the boundary.
construction Rational.fraction
        (n : Integer) (d : Integer) (denominatorNonzero : d ≠ Integer.zero)
        : Rational :=
  unfold Rational in Quotient.class_of(RationalRepresentative.make(n, d, denominatorNonzero))

-- ----------------------------------------------------------------------
-- The boundary API. Every consumer compares rationals through these two
-- lemmas: `fraction(n1, d1, _) = fraction(n2, d2, _)` is exactly the Integer
-- cross-equation `n1 · d2 = n2 · d1`, in both directions. The opaque
-- `Rational` is pierced only here.

-- Cross-equation ⇒ equal fractions (via Quotient.equivalent_implies_equal).
automatic theorem Rational.fraction_equal
        (n1 d1 : Integer) (d1Nonzero : d1 ≠ Integer.zero)
        (n2 d2 : Integer) (d2Nonzero : d2 ≠ Integer.zero)
        (crossEquation : n1 * d2 = n2 * d1)
        : Rational.fraction(n1, d1, d1Nonzero) = Rational.fraction(n2, d2, d2Nonzero) :=
  unfold Rational in
    Quotient.equivalent_implies_equal(RationalRepresentative.make(n1, d1, d1Nonzero),
                   RationalRepresentative.make(n2, d2, d2Nonzero),
                   crossEquation)

-- Equal fractions ⇒ cross-equation (via Quotient.equal_implies_equivalent).
theorem Rational.fraction_equal_implies
        (n1 d1 : Integer) (d1Nonzero : d1 ≠ Integer.zero)
        (n2 d2 : Integer) (d2Nonzero : d2 ≠ Integer.zero)
        (fractionEquality
            : Rational.fraction(n1, d1, d1Nonzero) = Rational.fraction(n2, d2, d2Nonzero))
        : n1 * d2 = n2 * d1 :=
  Quotient.equal_implies_equivalent(RationalRepresentative.make(n1, d1, d1Nonzero),
                 RationalRepresentative.make(n2, d2, d2Nonzero),
                 unfold Rational in fractionEquality)

-- Division of two integers as a rational. The denominator's nonzeroness is
-- a genuine side condition; the `/` operator leaves it for the auto-prover
-- to discharge at the use site (a decidable `2 ≠ 0`, or a hypothesis in
-- scope), so `a / b` reads plainly while staying mathematically honest.
definition Integer.divide
        (a : Integer) (b : Integer) (denominatorNonzero : b ≠ Integer.zero)
        : Rational :=
  Rational.fraction(a, b, denominatorNonzero)

operator (/) on (Integer, Integer) := Integer.divide

definition Rational.zero : Rational :=
  Rational.fraction(Integer.zero, Integer.one, Integer.one_is_nonzero)

definition Rational.one : Rational :=
  Rational.fraction(Integer.one, Integer.one, Integer.one_is_nonzero)

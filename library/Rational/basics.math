-- Rational/basics.math
--
-- The rationals, constructed as a quotient of triples of Naturals.
-- A representative `make(positivePart, negativePart, denominatorMinusOne)`
-- stands for the rational
--     (positivePart − negativePart) / (denominatorMinusOne + 1).
-- The "denominator minus one" trick keeps the denominator
-- automatically positive without a side-condition; the integer
-- numerator is encoded as a pair of Naturals, the same way Integer
-- is built (but inlined here rather than going through Integer, so
-- the equivalence relation stays in Natural and the transitivity
-- proof can use Natural multiplication cancellation directly).
--
-- The equivalence relation cross-multiplies. With ni : Integer
-- written as `pi − ni` and denominators di + 1:
--     (p1 − n1) · (d2 + 1) = (p2 − n2) · (d1 + 1)
-- becomes, after expansion and avoiding Natural subtraction,
--     p1 · succ(d2) + n2 · succ(d1) = n1 · succ(d2) + p2 · succ(d1).
-- That is the form we use below.

module Rational.basics

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.cancellation

-- ----------------------------------------------------------------------
-- Small Natural-level helpers used inside the transitivity proof.

-- `(a · b) · c = (a · c) · b`. Pulls a chosen factor into the
-- rightmost position of a triple product.
theorem Natural.multiply_associative_right_swap_in_pair
        (a b c : Natural)
        : (a * b) * c = (a * c) * b :=
  calc (a * b) * c
     = a * (b * c)   by Natural.multiply_associative(a, b, c)
     = a * (c * b)   by congruenceOf(
                            function (rest : Natural) => a * rest,
                            Natural.multiply_commutative(b, c))
     = (a * c) * b   by Equality.symmetry(
                            Natural.multiply_associative(a, c, b))

-- `(a + b) + (c + d) = (c + a) + (b + d)`. Swaps the first elements
-- of the two sub-sums (a ↔ c, with c landing left of a). Two-step
-- shuffle: a swap followed by a commute.
theorem Natural.add_two_two_swap_first
        (a b c d : Natural)
        : (a + b) + (c + d) = (c + a) + (b + d) :=
  calc (a + b) + (c + d)
     = (a + c) + (b + d)
            by Natural.add_two_two_swap(a, b, c, d)
     = (c + a) + (b + d)
            by congruenceOf(
                   function (lhs : Natural) => lhs + (b + d),
                   Natural.add_commutative(a, c))

-- `(a + b) + (c + d) = (c + b) + (a + d)`. Swaps a ↔ c keeping each
-- in the "first of pair" position. Three-step: swap, commute, swap.
theorem Natural.add_two_two_swap_outer_firsts
        (a b c d : Natural)
        : (a + b) + (c + d) = (c + b) + (a + d) :=
  calc (a + b) + (c + d)
     = (a + c) + (b + d)
            by Natural.add_two_two_swap(a, b, c, d)
     = (c + a) + (b + d)
            by congruenceOf(
                   function (lhs : Natural) => lhs + (b + d),
                   Natural.add_commutative(a, c))
     = (c + b) + (a + d)
            by Natural.add_two_two_swap(c, a, b, d)

inductive RationalRepresentative : Type(0) where
  | RationalRepresentative.make
      : Natural → Natural → Natural → RationalRepresentative

-- The equivalence: cross-multiply with the sign convention encoded
-- as "positive part − negative part".
definition RationalEquivalent
        : RationalRepresentative → RationalRepresentative → Proposition
  | RationalRepresentative.make(p1, n1, d1),
    RationalRepresentative.make(p2, n2, d2) =>
      p1 * successor(d2) + n2 * successor(d1)
      = n1 * successor(d2) + p2 * successor(d1)

-- ----------------------------------------------------------------------
-- Reflexivity: (p, n, d) ~ (p, n, d). The unfolded definition wants
--     p · succ(d) + n · succ(d) = n · succ(d) + p · succ(d).
-- That's the symmetric version of `add_commutative`.
theorem RationalEquivalent.reflexive
        : (representative : RationalRepresentative)
          → RationalEquivalent(representative, representative)
  | RationalRepresentative.make(p, n, d) =>
      Natural.add_commutative(p * successor(d), n * successor(d))

-- ----------------------------------------------------------------------
-- Symmetry. After destructuring both representatives, the goal is
-- the same equation with both sides swapped — three `add_commutative`
-- shuffles via `Equality.symmetry` on the hypothesis.

theorem RationalEquivalent.symmetric_after_first
        (p1 n1 d1 : Natural)
        : (other : RationalRepresentative)
          → RationalEquivalent(
                RationalRepresentative.make(p1, n1, d1), other)
          → RationalEquivalent(
                other, RationalRepresentative.make(p1, n1, d1))
  | RationalRepresentative.make(p2, n2, d2), equivalenceProof =>
      calc p2 * successor(d1) + n1 * successor(d2)
         = n1 * successor(d2) + p2 * successor(d1)
                by Natural.add_commutative(
                       p2 * successor(d1), n1 * successor(d2))
         = p1 * successor(d2) + n2 * successor(d1)
                by Equality.symmetry(equivalenceProof)
         = n2 * successor(d1) + p1 * successor(d2)
                by Natural.add_commutative(
                       p1 * successor(d2), n2 * successor(d1))

theorem RationalEquivalent.symmetric
        : (x y : RationalRepresentative)
          → RationalEquivalent(x, y)
          → RationalEquivalent(y, x)
  | RationalRepresentative.make(p1, n1, d1), y, equivalenceProof =>
      RationalEquivalent.symmetric_after_first(
          p1, n1, d1, y, equivalenceProof)

-- ----------------------------------------------------------------------
-- Transitivity is the substantial step. With representatives
--     (p1, n1, d1), (p2, n2, d2), (p3, n3, d3)
-- and hypotheses
--     H1: p1·succ(d2) + n2·succ(d1) = n1·succ(d2) + p2·succ(d1)
--     H2: p2·succ(d3) + n3·succ(d2) = n2·succ(d3) + p3·succ(d2)
-- we want
--          p1·succ(d3) + n3·succ(d1) = n1·succ(d3) + p3·succ(d1).
--
-- Strategy: multiply H1 through by succ(d3), multiply H2 through by
-- succ(d1), add them. The terms `p2·succ(d1)·succ(d3)` and
-- `n2·succ(d1)·succ(d3)` appear on both sides (up to commutativity)
-- and cancel. What's left factors a `succ(d2)`, which is positive,
-- so `Natural.multiply_cancel_right` finishes the job.

theorem RationalEquivalent.transitive_natural
        (p1 n1 d1 p2 n2 d2 p3 n3 d3 : Natural)
        (hyp1
            : p1 * successor(d2) + n2 * successor(d1)
              = n1 * successor(d2) + p2 * successor(d1))
        (hyp2
            : p2 * successor(d3) + n3 * successor(d2)
              = n2 * successor(d3) + p3 * successor(d2))
        : p1 * successor(d3) + n3 * successor(d1)
          = n1 * successor(d3) + p3 * successor(d1) := {
    -- Step 1: scale hyp1 by succ(d3) on the right, distribute, and
    -- regroup the products so the factor that will eventually
    -- cancel (succ(d2)) is rightmost.
    claim hyp1Scaled
          : (p1 * successor(d3)) * successor(d2)
            + (n2 * successor(d1)) * successor(d3)
            = (n1 * successor(d3)) * successor(d2)
              + (p2 * successor(d1)) * successor(d3)
        by calc (p1 * successor(d3)) * successor(d2)
                + (n2 * successor(d1)) * successor(d3)
              = (p1 * successor(d2)) * successor(d3)
                + (n2 * successor(d1)) * successor(d3)
                    by congruenceOf(
                           function (term : Natural) =>
                               term + (n2 * successor(d1))
                                       * successor(d3),
                           Natural.multiply_associative_right_swap_in_pair(
                               p1, successor(d3), successor(d2)))
              = (p1 * successor(d2) + n2 * successor(d1))
                * successor(d3)
                    by Equality.symmetry(
                           Natural.distributivity_right(
                               p1 * successor(d2),
                               n2 * successor(d1),
                               successor(d3)))
              = (n1 * successor(d2) + p2 * successor(d1))
                * successor(d3)
                    by congruenceOf(
                           function (sum : Natural) =>
                               sum * successor(d3),
                           hyp1)
              = (n1 * successor(d2)) * successor(d3)
                + (p2 * successor(d1)) * successor(d3)
                    by Natural.distributivity_right(
                           n1 * successor(d2),
                           p2 * successor(d1),
                           successor(d3))
              = (n1 * successor(d3)) * successor(d2)
                + (p2 * successor(d1)) * successor(d3)
                    by congruenceOf(
                           function (term : Natural) =>
                               term + (p2 * successor(d1))
                                       * successor(d3),
                           Natural.multiply_associative_right_swap_in_pair(
                               n1, successor(d2), successor(d3)));
    -- Step 2: scale hyp2 by succ(d1), distribute, and regroup so
    -- the succ(d2) factor ends up rightmost.
    claim hyp2Scaled
          : (p2 * successor(d1)) * successor(d3)
            + (n3 * successor(d1)) * successor(d2)
            = (n2 * successor(d1)) * successor(d3)
              + (p3 * successor(d1)) * successor(d2)
        by calc (p2 * successor(d1)) * successor(d3)
                + (n3 * successor(d1)) * successor(d2)
              = (p2 * successor(d3)) * successor(d1)
                + (n3 * successor(d1)) * successor(d2)
                    by congruenceOf(
                           function (term : Natural) =>
                               term + (n3 * successor(d1))
                                       * successor(d2),
                           Natural.multiply_associative_right_swap_in_pair(
                               p2, successor(d1), successor(d3)))
              = (p2 * successor(d3)) * successor(d1)
                + (n3 * successor(d2)) * successor(d1)
                    by congruenceOf(
                           function (term : Natural) =>
                               (p2 * successor(d3)) * successor(d1)
                               + term,
                           Natural.multiply_associative_right_swap_in_pair(
                               n3, successor(d1), successor(d2)))
              = (p2 * successor(d3) + n3 * successor(d2))
                * successor(d1)
                    by Equality.symmetry(
                           Natural.distributivity_right(
                               p2 * successor(d3),
                               n3 * successor(d2),
                               successor(d1)))
              = (n2 * successor(d3) + p3 * successor(d2))
                * successor(d1)
                    by congruenceOf(
                           function (sum : Natural) =>
                               sum * successor(d1),
                           hyp2)
              = (n2 * successor(d3)) * successor(d1)
                + (p3 * successor(d2)) * successor(d1)
                    by Natural.distributivity_right(
                           n2 * successor(d3),
                           p3 * successor(d2),
                           successor(d1))
              = (n2 * successor(d1)) * successor(d3)
                + (p3 * successor(d2)) * successor(d1)
                    by congruenceOf(
                           function (term : Natural) =>
                               term + (p3 * successor(d2))
                                       * successor(d1),
                           Natural.multiply_associative_right_swap_in_pair(
                               n2, successor(d3), successor(d1)))
              = (n2 * successor(d1)) * successor(d3)
                + (p3 * successor(d1)) * successor(d2)
                    by congruenceOf(
                           function (term : Natural) =>
                               (n2 * successor(d1)) * successor(d3)
                               + term,
                           Natural.multiply_associative_right_swap_in_pair(
                               p3, successor(d2), successor(d1)));
    -- Step 3: add the two scaled hypotheses. Group the term
    -- (p2·succ(d1))·succ(d3) on both sides, and (n2·succ(d1))·succ(d3)
    -- ditto, so they cancel by add_cancel_left.
    claim sumOfScaled
          : ((p1 * successor(d3)) * successor(d2)
             + (p2 * successor(d1)) * successor(d3))
            + ((n2 * successor(d1)) * successor(d3)
               + (n3 * successor(d1)) * successor(d2))
            = ((n1 * successor(d3)) * successor(d2)
               + (n2 * successor(d1)) * successor(d3))
              + ((p2 * successor(d1)) * successor(d3)
                 + (p3 * successor(d1)) * successor(d2))
        by calc ((p1 * successor(d3)) * successor(d2)
                 + (p2 * successor(d1)) * successor(d3))
                + ((n2 * successor(d1)) * successor(d3)
                   + (n3 * successor(d1)) * successor(d2))
              = ((p1 * successor(d3)) * successor(d2)
                 + (n2 * successor(d1)) * successor(d3))
                + ((p2 * successor(d1)) * successor(d3)
                   + (n3 * successor(d1)) * successor(d2))
                    by Natural.add_two_two_swap(
                           (p1 * successor(d3)) * successor(d2),
                           (p2 * successor(d1)) * successor(d3),
                           (n2 * successor(d1)) * successor(d3),
                           (n3 * successor(d1)) * successor(d2))
              = ((n1 * successor(d3)) * successor(d2)
                 + (p2 * successor(d1)) * successor(d3))
                + ((p2 * successor(d1)) * successor(d3)
                   + (n3 * successor(d1)) * successor(d2))
                    by congruenceOf(
                           function (firstHalf : Natural) =>
                               firstHalf
                               + ((p2 * successor(d1)) * successor(d3)
                                  + (n3 * successor(d1)) * successor(d2)),
                           hyp1Scaled)
              = ((n1 * successor(d3)) * successor(d2)
                 + (p2 * successor(d1)) * successor(d3))
                + ((n2 * successor(d1)) * successor(d3)
                   + (p3 * successor(d1)) * successor(d2))
                    by congruenceOf(
                           function (secondHalf : Natural) =>
                               ((n1 * successor(d3)) * successor(d2)
                                + (p2 * successor(d1)) * successor(d3))
                               + secondHalf,
                           hyp2Scaled)
              = ((n1 * successor(d3)) * successor(d2)
                 + (n2 * successor(d1)) * successor(d3))
                + ((p2 * successor(d1)) * successor(d3)
                   + (p3 * successor(d1)) * successor(d2))
                    by Natural.add_two_two_swap(
                           (n1 * successor(d3)) * successor(d2),
                           (p2 * successor(d1)) * successor(d3),
                           (n2 * successor(d1)) * successor(d3),
                           (p3 * successor(d1)) * successor(d2));
    -- Step 4: cancel the shared (p2·succ(d1))·succ(d3) and
    -- (n2·succ(d1))·succ(d3) terms via reshuffling and add_cancel_left.
    -- What survives is
    --     (p1·succ(d3))·succ(d2) + (n3·succ(d1))·succ(d2)
    --       = (n1·succ(d3))·succ(d2) + (p3·succ(d1))·succ(d2).
    claim afterCancel
          : (p1 * successor(d3)) * successor(d2)
            + (n3 * successor(d1)) * successor(d2)
            = (n1 * successor(d3)) * successor(d2)
              + (p3 * successor(d1)) * successor(d2)
        by Natural.add_cancel_left(
               (p2 * successor(d1)) * successor(d3)
               + (n2 * successor(d1)) * successor(d3),
               (p1 * successor(d3)) * successor(d2)
               + (n3 * successor(d1)) * successor(d2),
               (n1 * successor(d3)) * successor(d2)
               + (p3 * successor(d1)) * successor(d2),
               calc ((p2 * successor(d1)) * successor(d3)
                     + (n2 * successor(d1)) * successor(d3))
                    + ((p1 * successor(d3)) * successor(d2)
                       + (n3 * successor(d1)) * successor(d2))
                  = ((p1 * successor(d3)) * successor(d2)
                     + (p2 * successor(d1)) * successor(d3))
                    + ((n2 * successor(d1)) * successor(d3)
                       + (n3 * successor(d1)) * successor(d2))
                        by Natural.add_two_two_swap_first(
                               (p2 * successor(d1)) * successor(d3),
                               (n2 * successor(d1)) * successor(d3),
                               (p1 * successor(d3)) * successor(d2),
                               (n3 * successor(d1)) * successor(d2))
                  = ((n1 * successor(d3)) * successor(d2)
                     + (n2 * successor(d1)) * successor(d3))
                    + ((p2 * successor(d1)) * successor(d3)
                       + (p3 * successor(d1)) * successor(d2))
                        by sumOfScaled
                  = ((p2 * successor(d1)) * successor(d3)
                     + (n2 * successor(d1)) * successor(d3))
                    + ((n1 * successor(d3)) * successor(d2)
                       + (p3 * successor(d1)) * successor(d2))
                        by Natural.add_two_two_swap_outer_firsts(
                               (n1 * successor(d3)) * successor(d2),
                               (n2 * successor(d1)) * successor(d3),
                               (p2 * successor(d1)) * successor(d3),
                               (p3 * successor(d1)) * successor(d2)));
    -- Step 5: factor succ(d2) out of both sides, then cancel.
    claim factored
          : (p1 * successor(d3) + n3 * successor(d1)) * successor(d2)
            = (n1 * successor(d3) + p3 * successor(d1)) * successor(d2)
        by Equality.transitivity(
               Natural.distributivity_right(
                   p1 * successor(d3),
                   n3 * successor(d1),
                   successor(d2)),
               Equality.transitivity(
                   afterCancel,
                   Equality.symmetry(
                       Natural.distributivity_right(
                           n1 * successor(d3),
                           p3 * successor(d1),
                           successor(d2)))));
    claim divisorPositive : 1 ≤ successor(d2)
        by Natural.successor_less_or_equal_successor(
               zero, d2, Natural.zero_least(d2));
    Natural.multiply_cancel_right(
        p1 * successor(d3) + n3 * successor(d1),
        n1 * successor(d3) + p3 * successor(d1),
        successor(d2),
        divisorPositive,
        factored)
}

-- Threaded transitivity follows the same destructure-chain pattern as
-- the existing IntegerEquivalent.transitive.
theorem RationalEquivalent.transitive_after_xy
        (p1 n1 d1 p2 n2 d2 : Natural)
        : (z : RationalRepresentative)
          → RationalEquivalent(
                RationalRepresentative.make(p1, n1, d1),
                RationalRepresentative.make(p2, n2, d2))
          → RationalEquivalent(
                RationalRepresentative.make(p2, n2, d2), z)
          → RationalEquivalent(
                RationalRepresentative.make(p1, n1, d1), z)
  | RationalRepresentative.make(p3, n3, d3), hyp1, hyp2 =>
      RationalEquivalent.transitive_natural(
          p1, n1, d1, p2, n2, d2, p3, n3, d3, hyp1, hyp2)

theorem RationalEquivalent.transitive_after_x
        (p1 n1 d1 : Natural)
        : (y z : RationalRepresentative)
          → RationalEquivalent(
                RationalRepresentative.make(p1, n1, d1), y)
          → RationalEquivalent(y, z)
          → RationalEquivalent(
                RationalRepresentative.make(p1, n1, d1), z)
  | RationalRepresentative.make(p2, n2, d2), z, hyp1, hyp2 =>
      RationalEquivalent.transitive_after_xy(
          p1, n1, d1, p2, n2, d2, z, hyp1, hyp2)

theorem RationalEquivalent.transitive
        : (x y z : RationalRepresentative)
          → RationalEquivalent(x, y)
          → RationalEquivalent(y, z)
          → RationalEquivalent(x, z)
  | RationalRepresentative.make(p1, n1, d1), y, z, hyp1, hyp2 =>
      RationalEquivalent.transitive_after_x(
          p1, n1, d1, y, z, hyp1, hyp2)

-- ----------------------------------------------------------------------
-- The Rational type and a few canonical constants.

definition Rational : Type(0) :=
  Quotient.{0}(RationalRepresentative, RationalEquivalent)

definition Rational.zero : Rational :=
  Quotient.mk.{0}(
      RationalRepresentative, RationalEquivalent,
      RationalRepresentative.make(zero, zero, zero))

definition Rational.one : Rational :=
  Quotient.mk.{0}(
      RationalRepresentative, RationalEquivalent,
      RationalRepresentative.make(successor(zero), zero, zero))

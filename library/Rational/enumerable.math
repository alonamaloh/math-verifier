-- Rational/enumerable.math
--
-- The denumerability of the rational numbers (Freek #3). A rational is
-- a class of (numerator, denominator) representatives; the integers
-- are countable (Integer/enumerable.math), pairs are countable
-- (the diagonal enumeration), and quotients of countable types are
-- countable — so ℚ is listed by composing the three.

module Rational.enumerable

import axioms
import Logic.basics
import Logic.exists
import Logic.product
import Logic.functions
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Natural.triangular
import Natural.pairing
import Set.basics
import Set.cantor
import Set.enumerable
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.sign
import Integer.integral_domain
import Integer.enumerable
import Rational.basics

-- Shared witness step: given any positive-denominator form
-- numCanonical / (k + 1) equal to a target rational, the listing
-- `(i, k) ↦ integerListing(i) / (k + 1)` hits it.
theorem Rational.enumeration_witness
        (integerListing : ℕ → ℤ)
        (integerSurjective : Function.IsSurjective(integerListing))
        (pairListing : ℕ → Product(ℕ, ℕ))
        (pairSurjective : Function.IsSurjective(pairListing))
        (target : ℚ) (numCanonical : ℤ) (k : ℕ)
        (targetEquation : target = numCanonical / ((k + 1) : ℤ))
        : ∃ (listIndex : ℕ).
            integerListing(Product.first(pairListing(listIndex)))
            / ((Product.second(pairListing(listIndex)) + 1) : ℤ)
            = target := {
  choose i such that integerListing(i) = numCanonical from integerSurjective(numCanonical);
  choose listIndex such that pairListing(listIndex) = Product.make(i, k)
      from pairSurjective(Product.make(i, k));
  witness listIndex with
      integerListing(Product.first(pairListing(listIndex)))
           / ((Product.second(pairListing(listIndex)) + 1) : ℤ)
         = integerListing(Product.first(Product.make(i, k)))
           / ((Product.second(Product.make(i, k)) + 1) : ℤ)
         = numCanonical / ((k + 1) : ℤ)
         = target
}

-- Freek #3: ℚ is denumerable. Enumerate via (i, k) ↦ integerListing(i) /
-- (k + 1); every rational has a positive-denominator form, found by
-- sign-splitting the denominator.
theorem Rational.is_enumerable : IsEnumerable(ℚ) := {
  choose integerListing such that Function.IsSurjective(integerListing)
      from Integer.is_enumerable;
  choose pairListing such that Function.IsSurjective(pairListing)
      from Natural.pairs_enumerable;
  witness ((listIndex : ℕ) ↦
      integerListing(Product.first(pairListing(listIndex)))
      / ((Product.second(pairListing(listIndex)) + 1) : ℤ))
  with {
    take target as RationalRepresentative.make(numerator, denominator, denominatorNonzero) : ℚ;
    Integer.IsNonneg(denominator) ∨ ∃ (k : ℕ). denominator = -(k : ℤ)
        by Integer.sign_split;
    done by cases {
      case Integer.IsNonneg(denominator) as denominatorNonneg: {
          choose m such that denominator = (m : ℤ) from denominatorNonneg;
          m = 0 ∨ ∃ (k : ℕ). m = k + 1;
          done by cases {
            case m = 0 as mIsZero: {
                denominator
                   = (m : ℤ)
                   = ((0 : ℕ) : ℤ)
                   = Integer.zero;
                absurd(denominatorNonzero(denominator = Integer.zero))
              }
            case ∃ (k : ℕ). m = k + 1 as mIsSuccessor: {
                choose k such that m = k + 1 from mIsSuccessor;
                numerator * ((k + 1) : ℤ)
                   = numerator * (m : ℤ)
                   = numerator * denominator;
                Rational.fraction(numerator, denominator, denominatorNonzero)
                      = numerator / ((k + 1) : ℤ);
                done
              }
          }
        }
      case ∃ (k : ℕ). denominator = -(k : ℤ) as denominatorNegated: {
          choose m such that denominator = -(m : ℤ) from denominatorNegated;
          m = 0 ∨ ∃ (k : ℕ). m = k + 1;
          done by cases {
            case m = 0 as mIsZero: {
                denominator
                   = -(m : ℤ)
                   = -((0 : ℕ) : ℤ)
                   = Integer.zero;
                absurd(denominatorNonzero(denominator = Integer.zero))
              }
            case ∃ (k : ℕ). m = k + 1 as mIsSuccessor: {
                choose k such that m = k + 1 from mIsSuccessor;
                numerator * ((k + 1) : ℤ)
                   = numerator * (m : ℤ)
                   = -numerator * -(m : ℤ)
                   = -numerator * denominator;
                Rational.fraction(numerator, denominator, denominatorNonzero)
                      = -numerator / ((k + 1) : ℤ);
                done
              }
          }
        }
    }
  }
}

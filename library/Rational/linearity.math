-- Rational/linearity.math
--
-- Linearity of the Rational order. With excluded_middle in scope,
-- every two Rationals are comparable, and ¬(a < b) gives b ≤ a.
-- These match the standard "totally-ordered field" facts about
-- Rational and unlock contrapositive-flavored reasoning the
-- constructive lemmas in `Rational/order_arithmetic.math` don't
-- provide.

module Rational.linearity

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Integer.basics
import Integer.embedding
import Integer.negation
import Integer.order
import Integer.sign
import Integer.absolute_value
import Rational.basics
import Rational.addition
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.absolute_value
import Rational.instances
import Algebra.ring_lemmas

-- ----------------------------------------------------------------------
-- Every Rational is either non-negative or its negation is.
-- Quotient.induct over `value`; at a representative `make(numerator,
-- denominator)`, IsNonneg reduces to Integer.IsNonneg(numerator).
-- For -value, it reduces to Integer.IsNonneg(-numerator). Apply
-- Integer.sign_split(numerator); on the "numerator = -(k : Integer)"
-- branch, -numerator = (k : Integer), which is non-negative.
automatic theorem Rational.IsNonneg_or_negate_IsNonneg
        (value : Rational)
        : Rational.IsNonneg(value) ∨ Rational.IsNonneg(-value) :=
  by_representatives value as ⟨numerator, denominator, denominatorNonzero⟩ => {
      -- Split on the sign of the sign-witness numerator · denominator.
      Integer.SignSplitProp(numerator * denominator) by Integer.sign_split;
      done by cases {
        case Integer.IsNonneg(numerator * denominator) as productNonneg: {
            Rational.IsNonneg(Rational.fraction(numerator, denominator, denominatorNonzero));
            done
          }
        case (∃ (k : Natural). numerator * denominator = -(k : Integer)) as productNegated: {
            choose k such that numerator * denominator = -(k : Integer) from productNegated;
            -- (−numerator)·denominator = −(numerator·denominator) = (k : Integer) ≥ 0.
            (-numerator) * denominator
               = -(numerator * denominator)
               = -(-(k : Integer))
               = (k : Integer)
            as negatedProductForm;
            Integer.IsNonneg((k : Integer));
            Integer.IsNonneg((-numerator) * denominator) by substituting negatedProductForm;
            Rational.IsNonneg(Rational.fraction(-numerator, denominator, denominatorNonzero));
            done
          }
      }
    }

-- ----------------------------------------------------------------------
-- Algebraic helper used by the linearity argument:
-- `-(right - left) = left - right`. Pure Rational ring identity.
theorem Rational.negate_subtract
        (right left : Rational)
        : -(right - left) = left - right := ring

-- ----------------------------------------------------------------------
-- Linearity of ≤. From the sign-split on `right - left`, derive
-- either `left ≤ right` (Rational.IsNonneg(right - left)) or
-- `right ≤ left` (Rational.IsNonneg(-(right - left)) = IsNonneg(left
-- - right), via `Rational.negate_subtract`).
automatic theorem Rational.LessOrEqual.linear
        (left right : Rational)
        : left ≤ right ∨ right ≤ left :=
  done by cases {
    case Rational.IsNonneg(right - left) as differenceNonneg:
        -- left ≤ right is exactly IsNonneg(right - left).
        done
    case Rational.IsNonneg(-(right - left)) as negatedDifferenceNonneg: {
        -- right ≤ left is IsNonneg(left - right) = IsNonneg(-(right - left)).
        Rational.IsNonneg(left - right) by substituting (left - right = -(right - left));
        done
      }
  }

-- ----------------------------------------------------------------------
-- Contrapositive of <: `¬(a < b)` forces `b ≤ a`. With linearity,
-- either `a ≤ b` or `b ≤ a`. The first case combined with
-- `¬(a < b) = ¬(a ≤ b ∧ ¬(a = b))` forces `a = b`, hence `b ≤ a`
-- by reflexivity. The second case is the conclusion directly.
theorem Rational.not_LessThan_implies_LessOrEqual
        (a b : Rational) (notLessThan : Not(Rational.LessThan(a, b)))
        : b ≤ a :=
  done by cases {
    case a ≤ b as aLeqB:
        done by cases {
          case a = b:
              -- a = b, so b = a and b ≤ a by reflexivity.
              calc b
                 = a
                 ≤ a
          case Not(a = b): {
              -- a ≤ b together with a ≠ b is a < b, contradicting notLessThan.
              a < b as aLessThanB;
              absurd(notLessThan(aLessThanB))
            }
        }
    case b ≤ a as bLeqA: bLeqA
  }

-- A Rational square is nonnegative.
theorem Rational.square_IsNonneg (q : Rational)
        : Rational.IsNonneg(q * q) :=
  done by cases {
    case Rational.IsNonneg(q) as qIsNonneg: {
        Rational.IsNonneg(q * q);
        done
      }
    case Rational.IsNonneg(-q) as negateQIsNonneg: {
        -- (−q)·(−q) = q·q, a product of nonnegatives.
        Rational.IsNonneg((-q) * (-q));
        done by substituting ((-q) * (-q) = q * q)
      }
  }


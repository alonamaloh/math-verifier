-- Rational/minimum.math
--
-- The minimum of two Rationals. The comparison is decided classically
-- (Logic.classical_decidable), so the definition is split into a
-- decidability-parametrized core plus the classical wrapper — the same
-- shape as Real.bisectionStepWithDec: a proof that case-analyzes the
-- decision (via `decide`) sees each arm ι-reduce to the chosen
-- endpoint.

module Rational.minimum

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.classical_decidable
import Natural.peano
import Integer.basics
import Integer.embedding
import Integer.negation
import Integer.order
import Integer.sign
import Integer.absolute_value
import Rational.basics
import Rational.addition
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.absolute_value
import Rational.linearity

-- The core, parametrized by the decision on a ≤ b.
definition Rational.minimumWithDecision
        (a b : Rational) (decision : Logic.Decidable(a ≤ b))
        : Rational :=
  cases decision {
    | Logic.Decidable.yes(_) => a
    | Logic.Decidable.no(_)  => b
  }

-- min(a, b): the smaller of the two.
definition Rational.minimum (a b : Rational) : Rational :=
  Rational.minimumWithDecision(a, b, Logic.classical_decidable(a ≤ b))

overload min := Rational.minimum

-- The characterizing equations: min(a, b) picks whichever endpoint the
-- order selects. These two lemmas are the QUARANTINE BOUNDARY for the
-- decision inside the definition — the one place `decide` refines the
-- `classical_decidable(a ≤ b)` term; every consumer below reasons
-- propositionally through the equations.
theorem Rational.minimum_eq_left (a b : Rational) (aLeqB : a ≤ b)
        : min(a, b) = a :=
  decide a ≤ b {
    | yes _ => {
        note goal : a = a;
        done
      }
    | no notALeqB => absurd(notALeqB(aLeqB))
  }

theorem Rational.minimum_eq_right (a b : Rational) (notALeqB : ¬(a ≤ b))
        : min(a, b) = b :=
  decide a ≤ b {
    | yes aLeqB => absurd(notALeqB(aLeqB))
    | no _ => {
        note goal : b = b;
        done
      }
  }

-- min(a, b) ≤ a. When a ≤ b the minimum is a itself; otherwise it is
-- b, and ¬(a ≤ b) forces b ≤ a by linearity of the order.
theorem Rational.minimum_LessOrEqual_left
        (a b : Rational) : min(a, b) ≤ a :=
  claim by cases {
    case a ≤ b as aLeqB: {
        min(a, b) = a by Rational.minimum_eq_left;
        done by substitution
      }
    otherwise as notALeqB: {
        b ≤ a by cases {
          case a ≤ b as aLeqB: absurd(notALeqB(aLeqB))
          case b ≤ a as bLeqA: bLeqA
        };
        min(a, b) = b   by Rational.minimum_eq_right
                  ≤ a;
        done
      }
  }

-- min(a, b) ≤ b. Symmetric: the yes arm is the hypothesis itself.
theorem Rational.minimum_LessOrEqual_right
        (a b : Rational) : min(a, b) ≤ b :=
  claim by cases {
    case a ≤ b as aLeqB: {
        min(a, b) = a   by Rational.minimum_eq_left
                  ≤ b;
        done
      }
    otherwise: {
        min(a, b) = b by Rational.minimum_eq_right;
        done by substitution
      }
  }

-- The minimum of two positives is positive: whichever endpoint the
-- order picks, its positivity hypothesis is already in context.
theorem Rational.minimum_positive
        (a b : Rational)
        (aPositive : Rational.zero < a) (bPositive : Rational.zero < b)
        : Rational.zero < min(a, b) :=
  claim by cases {
    case a ≤ b: {
        min(a, b) = a by Rational.minimum_eq_left;
        done by substitution
      }
    otherwise: {
        min(a, b) = b by Rational.minimum_eq_right;
        done by substitution
      }
  }

-- Rational/division.math
--
-- Division on the rationals: `a / b := a · reciprocal_function(b)`. The
-- denominator's nonzeroness is a genuine side condition the `/` operator
-- leaves for the auto-prover to discharge at the use site (a decidable
-- `2 ≠ 0`, or a hypothesis in scope) — mirroring `Integer.divide` in
-- Rational/basics, so `ε / 2` and `(ε / 2) / roof` read
-- plainly while staying mathematically honest.

module Rational.division

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Integer.basics
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.halve
import Rational.positive
import Rational.reciprocal_function
import Rational.archimedean

definition Rational.divide
        (a b : ℚ) (denominatorNonzero : b ≠ Rational.zero)
        : ℚ :=
  a * Rational.reciprocal_function(b)

operator (/) on (Rational, Rational) := Rational.divide

-- 0 < 2 in ℚ — `1 + 1`, each summand above zero.
theorem Rational.two_positive : Rational.zero < (2 : ℚ) :=
  (0 : ℚ)
     = (0 : ℚ) + (0 : ℚ)
     < (1 : ℚ) + (1 : ℚ)
           by Rational.LessThan.add_strict_strict
     = (2 : ℚ)

-- 2 ≠ 0 in ℚ — the side condition every `/2` use site discharges.
theorem Rational.two_is_nonzero : (2 : ℚ) ≠ Rational.zero := {
  Rational.zero < (2 : ℚ);
  done
}

-- Quotients agree whenever their denominators do, whatever nonzero
-- proofs they carry: ℚ division is a·reciprocal_function(b), and the
-- total reciprocal_function is proof-free, so this is congruence. A
-- transport motive cannot abstract a denominator (the carried proof's
-- TYPE mentions it), so denominator rewrites go through this lemma.
automatic theorem Rational.divide_denominator_congruence
        (a b c : ℚ) (bNonzero : b ≠ Rational.zero) (cNonzero : c ≠ Rational.zero)
        (denominatorsEqual : b = c)
        : a / b = a / c := {
  a * Rational.reciprocal_function(b) = a * Rational.reciprocal_function(c)
      by substituting denominatorsEqual;
  done
}

-- b · (a / b) = a — the cancellation tolerances lean on. The `bNonzero`
-- hypothesis is what the `/` operator's side-condition hole resolves to,
-- so `a / b` here elaborates to `divide(a, b, bNonzero)` with the proof a
-- bound variable — a unifiable slot the citation matcher binds to whatever
-- proof a use site carries (this kernel has no definitional proof
-- irrelevance, so a *compound* proof baked in would not match across sites).
theorem Rational.divide_cancel (a b : ℚ) (bNonzero : b ≠ Rational.zero)
        : b * (a / b) = a := {
  b * Rational.reciprocal_function(b) = Rational.one
      by Rational.reciprocal_function_multiplies as bReciprocal;
  b * (a / b)
     = b * (a * Rational.reciprocal_function(b))
     = a * (b * Rational.reciprocal_function(b))
     = a * Rational.one                            by substituting bReciprocal
     = a
}

-- Left cancellation: c ≠ 0 and c·a = c·b give a = b (multiply by 1/c).
-- `field`'s denominator-clearing route multiplies both sides through by
-- the product of the denominators and concludes with this lemma — the
-- ℚ twin of Real.equal_of_multiply_left.
theorem Rational.equal_of_multiply_left (a b c : ℚ)
        (cNonzero : c ≠ Rational.zero)
        (cancellable : c * a = c * b) : a = b := {
  a
     = Rational.reciprocal_function(c) * (c * a)   by field(cNonzero)
     = Rational.reciprocal_function(c) * (c * b)
     = b                                           by field(cNonzero)
}

-- a / b is positive when both a and b are.
theorem Rational.divide_positive (a b : ℚ) (bNonzero : b ≠ Rational.zero)
        (aPositive : Rational.zero < a) (bPositive : Rational.zero < b)
        : Rational.zero < a / b := {
  Rational.zero < Rational.reciprocal_function(b);
  done by Rational.multiply_positive_positive
}

-- a / b is nonnegative when a is nonnegative and b is positive.
automatic theorem Rational.divide_nonneg (a b : ℚ) (bNonzero : b ≠ Rational.zero)
        (aNonneg : a ≥ Rational.zero) (bPositive : b > Rational.zero)
        : a / b ≥ Rational.zero := {
  Rational.zero < Rational.reciprocal_function(b)
      by Rational.reciprocal_function_positive_of_positive;
  Rational.zero ≤ Rational.reciprocal_function(b);
  Rational.IsNonneg(a);
  Rational.IsNonneg(Rational.reciprocal_function(b));
  Rational.IsNonneg(a * Rational.reciprocal_function(b));
  done
}

-- a / b is nonzero when both a and b are.
automatic theorem Rational.divide_nonzero (a b : ℚ) (bNonzero : b ≠ Rational.zero)
        (aNonzero : a ≠ Rational.zero)
        : a / b ≠ Rational.zero := {
  Rational.reciprocal_function(b) ≠ Rational.zero;
  done by Rational.multiply_nonzero
}

-- x / 2 + x / 2 = x — the ε/2 split. The `/2` side condition resolves to
-- the global `two_is_nonzero`, the same proof every `/2` use site carries,
-- so the two occurrences match by that shared constant.
theorem Rational.divide_two_doubled (x : ℚ) : x / 2 + x / 2 = x := {
  (2 : ℚ) * Rational.reciprocal_function((2 : ℚ)) = Rational.one
      by Rational.reciprocal_function_multiplies as twoReciprocal;
  x / 2 + x / 2
     = x * Rational.reciprocal_function((2 : ℚ))
       + x * Rational.reciprocal_function((2 : ℚ))
     = x * ((2 : ℚ) * Rational.reciprocal_function((2 : ℚ)))
     = x * Rational.one                                                      by substituting twoReciprocal
     = x
}

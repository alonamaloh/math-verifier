-- Rational/halve.math
--
-- The Rational `1/2` and `halve(q) := q * (1/2)`. Key properties:
-- `halve(q) + halve(q) = q`, `0 < halve(positive)`. Used for the
-- standard ε/2 split in analytic proofs.

module Rational.halve

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Integer.sign
import Integer.absolute_value
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value

-- 1/2 : numerator 1 over the denominator 2 = 2.
definition Rational.one_half : Rational :=
  Rational.fraction(
      Integer.one, (2 : Integer), Integer.from_natural_successor_nonzero(1))

-- The key identity: 1/2 + 1/2 = 1. The combined denominator is 2·2 and the
-- numerator 1·2 + 1·2; equivalence to 1/1 needs `2 = 1 + 1` made concrete so
-- ring can fold `(2 + 2)·1 = 1·(2·2)`.
theorem Rational.one_half_doubled
        : Rational.one_half + Rational.one_half = Rational.one :=
  Quotient.sound(
      Rational.add_representatives(
          RationalRepresentative.make(
              Integer.one, (2 : Integer),
              Integer.from_natural_successor_nonzero(1)),
          RationalRepresentative.make(
              Integer.one, (2 : Integer),
              Integer.from_natural_successor_nonzero(1))),
      RationalRepresentative.make(Integer.one, Integer.one, Integer.one_is_nonzero),
      {
        claim castTwo : (2 : Integer) = Integer.one + Integer.one
            by calc (2 : Integer)
                  = Integer.one + (1 : Integer)        by Natural.to_integer.successor_preserves
                  = Integer.one + Integer.one          by substituting Natural.to_integer.one_preserves;
        calc (Integer.one * (2 : Integer) + Integer.one * (2 : Integer)) * Integer.one
           = (Integer.one * (Integer.one + Integer.one) + Integer.one * (Integer.one + Integer.one)) * Integer.one  by substituting castTwo
           = Integer.one * ((Integer.one + Integer.one) * (Integer.one + Integer.one))                             by ring
           = Integer.one * ((2 : Integer) * (2 : Integer))                                   by substituting castTwo
      })

-- Halve a rational: q * (1/2).
definition Rational.halve (q : Rational) : Rational :=
  q * Rational.one_half

-- halve(q) + halve(q) = q. Distributivity + one_half_doubled +
-- multiply_one.
theorem Rational.halve_doubled (q : Rational)
        : Rational.halve(q) + Rational.halve(q) = q :=
  calc Rational.halve(q) + Rational.halve(q)
     = q * Rational.one_half + q * Rational.one_half
     = q * (Rational.one_half + Rational.one_half)
     = q * Rational.one
            by rewrite(Rational.one_half_doubled)
     = q

-- ----------------------------------------------------------------------
-- Rational arithmetic helpers.

-- (a + b) - (a + c) = b - c. Used in respect proofs where the
-- shared left component cancels.
theorem Rational.add_subtract_cancel_left (a b c : Rational)
        : (a + b) - (a + c) = b - c :=
  calc (a + b) - (a + c)
     = b - c

-- (a + b) - (c + b) = a - c. The shared right component cancels.
theorem Rational.add_subtract_cancel_right (a b c : Rational)
        : (a + b) - (c + b) = a - c :=
  calc (a + b) - (c + b)
     = a - c

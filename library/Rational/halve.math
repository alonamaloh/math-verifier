-- Rational/halve.math
--
-- The Rational `1/2` and `halve(q) := q * (1/2)`. Key properties:
-- `halve(q) + halve(q) = q`, `0 < halve(positive)`. Used for the
-- standard ε/2 split in analytic proofs.

module Rational.halve

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Integer.sign
import Integer.absolute_value
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value

-- 2 ≠ 0 in ℤ: the image of a nonzero natural is a valid denominator.
theorem Rational.two_nonzero : (2 : ℤ) ≠ Integer.zero := {
  ¬((2 : ℕ) = 0);
  done
}

-- 1/2 : numerator 1 over denominator 2.
definition Rational.one_half : ℚ :=
  Rational.fraction(Integer.one, (2 : ℤ), Rational.two_nonzero)

-- The key identity: 1/2 + 1/2 = 1. Adding the fractions gives numerator
-- 1·2 + 1·2 over denominator 2·2; the cross-equation with 1/1 is the ring
-- identity (1·2 + 1·2)·1 = 1·(2·2).
theorem Rational.one_half_doubled
        : Rational.one_half + Rational.one_half = Rational.one :=
  let oneHalfRepresentative : RationalRepresentative :=
      RationalRepresentative.make(Integer.one, (2 : ℤ), Rational.two_nonzero) in
  Quotient.equivalent_implies_equal(
      Rational.add_representatives(oneHalfRepresentative, oneHalfRepresentative),
      RationalRepresentative.make(Integer.one, Integer.one, Integer.one_is_nonzero),
      { (Integer.one * (2 : ℤ) + Integer.one * (2 : ℤ)) * Integer.one
         = Integer.one * ((2 : ℤ) * (2 : ℤ)) })

-- Halve a rational: q * (1/2).
definition Rational.halve (q : ℚ) : ℚ :=
  q * Rational.one_half

-- halve(q) + halve(q) = q.
theorem Rational.halve_doubled (q : ℚ)
        : Rational.halve(q) + Rational.halve(q) = q :=
  Rational.halve(q) + Rational.halve(q)
     = q * Rational.one_half + q * Rational.one_half
     = q * (Rational.one_half + Rational.one_half)
     = q * Rational.one
            by substituting Rational.one_half_doubled
     = q

-- ----------------------------------------------------------------------
-- Rational arithmetic helpers.

-- (a + b) - (a + c) = b - c. Used in respect proofs where the
-- shared left component cancels.
theorem Rational.add_subtract_cancel_left (a b c : ℚ)
        : (a + b) - (a + c) = b - c :=
  (a + b) - (a + c)
     = b - c

-- (a + b) - (c + b) = a - c. The shared right component cancels.
theorem Rational.add_subtract_cancel_right (a b c : ℚ)
        : (a + b) - (c + b) = a - c :=
  (a + b) - (c + b)
     = a - c

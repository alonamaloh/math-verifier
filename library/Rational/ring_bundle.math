-- Rational/ring_bundle.math
--
-- ℚ as a bundled `Ring` and `CommutativeRing`, mirroring
-- `Real/ring_bundle.math`: bundling ℚ lets the generic ring
-- development — and the `Field` bundle over it — apply to ℚ.

module Rational.ring_bundle

import Logic.basics
import Equality.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Rational.basics
import Rational.addition
import Rational.negation
import Rational.multiplication
import Rational.ring
import Rational.algebra
import Rational.instances

-- ℚ as a bundled ring.
definition Rational.ring : Ring :=
  Ring.make(Rational, Rational.add, Rational.zero, Rational.negate,
      Rational.multiply, Rational.one, Rational.is_ring)

-- Canonical `Ring` for the carrier `Rational`, like `Real.ring` for ℝ.
instance Rational.ring

-- ℚ as a bundled commutative ring (the commutativity witness is exactly
-- `Rational.multiply_commutative`, defeq through the `Ring.make`
-- projections).
definition Rational.commutative_ring : CommutativeRing :=
  CommutativeRing.make(Rational.ring, Rational.multiply_commutative)

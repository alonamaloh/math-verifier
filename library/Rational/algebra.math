-- Rational/algebra.math
--
-- Three-argument ring laws for Rational: associativity of `+` and `·`, and
-- distributivity of `·` over `+`. With denominators now plain nonzero
-- integers, the combined denominator of each side is a product of the
-- d_i's, so every cross-multiplication equivalence is a pure ring identity
-- in the Integer numerators — pull the three representatives and reshape
-- (the additive associativity step still needs an explicit `ring`).

module Rational.algebra

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.ring
import Integer.negation
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.ring

-- ======================================================================
-- Multiplicative associativity.

theorem Rational.multiply_associative (x y z : Rational)
        : (x * y) * z = x * (y * z) := {
  obtain RationalRepresentative.make(n1, d1, _) from x;
  obtain RationalRepresentative.make(n2, d2, _) from y;
  obtain RationalRepresentative.make(n3, d3, _) from z;
  calc ((n1 * n2) * n3) * (d1 * (d2 * d3))
     = (n1 * (n2 * n3)) * ((d1 * d2) * d3)
}

-- ======================================================================
-- Additive associativity.

theorem Rational.add_associative (x y z : Rational)
        : (x + y) + z = x + (y + z) := {
  obtain RationalRepresentative.make(n1, d1, _) from x;
  obtain RationalRepresentative.make(n2, d2, _) from y;
  obtain RationalRepresentative.make(n3, d3, _) from z;
  calc ((n1 * d2 + n2 * d1) * d3 + n3 * (d1 * d2)) * (d1 * (d2 * d3))
     = (n1 * (d2 * d3) + (n2 * d3 + n3 * d2) * d1) * ((d1 * d2) * d3)   by ring
}

-- ======================================================================
-- Left distributivity: `x · (y + z) = x · y + x · z`.

theorem Rational.distributivity_left (x y z : Rational)
        : x * (y + z) = x * y + x * z := {
  obtain RationalRepresentative.make(n1, d1, _) from x;
  obtain RationalRepresentative.make(n2, d2, _) from y;
  obtain RationalRepresentative.make(n3, d3, _) from z;
  calc (n1 * (n2 * d3 + n3 * d2)) * ((d1 * d2) * (d1 * d3))
     = ((n1 * n2) * (d1 * d3) + (n1 * n3) * (d1 * d2)) * (d1 * (d2 * d3))
}

-- Right distributivity: derived from left + multiply_commutative.
theorem Rational.distributivity_right (x y z : Rational)
        : (x + y) * z = x * z + y * z :=
  calc (x + y) * z
     = z * (x + y)
     = z * x + z * y
     = x * z + y * z

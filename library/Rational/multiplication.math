-- Rational/multiplication.math
--
-- Multiplication on Rational, lifted from the textbook formula on
-- representatives:
--     n1/(d1+1) · n2/(d2+1)  =  (n1·n2) / ((d1+1)·(d2+1))
-- The combined denominator-minus-one is the same expression
-- (`d2 + d1·succ(d2)`) used for addition, so we reuse
-- `Rational.lifted_denominator_factors` from Rational.addition.
-- The respect proofs are simpler than addition's — there is no
-- distributivity step, just a four-factor rearrangement that re-pairs
-- the hypothesis-bound factors so the cross-multiplication hypothesis
-- bites directly.

module Rational.multiplication

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.ring
import Rational.basics
import Rational.addition

-- ----------------------------------------------------------------------
-- Multiplication on representatives. Numerator is the Integer product;
-- the combined denominator-minus-one is `d2 + d1·succ(d2)`, identical
-- to the addition case (its successor reduces to `succ(d1)·succ(d2)`).
definition Rational.multiply_representatives
        : RationalRepresentative → RationalRepresentative
          → RationalRepresentative
  | RationalRepresentative.make(n1, d1),
    RationalRepresentative.make(n2, d2) =>
      RationalRepresentative.make(
          Integer.multiply(n1, n2),
          d2 + d1 * successor(d2))

-- ----------------------------------------------------------------------
-- First-argument respect, factored form. With shared denominator
-- factoring (`succ(d1') · succ(d2)`) split into `succ(d1') · succ(d2)`
-- the proof is a three-step calc: re-pair to surface the hypothesis,
-- substitute, re-pair back.

theorem Rational.multiply_respects_first_integer_factored
        (n1 n1Prime n2 : Integer) (d1 d1Prime d2 : Natural)
        (equivalenceHypothesis
            : Integer.multiply(n1,
                    Natural.to_integer(successor(d1Prime))) = Integer.multiply(n1Prime,
                    Natural.to_integer(successor(d1))))
        : Integer.multiply(
                  Integer.multiply(n1, n2),
                  Integer.multiply(
                      Natural.to_integer(successor(d1Prime)),
                      Natural.to_integer(successor(d2)))) = Integer.multiply(
                  Integer.multiply(n1Prime, n2),
                  Integer.multiply(
                      Natural.to_integer(successor(d1)),
                      Natural.to_integer(successor(d2)))) :=
  calc Integer.multiply(
           Integer.multiply(n1, n2),
           Integer.multiply(
               Natural.to_integer(successor(d1Prime)),
               Natural.to_integer(successor(d2))))
     = Integer.multiply(
           Integer.multiply(n1,
               Natural.to_integer(successor(d1Prime))),
           Integer.multiply(n2,
               Natural.to_integer(successor(d2))))
            by Integer.multiply_swap_inner_positions(
                   n1, n2,
                   Natural.to_integer(successor(d1Prime)),
                   Natural.to_integer(successor(d2)))
     = Integer.multiply(
           Integer.multiply(n1Prime,
               Natural.to_integer(successor(d1))),
           Integer.multiply(n2,
               Natural.to_integer(successor(d2))))
            by congruenceOf(
                   function (n1Combined : Integer) =>
                       Integer.multiply(n1Combined,
                           Integer.multiply(n2,
                               Natural.to_integer(successor(d2)))),
                   equivalenceHypothesis)
     = Integer.multiply(
           Integer.multiply(n1Prime, n2),
           Integer.multiply(
               Natural.to_integer(successor(d1)),
               Natural.to_integer(successor(d2))))
            by Equality.symmetry(
                   Integer.multiply_swap_inner_positions(
                       n1Prime, n2,
                       Natural.to_integer(successor(d1)),
                       Natural.to_integer(successor(d2))))

-- Wrap the factored kernel so the conclusion uses
-- `to_integer(succ(_) · succ(_))` directly, matching the form the
-- kernel reduces the RationalEquivalent of the multiplied
-- representatives to.

theorem Rational.multiply_respects_first_integer
        (n1 n1Prime n2 : Integer) (d1 d1Prime d2 : Natural)
        (equivalenceHypothesis
            : Integer.multiply(n1,
                    Natural.to_integer(successor(d1Prime))) = Integer.multiply(n1Prime,
                    Natural.to_integer(successor(d1))))
        : Integer.multiply(
                  Integer.multiply(n1, n2),
                  Natural.to_integer(
                      successor(d1Prime) * successor(d2))) = Integer.multiply(
                  Integer.multiply(n1Prime, n2),
                  Natural.to_integer(
                      successor(d1) * successor(d2))) :=
  calc Integer.multiply(
           Integer.multiply(n1, n2),
           Natural.to_integer(successor(d1Prime) * successor(d2)))
     = Integer.multiply(
           Integer.multiply(n1, n2),
           Integer.multiply(
               Natural.to_integer(successor(d1Prime)),
               Natural.to_integer(successor(d2))))
            by congruenceOf(
                   function (liftedDenominator : Integer) =>
                       Integer.multiply(
                           Integer.multiply(n1, n2),
                           liftedDenominator),
                   Rational.lifted_denominator_factors(d1Prime, d2))
     = Integer.multiply(
           Integer.multiply(n1Prime, n2),
           Integer.multiply(
               Natural.to_integer(successor(d1)),
               Natural.to_integer(successor(d2))))
            by Rational.multiply_respects_first_integer_factored(
                   n1, n1Prime, n2, d1, d1Prime, d2,
                   equivalenceHypothesis)
     = Integer.multiply(
           Integer.multiply(n1Prime, n2),
           Natural.to_integer(successor(d1) * successor(d2)))
            by congruenceOf(
                   function (liftedDenominator : Integer) =>
                       Integer.multiply(
                           Integer.multiply(n1Prime, n2),
                           liftedDenominator),
                   Equality.symmetry(
                       Rational.lifted_denominator_factors(d1, d2)))

-- Destructure chain for first-argument respect at representative level.

theorem Rational.multiply_respects_first_after_first
        (n1 : Integer) (d1 : Natural)
        : (rep1Prime rep2 : RationalRepresentative)
          → RationalEquivalent(
                RationalRepresentative.make(n1, d1), rep1Prime)
          → RationalEquivalent(
                Rational.multiply_representatives(
                    RationalRepresentative.make(n1, d1), rep2),
                Rational.multiply_representatives(rep1Prime, rep2))
  | RationalRepresentative.make(n1Prime, d1Prime),
    RationalRepresentative.make(n2, d2),
    equivalenceHypothesis =>
      Rational.multiply_respects_first_integer(
          n1, n1Prime, n2, d1, d1Prime, d2,
          equivalenceHypothesis)

theorem Rational.multiply_respects_first
        : (rep1 rep1Prime rep2 : RationalRepresentative)
          → RationalEquivalent(rep1, rep1Prime)
          → RationalEquivalent(
                Rational.multiply_representatives(rep1, rep2),
                Rational.multiply_representatives(rep1Prime, rep2))
  | RationalRepresentative.make(n1, d1),
    rep1Prime, rep2, equivalenceHypothesis =>
      Rational.multiply_respects_first_after_first(
          n1, d1, rep1Prime, rep2, equivalenceHypothesis)

-- ----------------------------------------------------------------------
-- Second-argument respect, factored form. Symmetric: re-pair to
-- surface the hypothesis on the n2 / n2' side, substitute, re-pair
-- back.

theorem Rational.multiply_respects_second_integer_factored
        (n1 n2 n2Prime : Integer) (d1 d2 d2Prime : Natural)
        (equivalenceHypothesis
            : Integer.multiply(n2,
                    Natural.to_integer(successor(d2Prime))) = Integer.multiply(n2Prime,
                    Natural.to_integer(successor(d2))))
        : Integer.multiply(
                  Integer.multiply(n1, n2),
                  Integer.multiply(
                      Natural.to_integer(successor(d1)),
                      Natural.to_integer(successor(d2Prime)))) = Integer.multiply(
                  Integer.multiply(n1, n2Prime),
                  Integer.multiply(
                      Natural.to_integer(successor(d1)),
                      Natural.to_integer(successor(d2)))) :=
  calc Integer.multiply(
           Integer.multiply(n1, n2),
           Integer.multiply(
               Natural.to_integer(successor(d1)),
               Natural.to_integer(successor(d2Prime))))
     = Integer.multiply(
           Integer.multiply(n1,
               Natural.to_integer(successor(d1))),
           Integer.multiply(n2,
               Natural.to_integer(successor(d2Prime))))
            by Integer.multiply_swap_inner_positions(
                   n1, n2,
                   Natural.to_integer(successor(d1)),
                   Natural.to_integer(successor(d2Prime)))
     = Integer.multiply(
           Integer.multiply(n1,
               Natural.to_integer(successor(d1))),
           Integer.multiply(n2Prime,
               Natural.to_integer(successor(d2))))
            by congruenceOf(
                   function (n2Combined : Integer) =>
                       Integer.multiply(
                           Integer.multiply(n1,
                               Natural.to_integer(successor(d1))),
                           n2Combined),
                   equivalenceHypothesis)
     = Integer.multiply(
           Integer.multiply(n1, n2Prime),
           Integer.multiply(
               Natural.to_integer(successor(d1)),
               Natural.to_integer(successor(d2))))
            by Equality.symmetry(
                   Integer.multiply_swap_inner_positions(
                       n1, n2Prime,
                       Natural.to_integer(successor(d1)),
                       Natural.to_integer(successor(d2))))

theorem Rational.multiply_respects_second_integer
        (n1 n2 n2Prime : Integer) (d1 d2 d2Prime : Natural)
        (equivalenceHypothesis
            : Integer.multiply(n2,
                    Natural.to_integer(successor(d2Prime))) = Integer.multiply(n2Prime,
                    Natural.to_integer(successor(d2))))
        : Integer.multiply(
                  Integer.multiply(n1, n2),
                  Natural.to_integer(
                      successor(d1) * successor(d2Prime))) = Integer.multiply(
                  Integer.multiply(n1, n2Prime),
                  Natural.to_integer(
                      successor(d1) * successor(d2))) :=
  calc Integer.multiply(
           Integer.multiply(n1, n2),
           Natural.to_integer(successor(d1) * successor(d2Prime)))
     = Integer.multiply(
           Integer.multiply(n1, n2),
           Integer.multiply(
               Natural.to_integer(successor(d1)),
               Natural.to_integer(successor(d2Prime))))
            by congruenceOf(
                   function (liftedDenominator : Integer) =>
                       Integer.multiply(
                           Integer.multiply(n1, n2),
                           liftedDenominator),
                   Rational.lifted_denominator_factors(d1, d2Prime))
     = Integer.multiply(
           Integer.multiply(n1, n2Prime),
           Integer.multiply(
               Natural.to_integer(successor(d1)),
               Natural.to_integer(successor(d2))))
            by Rational.multiply_respects_second_integer_factored(
                   n1, n2, n2Prime, d1, d2, d2Prime,
                   equivalenceHypothesis)
     = Integer.multiply(
           Integer.multiply(n1, n2Prime),
           Natural.to_integer(successor(d1) * successor(d2)))
            by congruenceOf(
                   function (liftedDenominator : Integer) =>
                       Integer.multiply(
                           Integer.multiply(n1, n2Prime),
                           liftedDenominator),
                   Equality.symmetry(
                       Rational.lifted_denominator_factors(d1, d2)))

theorem Rational.multiply_respects_second_after_first_second
        (n1 : Integer) (d1 : Natural)
        (n2 : Integer) (d2 : Natural)
        : (rep2Prime : RationalRepresentative)
          → RationalEquivalent(
                RationalRepresentative.make(n2, d2), rep2Prime)
          → RationalEquivalent(
                Rational.multiply_representatives(
                    RationalRepresentative.make(n1, d1),
                    RationalRepresentative.make(n2, d2)),
                Rational.multiply_representatives(
                    RationalRepresentative.make(n1, d1), rep2Prime))
  | RationalRepresentative.make(n2Prime, d2Prime),
    equivalenceHypothesis =>
      Rational.multiply_respects_second_integer(
          n1, n2, n2Prime, d1, d2, d2Prime,
          equivalenceHypothesis)

theorem Rational.multiply_respects_second_after_first
        (n1 : Integer) (d1 : Natural)
        : (rep2 rep2Prime : RationalRepresentative)
          → RationalEquivalent(rep2, rep2Prime)
          → RationalEquivalent(
                Rational.multiply_representatives(
                    RationalRepresentative.make(n1, d1), rep2),
                Rational.multiply_representatives(
                    RationalRepresentative.make(n1, d1), rep2Prime))
  | RationalRepresentative.make(n2, d2),
    rep2Prime,
    equivalenceHypothesis =>
      Rational.multiply_respects_second_after_first_second(
          n1, d1, n2, d2, rep2Prime, equivalenceHypothesis)

theorem Rational.multiply_respects_second
        : (rep1 rep2 rep2Prime : RationalRepresentative)
          → RationalEquivalent(rep2, rep2Prime)
          → RationalEquivalent(
                Rational.multiply_representatives(rep1, rep2),
                Rational.multiply_representatives(rep1, rep2Prime))
  | RationalRepresentative.make(n1, d1),
    rep2, rep2Prime, equivalenceHypothesis =>
      Rational.multiply_respects_second_after_first(
          n1, d1, rep2, rep2Prime, equivalenceHypothesis)

-- ----------------------------------------------------------------------
-- The lift: Rational.multiply as two nested Quotient.lifts.

definition Rational.multiply_after_first
        (rep1 : RationalRepresentative)
        (secondRational : Rational)
        : Rational :=
  Quotient.lift(
      function (rep2 : RationalRepresentative) =>
          Quotient.mk(
              RationalRepresentative, RationalEquivalent,
              Rational.multiply_representatives(rep1, rep2)),
      function (rep2 rep2Prime : RationalRepresentative)
               (rep2EquivalentRep2Prime
                   : RationalEquivalent(rep2, rep2Prime)) =>
          Quotient.sound(
              Rational.multiply_representatives(rep1, rep2),
              Rational.multiply_representatives(rep1, rep2Prime),
              Rational.multiply_respects_second(
                  rep1, rep2, rep2Prime,
                  rep2EquivalentRep2Prime)),
      secondRational)

theorem Rational.multiply_after_first_respects
        (rep1 rep1Prime : RationalRepresentative)
        (rep1EquivalentRep1Prime
            : RationalEquivalent(rep1, rep1Prime))
        (secondRational : Rational)
        : Rational.multiply_after_first(rep1, secondRational) = Rational.multiply_after_first(rep1Prime, secondRational) :=
  Quotient.induct(
      function (q : Rational) =>
          Rational.multiply_after_first(rep1, q) = Rational.multiply_after_first(rep1Prime, q),
      function (rep2 : RationalRepresentative) =>
          Quotient.sound(
              Rational.multiply_representatives(rep1, rep2),
              Rational.multiply_representatives(rep1Prime, rep2),
              Rational.multiply_respects_first(
                  rep1, rep1Prime, rep2,
                  rep1EquivalentRep1Prime)),
      secondRational)

definition Rational.multiply (firstRational secondRational : Rational)
        : Rational :=
  Quotient.lift(
      function (rep1 : RationalRepresentative) =>
          Rational.multiply_after_first(rep1, secondRational),
      function (rep1 rep1Prime : RationalRepresentative)
               (rep1EquivalentRep1Prime
                   : RationalEquivalent(rep1, rep1Prime)) =>
          Rational.multiply_after_first_respects(
              rep1, rep1Prime, rep1EquivalentRep1Prime,
              secondRational),
      firstRational)

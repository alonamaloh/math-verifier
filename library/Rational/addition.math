-- Rational/addition.math
--
-- Addition on Rational, lifted from the textbook formula on
-- representatives:
--     n1/d1 + n2/d2 = (n1·d2 + n2·d1) / (d1·d2)
-- where numerators and denominators are Integers and the combined
-- denominator d1·d2 is nonzero because ℤ is an integral domain.

module Rational.addition

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.ring
import Integer.integral_domain
import Rational.basics

-- ----------------------------------------------------------------------
-- Addition on representatives. The combined denominator d1·d2 is nonzero
-- (product of nonzero integers), so it is a valid denominator.
definition Rational.add_representatives
        : RationalRepresentative → RationalRepresentative
          → RationalRepresentative
  | RationalRepresentative.make(n1, d1, d1Nonzero),
    RationalRepresentative.make(n2, d2, d2Nonzero) =>
      RationalRepresentative.make(
          n1 * d2 + n2 * d1,
          d1 * d2,
          Integer.multiply_nonzero(d1, d2, d1Nonzero, d2Nonzero))

-- ----------------------------------------------------------------------
-- Respect in each argument. The cross-multiplication equivalence of the
-- two combined representatives is a ring identity once the hypothesis
-- `n1·d1' = n1'·d1` (resp. `n2·d2' = n2'·d2`) is applied to the one term
-- where it bites.

theorem Rational.add_respects_first
        : (rep1 rep1Prime rep2 : RationalRepresentative)
          → RationalEquivalent(rep1, rep1Prime)
          → RationalEquivalent(
                Rational.add_representatives(rep1, rep2),
                Rational.add_representatives(rep1Prime, rep2))
  | RationalRepresentative.make(n1, d1, _),
    RationalRepresentative.make(n1Prime, d1Prime, _),
    RationalRepresentative.make(n2, d2, _),
    equivalenceHypothesis =>
      calc (n1 * d2 + n2 * d1) * (d1Prime * d2)
         = (n1 * d1Prime) * (d2 * d2) + (n2 * d1 * d1Prime) * d2   by ring
         = (n1Prime * d1) * (d2 * d2) + (n2 * d1 * d1Prime) * d2   by substituting equivalenceHypothesis
         = (n1Prime * d2 + n2 * d1Prime) * (d1 * d2)               by ring

theorem Rational.add_respects_second
        : (rep1 rep2 rep2Prime : RationalRepresentative)
          → RationalEquivalent(rep2, rep2Prime)
          → RationalEquivalent(
                Rational.add_representatives(rep1, rep2),
                Rational.add_representatives(rep1, rep2Prime))
  | RationalRepresentative.make(n1, d1, _),
    RationalRepresentative.make(n2, d2, _),
    RationalRepresentative.make(n2Prime, d2Prime, _),
    equivalenceHypothesis =>
      calc (n1 * d2 + n2 * d1) * (d1 * d2Prime)
         = (n2 * d2Prime) * (d1 * d1) + (n1 * d1 * d2Prime) * d2   by ring
         = (n2Prime * d2) * (d1 * d1) + (n1 * d1 * d2Prime) * d2   by substituting equivalenceHypothesis
         = (n1 * d2Prime + n2Prime * d1) * (d1 * d2)               by ring

-- ----------------------------------------------------------------------
-- Add the fraction representatives; well-defined in each argument by the
-- two *_respects lemmas. The binary define-by-representatives synthesises
-- the nested lift over both arguments.
definition Rational.add : Rational → Rational → Rational
  by representatives a, c ↦ Quotient.mk(Rational.add_representatives(a, c))
  well_defined by Rational.add_respects_first, Rational.add_respects_second

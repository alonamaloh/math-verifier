-- Rational/addition.math
--
-- Addition on Rational, lifted from the textbook formula on
-- representatives:
--     n1/(d1+1) + n2/(d2+1)
--       = (n1·(d2+1) + n2·(d1+1)) / ((d1+1)·(d2+1))
-- where both numerators are Integers and both denominators are
-- positive Naturals. With our representative
-- `make(n : Integer, denominatorMinusOne : Natural)`, the formula
-- becomes:
--     numerator            = n1·succ(d2) + n2·succ(d1)
--     denominatorMinusOne  = d2 + d1·succ(d2)
-- The latter identity uses succ(d1)·succ(d2) = succ(d2 +
-- d1·succ(d2)), which is the kernel reduction of Natural.multiply
-- on its first argument.

module Rational.addition

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.ring
import Rational.basics

-- ----------------------------------------------------------------------
-- Addition on representatives.
definition Rational.add_representatives
        : RationalRepresentative → RationalRepresentative
          → RationalRepresentative
  | RationalRepresentative.make(n1, d1),
    RationalRepresentative.make(n2, d2) =>
      RationalRepresentative.make(
          Integer.add(
              Integer.multiply(n1, Natural.to_integer(successor(d2))),
              Integer.multiply(n2, Natural.to_integer(successor(d1)))),
          d2 + d1 * successor(d2))

-- A small lemma we'll need repeatedly when verifying that addition
-- respects the equivalence relation: the Integer corresponding to a
-- product of two positive-Natural successors factors as the product
-- of their individual Integer lifts.
theorem Rational.lifted_denominator_factors (d1 d2 : Natural)
        : Equality.{0}(Integer,
              Natural.to_integer(successor(d1) * successor(d2)),
              Integer.multiply(Natural.to_integer(successor(d1)),
                                Natural.to_integer(successor(d2)))) :=
  Natural.to_integer.multiply_preserves(successor(d1), successor(d2))

-- The respect-proofs for both arguments + the Quotient.lift wiring
-- for Rational.add itself remain. The proof shape is mechanical
-- (mirroring Integer.add) but the calc chains are large Integer-
-- algebra rearrangements (~150 lines each). Tracking this as the
-- next focused chunk in TODO.md.

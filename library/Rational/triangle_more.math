-- Rational/triangle_more.math
--
-- Reverse-triangle inequalities and the "absolute value equals
-- the value when sign is known" identifiers used by `Real`'s
-- absolute-value construction. Also provides the Integer-level
-- "|x| = x when IsNonneg" helper which the Rational version
-- cascades through.

module Rational.triangle_more

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Integer.order_multiply
import Integer.absolute_value
import Integer.absolute_value_natural
import Integer.absolute_value_multiplicative
import Integer.integral_domain
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.order_arithmetic
import Rational.positive
import Rational.absolute_value
import Rational.triangle
import Rational.linearity
import Rational.order_multiplication

-- ----------------------------------------------------------------------
-- Integer-level: IsNonneg(x) → |x| = x.

theorem Integer.absolute_value_when_nonneg
        (x : Integer) (xIsNonneg : Integer.IsNonneg(x))
        : abs(x) = x := {
    choose n as xIsImage from xIsNonneg;
    calc abs(x)
       = abs((n : Integer))
       = (n : Integer)
       = x
}

-- For a fraction n/d with n·d ≥ 0, |n|·d = n·|d| (the cross-multiplication
-- that makes |n|/|d| equal to n/d). Cancel a common d after using
-- |n|·|d| = |n·d| = n·d and d² = |d|².
theorem Integer.absolute_value_numerator_cross
        (n d : Integer) (denominatorNonzero : ¬(d = Integer.zero))
        (productNonneg : Integer.IsNonneg(n * d))
        : abs(n) * d = n * abs(d) := {
  calc abs(n) * abs(d)
     = abs(n * d)   since Integer.absolute_value_multiplicative
     = n * d        since Integer.absolute_value_when_nonneg
  as absoluteProduct;
  claim Integer.IsNonneg(d * d) since Integer.square_IsNonneg;
  calc d * d
     = abs(d * d)        since Integer.absolute_value_when_nonneg
     = abs(d) * abs(d)   since Integer.absolute_value_multiplicative
  as squareAbsolute;
  calc (abs(n) * d) * d
     = abs(n) * (d * d)
     = abs(n) * (abs(d) * abs(d))
     = (abs(n) * abs(d)) * abs(d)
     = (n * d) * abs(d)
     = (n * abs(d)) * d
  as cancelEquation;
  done by Integer.multiply_cancel_right_by_nonzero
}

-- ----------------------------------------------------------------------
-- Rational-level: IsNonneg(x) → |x| = x.

-- At a representative make(n, d): Rational.absolute_value reduces to
-- mk(make(|n|, d)); Rational.IsNonneg reduces to Integer.IsNonneg(n);
-- so we need mk(make(|n|, d)) = mk(make(n, d)), i.e., congruence on
-- the numerator using Integer.absolute_value_when_nonneg.
theorem Rational.absolute_value_when_nonneg_at_representative
        (rep : RationalRepresentative)
        (representativeIsNonneg : Rational.IsNonneg_at_representative(rep))
        : Rational.absolute_value_at_representative(rep)
          = (Quotient.class_of(rep) : Rational) :=
  cases rep refining representativeIsNonneg {
    | RationalRepresentative.make(n, d, dNonzero) => {
        claim productNonneg : Integer.IsNonneg(n * d)
            since Integer.nonneg_of_zero_less_or_equal;
        Quotient.equivalent_implies_equal(
            RationalRepresentative.make(
                abs(n), abs(d), Integer.absolute_value_nonzero(d, dNonzero)),
            RationalRepresentative.make(n, d, dNonzero),
            Integer.absolute_value_numerator_cross(n, d, dNonzero, productNonneg))
    }
  }

-- |x| = x on Rational when IsNonneg(x). Lift via cases on x.
theorem Rational.absolute_value_when_nonneg
        (x : Rational) (xIsNonneg : Rational.IsNonneg(x))
        : abs(x) = x :=
  cases x refining xIsNonneg {
    | RationalRepresentative.make(n, d, dNonzero) => {
        claim Integer.IsNonneg(n * d)
            since Rational.IsNonneg.numerator_denominator;
        claim representativeIsNonneg : (0 : Integer) ≤ n * d
            since Integer.zero_less_or_equal_of_nonneg;
        Rational.absolute_value_when_nonneg_at_representative(
            RationalRepresentative.make(n, d, dNonzero),
            representativeIsNonneg)
    }
  }

-- |x| = -x on Rational when IsNonneg(-x). From the previous lemma
-- applied to -x: |-x| = -x. And |-x| = |x|, so |x| = -x.
theorem Rational.absolute_value_when_negate_nonneg
        (x : Rational) (negXIsNonneg : Rational.IsNonneg(-x))
        : abs(x) = -x :=
  calc abs(x)
     = abs(-x)
     = -x

-- ----------------------------------------------------------------------
-- IsNonneg basics: 0 ≤ |x| and similar small reductions.

-- Integer level: |n| is always IsNonneg. From
-- absolute_value_natural_is_image: |n| = (|n|_ℕ : I), the embedding
-- of a Natural, which is IsNonneg.
theorem Integer.absolute_value_IsNonneg (n : Integer)
        : Integer.IsNonneg(abs(n)) := {
  -- |n| is the embedding of the Natural |n|_ℕ, which is nonnegative.
  claim Integer.IsNonneg((Integer.absolute_value_natural(n) : Integer))
      since Integer.from_natural_is_nonneg;
  done by substituting Integer.absolute_value_natural_is_image
}

-- |x| < c implies -c < x and x < c. Case split on the sign of x via
-- IsNonneg_or_negate_IsNonneg. Each branch uses absolute_value_when_*
-- to identify |x| with x or -x, then closes via the chain
-- -c < 0 ≤ x  (branch 1)  or  x ≤ 0 < c  (branch 2).
theorem Rational.absolute_value_LessThan_bounds
        (x c : Rational)
        (absLessThan : abs(x) < c)
        : -c < x ∧ x < c := {
    claim Rational.IsNonneg(abs(x)) since Rational.absolute_value_IsNonneg;
    calc Rational.zero
       ≤ abs(x)   since Rational.LessOrEqual_zero_of_IsNonneg
       < c;
    claim by cases {
      case Rational.IsNonneg(x) as xNonneg: {
          -- |x| = x; so x < c, and -c < 0 ≤ x.
          calc -c
             < Rational.zero
             ≤ x;
          calc x
             = abs(x)
             < c;
          done
        }
      case Rational.IsNonneg(-x) as negXNonneg: {
          -- |x| = -x; so -x < c, giving -c < -(-x) = x; and x ≤ 0 < c.
          calc -x
             = abs(x)
             < c;
          calc -c
             < -(-x)
             = x;
          calc x
             ≤ Rational.zero
             < c;
          done
        }
    }
}

-- ----------------------------------------------------------------------
-- Reverse triangle: |a| - |b| ≤ |a - b|.

-- Strategy: |a| = |(a - b) + b| ≤ |a - b| + |b|. Subtract |b| from
-- both sides via Rational.add_preserves_LessOrEqual on +(-|b|).
theorem Rational.absolute_value_difference_le
        (a b : Rational)
        : abs(a) - abs(b)
          ≤ abs(a - b) := {
    -- Triangle applied to (a - b) and b: |(a - b) + b| ≤ |a - b| + |b|.
    -- The equality |(a - b) + b| = |a| comes from (a - b) + b = a by ring.
    calc abs(a)
              = abs((a - b) + b)
                  by (ring : a = (a - b) + b)
              ≤ abs(a - b) + abs(b);
    -- Add -|b| to both sides; the RHS (|a - b| + |b|) + -|b| reduces
    -- to |a - b| by ring.
    calc abs(a) - abs(b)
       = abs(a) + -abs(b)
       ≤ (abs(a - b) + abs(b)) + -abs(b)
       = abs(a - b)
}

-- ----------------------------------------------------------------------
-- Reverse triangle: ||a| - |b|| ≤ |a - b|.

-- Case-split on the sign of (|a| - |b|) via
-- Rational.IsNonneg_or_negate_IsNonneg. In each branch, identify
-- ||a| - |b|| with either |a| - |b| or |b| - |a|, then bound by
-- |a - b| via absolute_value_difference_le.
theorem Rational.absolute_value_reverse_triangle
        (a b : Rational)
        : abs(
              abs(a) - abs(b))
          ≤ abs(a - b) :=
  claim by cases {
    case Rational.IsNonneg(abs(a) - abs(b)) as diffNonneg:
        -- IsNonneg(|a| - |b|), so ||a| - |b|| = |a| - |b| ≤ |a - b|.
        calc abs(
                 abs(a)
                 - abs(b))
           = abs(a)
             - abs(b)
           ≤ abs(a - b)
    case Rational.IsNonneg(-(abs(a) - abs(b))) as negDiffNonneg:
        -- IsNonneg(-(|a| - |b|)), so ||a| - |b|| = |b| - |a| ≤ |b - a| = |a - b|.
        calc abs(
                 abs(a)
                 - abs(b))
           = -(abs(a)
               - abs(b))
           = abs(b)
             - abs(a)
           ≤ abs(b - a)
           = abs(a - b)
  }

-- ----------------------------------------------------------------------
-- Reverse of absolute_value_LessThan_bounds: from -c < x and x < c,
-- conclude |x| < c. Case-split on the sign of x: when x is IsNonneg,
-- |x| = x < c; when -x is IsNonneg, |x| = -x and -c < x gives
-- -x < c after negation.
theorem Rational.absolute_value_LessThan_of_bounds
        (x c : Rational)
        (lowerBound : -c < x) (upperBound : x < c)
        : abs(x) < c :=
  claim by cases {
    case Rational.IsNonneg(x) as xNonneg:
        -- x is IsNonneg, so |x| = x < c directly.
        calc abs(x)
           = x
           < c
    case Rational.IsNonneg(-x) as negXNonneg:
        -- -x is IsNonneg, so |x| = -x; from -c < x, negate to get -x < -(-c) = c.
        calc abs(x)
           = -x
           < -(-c)
           = c
  }

-- ----------------------------------------------------------------------
-- x ≤ |x|: equality when x is nonnegative; otherwise x ≤ -x = |x|.
theorem Rational.le_absolute_value (x : Rational) : x ≤ abs(x) :=
  claim by cases {
    case Rational.IsNonneg(x) as xNonneg:
        calc x
           ≤ x        by Rational.LessOrEqual.reflexive
           = abs(x)   since Rational.absolute_value_when_nonneg
    case Rational.IsNonneg(-x) as negateNonneg: {
        -- x ≤ -x, since -x - x = -x + -x is a sum of nonnegatives.
        claim Rational.IsNonneg(-x + -x) since Rational.IsNonneg.add;
        claim x ≤ -x by substituting (ring : -x + -x = -x - x);
        calc x
           ≤ -x       by (x ≤ -x)
           = abs(x)   since Rational.absolute_value_when_negate_nonneg
      }
  }

-- A lower bound survives subtracting the absolute value, at twice the
-- slack: -δ < x gives -(δ + δ) < x - |x| (the difference is 0 when x is
-- nonnegative, and 2x > -2δ otherwise).
theorem Rational.subtract_absolute_value_lower_bound (x delta : Rational)
        (deltaPositive : Rational.zero < delta)
        (lowerBound : -delta < x)
        : -(delta + delta) < x - abs(x) :=
  claim by cases {
    case Rational.IsNonneg(x) as xNonneg: {
        claim abs(x) = x since Rational.absolute_value_when_nonneg;
        calc Rational.zero
           = Rational.zero + Rational.zero
           < delta + Rational.zero           since Rational.add_preserves_LessThan
           < delta + delta                   since Rational.add_left_preserves_LessThan;
        calc -(delta + delta)
           < Rational.zero    since Rational.negate_LessThan_zero_of_positive
           = x - x
           = x - abs(x)
      }
    case Rational.IsNonneg(-x) as negateNonneg: {
        claim abs(x) = -x since Rational.absolute_value_when_negate_nonneg;
        -- x - |x| = x + x, and each summand exceeds -δ.
        calc -(delta + delta)
           = -delta + -delta
           < x + -delta        since Rational.add_preserves_LessThan
           < x + x             since Rational.add_left_preserves_LessThan
           = x - -x
           = x - abs(x)
      }
  }

-- ----------------------------------------------------------------------
-- Lower bound for a product of almost-nonnegative bounded factors: with
-- -δ < s, -δ < t and both |s|, |t| ≤ B, the product sits above -(B·δ).
-- Case on the sign of t: when t ≥ 0 the worst case is (-δ)·t ≥ -(δ·B);
-- when t < 0 we have |t| < δ, so |s·t| = |s|·|t| ≤ B·δ.
theorem Rational.product_lower_bound_of_lower_bounds (s t delta bound : Rational)
        (deltaPositive : Rational.zero < delta)
        (sLower : -delta < s) (tLower : -delta < t)
        (sBound : abs(s) ≤ bound) (tBound : abs(t) ≤ bound)
        : -(bound * delta) ≤ s * t := {
  claim Rational.zero ≤ delta since Rational.LessThan.weaken;
  calc Rational.zero
     ≤ abs(s)   since Rational.zero_le_absolute_value
     ≤ bound    since sBound;
  claim by cases {
    case Rational.IsNonneg(t) as tNonneg: {
        claim -delta ≤ s since Rational.LessThan.weaken;
        claim scaledLower : -delta * t ≤ s * t
            since Rational.LessOrEqual.multiply_by_nonneg_right;
        calc t
           ≤ abs(t)   since Rational.le_absolute_value
           ≤ bound    since tBound;
        claim delta * t ≤ delta * bound
            since Rational.LessOrEqual.multiply_by_nonneg_left;
        calc -(bound * delta)
           = -(delta * bound)
           ≤ -(delta * t)       by Rational.LessOrEqual.negate
           = -delta * t
           ≤ s * t              since scaledLower
      }
    case Rational.IsNonneg(-t) as negateTNonneg: {
        -- |t| ≤ δ, so the product is within B·δ of zero in absolute value.
        claim absTEquation : abs(t) = -t
            since Rational.absolute_value_when_negate_nonneg;
        claim -t < -(-delta) since Rational.LessThan.negate;
        claim -t < delta by substituting (ring : -(-delta) = delta);
        claim -t ≤ delta since Rational.LessThan.weaken;
        claim absProduct : abs(s * t) = abs(s) * abs(t)
            since Rational.absolute_value_multiplicative;
        claim Rational.IsNonneg(abs(t)) since Rational.absolute_value_IsNonneg;
        claim firstFactor : abs(s) * abs(t) ≤ bound * abs(t)
            since Rational.LessOrEqual.multiply_by_nonneg_right;
        calc abs(t)
           = -t      by absTEquation
           ≤ delta   by (-t ≤ delta);
        claim secondFactor : bound * abs(t) ≤ bound * delta
            since Rational.LessOrEqual.multiply_by_nonneg_left;
        calc abs(s * t)
           = abs(s) * abs(t)   by absProduct
           ≤ bound * abs(t)    by firstFactor
           ≤ bound * delta     by secondFactor;
        -- s·t ≥ -|s·t| ≥ -(B·δ).
        claim -(s * t) ≤ abs(-(s * t)) since Rational.le_absolute_value;
        claim absNegate : abs(-(s * t)) = abs(s * t)
            since Rational.absolute_value_negate;
        claim -(s * t) ≤ abs(s * t) by substituting absNegate;
        calc -(bound * delta)
           ≤ -abs(s * t)    by Rational.LessOrEqual.negate
           ≤ -(-(s * t))    by Rational.LessOrEqual.negate
           = s * t           by ring
      }
  }
}

-- Rational/triangle_more.math
--
-- Reverse-triangle inequalities and the "absolute value equals
-- the value when sign is known" identifiers used by `Real`'s
-- absolute-value construction. Also provides the Integer-level
-- "|x| = x when IsNonneg" helper which the Rational version
-- cascades through.

module Rational.triangle_more

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Integer.absolute_value
import Integer.absolute_value_natural
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.order_arithmetic
import Rational.positive
import Rational.absolute_value
import Rational.triangle
import Rational.linearity

-- ----------------------------------------------------------------------
-- Integer-level: IsNonneg(x) → |x| = x.

theorem Integer.absolute_value_when_nonneg
        (x : Integer) (xIsNonneg : Integer.IsNonneg(x))
        : abs(x) = x := {
    obtain ⟨n, xIsImage⟩ from xIsNonneg;
    calc abs(x)
       = abs((n : Integer))
       = (n : Integer)
       = x
}

-- ----------------------------------------------------------------------
-- Rational-level: IsNonneg(x) → |x| = x.

-- At a representative make(n, d): Rational.absolute_value reduces to
-- mk(make(|n|, d)); Rational.IsNonneg reduces to Integer.IsNonneg(n);
-- so we need mk(make(|n|, d)) = mk(make(n, d)), i.e., congruence on
-- the numerator using Integer.absolute_value_when_nonneg.
theorem Rational.absolute_value_when_nonneg_at_representative
        (rep : RationalRepresentative)
        (representativeIsNonneg : Rational.IsNonneg_at_representative(rep))
        : Rational.absolute_value_at_representative(rep)
          = (Quotient.mk(rep) : Rational) :=
  cases rep refining representativeIsNonneg {
    | RationalRepresentative.make(n, d) =>
        Integer.absolute_value_when_nonneg(n, representativeIsNonneg)
  }

-- |x| = x on Rational when IsNonneg(x). Lift via cases on x.
theorem Rational.absolute_value_when_nonneg
        (x : Rational) (xIsNonneg : Rational.IsNonneg(x))
        : abs(x) = x :=
  
  (cases x refining xIsNonneg {
    | rep =>
        Rational.absolute_value_when_nonneg_at_representative(rep, xIsNonneg)
  })

-- |x| = -x on Rational when IsNonneg(-x). From the previous lemma
-- applied to -x: |-x| = -x. And |-x| = |x|, so |x| = -x.
theorem Rational.absolute_value_when_negate_nonneg
        (x : Rational) (negXIsNonneg : Rational.IsNonneg(-x))
        : abs(x) = -x :=
  calc abs(x)
     = abs(-x)
     = -x

-- ----------------------------------------------------------------------
-- IsNonneg basics: 0 ≤ |x| and similar small reductions.

-- Integer level: |n| is always IsNonneg. From
-- absolute_value_natural_is_image: |n| = (|n|_ℕ : I), the embedding
-- of a Natural, which is IsNonneg.
theorem Integer.absolute_value_IsNonneg (n : Integer)
        : Integer.IsNonneg(abs(n)) :=
  rewrite(
      Equality.symmetry(
          Integer.absolute_value_natural_is_image(n)),
      Integer.from_natural_is_nonneg(
          Integer.absolute_value_natural(n)))

-- |x| is always IsNonneg. At rep level it reduces to
-- Integer.IsNonneg(|n|).
theorem Rational.absolute_value_IsNonneg_at_representative
        : (rep : RationalRepresentative)
          → Rational.IsNonneg(
                Rational.absolute_value_at_representative(rep))
  | RationalRepresentative.make(n, d) =>
      
      (Integer.absolute_value_IsNonneg(n))

-- Restated cleanly: |x| IsNonneg.
theorem Rational.absolute_value_IsNonneg (x : Rational)
        : Rational.IsNonneg(abs(x)) :=
  cases x {
    | rep => Rational.absolute_value_IsNonneg_at_representative(rep)
  }

-- |x| < c implies -c < x and x < c. Case split on the sign of x via
-- IsNonneg_or_negate_IsNonneg. Each branch uses absolute_value_when_*
-- to identify |x| with x or -x, then closes via the chain
-- -c < 0 ≤ x  (branch 1)  or  x ≤ 0 < c  (branch 2).
theorem Rational.absolute_value_LessThan_bounds
        (x c : Rational)
        (absLessThan : abs(x) < c)
        : And(-c < x, x < c) := {
    calc Rational.zero
       ≤ abs(x)
           by Rational.LessOrEqual_zero_of_IsNonneg(
                  abs(x),
                  Rational.absolute_value_IsNonneg(x))
       < c;
    cases Rational.IsNonneg_or_negate_IsNonneg(x) {
      | Or.introduceLeft(xNonneg) =>
          -- |x| = x; so x < c. For -c < x: chain -c < 0 ≤ x.
          ⟨calc -c
              < Rational.zero
              ≤ x,
           calc x
              = abs(x)
              < c⟩
      | Or.introduceRight(negXNonneg) =>
          -- |x| = -x; so -x < c. Negate to get -c < -(-x) = x. And
          -- x < c follows from x ≤ 0 < c.
          ({
            claim -x < c
                by calc -x
                      = abs(x)
                      < c;
            ⟨calc -c
                < -(-x)
                = x,
             calc x
                ≤ Rational.zero
                < c⟩
          } : And(-c < x, x < c))
    }
}

-- ----------------------------------------------------------------------
-- Reverse triangle: |a| - |b| ≤ |a - b|.

-- Strategy: |a| = |(a - b) + b| ≤ |a - b| + |b|. Subtract |b| from
-- both sides via Rational.add_preserves_LessOrEqual on +(-|b|).
theorem Rational.absolute_value_difference_le
        (a b : Rational)
        : abs(a) - abs(b)
          ≤ abs(a - b) := {
    -- Triangle applied to (a - b) and b: |(a - b) + b| ≤ |a - b| + |b|.
    -- The equality |(a - b) + b| = |a| comes from (a - b) + b = a by ring.
    claim
          abs(a)
            ≤ abs(a - b)
              + abs(b)
        by calc abs(a)
              = abs((a - b) + b)
                  by (ring : a = (a - b) + b)
              ≤ abs(a - b) + abs(b);
    -- Add -|b| to both sides; the RHS (|a - b| + |b|) + -|b| reduces
    -- to |a - b| by ring.
    calc abs(a) - abs(b)
       = abs(a) + -abs(b)
       ≤ (abs(a - b) + abs(b)) + -abs(b)
       = abs(a - b)
}

-- ----------------------------------------------------------------------
-- Reverse triangle: ||a| - |b|| ≤ |a - b|.

-- Case-split on the sign of (|a| - |b|) via
-- Rational.IsNonneg_or_negate_IsNonneg. In each branch, identify
-- ||a| - |b|| with either |a| - |b| or |b| - |a|, then bound by
-- |a - b| via absolute_value_difference_le.
theorem Rational.absolute_value_reverse_triangle
        (a b : Rational)
        : abs(
              abs(a) - abs(b))
          ≤ abs(a - b) :=
  cases Rational.IsNonneg_or_negate_IsNonneg(
            abs(a) - abs(b)) {
    | Or.introduceLeft(diffNonneg) =>
        -- Branch 1: IsNonneg(|a| - |b|), so ||a| - |b|| = |a| - |b| ≤ |a - b|.
        calc abs(
                 abs(a)
                 - abs(b))
           = abs(a)
             - abs(b)
           ≤ abs(a - b)
    | Or.introduceRight(negDiffNonneg) =>
        -- Branch 2: IsNonneg(-(|a| - |b|)), so ||a| - |b|| = |b| - |a|.
        -- Bound by |b - a| via absolute_value_difference_le.
        -- Then |b - a| = |a - b| via absolute_value_subtract_swap.
        calc abs(
                 abs(a)
                 - abs(b))
           = -(abs(a)
               - abs(b))
           = abs(b)
             - abs(a)
           ≤ abs(b - a)
           = abs(a - b)
  }

-- ----------------------------------------------------------------------
-- Reverse of absolute_value_LessThan_bounds: from -c < x and x < c,
-- conclude |x| < c. Case-split on the sign of x: when x is IsNonneg,
-- |x| = x < c; when -x is IsNonneg, |x| = -x and -c < x gives
-- -x < c after negation.
theorem Rational.absolute_value_LessThan_of_bounds
        (x c : Rational)
        (lowerBound : -c < x) (upperBound : x < c)
        : abs(x) < c :=
  cases Rational.IsNonneg_or_negate_IsNonneg(x) {
    | Or.introduceLeft(xNonneg) =>
        -- Branch 1: x is IsNonneg, so |x| = x < c directly.
        calc abs(x)
           = x
           < c
    | Or.introduceRight(negXNonneg) =>
        -- Branch 2: -x is IsNonneg, so |x| = -x. From -c < x, negate
        -- both sides to get -x < c.
        calc abs(x)
           = -x
           < -(-c)
           = c
  }

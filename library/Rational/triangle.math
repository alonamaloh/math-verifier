-- Rational/triangle.math
--
-- The Rational triangle inequality |x + y| ≤ |x| + |y| and
-- multiplicativity |x·y| = |x|·|y|. With |n/d| = |n|/|d| and signed
-- denominators, both reduce — via multiplicativity of Integer absolute
-- value (|d1·d2| = |d1|·|d2|) — to facts about the integer numerators.

module Rational.triangle

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.order
import Integer.order_multiply
import Integer.absolute_value
import Integer.absolute_value_multiplicative
import Integer.integral_domain
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value

-- ----------------------------------------------------------------------
-- |x + y| ≤ |x| + |y|.
--
-- At reps the sign-witness of (|x|+|y|) − |x+y| is
--   (A·Q + (−B)·P) · (P·Q),   A = |n1||d2| + |n2||d1|,  B = |n1·d2 + n2·d1|,
--                              P = |d1||d2|,             Q = |d1·d2|.
-- Since Q = P (multiplicativity), this is (A−B)·P³, and A−B ≥ 0 by the
-- Integer triangle inequality, P ≥ 0 as a product of absolute values.
automatic theorem Rational.triangle_inequality (x y : Rational)
        : abs(x + y) ≤ abs(x) + abs(y) :=
  by_representatives x as ⟨n1, d1, _⟩, y as ⟨n2, d2, _⟩ =>
    unfold Rational.IsNonneg in {
      Integer.IsNonneg(
                  (abs(n1) * abs(d2) + abs(n2) * abs(d1))
                  + -abs(n1 * d2 + n2 * d1)) by {
        abs(n1 * d2 + n2 * d1) ≤ abs(n1 * d2) + abs(n2 * d1)
            by Integer.triangle_inequality;
        Integer.IsNonneg(
                  (abs(n1 * d2) + abs(n2 * d1)) - abs(n1 * d2 + n2 * d1));
        done by substituting Integer.absolute_value_multiplicative
      };
      Integer.IsNonneg(abs(d1) * abs(d2));
      Integer.IsNonneg((abs(d1) * abs(d2)) * (abs(d1) * abs(d2)));
      Integer.IsNonneg(
                  (abs(d1) * abs(d2))
                  * ((abs(d1) * abs(d2)) * (abs(d1) * abs(d2))));
      Integer.IsNonneg(
                  ((abs(n1) * abs(d2) + abs(n2) * abs(d1))
                   + -abs(n1 * d2 + n2 * d1))
                  * ((abs(d1) * abs(d2))
                     * ((abs(d1) * abs(d2)) * (abs(d1) * abs(d2)))));
      (0 : ℤ) ≤
                  ((abs(n1) * abs(d2) + abs(n2) * abs(d1))
                   + -abs(n1 * d2 + n2 * d1))
                  * ((abs(d1) * abs(d2))
                     * ((abs(d1) * abs(d2)) * (abs(d1) * abs(d2))));
      abs(d1 * d2) = abs(d1) * abs(d2);
      ((abs(n1) * abs(d2) + abs(n2) * abs(d1)) * abs(d1 * d2)
                   + -abs(n1 * d2 + n2 * d1) * (abs(d1) * abs(d2)))
                  * ((abs(d1) * abs(d2)) * abs(d1 * d2))
             = ((abs(n1) * abs(d2) + abs(n2) * abs(d1)) * (abs(d1) * abs(d2))
                + -abs(n1 * d2 + n2 * d1) * (abs(d1) * abs(d2)))
                  * ((abs(d1) * abs(d2)) * (abs(d1) * abs(d2)))
             = ((abs(n1) * abs(d2) + abs(n2) * abs(d1)) + -abs(n1 * d2 + n2 * d1))
                  * ((abs(d1) * abs(d2)) * ((abs(d1) * abs(d2)) * (abs(d1) * abs(d2))))   by ring
        as witnessEquation;
      done by substituting witnessEquation
    }

-- ----------------------------------------------------------------------
-- |x · y| = |x| · |y|: |n_x·n_y|/|d_x·d_y| ~ (|n_x|·|n_y|)/(|d_x|·|d_y|).
theorem Rational.absolute_value_multiplicative (x y : Rational)
        : abs(x * y) = abs(x) * abs(y) :=
  by_representatives x as ⟨n_x, d_x, _⟩, y as ⟨n_y, d_y, _⟩ =>
    abs(n_x * n_y) * (abs(d_x) * abs(d_y))
       = (abs(n_x) * abs(n_y)) * (abs(d_x) * abs(d_y))   by Integer.absolute_value_multiplicative
       = (abs(n_x) * abs(n_y)) * abs(d_x * d_y)          by Integer.absolute_value_multiplicative

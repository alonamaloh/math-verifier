-- Rational/triangle.math
--
-- The Rational triangle inequality |x + y| ≤ |x| + |y| and
-- multiplicativity |x·y| = |x|·|y|. With |n/d| = |n|/|d| and signed
-- denominators, both reduce — via multiplicativity of Integer absolute
-- value (|d1·d2| = |d1|·|d2|) — to facts about the integer numerators.

module Rational.triangle

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.order
import Integer.order_multiply
import Integer.absolute_value
import Integer.absolute_value_multiplicative
import Integer.integral_domain
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value

-- ----------------------------------------------------------------------
-- |x + y| ≤ |x| + |y|.
--
-- At reps the sign-witness of (|x|+|y|) − |x+y| is
--   (A·Q + (−B)·P) · (P·Q),   A = |n1||d2| + |n2||d1|,  B = |n1·d2 + n2·d1|,
--                              P = |d1||d2|,             Q = |d1·d2|.
-- Since Q = P (multiplicativity), this is (A−B)·P³, and A−B ≥ 0 by the
-- Integer triangle inequality, P ≥ 0 as a product of absolute values.
theorem Rational.triangle_inequality (x y : Rational)
        : abs(x + y) ≤ abs(x) + abs(y) :=
  by_representatives x as ⟨n1, d1, _⟩, y as ⟨n2, d2, _⟩ =>
    unfold Rational.IsNonneg in {
      claim crossTriangle
            : Integer.IsNonneg(
                  (abs(n1) * abs(d2) + abs(n2) * abs(d1))
                  + -abs(n1 * d2 + n2 * d1)) by {
        claim baseLessOrEqual : abs(n1 * d2 + n2 * d1) ≤ abs(n1 * d2) + abs(n2 * d1)
            by Integer.triangle_inequality;
        claim Integer.IsNonneg(
                  (abs(n1 * d2) + abs(n2 * d1)) - abs(n1 * d2 + n2 * d1))
            by Integer.nonneg_difference_of_le(
                   abs(n1 * d2 + n2 * d1), abs(n1 * d2) + abs(n2 * d1),
                   baseLessOrEqual);
        done by substituting Integer.absolute_value_multiplicative
      };
      claim denominatorNonneg : Integer.IsNonneg(abs(d1) * abs(d2)) by {
        claim Integer.IsNonneg(abs(d1)) by Integer.absolute_value_is_nonneg;
        claim Integer.IsNonneg(abs(d2)) by Integer.absolute_value_is_nonneg;
        done by Integer.multiply_nonneg
      };
      claim denominatorSquareNonneg
            : Integer.IsNonneg((abs(d1) * abs(d2)) * (abs(d1) * abs(d2)))
          by Integer.multiply_nonneg(
                 abs(d1) * abs(d2), abs(d1) * abs(d2),
                 denominatorNonneg, denominatorNonneg);
      claim denominatorCubeNonneg
            : Integer.IsNonneg(
                  (abs(d1) * abs(d2))
                  * ((abs(d1) * abs(d2)) * (abs(d1) * abs(d2))))
          by Integer.multiply_nonneg(
                 abs(d1) * abs(d2),
                 (abs(d1) * abs(d2)) * (abs(d1) * abs(d2)),
                 denominatorNonneg, denominatorSquareNonneg);
      claim Integer.IsNonneg(
                  ((abs(n1) * abs(d2) + abs(n2) * abs(d1))
                   + -abs(n1 * d2 + n2 * d1))
                  * ((abs(d1) * abs(d2))
                     * ((abs(d1) * abs(d2)) * (abs(d1) * abs(d2)))))
          by Integer.multiply_nonneg(
                 (abs(n1) * abs(d2) + abs(n2) * abs(d1)) + -abs(n1 * d2 + n2 * d1),
                 (abs(d1) * abs(d2)) * ((abs(d1) * abs(d2)) * (abs(d1) * abs(d2))),
                 crossTriangle, denominatorCubeNonneg);
      claim denominatorFactors : abs(d1 * d2) = abs(d1) * abs(d2)
          by Integer.absolute_value_multiplicative;
      claim witnessEquation
            : ((abs(n1) * abs(d2) + abs(n2) * abs(d1)) * abs(d1 * d2)
               + -abs(n1 * d2 + n2 * d1) * (abs(d1) * abs(d2)))
              * ((abs(d1) * abs(d2)) * abs(d1 * d2))
              = ((abs(n1) * abs(d2) + abs(n2) * abs(d1)) + -abs(n1 * d2 + n2 * d1))
                * ((abs(d1) * abs(d2)) * ((abs(d1) * abs(d2)) * (abs(d1) * abs(d2))))
          by calc ((abs(n1) * abs(d2) + abs(n2) * abs(d1)) * abs(d1 * d2)
                   + -abs(n1 * d2 + n2 * d1) * (abs(d1) * abs(d2)))
                  * ((abs(d1) * abs(d2)) * abs(d1 * d2))
             = ((abs(n1) * abs(d2) + abs(n2) * abs(d1)) * (abs(d1) * abs(d2))
                + -abs(n1 * d2 + n2 * d1) * (abs(d1) * abs(d2)))
                  * ((abs(d1) * abs(d2)) * (abs(d1) * abs(d2)))   by substituting denominatorFactors
             = ((abs(n1) * abs(d2) + abs(n2) * abs(d1)) + -abs(n1 * d2 + n2 * d1))
                  * ((abs(d1) * abs(d2)) * ((abs(d1) * abs(d2)) * (abs(d1) * abs(d2))))   by ring;
      done by substituting witnessEquation
    }

-- ----------------------------------------------------------------------
-- |x · y| = |x| · |y|: |n_x·n_y|/|d_x·d_y| ~ (|n_x|·|n_y|)/(|d_x|·|d_y|).
theorem Rational.absolute_value_multiplicative (x y : Rational)
        : abs(x * y) = abs(x) * abs(y) :=
  by_representatives x as ⟨n_x, d_x, _⟩, y as ⟨n_y, d_y, _⟩ =>
    calc abs(n_x * n_y) * (abs(d_x) * abs(d_y))
       = (abs(n_x) * abs(n_y)) * (abs(d_x) * abs(d_y))   by substituting Integer.absolute_value_multiplicative
       = (abs(n_x) * abs(n_y)) * abs(d_x * d_y)          by substituting Integer.absolute_value_multiplicative

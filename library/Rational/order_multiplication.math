-- Rational/order_multiplication.math
--
-- Multiplicative order arithmetic on Rational: ≤ is preserved when
-- scaling by a non-negative; plus a handful of foundational helpers
-- (`zero_less_one`, `halve_less_than_self`, `absolute_value_IsNonneg`,
-- Archimedean bound). These feed into the Cauchy product / multiply
-- respect proofs.

module Rational.order_multiplication

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.distance
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Integer.sign
import Integer.absolute_value
import Integer.absolute_value_natural
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.order_arithmetic
import Rational.triangle
import Rational.reciprocal

-- The rational image of a natural number is nonnegative. A boundary
-- lemma for the opaque IsNonneg (the cast form): the `unfold` collapses
-- the lift, so call sites cite this name and never pierce the opacity.
automatic theorem Rational.from_natural_is_nonneg (n : Natural)
        : Rational.IsNonneg((n : Rational)) := {
  claim Integer.IsNonneg((n : Integer)) since Integer.from_natural_is_nonneg;
  claim (0 : Integer) ≤ (n : Integer) since Integer.zero_less_or_equal_of_nonneg;
  done by substituting (ring : n * Integer.one = (n : Integer))
      unfolding Rational.IsNonneg
}

-- The same fact in `≤` form, so a call site needing `0 ≤ (n : Rational)`
-- — the non-negativity premise of `multiply_by_nonneg_left/right` — cites
-- it in one step instead of chaining through `IsNonneg`. Mirrors
-- `zero_le_absolute_value`, the directly-citable nonnegativity of `abs`.
automatic theorem Rational.from_natural_LessOrEqual_zero (n : Natural)
        : Rational.zero ≤ (n : Rational) := {
  claim Rational.IsNonneg((n : Rational)) since Rational.from_natural_is_nonneg;
  done since Rational.LessOrEqual_zero_of_IsNonneg
}

-- ----------------------------------------------------------------------
-- Multiplication and negation interaction at Rational.

-- (-x) * y = -(x * y). At reps, both sides have the same denominator
-- and the numerator equality reduces to Integer.multiply_negate_left.
theorem Rational.multiply_negate_left (x y : Rational)
        : (-x) * y = -(x * y) :=
  by_representatives x as ⟨n_x, d_x, _⟩, y as ⟨n_y, d_y, _⟩ =>
      calc ((-n_x) * n_y) * (d_x * d_y)
         = (-(n_x * n_y)) * (d_x * d_y)

-- Distribute multiplication over subtraction: (b - a) * c = b*c - a*c.
theorem Rational.subtract_multiply_distribute (a b c : Rational)
        : (b - a) * c = b * c - a * c :=
  calc (b - a) * c
     = b * c - a * c

-- ----------------------------------------------------------------------
-- Multiplicative monotonicity (weak).

-- a ≤ b ∧ 0 ≤ c → a * c ≤ b * c.
automatic theorem Rational.LessOrEqual.multiply_by_nonneg_right
        (a b c : Rational) (aLeqB : a ≤ b)
        (cNonneg : Rational.LessOrEqual(Rational.zero, c))
        : a * c ≤ b * c := {
  claim Rational.IsNonneg(c) since Rational.IsNonneg_of_LessOrEqual_zero;
  claim Rational.IsNonneg((b - a) * c) since Rational.IsNonneg.multiply;
  -- a·c ≤ b·c, i.e. IsNonneg(b·c − a·c), since b·c − a·c = (b − a)·c ≥ 0.
  claim Rational.IsNonneg(b * c - a * c) by substituting Rational.subtract_multiply_distribute;
  done
}

-- a ≤ b ∧ 0 ≤ c → c * a ≤ c * b. By commutativity.
automatic theorem Rational.LessOrEqual.multiply_by_nonneg_left
        (a b c : Rational) (aLeqB : a ≤ b)
        (cNonneg : Rational.LessOrEqual(Rational.zero, c))
        : c * a ≤ c * b :=
  calc c * a
     = a * c
     ≤ b * c
     = c * b

-- ----------------------------------------------------------------------
-- Foundational positivity helpers.

-- 0 ≠ 1 at Rational. Equal Rational classes give equivalent
-- representatives, descending through Integer to 1 = 0 at Natural —
-- impossible.
automatic theorem Rational.zero_not_equal_one : Rational.zero ≠ Rational.one :=
  (zeroEqOne : Rational.zero = Rational.one) ↦ {
    claim Rational.fraction(Integer.zero, Integer.one, Integer.one_is_nonzero)
            = Rational.fraction(Integer.one, Integer.one, Integer.one_is_nonzero)
        since zeroEqOne;
    -- Equal fractions ⇒ Integer.zero · 1 = Integer.one · 1, i.e. 0 = 1 in ℤ.
    claim crossEquation : Integer.zero * Integer.one = Integer.one * Integer.one
        since Rational.fraction_equal_implies;
    calc (1 : Integer)
       = Integer.one * Integer.one
       = Integer.zero * Integer.one   since crossEquation
       = (0 : Integer);
    claim 1 = 0 since Natural.to_integer.injective;
    absurd(1 = 0)
  }

-- 0 < 1 at Rational. And of (0 ≤ 1) and (0 ≠ 1).
automatic theorem Rational.zero_less_one : Rational.zero < Rational.one := {
  -- Rational.one is 1/1, sign-witness 1·1 = 1 ≥ 0.
  claim oneImage : Integer.one = ((1 : Natural) : Integer) since Natural.to_integer.one_preserves;
  claim Integer.IsNonneg(((1 : Natural) : Integer)) since Integer.from_natural_is_nonneg;
  claim Integer.IsNonneg(Integer.one) by substituting oneImage;
  claim Integer.IsNonneg(Integer.one * Integer.one)
      by substituting (ring : Integer.one * Integer.one = Integer.one);
  claim Rational.IsNonneg(Rational.one) since Rational.IsNonneg.of_numerator_denominator;
  claim Rational.LessOrEqual(Rational.zero, Rational.one) since Rational.LessOrEqual_zero_of_IsNonneg;
  claim Rational.zero ≠ Rational.one since Rational.zero_not_equal_one;
  done
}

-- halve(ε) < ε when 0 < ε.
automatic theorem Rational.halve_less_than_self
        (ε : Rational) (εPos : Rational.zero < ε)
        : Rational.halve(ε) < ε := {
  -- ε − halve(ε) = halve(ε), since ε = halve(ε) + halve(ε).
  calc ε - Rational.halve(ε)
     = (Rational.halve(ε) + Rational.halve(ε))
         - Rational.halve(ε)
            since Rational.halve_doubled
     = Rational.halve(ε)                                       as diffEqualsHalve;
  claim Rational.zero < Rational.halve(ε);
  -- halve(ε) ≤ ε since ε − halve(ε) = halve(ε) ≥ 0.
  claim Rational.IsNonneg(Rational.halve(ε)) since Rational.IsNonneg_of_LessOrEqual_zero;
  claim Rational.IsNonneg(ε - Rational.halve(ε))
      by substituting diffEqualsHalve;
  claim Rational.halve(ε) ≤ ε;
  claim halveDistinct : Rational.zero ≠ Rational.halve(ε) since Rational.LessThan.distinct;
  claim Rational.halve(ε) ≠ ε
      by (halveEqualsε : Rational.halve(ε) = ε) ↦ {
          calc Rational.zero
             = ε - ε                  since (ring : ε - ε = Rational.zero)
             = ε - Rational.halve(ε)  by substituting halveEqualsε
             = Rational.halve(ε)            since diffEqualsHalve;
          done since halveDistinct
      };
  done
}

-- ----------------------------------------------------------------------
-- |q| is non-negative.

-- |q|_at_rep = mk(make(|n|_int, d)) — its numerator is |n|, which is
-- IsNonneg (image of a Natural). So |q| is IsNonneg.
automatic theorem Rational.absolute_value_IsNonneg (q : Rational)
        : Rational.IsNonneg(abs(q)) :=
  -- At a representative make(n, d), |q| has numerator
  -- Integer.absolute_value(n) — the image of a Natural (= distance(a, b)
  -- for n = mk(make(a, b))), hence IsNonneg.
  by_representatives q as ⟨n, d, _⟩ =>
      unfold Rational.IsNonneg in {
        claim Integer.IsNonneg(abs(n)) since Integer.absolute_value_is_nonneg;
        claim Integer.IsNonneg(abs(d)) since Integer.absolute_value_is_nonneg;
        claim Integer.IsNonneg(abs(n) * abs(d)) since Integer.multiply_nonneg;
        done since Integer.zero_less_or_equal_of_nonneg
      }

-- 0 ≤ |q|.
automatic theorem Rational.zero_le_absolute_value (q : Rational)
        : Rational.LessOrEqual(Rational.zero, abs(q)) := {
  claim Rational.IsNonneg(abs(q)) since Rational.absolute_value_IsNonneg;
  done since Rational.LessOrEqual_zero_of_IsNonneg
}

-- ----------------------------------------------------------------------
-- Archimedean property: |q| is bounded by some Natural's image.

-- At rep make(n, d): |q| = |n|/|d| ≤ succ(K) with K := |n| as a Natural,
-- because |d| ≥ 1. The sign-witness of succ(K) − |q| is
--   ((succ(K):I)·|d| + (-|n|)·1) · (1·|d|),
-- which equals ((K:I)·(|d|−1) + |d|) · |d| ≥ 0.
theorem Rational.absolute_value_le_add_one_natural_at_representative
        (n d : Integer) (dNonzero : d ≠ Integer.zero)
        : Rational.LessOrEqual(
              abs(Rational.fraction(n, d, dNonzero)),
              ((Integer.absolute_value_natural(n) + 1) : Rational)) :=
  unfold Rational.IsNonneg in {
    claim absoluteImage : abs(n) = (Integer.absolute_value_natural(n) : Integer)
        since Integer.absolute_value_natural_is_image;
    claim successorImage
          : ((Integer.absolute_value_natural(n) + 1) : Integer)
            = Integer.absolute_value_natural(n) + Integer.one
        since Natural.to_integer.add_one_preserves;
    claim Integer.IsNonneg(abs(d) + -Integer.one)
        since Integer.absolute_value_minus_one_nonneg;
    claim Integer.IsNonneg(abs(d)) since Integer.absolute_value_is_nonneg;
    claim Integer.IsNonneg((Integer.absolute_value_natural(n) : Integer))
        since Integer.from_natural_is_nonneg;
    claim Integer.IsNonneg(
                Integer.absolute_value_natural(n) * (abs(d) + -Integer.one))
        since Integer.multiply_nonneg;
    claim Integer.IsNonneg(
                Integer.absolute_value_natural(n) * (abs(d) + -Integer.one) + abs(d))
        since Integer.IsNonneg.add;
    -- The sign-witness numerator factors as (K·(|d|−1) + |d|) · |d| ≥ 0.
    claim Integer.IsNonneg(
                (Integer.absolute_value_natural(n) * (abs(d) + -Integer.one) + abs(d))
                * abs(d))
        since Integer.multiply_nonneg;
    claim (0 : Integer) ≤
                ((Integer.absolute_value_natural(n) : Integer) * (abs(d) + -Integer.one) + abs(d))
                * abs(d)
        since Integer.zero_less_or_equal_of_nonneg;
    calc (((Integer.absolute_value_natural(n) + 1) : Integer) * abs(d)
          + (-abs(n)) * Integer.one) * (Integer.one * abs(d))
       = (((Integer.absolute_value_natural(n) : Integer) + Integer.one) * abs(d)
          + (-abs(n)) * Integer.one)
         * (Integer.one * abs(d))
             since successorImage
       = (((Integer.absolute_value_natural(n) : Integer) + Integer.one) * abs(d)
          + (-(Integer.absolute_value_natural(n) : Integer)) * Integer.one)
         * (Integer.one * abs(d))
             since absoluteImage
       = (Integer.absolute_value_natural(n) * (abs(d) + -Integer.one) + abs(d))
         * abs(d)                                                          as witnessEquation;
    done by substituting witnessEquation
  }

-- ((n + 1) : Rational) = (n : Rational) + 1. The `n + 1` cast bridge, so
-- consumers add one to a natural-image bound without naming the constructor.
theorem Rational.add_one_cast (n : Natural)
        : ((n + 1) : Rational) = n + Rational.one :=
  calc ((n + 1) : Rational)
     = (n : Rational) + ((1 : Natural) : Rational)   since Rational.from_natural_add_preserves
     = (n : Rational) + Rational.one

-- The headline Archimedean property: for any Rational q, there is a
-- Natural K with |q| ≤ ((K + 1) : Rational).
theorem Rational.absolute_value_le_add_one_natural (q : Rational)
        : ∃ (K : Natural).
            abs(q) ≤ ((K + 1) : Rational) :=
  by_representatives q as ⟨n, d, dNonzero⟩ => {
    claim abs(Rational.fraction(n, d, dNonzero))
            ≤ ((Integer.absolute_value_natural(n) + 1) : Rational)
        since Rational.absolute_value_le_add_one_natural_at_representative;
    witness Integer.absolute_value_natural(n) with done
  }

-- ----------------------------------------------------------------------
-- General additive monotonicity (left-add by any constant) and
-- sum-of-LessOrEqual.

-- c ≤ d → b + c ≤ b + d. General left-add.
automatic theorem Rational.add_general_LessOrEqual_left
        (b c d : Rational) (cLeqD : c ≤ d)
        : b + c ≤ b + d :=
  calc b + c
     = c + b
     ≤ d + b
     = b + d

-- a ≤ b ∧ c ≤ d → a + c ≤ b + d.
automatic theorem Rational.LessOrEqual.sum
        {a b c d : Rational} (aLeqB : a ≤ b) (cLeqD : c ≤ d)
        : a + c ≤ b + d :=
  calc a + c
     ≤ b + c
     ≤ b + d

-- ----------------------------------------------------------------------
-- ε / (K + 1) construction.

-- The reciprocal of (succ(K) : R) packaged as StrictPositiveRational.
-- 1/(succ(K)) = mk(make(succ(zero) : Integer, K)) per the definition.
-- IsNonneg follows from numerator = (1 : Integer) being IsNonneg.
theorem Rational.reciprocal_of_succ_IsNonneg (K : Natural)
        : Rational.IsNonneg(
              StrictPositiveRational.reciprocal(
                  StrictPositiveRational.make(K, 0))) :=
  -- The reciprocal is (0+1)/(K+1); sign-witness (0+1)·(K+1) ≥ 0.
  unfold Rational.IsNonneg in {
    claim Integer.IsNonneg(((0 + 1) : Integer)) since Integer.from_natural_is_nonneg;
    claim Integer.IsNonneg(((K + 1) : Integer)) since Integer.from_natural_is_nonneg;
    claim Integer.IsNonneg(((0 + 1) : Integer) * ((K + 1) : Integer))
        since Integer.multiply_nonneg;
    done since Integer.zero_less_or_equal_of_nonneg
  }

-- 1/(succ(K)) is non-zero.
theorem Rational.reciprocal_of_succ_nonzero (K : Natural)
        : Rational.zero
              ≠ StrictPositiveRational.reciprocal(
                    StrictPositiveRational.make(K, 0)) :=
  (zeroEqRecip
              : Rational.zero
                = StrictPositiveRational.reciprocal(
                      StrictPositiveRational.make(K, 0))) ↦ {
    let denominatorNonzero : ((K + 1) : Integer) ≠ Integer.zero :=
        done since Integer.from_natural_add_one_nonzero;
    -- Equal classes ⇒ 0·(K+1) = (0+1)·1, i.e. 0 = 1 in ℤ.
    claim rationalEquivalence
          : RationalEquivalent(
                RationalRepresentative.make(Integer.zero, Integer.one, Integer.one_is_nonzero),
                RationalRepresentative.make(
                    ((0 + 1) : Integer), ((K + 1) : Integer), denominatorNonzero))
        by Quotient.equal_implies_equivalent(
               RationalRepresentative.make(Integer.zero, Integer.one, Integer.one_is_nonzero),
               RationalRepresentative.make(
                   ((0 + 1) : Integer), ((K + 1) : Integer), denominatorNonzero),
               unfold Rational in zeroEqRecip);
    calc ((0 + 1) : Integer)
       = ((0 + 1) : Integer) * Integer.one
       = Integer.zero * ((K + 1) : Integer)   since rationalEquivalence
       = Integer.zero                          as addOneZero;
    claim addOneNonzero : ((0 + 1) : Integer) ≠ Integer.zero
        since Integer.from_natural_add_one_nonzero;
    absurd(addOneNonzero(addOneZero))
  }

-- 1/(succ(K)) > 0.
theorem Rational.reciprocal_of_succ_positive (K : Natural)
        : Rational.zero
            < StrictPositiveRational.reciprocal(
                  StrictPositiveRational.make(K, 0)) := {
  claim Rational.IsNonneg(
            StrictPositiveRational.reciprocal(StrictPositiveRational.make(K, 0)))
      since Rational.reciprocal_of_succ_IsNonneg;
  claim Rational.LessOrEqual(
            Rational.zero,
            StrictPositiveRational.reciprocal(StrictPositiveRational.make(K, 0)))
      since Rational.LessOrEqual_zero_of_IsNonneg;
  claim Rational.zero
            ≠ StrictPositiveRational.reciprocal(StrictPositiveRational.make(K, 0))
      since Rational.reciprocal_of_succ_nonzero;
  done
}

-- A zero numerator makes a fraction zero, so a nonzero fraction has a
-- nonzero numerator.
theorem Rational.numerator_nonzero
        (n d : Integer) (denominatorNonzero : d ≠ Integer.zero)
        (fractionNonzero : Rational.fraction(n, d, denominatorNonzero) ≠ Rational.zero)
        : n ≠ Integer.zero := {
  suppose n = Integer.zero as numeratorZero;
  -- 0/d ≡ 0/1 since 0·1 = 0·d, so 0/d is the zero class.
  claim RationalEquivalent(
            RationalRepresentative.make(Integer.zero, d, denominatorNonzero),
            RationalRepresentative.make(Integer.zero, Integer.one, Integer.one_is_nonzero))
      since (Integer.zero * Integer.one = Integer.zero * d);
  calc Rational.fraction(n, d, denominatorNonzero)
     = Rational.fraction(Integer.zero, d, denominatorNonzero)   since numeratorZero
     = Rational.zero
         as fractionIsZero;
  absurd(fractionNonzero(fractionIsZero))
}

-- ℚ has no zero divisors: a product of nonzero rationals is nonzero. At
-- reps the cross with 0/1 forces n_x·n_y = 0, impossible for nonzero
-- numerators (ℤ is an integral domain).
automatic theorem Rational.multiply_nonzero
        (x y : Rational)
        (xNonzero : x ≠ Rational.zero) (yNonzero : y ≠ Rational.zero)
        : x * y ≠ Rational.zero :=
  cases x refining xNonzero { | RationalRepresentative.make(n_x, d_x, dxNonzero) =>
    cases y refining yNonzero { | RationalRepresentative.make(n_y, d_y, dyNonzero) => {
      suppose Rational.fraction(n_x, d_x, dxNonzero) * Rational.fraction(n_y, d_y, dyNonzero)
              = Rational.zero as productZero;
      -- Equal classes ⇒ (n_x·n_y)·1 = 0·(d_x·d_y), i.e. n_x·n_y = 0 in ℤ.
      claim crossEquivalence
            : RationalEquivalent(
                  Rational.multiply_representatives(
                      RationalRepresentative.make(n_x, d_x, dxNonzero),
                      RationalRepresentative.make(n_y, d_y, dyNonzero)),
                  RationalRepresentative.make(Integer.zero, Integer.one, Integer.one_is_nonzero))
          by Quotient.equal_implies_equivalent(
                 Rational.multiply_representatives(
                     RationalRepresentative.make(n_x, d_x, dxNonzero),
                     RationalRepresentative.make(n_y, d_y, dyNonzero)),
                 RationalRepresentative.make(Integer.zero, Integer.one, Integer.one_is_nonzero),
                 productZero);
      calc n_x * n_y
         = (n_x * n_y) * Integer.one
         = Integer.zero * (d_x * d_y)   since crossEquivalence
         = Integer.zero;
      claim n_x ≠ Integer.zero by Rational.numerator_nonzero(n_x, d_x, dxNonzero, xNonzero);
      claim n_y ≠ Integer.zero by Rational.numerator_nonzero(n_y, d_y, dyNonzero, yNonzero);
      claim productNumeratorNonzero : n_x * n_y ≠ Integer.zero since Integer.multiply_nonzero;
      absurd(productNumeratorNonzero(n_x * n_y = Integer.zero))
    } } }

-- Multiplication preserves strict positivity: 0 < x, 0 < y → 0 < x·y.
automatic theorem Rational.multiply_positive_positive
        (x y : Rational) (xPos : Rational.zero < x) (yPos : Rational.zero < y)
        : Rational.zero < x * y := {
  -- 0 ≤ x·y since both factors are nonnegative.
  claim Rational.LessOrEqual(Rational.zero, x) since Rational.LessThan.weaken;
  claim Rational.LessOrEqual(Rational.zero, y) since Rational.LessThan.weaken;
  claim Rational.IsNonneg(x) since Rational.IsNonneg_of_LessOrEqual_zero;
  claim Rational.IsNonneg(y) since Rational.IsNonneg_of_LessOrEqual_zero;
  claim Rational.IsNonneg(x * y) since Rational.IsNonneg.multiply;
  claim Rational.LessOrEqual(Rational.zero, x * y) since Rational.LessOrEqual_zero_of_IsNonneg;
  -- x·y ≠ 0 since neither factor is 0 (no zero divisors).
  claim x ≠ Rational.zero since Rational.LessThan.distinct;
  claim y ≠ Rational.zero since Rational.LessThan.distinct;
  claim Rational.zero ≠ x * y by {
    suppose Rational.zero = x * y as zeroEqProduct;
    claim productNonzero : x * y ≠ Rational.zero since Rational.multiply_nonzero;
    absurd(productNonzero(x * y = Rational.zero))
  };
  done
}
-- The packaged value of make(K, 0) is the integer image (K + 1): denominator
-- (0 + 1) is one. `fraction_equal` after unfolding the value / cast, with the
-- cross-equation closed by `(0 + 1 : I) = one`.
theorem Rational.value_at_zero_is_add_one (K : Natural)
        : StrictPositiveRational.value(StrictPositiveRational.make(K, 0))
          = ((K + 1) : Rational) :=
  unfold StrictPositiveRational.value, Integer.to_rational in {
    claim denominatorOne : ((0 + 1) : Integer) = Integer.one;
    claim ((K + 1) : Integer) * Integer.one = ((K + 1) : Integer) * ((0 + 1) : Integer)
        by substituting denominatorOne;
    done since Rational.fraction_equal
  }

-- δ with ((K + 1) : R) · δ ≤ ε. Witness: δ := ε · (1/(K + 1)).
theorem Rational.divide_by_succ_positive
        (ε : Rational) (K : Natural)
        (εPos : Rational.zero < ε)
        : ∃ (δ : Rational).
            Rational.zero < δ ∧ Rational.LessOrEqual(
                    ((K + 1) : Rational) * δ,
                    ε) :=
  {
    let δ : Rational :=
        ε * StrictPositiveRational.reciprocal(StrictPositiveRational.make(K, 0));
    claim Rational.zero < StrictPositiveRational.reciprocal(StrictPositiveRational.make(K, 0))
        since Rational.reciprocal_of_succ_positive;
    claim Rational.zero < δ since Rational.multiply_positive_positive;
    claim StrictPositiveRational.value(StrictPositiveRational.make(K, 0)) = ((K + 1) : Rational)
        since Rational.value_at_zero_is_add_one;
    -- ((K+1) : R) · (ε · (1/(K+1))) = ε · (((K+1) : R) · (1/(K+1))) = ε · 1 = ε.
    calc ((K + 1) : Rational) * δ
       = StrictPositiveRational.value(StrictPositiveRational.make(K, 0)) * δ
       = ε
             * (StrictPositiveRational.value(StrictPositiveRational.make(K, 0))
                * StrictPositiveRational.reciprocal(StrictPositiveRational.make(K, 0)))
       = ε * Rational.one
       = ε
       ≤ ε;
    witness δ with done
  }


-- 0 ≠ 1/2: equal classes would force 0 · succ(1) = 1 · succ(0) at the
-- Integer level, i.e. Integer.zero = Integer.one — same numeral
-- discrimination as zero_not_equal_one.
theorem Rational.zero_not_equal_one_half
        : Rational.zero ≠ Rational.one_half :=
  (zeroEqualsOneHalf : Rational.zero = Rational.one_half) ↦ {
    -- Equal classes ⇒ 0·2 = 1·1, i.e. 0 = 1 in ℤ.
    claim rationalEquivalence
          : RationalEquivalent(
                RationalRepresentative.make(Integer.zero, Integer.one, Integer.one_is_nonzero),
                RationalRepresentative.make(
                    Integer.one, (2 : Integer), Rational.two_nonzero))
        by Quotient.equal_implies_equivalent(
               RationalRepresentative.make(Integer.zero, Integer.one, Integer.one_is_nonzero),
               RationalRepresentative.make(
                   Integer.one, (2 : Integer), Rational.two_nonzero),
               unfold Rational in zeroEqualsOneHalf);
    calc (1 : Integer)
       = Integer.one * Integer.one
       = Integer.zero * (2 : Integer)  since rationalEquivalence
       = (0 : Integer);
    claim 1 = 0 since Natural.to_integer.injective;
    absurd(1 = 0)
  }

-- 0 < 1/2 at Rational. And of (0 ≤ 1/2) and (0 ≠ 1/2).
theorem Rational.one_half_positive : Rational.zero < Rational.one_half := {
  claim Rational.IsNonneg(Rational.one_half) since Rational.one_half_IsNonneg;
  claim Rational.LessOrEqual(Rational.zero, Rational.one_half) since Rational.LessOrEqual_zero_of_IsNonneg;
  claim Rational.zero ≠ Rational.one_half since Rational.zero_not_equal_one_half;
  done
}

-- Rational/order_multiplication.math
--
-- Multiplicative order arithmetic on Rational: ≤ is preserved when
-- scaling by a non-negative; plus a handful of foundational helpers
-- (`zero_less_one`, `halve_less_than_self`, `absolute_value_IsNonneg`,
-- Archimedean bound). These feed into the Cauchy product / multiply
-- respect proofs.

module Rational.order_multiplication

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.distance
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Integer.sign
import Integer.absolute_value
import Integer.absolute_value_natural
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.order_arithmetic
import Rational.triangle
import Rational.reciprocal

-- The rational image of a natural number is nonnegative. Characterising
-- lemma for the opaque IsNonneg: call sites cite it instead of writing
-- `unfold Rational.IsNonneg in (Integer.from_natural_is_nonneg(n))`.
theorem Rational.from_natural_is_nonneg (n : Natural)
        : Rational.IsNonneg((n : Rational)) :=
  (Integer.from_natural_is_nonneg(n))

-- ----------------------------------------------------------------------
-- Multiplication and negation interaction at Rational.

-- (-x) * y = -(x * y). At reps, both sides have the same denominator
-- and the numerator equality reduces to Integer.multiply_negate_left.
theorem Rational.multiply_negate_left_at_representatives
        (n_x n_y : Integer) (d_x d_y : Natural)
        : Rational.fraction(-n_x, d_x)
              * Rational.fraction(n_y, d_y)
          = -(Rational.fraction(n_x, d_x)
              * Rational.fraction(n_y, d_y)) :=
  Integer.multiply_negate_left(n_x, n_y)

theorem Rational.multiply_negate_left (x y : Rational)
        : (-x) * y = -(x * y) :=
  by_representatives x as ⟨n_x, d_x⟩, y as ⟨n_y, d_y⟩ =>
      Rational.multiply_negate_left_at_representatives(n_x, n_y, d_x, d_y)

-- Distribute multiplication over subtraction: (b - a) * c = b*c - a*c.
theorem Rational.subtract_multiply_distribute (a b c : Rational)
        : (b - a) * c = b * c - a * c :=
  calc (b - a) * c
     = b * c - a * c

-- ----------------------------------------------------------------------
-- Multiplicative monotonicity (weak).

-- a ≤ b ∧ 0 ≤ c → a * c ≤ b * c.
theorem Rational.LessOrEqual.multiply_by_nonneg_right
        (a b c : Rational) (aLeqB : a ≤ b)
        (cNonneg : Rational.LessOrEqual(Rational.zero, c))
        : a * c ≤ b * c :=
  rewrite(
      Rational.subtract_multiply_distribute(a, b, c),
      Rational.IsNonneg.multiply(
          b - a, c,
          aLeqB,
          Rational.IsNonneg_of_LessOrEqual_zero(c, cNonneg)))

-- a ≤ b ∧ 0 ≤ c → c * a ≤ c * b. By commutativity.
theorem Rational.LessOrEqual.multiply_by_nonneg_left
        (a b c : Rational) (aLeqB : a ≤ b)
        (cNonneg : Rational.LessOrEqual(Rational.zero, c))
        : c * a ≤ c * b :=
  calc c * a
     = a * c
     ≤ b * c
     = c * b

-- ----------------------------------------------------------------------
-- Foundational positivity helpers.

-- 0 ≠ 1 at Rational. Equal Rational classes give equivalent
-- representatives, descending through Integer to 0 = successor(0) at
-- Natural — impossible.
theorem Rational.zero_not_equal_one : Not(Rational.zero = Rational.one) :=
  (zeroEqOne : Rational.zero = Rational.one) ↦ {
    -- Rational.zero = [Integer.zero / 0], Rational.one = [Integer.one / 0];
    -- equal classes ⇒ Integer.zero · 1 = Integer.one · 1, i.e. the Integers
    -- are equal.
    claim Integer.zero = Integer.one;
    -- Integer.zero = [0 / 0], Integer.one = [successor(0) / 0]; equal classes
    -- ⇒ 0 + 0 = successor(0) + 0, i.e. successor(0) = 0.
    claim successorZeroEqualsZero : successor(0) = (0 : Natural);
    Natural.successor_not_zero(0, successorZeroEqualsZero)
  }

-- 0 < 1 at Rational. And of (0 ≤ 1) and (0 ≠ 1).
theorem Rational.zero_less_one : Rational.zero < Rational.one :=
  And.introduction(
      Rational.LessOrEqual_zero_of_IsNonneg(
          Rational.one,
          -- IsNonneg(Rational.one) at rep reduces to Integer.IsNonneg(Integer.one).
          -- Integer.one = (succ(zero) : I), which is IsNonneg.
          
          (Integer.from_natural_is_nonneg(successor(0)))),
      Rational.zero_not_equal_one)

-- halve(ε) < ε when 0 < ε.
theorem Rational.halve_less_than_self
        (epsilon : Rational) (epsilonPos : Rational.zero < epsilon)
        : Rational.halve(epsilon) < epsilon := {
  -- halve(ε) ≤ ε: IsNonneg(ε - halve(ε)). ε - halve(ε) = halve(ε)
  -- by halve_doubled and ring algebra. halve_IsNonneg gives IsNonneg.
  calc epsilon - Rational.halve(epsilon)
     = (Rational.halve(epsilon) + Rational.halve(epsilon))
         + -Rational.halve(epsilon)
            by Rational.halve_doubled(epsilon)
     = Rational.halve(epsilon)                                       as diffEqualsHalve;
  -- halve(ε) > 0 from halve_positive.
  claim halvePositive : Rational.zero < Rational.halve(epsilon);
  -- halve(ε) ≤ ε from IsNonneg(ε - halve(ε)) = IsNonneg(halve(ε)).
  claim halveLeqEpsilon : Rational.halve(epsilon) ≤ epsilon
    by rewrite(
           Equality.symmetry(diffEqualsHalve),
           Rational.IsNonneg_of_LessOrEqual_zero(
               Rational.halve(epsilon),
               Rational.LessThan.weaken(halvePositive)));
  -- halve(ε) ≠ ε. If halve(ε) = ε, then ε - halve(ε) = 0, but it = halve(ε).
  -- So halve(ε) = 0. But halve_positive says ¬(0 = halve(ε)). Contradiction.
  claim halveNeqEpsilon : Not(Rational.halve(epsilon) = epsilon);
  And.introduction(halveLeqEpsilon, halveNeqEpsilon)
}

-- ----------------------------------------------------------------------
-- |q| is non-negative.

-- |q|_at_rep = mk(make(|n|_int, d)) — its numerator is |n|, which is
-- IsNonneg (image of a Natural). So |q| is IsNonneg.
theorem Rational.absolute_value_IsNonneg (q : Rational)
        : Rational.IsNonneg(abs(q)) :=
  -- At a representative make(n, d), |q| has numerator
  -- Integer.absolute_value(n) — the image of a Natural (= distance(a, b)
  -- for n = mk(make(a, b))), hence IsNonneg.
  by_representatives q as ⟨n, d⟩ =>
      rewrite(
          Equality.symmetry(
              Integer.absolute_value_natural_is_image(n)),
          Integer.from_natural_is_nonneg(
              Integer.absolute_value_natural(n)))

-- 0 ≤ |q|.
theorem Rational.zero_le_absolute_value (q : Rational)
        : Rational.LessOrEqual(Rational.zero, abs(q)) :=
  Rational.LessOrEqual_zero_of_IsNonneg(
      abs(q),
      Rational.absolute_value_IsNonneg(q))

-- ----------------------------------------------------------------------
-- Archimedean property: |q| is bounded by some Natural's image.

-- (succ(K) : I) + -(K : I) = Integer.one. Direct calc using
-- (succ(K) : I) = (K + 1 : I) then split and cancel.
theorem Integer.succ_minus_natural (K : Natural)
        : (successor(K) : Integer) + -(K : Integer) = Integer.one := {
  calc successor(K)
     = successor(K + 0)
     = K + successor(0);
  calc (successor(K) : Integer) + -(K : Integer)
     = ((K + successor(0)) : Integer) + -(K : Integer)
     = ((K : Integer) + (successor(0) : Integer)) + -(K : Integer)
     = Integer.one
}

-- The numerator-simplification step: at Integer level,
-- (succ(K) : I) * succ(d) + -(K : I) = (succ(K * d + d) : I).
-- Concretely: succ(K)·succ(d) = K·d + K + d + 1, so the LHS = K·d + d + 1
-- (after the -K cancels K). Stated for use in the IsNonneg argument.
theorem Integer.scaled_succ_minus_natural_simplifies
        (K d : Natural)
        : (successor(K) : Integer) * (successor(d) : Integer)
              + -(K : Integer)
          = (successor(K * d + d) : Integer) :=
  calc (successor(K) : Integer) * (successor(d) : Integer)
           + -(K : Integer)
     = (successor(K) * successor(d) : Integer) + -(K : Integer)
     -- succ(K) · succ(d) = succ(K) + succ(K)·d (multiply_successor).
     = (successor(K) + successor(K) * d : Integer) + -(K : Integer)
     -- Split the Integer image of a sum: (a + b : I) = (a : I) + (b : I).
     = ((successor(K) : Integer) + (successor(K) * d : Integer))
           + -(K : Integer)
     -- Regroup so the -K combines with succ(K).
     = ((successor(K) : Integer) + -(K : Integer))
           + (successor(K) * d : Integer)
     -- succ(K) - K = 1. Via Integer.succ_minus_natural (below).
     = Integer.one + (successor(K) * d : Integer)
     -- Combine 1 + (succ(K)·d : I) = (succ(succ(K) · d) : I).
     = (successor(successor(K) * d) : Integer)
     -- successor(K) · d = K · d + d (multiply_successor on first arg, then commute).
     = (successor(K * d + d) : Integer)
            by (calc successor(K) * d
                   = d + K * d
                   = K * d + d)

-- Archimedean step: at rep make(n, d), |q| ≤ (succ(K) : R) where
-- K := Integer.absolute_value_natural(n). The difference simplifies
-- to a non-negative Integer numerator over denominator d.
-- Helper: the explicit Rational difference equation
--   (succ(K) : R) - mk(make((K : I), d)) = mk(make((succ(K·d + d) : I), d))
-- via Quotient.sound. Bridges the unreduced Rational subtraction to a
-- clean mk form so we can apply IsNonneg through the lift.
theorem Rational.succ_natural_minus_natural_form_at_rep
        (K d : Natural)
        : (successor(K) : Rational)
              - Rational.fraction((K : Integer), d)
          = Rational.fraction((successor(K * d + d) : Integer), d) :=
  -- LHS reduces (through Rational.add + Rational.negate β) to
  -- mk(make((succ K : I)·succ(d) + (-(K : I))·succ(0), d + 0·succ(d))).
  -- We Quotient.sound to mk(make((succ(K·d + d) : I), d)) by
  -- cross-multiplying with Quotient.exact–free arithmetic.
  Quotient.sound(
      RationalRepresentative, RationalEquivalent,
      RationalRepresentative.make(
          (successor(K) : Integer) * (successor(d) : Integer)
              + -(K : Integer) * (successor(0) : Integer),
          d + 0 * successor(d)),
      RationalRepresentative.make(
          (successor(K * d + d) : Integer), d),
      -- Cross equivalence: LHS_num · succ(d) = (succ(K·d+d) : I) · succ(d + 0·s(d)).
      -- The RHS side's denom-1 reduces: succ(d + 0·succ(d)) = succ(d + 0) = succ(d)
      -- (Natural.zero_multiply makes 0·succ(d) = 0; then d + 0 stays unreduced,
      -- but succ(d + 0) = succ(d) requires add_zero in the body).
      calc ((successor(K) : Integer) * (successor(d) : Integer)
            + -(K : Integer) * (successor(0) : Integer))
              * (successor(d) : Integer)
         -- Simplify · succ(zero) at the second term to identity.
         = ((successor(K) : Integer) * (successor(d) : Integer)
            + -(K : Integer))
              * (successor(d) : Integer)
         -- Apply the Integer simplification lemma.
         = (successor(K * d + d) : Integer)
              * (successor(d + 0 * successor(d)) : Integer))

-- |q|-at-rep ≤ (succ(K) : R) form, expressed via the explicit
-- difference equation above.
theorem Rational.absolute_value_natural_form_le_succ
        (K d : Natural)
        : Rational.LessOrEqual(
              Rational.fraction((K : Integer), d),
              (successor(K) : Rational)) :=
  -- Rational.LessOrEqual unfolds to Rational.IsNonneg of the diff.
  -- Transport the diff to the explicit mk(make((succ(K·d+d) : I), d))
  -- form, where Rational.IsNonneg reduces (via the lift) to
  -- Integer.IsNonneg of the numerator, which is a Natural image.
  Equality.transport_proposition(
      Rational.IsNonneg, ?, ?,
      Equality.symmetry(
          Rational.succ_natural_minus_natural_form_at_rep(K, d)),
      
      (Integer.from_natural_is_nonneg(successor(K * d + d))))

-- Archimedean step at a Rational representative.
theorem Rational.absolute_value_le_succ_natural_at_representative
        (n : Integer) (d : Natural)
        : Rational.LessOrEqual(
              abs(Rational.fraction(n, d)),
              (successor(Integer.absolute_value_natural(n)) : Rational)) :=
  -- |q| at rep = mk(make(Integer.absolute_value(n), d)) which equals
  -- mk(make((K : I), d)) via the abs_value_natural_is_image bridge.
  calc abs(Rational.fraction(n, d))
     = Rational.fraction((Integer.absolute_value_natural(n) : Integer), d)
         by Integer.absolute_value_natural_is_image(n)
     ≤ (successor(Integer.absolute_value_natural(n)) : Rational)

-- The headline Archimedean property: for any Rational q, there is a
-- Natural K with |q| ≤ (succ(K) : Rational).
theorem Rational.absolute_value_le_succ_natural (q : Rational)
        : ∃ (K : Natural).
            abs(q) ≤ (successor(K) : Rational) :=
  by_representatives q as ⟨n, d⟩ =>
      witness Integer.absolute_value_natural(n) with
          Rational.absolute_value_le_succ_natural_at_representative(n, d)

-- ----------------------------------------------------------------------
-- General additive monotonicity (left-add by any constant) and
-- sum-of-LessOrEqual.

-- c ≤ d → b + c ≤ b + d. General left-add.
theorem Rational.add_general_LessOrEqual_left
        (b c d : Rational) (cLeqD : c ≤ d)
        : b + c ≤ b + d :=
  calc b + c
     = c + b
     ≤ d + b
     = b + d

-- a ≤ b ∧ c ≤ d → a + c ≤ b + d.
theorem Rational.LessOrEqual.sum
        {a b c d : Rational} (aLeqB : a ≤ b) (cLeqD : c ≤ d)
        : a + c ≤ b + d :=
  calc a + c
     ≤ b + c
     ≤ b + d

-- ----------------------------------------------------------------------
-- ε / (K + 1) construction.

-- The reciprocal of (succ(K) : R) packaged as StrictPositiveRational.
-- 1/(succ(K)) = mk(make(succ(zero) : Integer, K)) per the definition.
-- IsNonneg follows from numerator = (1 : Integer) being IsNonneg.
theorem Rational.reciprocal_of_succ_IsNonneg (K : Natural)
        : Rational.IsNonneg(
              StrictPositiveRational.reciprocal(
                  StrictPositiveRational.make(K, 0))) :=
  -- The reciprocal is mk(make((successor(zero) : Integer), K)),
  -- whose numerator is (1 : Integer), IsNonneg by from_natural_is_nonneg.
  
  (Integer.from_natural_is_nonneg(successor(0)))

-- 1/(succ(K)) is non-zero (numerator is succ(zero) ≠ 0 as Integer).
theorem Rational.reciprocal_of_succ_nonzero (K : Natural)
        : Not(Rational.zero
              = StrictPositiveRational.reciprocal(
                    StrictPositiveRational.make(K, 0))) :=
  (zeroEqRecip
              : Rational.zero
                = StrictPositiveRational.reciprocal(
                      StrictPositiveRational.make(K, 0))) ↦ {
    -- Rational.zero = [Integer.zero / 0] and 1/(K+1) = [successor(0) / K];
    -- equal classes ⇒ Integer.zero · succ(K) = successor(0) · 1, i.e. the
    -- Integers are equal.
    claim Integer.zero = (successor(0) : Integer);
    -- Descending to Natural as in zero_not_equal_one: successor(0) = 0.
    claim successorZeroEqualsZero : successor(0) = (0 : Natural);
    Natural.successor_not_zero(0, successorZeroEqualsZero)
  }

-- 1/(succ(K)) > 0.
theorem Rational.reciprocal_of_succ_positive (K : Natural)
        : Rational.zero
            < StrictPositiveRational.reciprocal(
                  StrictPositiveRational.make(K, 0)) :=
  And.introduction(
      Rational.LessOrEqual_zero_of_IsNonneg(
          StrictPositiveRational.reciprocal(
              StrictPositiveRational.make(K, 0)),
          Rational.reciprocal_of_succ_IsNonneg(K)),
      Rational.reciprocal_of_succ_nonzero(K))

-- Helper: at representatives `make(n_x, d_x)` and `make(n_y, d_y)`,
-- if both numerators are strictly positive (= succ(k) form), then the
-- product is strictly positive (= succ(_) numerator).
theorem Rational.multiply_positive_at_representatives
        (k_x k_y d_x d_y : Natural)
        : Rational.zero
            < Rational.fraction((successor(k_x) : Integer), d_x)
                * Rational.fraction((successor(k_y) : Integer), d_y) := {
  -- The product at rep: mk(make((succ(k_x) : I) · (succ(k_y) : I), d_y + d_x · succ(d_y))).
  -- (succ(k_x) : I) · (succ(k_y) : I) = (succ(k_x) · succ(k_y) : I) = (succ(some) : I).
  -- IsNonneg follows from from_natural_is_nonneg.
  -- Nonzero: assume 0 = product. Quotient.exact gives Integer-level
  -- equation; reduces to (succ(k_x) · succ(k_y)) = 0 (Natural), false.
  claim productIsNonneg
      : Rational.IsNonneg(
            Rational.fraction((successor(k_x) : Integer), d_x)
              * Rational.fraction((successor(k_y) : Integer), d_y))
    by -- The numerator (succ(k_x) : I) · (succ(k_y) : I) =
       -- (succ(k_x) · succ(k_y) : I), IsNonneg.
       
       (rewrite(
           Natural.to_integer.multiply_preserves(
               successor(k_x), successor(k_y)),
           Integer.from_natural_is_nonneg(
               successor(k_x) * successor(k_y))));
  claim productNonzero
      : Not(Rational.zero
            = Rational.fraction((successor(k_x) : Integer), d_x)
                * Rational.fraction((successor(k_y) : Integer), d_y));
  And.introduction(
      Rational.LessOrEqual_zero_of_IsNonneg(
          Rational.fraction((successor(k_x) : Integer), d_x)
              * Rational.fraction((successor(k_y) : Integer), d_y),
          productIsNonneg),
      productNonzero)
}

-- Multiplication preserves strict positivity. Take representatives
-- x = [n_x/d_x], y = [n_y/d_y]; strict-positive witnesses give
-- n_x = succ(k_x), n_y = succ(k_y), then succ * succ > 0 at the
-- representative level proves the result.
theorem Rational.multiply_positive_positive
        (x y : Rational) (xPos : Rational.zero < x) (yPos : Rational.zero < y)
        : Rational.zero < x * y :=
  cases x refining xPos { | RationalRepresentative.make(n_x, d_x) =>
    cases y refining yPos { | RationalRepresentative.make(n_y, d_y) => {
      obtain ⟨k_x, n_x_eq⟩ from
        Rational.strict_positive_witness_at_representative(
            n_x, d_x,
            
            (Rational.IsNonneg_of_LessOrEqual_zero(
                Rational.fraction(n_x, d_x),
                Rational.LessThan.weaken(xPos))),
            (zeroEqNx : n_x = Integer.zero) ↦
              Rational.LessThan.distinct(xPos)(
                  calc Rational.zero
                     = Quotient.mk(
                           RationalRepresentative,
                           RationalEquivalent,
                           RationalRepresentative.make(Integer.zero, 0))
                     = Quotient.mk(
                           RationalRepresentative,
                           RationalEquivalent,
                           RationalRepresentative.make(n_x, d_x))
                           by Quotient.sound(
                                  RationalRepresentative,
                                  RationalEquivalent,
                                  RationalRepresentative.make(
                                      Integer.zero, 0),
                                  RationalRepresentative.make(n_x, d_x),
                                  calc Integer.zero
                                          * (successor(d_x) : Integer)
                                      = n_x
                                      = n_x
                                          * (successor(0) : Integer))));
      obtain ⟨k_y, n_y_eq⟩ from
        Rational.strict_positive_witness_at_representative(
            n_y, d_y,
            
            (Rational.IsNonneg_of_LessOrEqual_zero(
                Rational.fraction(n_y, d_y),
                Rational.LessThan.weaken(yPos))),
            (zeroEqNy : n_y = Integer.zero) ↦
              Rational.LessThan.distinct(yPos)(
                  calc Rational.zero
                     = Quotient.mk(
                           RationalRepresentative,
                           RationalEquivalent,
                           RationalRepresentative.make(Integer.zero, 0))
                     = Quotient.mk(
                           RationalRepresentative,
                           RationalEquivalent,
                           RationalRepresentative.make(n_y, d_y))
                           by Quotient.sound(
                                  RationalRepresentative,
                                  RationalEquivalent,
                                  RationalRepresentative.make(
                                      Integer.zero, 0),
                                  RationalRepresentative.make(n_y, d_y),
                                  calc Integer.zero
                                          * (successor(d_y) : Integer)
                                      = n_y
                                      = n_y
                                          * (successor(0) : Integer))));
      -- Transport to the (succ k_x, succ k_y) form.
      calc Rational.zero
         < Rational.fraction((successor(k_x) : Integer), d_x)
               * Rational.fraction((successor(k_y) : Integer), d_y)
         = Rational.fraction(n_x, d_x)
               * Rational.fraction(n_y, d_y)
    } } }

-- The ε construction: given ε > 0 and Natural K, produce a positive
-- δ with (succ(K) : R) · δ ≤ ε. Witness: δ := ε · (1/succ(K)).
theorem Rational.divide_by_succ_positive
        (epsilon : Rational) (K : Natural)
        (epsilonPos : Rational.zero < epsilon)
        : ∃ (delta : Rational).
            And(Rational.zero < delta,
                Rational.LessOrEqual(
                    (successor(K) : Rational) * delta,
                    epsilon)) :=
  witness epsilon * StrictPositiveRational.reciprocal(
                        StrictPositiveRational.make(K, 0)) with
      ⟨Rational.multiply_positive_positive(
           epsilon,
           StrictPositiveRational.reciprocal(
               StrictPositiveRational.make(K, 0)),
           epsilonPos,
           Rational.reciprocal_of_succ_positive(K)),
       -- (succ(K) : R) · (ε · (1/succ(K))) = ε · ((succ(K) : R) · (1/succ(K)))
       -- = ε · 1 = ε.
       calc (successor(K) : Rational)
                * (epsilon
                   * StrictPositiveRational.reciprocal(
                         StrictPositiveRational.make(K, 0)))
          = StrictPositiveRational.value(
                StrictPositiveRational.make(K, 0))
                * (epsilon
                   * StrictPositiveRational.reciprocal(
                         StrictPositiveRational.make(K, 0)))
          = epsilon
                * (StrictPositiveRational.value(
                       StrictPositiveRational.make(K, 0))
                   * StrictPositiveRational.reciprocal(
                         StrictPositiveRational.make(K, 0)))
          = epsilon * Rational.one
          = epsilon
          ≤ epsilon⟩

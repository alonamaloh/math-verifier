-- Rational/field_bundle.math
--
-- ℚ as a bundled `Field`: `Rational.commutative_ring` plus the two
-- field properties ℚ already proves (`Rational.zero_not_equal_one`,
-- `Rational.reciprocal_exists_for_nonzero`).

module Rational.field_bundle

import Logic.basics
import Logic.exists
import Equality.basics
import Algebra.ring
import Algebra.field
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.field_bundle
import Rational.basics
import Rational.addition
import Rational.negation
import Rational.multiplication
import Rational.ring
import Rational.algebra
import Rational.instances
import Rational.ring_bundle
import Rational.order
import Rational.order_multiplication
import Rational.field

-- ℚ as a bundled field. The property arguments land at the
-- `CommutativeRing` projections of `Rational.commutative_ring`, which
-- reduce to the concrete ℚ constants, so the existing lemmas fit
-- definitionally.
definition Rational.field : Field :=
  Field.make(Rational.commutative_ring, Rational.zero_not_equal_one,
      Rational.reciprocal_exists_for_nonzero)

-- Canonical `Field` for the carrier `Rational`.
instance Rational.field

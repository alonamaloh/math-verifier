-- Rational/archimedean.math
--
-- The Archimedean property of the rational order, with the natural-cast
-- and reciprocal-positivity lemmas it runs on, plus strict cancellation
-- of a positive factor. (Originally written inside Real/supremum.math
-- for the bisection's Cauchy modulus; moved here so Rational-level
-- developments — powers, geometric decay — can import them without
-- reaching into the Real layer.)

module Rational.archimedean

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Integer.sign
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.absolute_value
import Rational.triangle
import Rational.triangle_more
import Rational.positive
import Rational.linearity
import Rational.reciprocal
import Rational.reciprocal_function

-- ----------------------------------------------------------------------
-- Natural → Rational monotonicity for `succ`.

theorem Rational.from_natural_le_preserves
        (a b : Natural) (aLeqB : a ≤ b)
        : (a : Rational) ≤ (b : Rational) := {
    claim subtractionWitness : ∃ (c : Natural). b = a + c
        since Natural.subtraction_witness;
    choose c as witnessEquation from subtractionWitness;
    -- At the representatives, ((a + c) : R) - (a : R) = (c : R): cross-
    -- multiply, and both numerators reduce to (c : Integer).
    calc ((a + c) : Rational) - (a : Rational)
       = ((a : Rational) + (c : Rational)) - (a : Rational)
             since Rational.from_natural_add_preserves
       = (c : Rational);
    -- With b = a + c, (b : R) - (a : R) = (c : R), and the rational image of
    -- a natural is nonnegative. The goal (a : R) ≤ (b : R) is by definition
    -- IsNonneg of that difference, so substituting closes it.
    claim differenceIsImage : (b : Rational) - (a : Rational) = (c : Rational);
    claim differenceIsNonneg
        : Rational.IsNonneg((b : Rational) - (a : Rational))
      by substituting differenceIsImage;
    differenceIsNonneg
}

-- A positive natural casts to a positive rational. `0 < n` is `1 ≤ n`, so
-- `1 = ((1:Natural):ℚ) ≤ (n:ℚ)` by le_preserves, and `0 < 1 ≤ (n:ℚ)`. Automatic:
-- this is the ℕ→ℚ rung of the positivity tower the division/nonzero discharge
-- walks (with `Rational.to_real.positive_preserves` for ℚ→ℝ).
automatic theorem Rational.from_natural_positive (n : Natural) (nPositive : 0 < n)
        : (0 : Rational) < (n : Rational) := {
  claim (1 : Natural) ≤ n;
  claim ((1 : Natural) : Rational) ≤ (n : Rational)
      since Rational.from_natural_le_preserves;
  claim oneCast : ((1 : Natural) : Rational) = Rational.one;
  claim Rational.one ≤ (n : Rational) by substituting oneCast;
  claim (0 : Rational) < Rational.one since Rational.zero_less_one;
  done since Rational.LessThan.transitive_right
}

-- (n : Rational) is nonneg for natural n. The cast goes
-- Natural → Integer → Rational; the numerator at the Rational
-- representative is Integer.from_natural(n), which is Integer.IsNonneg.
theorem Rational.from_natural_IsNonneg (n : Natural)
        : Rational.IsNonneg((n : Rational)) := {
  claim Integer.IsNonneg((n : Integer)) since Integer.from_natural_is_nonneg;
  done by substituting (ring : (n : Integer) * Integer.one = (n : Integer))
      unfolding Rational.IsNonneg
}

-- The Integer analogue: a nonnegative integer casts to a nonnegative rational.
-- (i : Rational) is the representative (i, 1), whose IsNonneg predicate is
-- i · 1 ≥ 0, i.e. i ≥ 0.
theorem Rational.from_integer_IsNonneg (i : Integer) (iNonneg : Integer.IsNonneg(i))
        : Rational.IsNonneg((i : Rational)) := {
  claim (0 : Integer) ≤ i since Integer.zero_less_or_equal_of_nonneg;
  done by substituting (ring : i * Integer.one = i) unfolding Rational.IsNonneg
}

-- ℤ→ℚ preserves ≤: with b = a + n (n : Natural), the difference (b:ℚ) - (a:ℚ)
-- is the image of the nonnegative integer b - a, hence IsNonneg — which is
-- exactly (a:ℚ) ≤ (b:ℚ).
theorem Integer.to_rational.LessOrEqual_preserves (a b : Integer) (aLeqB : a ≤ b)
        : (a : Rational) ≤ (b : Rational) := {
  choose n such that b = a + (n : Integer) from aLeqB;
  claim differenceEquation : b - a = (n : Integer);
  claim Integer.IsNonneg(b - a) by substituting differenceEquation;
  claim Rational.IsNonneg(((b - a) : Rational)) since Rational.from_integer_IsNonneg;
  claim castDifference : ((b - a) : Rational) = (b : Rational) - (a : Rational)
      since Integer.to_rational.subtract_preserves;
  claim Rational.IsNonneg((b : Rational) - (a : Rational))
      by substituting castDifference;
  done
}

-- ℤ→ℚ is injective: the casts are fraction(a, 1) and fraction(b, 1), so their
-- equality cross-multiplies to a · 1 = b · 1. (The keystone for the strict rung
-- `LessThan_preserves`: Rational `<` is `≤ ∧ ≠`, and injectivity carries the ≠.)
theorem Integer.to_rational.injective (a b : Integer)
        (castEqual : (a : Rational) = (b : Rational))
        : a = b := {
  claim crossMultiply : a * Integer.one = b * Integer.one
      since Rational.fraction_equal_implies;
  calc a
     = a * Integer.one
     = b * Integer.one   by crossMultiply
     = b
}

-- (successor(n) : Rational) = (1 : Rational) + (n : Rational). The cast
-- of (succ(n) : Integer) reduces definitionally to Integer.one + (n :
-- Integer); applying Integer.to_rational.add_preserves bridges to the
-- Rational sum.
theorem Rational.successor_cast (n : Natural)
        : (successor(n) : Rational) = (1 : Rational) + (n : Rational) :=
  -- (successor n : Integer) no longer folds to Integer.one + (n : Integer)
  -- on its own (Natural.add opaque); bridge it, then split the cast.
  calc (successor(n) : Rational)
     = ((n + 1 : Natural) : Rational)                                      since Natural.add_one
     = (((n : Integer) + Integer.one) : Rational)                          since Natural.to_integer.add_one_preserves
     = ((Integer.one + (n : Integer)) : Rational)
     = ((Integer.one : Integer) : Rational) + ((n : Integer) : Rational)   since Integer.to_rational.add_preserves
     = (1 : Rational) + (n : Rational)

-- 0 < (successor(n) : Rational). 0 < 1 (strict) ≤ 1 + (n : R) = succ(n).
theorem Rational.successor_cast_positive (n : Natural)
        : (0 : Rational) < (successor(n) : Rational) := {
  claim Rational.IsNonneg((n : Rational)) since Rational.from_natural_IsNonneg;
  claim (0 : Rational) ≤ (n : Rational) since Rational.LessOrEqual_zero_of_IsNonneg;
  calc (0 : Rational)
     < (1 : Rational)
     = (1 : Rational) + (0 : Rational)
     ≤ (1 : Rational) + (n : Rational)
          since Rational.add_general_LessOrEqual_left
     = (successor(n) : Rational)
}

-- (successor(successor(n)) : Rational) = (1 : Rational) + (1 : Rational)
-- + (n : Rational). Two applications of add_preserves, bridging
-- (Integer.one + Integer.one + (n : Integer)) up to Rational.
theorem Rational.successor_successor_cast (n : Natural)
        : (successor(successor(n)) : Rational)
          = (1 : Rational) + (1 : Rational) + (n : Rational) :=
  {
    calc (successor(successor(n)) : Integer)
       = ((successor(n) + 1 : Natural) : Integer)            since Natural.add_one
       = (successor(n) : Integer) + Integer.one             since Natural.to_integer.add_one_preserves
       = ((n + 1 : Natural) : Integer) + Integer.one        since Natural.add_one
       = ((n : Integer) + Integer.one) + Integer.one        since Natural.to_integer.add_one_preserves
       = Integer.one + Integer.one + (n : Integer)
      as castSuccessorSuccessor;
    calc (successor(successor(n)) : Rational)
       = ((Integer.one + Integer.one + (n : Integer)) : Rational)            since castSuccessorSuccessor
       = ((Integer.one + Integer.one : Integer) : Rational) + (n : Rational) since Integer.to_rational.add_preserves
       = (1 : Rational) + (1 : Rational) + (n : Rational)
  }

-- The `1 + n` forms of the cast lemmas. `Natural.add` is opaque, so a goal
-- phrased with `1 + n` does not reduce to `successor(n)` on its own — a
-- consumer that wants to keep `successor` out of its statements cites these
-- instead, and the `successor` token stays confined to this layer.
theorem Rational.one_plus_cast (n : Natural)
        : (1 + n : Rational) = (1 : Rational) + (n : Rational) :=
  calc (1 + n : Rational)
     = (successor(n) : Rational)              since Natural.one_add
     = (1 : Rational) + (n : Rational)        since Rational.successor_cast

theorem Rational.one_plus_cast_positive (n : Natural)
        : (0 : Rational) < (1 + n : Rational) := {
  claim (0 : Rational) < (successor(n) : Rational)
      since Rational.successor_cast_positive;
  done by substituting Natural.one_add
}


-- ----------------------------------------------------------------------
-- Positive rationals are nonzero — the flip of LessThan.distinct that
-- reciprocal arguments want.
automatic theorem Rational.nonzero_of_positive (q : Rational)
        (qPositive : Rational.zero < q)
        : q ≠ Rational.zero :=
  done since Rational.LessThan.distinct

-- Reciprocal positivity: 0 < x → 0 < reciprocal_function(x).
-- Standard contradiction: if recip ≤ 0 then x * recip ≤ 0; if
-- recip = 0 then x * recip = 0. Either contradicts x * recip = 1 > 0.

theorem Rational.reciprocal_function_positive_of_positive
        (x : Rational) (xPositive : (0 : Rational) < x)
        : (0 : Rational) < Rational.reciprocal_function(x) := {
  claim x ≠ (0 : Rational) since Rational.nonzero_of_positive;
  claim xRecipEqOne
        : x * Rational.reciprocal_function(x) = (1 : Rational);
  claim (0 : Rational) ≤ x since Rational.LessThan.weaken;
  claim Rational.IsNonneg(x) since Rational.IsNonneg_of_LessOrEqual_zero;
  claim recipDichotomy
      : Rational.reciprocal_function(x) ≤ (0 : Rational)
        ∨ (0 : Rational) ≤ Rational.reciprocal_function(x)
      since Rational.LessOrEqual.linear;
  cases recipDichotomy {
    | Or.introduceLeft(recipLeqZero) => {
        -- recip ≤ 0: derive x*recip ≤ 0, contradicting x*recip = 1.
        claim (0 : Rational) ≤ -Rational.reciprocal_function(x);
        claim Rational.IsNonneg(-Rational.reciprocal_function(x));
        claim Rational.IsNonneg(x * -Rational.reciprocal_function(x));
        claim Rational.IsNonneg(-(x * Rational.reciprocal_function(x)))
          by substituting (ring : x * -Rational.reciprocal_function(x)
                                  = -(x * Rational.reciprocal_function(x)));
        claim x * Rational.reciprocal_function(x) ≤ (0 : Rational)
          since Rational.LessOrEqual_zero_of_negate_IsNonneg;
        claim (1 : Rational) ≤ (0 : Rational) by substituting xRecipEqOne;
        claim (0 : Rational) ≤ (1 : Rational) since Rational.LessThan.weaken;
        claim zeroEqOne : (0 : Rational) = (1 : Rational)
          since Rational.LessOrEqual.antisymmetric;
        claim (0 : Rational) < (1 : Rational) since Rational.zero_less_one;
        claim zeroNotOne : (0 : Rational) ≠ (1 : Rational) since Rational.LessThan.distinct;
        absurd(zeroNotOne(zeroEqOne))
      }
    | Or.introduceRight(zeroLeqRecip) =>
        decide (0 : Rational) = Rational.reciprocal_function(x) {
          | yes zeroEqRecip => {
              -- recip = 0: x*recip = x*0 = 0 ≠ 1.
              claim x * (0 : Rational) = (1 : Rational);
              calc (0 : Rational)
                      = x * (0 : Rational)
                      = (1 : Rational) as zeroEqOne;
              claim (0 : Rational) < (1 : Rational) since Rational.zero_less_one;
              claim zeroNotOne : (0 : Rational) ≠ (1 : Rational) since Rational.LessThan.distinct;
              absurd(zeroNotOne(zeroEqOne))
            }
          | no zeroNotEqRecip =>
              And.introduction(zeroLeqRecip, zeroNotEqRecip)
        }
  }
}

-- ----------------------------------------------------------------------
-- Archimedean property for two positives: given 0 ≤ c and 0 < ε, find
-- K with c ≤ (succ(K) : R) * ε. Apply the standard Archimedean lemma
-- to c * reciprocal(ε), which is nonneg, then multiply both sides by ε.

theorem Rational.archimedean_for_positives
        (c ε : Rational)
        (cNonneg : Rational.IsNonneg(c))
        (εPositive : (0 : Rational) < ε)
        : ∃ (K : Natural). c ≤ (1 + K : Rational) * ε := {
  claim (0 : Rational) < Rational.reciprocal_function(ε);
  claim (0 : Rational) ≤ Rational.reciprocal_function(ε)
    since Rational.LessThan.weaken;
  claim Rational.IsNonneg(Rational.reciprocal_function(ε))
    since Rational.IsNonneg_of_LessOrEqual_zero;
  claim Rational.IsNonneg(c * Rational.reciprocal_function(ε));
  claim abs(c * Rational.reciprocal_function(ε))
        = c * Rational.reciprocal_function(ε);
  claim absoluteBound
      : ∃ (K : Natural).
          abs(c * Rational.reciprocal_function(ε)) ≤ ((K + 1) : Rational)
      since Rational.absolute_value_le_add_one_natural;
  choose K as absBound from absoluteBound;
  calc c * Rational.reciprocal_function(ε)
          = abs(c * Rational.reciprocal_function(ε))
          ≤ ((K + 1) : Rational)
          = (1 + K : Rational)   by (K + 1 = 1 + K);
  claim Rational.LessOrEqual((0 : Rational), ε);
  claim (c * Rational.reciprocal_function(ε)) * ε
          ≤ (1 + K : Rational) * ε;
  claim ε ≠ (0 : Rational) since Rational.nonzero_of_positive;
  calc (c * Rational.reciprocal_function(ε)) * ε
          = c * (ε * Rational.reciprocal_function(ε))
          = c * (1 : Rational)
          = c;
  witness K with
      calc c
         = (c * Rational.reciprocal_function(ε)) * ε
         ≤ (1 + K : Rational) * ε
}

-- The `successor(K)` face of the same bound, for consumers still phrased with
-- the constructor. (Temporary: delete once they migrate to the `1 + K` form.)
theorem Rational.archimedean_for_positives_successor
        (c ε : Rational)
        (cNonneg : Rational.IsNonneg(c))
        (εPositive : (0 : Rational) < ε)
        : ∃ (K : Natural). c ≤ (successor(K) : Rational) * ε := {
  choose K such that c ≤ (1 + K : Rational) * ε as bound
      from Rational.archimedean_for_positives;
  witness K with
      calc c
         ≤ (1 + K : Rational) * ε          by bound
         = (successor(K) : Rational) * ε   since Natural.one_add
}

-- ----------------------------------------------------------------------
-- Strict multiplicative cancellation: from a * c < b * c and 0 < c,
-- conclude a < b.

theorem Rational.LessThan.multiply_cancel_right_positive
        (a b c : Rational)
        (cPositive : (0 : Rational) < c)
        (productLessThan : a * c < b * c)
        : a < b := {
  claim abDichotomy : a ≤ b ∨ b ≤ a since Rational.LessOrEqual.linear;
  cases abDichotomy {
    | Or.introduceLeft(aLeqB) =>
        decide a = b {
          | yes aEqB => {
              claim productsEqual : a * c = b * c;
              claim productNotEqual : a * c ≠ b * c since Rational.LessThan.distinct;
              absurd(productNotEqual(productsEqual))
            }
          | no aNotEqB =>
              And.introduction(aLeqB, aNotEqB)
        }
    | Or.introduceRight(bLeqA) => {
        claim Rational.LessOrEqual((0 : Rational), c);
        claim b * c ≤ a * c;
        claim a * c ≤ b * c since Rational.LessThan.weaken;
        claim productsEqual : a * c = b * c since Rational.LessOrEqual.antisymmetric;
        claim productNotEqual : a * c ≠ b * c since Rational.LessThan.distinct;
        absurd(productNotEqual(productsEqual))
      }
  }
}

-- ----------------------------------------------------------------------
-- Strict step: succ(K) * ε < succ(succ(K)) * ε for 0 < ε.

theorem Rational.succ_K_strictly_less_succ_succ_K_times_ε
        (K : Natural) (ε : Rational)
        (εPositive : (0 : Rational) < ε)
        : (successor(K) : Rational) * ε
          < (successor(successor(K)) : Rational) * ε :=
  calc (successor(K) : Rational) * ε
     = (successor(K) : Rational) * ε + (0 : Rational)
     < (successor(K) : Rational) * ε + ε
          since Rational.add_left_preserves_LessThan
     = ((1 : Rational) + (successor(K) : Rational)) * ε
     = (successor(successor(K)) : Rational) * ε


-- ----------------------------------------------------------------------
-- Tail bound for c/(m+1): past some index every scaled reciprocal of a
-- successor drops below any positive ε. Archimedes pins K with
-- c ≤ (K+1)·(ε/2); past K the factor (m+1) only grows, and the spare
-- factor of two makes the bound strict.
theorem Rational.scaled_reciprocal_eventually_below
        (c ε : Rational)
        (cNonneg : Rational.IsNonneg(c))
        (εPositive : Rational.zero < ε)
        : ∃ (N : Natural). ∀ (m : Natural). N ≤ m
            → c * Rational.reciprocal_function((1 + m : Rational))
              < ε := {
  claim Rational.zero < Rational.halve(ε)
      since Rational.halve_positive;
  claim Rational.zero ≤ Rational.halve(ε)
      since Rational.LessThan.weaken;
  claim archimedeanWitness
      : ∃ (K : Natural). c ≤ (1 + K : Rational) * Rational.halve(ε)
      since Rational.archimedean_for_positives;
  choose K as archBound from archimedeanWitness;
  witness K with
      (m : Natural) (KLeqM : K ≤ m) ↦ {
        claim Rational.zero < (1 + m : Rational)
            since Rational.one_plus_cast_positive;
        claim Rational.zero
                < Rational.reciprocal_function((1 + m : Rational))
            since Rational.reciprocal_function_positive_of_positive;
        claim Rational.zero
                ≤ Rational.reciprocal_function((1 + m : Rational))
            since Rational.LessThan.weaken;
        claim 1 + K ≤ 1 + m
            since Natural.add_left_monotone;
        claim (1 + K : Rational) ≤ (1 + m : Rational)
            since Rational.from_natural_le_preserves;
        claim (1 + K : Rational) * Rational.halve(ε)
                ≤ (1 + m : Rational) * Rational.halve(ε)
            since Rational.LessOrEqual.multiply_by_nonneg_right;
        claim (1 + m : Rational) ≠ Rational.zero
            since Rational.nonzero_of_positive;
        claim cancel
              : (1 + m : Rational)
                    * Rational.reciprocal_function((1 + m : Rational))
                = Rational.one;
        calc c * Rational.reciprocal_function((1 + m : Rational))
           ≤ ((1 + K : Rational) * Rational.halve(ε))
                 * Rational.reciprocal_function((1 + m : Rational))
                 since Rational.LessOrEqual.multiply_by_nonneg_right
           ≤ ((1 + m : Rational) * Rational.halve(ε))
                 * Rational.reciprocal_function((1 + m : Rational))
                 since Rational.LessOrEqual.multiply_by_nonneg_right
           = Rational.halve(ε)
                 * ((1 + m : Rational)
                    * Rational.reciprocal_function((1 + m : Rational)))
           = Rational.halve(ε) * Rational.one
                 since cancel
           = Rational.halve(ε)
           < ε
                 since Rational.halve_less_than_self
      }
}

-- ----------------------------------------------------------------------
-- Reciprocals reverse the order on positives: trade 1 = a·(1/a) in,
-- grow a to b under the nonnegative factor (1/a)·(1/b), and cancel.
theorem Rational.reciprocal_function_antitone
        (a b : Rational) (aPositive : Rational.zero < a) (aLeqB : a ≤ b)
        : Rational.reciprocal_function(b) ≤ Rational.reciprocal_function(a) := {
  claim Rational.zero < b since Rational.LessThan.transitive_right;
  claim a ≠ Rational.zero since Rational.nonzero_of_positive;
  claim b ≠ Rational.zero since Rational.nonzero_of_positive;
  claim aCancel : a * Rational.reciprocal_function(a) = Rational.one;
  claim bCancel : b * Rational.reciprocal_function(b) = Rational.one;
  claim Rational.zero < Rational.reciprocal_function(a)
      since Rational.reciprocal_function_positive_of_positive;
  claim Rational.zero < Rational.reciprocal_function(b)
      since Rational.reciprocal_function_positive_of_positive;
  claim Rational.zero ≤ Rational.reciprocal_function(a)
      since Rational.LessThan.weaken;
  claim Rational.zero ≤ Rational.reciprocal_function(b)
      since Rational.LessThan.weaken;
  claim Rational.IsNonneg(Rational.reciprocal_function(a))
      since Rational.IsNonneg_of_LessOrEqual_zero;
  claim Rational.IsNonneg(Rational.reciprocal_function(b))
      since Rational.IsNonneg_of_LessOrEqual_zero;
  claim Rational.IsNonneg(
            Rational.reciprocal_function(a) * Rational.reciprocal_function(b))
      since Rational.IsNonneg.multiply;
  claim Rational.zero
          ≤ Rational.reciprocal_function(a) * Rational.reciprocal_function(b)
      since Rational.LessOrEqual_zero_of_IsNonneg;
  calc Rational.reciprocal_function(b)
     = Rational.one * Rational.reciprocal_function(b)
     = (a * Rational.reciprocal_function(a)) * Rational.reciprocal_function(b)
           since aCancel
     = (Rational.reciprocal_function(a) * Rational.reciprocal_function(b)) * a
     ≤ (Rational.reciprocal_function(a) * Rational.reciprocal_function(b)) * b
           since Rational.LessOrEqual.multiply_by_nonneg_left
     = Rational.reciprocal_function(a) * (b * Rational.reciprocal_function(b))
     = Rational.reciprocal_function(a) * Rational.one
           since bCancel
     = Rational.reciprocal_function(a)
}

-- ----------------------------------------------------------------------
-- The tolerance collapse q · (t · q⁻¹) = t for positive q: every
-- ε-argument that scales a tolerance down by a roof q and later
-- multiplies the roof back ends with exactly this cancellation.
theorem Rational.scale_reciprocal_collapse (q t : Rational)
        (qPositive : Rational.zero < q)
        : q * (t * Rational.reciprocal_function(q)) = t := {
  claim q ≠ Rational.zero since Rational.nonzero_of_positive;
  claim cancel : q * Rational.reciprocal_function(q) = Rational.one
      since Rational.reciprocal_function_multiplies;
  calc q * (t * Rational.reciprocal_function(q))
     = t * (q * Rational.reciprocal_function(q))
     = t * Rational.one                             since cancel
     = t
}

-- The reciprocal of one is one.
theorem Rational.reciprocal_function_one
        : Rational.reciprocal_function(Rational.one) = Rational.one := {
  claim Rational.zero < Rational.one since Rational.zero_less_one;
  claim ¬(Rational.one = Rational.zero) since Rational.nonzero_of_positive;
  claim cancel
        : Rational.one * Rational.reciprocal_function(Rational.one)
          = Rational.one
      since Rational.reciprocal_function_multiplies;
  calc Rational.reciprocal_function(Rational.one)
     = Rational.one * Rational.reciprocal_function(Rational.one)
     = Rational.one                                                since cancel
}

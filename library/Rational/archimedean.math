-- Rational/archimedean.math
--
-- The Archimedean property of the rational order, with the natural-cast
-- and reciprocal-positivity lemmas it runs on, plus strict cancellation
-- of a positive factor. (Originally written inside Real/supremum.math
-- for the bisection's Cauchy modulus; moved here so Rational-level
-- developments — powers, geometric decay — can import them without
-- reaching into the Real layer.)

module Rational.archimedean

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Integer.order_multiply
import Integer.sign
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.absolute_value
import Rational.triangle
import Rational.triangle_more
import Rational.positive
import Rational.linearity
import Rational.reciprocal
import Rational.reciprocal_function

-- ----------------------------------------------------------------------
-- Natural → Rational monotonicity for `succ`.

theorem Rational.from_natural.LessOrEqual_preserves
        (a b : ℕ) (aLeqB : a ≤ b)
        : (a : ℚ) ≤ (b : ℚ) := {
    choose c such that b = a + c from Natural.subtraction_witness;
    -- At the representatives, ((a + c) : R) - (a : R) = (c : R): cross-
    -- multiply, and both numerators reduce to (c : ℤ).
    ((a + c) : ℚ) - (a : ℚ)
       = ((a : ℚ) + (c : ℚ)) - (a : ℚ)
       = (c : ℚ);
    -- With b = a + c, (b : R) - (a : R) = (c : R), and the rational image of
    -- a natural is nonnegative. The goal (a : R) ≤ (b : R) is by definition
    -- IsNonneg of that difference, so substituting closes it.
    (b : ℚ) - (a : ℚ) = (c : ℚ);
    Rational.IsNonneg((b : ℚ) - (a : ℚ)) as differenceIsNonneg;
    differenceIsNonneg
}

-- (n : ℚ) is nonneg for natural n. The cast goes
-- Natural → Integer → Rational; the numerator at the Rational
-- representative is Integer.from_natural(n), which is Integer.IsNonneg.
theorem Rational.from_natural_IsNonneg (n : ℕ)
        : Rational.IsNonneg((n : ℚ)) := {
  Integer.IsNonneg((n : ℤ));
  done by substituting (ring : (n : ℤ) * Integer.one = (n : ℤ))
      unfolding Rational.IsNonneg
}

-- The Integer analogue: a nonnegative integer casts to a nonnegative rational.
-- (i : ℚ) is the representative (i, 1), whose IsNonneg predicate is
-- i · 1 ≥ 0, i.e. i ≥ 0.
theorem Rational.from_integer_IsNonneg (i : ℤ) (iNonneg : Integer.IsNonneg(i))
        : Rational.IsNonneg((i : ℚ)) := {
  (0 : ℤ) ≤ i;
  done by substituting (ring : i * Integer.one = i) unfolding Rational.IsNonneg
}

-- ℤ→ℚ preserves ≤: with b = a + n (n : ℕ), the difference (b:ℚ) - (a:ℚ)
-- is the image of the nonnegative integer b - a, hence IsNonneg — which is
-- exactly (a:ℚ) ≤ (b:ℚ).
theorem Integer.to_rational.LessOrEqual_preserves (a b : ℤ) (aLeqB : a ≤ b)
        : (a : ℚ) ≤ (b : ℚ) := {
  choose n such that b = a + (n : ℤ) from aLeqB;
  Integer.IsNonneg(b - a);
  Rational.IsNonneg(((b - a) : ℚ));
  ((b - a) : ℚ) = (b : ℚ) - (a : ℚ);
  Rational.IsNonneg((b : ℚ) - (a : ℚ));
  done
}

-- ℤ→ℚ is injective: the casts are fraction(a, 1) and fraction(b, 1), so their
-- equality cross-multiplies to a · 1 = b · 1. (The keystone for the strict rung
-- `LessThan_preserves`: Rational `<` is `≤ ∧ ≠`, and injectivity carries the ≠.)
theorem Integer.to_rational.injective (a b : ℤ)
        (castEqual : (a : ℚ) = (b : ℚ))
        : a = b := {
  a * Integer.one = b * Integer.one
      by Rational.fraction_equal_implies;
  a
     = a * Integer.one
     = b * Integer.one
     = b
}

-- ℤ→ℚ preserves <: the ≤ part is preserved, and strictness survives because
-- ℤ→ℚ is injective (Rational `<` is `≤ ∧ ≠`).
theorem Integer.to_rational.LessThan_preserves (a b : ℤ) (aLessThanB : a < b)
        : (a : ℚ) < (b : ℚ) := {
  a ≤ b by Integer.LessThan.weaken;
  (a : ℚ) ≤ (b : ℚ);
  a ≠ b by Integer.LessThan.distinct;
  (a : ℚ) ≠ (b : ℚ);
  done
}

-- ℤ→ℚ preserves positivity: preserve `0 < i` as `(0:ℚ) < (i:ℚ)`, then rewrite the
-- image of 0. Automatic: the ℤ→ℚ rung of the positivity tower.
automatic theorem Integer.to_rational.positive_preserves (i : ℤ) (iPositive : Integer.zero < i)
        : Rational.zero < (i : ℚ) := {
  ((0 : ℤ) : ℚ) < (i : ℚ);
  done
}

-- ℤ→ℚ reflects ≤: the weak inequality between the casts is IsNonneg of their
-- difference, which is the cast of b − a; the fraction boundary reads that
-- back as Integer.IsNonneg(b − a).
theorem Integer.to_rational.LessOrEqual_reflects (a b : ℤ)
        (imageLessOrEqual : (a : ℚ) ≤ (b : ℚ)) : a ≤ b := {
  Rational.IsNonneg((b : ℚ) - (a : ℚ));
  Rational.IsNonneg(((b - a : ℤ) : ℚ));
  Integer.IsNonneg((b - a) * Integer.one);
  Integer.IsNonneg(b - a);
  done by Integer.le_of_nonneg_difference
}

-- ℤ→ℚ reflects <: the weak part reflects, distinctness reflects (the cast is a
-- function), and a distinct weak inequality of integers steps by at least one.
theorem Integer.to_rational.LessThan_reflects (a b : ℤ)
        (imageLessThan : (a : ℚ) < (b : ℚ)) : a < b := {
  (a : ℚ) ≤ (b : ℚ);
  a ≤ b by Integer.to_rational.LessOrEqual_reflects as weakPart;
  (a : ℚ) ≠ (b : ℚ);
  a ≠ b;
  choose gap such that b = a + (gap : ℤ) from weakPart;
  done by cases {
    case gap = 0: {
        b = a;
        a = b;
        False;
        done
      }
    case gap = 1 + gapPredecessor for some gapPredecessor:
        witness gapPredecessor with
            b
               = a + (1 + gapPredecessor : ℤ)
               = a + ((gapPredecessor + 1 : ℕ) : ℤ)
               = a + ((gapPredecessor : ℤ) + Integer.one)
               = (a + Integer.one) + (gapPredecessor : ℤ)
  }
}

-- (1 + n : ℚ) = (1 : ℚ) + (n : ℚ). The Natural →
-- Rational cast is additive, so this is `Rational.from_natural.add_preserves`
-- applied at the summand 1.
theorem Rational.one_plus_cast (n : ℕ)
        : (1 + n : ℚ) = (1 : ℚ) + (n : ℚ) :=
  done

-- 0 < (1 + n : ℚ). 0 < 1 (strict) ≤ 1 + (n : R).
theorem Rational.one_plus_cast_positive (n : ℕ)
        : (0 : ℚ) < (1 + n : ℚ) := {
  Rational.IsNonneg((n : ℚ));
  (0 : ℚ) ≤ (n : ℚ);
  (0 : ℚ)
     < (1 : ℚ)
     = (1 : ℚ) + (0 : ℚ)
     ≤ (1 : ℚ) + (n : ℚ)
     = (1 + n : ℚ)
}


-- ----------------------------------------------------------------------
-- Positive rationals are nonzero — the flip of LessThan.distinct that
-- reciprocal arguments want.
automatic theorem Rational.nonzero_of_positive (q : ℚ)
        (qPositive : Rational.zero < q)
        : q ≠ Rational.zero :=
  done by Rational.LessThan.distinct

-- Reciprocal positivity: 0 < x → 0 < reciprocal_function(x).
-- Standard contradiction: if recip ≤ 0 then x * recip ≤ 0; if
-- recip = 0 then x * recip = 0. Either contradicts x * recip = 1 > 0.

theorem Rational.reciprocal_function_positive_of_positive
        (x : ℚ) (xPositive : (0 : ℚ) < x)
        : (0 : ℚ) < Rational.reciprocal_function(x) := {
  x ≠ (0 : ℚ);
  x * Rational.reciprocal_function(x) = (1 : ℚ);
  (0 : ℚ) ≤ x;
  Rational.IsNonneg(x);
  Rational.reciprocal_function(x) ≤ (0 : ℚ)
        ∨ (0 : ℚ) ≤ Rational.reciprocal_function(x);
  done by cases {
    case Rational.reciprocal_function(x) ≤ (0 : ℚ): {
        -- recip ≤ 0: derive x*recip ≤ 0, contradicting x*recip = 1.
        (0 : ℚ) ≤ -Rational.reciprocal_function(x);
        Rational.IsNonneg(-Rational.reciprocal_function(x));
        Rational.IsNonneg(x * -Rational.reciprocal_function(x));
        Rational.IsNonneg(-(x * Rational.reciprocal_function(x)))
          by substituting (ring : x * -Rational.reciprocal_function(x)
                                  = -(x * Rational.reciprocal_function(x)));
        x * Rational.reciprocal_function(x) ≤ (0 : ℚ);
        (1 : ℚ) ≤ (0 : ℚ);
        (0 : ℚ) ≤ (1 : ℚ);
        (0 : ℚ) = (1 : ℚ);
        (0 : ℚ) < (1 : ℚ);
        (0 : ℚ) ≠ (1 : ℚ);
        done
      }
    case (0 : ℚ) ≤ Rational.reciprocal_function(x): {
        suppose (0 : ℚ) = Rational.reciprocal_function(x) for contradiction {
            -- recip = 0: x*recip = x*0 = 0 ≠ 1.
            x * (0 : ℚ) = (1 : ℚ);
            (0 : ℚ)
                    = x * (0 : ℚ)
                    = (1 : ℚ);
            (0 : ℚ) < (1 : ℚ);
            (0 : ℚ) ≠ (1 : ℚ);
            done
        };
        done
      }
  }
}

-- ----------------------------------------------------------------------
-- Archimedean property for two positives: given 0 ≤ c and 0 < ε, find
-- K with c ≤ (succ(K) : R) * ε. Apply the standard Archimedean lemma
-- to c * reciprocal(ε), which is nonneg, then multiply both sides by ε.

theorem Rational.archimedean_for_positives
        (c ε : ℚ)
        (cNonneg : Rational.IsNonneg(c))
        (εPositive : (0 : ℚ) < ε)
        : ∃ (K : ℕ). c ≤ (1 + K : ℚ) * ε := {
  (0 : ℚ) < Rational.reciprocal_function(ε);
  (0 : ℚ) ≤ Rational.reciprocal_function(ε);
  Rational.IsNonneg(Rational.reciprocal_function(ε));
  Rational.IsNonneg(c * Rational.reciprocal_function(ε));
  abs(c * Rational.reciprocal_function(ε))
        = c * Rational.reciprocal_function(ε);
  choose K such that
          abs(c * Rational.reciprocal_function(ε)) ≤ ((K + 1) : ℚ)
      from Rational.absolute_value_le_add_one_natural;
  c * Rational.reciprocal_function(ε)
          = abs(c * Rational.reciprocal_function(ε))
          ≤ ((K + 1) : ℚ)
          = (1 + K : ℚ);
  Rational.LessOrEqual((0 : ℚ), ε);
  (c * Rational.reciprocal_function(ε)) * ε
          ≤ (1 + K : ℚ) * ε;
  ε ≠ (0 : ℚ);
  (c * Rational.reciprocal_function(ε)) * ε
          = c * (ε * Rational.reciprocal_function(ε))
          = c * (1 : ℚ)
          = c;
  witness K with
      c
         = (c * Rational.reciprocal_function(ε)) * ε
         ≤ (1 + K : ℚ) * ε
}

-- ----------------------------------------------------------------------
-- Strict multiplicative cancellation: from a * c < b * c and 0 < c,
-- conclude a < b.

theorem Rational.LessThan.multiply_cancel_right_positive
        (a b c : ℚ)
        (cPositive : (0 : ℚ) < c)
        (productLessThan : a * c < b * c)
        : a < b := {
  a ≤ b ∨ b ≤ a;
  done by cases {
    case a ≤ b: {
        suppose a = b for contradiction {
            a * c = b * c;
            a * c ≠ b * c;
            done
        };
        done
      }
    case b ≤ a: {
        Rational.LessOrEqual((0 : ℚ), c);
        b * c ≤ a * c;
        a * c ≤ b * c;
        a * c = b * c by Rational.LessOrEqual.antisymmetric;
        a * c ≠ b * c;
        done
      }
  }
}

-- ----------------------------------------------------------------------
-- Strict step: (1 + K) * ε < (1 + (1 + K)) * ε for 0 < ε.

theorem Rational.one_plus_K_strictly_less_one_plus_one_plus_K_times_ε
        (K : ℕ) (ε : ℚ)
        (εPositive : (0 : ℚ) < ε)
        : (1 + K : ℚ) * ε
          < (1 + (1 + K) : ℚ) * ε :=
  (1 + K : ℚ) * ε
     = (1 + K : ℚ) * ε + (0 : ℚ)
     < (1 + K : ℚ) * ε + ε
     = ((1 : ℚ) + (1 + K : ℚ)) * ε
     = (1 + (1 + K) : ℚ) * ε


-- ----------------------------------------------------------------------
-- Tail bound for c/(m+1): past some index every scaled reciprocal of the
-- form c/(m+1) drops below any positive ε. Archimedes pins K with
-- c ≤ (K+1)·(ε/2); past K the factor (m+1) only grows, and the spare
-- factor of two makes the bound strict.
theorem Rational.scaled_reciprocal_eventually_below
        (c ε : ℚ)
        (cNonneg : Rational.IsNonneg(c))
        (εPositive : Rational.zero < ε)
        : ∃ (N : ℕ). ∀ (m : ℕ). N ≤ m
            → c * Rational.reciprocal_function((1 + m : ℚ))
              < ε := {
  Rational.zero < Rational.halve(ε);
  Rational.zero ≤ Rational.halve(ε);
  choose K such that c ≤ (1 + K : ℚ) * Rational.halve(ε)
      from Rational.archimedean_for_positives;
  witness K with
      (m : ℕ) (KLeqM : K ≤ m) ↦ {
        Rational.zero < (1 + m : ℚ);
        Rational.zero
                < Rational.reciprocal_function((1 + m : ℚ));
        Rational.zero
                ≤ Rational.reciprocal_function((1 + m : ℚ));
        1 + K ≤ 1 + m;
        (1 + K : ℚ) ≤ (1 + m : ℚ);
        (1 + K : ℚ) * Rational.halve(ε)
                ≤ (1 + m : ℚ) * Rational.halve(ε);
        (1 + m : ℚ) ≠ Rational.zero;
        (1 + m : ℚ)
                    * Rational.reciprocal_function((1 + m : ℚ))
                = Rational.one;
        c * Rational.reciprocal_function((1 + m : ℚ))
           ≤ ((1 + K : ℚ) * Rational.halve(ε))
                 * Rational.reciprocal_function((1 + m : ℚ))
           ≤ ((1 + m : ℚ) * Rational.halve(ε))
                 * Rational.reciprocal_function((1 + m : ℚ))
           = Rational.halve(ε)
                 * ((1 + m : ℚ)
                    * Rational.reciprocal_function((1 + m : ℚ)))
           = Rational.halve(ε) * Rational.one
           = Rational.halve(ε)
           < ε
      }
}

-- ----------------------------------------------------------------------
-- Reciprocals reverse the order on positives: trade 1 = a·(1/a) in,
-- grow a to b under the nonnegative factor (1/a)·(1/b), and cancel.
theorem Rational.reciprocal_function_antitone
        (a b : ℚ) (aPositive : Rational.zero < a) (aLeqB : a ≤ b)
        : Rational.reciprocal_function(b) ≤ Rational.reciprocal_function(a) := {
  Rational.zero < b by Rational.LessThan.transitive_right;
  a ≠ Rational.zero;
  b ≠ Rational.zero;
  a * Rational.reciprocal_function(a) = Rational.one;
  b * Rational.reciprocal_function(b) = Rational.one;
  Rational.zero < Rational.reciprocal_function(a);
  Rational.zero < Rational.reciprocal_function(b);
  Rational.zero ≤ Rational.reciprocal_function(a);
  Rational.zero ≤ Rational.reciprocal_function(b);
  Rational.IsNonneg(Rational.reciprocal_function(a));
  Rational.IsNonneg(Rational.reciprocal_function(b));
  Rational.IsNonneg(
            Rational.reciprocal_function(a) * Rational.reciprocal_function(b));
  Rational.zero
          ≤ Rational.reciprocal_function(a) * Rational.reciprocal_function(b);
  Rational.reciprocal_function(b)
     = Rational.one * Rational.reciprocal_function(b)
     = (a * Rational.reciprocal_function(a)) * Rational.reciprocal_function(b)
     = (Rational.reciprocal_function(a) * Rational.reciprocal_function(b)) * a
     ≤ (Rational.reciprocal_function(a) * Rational.reciprocal_function(b)) * b
     = Rational.reciprocal_function(a) * (b * Rational.reciprocal_function(b))
     = Rational.reciprocal_function(a) * Rational.one
     = Rational.reciprocal_function(a)
}

-- ----------------------------------------------------------------------
-- The tolerance collapse q · (t · q⁻¹) = t for positive q: every
-- ε-argument that scales a tolerance down by a roof q and later
-- multiplies the roof back ends with exactly this cancellation.
theorem Rational.scale_reciprocal_collapse (q t : ℚ)
        (qPositive : Rational.zero < q)
        : q * (t * Rational.reciprocal_function(q)) = t := {
  q ≠ Rational.zero;
  q * Rational.reciprocal_function(q) = Rational.one;
  q * (t * Rational.reciprocal_function(q))
     = t * (q * Rational.reciprocal_function(q))
     = t * Rational.one
     = t
}

-- The reciprocal of one is one.
theorem Rational.reciprocal_function_one
        : Rational.reciprocal_function(Rational.one) = Rational.one := {
  Rational.zero < Rational.one;
  ¬(Rational.one = Rational.zero);
  Rational.one * Rational.reciprocal_function(Rational.one)
          = Rational.one;
  Rational.reciprocal_function(Rational.one)
     = Rational.one
}

-- Logic/functions.math
--
-- The basic properties of a function between two types: injective
-- (distinct inputs, distinct outputs), surjective (every output is hit),
-- and bijective (both). These are the vocabulary of cardinality — "X and
-- Y have the same size" is "there is a bijection X → Y", "X is enumerable"
-- is "there is a surjection ℕ → X" — so they live in their own module,
-- separate from the group-homomorphism-specific `IsInjective` in
-- Algebra/subgroup.
--
-- Everything is stated at `Type(0)`, where the concrete carriers
-- (Natural, Integer, Rational, Real, …) live and where `congruenceOf`
-- and the `=` desugaring operate.

module Logic.functions

import axioms
import Logic.basics
import Logic.exists
import Equality.basics

-- `f` is injective: equal outputs force equal inputs.
definition Function.IsInjective (A B : Type(0)) (f : A → B) : Proposition :=
  (x y : A) → f(x) = f(y) → x = y

-- `f` is surjective: every element of the codomain is some `f(x)`.
definition Function.IsSurjective (A B : Type(0)) (f : A → B) : Proposition :=
  (y : B) → ∃ (x : A). f(x) = y

-- `f` is bijective: injective and surjective.
definition Function.IsBijective (A B : Type(0)) (f : A → B) : Proposition :=
  Function.IsInjective(A, B, f) ∧ Function.IsSurjective(A, B, f)

-- ----------------------------------------------------------------------
-- The identity is bijective, and both properties compose. These are the
-- closure facts every cardinality argument leans on.

theorem Function.identity_is_injective (A : Type(0))
        : Function.IsInjective(A, A, (x : A) ↦ x) :=
  (x y : A) (equalImages : x = y) ↦ equalImages

theorem Function.identity_is_surjective (A : Type(0))
        : Function.IsSurjective(A, A, (x : A) ↦ x) :=
  (y : A) ↦ witness y with reflexivity(A, y)

-- The composite of injective functions is injective.
theorem Function.compose_injective
        (A B C : Type(0)) (f : A → B) (g : B → C)
        (fInjective : Function.IsInjective(A, B, f))
        (gInjective : Function.IsInjective(B, C, g))
        : Function.IsInjective(A, C, (x : A) ↦ g(f(x))) :=
  (x y : A) (equalImages : g(f(x)) = g(f(y))) ↦
    fInjective(x, y, gInjective(f(x), f(y), equalImages))

-- The composite of surjective functions is surjective: pull `z` back
-- through `g`, then that preimage back through `f`.
theorem Function.compose_surjective
        (A B C : Type(0)) (f : A → B) (g : B → C)
        (fSurjective : Function.IsSurjective(A, B, f))
        (gSurjective : Function.IsSurjective(B, C, g))
        : Function.IsSurjective(A, C, (x : A) ↦ g(f(x))) :=
  (z : C) ↦ {
    choose y such that g(y) = z from gSurjective(z);
    choose x such that f(x) = y from fSurjective(y);
    witness x with
      g(f(x))
         = g(y)
         = z
  }

-- ----------------------------------------------------------------------
-- Function extensionality: pointwise-equal functions are equal. NOT an
-- axiom — derived from the quotient axioms plus η, the standard
-- construction: divide the function space by pointwise equality,
-- evaluate through the quotient (evaluation at a point respects the
-- relation), and observe that the round trip
-- `x ↦ applyClass(pointwiseClass(f), x)` computes back to `f`. The two
-- classes are equal by soundness, so the round trips — and hence the
-- functions — agree.

-- Pointwise equality — the relation the extensionality quotient
-- divides by.
definition Function.PointwiseEqual (A B : Type(0)) (f g : A → B) : Proposition :=
  ∀ (x : A). f(x) = g(x)

-- The class of a function under pointwise equality (names the relation,
-- which `Quotient.class_of` cannot read off the function alone).
definition Function.pointwiseClass (A B : Type(0)) (f : A → B)
        : Quotient(A → B, Function.PointwiseEqual(A, B)) :=
  Quotient.class_of(f)

-- Evaluation at a point, through the quotient: pointwise-equal
-- functions agree at every point, so it is well-defined.
definition Function.applyClass (A B : Type(0))
        (q : Quotient(A → B, Function.PointwiseEqual(A, B))) (x : A) : B :=
  Quotient.lift(
      (h : A → B) ↦ h(x),
      (h1 h2 : A → B)
          (pointwise : Function.PointwiseEqual(A, B, h1, h2)) ↦ pointwise(x),
      q)

theorem Function.extensionality (A B : Type(0)) (f g : A → B)
        (pointwiseEqual : ∀ (x : A). f(x) = g(x))
        : f = g := {
  Function.pointwiseClass(A, B, f) = Function.pointwiseClass(A, B, g)
      by Quotient.equivalent_implies_equal;
  f
     = ((x : A) ↦ Function.applyClass(A, B, Function.pointwiseClass(A, B, f), x))
     = ((x : A) ↦ Function.applyClass(A, B, Function.pointwiseClass(A, B, g), x))
     = g
}

-- ----------------------------------------------------------------------
-- Dependent and Prop-domain extensionality. The same quotient construction
-- as `Function.extensionality`, generalised to a dependent codomain `B(x)`
-- and (impredicatively) to a Proposition domain. These are what a
-- well-founded recursion's accessibility proofs need to be shown equal.
-- The round trip through the quotient is closed by congruence rather than a
-- bare calc so no library-theorem search runs on the Prop-domain endpoints.

definition Function.DependentPointwiseEqual (A : Type(0)) (B : A → Type(0))
        (f g : (x : A) → B(x)) : Proposition :=
  ∀ (x : A). f(x) = g(x)

definition Function.dependentPointwiseClass (A : Type(0)) (B : A → Type(0))
        (f : (x : A) → B(x))
        : Quotient((x : A) → B(x), Function.DependentPointwiseEqual(A, B)) :=
  Quotient.class_of(f)

definition Function.dependentApplyClass (A : Type(0)) (B : A → Type(0))
        (q : Quotient((x : A) → B(x), Function.DependentPointwiseEqual(A, B))) (x : A) : B(x) :=
  Quotient.lift(
      (h : (x : A) → B(x)) ↦ h(x),
      (h1 h2 : (x : A) → B(x))
          (pointwise : Function.DependentPointwiseEqual(A, B, h1, h2)) ↦ pointwise(x),
      q)

-- Pointwise-equal dependent functions are equal.
theorem Function.dependent_extensionality (A : Type(0)) (B : A → Type(0))
        (f g : (x : A) → B(x))
        (pointwiseEqual : ∀ (x : A). f(x) = g(x))
        : f = g := {
  Function.dependentPointwiseClass(A, B, f) = Function.dependentPointwiseClass(A, B, g)
      by Quotient.equivalent_implies_equal as classEqual;
  Equality.congruence(
      (q : Quotient((x : A) → B(x), Function.DependentPointwiseEqual(A, B))) ↦
          ((x : A) ↦ Function.dependentApplyClass(A, B, q, x)),
      Function.dependentPointwiseClass(A, B, f), Function.dependentPointwiseClass(A, B, g), classEqual)
}

definition Function.PropositionPointwiseEqual (P : Proposition) (X : Type(0)) (f g : P → X)
        : Proposition :=
  ∀ (p : P). f(p) = g(p)

definition Function.propositionPointwiseClass (P : Proposition) (X : Type(0)) (f : P → X)
        : Quotient(P → X, Function.PropositionPointwiseEqual(P, X)) :=
  Quotient.class_of(f)

definition Function.propositionApplyClass (P : Proposition) (X : Type(0))
        (q : Quotient(P → X, Function.PropositionPointwiseEqual(P, X))) (p : P) : X :=
  Quotient.lift(
      (h : P → X) ↦ h(p),
      (h1 h2 : P → X) (pointwise : Function.PropositionPointwiseEqual(P, X, h1, h2)) ↦ pointwise(p),
      q)

-- Functions out of a Proposition are equal when they agree on every proof
-- (the carrier `P → X` is Type(0) by impredicative Prop).
theorem Function.extensionality_from_proposition (P : Proposition) (X : Type(0)) (f g : P → X)
        (pointwiseEqual : ∀ (p : P). f(p) = g(p))
        : f = g := {
  Function.propositionPointwiseClass(P, X, f) = Function.propositionPointwiseClass(P, X, g)
      by Quotient.equivalent_implies_equal as classEqual;
  Equality.congruence(
      (q : Quotient(P → X, Function.PropositionPointwiseEqual(P, X))) ↦
          ((p : P) ↦ Function.propositionApplyClass(P, X, q, p)),
      Function.propositionPointwiseClass(P, X, f), Function.propositionPointwiseClass(P, X, g), classEqual)
}

-- A function taking an element and then a proof about it — `(x : A) →
-- P(x) → C(x)` — is determined by its values, combining the two
-- extensionalities above.
theorem Function.dependent_extensionality_over_proposition
        (A : Type(0)) (P : A → Proposition) (C : A → Type(0))
        (f g : (x : A) → P(x) → C(x))
        (pointwise : ∀ (x : A). ∀ (p : P(x)). f(x, p) = g(x, p))
        : f = g := {
  ∀ (x : A). f(x) = g(x) by {
    take x : A;
    Function.extensionality_from_proposition(P(x), C(x), f(x), g(x), pointwise(x))
  };
  done by Function.dependent_extensionality(A, (x : A) ↦ (P(x) → C(x)), f, g)
}

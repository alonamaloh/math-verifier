-- Logic/basics.math
--
-- Core propositional connectives. All are Proposition-valued inductive types
-- with one or two constructors. Definitions are conventional: True is
-- inhabited by `trivial`; False is uninhabited; And and Or have the
-- expected introduction rules; Not(A) is sugar for A → False.

module Logic.basics

inductive True : Proposition where
  | True.trivial : True

inductive False : Proposition where
  -- no constructors; False is uninhabited

inductive And (A B : Proposition) : Proposition where
  | And.introduction : A → B → And(A, B)

inductive Or (A B : Proposition) : Proposition where
  | Or.introduceLeft  : A → Or(A, B)
  | Or.introduceRight : B → Or(A, B)

definition Not (A : Proposition) : Proposition := A → False

-- From a proof of False, anything follows. Uses the auto-generated
-- False_recursor, which has the form
--   False_recursor.{u} : (motive : False → Sort u)
--                          → ∀ (target : False). motive(target)
-- The motive ignores its argument (False has no constructors so we
-- never need to handle any case).
definition False.eliminate(GoalType : Type) (proofOfFalse : False)
        : GoalType :=
  False_recursor((_ : False) ↦ GoalType, proofOfFalse)

-- Same idea, but for a Proposition-valued goal. Needed because
-- `False.eliminate`'s `GoalType : Type` parameter binds an auto-bound
-- universe `u`, instantiating to `Type u = Sort (u+1)` — which is never
-- `Sort 0`, the home of Propositions. So a Proposition goal can't be
-- supplied to `False.eliminate` directly.
definition False.eliminate_proposition
        (GoalProposition : Proposition) (proofOfFalse : False)
        : GoalProposition :=
  False_recursor(
      (_ : False) ↦ GoalProposition,
      proofOfFalse)

-- A proposition equivalent to its own negation is absurd. This is the
-- engine of every diagonal argument (Cantor, Russell, Tarski): once a
-- self-referential `Q ⟺ ¬Q` is exhibited, `False` follows. Supplying the
-- contradiction as a named lemma lets those proofs end with one line that
-- reads "Q is equivalent to its own negation — absurd" instead of an
-- open-coded double application of the negation.
theorem Not.self_negation_absurd (Q : Proposition)
        (impliesNegation : Q → Not(Q))
        (negationImplies : Not(Q) → Q)
        : False := {
  let negationOfQ : Not(Q) := (q : Q) ↦ impliesNegation(q)(q);
  negationOfQ(negationImplies(negationOfQ))
}

-- Project the left component of a conjunction.
definition And.left (A B : Proposition) : And(A, B) → A
  | And.introduction(leftProof, _) => leftProof

-- Project the right component of a conjunction.
definition And.right (A B : Proposition) : And(A, B) → B
  | And.introduction(_, rightProof) => rightProof

-- And.swap: And(A, B) → And(B, A).
definition And.swap (A B : Proposition) : And(A, B) → And(B, A)
  | And.introduction(leftProof, rightProof) =>
      And.introduction(rightProof, leftProof)

-- Or.swap: Or(A, B) → Or(B, A).
definition Or.swap (A B : Proposition) : Or(A, B) → Or(B, A)
  | Or.introduceLeft(leftProof)   => Or.introduceRight(leftProof)
  | Or.introduceRight(rightProof) => Or.introduceLeft(rightProof)

-- Or.eliminate (case analysis to a Proposition goal). Lets us
-- handle the left and right alternatives separately.
definition Or.eliminate
        (A B GoalProposition : Proposition)
        (handleLeft : A → GoalProposition)
        (handleRight : B → GoalProposition)
        (disjunction : Or(A, B))
        : GoalProposition :=
  Or_recursor(
    A, B,
    (_ : Or(A, B)) ↦ GoalProposition,
    handleLeft, handleRight, disjunction)

-- And.eliminate (analogous, for conjunctions).
definition And.eliminate
        (A B GoalProposition : Proposition)
        (handler : A → B → GoalProposition)
        (conjunction : And(A, B))
        : GoalProposition :=
  And_recursor(
    A, B,
    (_ : And(A, B)) ↦ GoalProposition,
    handler, conjunction)

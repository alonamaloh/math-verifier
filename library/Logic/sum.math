-- Logic/sum.math
--
-- Type-level disjunction `Sum (A B : Type) : Type`. Unlike `Or`,
-- which lives in `Proposition` and only supports Proposition-valued
-- elimination, `Sum` lives in `Type` and its eliminator returns
-- Type values. This is the escape hatch CIC needs to express
-- "decidable" choices that drive computation.
--
-- Convention matches Coq's `sum` and Lean's `Sum`.

module Logic.sum

inductive Sum (A B : Type) : Type where
  | Sum.left  : A → Sum(A, B)
  | Sum.right : B → Sum(A, B)

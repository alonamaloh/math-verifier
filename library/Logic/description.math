-- Logic/description.math
--
-- The definite-description axiom and its characterising property.

module Logic.description

import axioms
import Logic.basics
import Logic.exists
import Equality.basics
-- ----------------------------------------------------------------------
-- Definite description ("the"): from a proof that EXACTLY ONE element
-- satisfies a predicate, extract that element — together with the fact
-- that it satisfies the predicate. This is unique choice: strictly
-- weaker than Hilbert's ε / the axiom of choice, valid in the
-- set-theoretic model alongside the axioms above, and the standard
-- bridge from "∃! limit / root / inverse" to an actual FUNCTION.
-- Without it, CIC's "no large elimination from Prop" rule blocks
-- turning a functional relation into a function (the unique-choice
-- wall that the explicit bisection constructions worked around).
--
-- Decided 2026-06-12: adopted to support the analysis arc (limits,
-- exp, sqrt as functions) and Schröder–Bernstein.

axiom Logic.the.{u}
    : (T : Type(u)) → (P : T → Proposition)
      → (∃ (x : T). P(x))
      → ((x y : T) → P(x) → P(y) → x = y)
      → T

axiom Logic.the_satisfies.{u}
    : (T : Type(u)) → (P : T → Proposition)
      → (existence : ∃ (x : T). P(x))
      → (uniqueness : (x y : T) → P(x) → P(y) → x = y)
      → P(Logic.the(T, P, existence, uniqueness))


-- Logic/exists.math
--
-- Existential quantification: Exists(A, P) is inhabited by `introduce`
-- given a witness `a : A` and a proof `P(a)`. The introduce constructor
-- carries the witness, so the elimination via the recursor lets us pull
-- the witness back out when proving things of the form "if Exists A P
-- holds, then …".

module Logic.exists

inductive Exists (A : Type) (P : A → Prop) : Prop where
  | Exists.introduce : (a : A) → P(a) → Exists(A, P)

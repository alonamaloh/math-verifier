-- Logic/excluded_middle.math
--
-- Classical machinery derived from `Logic.excluded_middle`. Once
-- excluded middle is in scope, the standard double-negation /
-- quantifier-swap identities follow immediately and are convenient
-- to have under their math names rather than re-derived at every
-- use site.

module Logic.excluded_middle

import Logic.basics
import Logic.exists
import axioms

-- ----------------------------------------------------------------------
-- Double-negation elimination: `¬¬proposition → proposition`. Either the
-- proposition holds, or its negation does — and the latter contradicts
-- `notNotProposition`.
theorem Logic.double_negation_eliminate
        (proposition : Proposition)
        (notNotProposition : Not(Not(proposition)))
        : proposition :=
  claim by cases {
    case proposition       as proof:           proof
    case Not(proposition)  as notProposition:  absurd(notNotProposition(notProposition))
  }

-- ----------------------------------------------------------------------
-- Proof by contradiction with the proposition left implicit, recovered
-- from the goal. The `suppose P for contradiction;` surface form
-- desugars to this: the block proves `Not(Not(proposition))` by refuting
-- the assumed negation, and the goal supplies `proposition`.
theorem Logic.by_contradiction {proposition : Proposition}
        (refuteNegation : Not(Not(proposition)))
        : proposition :=
  Logic.double_negation_eliminate(proposition, refuteNegation)

-- ----------------------------------------------------------------------
-- Negation distributes across implication: `¬(antecedent → consequent)
-- → antecedent ∧ ¬consequent`. Classical, on whether the antecedent holds.
automatic theorem Logic.not_implies_implies_and_not
        (antecedent consequent : Proposition)
        (notImplication : Not(antecedent → consequent))
        : antecedent ∧ Not(consequent) :=
  {
    -- Any proof of `consequent` would make the implication hold constantly,
    -- contradicting `notImplication`.
    claim Not(consequent)
        by (consequentHolds : consequent) ↦
            notImplication((givenAntecedent : antecedent) ↦ consequentHolds);
    -- And `antecedent` must hold: with no antecedent the implication is
    -- vacuous, again contradicting `notImplication`.
    claim antecedent by {
        claim Not(Not(antecedent))
            by (notAntecedent : Not(antecedent)) ↦
                notImplication((givenAntecedent : antecedent) ↦
                    absurd(notAntecedent(givenAntecedent)));
        done
    };
    done
  }

-- ----------------------------------------------------------------------
-- `¬(∀ x. predicate(x)) → ∃ x. ¬predicate(x)`. Standard classical
-- swap. By double-negation elimination it suffices to derive False
-- from `¬∃ x. ¬predicate(x)` and `notForall`: at each x apply DNE
-- pointwise (the ¬∃ kills any ¬predicate(x) witness), reconstructing
-- `∀ x. predicate(x)`, which contradicts `notForall`.
theorem Logic.not_forall_implies_exists_not
        (Domain : Type(0))
        (predicate : Domain → Proposition)
        (notForall : Not(∀ (x : Domain). predicate(x)))
        : ∃ (x : Domain). Not(predicate(x)) := {
  claim Not(Not(∃ (x : Domain). Not(predicate(x))))
      by (notExists : Not(∃ (x : Domain). Not(predicate(x)))) ↦ {
          claim forallPredicate : ∀ (x : Domain). predicate(x)
              by (x : Domain) ↦ {
                  claim Not(Not(predicate(x)))
                      by (notPredicateAtX : Not(predicate(x))) ↦ {
                          claim witnessExists : ∃ (y : Domain). Not(predicate(y))
                              by { witness x with notPredicateAtX };
                          notExists(witnessExists)
                      };
                  done
              };
          notForall(forallPredicate)
      };
  done by Logic.double_negation_eliminate
}

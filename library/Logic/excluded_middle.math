-- Logic/excluded_middle.math
--
-- Classical machinery derived from `Logic.excluded_middle`. Once
-- excluded middle is in scope, the standard double-negation /
-- quantifier-swap identities follow immediately and are convenient
-- to have under their math names rather than re-derived at every
-- use site.

module Logic.excluded_middle

import Logic.basics
import Logic.exists
import axioms

-- ----------------------------------------------------------------------
-- Double-negation elimination: `¬¬proposition → proposition`. Case on
-- excluded_middle: the positive branch returns the proof; the
-- negative branch is absurd from `notNotProposition(notProposition)`.
theorem Logic.double_negation_eliminate
        (proposition : Proposition)
        (notNotProposition : Not(Not(proposition)))
        : proposition :=
  cases Logic.excluded_middle(proposition) {
    | Or.introduceLeft(proof) => proof
    | Or.introduceRight(notProposition) =>
        False.eliminate_proposition(
            proposition, notNotProposition(notProposition))
  }

-- ----------------------------------------------------------------------
-- Negation distributes across implication: `¬(antecedent → consequent)
-- → antecedent ∧ ¬consequent`. Classical — case-split on
-- excluded_middle(antecedent):
--   * antecedent holds: pair it with `¬consequent`, derived because
--     any proof of consequent would satisfy the implication via the
--     constant function, contradicting notImplication.
--   * antecedent fails: notImplication applied to the vacuous
--     ⊥-implication (antecedent → False → consequent) is absurd.
theorem Logic.not_implies_implies_and_not
        (antecedent consequent : Proposition)
        (notImplication : Not(antecedent → consequent))
        : And(antecedent, Not(consequent)) :=
  cases Logic.excluded_middle(antecedent) {
    | Or.introduceLeft(antecedentHolds) =>
        And.introduction(
            antecedent, Not(consequent),
            antecedentHolds,
            function (consequentHolds : consequent) =>
                notImplication(
                    function (_ : antecedent) => consequentHolds))
    | Or.introduceRight(notAntecedent) =>
        False.eliminate_proposition(
            And(antecedent, Not(consequent)),
            notImplication(
                function (antecedentHolds : antecedent) =>
                    False.eliminate_proposition(
                        consequent,
                        notAntecedent(antecedentHolds))))
  }

-- ----------------------------------------------------------------------
-- `¬(∀ x. predicate(x)) → ∃ x. ¬predicate(x)`. Standard classical
-- swap. By double-negation elimination it suffices to derive False
-- from `¬∃ x. ¬predicate(x)` and `notForall`: at each x apply DNE
-- pointwise (the ¬∃ kills any ¬predicate(x) witness), reconstructing
-- `∀ x. predicate(x)`, which contradicts `notForall`.
theorem Logic.not_forall_implies_exists_not
        (Domain : Type(0))
        (predicate : Domain → Proposition)
        (notForall : Not((x : Domain) → predicate(x)))
        : ∃ (x : Domain). Not(predicate(x)) :=
  Logic.double_negation_eliminate(
      ∃ (x : Domain). Not(predicate(x)),
      function (notExistsCounterexample
                    : Not(∃ (x : Domain). Not(predicate(x)))) =>
          notForall(
              function (x : Domain) =>
                  Logic.double_negation_eliminate(
                      predicate(x),
                      function (notPredicateAtX : Not(predicate(x))) =>
                          notExistsCounterexample(
                              Exists.introduce(
                                  Domain,
                                  function (y : Domain) =>
                                      Not(predicate(y)),
                                  x,
                                  notPredicateAtX)))))

-- Logic/quotient.math
--
-- Quotient types: given a type T and an equivalence relation R on T,
-- `Quotient(T, R)` is the type of equivalence classes of T under R.
-- Two `Quotient.mk` applications are equal whenever the underlying
-- representatives are related: `Quotient.sound`. Functions on T that
-- respect R lift to functions on the quotient via `Quotient.lift`.
--
-- The reduction rule `Quotient.lift(_, _, _, f, _, Quotient.mk(_, _,
-- x)) ≡ f(x)` is built into the kernel's `weakHeadNormalForm` so the
-- equivalence is preserved by computation. Without that rule, every
-- compute-step would need an explicit Equality.transport via
-- `Quotient.compute`.
--
-- The API deliberately does NOT expose a vanilla recursor for
-- Quotient — only `lift` (with the respect-proof) and `induction`
-- (with a Proposition-valued predicate). This is what prevents users
-- from "extracting the representative" of an equivalence class and
-- so what makes the quotient sound.

module Logic.quotient

import Logic.basics
import Equality.basics

-- The quotient type itself. T lives in Type(u); the quotient lives in
-- the same universe.
axiom Quotient.{u} : (T : Type(u)) → (R : T → T → Proposition) → Type(u)

-- Construct an equivalence class from a representative.
axiom Quotient.mk.{u}
    : (T : Type(u)) → (R : T → T → Proposition)
      → T → Quotient.{u}(T, R)

-- Two `mk` applications are equal whenever the representatives are
-- related. This is the soundness axiom: equivalent representatives
-- pick the same equivalence class.
axiom Quotient.sound.{u}
    : (T : Type(u)) → (R : T → T → Proposition)
      → (x y : T) → R(x, y)
      → Equality.{u}(Quotient.{u}(T, R),
                       Quotient.mk.{u}(T, R, x),
                       Quotient.mk.{u}(T, R, y))

-- Lift a function that respects R to a function on the quotient. The
-- second-to-last argument is the proof of respect.
axiom Quotient.lift.{u, v}
    : (T : Type(u)) → (R : T → T → Proposition) → (U : Type(v))
      → (f : T → U)
      → ((x y : T) → R(x, y) → Equality.{v}(U, f(x), f(y)))
      → Quotient.{u}(T, R) → U

-- Propositional predicate eliminator: any Proposition that holds for
-- every `Quotient.mk` value holds for every quotient value. This is
-- the soundness-preserving form of induction — it can't be used to
-- extract a representative since the predicate is a Proposition.
axiom Quotient.induct.{u}
    : (T : Type(u)) → (R : T → T → Proposition)
      → (predicate : Quotient.{u}(T, R) → Proposition)
      → ((x : T) → predicate(Quotient.mk.{u}(T, R, x)))
      → (q : Quotient.{u}(T, R)) → predicate(q)

-- Compute rule as a propositional equality: a `reflexivity` proof
-- because the kernel's WHNF rule reduces `Quotient.lift(_, _, _, f, _,
-- Quotient.mk(_, _, x))` to `f(x)` definitionally. Useful when a
-- user needs the equality explicitly (e.g., to transport along a
-- specific predicate).
theorem Quotient.compute.{u, v}
        (T : Type(u)) (R : T → T → Proposition) (U : Type(v))
        (f : T → U)
        (h : (x y : T) → R(x, y) → Equality.{v}(U, f(x), f(y)))
        (x : T)
        : Equality.{v}(U,
                       Quotient.lift.{u, v}(
                           T, R, U, f, h, Quotient.mk.{u}(T, R, x)),
                       f(x)) :=
  reflexivity.{v}(U, f(x))

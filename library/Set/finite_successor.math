-- Set/finite_successor.math
--
-- The recursive backbone of counting and the smallest nontrivial size.
-- The sum rule at m = 1 says NaturalsBelow(1) ⊎ NaturalsBelow(n) ≅
-- NaturalsBelow(1 + n): adjoining one point to an n-element type yields
-- an (n+1)-element type. That is the step every inductive counting
-- argument runs on. Alongside it we pin down NaturalsBelow(1) itself — a
-- single point — which is the base those inductions start from.

module Set.finite_successor

import Logic.basics
import Logic.sum
import Equality.basics
import Set.subtype
import Set.equinumerous
import Set.finite
import Set.finite_sum
import Natural.basics
import Natural.order
import Natural.strong_recursion

-- Only 0 lies below 1: k < 1 collapses to k ≤ 0, which forces k = 0.
theorem NaturalsBelow.below_one_is_zero (k : ℕ)
        (belowOne : k < 1) : k = 0 := {
  k ≤ 0 by Natural.le_of_lt_one_plus;
  done by Natural.less_or_equal_zero_implies_equals_zero
}

-- NaturalsBelow(1) is inhabited: 0 is its single point.
definition NaturalsBelow.one_point : NaturalsBelow(1) :=
  NaturalsBelow.make(0, Natural.lt_one_plus(0))

-- NaturalsBelow(1) is a subsingleton: any two elements are equal, since
-- both have value 0.
theorem NaturalsBelow.one_subsingleton (a b : NaturalsBelow(1)) : a = b :=
  NaturalsBelow.equal_of_value(1, a, b,
      { NaturalsBelow.value(a)
         = 0                      by NaturalsBelow.below_one_is_zero
         = NaturalsBelow.value(b) by NaturalsBelow.below_one_is_zero })

-- The one-more-point decomposition: NaturalsBelow(1) ⊎ NaturalsBelow(n)
-- is the same size as NaturalsBelow(1 + n) — the sum bijection at m = 1.
theorem NaturalsBelow.one_plus_equinumerous (n : ℕ)
        : Equinumerous(DisjointUnion(NaturalsBelow(1), NaturalsBelow(n)), NaturalsBelow(1 + n)) :=
  done by NaturalsBelow.sum_equinumerous

-- Counting, one element at a time: adjoining a fresh point to a size-n
-- type gives a size-(n+1) type.
theorem HasSize.one_plus (X : Type(0)) (n : ℕ) (sizeX : HasSize(X, n))
        : HasSize(DisjointUnion(NaturalsBelow(1), X), 1 + n) := {
  HasSize(NaturalsBelow(1), 1) by NaturalsBelow.has_size;
  done by HasSize.sum
}

-- Set/basics.math
--
-- A set over a type T is a predicate `T → Proposition`. Members of
-- the set are exactly the elements satisfying the predicate.
--
-- Operators `∈` (membership) and `⊆` (subset) are registered against
-- `Set` so call sites read as math: `x ∈ S`, `A ⊆ B`. The operator
-- registry uses wildcard `_` for the LHS of `∈` since membership
-- carriers are arbitrary.

module Set.basics

import Logic.basics
import Logic.exists
import Equality.basics

definition Set (T : Type(0)) : Type(0) :=
  T → Proposition

-- Membership. The `{T}` implicit is inferred from `subject` at call
-- sites; the operator dispatch infers it the same way.
definition Set.member {T : Type(0)} (subject : T) (subset : Set(T))
        : Proposition :=
  subset(subject)

operator (∈) on (_, Set) := Set.member

definition Set.subset {T : Type(0)} (smaller larger : Set(T))
        : Proposition :=
  (subject : T) → subject ∈ smaller → subject ∈ larger

operator (⊆) on (Set, Set) := Set.subset

-- Transport membership along an equality of sets: from `source = target`
-- and `subject ∈ source`, conclude `subject ∈ target`. `rewrite` struggles
-- here because membership reduces (`x ∈ {…}` unfolds to the predicate
-- body), erasing the set spelling it would need to target; this lemma
-- hands `transport_proposition` the membership predicate directly, so call
-- sites read "membership moves along the set equality."
theorem Set.transport_member {T : Type(0)} (subject : T)
        (source target : Set(T)) (setsEqual : source = target)
        (member : subject ∈ source) : subject ∈ target :=
  Equality.transport_proposition(
      (candidate : Set(T)) ↦ subject ∈ candidate,
      source, target, setsEqual, member)

-- `Set.IsNonempty(T, S)` — the carrier is passed explicitly because
-- the implicit-argument inference machinery requires an outer
-- expectedType to engage, and many call sites (the `(h :
-- Set.IsNonempty(S))` binder, where no expectedType is propagated)
-- can't supply one. Operator-call paths fill implicits without
-- needing expectedType; ordinary calls don't.
definition Set.IsNonempty (carrier : Type(0)) (subset : Set(carrier))
        : Proposition :=
  ∃ (subject : carrier). subject ∈ subset

theorem Set.subset.reflexive {T : Type(0)} (subset : Set(T))
        : subset ⊆ subset :=
  (subject : T) (memberInSubset : subject ∈ subset) ↦
    memberInSubset

theorem Set.subset.transitive
        {T : Type(0)} (a b c : Set(T))
        (aSubB : a ⊆ b) (bSubC : b ⊆ c)
        : a ⊆ c :=
  (subject : T) (memberInA : subject ∈ a) ↦
    bSubC(subject, aSubB(subject, memberInA))

-- Set/finite_pigeonhole.math
--
-- The pigeonhole principle and the well-definedness of size. An injective
-- map between yardsticks cannot shrink: NaturalsBelow(m) ↪ NaturalsBelow(n)
-- forces m ≤ n. The proof is by induction on n; the inductive step takes an
-- injection out of NaturalsBelow(1+k) and produces one out of
-- NaturalsBelow(k) by "redirecting" the one input that could collide.
-- Antisymmetry then gives uniqueness of size: a type has at most one size.

module Set.finite_pigeonhole

import Logic.basics
import Logic.exists
import Equality.basics
import Set.subtype
import Set.equinumerous
import Set.finite
import Natural.basics
import Natural.order
import Natural.add_order
import Natural.strong_recursion
import Natural.compare

-- The inclusion NaturalsBelow(k) ↪ NaturalsBelow(1 + k): keep the
-- value, loosen the bound by one.
theorem NaturalsBelow.value_below_one_add (k : Natural) (element : NaturalsBelow(k))
        : NaturalsBelow.value(element) < 1 + k :=
  calc NaturalsBelow.value(element)
     < k
     ≤ 1 + k

definition NaturalsBelow.inclusion (k : Natural) (element : NaturalsBelow(k))
        : NaturalsBelow(1 + k) :=
  NaturalsBelow.make(NaturalsBelow.value(element), NaturalsBelow.value_below_one_add)

-- The top element of NaturalsBelow(1 + k): value k.
definition NaturalsBelow.top (k : Natural) : NaturalsBelow(1 + k) :=
  NaturalsBelow.make(k, Natural.lt_one_plus)

-- ----------------------------------------------------------------------
-- The redirect. Given an injection f : NaturalsBelow(1+k) → NaturalsBelow(1+n')
-- we build an injection NaturalsBelow(k) → NaturalsBelow(n'). For an input i,
-- look at where f sends the inclusion of i. If that image is already below n',
-- keep it; otherwise it must equal n' (the only value of NaturalsBelow(1+n')
-- that is not below n'), and we redirect to where f sends the top element k.
-- Injectivity of f keeps the top's image out of the way.

-- The bound used by the redirect's "at least n'" branch: when f(inclusion i)
-- is at least n', the image of the top element is strictly below n'.
-- PROOF: write v = value(f(inclusion i)) and L = value(f(top)). From the
-- bound on f(inclusion i) we get v ≤ n'; with n' ≤ v this gives v = n'.
-- Likewise L ≤ n'. So it suffices to show n' ≠ L. If n' = L, then
-- L = n' = v, so f(top) and f(inclusion i) have equal values, hence are
-- equal; injectivity of f forces top = inclusion i, and reading off values
-- gives k = value i — impossible, since value i < k.
theorem NaturalsBelow.pigeonhole_top_value_below (k n' : Natural)
        (f : NaturalsBelow(1 + k) → NaturalsBelow(1 + n'))
        (inj : Function.IsInjective(NaturalsBelow(1 + k), NaturalsBelow(1 + n'), f))
        (i : NaturalsBelow(k))
        (atLeast : n' ≤ NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i))))
        : NaturalsBelow.value(f(NaturalsBelow.top(k))) < n' := {
  let imageValue : Natural := NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i)));
  let topValue : Natural := NaturalsBelow.value(f(NaturalsBelow.top(k)));
  imageValue < 1 + n';
  imageValue ≤ n' by Natural.le_cancel_one_plus;
  -- imageValue is both ≤ n' and (atLeast) ≥ n', so it equals n'.
  imageValue = n' by Natural.le_antisymmetric;
  topValue < 1 + n';
  topValue ≤ n' by Natural.le_cancel_one_plus;
  -- topValue ≠ n': otherwise top and inclusion i collide under f.
  topValue ≠ n' by {
    suppose topValue = n' for contradiction {
      -- topValue = n' = imageValue, so f(top) and f(incl i) share a value,
      -- hence are equal; injectivity forces top = incl i, i.e. k = value i.
      topValue = imageValue;
      f(NaturalsBelow.top(k)) = f(NaturalsBelow.inclusion(k, i));
      NaturalsBelow.top(k) = NaturalsBelow.inclusion(k, i);
      NaturalsBelow.value(NaturalsBelow.top(k))
                = NaturalsBelow.value(NaturalsBelow.inclusion(k, i));
      NaturalsBelow.value(i)
                < k
                = NaturalsBelow.value(i);
      done by Natural.lt_irreflexive
    }
  };
  done by Natural.lt_of_le_of_ne
}

-- The redirect map itself: branch on how f(inclusion i) compares to n'.
definition NaturalsBelow.pigeonhole_redirect (k n' : Natural)
        (f : NaturalsBelow(1 + k) → NaturalsBelow(1 + n'))
        (inj : Function.IsInjective(NaturalsBelow(1 + k), NaturalsBelow(1 + n'), f))
        : NaturalsBelow(k) → NaturalsBelow(n') :=
  (i : NaturalsBelow(k)) ↦
    cases Natural.compare_strict(NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i))), n') {
      | Natural.StrictComparison.below(strictlyBelow) =>
          NaturalsBelow.make(NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i))), Natural.lt_of_add_one_le)
      | Natural.StrictComparison.atLeast(atLeast) =>
          NaturalsBelow.make(NaturalsBelow.value(f(NaturalsBelow.top(k))),
              NaturalsBelow.pigeonhole_top_value_below)
    }

-- Reading off the redirect's value. Branching on the comparison reduces
-- the redirect: in the "below" branch its value is value(f(incl i)) (the
-- "at least" branch is then ruled out by the strict bound), and in the
-- "at least" branch its value is value(f(top)) (the "below" branch is
-- ruled out symmetrically). These two equations are all the injectivity
-- proof needs.
theorem NaturalsBelow.pigeonhole_redirect_value_below (k n' : Natural)
        (f : NaturalsBelow(1 + k) → NaturalsBelow(1 + n'))
        (inj : Function.IsInjective(NaturalsBelow(1 + k), NaturalsBelow(1 + n'), f))
        (i : NaturalsBelow(k))
        (strictlyBelow : NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i))) < n')
        : NaturalsBelow.value(NaturalsBelow.pigeonhole_redirect(k, n', f, inj, i))
            = NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i))) :=
  cases Natural.compare_strict(NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i))), n') {
    | Natural.StrictComparison.below(strictlyBelowAgain) =>
        reflexivity(NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i))))
    | Natural.StrictComparison.atLeast(atLeast) => {
        -- value(f(incl i)) ≥ n' contradicts value(f(incl i)) < n'.
        NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i)))
           < n'
           ≤ NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i)));
        False by Natural.lt_irreflexive;
        okay
      }
  }

theorem NaturalsBelow.pigeonhole_redirect_value_at_least (k n' : Natural)
        (f : NaturalsBelow(1 + k) → NaturalsBelow(1 + n'))
        (inj : Function.IsInjective(NaturalsBelow(1 + k), NaturalsBelow(1 + n'), f))
        (i : NaturalsBelow(k))
        (atLeast : n' ≤ NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i))))
        : NaturalsBelow.value(NaturalsBelow.pigeonhole_redirect(k, n', f, inj, i))
            = NaturalsBelow.value(f(NaturalsBelow.top(k))) :=
  cases Natural.compare_strict(NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i))), n') {
    | Natural.StrictComparison.below(strictlyBelow) => {
        -- value(f(incl i)) < n' contradicts value(f(incl i)) ≥ n'.
        NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i)))
           < n'
           ≤ NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i)));
        False by Natural.lt_irreflexive;
        okay
      }
    | Natural.StrictComparison.atLeast(atLeastAgain) =>
        reflexivity(NaturalsBelow.value(f(NaturalsBelow.top(k))))
  }

-- Two inputs whose inclusions get the same f-image are equal. This is the
-- shared "both stayed below n'" closing move of the injectivity proof:
-- inj turns equal images into equal inclusions, and reading off values
-- (value(inclusion i) ≡ value i) gives value i = value j, hence i = j.
theorem NaturalsBelow.pigeonhole_inclusion_image_injective (k n' : Natural)
        (f : NaturalsBelow(1 + k) → NaturalsBelow(1 + n'))
        (inj : Function.IsInjective(NaturalsBelow(1 + k), NaturalsBelow(1 + n'), f))
        (i j : NaturalsBelow(k))
        (imagesEqual : f(NaturalsBelow.inclusion(k, i)) = f(NaturalsBelow.inclusion(k, j)))
        : i = j := {
  NaturalsBelow.inclusion(k, i) = NaturalsBelow.inclusion(k, j);
  -- value(inclusion i) ≡ value i and value(inclusion j) ≡ value j.
  NaturalsBelow.value(NaturalsBelow.inclusion(k, i))
            = NaturalsBelow.value(NaturalsBelow.inclusion(k, j));
  done
}

-- The "one stayed below, one redirected to the top" cross case is
-- impossible: it would make f send the inclusion of i and the top element
-- to the same place, so inj collapses inclusion i and top, and reading off
-- values gives value i = k — contradicting value i < k.
theorem NaturalsBelow.pigeonhole_inclusion_not_top (k n' : Natural)
        (f : NaturalsBelow(1 + k) → NaturalsBelow(1 + n'))
        (inj : Function.IsInjective(NaturalsBelow(1 + k), NaturalsBelow(1 + n'), f))
        (i : NaturalsBelow(k))
        (imagesEqual : f(NaturalsBelow.inclusion(k, i)) = f(NaturalsBelow.top(k)))
        : False := {
  NaturalsBelow.inclusion(k, i) = NaturalsBelow.top(k);
  -- value(inclusion i) ≡ value i and value(top) ≡ k.
  NaturalsBelow.value(NaturalsBelow.inclusion(k, i))
            = NaturalsBelow.value(NaturalsBelow.top(k));
  NaturalsBelow.value(i)
            < k
            = NaturalsBelow.value(i);
  done by Natural.lt_irreflexive
}

-- The redirect is injective. Take i, j with redirect(i) = redirect(j) and
-- split on how each f(inclusion …) compares to n'. In the two "same side"
-- cases the equality of redirects is an equality of values, which feeds
-- the shared inclusion-image closing move; the two "different side" cases
-- are impossible (the equality identifies an inclusion-image with the
-- top-image), so they are closed by contradiction.
theorem NaturalsBelow.pigeonhole_redirect_injective (k n' : Natural)
        (f : NaturalsBelow(1 + k) → NaturalsBelow(1 + n'))
        (inj : Function.IsInjective(NaturalsBelow(1 + k), NaturalsBelow(1 + n'), f))
        : Function.IsInjective(NaturalsBelow(k), NaturalsBelow(n'),
              NaturalsBelow.pigeonhole_redirect(k, n', f, inj)) :=
  (i j : NaturalsBelow(k))
  (equalRedirect : NaturalsBelow.pigeonhole_redirect(k, n', f, inj, i)
                     = NaturalsBelow.pigeonhole_redirect(k, n', f, inj, j)) ↦ {
  -- The two redirects have equal underlying values (read off equalRedirect).
  NaturalsBelow.value(NaturalsBelow.pigeonhole_redirect(k, n', f, inj, i))
          = NaturalsBelow.value(NaturalsBelow.pigeonhole_redirect(k, n', f, inj, j));
  -- Branch on how each image compares to n'; the reduction lemmas read off
  -- each redirect's value in the matching branch.
  cases Natural.compare_strict(NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i))), n') {
    | Natural.StrictComparison.below(strictlyBelowI) =>
        cases Natural.compare_strict(NaturalsBelow.value(f(NaturalsBelow.inclusion(k, j))), n') {
          | Natural.StrictComparison.below(strictlyBelowJ) => {
              -- Both stayed below n': both redirects are the images.
              NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i))) < n';
              NaturalsBelow.value(f(NaturalsBelow.inclusion(k, j))) < n';
              NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i)))
                        = NaturalsBelow.value(NaturalsBelow.pigeonhole_redirect(k, n', f, inj, i))
                        = NaturalsBelow.value(NaturalsBelow.pigeonhole_redirect(k, n', f, inj, j))
                        = NaturalsBelow.value(f(NaturalsBelow.inclusion(k, j)));
              f(NaturalsBelow.inclusion(k, i)) = f(NaturalsBelow.inclusion(k, j));
              okay
            }
          | Natural.StrictComparison.atLeast(atLeastJ) => {
              -- i stayed below, j redirected to the top: impossible.
              NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i))) < n';
              NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i)))
                        = NaturalsBelow.value(NaturalsBelow.pigeonhole_redirect(k, n', f, inj, i))
                        = NaturalsBelow.value(NaturalsBelow.pigeonhole_redirect(k, n', f, inj, j))
                        = NaturalsBelow.value(f(NaturalsBelow.top(k)));
              f(NaturalsBelow.inclusion(k, i)) = f(NaturalsBelow.top(k));
              False;
              okay
            }
        }
    | Natural.StrictComparison.atLeast(atLeastI) =>
        cases Natural.compare_strict(NaturalsBelow.value(f(NaturalsBelow.inclusion(k, j))), n') {
          | Natural.StrictComparison.below(strictlyBelowJ) => {
              -- j stayed below, i redirected to the top: impossible.
              NaturalsBelow.value(f(NaturalsBelow.inclusion(k, j))) < n';
              NaturalsBelow.value(f(NaturalsBelow.inclusion(k, j)))
                        = NaturalsBelow.value(NaturalsBelow.pigeonhole_redirect(k, n', f, inj, j))
                        = NaturalsBelow.value(NaturalsBelow.pigeonhole_redirect(k, n', f, inj, i))
                        = NaturalsBelow.value(f(NaturalsBelow.top(k)));
              f(NaturalsBelow.inclusion(k, j)) = f(NaturalsBelow.top(k));
              False;
              okay
            }
          | Natural.StrictComparison.atLeast(atLeastJ) => {
              -- Both at least n': each image value equals n', so the images
              -- agree directly (the redirect equality is unneeded here).
              NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i))) < 1 + n';
              NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i))) ≤ n'
                  by Natural.le_cancel_one_plus;
              NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i))) = n' by Natural.le_antisymmetric;
              NaturalsBelow.value(f(NaturalsBelow.inclusion(k, j))) < 1 + n';
              NaturalsBelow.value(f(NaturalsBelow.inclusion(k, j))) ≤ n'
                  by Natural.le_cancel_one_plus;
              NaturalsBelow.value(f(NaturalsBelow.inclusion(k, j))) = n' by Natural.le_antisymmetric;
              NaturalsBelow.value(f(NaturalsBelow.inclusion(k, i)))
                        = n'
                        = NaturalsBelow.value(f(NaturalsBelow.inclusion(k, j)));
              f(NaturalsBelow.inclusion(k, i)) = f(NaturalsBelow.inclusion(k, j));
              okay
            }
        }
  }
}

-- ----------------------------------------------------------------------
-- The pigeonhole principle: an injection NaturalsBelow(m) ↪ NaturalsBelow(n)
-- forces m ≤ n. Induction on n (so the inductive hypothesis stays
-- polymorphic in the domain size m). At n = 0 either m = 0 (then 0 ≤ 0) or
-- m = 1 + k, and the injection sends a point into the empty
-- NaturalsBelow(0) — impossible. At n = 1 + n' either m = 0
-- (then 0 ≤ 1 + n') or m = 1 + k, and the redirect turns f
-- into an injection NaturalsBelow(k) ↪ NaturalsBelow(n'); the hypothesis
-- gives k ≤ n', and 1 + k ≤ 1 + n' follows.
theorem NaturalsBelow.injective_domain_le_codomain (n : Natural)
        : ∀ (m : Natural).
          (f : NaturalsBelow(m) → NaturalsBelow(n))
          → Function.IsInjective(NaturalsBelow(m), NaturalsBelow(n), f)
          → m ≤ n :=
  by_induction on n with IH {
    case base: {
        take m : Natural;
        take f : NaturalsBelow(m) → NaturalsBelow(0);
        take inj : Function.IsInjective(NaturalsBelow(m), NaturalsBelow(0), f);
        by_induction on m with mIH refining f, inj {
          case base: { okay }
          case step(k): {
              -- Any point of NaturalsBelow(1 + k) maps into the empty
              -- NaturalsBelow(0) — impossible.
              NaturalsBelow(0) by f(NaturalsBelow.top(k));
              False by NaturalsBelow.zero_is_empty;
              okay
            }
        }
      }
    case step(n'): {
        take m : Natural;
        take f : NaturalsBelow(m) → NaturalsBelow(1 + n');
        take inj : Function.IsInjective(NaturalsBelow(m), NaturalsBelow(1 + n'), f);
        by_induction on m with mIH refining f, inj {
          case base: { okay by Natural.zero_least }
          case step(k): {
              -- Redirect f to an injection out of NaturalsBelow(k), recurse;
              -- k ≤ n' then lifts to 1 + k ≤ 1 + n'.
              Function.IsInjective(NaturalsBelow(k), NaturalsBelow(n'),
                      NaturalsBelow.pigeonhole_redirect(k, n', f, inj)) as redirectInjective;
              k ≤ n' by IH(k, NaturalsBelow.pigeonhole_redirect(k, n', f, inj), redirectInjective);
              claim (1 + k) ≤ (1 + n');
            }
        }
      }
  }

-- The contrapositive: if the codomain is strictly smaller, no injection
-- exists. From an injection we would get m ≤ n, but n < m then yields
-- n < n, which is impossible.
theorem NaturalsBelow.no_injection_when_smaller (m n : Natural)
        (smaller : n < m)
        (f : NaturalsBelow(m) → NaturalsBelow(n))
        (inj : Function.IsInjective(NaturalsBelow(m), NaturalsBelow(n), f))
        : False := {
  m ≤ n;
  n
     < m
     ≤ n;
  done by Natural.lt_irreflexive
}

-- Uniqueness of size: a type has at most one size. Two sizes m and n make
-- the yardsticks NaturalsBelow(m) and NaturalsBelow(n) equinumerous, whose
-- inverse pair gives injections in both directions; pigeonhole then forces
-- m ≤ n and n ≤ m, and antisymmetry concludes m = n.
theorem HasSize.unique (X : Type(0)) (m n : Natural)
        (sizeM : HasSize(X, m)) (sizeN : HasSize(X, n)) : m = n := {
  Equinumerous(NaturalsBelow(m), X) by Equinumerous.symmetric;
  Equinumerous(X, NaturalsBelow(n));
  Equinumerous(NaturalsBelow(m), NaturalsBelow(n)) as yardsticksEquinumerous;
  choose forward from yardsticksEquinumerous;
  choose backward such that Function.IsInverse(NaturalsBelow(m), NaturalsBelow(n), forward, backward);
  Function.IsInverse(NaturalsBelow(n), NaturalsBelow(m), backward, forward);
  Function.IsInjective(NaturalsBelow(m), NaturalsBelow(n), forward) by Function.inverse_is_injective;
  Function.IsInjective(NaturalsBelow(n), NaturalsBelow(m), backward) by Function.inverse_is_injective;
  m ≤ n by NaturalsBelow.injective_domain_le_codomain;
  n ≤ m by NaturalsBelow.injective_domain_le_codomain;
  done by Natural.le_antisymmetric
}

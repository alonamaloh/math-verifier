-- Set/finite_sum.math
--
-- The sum rule of counting: |X ⊎ Y| = |X| + |Y|. Its heart is an explicit
-- bijection between the disjoint union of two yardsticks and a single
-- yardstick — `NaturalsBelow(m) ⊎ NaturalsBelow(n) ≅ NaturalsBelow(m+n)`
-- — laying {0,…,m-1} and {0,…,n-1} end to end, the right block shifted up
-- by m. The inverse decides, for each k below m+n, which block it landed
-- in; that decision is `Natural.compare_strict` (a Type-valued comparison,
-- since the inverse is data).

module Set.finite_sum

import Logic.basics
import Logic.exists
import Logic.sum
import Equality.basics
import Set.subtype
import Set.equinumerous
import Set.finite
import Natural.basics
import Natural.order
import Natural.arithmetic
import Natural.monus
import Natural.divide
import Natural.add_order
import Natural.strong_recursion
import Natural.compare

-- If m ≤ k, then k splits as m plus its excess over m.
theorem NaturalsBelow.decompose_at_least (m k : Natural) (atLeast : m ≤ k)
        : k = m + Natural.monus(k, m) :=
  Natural.monus_zero_implies_decompose(m, k,
      Natural.le_implies_monus_zero(k, m, atLeast))

-- ----------------------------------------------------------------------
-- Three bound facts: a value below one block is still below the union,
-- after the appropriate shift. Naming them keeps the bijection itself
-- free of inequality bookkeeping.

-- A value already below m is below m + n: the left block stays put.
theorem NaturalsBelow.below_extends (m n value : Natural) (belowM : successor(value) ≤ m)
        : successor(value) ≤ m + n :=
  calc successor(value)
     ≤ m
     ≤ m + n   by Natural.less_or_equal_add_right

-- A value below n, shifted up by m, is below m + n: the right block.
theorem NaturalsBelow.below_shifts (m n value : Natural) (belowN : successor(value) ≤ n)
        : successor(m + value) ≤ m + n :=
  calc successor(m + value)
     = m + successor(value)   by Natural.add_successor(m, value)
     ≤ m + n                  by Natural.add_left_monotone

-- Conversely, a value at least m and below m + n drops below n once shifted
-- down by m. Rewrite the bound as `m + successor(value − m) ≤ m + n` using
-- `value = m + (value − m)`, then cancel m on the left.
theorem NaturalsBelow.below_unshifts (m n value : Natural)
        (atLeast : m ≤ value) (belowSum : successor(value) ≤ m + n)
        : successor(Natural.monus(value, m)) ≤ n := {
  claim shifted : m + successor(Natural.monus(value, m)) ≤ m + n
      by calc m + successor(Natural.monus(value, m))
            = successor(m + Natural.monus(value, m))   by Natural.add_successor(m, Natural.monus(value, m))
            = successor(value)                          by NaturalsBelow.decompose_at_least(m, value, atLeast)
            ≤ m + n;
  claim by Natural.add_left_le_cancel
}

-- ----------------------------------------------------------------------
-- The bijection.

-- Lay the two blocks end to end.
definition NaturalsBelow.sum_into (m n : Natural)
        : Sum.{0,0,0}(NaturalsBelow(m), NaturalsBelow(n)) → NaturalsBelow(m + n)
  | Sum.left(element) =>
      NaturalsBelow.make(NaturalsBelow.value(element),
          NaturalsBelow.below_extends(m, n, NaturalsBelow.value(element), NaturalsBelow.below(element)))
  | Sum.right(element) =>
      NaturalsBelow.make(m + NaturalsBelow.value(element),
          NaturalsBelow.below_shifts(m, n, NaturalsBelow.value(element), NaturalsBelow.below(element)))

-- The inverse: compare the value against m. Below m → the left block,
-- keeping the value. At least m → the right block, value shifted down by m.
definition NaturalsBelow.sum_out_of (m n : Natural)
        : NaturalsBelow(m + n) → Sum.{0,0,0}(NaturalsBelow(m), NaturalsBelow(n)) :=
  (element : NaturalsBelow(m + n)) ↦
    cases Natural.compare_strict(NaturalsBelow.value(element), m) {
      | Natural.StrictComparison.below(strictlyBelow) =>
          Sum.left.{0,0,0}(NaturalsBelow(m), NaturalsBelow(n),
              NaturalsBelow.make(NaturalsBelow.value(element), strictlyBelow))
      | Natural.StrictComparison.atLeast(atLeast) =>
          Sum.right.{0,0,0}(NaturalsBelow(m), NaturalsBelow(n),
              NaturalsBelow.make(Natural.monus(NaturalsBelow.value(element), m),
                  NaturalsBelow.below_unshifts(m, n, NaturalsBelow.value(element),
                      atLeast, NaturalsBelow.below(element))))
    }

-- ----------------------------------------------------------------------
-- The two inverse laws. Both turn on the dichotomy `compare_strict` makes;
-- in each, the impossible branch is a value strictly below itself.

-- out_of recovers the summand into placed.
theorem NaturalsBelow.sum_round_trip_left (m n : Natural)
        (s : Sum.{0,0,0}(NaturalsBelow(m), NaturalsBelow(n)))
        : NaturalsBelow.sum_out_of(m, n, NaturalsBelow.sum_into(m, n, s)) = s :=
  cases s {
    | Sum.left(element) =>
        cases Natural.compare_strict(NaturalsBelow.value(element), m) {
          -- The value really is below m, so out_of returns it to the left.
          | Natural.StrictComparison.below(strictlyBelow) =>
              congruenceOf(
                  (summand : NaturalsBelow(m)) ↦
                      Sum.left.{0,0,0}(NaturalsBelow(m), NaturalsBelow(n), summand),
                  NaturalsBelow.equal_of_value(m,
                      NaturalsBelow.make(NaturalsBelow.value(element), strictlyBelow), element,
                      reflexivity(Natural, NaturalsBelow.value(element))))
          -- m ≤ value contradicts value < m.
          | Natural.StrictComparison.atLeast(atLeast) =>
              absurd(Natural.not_successor_less_or_equal_self(NaturalsBelow.value(element),
                  LessOrEqual.transitive(
                      successor(NaturalsBelow.value(element)), m, NaturalsBelow.value(element),
                      atLeast, NaturalsBelow.below(element))))
        }
    | Sum.right(element) =>
        cases Natural.compare_strict(m + NaturalsBelow.value(element), m) {
          -- m + value < m is impossible, since m ≤ m + value.
          | Natural.StrictComparison.below(strictlyBelow) =>
              absurd(Natural.not_successor_less_or_equal_self(m + NaturalsBelow.value(element),
                  LessOrEqual.transitive(
                      successor(m + NaturalsBelow.value(element)), m, m + NaturalsBelow.value(element),
                      Natural.less_or_equal_add_right(m, NaturalsBelow.value(element)), strictlyBelow)))
          -- The shifted value, brought back down by m, is the original.
          | Natural.StrictComparison.atLeast(atLeast) =>
              congruenceOf(
                  (summand : NaturalsBelow(n)) ↦
                      Sum.right.{0,0,0}(NaturalsBelow(m), NaturalsBelow(n), summand),
                  NaturalsBelow.equal_of_value(n,
                      NaturalsBelow.make(Natural.monus(m + NaturalsBelow.value(element), m),
                          NaturalsBelow.below_unshifts(m, n, m + NaturalsBelow.value(element), atLeast,
                              NaturalsBelow.below_shifts(m, n, NaturalsBelow.value(element),
                                  NaturalsBelow.below(element)))),
                      element,
                      Natural.monus_add_cancel(m, NaturalsBelow.value(element))))
        }
  }

-- into reassembles whatever out_of split. The below branch holds because the
-- value is unchanged; the atLeast branch because m + (value − m) = value.
theorem NaturalsBelow.sum_round_trip_right (m n : Natural)
        (element : NaturalsBelow(m + n))
        : NaturalsBelow.sum_into(m, n, NaturalsBelow.sum_out_of(m, n, element)) = element :=
  cases Natural.compare_strict(NaturalsBelow.value(element), m) {
    | Natural.StrictComparison.below(strictlyBelow) =>
        NaturalsBelow.equal_of_value(m + n, ?, element,
            reflexivity(Natural, NaturalsBelow.value(element)))
    | Natural.StrictComparison.atLeast(atLeast) =>
        NaturalsBelow.equal_of_value(m + n, ?, element,
            Equality.symmetry(Natural,
                NaturalsBelow.value(element), m + Natural.monus(NaturalsBelow.value(element), m),
                NaturalsBelow.decompose_at_least(m, NaturalsBelow.value(element), atLeast)))
  }

-- The two yardsticks laid end to end form one.
theorem NaturalsBelow.sum_equinumerous (m n : Natural)
        : Equinumerous(Sum.{0,0,0}(NaturalsBelow(m), NaturalsBelow(n)), NaturalsBelow(m + n)) :=
  ⟨NaturalsBelow.sum_into(m, n),
   ⟨NaturalsBelow.sum_out_of(m, n),
    And.introduction(
        NaturalsBelow.sum_round_trip_left(m, n),
        NaturalsBelow.sum_round_trip_right(m, n))⟩⟩

-- ----------------------------------------------------------------------
-- Disjoint union respects sameness of size, then the sum rule itself.

-- Replacing each side of a disjoint union by an equinumerous type gives an
-- equinumerous union: map each summand through its component bijection.
theorem Equinumerous.sum_congruence (A A' B B' : Type(0))
        (firstSame : Equinumerous(A, A')) (secondSame : Equinumerous(B, B'))
        : Equinumerous(Sum.{0,0,0}(A, B), Sum.{0,0,0}(A', B')) := {
  obtain ⟨forwardA, forwardATail⟩ from firstSame;
  obtain ⟨backwardA, inverseA⟩ from forwardATail;
  obtain ⟨forwardB, forwardBTail⟩ from secondSame;
  obtain ⟨backwardB, inverseB⟩ from forwardBTail;
  obtain ⟨leftA, rightA⟩ from inverseA;
  obtain ⟨leftB, rightB⟩ from inverseB;
  ⟨(s : Sum.{0,0,0}(A, B)) ↦
       cases s {
         | Sum.left(a)  => Sum.left.{0,0,0}(A', B', forwardA(a))
         | Sum.right(b) => Sum.right.{0,0,0}(A', B', forwardB(b))
       },
   ⟨(s : Sum.{0,0,0}(A', B')) ↦
        cases s {
          | Sum.left(a)  => Sum.left.{0,0,0}(A, B, backwardA(a))
          | Sum.right(b) => Sum.right.{0,0,0}(A, B, backwardB(b))
        },
    And.introduction(
        (s : Sum.{0,0,0}(A, B)) ↦
            cases s {
              | Sum.left(a)  => congruenceOf((x : A) ↦ Sum.left.{0,0,0}(A, B, x), leftA(a))
              | Sum.right(b) => congruenceOf((x : B) ↦ Sum.right.{0,0,0}(A, B, x), leftB(b))
            },
        (s : Sum.{0,0,0}(A', B')) ↦
            cases s {
              | Sum.left(a)  => congruenceOf((y : A') ↦ Sum.left.{0,0,0}(A', B', y), rightA(a))
              | Sum.right(b) => congruenceOf((y : B') ↦ Sum.right.{0,0,0}(A', B', y), rightB(b))
            })⟩⟩
}

-- The sum rule: a size-m type and a size-n type have a size-(m+n) union.
-- Compose the componentwise bijection with the end-to-end one.
theorem HasSize.sum (X Y : Type(0)) (m n : Natural)
        (sizeX : HasSize(X, m)) (sizeY : HasSize(Y, n))
        : HasSize(Sum.{0,0,0}(X, Y), m + n) :=
  Equinumerous.transitive(
      Sum.{0,0,0}(X, Y), Sum.{0,0,0}(NaturalsBelow(m), NaturalsBelow(n)), NaturalsBelow(m + n),
      Equinumerous.sum_congruence(X, NaturalsBelow(m), Y, NaturalsBelow(n), sizeX, sizeY),
      NaturalsBelow.sum_equinumerous(m, n))

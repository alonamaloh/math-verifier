-- Set/cantor.math
--
-- Cantor's theorem: no function from a type X onto its power set Set(X)
-- is surjective. In particular Set(X) is strictly "bigger" than X, so the
-- power set of the naturals is not enumerable — the prototype of an
-- uncountable collection.
--
-- The proof is the diagonal argument. Given f : X → Set(X), form the
-- diagonal set  D = { x | x ∉ f(x) }.  If some d had f(d) = D then
-- "d ∈ D" would mean both "d ∈ f(d)" (since f(d) = D) and "d ∉ f(d)" (the
-- defining property of D) — a contradiction. So D is not in the image and
-- f is not surjective.

module Set.cantor

import Logic.basics
import Logic.exists
import Equality.basics
import Set.basics
import Logic.functions

-- The diagonal set of f: the elements their own image leaves out.
definition Cantor.diagonal (X : Type(0)) (f : X → Set(X)) : Set(X) :=
  (x : X) ↦ Not(x ∈ f(x))

-- No surjection X → Set(X) exists.
theorem Cantor.no_surjection_onto_powerset (X : Type(0))
        (f : X → Set(X))
        : Not(Function.IsSurjective(X, Set(X), f)) :=
  (surjective : Function.IsSurjective(X, Set(X), f)) ↦ {
    -- By surjectivity some d maps onto the diagonal.
    obtain ⟨d, imageIsDiagonal⟩ from surjective(Cantor.diagonal(X, f));
    -- "d ∈ diagonal" is by definition "d ∉ f(d)", and f(d) = diagonal lets
    -- membership move between the two sets. So "d ∈ f(d)" is equivalent to
    -- its own negation — absurd.
    Not.self_negation_absurd(d ∈ f(d),
        (inImage : d ∈ f(d)) ↦
            Set.transport_member(d, f(d), Cantor.diagonal(X, f),
                imageIsDiagonal, inImage),
        (notInImage : Not(d ∈ f(d))) ↦
            Set.transport_member(d, Cantor.diagonal(X, f), f(d),
                Equality.symmetry(imageIsDiagonal), notInImage))
  }

-- ----------------------------------------------------------------------
-- The other half of "Set(X) is strictly bigger than X": X does embed
-- into its power set, by sending each point to its singleton. With the
-- theorem above (no surjection X → Set(X)), this is the order-theoretic
-- statement that the power set is strictly larger.

-- The singleton set {x}.
definition Set.singleton (X : Type(0)) (x : X) : Set(X) :=
  (y : X) ↦ y = x

-- x ↦ {x} is injective: if {x} = {y} then, since x ∈ {x}, also x ∈ {y},
-- i.e. x = y.
theorem Set.singleton_is_injective (X : Type(0))
        : Function.IsInjective(X, Set(X), Set.singleton(X)) :=
  (x y : X) (singletonsEqual : Set.singleton(X, x) = Set.singleton(X, y)) ↦
    -- Move "x is a member" along {x} = {y}: x ∈ {x} holds (x = x), so
    -- x ∈ {y}, which is x = y.
    Set.transport_member(x, Set.singleton(X, x), Set.singleton(X, y),
        singletonsEqual, reflexivity(X, x))

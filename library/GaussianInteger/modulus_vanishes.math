-- GaussianInteger/modulus_vanishes.math
--
-- The coordinate map kills multiples of the modulus x²+1 — the second
-- half (with additivity) of what makes it descend through the (x²+1)-
-- congruence. The engine is `coords(x·p)`: multiplying by x rotates the
-- coordinates, (re, im) ↦ (−im, re). Multiplying by x twice negates, so
-- coords((x²+1)·q) = coords(x²·q) ⊕ coords(q) = −coords(q) ⊕ coords(q) = 0.

module GaussianInteger.modulus_vanishes

import Logic.basics
import Logic.product
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Algebra.ring
import Algebra.ring_bundle
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Polynomial.basics
import Polynomial.addition
import Polynomial.multiplication
import Polynomial.multiply_laws
import Polynomial.monomial
import GaussianInteger.basics
import GaussianInteger.coordinates
import GaussianInteger.coordinate_homomorphism

-- ----------------------------------------------------------------------
-- Multiplying by x rotates the coordinates: coords(x·p) = (−im p, re p).
--
-- x's coefficient list is shift([1]), so multiplying by x is, up to the
-- equivalence, a shift: x·k ~ shift(1·k) ~ shift(k). `coords` transports
-- through the equivalence (coordinatesOfCoefficients_respects), and a
-- shift rotates the coordinates (coordinatesOfCoefficients_shift).
theorem GaussianInteger.coordinatesOfPolynomial_times_x
        (p : Polynomial(Integer, Integer.zero))
        : coords(GaussianInteger.x * p)
          = Product.make(
                -Product.second(coords(p)),
                Product.first(coords(p))) :=
  cases p { | k => {
    let one : Polynomial.Coefficients(Integer) :=
        Polynomial.Coefficients.cons(Integer, Integer.one,
            Polynomial.Coefficients.nil(Integer));
    -- The two coefficient-level equivalences behind "x· is a shift".
    claim oneTimesK
        : Polynomial.ExtensionallyEqual(Integer, Integer.zero,
              Polynomial.Coefficients.multiply(Integer.ring_bundle, one, k), k)
        by Polynomial.Coefficients.multiply_one_left(Integer.ring_bundle, k);
    claim shiftedProduct
        : Polynomial.ExtensionallyEqual(Integer, Integer.zero,
              Polynomial.Coefficients.multiply(Integer.ring_bundle,
                  Polynomial.Coefficients.shift(Integer.ring_bundle, one), k),
              Polynomial.Coefficients.shift(Integer.ring_bundle,
                  Polynomial.Coefficients.multiply(Integer.ring_bundle, one, k)))
        by Polynomial.Coefficients.shift_multiply;
    claim shiftedOneTimesK
        : Polynomial.ExtensionallyEqual(Integer, Integer.zero,
              Polynomial.Coefficients.shift(Integer.ring_bundle,
                  Polynomial.Coefficients.multiply(Integer.ring_bundle, one, k)),
              Polynomial.Coefficients.shift(Integer.ring_bundle, k))
        by Polynomial.Coefficients.shift_respects;
    -- Transport `coords` along each equivalence in turn, then rotate.
    calc coords(Polynomial.Coefficients.multiply(Integer.ring_bundle,
                 Polynomial.Coefficients.shift(Integer.ring_bundle, one), k))
       = coords(Polynomial.Coefficients.shift(Integer.ring_bundle,
                 Polynomial.Coefficients.multiply(Integer.ring_bundle, one, k)))
             by GaussianInteger.coordinatesOfCoefficients_respects
       = coords(Polynomial.Coefficients.shift(Integer.ring_bundle, k))
             by GaussianInteger.coordinatesOfCoefficients_respects
       = Product.make(
             -Product.second(coords(k)),
             Product.first(coords(k)))
             by GaussianInteger.coordinatesOfCoefficients_shift
  } }

-- ----------------------------------------------------------------------
-- Additivity lifted to ℤ[x] (polynomial add lifts coefficient-list add).
theorem GaussianInteger.coordinatesOfPolynomial_add
        (p q : Polynomial(Integer, Integer.zero))
        : coords(p + q)
          = Product.make(
                Product.first(coords(p)) + Product.first(coords(q)),
                Product.second(coords(p)) + Product.second(coords(q))) :=
  cases p { | a =>
    cases q { | b =>
      GaussianInteger.coordinatesOfCoefficients_add(a, b)
    }
  }

-- ----------------------------------------------------------------------
-- Multiplying by x twice negates both coordinates: coords(x·(x·q)) = −coords(q).
theorem GaussianInteger.coordinatesOfPolynomial_times_x_squared
        (q : Polynomial(Integer, Integer.zero))
        : coords(GaussianInteger.x * (GaussianInteger.x * q))
          = Product.make(
                -Product.first(coords(q)),
                -Product.second(coords(q))) :=
  calc coords(GaussianInteger.x * (GaussianInteger.x * q))
     = Product.make(
           -Product.second(coords(GaussianInteger.x * q)),
           Product.first(coords(GaussianInteger.x * q)))
           by GaussianInteger.coordinatesOfPolynomial_times_x
     = Product.make(
           -Product.first(coords(q)),
           -Product.second(coords(q)))
           by {
             -- substitute the single-x rotation coords(x·q) = (−im q, re q)
             -- into each coordinate
             claim -Product.second(coords(GaussianInteger.x * q)) = -Product.first(coords(q))
                 by substituting GaussianInteger.coordinatesOfPolynomial_times_x(q);
             claim Product.first(coords(GaussianInteger.x * q)) = -Product.second(coords(q))
                 by substituting GaussianInteger.coordinatesOfPolynomial_times_x(q);
             done
           }

-- ----------------------------------------------------------------------
-- (x²+1)·q = x·(x·q) + q, by distributivity / associativity / 1·q = q.
theorem GaussianInteger.multiply_modulus
        (q : Polynomial(Integer, Integer.zero))
        : GaussianInteger.modulus * q
          = GaussianInteger.x * (GaussianInteger.x * q) + q :=
  calc GaussianInteger.modulus * q
     = GaussianInteger.x * GaussianInteger.x * q + Polynomial.one(Integer.ring_bundle) * q
           by Polynomial.multiply_distributivity_right
     = GaussianInteger.x * (GaussianInteger.x * q) + Polynomial.one(Integer.ring_bundle) * q
           by Polynomial.multiply_associative
     = GaussianInteger.x * (GaussianInteger.x * q) + q
           by Polynomial.multiply_one_left

-- ----------------------------------------------------------------------
-- The payoff: coords((x²+1)·q) = (0, 0).
theorem GaussianInteger.coordinatesOfPolynomial_modulus_multiply
        (q : Polynomial(Integer, Integer.zero))
        : coords(GaussianInteger.modulus * q)
          = Product.make(Integer.zero, Integer.zero) :=
  calc coords(GaussianInteger.modulus * q)
     = coords(GaussianInteger.x * (GaussianInteger.x * q) + q)
           by GaussianInteger.multiply_modulus
     = Product.make(
           Product.first(coords(GaussianInteger.x * (GaussianInteger.x * q))) + Product.first(coords(q)),
           Product.second(coords(GaussianInteger.x * (GaussianInteger.x * q))) + Product.second(coords(q)))
           by GaussianInteger.coordinatesOfPolynomial_add
     = Product.make(
           -Product.first(coords(q)) + Product.first(coords(q)),
           -Product.second(coords(q)) + Product.second(coords(q)))
           by {
             -- substitute the double-x rotation coords(x·(x·q)) = (−re q, −im q)
             -- into each coordinate
             claim Product.first(coords(GaussianInteger.x * (GaussianInteger.x * q))) + Product.first(coords(q))
                 = -Product.first(coords(q)) + Product.first(coords(q))
                 by substituting GaussianInteger.coordinatesOfPolynomial_times_x_squared(q);
             claim Product.second(coords(GaussianInteger.x * (GaussianInteger.x * q))) + Product.second(coords(q))
                 = -Product.second(coords(q)) + Product.second(coords(q))
                 by substituting GaussianInteger.coordinatesOfPolynomial_times_x_squared(q);
             done
           }
     = Product.make(Integer.zero, Integer.zero)
           by {
             -- each coordinate is −a + a = 0
             claim -Product.first(coords(q)) + Product.first(coords(q)) = Integer.zero;
             claim -Product.second(coords(q)) + Product.second(coords(q)) = Integer.zero;
             done
           }

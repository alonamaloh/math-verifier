-- GaussianInteger/sum_of_two_squares.math
--
-- The descent step of Fermat's two-squares theorem (Freek #20), carried
-- out in ℤ[i]. If a prime p (as an integer) divides m² + 1, then p is a
-- sum of two integer squares.
--
-- The argument: bigP = embed(p) divides α·β where α = m + i, β = m − i
-- (because α·β = embed(m² + 1)). But bigP divides neither α nor β (else p
-- would divide the imaginary part ±1). So bigP is not irreducible in the
-- PID ℤ[i]; nor is it zero or a unit (its norm is p²). Hence it has a
-- factorization bigP = aG·bG into two non-units, each of norm ≥ 2, whose
-- norms multiply to p². By `prime_square_factor` the norm of aG is exactly
-- p, i.e. p = re(aG)² + im(aG)².

module GaussianInteger.sum_of_two_squares

import Logic.basics
import Logic.sum
import Logic.exists
import Logic.product
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.add_order
import Natural.strong_recursion
import Natural.prime
import Natural.prime_divides_product
import Natural.prime_square
import Natural.multiply_bounds
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.embedding
import Integer.divisibility
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Algebra.ring_divisibility
import Algebra.integral_domain
import Algebra.irreducible
import Algebra.principal_ideal_domain
import Logic.excluded_middle
import RingModulo.basics
import RingModulo.operations
import GaussianInteger.basics
import GaussianInteger.coordinates
import GaussianInteger.coordinate_map
import GaussianInteger.norm
import GaussianInteger.reconstruction
import GaussianInteger.of_coordinates
import GaussianInteger.norm_natural
import GaussianInteger.integral_domain
import GaussianInteger.units
import GaussianInteger.euclidean

-- ----------------------------------------------------------------------
-- Helper: a prime, embedded in ℤ, does not divide 1.
theorem Integer.prime_natural_not_divides_one (p : Natural)
        (primality : Natural.is_prime(p))
        (dividesOne : Integer.divides((p : Integer), Integer.one))
        : False := {
  claim oneCast : Integer.one = (Natural.to_integer(1));
  claim Integer.divides((p : Integer), (Natural.to_integer(1)))
      by substituting oneCast;
  claim Natural.divides(p, 1) by Integer.natural_divides_of_integer_divides;
  claim pEqualOne : p = 1 since Natural.divides_one_implies_equals_one;
  claim 2 ≤ p since Natural.is_prime.at_least_two;
  claim 2 ≤ 1 by substituting pEqualOne;
  done
}

-- ----------------------------------------------------------------------
-- Helper: 1 ≤ x and x ≠ 1 force 2 ≤ x.
theorem Natural.at_least_two_of_at_least_one_and_not_one (x : Natural)
        (atLeastOne : 1 ≤ x) (notOne : ¬(x = 1))
        : 2 ≤ x := {
  done by Natural.less_or_equal_not_equal_successor
}

-- ----------------------------------------------------------------------
-- The descent step of the two-squares theorem.
theorem GaussianInteger.sum_of_two_squares_of_divides_square_plus_one
        (p : Natural) (primality : Natural.is_prime(p))
        (m : Integer)
        (dividesSquarePlusOne : Integer.divides((p : Integer), m * m + Integer.one))
        : ∃ (a : Integer). ∃ (b : Integer). (p : Integer) = a * a + b * b := {
  let s : Ring := GaussianInteger.ring_bundle;
  let bigP : GaussianInteger := GaussianInteger.embedInteger((p : Integer));
  let alpha : GaussianInteger := GaussianInteger.ofCoordinates(m, Integer.one);
  let beta : GaussianInteger := GaussianInteger.ofCoordinates(m, -(Integer.one));

  claim 2 ≤ p since Natural.is_prime.at_least_two;
  claim 1 ≤ p by Natural.is_prime.positive;

  -- Step 1: α·β = embed(m² + 1).
  claim alphaCoordinates : coords(alpha) = Product.make(m, Integer.one);
  claim betaCoordinates : coords(beta) = Product.make(m, -(Integer.one));
  claim firstSimplify : m * m - Integer.one * (-(Integer.one)) = m * m + Integer.one by ring;
  claim secondSimplify : m * (-(Integer.one)) + Integer.one * m = Integer.zero by ring;
  calc coords(alpha * beta)
            = GaussianInteger.gaussianProduct(coords(alpha), coords(beta))
                  by GaussianInteger.coordinates_multiply
            = GaussianInteger.gaussianProduct(Product.make(m, Integer.one), coords(beta))
                  by substituting alphaCoordinates
            = GaussianInteger.gaussianProduct(Product.make(m, Integer.one),
                  Product.make(m, -(Integer.one)))
                  by substituting betaCoordinates
            = Product.make(m * m - Integer.one * (-(Integer.one)),
                  m * (-(Integer.one)) + Integer.one * m)
            = Product.make(m * m + Integer.one, m * (-(Integer.one)) + Integer.one * m)
                  by substituting firstSimplify
            = Product.make(m * m + Integer.one, Integer.zero)
                  by substituting secondSimplify
            = coords(GaussianInteger.embedInteger(m * m + Integer.one));
  claim alphaBetaEqual : alpha * beta = GaussianInteger.embedInteger(m * m + Integer.one)
      by GaussianInteger.coordinates_injective;

  -- Step 2: bigP divides α·β.
  choose q such that m * m + Integer.one = (p : Integer) * q as qEqual from dividesSquarePlusOne;
  claim Ring.divides(s, bigP, alpha * beta)
      by witness GaussianInteger.embedInteger(q) with
          calc alpha * beta
             = GaussianInteger.embedInteger(m * m + Integer.one)   by alphaBetaEqual
             = GaussianInteger.embedInteger((p : Integer) * q)     by substituting qEqual
             = bigP * GaussianInteger.embedInteger(q);

  -- Step 3: bigP divides neither α nor β.
  claim bigPNotDividesAlpha : ¬(Ring.divides(s, bigP, alpha))
      by {
        suppose Ring.divides(s, bigP, alpha) as dividesAlpha;
        claim Integer.divides((p : Integer), Product.second(coords(alpha)))
            by GaussianInteger.embedInteger_divides_imaginary;
        calc Product.second(coords(alpha))
                  = Product.second(Product.make(m, Integer.one))   by substituting alphaCoordinates
                  = Integer.one
            as imaginaryOne;
        claim Integer.divides((p : Integer), Integer.one) by substituting imaginaryOne;
        done since Integer.prime_natural_not_divides_one
      };
  claim bigPNotDividesBeta : ¬(Ring.divides(s, bigP, beta))
      by {
        suppose Ring.divides(s, bigP, beta) as dividesBeta;
        claim Integer.divides((p : Integer), Product.second(coords(beta)))
            by GaussianInteger.embedInteger_divides_imaginary;
        calc Product.second(coords(beta))
                  = Product.second(Product.make(m, -(Integer.one)))   by substituting betaCoordinates
                  = -(Integer.one)
            as imaginaryNegOne;
        claim Integer.divides((p : Integer), -(Integer.one)) by substituting imaginaryNegOne;
        choose quotientNeg such that -(Integer.one) = (p : Integer) * quotientNeg as negEqual;
        claim Integer.divides((p : Integer), Integer.one)
            by witness -(quotientNeg) with
                calc Integer.one
                   = -(-(Integer.one))
                   = -((p : Integer) * quotientNeg)        by substituting negEqual
                   = (p : Integer) * (-(quotientNeg));
        done since Integer.prime_natural_not_divides_one
      };

  -- Step 5: bigP ≠ 0.
  claim bigPNotZero : ¬(bigP = Ring.zero(s))
      by {
        suppose bigP = Ring.zero(s) as bigPZero;
        claim GaussianInteger.normNatural(GaussianInteger.embedInteger((p : Integer))) = p * p;
        calc p * p
                  = GaussianInteger.normNatural(bigP)
                  = GaussianInteger.normNatural(Ring.zero(s))   by substituting bigPZero
                  = 0   by GaussianInteger.normNatural_zero
            as normEqual;
        claim p ≤ p * p
            by Natural.le_multiply_when_factor_at_least_one;
        claim p ≤ 0 by substituting normEqual;
        calc (2 : Natural) ≤ p ≤ 0;
        done
      };

  -- Step 6: bigP is not a unit.
  claim ¬(Ring.IsUnit(s, bigP))
      by {
        suppose Ring.IsUnit(s, bigP) as bigPUnit;
        choose w such that Ring.one(s) = bigP * w as oneEqual from bigPUnit;
        let factor : GaussianInteger := w;
        calc (1 : Natural)
                  = GaussianInteger.normNatural(Ring.one(s))   by GaussianInteger.normNatural_one
                  = GaussianInteger.normNatural(bigP * factor)   by substituting oneEqual
                  = GaussianInteger.normNatural(bigP) * GaussianInteger.normNatural(factor)
                  = (p * p) * GaussianInteger.normNatural(factor)
                        by substituting (GaussianInteger.normNatural(bigP) = p * p)
            as normProduct;
        claim (p * p) ∣ 1 by witness GaussianInteger.normNatural(factor) with normProduct;
        claim squareEqualOne : p * p = 1 since Natural.divides_one_implies_equals_one;
        claim p ≤ p * p
            by Natural.le_multiply_when_factor_at_least_one;
        claim p ≤ 1 by substituting squareEqualOne;
        calc (2 : Natural) ≤ p ≤ 1;
        done
      };

  -- Step 4 + 7: bigP is not irreducible, so the factorization clause fails.
  claim ¬(∀ (a b : Ring.carrier(s)). bigP = a * b
            → Ring.IsUnit(s, a) ∨ Ring.IsUnit(s, b))
      by {
        suppose ∀ (a b : Ring.carrier(s)). bigP = a * b
            → Ring.IsUnit(s, a) ∨ Ring.IsUnit(s, b) as factorClause;
        claim IntegralDomain.IsIrreducible(GaussianInteger.integral_domain, bigP);
        claim Ring.divides(s, bigP, alpha) ∨ Ring.divides(s, bigP, beta)
            by PrincipalIdealDomain.irreducible_divides_factor(
                   pid := GaussianInteger.principal_ideal_domain);
        claim by cases {
          in (Ring.divides(s, bigP, alpha)) as dividesAlpha: done since bigPNotDividesAlpha
          in (Ring.divides(s, bigP, beta)) as dividesBeta: done since bigPNotDividesBeta
        }
      };

  -- Peel the failing ∀-clause into an explicit non-unit factorization.
  choose aG such that ¬(∀ (b : Ring.carrier(s)). bigP = aG * b
          → Ring.IsUnit(s, aG) ∨ Ring.IsUnit(s, b))
      from Logic.not_forall_implies_exists_not(
               predicate := (a : Ring.carrier(s)) ↦ (∀ (b : Ring.carrier(s)). bigP = a * b
                   → Ring.IsUnit(s, a) ∨ Ring.IsUnit(s, b)));
  choose bG such that ¬(bigP = aG * bG
          → Ring.IsUnit(s, aG) ∨ Ring.IsUnit(s, bG))
      from Logic.not_forall_implies_exists_not(
               predicate := (b : Ring.carrier(s)) ↦ (bigP = aG * b
                   → Ring.IsUnit(s, aG) ∨ Ring.IsUnit(s, b)));
  claim bigP = aG * bG ∧ ¬(Ring.IsUnit(s, aG) ∨ Ring.IsUnit(s, bG))
      by Logic.not_implies_implies_and_not;
  claim bigPFactored : bigP = aG * bG;
  claim notOrUnit : ¬(Ring.IsUnit(s, aG) ∨ Ring.IsUnit(s, bG));
  let aGauss : GaussianInteger := aG;
  claim aGNotUnit : ¬(Ring.IsUnit(s, aG))
      by {
        suppose Ring.IsUnit(s, aG) as aGUnit;
        claim Ring.IsUnit(s, aG) ∨ Ring.IsUnit(s, bG);
        done since notOrUnit
      };
  claim bGNotUnit : ¬(Ring.IsUnit(s, bG))
      by {
        suppose Ring.IsUnit(s, bG) as bGUnit;
        claim Ring.IsUnit(s, aG) ∨ Ring.IsUnit(s, bG);
        done since notOrUnit
      };

  -- Step 8: aG ≠ 0 and bG ≠ 0 (else bigP = aG·bG = 0).
  claim ¬(aG = Ring.zero(s))
      by {
        suppose aG = Ring.zero(s) as aGZero;
        calc bigP
                  = aG * bG                  by bigPFactored
                  = Ring.zero(s) * bG        by substituting aGZero
                  = Ring.zero(s);
        done since bigPNotZero
      };
  claim ¬(bG = Ring.zero(s))
      by {
        suppose bG = Ring.zero(s) as bGZero;
        calc bigP
                  = aG * bG                  by bigPFactored
                  = aG * Ring.zero(s)        by substituting bGZero
                  = Ring.zero(s);
        done since bigPNotZero
      };

  -- Step 9: norms of aG and bG are ≥ 2.
  claim 1 ≤ GaussianInteger.normNatural(aG)
      by GaussianInteger.normNatural_positive;
  claim 1 ≤ GaussianInteger.normNatural(bG)
      by GaussianInteger.normNatural_positive;
  claim ¬(GaussianInteger.normNatural(aG) = 1)
      by {
        suppose GaussianInteger.normNatural(aG) = 1 as aGNormOne;
        calc GaussianInteger.normInteger(aG)
                  = (GaussianInteger.normNatural(aG) : Integer)
                  = (Natural.to_integer(1))   by substituting aGNormOne
                  = Integer.one;
        claim Ring.IsUnit(s, aG) by GaussianInteger.unit_of_normInteger_one;
        done since aGNotUnit
      };
  claim ¬(GaussianInteger.normNatural(bG) = 1)
      by {
        suppose GaussianInteger.normNatural(bG) = 1 as bGNormOne;
        calc GaussianInteger.normInteger(bG)
                  = (GaussianInteger.normNatural(bG) : Integer)
                  = (Natural.to_integer(1))   by substituting bGNormOne
                  = Integer.one;
        claim Ring.IsUnit(s, bG) by GaussianInteger.unit_of_normInteger_one;
        done since bGNotUnit
      };
  claim 2 ≤ GaussianInteger.normNatural(aG)
      since Natural.at_least_two_of_at_least_one_and_not_one;
  claim 2 ≤ GaussianInteger.normNatural(bG)
      since Natural.at_least_two_of_at_least_one_and_not_one;

  -- Step 10: norm(aG)·norm(bG) = p², so norm(aG) = p.
  calc GaussianInteger.normNatural(aG) * GaussianInteger.normNatural(bG)
            = GaussianInteger.normNatural(aG * bG)
            = GaussianInteger.normNatural(bigP)   by substituting bigPFactored
            = p * p;
  claim aGNormEqualP : GaussianInteger.normNatural(aG) = p
      since Natural.prime_square_factor;

  -- Step 11: p = re(aG)² + im(aG)².
  calc (p : Integer)
            = (GaussianInteger.normNatural(aG) : Integer)   by substituting aGNormEqualP
            = GaussianInteger.normInteger(aGauss)
            = re(aGauss) * re(aGauss)
              + im(aGauss) * im(aGauss)
      as pEqualNorm;
  witness re(aGauss) with witness im(aGauss) with pEqualNorm
}

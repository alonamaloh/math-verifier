-- GaussianInteger/coordinate_multiplicative.math
--
-- The coordinate map is multiplicative: coords(p·q) = coords(p) ⊗ coords(q),
-- where ⊗ is the Gaussian product (a,b)⊗(c,d) = (ac−bd, ad+bc) on pairs —
-- i.e. "evaluation at i is a ring homomorphism". This is what makes the
-- norm multiplicative. Proved by induction on the first coefficient list,
-- using additivity, the shift (×x) rotation, and a scale (×constant) lemma.

module GaussianInteger.coordinate_multiplicative

import Logic.basics
import Logic.product
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Algebra.ring
import Algebra.ring_bundle
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Polynomial.basics
import Polynomial.addition
import Polynomial.multiplication
import GaussianInteger.basics
import GaussianInteger.coordinates
import GaussianInteger.coordinate_homomorphism

-- ----------------------------------------------------------------------
-- The Gaussian product on coordinate pairs.
definition GaussianInteger.gaussianProduct (u v : Pair(Integer, Integer))
        : Pair(Integer, Integer) :=
  Product.make(
      Product.first(u) * Product.first(v) - Product.second(u) * Product.second(v),
      Product.first(u) * Product.second(v) + Product.second(u) * Product.first(v))

-- ----------------------------------------------------------------------
-- Scaling a coefficient list by a constant scales both coordinates.
theorem GaussianInteger.coordinatesOfCoefficients_scale (a : Integer)
        : (k : Polynomial.Coefficients(Integer))
          → GaussianInteger.coordinatesOfCoefficients(
                Polynomial.Coefficients.scale(Integer.ring_bundle, a, k))
            = Product.make(
                  a * Product.first(GaussianInteger.coordinatesOfCoefficients(k)),
                  a * Product.second(GaussianInteger.coordinatesOfCoefficients(k)))
  | Polynomial.Coefficients.nil =>
      Product.make_equal(Integer, Integer,
          Integer.zero, a * Integer.zero, Integer.zero, a * Integer.zero, ring, ring)
  | Polynomial.Coefficients.cons(c, rest) => {
      claim ih
          : GaussianInteger.coordinatesOfCoefficients(
                Polynomial.Coefficients.scale(Integer.ring_bundle, a, rest))
            = Product.make(
                  a * Product.first(GaussianInteger.coordinatesOfCoefficients(rest)),
                  a * Product.second(GaussianInteger.coordinatesOfCoefficients(rest)))
          by GaussianInteger.coordinatesOfCoefficients_scale(a, rest);
      Product.make_equal(Integer, Integer,
          a * c - Product.second(GaussianInteger.coordinatesOfCoefficients(
              Polynomial.Coefficients.scale(Integer.ring_bundle, a, rest))),
          a * (c - Product.second(GaussianInteger.coordinatesOfCoefficients(rest))),
          Product.first(GaussianInteger.coordinatesOfCoefficients(
              Polynomial.Coefficients.scale(Integer.ring_bundle, a, rest))),
          a * Product.first(GaussianInteger.coordinatesOfCoefficients(rest)),
          calc a * c - Product.second(GaussianInteger.coordinatesOfCoefficients(
                   Polynomial.Coefficients.scale(Integer.ring_bundle, a, rest)))
             = a * c - a * Product.second(GaussianInteger.coordinatesOfCoefficients(rest))
                   by congruenceOf(
                          (pair : Pair(Integer, Integer)) ↦ a * c - Product.second(pair), ih)
             = a * (c - Product.second(GaussianInteger.coordinatesOfCoefficients(rest)))
                   by ring,
          congruenceOf((pair : Pair(Integer, Integer)) ↦ Product.first(pair), ih))
    }

-- ----------------------------------------------------------------------
-- Multiplicativity on coefficient lists: coords(p·q) = coords(p) ⊗ coords(q).
-- Induction on p. On cons(a, restA): p·q = scale(a, q) + shift(restA·q), so
-- coords(p·q) = a·coords(q) ⊕ i·(coords(restA)⊗coords(q)), which is the
-- Gaussian product coords(cons(a,restA)) ⊗ coords(q) by ring.
theorem GaussianInteger.coordinatesOfCoefficients_multiply
        : (p q : Polynomial.Coefficients(Integer))
          → GaussianInteger.coordinatesOfCoefficients(
                Polynomial.Coefficients.multiply(Integer.ring_bundle, p, q))
            = GaussianInteger.gaussianProduct(
                  GaussianInteger.coordinatesOfCoefficients(p),
                  GaussianInteger.coordinatesOfCoefficients(q))
  | Polynomial.Coefficients.nil, q =>
      -- coords(nil·q) = coords(nil) = (0,0) = (0,0) ⊗ coords(q).
      Product.make_equal(Integer, Integer,
          Integer.zero,
          Integer.zero * Product.first(GaussianInteger.coordinatesOfCoefficients(q))
              - Integer.zero * Product.second(GaussianInteger.coordinatesOfCoefficients(q)),
          Integer.zero,
          Integer.zero * Product.second(GaussianInteger.coordinatesOfCoefficients(q))
              + Integer.zero * Product.first(GaussianInteger.coordinatesOfCoefficients(q)),
          ring, ring)
  | Polynomial.Coefficients.cons(a, restA), q => {
      claim ihMultiply
          : GaussianInteger.coordinatesOfCoefficients(
                Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q))
            = GaussianInteger.gaussianProduct(
                  GaussianInteger.coordinatesOfCoefficients(restA),
                  GaussianInteger.coordinatesOfCoefficients(q))
          by GaussianInteger.coordinatesOfCoefficients_multiply(restA, q);
      claim scaleCoordinates
          : GaussianInteger.coordinatesOfCoefficients(
                Polynomial.Coefficients.scale(Integer.ring_bundle, a, q))
            = Product.make(
                  a * Product.first(GaussianInteger.coordinatesOfCoefficients(q)),
                  a * Product.second(GaussianInteger.coordinatesOfCoefficients(q)))
          by GaussianInteger.coordinatesOfCoefficients_scale(a, q);
      claim shiftCoordinates
          : GaussianInteger.coordinatesOfCoefficients(
                Polynomial.Coefficients.shift(Integer.ring_bundle,
                    Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))
            = Product.make(
                  Integer.negate(Product.second(GaussianInteger.coordinatesOfCoefficients(
                      Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))),
                  Product.first(GaussianInteger.coordinatesOfCoefficients(
                      Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q))))
          by GaussianInteger.coordinatesOfCoefficients_shift(
                 Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q));
      calc GaussianInteger.coordinatesOfCoefficients(
               Polynomial.Coefficients.add(Integer.ring_bundle,
                   Polynomial.Coefficients.scale(Integer.ring_bundle, a, q),
                   Polynomial.Coefficients.shift(Integer.ring_bundle,
                       Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q))))
         = Product.make(
               Product.first(GaussianInteger.coordinatesOfCoefficients(
                   Polynomial.Coefficients.scale(Integer.ring_bundle, a, q)))
                   + Product.first(GaussianInteger.coordinatesOfCoefficients(
                         Polynomial.Coefficients.shift(Integer.ring_bundle,
                             Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))),
               Product.second(GaussianInteger.coordinatesOfCoefficients(
                   Polynomial.Coefficients.scale(Integer.ring_bundle, a, q)))
                   + Product.second(GaussianInteger.coordinatesOfCoefficients(
                         Polynomial.Coefficients.shift(Integer.ring_bundle,
                             Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))))
             by GaussianInteger.coordinatesOfCoefficients_add(
                    Polynomial.Coefficients.scale(Integer.ring_bundle, a, q),
                    Polynomial.Coefficients.shift(Integer.ring_bundle,
                        Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))
         = GaussianInteger.gaussianProduct(
               GaussianInteger.coordinatesOfCoefficients(
                   Polynomial.Coefficients.cons(Integer, a, restA)),
               GaussianInteger.coordinatesOfCoefficients(q))
             by Product.make_equal(Integer, Integer,
                    Product.first(GaussianInteger.coordinatesOfCoefficients(
                        Polynomial.Coefficients.scale(Integer.ring_bundle, a, q)))
                        + Product.first(GaussianInteger.coordinatesOfCoefficients(
                              Polynomial.Coefficients.shift(Integer.ring_bundle,
                                  Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))),
                    (a - Product.second(GaussianInteger.coordinatesOfCoefficients(restA)))
                        * Product.first(GaussianInteger.coordinatesOfCoefficients(q))
                        - Product.first(GaussianInteger.coordinatesOfCoefficients(restA))
                          * Product.second(GaussianInteger.coordinatesOfCoefficients(q)),
                    Product.second(GaussianInteger.coordinatesOfCoefficients(
                        Polynomial.Coefficients.scale(Integer.ring_bundle, a, q)))
                        + Product.second(GaussianInteger.coordinatesOfCoefficients(
                              Polynomial.Coefficients.shift(Integer.ring_bundle,
                                  Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))),
                    (a - Product.second(GaussianInteger.coordinatesOfCoefficients(restA)))
                        * Product.second(GaussianInteger.coordinatesOfCoefficients(q))
                        + Product.first(GaussianInteger.coordinatesOfCoefficients(restA))
                          * Product.first(GaussianInteger.coordinatesOfCoefficients(q)),
                    -- first component
                    calc Product.first(GaussianInteger.coordinatesOfCoefficients(
                             Polynomial.Coefficients.scale(Integer.ring_bundle, a, q)))
                             + Product.first(GaussianInteger.coordinatesOfCoefficients(
                                   Polynomial.Coefficients.shift(Integer.ring_bundle,
                                       Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q))))
                       = a * Product.first(GaussianInteger.coordinatesOfCoefficients(q))
                             + Product.first(GaussianInteger.coordinatesOfCoefficients(
                                   Polynomial.Coefficients.shift(Integer.ring_bundle,
                                       Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q))))
                             by congruenceOf(
                                    (w : Integer) ↦ w + Product.first(GaussianInteger.coordinatesOfCoefficients(
                                        Polynomial.Coefficients.shift(Integer.ring_bundle,
                                            Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))),
                                    congruenceOf((pair : Pair(Integer, Integer)) ↦ Product.first(pair), scaleCoordinates))
                       = a * Product.first(GaussianInteger.coordinatesOfCoefficients(q))
                             + Integer.negate(Product.second(GaussianInteger.coordinatesOfCoefficients(
                                   Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q))))
                             by congruenceOf(
                                    (w : Integer) ↦ a * Product.first(GaussianInteger.coordinatesOfCoefficients(q)) + w,
                                    congruenceOf((pair : Pair(Integer, Integer)) ↦ Product.first(pair), shiftCoordinates))
                       = a * Product.first(GaussianInteger.coordinatesOfCoefficients(q))
                             + Integer.negate(
                                   Product.first(GaussianInteger.coordinatesOfCoefficients(restA))
                                       * Product.second(GaussianInteger.coordinatesOfCoefficients(q))
                                   + Product.second(GaussianInteger.coordinatesOfCoefficients(restA))
                                       * Product.first(GaussianInteger.coordinatesOfCoefficients(q)))
                             by congruenceOf(
                                    (w : Integer) ↦ a * Product.first(GaussianInteger.coordinatesOfCoefficients(q)) + Integer.negate(w),
                                    congruenceOf((pair : Pair(Integer, Integer)) ↦ Product.second(pair), ihMultiply))
                       = (a - Product.second(GaussianInteger.coordinatesOfCoefficients(restA)))
                             * Product.first(GaussianInteger.coordinatesOfCoefficients(q))
                             - Product.first(GaussianInteger.coordinatesOfCoefficients(restA))
                               * Product.second(GaussianInteger.coordinatesOfCoefficients(q))
                             by ring,
                    -- second component
                    calc Product.second(GaussianInteger.coordinatesOfCoefficients(
                             Polynomial.Coefficients.scale(Integer.ring_bundle, a, q)))
                             + Product.second(GaussianInteger.coordinatesOfCoefficients(
                                   Polynomial.Coefficients.shift(Integer.ring_bundle,
                                       Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q))))
                       = a * Product.second(GaussianInteger.coordinatesOfCoefficients(q))
                             + Product.second(GaussianInteger.coordinatesOfCoefficients(
                                   Polynomial.Coefficients.shift(Integer.ring_bundle,
                                       Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q))))
                             by congruenceOf(
                                    (w : Integer) ↦ w + Product.second(GaussianInteger.coordinatesOfCoefficients(
                                        Polynomial.Coefficients.shift(Integer.ring_bundle,
                                            Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))),
                                    congruenceOf((pair : Pair(Integer, Integer)) ↦ Product.second(pair), scaleCoordinates))
                       = a * Product.second(GaussianInteger.coordinatesOfCoefficients(q))
                             + Product.first(GaussianInteger.coordinatesOfCoefficients(
                                   Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))
                             by congruenceOf(
                                    (w : Integer) ↦ a * Product.second(GaussianInteger.coordinatesOfCoefficients(q)) + w,
                                    congruenceOf((pair : Pair(Integer, Integer)) ↦ Product.second(pair), shiftCoordinates))
                       = a * Product.second(GaussianInteger.coordinatesOfCoefficients(q))
                             + (Product.first(GaussianInteger.coordinatesOfCoefficients(restA))
                                    * Product.first(GaussianInteger.coordinatesOfCoefficients(q))
                                - Product.second(GaussianInteger.coordinatesOfCoefficients(restA))
                                    * Product.second(GaussianInteger.coordinatesOfCoefficients(q)))
                             by congruenceOf(
                                    (w : Integer) ↦ a * Product.second(GaussianInteger.coordinatesOfCoefficients(q)) + w,
                                    congruenceOf((pair : Pair(Integer, Integer)) ↦ Product.first(pair), ihMultiply))
                       = (a - Product.second(GaussianInteger.coordinatesOfCoefficients(restA)))
                             * Product.second(GaussianInteger.coordinatesOfCoefficients(q))
                             + Product.first(GaussianInteger.coordinatesOfCoefficients(restA))
                               * Product.first(GaussianInteger.coordinatesOfCoefficients(q))
                             by ring)
    }

-- ----------------------------------------------------------------------
-- Lifted to ℤ[x]: coords(p·q) = coords(p) ⊗ coords(q).
theorem GaussianInteger.coordinatesOfPolynomial_multiply
        (p q : Polynomial(Integer, Integer.zero))
        : GaussianInteger.coordinatesOfPolynomial(
              Polynomial.multiply(Integer.ring_bundle, p, q))
          = GaussianInteger.gaussianProduct(
                GaussianInteger.coordinatesOfPolynomial(p),
                GaussianInteger.coordinatesOfPolynomial(q)) :=
  cases p { | a =>
    cases q { | b =>
      GaussianInteger.coordinatesOfCoefficients_multiply(a, b)
    }
  }

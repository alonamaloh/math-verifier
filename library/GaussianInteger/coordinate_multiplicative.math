-- GaussianInteger/coordinate_multiplicative.math
--
-- The coordinate map is multiplicative: coords(p·q) = coords(p) ⊗ coords(q),
-- where ⊗ is the Gaussian product (a,b)⊗(c,d) = (ac−bd, ad+bc) on pairs —
-- i.e. "evaluation at i is a ring homomorphism". This is what makes the
-- norm multiplicative. Proved by induction on the first coefficient list,
-- using additivity, the shift (×x) rotation, and a scale (×constant) lemma.

module GaussianInteger.coordinate_multiplicative

import Logic.basics
import Logic.product
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Algebra.ring
import Algebra.ring_bundle
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Polynomial.basics
import Polynomial.addition
import Polynomial.multiplication
import GaussianInteger.basics
import GaussianInteger.coordinates
import GaussianInteger.coordinate_homomorphism

-- ----------------------------------------------------------------------
-- The Gaussian product on coordinate pairs.
definition GaussianInteger.gaussianProduct (u v : Pair(Integer, Integer))
        : Pair(Integer, Integer) :=
  Product.make(
      Product.first(u) * Product.first(v) - Product.second(u) * Product.second(v),
      Product.first(u) * Product.second(v) + Product.second(u) * Product.first(v))

-- ----------------------------------------------------------------------
-- Scaling a coefficient list by a constant scales both coordinates.
theorem GaussianInteger.coordinatesOfCoefficients_scale (a : Integer)
        : ∀ (k : Polynomial.Coefficients(Integer)).
          coords(
                Polynomial.Coefficients.scale(Integer.ring_bundle, a, k))
            = Product.make(
                  a * Product.first(coords(k)),
                  a * Product.second(coords(k)))
  | Polynomial.Coefficients.nil => {
      -- coords(scale(a, [])) = (0, 0) = (a·0, a·0).
      Integer.zero = a * Integer.zero;
      done
    }
  | Polynomial.Coefficients.cons(c, rest) => {
      -- scale(a, c :: rest) = (a·c) :: scale(a, rest); the induction
      -- hypothesis gives the coordinates of the scaled tail.
      coords(
                Polynomial.Coefficients.scale(Integer.ring_bundle, a, rest))
            = Product.make(
                  a * Product.first(coords(rest)),
                  a * Product.second(coords(rest))) as tail;
      -- real part
      a * c - Product.second(coords(
               Polynomial.Coefficients.scale(Integer.ring_bundle, a, rest)))
         = a * c - a * Product.second(coords(rest))
               by tail
         = a * (c - Product.second(coords(rest)));
      -- imaginary part
      Product.first(coords(
                Polynomial.Coefficients.scale(Integer.ring_bundle, a, rest)))
            = a * Product.first(coords(rest))
          by tail;
      done
    }

-- ----------------------------------------------------------------------
-- Multiplicativity on coefficient lists: coords(p·q) = coords(p) ⊗ coords(q).
-- Induction on p. On cons(a, restA): p·q = scale(a, q) + shift(restA·q), so
-- coords(p·q) = a·coords(q) ⊕ i·(coords(restA)⊗coords(q)), which is the
-- Gaussian product coords(cons(a,restA)) ⊗ coords(q) by ring.
theorem GaussianInteger.coordinatesOfCoefficients_multiply
        : ∀ (p q : Polynomial.Coefficients(Integer)).
          coords(
                Polynomial.Coefficients.multiply(Integer.ring_bundle, p, q))
            = GaussianInteger.gaussianProduct(
                  coords(p),
                  coords(q))
  | Polynomial.Coefficients.nil, q => {
      -- coords(nil·q) = coords(nil) = (0,0) = (0,0) ⊗ coords(q).
      Integer.zero
          = Integer.zero * Product.first(coords(q))
                - Integer.zero * Product.second(coords(q));
      Integer.zero
          = Integer.zero * Product.second(coords(q))
                + Integer.zero * Product.first(coords(q));
      done
    }
  | Polynomial.Coefficients.cons(a, restA), q => {
      -- multiply(a :: restA, q) = scale(a, q) + shift(restA · q). The
      -- induction hypothesis evaluates coords(restA · q) as the Gaussian
      -- product; `scaleCoordinates` and `shiftCoordinates` evaluate the two
      -- summands. Additivity splits coords of the sum; then each coordinate
      -- is a `ring` rearrangement into the Gaussian product of the cons.
      -- induction hypothesis on the tail
      coords(
                Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q))
            = GaussianInteger.gaussianProduct(
                  coords(restA),
                  coords(q))
          by GaussianInteger.coordinatesOfCoefficients_multiply(restA, q) as ihMultiply;
      coords(
                Polynomial.Coefficients.scale(Integer.ring_bundle, a, q))
            = Product.make(
                  a * Product.first(coords(q)),
                  a * Product.second(coords(q))) as scaleCoordinates;
      coords(
                Polynomial.Coefficients.shift(Integer.ring_bundle,
                    Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))
            = Product.make(
                  Integer.negate(Product.second(coords(
                      Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))),
                  Product.first(coords(
                      Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))) as shiftCoordinates;
      -- The real part: a·re(q) − [re(restA)·im(q) + im(restA)·re(q)].
      Product.first(coords(
               Polynomial.Coefficients.scale(Integer.ring_bundle, a, q)))
               + Product.first(coords(
                     Polynomial.Coefficients.shift(Integer.ring_bundle,
                         Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q))))
                 = a * Product.first(coords(q))
                       + Product.first(coords(
                             Polynomial.Coefficients.shift(Integer.ring_bundle,
                                 Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q))))
                       by scaleCoordinates
                 = a * Product.first(coords(q))
                       + Integer.negate(Product.second(coords(
                             Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q))))
                       by shiftCoordinates
                 = a * Product.first(coords(q))
                       + Integer.negate(
                             Product.first(coords(restA))
                                 * Product.second(coords(q))
                             + Product.second(coords(restA))
                                 * Product.first(coords(q)))
                       by ihMultiply
                 = (a - Product.second(coords(restA)))
                       * Product.first(coords(q))
                       - Product.first(coords(restA))
                         * Product.second(coords(q));
      -- The imaginary part: a·im(q) + [re(restA)·re(q) − im(restA)·im(q)].
      Product.second(coords(
               Polynomial.Coefficients.scale(Integer.ring_bundle, a, q)))
               + Product.second(coords(
                     Polynomial.Coefficients.shift(Integer.ring_bundle,
                         Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q))))
                 = a * Product.second(coords(q))
                       + Product.second(coords(
                             Polynomial.Coefficients.shift(Integer.ring_bundle,
                                 Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q))))
                       by scaleCoordinates
                 = a * Product.second(coords(q))
                       + Product.first(coords(
                             Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))
                       by shiftCoordinates
                 = a * Product.second(coords(q))
                       + (Product.first(coords(restA))
                              * Product.first(coords(q))
                          - Product.second(coords(restA))
                              * Product.second(coords(q)))
                       by ihMultiply
                 = (a - Product.second(coords(restA)))
                       * Product.second(coords(q))
                       + Product.first(coords(restA))
                         * Product.first(coords(q));
      -- coords(scale(a,q) + shift(restA·q)) splits componentwise (additivity);
      -- the two claims are exactly its real and imaginary parts.
      coords(
               Polynomial.Coefficients.add(Integer.ring_bundle,
                   Polynomial.Coefficients.scale(Integer.ring_bundle, a, q),
                   Polynomial.Coefficients.shift(Integer.ring_bundle,
                       Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q))))
         = Product.make(
               Product.first(coords(
                   Polynomial.Coefficients.scale(Integer.ring_bundle, a, q)))
                   + Product.first(coords(
                         Polynomial.Coefficients.shift(Integer.ring_bundle,
                             Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))),
               Product.second(coords(
                   Polynomial.Coefficients.scale(Integer.ring_bundle, a, q)))
                   + Product.second(coords(
                         Polynomial.Coefficients.shift(Integer.ring_bundle,
                             Polynomial.Coefficients.multiply(Integer.ring_bundle, restA, q)))))
             by GaussianInteger.coordinatesOfCoefficients_add
         = GaussianInteger.gaussianProduct(
               coords(
                   Polynomial.Coefficients.cons(Integer, a, restA)),
               coords(q));
    }

-- ----------------------------------------------------------------------
-- Lifted to ℤ[x]: coords(p·q) = coords(p) ⊗ coords(q).
theorem GaussianInteger.coordinatesOfPolynomial_multiply
        (p q : Polynomial(Integer, Integer.zero))
        : coords(
              (p * q))
          = GaussianInteger.gaussianProduct(
                coords(p),
                coords(q)) :=
  by_representatives p as a, q as b =>
    GaussianInteger.coordinatesOfCoefficients_multiply(a, b)

-- GaussianInteger/norm_natural.math
--
-- The Natural-valued norm on ℤ[i], the degree function for the Euclidean
-- structure. N(z) = re² + im² is a sum of squares, hence non-negative, so
-- `normNatural z = |N(z)|` is a faithful Natural copy: (normNatural z : ℤ)
-- = normInteger z. The norm vanishes only at 0, so b ≠ 0 ⟹ normNatural b ≥ 1.

module GaussianInteger.norm_natural

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.prime_split
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.ring
import Integer.algebra
import Integer.embedding
import Integer.order
import Integer.sign
import Integer.absolute_value
import Integer.absolute_value_natural
import Integer.sum_of_squares
import RingModulo.basics
import RingModulo.operations
import GaussianInteger.basics
import GaussianInteger.coordinates
import GaussianInteger.coordinate_map
import GaussianInteger.norm
import GaussianInteger.integral_domain

-- The sum of two non-negative integers is non-negative.
theorem Integer.add_nonneg (a b : Integer)
        (aNonneg : Integer.IsNonneg(a)) (bNonneg : Integer.IsNonneg(b))
        : Integer.IsNonneg(a + b) := {
  obtain ⟨j, aImage⟩ from aNonneg;
  obtain ⟨k, bImage⟩ from bNonneg;
  witness j + k with
      calc a + b
         = (j : Integer) + (k : Integer)
               by substitution
         = ((j + k : Natural) : Integer)
               by Natural.to_integer.add_preserves
}

-- A non-negative integer is its own natural absolute value (as an integer).
theorem Integer.absolute_value_natural_of_nonneg (x : Integer) (xNonneg : Integer.IsNonneg(x))
        : (Integer.absolute_value_natural(x) : Integer) = x := {
  obtain ⟨n, xImage⟩ from xNonneg;
  calc (Integer.absolute_value_natural(x) : Integer)
     = abs(x)             by Integer.absolute_value_natural_is_image
     = abs((n : Integer))  by substituting xImage
     = (n : Integer)       by Integer.absolute_value_of_natural
     = x                   by xImage
}

-- The embedding reflects ≤: (a : ℤ) ≤ (b : ℤ) ⟹ a ≤ b.
theorem Natural.to_integer.reflects_less_or_equal (a b : Natural)
        (imageLe : (a : Integer) ≤ (b : Integer)) : a ≤ b := {
  obtain ⟨gap, gapImage⟩ from imageLe;
  -- gapImage : (b : ℤ) − (a : ℤ) = (gap : ℤ), so (b : ℤ) = ((a + gap) : ℤ).
  let _ : (b : Integer) = ((a + gap : Natural) : Integer) :=
      calc (b : Integer)
            = (a : Integer) + ((b : Integer) - (a : Integer))
                  by ring
            = (a : Integer) + (gap : Integer)
                  by substituting gapImage
            = ((a + gap : Natural) : Integer)
                  by Natural.to_integer.add_preserves;
  claim bEquation : b = a + gap by Natural.to_integer.injective;
  claim a ≤ a + gap by Natural.less_or_equal_add_right;
  done by substituting bEquation
}

-- N(z) = re² + im² is non-negative.
theorem GaussianInteger.normInteger_nonneg (z : GaussianInteger)
        : Integer.IsNonneg(GaussianInteger.normInteger(z)) := {
  claim Integer.IsNonneg(Product.first(coords(z)) * Product.first(coords(z)))
      by Integer.square_is_nonneg;
  claim Integer.IsNonneg(Product.second(coords(z)) * Product.second(coords(z)))
      by Integer.square_is_nonneg;
  done by Integer.add_nonneg
}

-- The Natural-valued norm.
definition GaussianInteger.normNatural (z : GaussianInteger) : Natural :=
  Integer.absolute_value_natural(GaussianInteger.normInteger(z))

-- (normNatural z : ℤ) = normInteger z.
theorem GaussianInteger.normNatural_is_normInteger (z : GaussianInteger)
        : (GaussianInteger.normNatural(z) : Integer) = GaussianInteger.normInteger(z) := {
  claim Integer.IsNonneg(GaussianInteger.normInteger(z)) by GaussianInteger.normInteger_nonneg;
  done by Integer.absolute_value_natural_of_nonneg
}

-- b ≠ 0 ⟹ normNatural b ≥ 1 (else N(b) = 0 forces b = 0).
theorem GaussianInteger.normNatural_positive (b : GaussianInteger)
        (bNonzero : ¬(b = RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)))
        : 1 ≤ GaussianInteger.normNatural(b) := {
  claim GaussianInteger.normNatural(b) ≠ 0 by (normZero : GaussianInteger.normNatural(b) = 0) ↦ {
    let _ : GaussianInteger.normInteger(b) = Integer.zero :=
        calc GaussianInteger.normInteger(b)
              = (GaussianInteger.normNatural(b) : Integer)
                    by GaussianInteger.normNatural_is_normInteger
              = (0 : Integer)
                    by normZero
              = Integer.zero
                    by Natural.to_integer.zero_preserves;
    claim b = RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)
        by GaussianInteger.eq_zero_of_norm_zero;
    done by bNonzero
  };
  done by Natural.geq_one_when_not_zero
}

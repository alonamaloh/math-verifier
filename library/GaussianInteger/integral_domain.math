-- GaussianInteger/integral_domain.math
--
-- ℤ[i] is an integral domain. The norm is multiplicative and vanishes
-- only at 0 (N(z)=0 ⟹ coords(z)=(0,0) ⟹ z=0, via the reconstruction),
-- so z·w = 0 ⟹ N(z)·N(w) = 0 ⟹ one of them is 0 ⟹ that factor is 0.

module GaussianInteger.integral_domain

import Logic.basics
import Logic.product
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.integral_domain
import Algebra.integer_domain
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.ring
import Integer.algebra
import Integer.embedding
import Integer.sum_of_squares
import RingModulo.basics
import RingModulo.operations
import RingModulo.ring
import RingModulo.instances
import GaussianInteger.basics
import GaussianInteger.coordinates
import GaussianInteger.coordinate_map
import GaussianInteger.norm
import GaussianInteger.imaginary_unit
import GaussianInteger.reconstruction

-- ℤ[i] as a bundled commutative ring.
definition GaussianInteger.commutative_ring_bundle : CommutativeRing :=
  CommutativeRing.make(GaussianInteger.ring_bundle,
      RingModulo.multiply_commutative(Integer.polynomial_commutative_ring,
          GaussianInteger.definingPolynomial))

-- N(z) = 0 ⟹ z = 0. The norm is re² + im²; both are 0, so coords(z) =
-- (0,0), and `coords` is injective at 0.
theorem GaussianInteger.eq_zero_of_norm_zero (z : GaussianInteger)
        (normZero : GaussianInteger.normInteger(z) = Integer.zero)
        : z = RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial) := {
  Product.first(GaussianInteger.coordinates(z)) = Integer.zero ∧ Product.second(GaussianInteger.coordinates(z)) = Integer.zero
      by Integer.sum_of_squares_zero as coordinateSquaresZero;
  obtain ⟨reZero, imZero⟩ from coordinateSquaresZero;
  let _ : GaussianInteger.coordinates(z) = Product.make(Integer.zero, Integer.zero) :=
      calc GaussianInteger.coordinates(z)
            = Product.make(Product.first(GaussianInteger.coordinates(z)),
                  Product.second(GaussianInteger.coordinates(z)))
                  by GaussianInteger.product_eta
            = Product.make(Integer.zero, Product.second(GaussianInteger.coordinates(z)))
                  by substituting reZero
            = Product.make(Integer.zero, Integer.zero);
  done by GaussianInteger.eq_zero_of_coordinates_zero
}

-- N(0) = 0.
theorem GaussianInteger.norm_zero
        : GaussianInteger.normInteger(
              RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial))
          = Integer.zero :=
  calc GaussianInteger.normInteger(
           RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial))
     = Integer.zero * Integer.zero + Integer.zero * Integer.zero
     = Integer.zero   by ring

-- 0 ≠ 1 in ℤ[i]: their first coordinates are 0 and 1.
theorem GaussianInteger.one_not_zero
        : ¬(RingModulo.one(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)
              = RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)) :=
  (oneEqualsZero
      : RingModulo.one(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)
        = RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)) ↦ {
    GaussianInteger.coordinates(
              RingModulo.one(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial))
          = GaussianInteger.coordinates(
                RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial))
        by substituting oneEqualsZero as coordinatesEqual;
    -- The first coordinate of 1 is Integer.one and of 0 is Integer.zero (both defeq).
    Product.first(GaussianInteger.coordinates(
              RingModulo.one(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)))
          = Product.first(GaussianInteger.coordinates(
                RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)))
        by substituting coordinatesEqual as firstEqual;
    let _ : Integer.one = Integer.zero :=
        calc Integer.one
           = Product.first(GaussianInteger.coordinates(
                 RingModulo.one(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)))
           = Product.first(GaussianInteger.coordinates(
                 RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)))
                 by firstEqual
           = Integer.zero;
    False by Integer.one_not_zero;
    done
  }

-- No zero divisors, via the multiplicative norm landing in ℤ.
theorem GaussianInteger.has_no_zero_divisors
        : Ring.HasNoZeroDivisors(GaussianInteger.ring_bundle) :=
  (z w : GaussianInteger)
      (productZero
          : z * w = RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)) ↦ {
    let _ : GaussianInteger.normInteger(z) * GaussianInteger.normInteger(w) = Integer.zero :=
        calc GaussianInteger.normInteger(z) * GaussianInteger.normInteger(w)
              = GaussianInteger.normInteger(z * w)
                    by GaussianInteger.normInteger_multiply
              = GaussianInteger.normInteger(
                    RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial))
                    by substituting productZero
              = Integer.zero
                    by GaussianInteger.norm_zero;
    cases by Integer.multiply_eq_zero_implies {
      | Or.introduceLeft(normZZero) => {
          z = RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)
              by GaussianInteger.eq_zero_of_norm_zero as zZero;
          Or.introduceLeft(zZero)
        }
      | Or.introduceRight(normWZero) => {
          w = RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)
              by GaussianInteger.eq_zero_of_norm_zero as wZero;
          Or.introduceRight(wZero)
        }
    }
  }

-- ℤ[i] is an integral domain.
definition GaussianInteger.integral_domain : IntegralDomain :=
  IntegralDomain.make(GaussianInteger.commutative_ring_bundle,
      GaussianInteger.one_not_zero,
      GaussianInteger.has_no_zero_divisors)

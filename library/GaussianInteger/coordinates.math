-- GaussianInteger/coordinates.math
--
-- The coordinate bridge out of the quotient: a total function reading the
-- pair (re, im) of integer coordinates off a Gaussian integer a + bi.
--
-- A function OUT of ℤ[i] = ℤ[x]/(x²+1) cannot extract a representative
-- (the quotient is opaque), so we build it the only sound way: a function
-- on coefficient lists that respects both quotient relations, then lift.
-- The recursion uses x·q ≡ i·q, i.e. re(x·q) = −im(q), im(x·q) = re(q):
--   reim(nil)         = (0, 0)
--   reim(cons(c, q))  = (c − im(q), re(q))      [the class is c + x·q]
-- This module lifts it through the polynomial quotient (trailing zeros);
-- the lift through the (x²+1)-congruence is in the sibling module.

module GaussianInteger.coordinates

import Logic.basics
import Logic.product
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Algebra.ring
import Algebra.ring_bundle
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Polynomial.basics
import Polynomial.addition
import GaussianInteger.basics

-- ----------------------------------------------------------------------
-- The coordinate recursion on raw coefficient lists.

-- (re, im) of the class of a coefficient list, reading c + x·(rest).
definition GaussianInteger.coordinatesOfCoefficients
        : Polynomial.Coefficients(Integer) → Pair(Integer, Integer)
  | Polynomial.Coefficients.nil => Product.make(Integer.zero, Integer.zero)
  | Polynomial.Coefficients.cons(c, rest) =>
      Product.make(
          c - Product.second(GaussianInteger.coordinatesOfCoefficients(rest)),
          Product.first(GaussianInteger.coordinatesOfCoefficients(rest)))

-- `coords` abbreviates the coordinate map for the whole GaussianInteger
-- cluster (importers inherit the overload); resolved by argument type —
-- a coefficient list here, a polynomial once that map is defined below.
overload coords := GaussianInteger.coordinatesOfCoefficients

-- ----------------------------------------------------------------------
-- An all-zero coefficient list has coordinates (0, 0).
theorem GaussianInteger.coordinatesOfCoefficients_all_zero
        : (a : Polynomial.Coefficients(Integer))
          → ((i : Natural) → Polynomial.nth(Integer, Integer.zero, a, i) = Integer.zero)
          → GaussianInteger.coordinatesOfCoefficients(a)
            = Product.make(Integer.zero, Integer.zero)
  | Polynomial.Coefficients.nil =>
      (allZero
          : (i : Natural) → Polynomial.nth(Integer, Integer.zero,
                Polynomial.Coefficients.nil(Integer), i) = Integer.zero) ↦
        reflexivity(Pair(Integer, Integer), Product.make(Integer.zero, Integer.zero))
  | Polynomial.Coefficients.cons(c, rest) =>
      (allZero
          : (i : Natural) → Polynomial.nth(Integer, Integer.zero,
                Polynomial.Coefficients.cons(Integer, c, rest), i) = Integer.zero) ↦ {
        claim cIsZero : c = Integer.zero by allZero(0);
        claim restCoordinates
            : coords(rest) = Product.make(Integer.zero, Integer.zero)
            by GaussianInteger.coordinatesOfCoefficients_all_zero(rest,
                   (i : Natural) ↦ allZero(successor(i)));
        -- coords(c :: rest) = (c − im(rest), re(rest)) = (0, 0).
        -- real coordinate
        calc c - Product.second(coords(rest))
           = c - Product.second(Product.make(Integer.zero, Integer.zero))
                 since restCoordinates
           = c - Integer.zero
           = Integer.zero - Integer.zero
                 by substituting cIsZero
           = Integer.zero
                 by ring;
        -- imaginary coordinate
        claim Product.first(coords(rest)) = Integer.zero by restCoordinates;
        done
      }

-- ----------------------------------------------------------------------
-- Coordinates respect extensional equality of coefficient lists: two
-- lists with the same coefficient at every index have equal coordinates.
-- Each branch returns an explicit term checked against the goal by
-- definitional unfolding of `coordinatesOfCoefficients` on a `cons`/`nil`.
theorem GaussianInteger.coordinatesOfCoefficients_respects
        : (a b : Polynomial.Coefficients(Integer))
          → Polynomial.ExtensionallyEqual(Integer, Integer.zero, a, b)
          → GaussianInteger.coordinatesOfCoefficients(a)
            = GaussianInteger.coordinatesOfCoefficients(b)
  | Polynomial.Coefficients.nil =>
      (b : Polynomial.Coefficients(Integer))
      (extensionallyEqual : Polynomial.ExtensionallyEqual(Integer, Integer.zero,
          Polynomial.Coefficients.nil(Integer), b)) ↦ {
        -- b agrees with the empty list at every index, so b is all-zero too.
        claim bAllZero
            : (i : Natural) → Polynomial.nth(Integer, Integer.zero, b, i) = Integer.zero
            by (i : Natural) ↦
                 calc Polynomial.nth(Integer, Integer.zero, b, i)
                    = Integer.zero   since extensionallyEqual(i);
        calc coords(Polynomial.Coefficients.nil(Integer))
           = Product.make(Integer.zero, Integer.zero)
           = coords(b)
                 since GaussianInteger.coordinatesOfCoefficients_all_zero(b, bAllZero)
      }
  | Polynomial.Coefficients.cons(c, rest) =>
      (b : Polynomial.Coefficients(Integer))
      (extensionallyEqual : Polynomial.ExtensionallyEqual(Integer, Integer.zero,
          Polynomial.Coefficients.cons(Integer, c, rest), b)) ↦
        cases b {
          | Polynomial.Coefficients.nil =>
              GaussianInteger.coordinatesOfCoefficients_all_zero(
                  Polynomial.Coefficients.cons(Integer, c, rest),
                  (i : Natural) ↦ extensionallyEqual(i))
          | Polynomial.Coefficients.cons(d, restB) => {
              claim headsEqual : c = d by extensionallyEqual(0);
              claim tailCoordinates
                  : coords(rest) = coords(restB)
                  by GaussianInteger.coordinatesOfCoefficients_respects(rest, restB,
                         (i : Natural) ↦ extensionallyEqual(successor(i)));
              -- coords(c :: rest) = (c − im(rest), re(rest)), likewise for d :: restB.
              -- real coordinate: c − im(rest) = d − im(restB)
              calc c - Product.second(coords(rest))
                 = d - Product.second(coords(rest))   by headsEqual
                 = d - Product.second(coords(restB))  by tailCoordinates;
              -- imaginary coordinate: re(rest) = re(restB)
              claim Product.first(coords(rest)) = Product.first(coords(restB))
                  by tailCoordinates;
              -- assemble through the explicit pair forms (keeps both endpoints
              -- cheap make(…) so the prover never unfolds the recursive coords)
              calc coords(Polynomial.Coefficients.cons(Integer, c, rest))
                 = Product.make(
                       c - Product.second(coords(rest)), Product.first(coords(rest)))
                 = Product.make(
                       d - Product.second(coords(restB)), Product.first(coords(restB)))
                 = coords(Polynomial.Coefficients.cons(Integer, d, restB))
            }
        }

-- ----------------------------------------------------------------------
-- The coordinate map on ℤ[x] (lifting over the polynomial quotient).
definition GaussianInteger.coordinatesOfPolynomial
        : Polynomial(Integer, Integer.zero) → Pair(Integer, Integer)
  by representatives a ↦ GaussianInteger.coordinatesOfCoefficients(a)
  well_defined by GaussianInteger.coordinatesOfCoefficients_respects

-- `coords` also abbreviates the polynomial-level coordinate map.
overload coords := GaussianInteger.coordinatesOfPolynomial

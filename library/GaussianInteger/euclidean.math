import Natural.peano
import Natural.order
import Natural.add_order
import Natural.arithmetic
import Natural.multiply_order
import Natural.multiply_bounds
import Natural.compare
import Natural.cancellation
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.embedding
import Integer.order
import Integer.absolute_value
import Integer.order_multiply
import Integer.balanced_division
import Logic.product
import Algebra.ring
import Algebra.ring_bundle
import Algebra.euclidean_domain
import Algebra.principal_ideal_domain
import RingModulo.basics
import RingModulo.operations
import RingModulo.ring
import RingModulo.instances
import GaussianInteger.basics
import GaussianInteger.coordinates
import GaussianInteger.coordinate_map
import GaussianInteger.coordinate_multiplicative
import GaussianInteger.norm
import GaussianInteger.reconstruction
import GaussianInteger.of_coordinates
import GaussianInteger.norm_natural
import GaussianInteger.integral_domain

-- Doubling as the integer numeral 2. With `Natural.add` opaque the cast
-- `(2 : ℤ) = ((2 : ℕ) : ℤ)` is an atom `ring` can no longer split into 1+1,
-- so spell the split out once through the additive cast lemma.
theorem Integer.two_as_one_plus_one : (2 : ℤ) = (1 : ℤ) + (1 : ℤ) :=
  (2 : ℤ)
     = Natural.to_integer(1 + 1)
     = Natural.to_integer(1) + Natural.to_integer(1)

theorem Integer.two_times (x : ℤ) : (2 : ℤ) * x = x + x :=
  (2 : ℤ) * x
     = ((1 : ℤ) + (1 : ℤ)) * x                           by substituting Integer.two_as_one_plus_one
     = x + x                                                          by ring

-- Scaling distributes over a sum of squares: (k·r₁)² + (k·r₂)² = k²·(r₁²+r₂²).
-- Kept symbolic in k so the crux's last step is degree 4 in {k, r₁, r₂} rather
-- than degree 6 once k = b₁²+b₂² is substituted in.
theorem Integer.scaled_sum_of_squares (k r1 r2 : ℤ)
        : (k * r1) * (k * r1) + (k * r2) * (k * r2) = (k * k) * (r1 * r1 + r2 * r2) := ring

-- The two linear relations: the conj-product times the divisor coordinates
-- gives D·r componentwise. Each is degree 4 — cheap for `ring`. Kept as
-- separate theorems (not inline `claim`s) so the crux references them as
-- opaque constants: a `substituting <local proof>` re-traverses the inlined
-- proof term on every use, turning these 66ms steps into a 7.9s blowup.
theorem Integer.gaussian_linear_relation_one (a1 a2 b1 b2 q1 q2 s1 s2 r1 : ℤ)
        (s1Def : s1 = (a1 * b1 + a2 * b2) - (b1 * b1 + b2 * b2) * q1)
        (s2Def : s2 = (a2 * b1 - a1 * b2) - (b1 * b1 + b2 * b2) * q2)
        (r1Def : r1 = a1 - (b1 * q1 - b2 * q2))
        : b1 * s1 - b2 * s2 = (b1 * b1 + b2 * b2) * r1 :=
  b1 * s1 - b2 * s2
     = b1 * ((a1 * b1 + a2 * b2) - (b1 * b1 + b2 * b2) * q1)
         - b2 * ((a2 * b1 - a1 * b2) - (b1 * b1 + b2 * b2) * q2)
           by substitution
     = (b1 * b1 + b2 * b2) * (a1 - (b1 * q1 - b2 * q2))
           by ring
     = (b1 * b1 + b2 * b2) * r1
           by substituting r1Def

theorem Integer.gaussian_linear_relation_two (a1 a2 b1 b2 q1 q2 s1 s2 r2 : ℤ)
        (s1Def : s1 = (a1 * b1 + a2 * b2) - (b1 * b1 + b2 * b2) * q1)
        (s2Def : s2 = (a2 * b1 - a1 * b2) - (b1 * b1 + b2 * b2) * q2)
        (r2Def : r2 = a2 - (b2 * q1 + b1 * q2))
        : b2 * s1 + b1 * s2 = (b1 * b1 + b2 * b2) * r2 :=
  b2 * s1 + b1 * s2
     = b2 * ((a1 * b1 + a2 * b2) - (b1 * b1 + b2 * b2) * q1)
         + b1 * ((a2 * b1 - a1 * b2) - (b1 * b1 + b2 * b2) * q2)
           by substitution
     = (b1 * b1 + b2 * b2) * (a2 - (b2 * q1 + b1 * q2))
           by ring
     = (b1 * b1 + b2 * b2) * r2
           by substituting r2Def

-- The norm crux: D·(s₁²+s₂²) = D²·(r₁²+r₂²), D = b₁²+b₂². Brahmagupta on the
-- two linear relations.
theorem Integer.gaussian_norm_crux (a1 a2 b1 b2 q1 q2 s1 s2 r1 r2 : ℤ)
        (s1Def : s1 = (a1 * b1 + a2 * b2) - (b1 * b1 + b2 * b2) * q1)
        (s2Def : s2 = (a2 * b1 - a1 * b2) - (b1 * b1 + b2 * b2) * q2)
        (r1Def : r1 = a1 - (b1 * q1 - b2 * q2))
        (r2Def : r2 = a2 - (b2 * q1 + b1 * q2))
        : (b1 * b1 + b2 * b2) * (s1 * s1 + s2 * s2)
          = ((b1 * b1 + b2 * b2) * (b1 * b1 + b2 * b2)) * (r1 * r1 + r2 * r2) := {
  b1 * s1 - b2 * s2 = (b1 * b1 + b2 * b2) * r1
      by Integer.gaussian_linear_relation_one as linRel1;
  b2 * s1 + b1 * s2 = (b1 * b1 + b2 * b2) * r2
      by Integer.gaussian_linear_relation_two as linRel2;
  (b1 * b1 + b2 * b2) * (s1 * s1 + s2 * s2)
     = (b1 * s1 - b2 * s2) * (b1 * s1 - b2 * s2)
         + (b2 * s1 + b1 * s2) * (b2 * s1 + b1 * s2)
           by ring
     = ((b1 * b1 + b2 * b2) * r1) * ((b1 * b1 + b2 * b2) * r1)
         + (b2 * s1 + b1 * s2) * (b2 * s1 + b1 * s2)
           by substituting linRel1
     = ((b1 * b1 + b2 * b2) * r1) * ((b1 * b1 + b2 * b2) * r1)
         + ((b1 * b1 + b2 * b2) * r2) * ((b1 * b1 + b2 * b2) * r2)
           by substituting linRel2
     = ((b1 * b1 + b2 * b2) * (b1 * b1 + b2 * b2)) * (r1 * r1 + r2 * r2)
}

-- 4a ≤ 2b with b ≥ 1 forces a < b: otherwise b ≤ a gives 4a ≤ 2a, while
-- 1 ≤ 2a gives 2a < 2a — impossible.
theorem Natural.less_of_four_times_le_double (a b : ℕ)
        (bound : 4 * a ≤ 2 * b) (bPositive : 1 ≤ b) : a < b := {
  suppose b ≤ a for contradiction {
    1 ≤ a;
    1 ≤ 2 * a by Natural.multiply_at_least_one;
    2 * b ≤ 2 * a;
    4 * a ≤ 2 * a as fourALeTwoA;
    4 * a = 2 * a + 2 * a as fourAExpand;
    2 * a
          < 2 * a + 2 * a                  by Natural.lt_add_of_one_le
          = 4 * a                          by fourAExpand
          ≤ 2 * a                          by fourALeTwoA;
    False by Natural.lt_irreflexive;
    done
  };
  done by Natural.lt_of_not_le
}

-- Cancelling the bound: from D·sSquares = D²·norm and 4·sSquares ≤ 2·D²,
-- multiply the bound by D and cancel D² to get 4·norm ≤ 2·D.
theorem Integer.cancel_norm_bound (dNat : ℕ) (dPositive : 1 ≤ dNat)
        (sSquares norm : ℤ)
        (crux : (dNat : ℤ) * sSquares = ((dNat : ℤ) * (dNat : ℤ)) * norm)
        (bound : (4 : ℤ) * sSquares ≤ (2 : ℤ) * ((dNat : ℤ) * (dNat : ℤ)))
        : (4 : ℤ) * norm ≤ (2 : ℤ) * (dNat : ℤ) := {
  (dNat : ℤ) * ((4 : ℤ) * sSquares)
        ≤ (dNat : ℤ) * ((2 : ℤ) * ((dNat : ℤ) * (dNat : ℤ)))
      by Integer.multiply_le_by_natural as scaled;
  ((dNat * dNat : ℕ) : ℤ) = (dNat : ℤ) * (dNat : ℤ) as dSquareCast;
  (dNat : ℤ) * ((4 : ℤ) * sSquares)
            = (4 : ℤ) * ((dNat : ℤ) * sSquares)
                  by ring
            = (4 : ℤ) * (((dNat : ℤ) * (dNat : ℤ)) * norm)
                  by substituting crux
            = ((dNat : ℤ) * (dNat : ℤ)) * ((4 : ℤ) * norm)
                  by ring
            = ((dNat * dNat : ℕ) : ℤ) * ((4 : ℤ) * norm)
                  by substituting dSquareCast
      as lhsForm;
  (dNat : ℤ) * ((2 : ℤ) * ((dNat : ℤ) * (dNat : ℤ)))
            = ((dNat : ℤ) * (dNat : ℤ)) * ((2 : ℤ) * (dNat : ℤ))
                  by ring
            = ((dNat * dNat : ℕ) : ℤ) * ((2 : ℤ) * (dNat : ℤ))
                  by substituting dSquareCast
      as rhsForm;
      ((dNat * dNat : ℕ) : ℤ) * ((4 : ℤ) * norm)
            = (dNat : ℤ) * ((4 : ℤ) * sSquares)
                  by lhsForm
            ≤ (dNat : ℤ) * ((2 : ℤ) * ((dNat : ℤ) * (dNat : ℤ)))
                  by scaled
            = ((dNat * dNat : ℕ) : ℤ) * ((2 : ℤ) * (dNat : ℤ))
                  by rhsForm;
  1 ≤ dNat * dNat;
  done by Integer.cancel_le_by_natural_positive
}

-- ----------------------------------------------------------------------
-- ℤ[i] admits Euclidean division by the norm.
theorem GaussianInteger.has_euclidean_division
        : Ring.HasEuclideanDivision(GaussianInteger.ring_bundle, GaussianInteger.normNatural) :=
  (a b : GaussianInteger)
      (bNonzero : ¬(b = RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial))) ↦ {
    let a1 : ℤ := Product.first(coords(a));
    let a2 : ℤ := Product.second(coords(a));
    let b1 : ℤ := Product.first(coords(b));
    let b2 : ℤ := Product.second(coords(b));
    let dNat : ℕ := GaussianInteger.normNatural(b);
    1 ≤ dNat by GaussianInteger.normNatural_positive;
    (dNat : ℤ)
              = GaussianInteger.normInteger(b)
              = b1 * b1 + b2 * b2
        as dCast;
    -- Balanced-divide the two coordinates of a·conj(b) by D.
    (dNat : ℤ) > Integer.zero by Natural.to_integer.positive_preserves as dIntPositive;
    choose q1, s1 such that
        a1 * b1 + a2 * b2 = (dNat : ℤ) * q1 + s1 ∧ 4 * s1² ≤ (dNat : ℤ)²
        from Integer.divide_balanced(a1 * b1 + a2 * b2, (dNat : ℤ), dIntPositive);
    a1 * b1 + a2 * b2 = (dNat : ℤ) * q1 + s1 as s1Equation;
    choose q2, s2 such that
        a2 * b1 - a1 * b2 = (dNat : ℤ) * q2 + s2 ∧ 4 * s2² ≤ (dNat : ℤ)²
        from Integer.divide_balanced(a2 * b1 - a1 * b2, (dNat : ℤ), dIntPositive);
    a2 * b1 - a1 * b2 = (dNat : ℤ) * q2 + s2 as s2Equation;
    -- s_i = n_i − D·q_i, with D = b₁²+b₂².
    s1
              = ((dNat : ℤ) * q1 + s1) - (dNat : ℤ) * q1   by ring
              = (a1 * b1 + a2 * b2) - (dNat : ℤ) * q1            by substituting s1Equation
              = (a1 * b1 + a2 * b2) - (b1 * b1 + b2 * b2) * q1         by substituting dCast;
    s2
              = ((dNat : ℤ) * q2 + s2) - (dNat : ℤ) * q2   by ring
              = (a2 * b1 - a1 * b2) - (dNat : ℤ) * q2            by substituting s2Equation
              = (a2 * b1 - a1 * b2) - (b1 * b1 + b2 * b2) * q2         by substituting dCast;
    -- The quotient and remainder in ℤ[i].
    let q : GaussianInteger := GaussianInteger.ofCoordinates(q1, q2);
    let r : GaussianInteger :=
        RingModulo.add(a, RingModulo.negate(RingModulo.multiply(b, q)));
    let r1 : ℤ := Product.first(coords(r));
    let r2 : ℤ := Product.second(coords(r));
    -- a = b·q + r, an additive-group rearrangement.
    a
              = RingModulo.add(RingModulo.multiply(b, q),
                    RingModulo.add(a, RingModulo.negate(RingModulo.multiply(b, q))))
                    by ring
        as aEquation;
    -- The coordinates of b·q.
    Product.first(coords(RingModulo.multiply(b, q)))
              = Product.first(GaussianInteger.gaussianProduct(coords(b), Product.make(q1, q2)))
                    by GaussianInteger.coordinates_multiply
              = b1 * q1 - b2 * q2
        as bqFirst;
        Product.second(coords(RingModulo.multiply(b, q)))
              = Product.second(GaussianInteger.gaussianProduct(coords(b), Product.make(q1, q2)))
                    by GaussianInteger.coordinates_multiply
              = b2 * q1 + b1 * q2;
    -- coords(a) = coords(b·q) + coords(r) componentwise.
    coords(a)
              = coords(RingModulo.add(RingModulo.multiply(b, q), r))
                    by substituting aEquation
              = Product.make(
                    Product.first(coords(RingModulo.multiply(b, q))) + r1,
                    Product.second(coords(RingModulo.multiply(b, q))) + r2)
                    by GaussianInteger.coordinates_add
              = Product.make((b1 * q1 - b2 * q2) + r1, (b2 * q1 + b1 * q2) + r2)
                    by substituting bqFirst
        as coordsAEquation;
    r1
              = ((b1 * q1 - b2 * q2) + r1) - (b1 * q1 - b2 * q2)
                    by ring
              = Product.first(coords(a)) - (b1 * q1 - b2 * q2)
                    by substituting coordsAEquation
              = a1 - (b1 * q1 - b2 * q2);
    r2
              = ((b2 * q1 + b1 * q2) + r2) - (b2 * q1 + b1 * q2)
                    by ring
              = Product.second(coords(a)) - (b2 * q1 + b1 * q2)
                    by substituting coordsAEquation
              = a2 - (b2 * q1 + b1 * q2);
    -- The crux, in terms of D = (dNat : ℤ).
    (dNat : ℤ) * (s1 * s1 + s2 * s2)
              = (b1 * b1 + b2 * b2) * (s1 * s1 + s2 * s2)
                    by substituting dCast
              = ((b1 * b1 + b2 * b2) * (b1 * b1 + b2 * b2)) * (r1 * r1 + r2 * r2)
                    by Integer.gaussian_norm_crux
              = ((dNat : ℤ) * (dNat : ℤ)) * (r1 * r1 + r2 * r2)
                    by substituting dCast;
    -- Combine the two coordinate bounds: 4·(s₁²+s₂²) ≤ 2·D².
    (4 : ℤ) * (s1 * s1 + s2 * s2)
              = (4 : ℤ) * (s1 * s1) + (4 : ℤ) * (s2 * s2)
              ≤ (dNat : ℤ) * (dNat : ℤ) + (4 : ℤ) * (s2 * s2)
                    by Integer.add_preserves_less_or_equal
              = (4 : ℤ) * (s2 * s2) + (dNat : ℤ) * (dNat : ℤ)
              ≤ (dNat : ℤ) * (dNat : ℤ) + (dNat : ℤ) * (dNat : ℤ)
                    by Integer.add_preserves_less_or_equal
              = (2 : ℤ) * ((dNat : ℤ) * (dNat : ℤ));
    -- 4·N(r) ≤ 2·D, then transfer to ℕ.
    (4 : ℤ) * (r1 * r1 + r2 * r2) ≤ (2 : ℤ) * (dNat : ℤ)
        by Integer.cancel_norm_bound as normBound;
    ((4 * GaussianInteger.normNatural(r) : ℕ) : ℤ)
              = (4 : ℤ) * (GaussianInteger.normNatural(r) : ℤ)
              = (4 : ℤ) * GaussianInteger.normInteger(r)
                    by substituting GaussianInteger.normNatural_is_normInteger(r)
              = (4 : ℤ) * (r1 * r1 + r2 * r2)
              ≤ (2 : ℤ) * (dNat : ℤ)               by normBound
              = (2 : ℤ) * (GaussianInteger.normNatural(b) : ℤ)
              = ((2 * GaussianInteger.normNatural(b) : ℕ) : ℤ);
    4 * GaussianInteger.normNatural(r) ≤ 2 * GaussianInteger.normNatural(b)
        by Natural.to_integer.LessOrEqual_reflects;
    GaussianInteger.normNatural(r) < GaussianInteger.normNatural(b)
        by Natural.less_of_four_times_le_double as remainderNormLess;
    witness q with
    witness r with
        And.introduction(aEquation, Or.introduceRight(remainderNormLess))
  }

-- ----------------------------------------------------------------------
-- ℤ[i] is therefore a Euclidean domain, and hence a principal ideal domain.
definition GaussianInteger.euclidean_domain : EuclideanDomain :=
  EuclideanDomain.make(GaussianInteger.integral_domain, GaussianInteger.normNatural,
      GaussianInteger.has_euclidean_division)

definition GaussianInteger.principal_ideal_domain : PrincipalIdealDomain :=
  EuclideanDomain.to_principal_ideal_domain(GaussianInteger.euclidean_domain)

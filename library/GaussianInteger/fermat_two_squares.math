-- GaussianInteger/fermat_two_squares.math
--
-- Fermat's two-squares theorem (Freek #20): every prime p ≡ 1 (mod 4)
-- is a sum of two squares. The two halves, both already proved:
--
--   * Wilson route (IntegerMod/square_root_of_minus_one.math): writing
--     p = 1 + 4t, the class of (2t)! is a square root of −1 in F_p, so
--     p ∣ ((2t)!)² + 1;
--   * Gaussian-integer descent (GaussianInteger/sum_of_two_squares.math):
--     a prime dividing m² + 1 is a sum of two squares, by factoring
--     m² + 1 = (m + i)(m − i) in the Euclidean domain ℤ[i].

module GaussianInteger.fermat_two_squares

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.factorial
import Natural.prime
import Natural.prime_split
import Integer.basics
import Integer.multiplication
import Integer.embedding
import Integer.divisibility
import IntegerMod.field
import IntegerMod.square_root_of_minus_one
import GaussianInteger.sum_of_two_squares

-- Every prime congruent to 1 modulo 4 is a sum of two squares.
theorem Natural.prime_one_mod_four_sum_of_two_squares (p : Natural)
        (primality : Natural.is_prime(p))
        (oneModFour : ∃ (t : Natural). p = 1 + 4 * t)
        : ∃ (a : Integer). ∃ (b : Integer). (p : Integer) = a * a + b * b := {
  choose t such that p = 1 + 4 * t from oneModFour;
  -- t ≥ 1: t = 0 would make p = 1, which is not prime.
  claim t ≠ 0 by {
      suppose t = 0 as tZero;
      claim 2 ≤ p;
      calc (2 : Natural) ≤ p = 1 + 4 * t = 1 + 4 * 0 = 1;
      done
    };
  claim 1 ≤ t;
  -- Write 4t as 2t + 2t, the shape the Wilson route wants.
  calc p = 1 + 4 * t = 1 + ((t + t) + (t + t));
  -- Wilson route: p divides ((2t)!)² + 1…
  claim Integer.divides((p : Integer),
            (Natural.factorial(t + t) : Integer)
                * (Natural.factorial(t + t) : Integer) + Integer.one)
      by IntegerMod.half_factorial_square_plus_one_divisible;
  -- …and the Gaussian-integer descent turns that into two squares.
  done by GaussianInteger.sum_of_two_squares_of_divides_square_plus_one
}

-- GaussianInteger/coordinate_map.math
--
-- The coordinate map descends to ℤ[i]: combining additivity with the
-- vanishing on multiples of x²+1, `coordinatesOfPolynomial` respects the (x²+1)-
-- congruence, so it lifts to a genuine function `coordinates : ℤ[i] →
-- ℤ×ℤ` reading the (re, im) of a Gaussian integer a + bi.

module GaussianInteger.coordinate_map

import Logic.basics
import Logic.exists
import Logic.product
import Logic.quotient
import Equality.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.ring_divisibility
import Integer.basics
import Integer.addition
import Integer.ring
import Integer.algebra
import Polynomial.basics
import Polynomial.addition
import Polynomial.negation
import Polynomial.additive_group
import Polynomial.multiplication
import Polynomial.instances
import RingModulo.basics
import GaussianInteger.basics
import GaussianInteger.coordinates
import GaussianInteger.coordinate_homomorphism
import GaussianInteger.defining_polynomial_vanishes

-- ----------------------------------------------------------------------
-- coordinatesOfPolynomial respects congruence modulo x²+1.
--
-- From p − p' = (x²+1)·cofactor we get p = p' + (x²+1)·cofactor, so by
-- additivity coords(p) = coords(p') ⊕ coords((x²+1)·cofactor) = coords(p').
theorem GaussianInteger.coords_descends_mod_x2_plus_1
        (p p' : Polynomial(Integer, Integer.zero))
        (congruent : Ring.CongruentModulo(Integer.polynomial_ring, GaussianInteger.definingPolynomial, p, p'))
        : GaussianInteger.coordinatesOfPolynomial(p)
          = GaussianInteger.coordinatesOfPolynomial(p') := {
  choose cofactor such that
      p + (-p') = GaussianInteger.definingPolynomial * cofactor
      as differenceEquation from congruent;
  -- Rearrange p + (−p') = (x²+1)·cofactor to p = p' + (x²+1)·cofactor
  -- (a group rearrangement; the reversed steps name the law they undo).
  calc p
            = p + Polynomial.zero(Integer.ring_bundle)
                  by Polynomial.add_identity_right
            = p + ((-p') + p')
                  by Polynomial.add_negate_left
            = (p + (-p')) + p'
                  by Polynomial.add_associative
            = GaussianInteger.definingPolynomial * cofactor + p'
                  by differenceEquation
            = p' + GaussianInteger.definingPolynomial * cofactor
                  by Polynomial.add_commutative as pEquation;
  -- coords of the (x²+1)-multiple vanish.
  claim modCoordinates
      : coords(GaussianInteger.definingPolynomial * cofactor) = Product.make(Integer.zero, Integer.zero)
      by GaussianInteger.coords_defining_polynomial_mul_zero;
  -- coords(p) = coords(p' + (x²+1)·cofactor) = coords(p') ⊕ (0,0) = coords(p').
  calc coords(p)
     = coords(p' + GaussianInteger.definingPolynomial * cofactor)
           by pEquation
     = Product.make(
           Product.first(coords(p')) + Product.first(coords(GaussianInteger.definingPolynomial * cofactor)),
           Product.second(coords(p')) + Product.second(coords(GaussianInteger.definingPolynomial * cofactor)))
           by GaussianInteger.coords_add
     = Product.make(Product.first(coords(p')), Product.second(coords(p')))
           by {
             -- each coordinate gains 0 from the vanishing multiple
             calc Product.first(coords(p')) + Product.first(coords(GaussianInteger.definingPolynomial * cofactor))
                = Product.first(coords(p')) + Integer.zero   by modCoordinates
                = Product.first(coords(p'));
             calc Product.second(coords(p')) + Product.second(coords(GaussianInteger.definingPolynomial * cofactor))
                = Product.second(coords(p')) + Integer.zero   by modCoordinates
                = Product.second(coords(p'));
             done
           }
     = coords(p')
           by GaussianInteger.product_eta
}

-- ----------------------------------------------------------------------
-- The coordinate map on ℤ[i]: (re, im) of a Gaussian integer.
definition GaussianInteger.coordinates : GaussianInteger → Pair(Integer, Integer)
  by representatives p ↦ GaussianInteger.coordinatesOfPolynomial(p)
  well_defined by GaussianInteger.coords_descends_mod_x2_plus_1

overload coords := GaussianInteger.coordinates

-- The named projections: real and imaginary parts of a Gaussian integer.
definition GaussianInteger.realPart (p : GaussianInteger) : Integer :=
  Product.first(GaussianInteger.coordinates(p))

definition GaussianInteger.imaginaryPart (p : GaussianInteger) : Integer :=
  Product.second(GaussianInteger.coordinates(p))

overload re := GaussianInteger.realPart
overload im := GaussianInteger.imaginaryPart

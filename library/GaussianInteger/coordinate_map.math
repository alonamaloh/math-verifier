-- GaussianInteger/coordinate_map.math
--
-- The coordinate map descends to ℤ[i]: combining additivity with the
-- modulus-vanishing, `coordinatesOfPolynomial` respects the (x²+1)-
-- congruence, so it lifts to a genuine function `coordinates : ℤ[i] →
-- ℤ×ℤ` reading the (re, im) of a Gaussian integer a + bi.

module GaussianInteger.coordinate_map

import Logic.basics
import Logic.exists
import Logic.product
import Logic.quotient
import Equality.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.ring_divisibility
import Integer.basics
import Integer.addition
import Integer.ring
import Integer.algebra
import Polynomial.basics
import Polynomial.addition
import Polynomial.negation
import Polynomial.additive_group
import Polynomial.multiplication
import Polynomial.instances
import RingModulo.basics
import GaussianInteger.basics
import GaussianInteger.coordinates
import GaussianInteger.coordinate_homomorphism
import GaussianInteger.modulus_vanishes

-- ----------------------------------------------------------------------
-- coordinatesOfPolynomial respects congruence modulo x²+1.
--
-- From p − p' = (x²+1)·cofactor we get p = p' + (x²+1)·cofactor, so by
-- additivity coords(p) = coords(p') ⊕ coords((x²+1)·cofactor) = coords(p').
theorem GaussianInteger.coordinatesOfPolynomial_respects_congruence
        (p p' : Polynomial(Integer, Integer.zero))
        (congruent : Ring.CongruentModulo(Integer.polynomial_ring, GaussianInteger.modulus, p, p'))
        : GaussianInteger.coordinatesOfPolynomial(p)
          = GaussianInteger.coordinatesOfPolynomial(p') := {
  obtain ⟨cofactor, differenceEquation⟩ from congruent;
  -- differenceEquation : p + (−p') = (x²+1)·cofactor. Rearrange to
  -- p = p' + (x²+1)·cofactor (a group rearrangement; the reversed steps
  -- name the law they undo).
  claim pEquation : p = p' + GaussianInteger.modulus * cofactor
      by calc p
            = p + Polynomial.zero(Integer.ring_bundle)
                  since Polynomial.add_identity_right(Integer.ring_bundle, p)
            = p + ((-p') + p')
                  since Polynomial.add_negate_left(Integer.ring_bundle, p')
            = (p + (-p')) + p'
                  since Polynomial.add_associative(Integer.ring_bundle, p, -p', p')
            = GaussianInteger.modulus * cofactor + p'
                  since differenceEquation
            = p' + GaussianInteger.modulus * cofactor
                  since Polynomial.add_commutative(Integer.ring_bundle,
                         GaussianInteger.modulus * cofactor, p');
  -- coords of the (x²+1)-multiple vanish.
  claim modCoordinates
      : coords(GaussianInteger.modulus * cofactor) = Product.make(Integer.zero, Integer.zero)
      since GaussianInteger.coordinatesOfPolynomial_modulus_multiply(cofactor);
  -- coords(p) = coords(p' + (x²+1)·cofactor) = coords(p') ⊕ (0,0) = coords(p').
  calc coords(p)
     = coords(p' + GaussianInteger.modulus * cofactor)
           since pEquation
     = Product.make(
           Product.first(coords(p')) + Product.first(coords(GaussianInteger.modulus * cofactor)),
           Product.second(coords(p')) + Product.second(coords(GaussianInteger.modulus * cofactor)))
           since GaussianInteger.coordinatesOfPolynomial_add(p', GaussianInteger.modulus * cofactor)
     = Product.make(Product.first(coords(p')), Product.second(coords(p')))
           by {
             -- each coordinate gains 0 from the vanishing multiple
             calc Product.first(coords(p')) + Product.first(coords(GaussianInteger.modulus * cofactor))
                = Product.first(coords(p')) + Integer.zero   by modCoordinates
                = Product.first(coords(p'));
             calc Product.second(coords(p')) + Product.second(coords(GaussianInteger.modulus * cofactor))
                = Product.second(coords(p')) + Integer.zero   by modCoordinates
                = Product.second(coords(p'));
             done
           }
     = coords(p')
           since GaussianInteger.product_eta(coords(p'))
}

-- ----------------------------------------------------------------------
-- The coordinate map on ℤ[i]: (re, im) of a Gaussian integer.
definition GaussianInteger.coordinates : GaussianInteger → Pair(Integer, Integer)
  by representatives p ↦ GaussianInteger.coordinatesOfPolynomial(p)
  well_defined by GaussianInteger.coordinatesOfPolynomial_respects_congruence

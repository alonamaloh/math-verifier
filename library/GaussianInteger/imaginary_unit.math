-- GaussianInteger/imaginary_unit.math
--
-- The imaginary unit i ∈ ℤ[i] (the class of the polynomial x) and the
-- defining relation i² = −1. The relation is just the defining
-- polynomial vanishing: x·x + 1 has class 0, so i·i + 1 = 0.

module GaussianInteger.imaginary_unit

import Logic.basics
import Logic.quotient
import Equality.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Integer.basics
import Integer.ring
import Polynomial.basics
import Polynomial.addition
import Polynomial.multiplication
import RingModulo.basics
import RingModulo.operations
import RingModulo.ring
import RingModulo.instances
import GaussianInteger.basics

-- The imaginary unit: the class of x in ℤ[x]/(x²+1).
definition GaussianInteger.i : GaussianInteger :=
  RingModulo.make(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial,
      GaussianInteger.x)

-- i² + 1 = 0 in ℤ[i]: the class of x·x + 1 (the defining polynomial) is zero.
theorem GaussianInteger.i_squared_plus_one
        : GaussianInteger.i * GaussianInteger.i
            + RingModulo.one(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)
          = RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial) :=
  calc GaussianInteger.i * GaussianInteger.i
         + RingModulo.one(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)
     = RingModulo.make(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial,
           GaussianInteger.definingPolynomial)
     = RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)
           by RingModulo.modulus_is_zero

-- i² = −1. Subtract 1 from i² + 1 = 0; `ring` does the regrouping.
theorem GaussianInteger.i_squared
        : GaussianInteger.i * GaussianInteger.i
          = RingModulo.negate(
                RingModulo.one(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)) :=
  calc GaussianInteger.i * GaussianInteger.i
     = (GaussianInteger.i * GaussianInteger.i
            + RingModulo.one(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial))
       - RingModulo.one(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)
           by ring
     = RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)
       - RingModulo.one(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial)
           by GaussianInteger.i_squared_plus_one
     = RingModulo.negate(
           RingModulo.one(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial))

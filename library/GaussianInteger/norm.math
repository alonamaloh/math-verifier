-- GaussianInteger/norm.math
--
-- The norm N(a+bi) = a²+b² on ℤ[i], and the structural facts it gives:
-- it is multiplicative and vanishes only at 0. Built on the coordinate
-- map being a ring homomorphism (additive + multiplicative).

module GaussianInteger.norm

import Logic.basics
import Logic.product
import Logic.quotient
import Equality.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.ring
import Integer.algebra
import RingModulo.basics
import RingModulo.operations
import GaussianInteger.basics
import GaussianInteger.coordinates
import GaussianInteger.coordinate_map
import GaussianInteger.coordinate_multiplicative

-- ----------------------------------------------------------------------
-- The coordinate map is multiplicative on ℤ[i] itself.
theorem GaussianInteger.coordinates_multiply (z w : GaussianInteger)
        : coords(RingModulo.multiply(z, w))
          = GaussianInteger.gaussianProduct(coords(z), coords(w)) :=
  by_representatives z as p, w as q =>
    GaussianInteger.coordinatesOfPolynomial_multiply(p, q)

-- ----------------------------------------------------------------------
-- The norm of a coordinate pair, N(a, b) = a² + b².
definition GaussianInteger.normPair (p : Pair(Integer, Integer)) : Integer :=
  Product.first(p) * Product.first(p) + Product.second(p) * Product.second(p)

-- The (integer-valued) norm N(z) = re(z)² + im(z)².
definition GaussianInteger.normInteger (z : GaussianInteger) : Integer :=
  GaussianInteger.normPair(coords(z))

-- ----------------------------------------------------------------------
-- The Brahmagupta–Fibonacci identity, isolated as a pure-`ring` fact about
-- coordinate pairs: (ac−bd)²+(ad+bc)² = (a²+b²)(c²+d²).
theorem GaussianInteger.normPair_gaussianProduct (u v : Pair(Integer, Integer))
        : GaussianInteger.normPair(GaussianInteger.gaussianProduct(u, v))
          = GaussianInteger.normPair(u) * GaussianInteger.normPair(v) :=
  -- destructure the pairs so the re/im projections of the gaussianProduct
  -- compute; the middle line is the plain Brahmagupta identity for `ring`,
  -- and the two outer `=` steps just fold the definitions back in (defeq).
  {
    let ⟨a, b⟩ := u;
    let ⟨c, d⟩ := v;
    GaussianInteger.normPair(GaussianInteger.gaussianProduct(
             Product.make(a, b), Product.make(c, d)))
       = (a * c - b * d) * (a * c - b * d) + (a * d + b * c) * (a * d + b * c)
       = (a * a + b * b) * (c * c + d * d)
             by ring
       = GaussianInteger.normPair(Product.make(a, b))
             * GaussianInteger.normPair(Product.make(c, d))
  }

-- ----------------------------------------------------------------------
-- The norm is multiplicative: N(z·w) = N(z)·N(w) — coordinates being
-- multiplicative turns it into the Brahmagupta–Fibonacci identity above.
theorem GaussianInteger.normInteger_multiply (z w : GaussianInteger)
        : GaussianInteger.normInteger(z * w)
          = GaussianInteger.normInteger(z) * GaussianInteger.normInteger(w) :=
  GaussianInteger.normPair(coords(z * w))
     = GaussianInteger.normPair(GaussianInteger.gaussianProduct(coords(z), coords(w)))
           by GaussianInteger.coordinates_multiply
     = GaussianInteger.normInteger(z) * GaussianInteger.normInteger(w)
           by GaussianInteger.normPair_gaussianProduct

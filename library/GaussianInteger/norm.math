-- GaussianInteger/norm.math
--
-- The norm N(a+bi) = a²+b² on ℤ[i], and the structural facts it gives:
-- it is multiplicative and vanishes only at 0. Built on the coordinate
-- map being a ring homomorphism (additive + multiplicative).

module GaussianInteger.norm

import Logic.basics
import Logic.product
import Logic.quotient
import Equality.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.ring
import Integer.algebra
import RingModulo.basics
import RingModulo.operations
import GaussianInteger.basics
import GaussianInteger.coordinates
import GaussianInteger.coordinate_map
import GaussianInteger.coordinate_multiplicative

-- ----------------------------------------------------------------------
-- The coordinate map is multiplicative on ℤ[i] itself.
theorem GaussianInteger.coordinates_multiply (z w : GaussianInteger)
        : GaussianInteger.coordinates(RingModulo.multiply(z, w))
          = GaussianInteger.gaussianProduct(
                GaussianInteger.coordinates(z), GaussianInteger.coordinates(w)) :=
  cases z { | p =>
    cases w { | q =>
      GaussianInteger.coordinatesOfPolynomial_multiply(p, q)
    }
  }

-- ----------------------------------------------------------------------
-- The (integer-valued) norm N(z) = re(z)² + im(z)².
definition GaussianInteger.normInteger (z : GaussianInteger) : Integer :=
  Product.first(GaussianInteger.coordinates(z)) * Product.first(GaussianInteger.coordinates(z))
    + Product.second(GaussianInteger.coordinates(z)) * Product.second(GaussianInteger.coordinates(z))

-- ----------------------------------------------------------------------
-- The norm is multiplicative: N(z·w) = N(z)·N(w). This is the
-- Brahmagupta–Fibonacci identity (ac−bd)²+(ad+bc)² = (a²+b²)(c²+d²),
-- pure `ring`, fed by coordinates being multiplicative.
theorem GaussianInteger.normInteger_multiply (z w : GaussianInteger)
        : GaussianInteger.normInteger(RingModulo.multiply(z, w))
          = GaussianInteger.normInteger(z) * GaussianInteger.normInteger(w) := {
  claim coordinatesEqual
      : GaussianInteger.coordinates(RingModulo.multiply(z, w))
        = GaussianInteger.gaussianProduct(
              GaussianInteger.coordinates(z), GaussianInteger.coordinates(w))
      by GaussianInteger.coordinates_multiply(z, w);
  calc Product.first(GaussianInteger.coordinates(RingModulo.multiply(z, w)))
           * Product.first(GaussianInteger.coordinates(RingModulo.multiply(z, w)))
       + Product.second(GaussianInteger.coordinates(RingModulo.multiply(z, w)))
           * Product.second(GaussianInteger.coordinates(RingModulo.multiply(z, w)))
     = (Product.first(GaussianInteger.coordinates(z)) * Product.first(GaussianInteger.coordinates(w))
            - Product.second(GaussianInteger.coordinates(z)) * Product.second(GaussianInteger.coordinates(w)))
           * (Product.first(GaussianInteger.coordinates(z)) * Product.first(GaussianInteger.coordinates(w))
              - Product.second(GaussianInteger.coordinates(z)) * Product.second(GaussianInteger.coordinates(w)))
       + (Product.first(GaussianInteger.coordinates(z)) * Product.second(GaussianInteger.coordinates(w))
            + Product.second(GaussianInteger.coordinates(z)) * Product.first(GaussianInteger.coordinates(w)))
           * (Product.first(GaussianInteger.coordinates(z)) * Product.second(GaussianInteger.coordinates(w))
              + Product.second(GaussianInteger.coordinates(z)) * Product.first(GaussianInteger.coordinates(w)))
           by congruenceOf(
                  (pair : Pair(Integer, Integer)) ↦
                      Product.first(pair) * Product.first(pair) + Product.second(pair) * Product.second(pair),
                  coordinatesEqual)
     = (Product.first(GaussianInteger.coordinates(z)) * Product.first(GaussianInteger.coordinates(z))
            + Product.second(GaussianInteger.coordinates(z)) * Product.second(GaussianInteger.coordinates(z)))
           * (Product.first(GaussianInteger.coordinates(w)) * Product.first(GaussianInteger.coordinates(w))
              + Product.second(GaussianInteger.coordinates(w)) * Product.second(GaussianInteger.coordinates(w)))
           by ring
}

-- RingModulo/operations.math
--
-- The ring operations on RingModulo(c, m): addition, negation,
-- subtraction, and multiplication, plus the constants zero and one.
-- Each operation descends from the corresponding operation on the
-- underlying ring `CommutativeRing.ring(c)` through the quotient,
-- mirroring IntegerMod/operations.math.
--
-- The well-definedness obligations are the three `CongruentModulo.*_
-- respects` lemmas (still stated over a plain `s : Ring`, since they are
-- general): addition and negation respect the congruence for any ring;
-- multiplication needs commutativity (a left multiple `a'·(b−b')` is
-- only divisible by `m` after commuting). The quotient is indexed by a
-- `CommutativeRing`, so `multiply` reads the commutativity proof off
-- `CommutativeRing.commutative(c)` rather than taking it as an argument.

module RingModulo.operations

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.ring_divisibility
import Algebra.ring_difference
import RingModulo.basics

-- ----------------------------------------------------------------------
-- Respect of congruence by the base ring operations. Stated over a
-- plain `s : Ring` — they are general divisibility/difference facts and
-- have nothing to do with the bundle.

-- (a + b) − (a' + b') = (a − a') + (b − b'); closed under addition.
theorem Ring.CongruentModulo.add_respects (s : Ring)
        (m a a' b b' : Ring.carrier(s))
        (congruentA : Ring.CongruentModulo(s, m, a, a'))
        (congruentB : Ring.CongruentModulo(s, m, b, b'))
        : Ring.CongruentModulo(s, m, Ring.add(s, a, b), Ring.add(s, a', b')) :=
  rewrite(Ring.difference_add_distribute(s, a, a', b, b'),
          Ring.divides_add(s, m,
              Ring.add(s, a, Ring.negate(s, a')),
              Ring.add(s, b, Ring.negate(s, b')),
              congruentA, congruentB))

-- (−a) − (−a') = −(a − a'); closed under negation.
theorem Ring.CongruentModulo.negate_respects (s : Ring)
        (m a a' : Ring.carrier(s))
        (congruentA : Ring.CongruentModulo(s, m, a, a'))
        : Ring.CongruentModulo(s, m, Ring.negate(s, a), Ring.negate(s, a')) :=
  rewrite(Ring.negate_add_distribute(s, a, Ring.negate(s, a')),
          Ring.divides_negate(s, m,
              Ring.add(s, a, Ring.negate(s, a')), congruentA))

-- a·b − a'·b' = (a − a')·b + a'·(b − b'); closed under addition of the
-- right multiple of (a − a') and the left multiple of (b − b'). The
-- left multiple needs commutativity to expose `m` as a divisor.
theorem Ring.CongruentModulo.multiply_respects (s : Ring)
        (commutativity : Ring.MultiplyCommutative(s))
        (m a a' b b' : Ring.carrier(s))
        (congruentA : Ring.CongruentModulo(s, m, a, a'))
        (congruentB : Ring.CongruentModulo(s, m, b, b'))
        : Ring.CongruentModulo(s, m,
              Ring.multiply(s, a, b), Ring.multiply(s, a', b')) :=
  rewrite(Ring.difference_multiply_split(s, a, a', b, b'),
          Ring.divides_add(s, m,
              Ring.multiply(s, Ring.add(s, a, Ring.negate(s, a')), b),
              Ring.multiply(s, a', Ring.add(s, b, Ring.negate(s, b'))),
              Ring.divides_multiply_right(s, m,
                  Ring.add(s, a, Ring.negate(s, a')), b, congruentA),
              Ring.divides_multiply_left(s, commutativity, m,
                  Ring.add(s, b, Ring.negate(s, b')), a', congruentB)))

-- ----------------------------------------------------------------------
-- The class of a representative. Canonical introduction form.

construction RingModulo.make (c : CommutativeRing) (m a : CommutativeRing.carrier(c))
        : RingModulo(c, m) :=
  Quotient.mk(a)

-- ----------------------------------------------------------------------
-- Addition. Lift base addition over both arguments.

-- Add the base-ring representatives modulo `m`; well-defined in each
-- argument because Ring addition respects congruence.
definition RingModulo.add {c : CommutativeRing} {m : CommutativeRing.carrier(c)}
        : RingModulo(c, m) → RingModulo(c, m) → RingModulo(c, m)
  by representatives a, b ↦ RingModulo.make(c, m, Ring.add(CommutativeRing.ring(c), a, b))
  well_defined by
    (a a' b : CommutativeRing.carrier(c))
        (congruentA : Ring.CongruentModulo(CommutativeRing.ring(c), m, a, a')) ↦
        Ring.CongruentModulo.add_respects(CommutativeRing.ring(c), m, a, a', b, b,
            congruentA, Ring.CongruentModulo.reflexive(CommutativeRing.ring(c), m, b)),
    (a b b' : CommutativeRing.carrier(c))
        (congruentB : Ring.CongruentModulo(CommutativeRing.ring(c), m, b, b')) ↦
        Ring.CongruentModulo.add_respects(CommutativeRing.ring(c), m, a, a, b, b',
            Ring.CongruentModulo.reflexive(CommutativeRing.ring(c), m, a), congruentB)

-- The ring/structure arguments are implicit and recovered from the
-- operand type RingModulo(c, m), so `x + y` dispatches here.
operator (+) on (RingModulo, RingModulo) := RingModulo.add

-- ----------------------------------------------------------------------
-- Negation. A single lift.

definition RingModulo.negate {c : CommutativeRing} {m : CommutativeRing.carrier(c)}
        : RingModulo(c, m) → RingModulo(c, m)
  by representatives a ↦
       RingModulo.make(c, m, Ring.negate(CommutativeRing.ring(c), a))
  well_defined by (a a' : CommutativeRing.carrier(c))
               (congruentA : Ring.CongruentModulo(CommutativeRing.ring(c), m, a, a')) ↦
          Ring.CongruentModulo.negate_respects(CommutativeRing.ring(c), m, a, a', congruentA)

-- ----------------------------------------------------------------------
-- Subtraction. x − y := x + (−y); the structure arguments are implicit
-- and recovered from the operand type, so `x - y` dispatches here.

definition RingModulo.subtract {c : CommutativeRing} {m : CommutativeRing.carrier(c)}
        (x y : RingModulo(c, m)) : RingModulo(c, m) :=
  RingModulo.add(x, RingModulo.negate(y))

operator (-) on (RingModulo, RingModulo) := RingModulo.subtract

-- ----------------------------------------------------------------------
-- Multiplication. Same two-lift shape as addition; the commutativity
-- proof comes from the bundle (`CommutativeRing.commutative(c)`).

-- Multiply the base-ring representatives modulo `m`; the commutativity
-- proof (needed for the left-multiple direction) comes from the bundle.
definition RingModulo.multiply {c : CommutativeRing} {m : CommutativeRing.carrier(c)}
        : RingModulo(c, m) → RingModulo(c, m) → RingModulo(c, m)
  by representatives a, b ↦ RingModulo.make(c, m, Ring.multiply(CommutativeRing.ring(c), a, b))
  well_defined by
    (a a' b : CommutativeRing.carrier(c))
        (congruentA : Ring.CongruentModulo(CommutativeRing.ring(c), m, a, a')) ↦
        Ring.CongruentModulo.multiply_respects(CommutativeRing.ring(c),
            CommutativeRing.commutative(c), m, a, a', b, b,
            congruentA, Ring.CongruentModulo.reflexive(CommutativeRing.ring(c), m, b)),
    (a b b' : CommutativeRing.carrier(c))
        (congruentB : Ring.CongruentModulo(CommutativeRing.ring(c), m, b, b')) ↦
        Ring.CongruentModulo.multiply_respects(CommutativeRing.ring(c),
            CommutativeRing.commutative(c), m, a, a, b, b',
            Ring.CongruentModulo.reflexive(CommutativeRing.ring(c), m, a), congruentB)

-- The commutativity proof is recovered from the bundle `c`, which is
-- itself recovered from the operand type, so `x * y` dispatches here.
operator (*) on (RingModulo, RingModulo) := RingModulo.multiply

-- ----------------------------------------------------------------------
-- Constants.

definition RingModulo.zero (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        : RingModulo(c, m) :=
  RingModulo.make(c, m, Ring.zero(CommutativeRing.ring(c)))

definition RingModulo.one (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        : RingModulo(c, m) :=
  RingModulo.make(c, m, Ring.one(CommutativeRing.ring(c)))

-- The class of the modulus is zero: m ≡ 0 (mod m), since m divides
-- m − 0 = m. (The defining relation of the quotient, packaged.)
theorem RingModulo.modulus_is_zero (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        : RingModulo.make(c, m, m) = RingModulo.zero(c, m) :=
  Quotient.sound(
      CommutativeRing.carrier(c), Ring.CongruentModulo(CommutativeRing.ring(c), m),
      m, Ring.zero(CommutativeRing.ring(c)),
      (⟨Ring.one(CommutativeRing.ring(c)),
        calc Ring.add(CommutativeRing.ring(c), m, Ring.negate(CommutativeRing.ring(c), Ring.zero(CommutativeRing.ring(c))))
           = Ring.add(CommutativeRing.ring(c), m, Ring.zero(CommutativeRing.ring(c)))
           = m
           = Ring.multiply(CommutativeRing.ring(c), m, Ring.one(CommutativeRing.ring(c)))⟩
       : Ring.divides(CommutativeRing.ring(c), m,
             Ring.add(CommutativeRing.ring(c), m, Ring.negate(CommutativeRing.ring(c), Ring.zero(CommutativeRing.ring(c)))))))

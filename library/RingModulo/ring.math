-- RingModulo/ring.math
--
-- The ring laws for RingModulo(c, m). Every law lifts the corresponding
-- law of the underlying ring `CommutativeRing.ring(c)` through the
-- quotient: on representatives the operations reduce (by the
-- Quotient.lift compute rule) to `RingModulo.make(c, m, <base
-- expression>)`, so the law is exactly `congruenceOf(make, <base law>)`.
-- The base laws come from the bundle's flattened projections
-- (`Ring.add_associative`, …); the multiplicative laws read the base
-- commutativity off `CommutativeRing.commutative(c)`.
--
-- Statements use the `+`/`*` operators on RingModulo(c, m); they dispatch
-- to `RingModulo.add`/`RingModulo.multiply`, which is the form the
-- quotient-lift bodies produce. Representatives are named `u v w` to
-- avoid colliding with the bundle parameter `c`.

module RingModulo.ring

import Logic.basics
import Logic.quotient
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import RingModulo.basics
import RingModulo.operations

-- ----------------------------------------------------------------------
-- Additive abelian group.

theorem RingModulo.add_associative (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        (x y z : RingModulo(c, m))
        : (x + y) + z = x + (y + z) :=
  Quotient.induct_three(
      (u v w : CommutativeRing.carrier(c)) ↦
          congruenceOf(
              (representativeValue : CommutativeRing.carrier(c)) ↦
                  RingModulo.make(c, m, representativeValue),
              Ring.add_associative(CommutativeRing.ring(c), u, v, w)),
      x, y, z)

theorem RingModulo.add_identity_left (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        (x : RingModulo(c, m))
        : RingModulo.zero(c, m) + x = x :=
  Quotient.induct(
      (u : CommutativeRing.carrier(c)) ↦
          congruenceOf(
              (representativeValue : CommutativeRing.carrier(c)) ↦
                  RingModulo.make(c, m, representativeValue),
              Ring.zero_add(CommutativeRing.ring(c), u)),
      x)

theorem RingModulo.add_identity_right (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        (x : RingModulo(c, m))
        : x + RingModulo.zero(c, m) = x :=
  Quotient.induct(
      (u : CommutativeRing.carrier(c)) ↦
          congruenceOf(
              (representativeValue : CommutativeRing.carrier(c)) ↦
                  RingModulo.make(c, m, representativeValue),
              Ring.add_zero(CommutativeRing.ring(c), u)),
      x)

theorem RingModulo.add_commutative (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        (x y : RingModulo(c, m))
        : x + y = y + x :=
  Quotient.induct_two(
      (u v : CommutativeRing.carrier(c)) ↦
          congruenceOf(
              (representativeValue : CommutativeRing.carrier(c)) ↦
                  RingModulo.make(c, m, representativeValue),
              Ring.add_commutative(CommutativeRing.ring(c), u, v)),
      x, y)

theorem RingModulo.add_negate_left (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        (x : RingModulo(c, m))
        : RingModulo.negate(x) + x = RingModulo.zero(c, m) :=
  Quotient.induct(
      (u : CommutativeRing.carrier(c)) ↦
          congruenceOf(
              (representativeValue : CommutativeRing.carrier(c)) ↦
                  RingModulo.make(c, m, representativeValue),
              Ring.add_negate_left(CommutativeRing.ring(c), u)),
      x)

theorem RingModulo.add_negate_right (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        (x : RingModulo(c, m))
        : x + RingModulo.negate(x) = RingModulo.zero(c, m) :=
  Quotient.induct(
      (u : CommutativeRing.carrier(c)) ↦
          congruenceOf(
              (representativeValue : CommutativeRing.carrier(c)) ↦
                  RingModulo.make(c, m, representativeValue),
              Ring.add_negate_right(CommutativeRing.ring(c), u)),
      x)

-- ----------------------------------------------------------------------
-- Multiplicative monoid.

theorem RingModulo.multiply_associative (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        (x y z : RingModulo(c, m))
        : (x * y) * z = x * (y * z) :=
  Quotient.induct_three(
      (u v w : CommutativeRing.carrier(c)) ↦
          congruenceOf(
              (representativeValue : CommutativeRing.carrier(c)) ↦
                  RingModulo.make(c, m, representativeValue),
              Ring.multiply_associative(CommutativeRing.ring(c), u, v, w)),
      x, y, z)

theorem RingModulo.multiply_identity_left (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        (x : RingModulo(c, m))
        : RingModulo.one(c, m) * x = x :=
  Quotient.induct(
      (u : CommutativeRing.carrier(c)) ↦
          congruenceOf(
              (representativeValue : CommutativeRing.carrier(c)) ↦
                  RingModulo.make(c, m, representativeValue),
              Ring.one_multiply(CommutativeRing.ring(c), u)),
      x)

theorem RingModulo.multiply_identity_right (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        (x : RingModulo(c, m))
        : x * RingModulo.one(c, m) = x :=
  Quotient.induct(
      (u : CommutativeRing.carrier(c)) ↦
          congruenceOf(
              (representativeValue : CommutativeRing.carrier(c)) ↦
                  RingModulo.make(c, m, representativeValue),
              Ring.multiply_one(CommutativeRing.ring(c), u)),
      x)

theorem RingModulo.multiply_commutative (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        (x y : RingModulo(c, m))
        : x * y = y * x :=
  Quotient.induct_two(
      (u v : CommutativeRing.carrier(c)) ↦
          congruenceOf(
              (representativeValue : CommutativeRing.carrier(c)) ↦
                  RingModulo.make(c, m, representativeValue),
              CommutativeRing.commutative(c)(u, v)),
      x, y)

-- ----------------------------------------------------------------------
-- Distributivity.

theorem RingModulo.distributivity_left (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        (x y z : RingModulo(c, m))
        : x * (y + z) = x * y + x * z :=
  Quotient.induct_three(
      (u v w : CommutativeRing.carrier(c)) ↦
          congruenceOf(
              (representativeValue : CommutativeRing.carrier(c)) ↦
                  RingModulo.make(c, m, representativeValue),
              Ring.distributivity_left(CommutativeRing.ring(c), u, v, w)),
      x, y, z)

theorem RingModulo.distributivity_right (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        (x y z : RingModulo(c, m))
        : (x + y) * z = x * z + y * z :=
  Quotient.induct_three(
      (u v w : CommutativeRing.carrier(c)) ↦
          congruenceOf(
              (representativeValue : CommutativeRing.carrier(c)) ↦
                  RingModulo.make(c, m, representativeValue),
              Ring.distributivity_right(CommutativeRing.ring(c), u, v, w)),
      x, y, z)

-- RingModulo/basics.math
--
-- A ring modulo the principal ideal generated by an element `m`:
--   RingModulo(s, m) := Quotient(Ring.carrier(s), CongruentModulo(s, m))
-- where two elements are congruent modulo `m` exactly when `m` divides
-- their difference. This is the abstract analogue of the IntegerMod(n)
-- construction (Z modulo the ideal (n)) lifted to an arbitrary bundled
-- ring `s`.
--
-- For univariate polynomials over a field every ideal is principal, so
-- `RingModulo(polynomialRing(field), f)` is the quotient by an
-- arbitrary ideal — the construction used to build finite fields
-- F_{p^k} = F_p[x]/(f) for an irreducible f (see FiniteField/).
--
-- The congruence is an equivalence and is respected by +, −, · exactly
-- as for IntegerMod; the proofs reduce to the generic divisibility
-- closure lemmas (Algebra/ring_divisibility) plus the difference
-- rearrangement identities (Algebra/ring_difference), which play the
-- role the `ring` tactic plays in the concrete IntegerMod proofs.

module RingModulo.basics

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.ring_divisibility
import Algebra.ring_difference

-- x is congruent to y modulo m when m divides the difference x + (−y).
definition Ring.CongruentModulo (s : Ring) (m x y : Ring.carrier(s))
        : Proposition :=
  Ring.divides(s, m, Ring.add(s, x, Ring.negate(s, y)))

-- The commutative ring `c` modulo the ideal generated by `m`. Indexed
-- by a `CommutativeRing` (not a plain `Ring`) so that the multiplicative
-- structure — which needs commutativity — recovers its commutativity
-- proof from the operand type alone (`c` is the head argument here).
-- Addition and negation ignore the commutativity field; they descend
-- through the underlying ring `CommutativeRing.ring(c)` exactly as
-- before.
definition RingModulo (c : CommutativeRing) (m : CommutativeRing.carrier(c)) : Type(0) :=
  Quotient(CommutativeRing.carrier(c),
           Ring.CongruentModulo(CommutativeRing.ring(c), m))

-- ----------------------------------------------------------------------
-- Congruence is an equivalence relation. Each property is one
-- divisibility closure lemma plus a difference rearrangement.

-- Reflexive: x − x = 0 and m divides 0.
theorem Ring.CongruentModulo.reflexive (s : Ring) (m x : Ring.carrier(s))
        : Ring.CongruentModulo(s, m, x, x) :=
  rewrite(Equality.symmetry(Ring.add_negate_right(s, x)),
          Ring.divides_zero(s, m))

-- Symmetric: −(x − y) = y − x, and divisibility is closed under negation.
theorem Ring.CongruentModulo.symmetric (s : Ring) (m x y : Ring.carrier(s))
        (congruent : Ring.CongruentModulo(s, m, x, y))
        : Ring.CongruentModulo(s, m, y, x) :=
  rewrite(Ring.negate_difference(s, x, y),
          Ring.divides_negate(s, m, Ring.add(s, x, Ring.negate(s, y)),
              congruent))

-- Transitive: (x − y) + (y − z) = x − z, and divisibility is closed
-- under addition.
theorem Ring.CongruentModulo.transitive (s : Ring) (m x y z : Ring.carrier(s))
        (congruentXY : Ring.CongruentModulo(s, m, x, y))
        (congruentYZ : Ring.CongruentModulo(s, m, y, z))
        : Ring.CongruentModulo(s, m, x, z) :=
  rewrite(Ring.difference_telescope(s, x, y, z),
          Ring.divides_add(s, m,
              Ring.add(s, x, Ring.negate(s, y)),
              Ring.add(s, y, Ring.negate(s, z)),
              congruentXY, congruentYZ))

-- The congruence bundled as an `IsEquivalenceRelation`.
definition RingModulo.equivalence (s : Ring) (m : Ring.carrier(s))
        : IsEquivalenceRelation(Ring.carrier(s), Ring.CongruentModulo(s, m)) :=
  ⟨function (x : Ring.carrier(s)) => Ring.CongruentModulo.reflexive(s, m, x),
   function (x y : Ring.carrier(s))
            (congruent : Ring.CongruentModulo(s, m, x, y)) =>
       Ring.CongruentModulo.symmetric(s, m, x, y, congruent),
   function (x y z : Ring.carrier(s))
            (congruentXY : Ring.CongruentModulo(s, m, x, y))
            (congruentYZ : Ring.CongruentModulo(s, m, y, z)) =>
       Ring.CongruentModulo.transitive(s, m, x, y, z, congruentXY, congruentYZ)⟩

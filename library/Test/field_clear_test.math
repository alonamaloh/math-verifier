module Test.field_clear_test

import Logic.basics
import Equality.basics
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.ring
import Rational.reciprocal_function
import Rational.division
import Real.basics
import Real.addition
import Real.multiplication
import Real.ring
import Real.reciprocal
import Real.field
import Real.division

-- Same denominator: the multiplicity already carries the factor (direct path).
theorem real_half (x : Real) : x / 2 + x / 2 = x :=
  field

-- Mixed denominators (2, 3, 6): no single multiplicity divides, so `field`
-- clears by D = 2·3 = 6 and cancels — route 1.
theorem real_sixths (x : Real)
        (threeNonzero : (3 : Real) ≠ Real.zero)
        (sixNonzero : (6 : Real) ≠ Real.zero)
        : x / 2 + x / 3 + x / 6 = x :=
  field

-- Mixed denominators on both sides: x/2 + x/6 = x/3 + x/3 (= 2x/3).
theorem real_two_thirds (x : Real)
        (threeNonzero : (3 : Real) ≠ Real.zero)
        (sixNonzero : (6 : Real) ≠ Real.zero)
        : x / 2 + x / 6 = x / 3 + x / 3 :=
  field

theorem real_divide_self (a : Real) (aNonzero : a ≠ Real.zero) : a / a = Real.one :=
  field

theorem rational_half (x : Rational) (twoNonzero : (2 : Rational) ≠ Rational.zero)
        : x / 2 + x / 2 = x :=
  field(twoNonzero)

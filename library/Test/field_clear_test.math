module Test.field_clear_test

import Logic.basics
import Equality.basics
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.ring
import Rational.reciprocal_function
import Rational.division
import Real.basics
import Real.addition
import Real.multiplication
import Real.ring
import Real.reciprocal
import Real.field
import Real.division

-- THE headline: clearing the denominator against the integer multiplicity.
theorem real_half (x : Real) : x / 2 + x / 2 = x :=
  field

theorem real_third (x : Real) (threeNonzero : (3 : Real) ≠ Real.zero)
        : x / 3 + x / 3 + x / 3 = x :=
  field

theorem real_divide_self (a : Real) (aNonzero : a ≠ Real.zero) : a / a = Real.one :=
  field

theorem rational_half (x : Rational) (twoNonzero : (2 : Rational) ≠ Rational.zero)
        : x / 2 + x / 2 = x :=
  field(twoNonzero)

-- Field-clearing: `field` (and `ring` / `linear_combination`) seeing
-- through `/`.
--
-- `field` δ-unfolds `<carrier>.divide(a, b, _proof)` to `a · reciprocal(b)`
-- in both endpoints, so division participates in the ring normaliser as a
-- reciprocal atom. It then clears each reciprocal against the cancellation
-- `b · reciprocal(b) = 1`:
--
--   * over ℚ the reciprocal is the *total* `reciprocal_function`, whose
--     cancellation needs a `b ≠ 0` hypothesis — passed as `field(h)`;
--   * over ℝ the reciprocal is the *partial* `reciprocal(b, proof)`, which
--     carries its own nonzero proof on the `/`, so `field` (no arguments)
--     synthesises the cancellation itself.
--
-- The contraction clears a reciprocal when its base occurs as an honest
-- factor of the same monomial (`a / a`, `a · reciprocal(a)`). Clearing a
-- denominator against an *integer multiplicity* — the `2` of `ε/2 + ε/2`,
-- which the normaliser carries as a coefficient, not an atom — still needs
-- the explicit cofactor of `linear_combination` (see `real_half`); a
-- cofactor-synthesising `field` is the next step.

module Test.field_clear_test

import Logic.basics
import Equality.basics
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.ring
import Rational.reciprocal_function
import Rational.division
import Real.basics
import Real.addition
import Real.multiplication
import Real.ring
import Real.reciprocal
import Real.field
import Real.division

-- ℝ, partial reciprocal: `field` with no arguments, the nonzero proof
-- riding on the `/`.
theorem real_divide_self (a : Real) (aNonzero : a ≠ Real.zero) : a / a = Real.one :=
  field

theorem real_reciprocal_cancel (a : Real) (aNonzero : a ≠ Real.zero)
        : a * Real.reciprocal(a, aNonzero) = Real.one :=
  field

-- ℚ, total reciprocal: division still participates (it is unfolded first),
-- but cancelling needs the `a ≠ 0` hypothesis.
theorem rational_divide_self (a : Rational) (aNonzero : a ≠ Rational.zero)
        : a / a = Rational.one :=
  field(aNonzero)

-- ε/2 + ε/2 = ε: the `2` to be cleared is an integer coefficient, not an
-- atom factor, so contraction can't reach it — supply the cofactor `ε`
-- explicitly to `linear_combination`.
theorem real_half (epsilon : Real) : epsilon / 2 + epsilon / 2 = epsilon :=
  linear_combination(epsilon * Real.reciprocal_multiplies((2 : Real), Real.two_is_nonzero))

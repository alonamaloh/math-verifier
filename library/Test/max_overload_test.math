-- Test/max_overload_test.math
--
-- `max` is an ordinary identifier since the universe-level keyword was
-- renamed to MaxUniverse (2026-06-12, Alvaro's call): overloadable like
-- min/abs/exp.

module Test.max_overload_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.maximum

theorem Test.max_overload_resolves : max(2, 3) = 3 := {
  done
}

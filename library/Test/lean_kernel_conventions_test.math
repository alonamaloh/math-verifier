module Test.lean_kernel_conventions_test

-- Pins the op-table conventions aligned with Lean's kernel language
-- (PLAN_KERNEL_EXPORT Stage 1) at the definitional-equality level, so
-- any drift is caught here by `make tests` rather than by the external
-- replay check: floor_divide/modulo take (dividend, divisor) with
-- Lean's division-by-zero conventions, monus is Nat.sub exactly, and
-- power is Nat.pow's (base, exponent).

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.monus
import Natural.power
import Natural.floor_divide

-- Argument order is (dividend, divisor), matching Nat.div / Nat.mod.
theorem Test.floor_divide_argument_order : Natural.floor_divide(17, 5) = 3 :=
  done

theorem Test.modulo_argument_order : Natural.modulo(17, 5) = 2 :=
  done

-- Division by zero is zero; a remainder with divisor zero carries the
-- dividend — Lean's n / 0 = 0 and n % 0 = n.
theorem Test.floor_divide_by_zero : Natural.floor_divide(5, 0) = 0 :=
  done

theorem Test.modulo_by_zero : Natural.modulo(5, 0) = 5 :=
  done

-- The zero conventions also hold as lemmas over a variable dividend.
theorem Test.floor_divide_by_zero_general (n : Natural) : Natural.floor_divide(n, 0) = 0 :=
  done

theorem Test.modulo_by_zero_general (n : Natural) : Natural.modulo(n, 0) = n :=
  done

-- monus is Nat.sub exactly: (minuend, subtrahend), truncated at zero.
theorem Test.monus_truncates : Natural.monus(3, 7) = 0 :=
  done

theorem Test.monus_subtracts : Natural.monus(7, 3) = 4 :=
  done

-- power is Nat.pow's argument order: power(base, exponent).
theorem Test.power_argument_order : Natural.power(2, 10) = 1024 :=
  done

-- The negated relational operators are pure notation for `Not` of the
-- positive relation, desugared in the elaborator (dispatch.cpp): `a ≠ b` is
-- `Not(a = b)`, `a ≰ b` is `Not(a ≤ b)`, `a ∤ b` is `Not(a ∣ b)`, `a ∉ b` is
-- `Not(a ∈ b)`, `a ⊈ b` is `Not(a ⊆ b)`. Each `theorem` below proves the
-- negated form directly from a hypothesis of the spelled-out `Not(…)`, which
-- only typechecks if the two are the same proposition.

module Test.negated_relation_operators_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.divisibility
import Natural.order
import Set.basics

theorem ne_is_not_equal (a b : Natural) (h : Not(a = b)) : a ≠ b := h
theorem nle_is_not_le (a b : Natural) (h : Not(a ≤ b)) : a ≰ b := h
theorem ndvd_is_not_divides (a b : Natural) (h : Not(a ∣ b)) : a ∤ b := h
theorem notin_is_not_member
        (A : Type(0)) (x : A) (s : Set(A)) (h : Not(x ∈ s)) : x ∉ s := h
theorem nsubset_is_not_subset
        (A : Type(0)) (s t : Set(A)) (h : Not(s ⊆ t)) : s ⊈ t := h

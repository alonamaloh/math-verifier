-- Tests for the conjunction-introduction auto-prover strategy.
-- When the goal is `A ∧ B`, the auto-prover recursively proves
-- each conjunct (using the full dispatch — hypothesis match,
-- transitivity, etc.) and combines via `And.introduction`.

module Test.conjunction_intro_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order

-- (1) Trivial: both conjuncts are local hypotheses.
theorem conj_intro_both_hyps
        (P Q : Proposition) (hP : P) (hQ : Q) : P ∧ Q :=
  claim

-- (2) Mixed: one conjunct is a hypothesis, the other is an
-- equality closed by reflexivity (via the equality battery).
theorem conj_intro_with_reflexivity
        (n : Natural) (hP : 0 ≤ n) : 0 ≤ n ∧ n = n :=
  claim

-- (3) Both conjuncts close via the transitivity bridge — exercises
-- the full recursive dispatch.
theorem conj_intro_with_transitivity
        (a b c : Natural)
        (h1 : a ≤ b) (h2 : b ≤ c)
        (i1 : c ≤ a) (i2 : a ≤ b) : a ≤ c ∧ c ≤ b :=
  claim

-- (4) Nested conjunction: `A ∧ (B ∧ C)`. Outer recursion proves
-- A; inner recursion proves the (B ∧ C) sub-conjunction.
theorem conj_intro_nested
        (P Q R : Proposition) (hP : P) (hQ : Q) (hR : R)
        : P ∧ Q ∧ R :=
  claim

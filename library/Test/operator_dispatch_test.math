-- Operator-dispatch with δ-reduction fallback.
--
-- The `+` operator is registered for (Integer, Integer). An expression
-- like `Quotient.mk(IntegerRepresentative, IntegerEquivalent, …)`
-- has raw head type `Quotient` — not `Integer`. The operator-dispatch
-- δ-reduce fallback notices that `Integer`'s definition body is
-- exactly that `Quotient(…)`, so the call routes to `Integer.add`.

module Test.operator_dispatch_test

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.addition
import Set.basics

-- Direct: operands typed as Integer. No δ-reduction needed.
theorem direct_integer_add (a b : Integer) : a + b = Integer.add(a, b) :=
  reflexivity(Integer.add(a, b))

-- Operands built by `Integer.from_difference` are `Integer`-typed (the
-- canonical intro), so `+` dispatches to `Integer.add` directly. (Since
-- `Integer` is now opaque, the raw `Quotient.mk(IntegerRepresentative,
-- IntegerEquivalent, …)` constructor type is NOT recognised as `Integer`
-- for dispatch — opacity seals the representation, so consumers go through
-- `from_difference` rather than the bare quotient.)
theorem from_difference_add (a1 b1 a2 b2 : Natural)
        : Integer.from_difference(a1, b1) + Integer.from_difference(a2, b2)
          = Integer.add(
                Integer.from_difference(a1, b1),
                Integer.from_difference(a2, b2)) :=
  reflexivity(
      Integer.add(
          Integer.from_difference(a1, b1),
          Integer.from_difference(a2, b2)))

-- The `∈` operator dispatches to `Set.member {T} (x : T) (S : Set(T))`.
-- The implicit `{T}` is inferred from the LEFT operand's type by
-- unifying `Set.member`'s first explicit argument's type template
-- (which is BoundVariable(0) → T) against that type.
--
-- The `∈` dispatch infers the implicit `{T}` by unifying `Set.member`'s
-- first explicit argument's type template against the LEFT operand's type.
-- Here the operand is `Integer`-typed (now an opaque constant — it no
-- longer δ-reduces to its `Quotient(…)` body, so the old Application-
-- peeling heuristic that wrongly picked `IntegerEquivalent` as the carrier
-- can't even be reached). The unification-based fix recovers `T = Integer`.
theorem integer_in_set (x : Integer)
                        (S : Set(Integer))
                        (h : x ∈ S)
        : x ∈ S :=
  h

-- `⊆` (Set.subset) is the other implicit-arg shape:
--     Set.subset {T} (smaller larger : Set(T))
-- The first explicit arg's type template is `Set(BoundVariable(0))`,
-- so unifying it against `Set(Integer)` recovers `T = Integer`.
theorem set_subset_reflexive_integer (S : Set(Integer)) : S ⊆ S :=
  Set.subset.reflexive(S)

-- `if P then a else b` — value-level conditional sugar for
-- `decide P { | yes _ => a | no _ => b }`. Branches a definition on any
-- (classically decidable) proposition, with no reference to a constructor
-- pattern; one reasons about the result by re-deciding the same condition.

module Test.if_then_else_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.classical_decidable

-- A function defined by a condition (k = 0), not by the inductive split.
definition Test.collapseAtZero (x : Natural) : Natural :=
  if x = 0 then 5 else 2 * x

-- The condition can be anything decidable — it need not align with how
-- Natural was built.
definition Test.fixedPointPick (x : Natural) : Natural :=
  if x = x * x then 7 else 9

-- Reason about the value by re-deciding the same proposition.
theorem Test.collapseAtZero_zero : Test.collapseAtZero(0) = 5 :=
  if (0 : Natural) = 0
  then reflexivity(Natural, 5)
  else { claim (0 : Natural) = 0; done }

-- The `else` branch is reached when the condition fails.
theorem Test.collapseAtZero_two : Test.collapseAtZero(2) = 2 * 2 :=
  if (2 : Natural) = 0
  then { claim (2 : Natural) ≠ 0; done }
  else reflexivity(Natural, 2 * 2)

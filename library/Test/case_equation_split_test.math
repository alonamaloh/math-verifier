-- `cases X with <equalityHypothesisName> { … }` — convoy form.
--
-- Each arm gets an additional binder
--   `equalityHypothesisName : X = <constructor pattern>`
-- so the arm body can reason about what X must equal.
--
-- Replaces the manual function-then-apply idiom documented in
-- CLAUDE.md ("cases with hypothesis"), which is the single biggest
-- line-eater the library audit flagged.

module Test.cases_with_equality_hypothesis_test

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

-- (1) Simplest case: name is bound, but the body doesn't use the
-- equation. Confirms the desugar leaves a well-typed term even
-- when the equation is ignored.
theorem identitySplit (a : Natural) : Natural :=
  cases a with equationFromSplit {
    | zero => zero
    | successor(predecessor) => predecessor
  }

-- (2) Use the equation inside one branch. The branch where `a` is
-- `zero` ignores the equation; the successor branch could use it
-- (here we just check the type checks).
theorem successorOrSelf (a : Natural) : Natural :=
  cases a with equationFromSplit {
    | zero => zero
    | successor(predecessor) => successor(predecessor)
  }

-- (3) Use the equation to construct a more interesting term. The
-- body returns the equation itself in each branch — proving that
-- `equationFromSplit` is actually in scope with the refined type.
theorem returnTheEquation
        (a : Natural)
        : Exists(Natural, (witnessValue : Natural) ↦ a = witnessValue) :=
  cases a with equationFromSplit {
    | zero => Exists.introduce(zero, equationFromSplit)
    | successor(predecessor) =>
        Exists.introduce(successor(predecessor), equationFromSplit)
  }

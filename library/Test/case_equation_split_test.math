-- Equation-shaped case splits — the replacement for the retired
-- `cases X with <eq>` convoy form.
--
-- Value-level `cases X { | pattern => … }` keeps its plain spelling;
-- when a PROOF needs the split equation, the by-cases arm states it
-- (`case X = <constructor pattern> [for some x] [as <eq>]:`) and
-- exhaustiveness discharges through the type's coverage lemma.

module Test.case_equation_split_test

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

-- (1) Value-level split, no equation needed: plain cases.
theorem identitySplit (a : Natural) : Natural :=
  by induction on a with IH {
    case zero: zero
    case successor(predecessor): predecessor
  }

-- (2) The equation carries the arm's knowledge into a witness: each
-- arm exhibits what `a` must equal, citing its own stated equation.
theorem returnTheEquation
        (a : Natural)
        : Exists(Natural, (witnessValue : Natural) ↦ a = witnessValue) :=
  done by cases {
    case a = 0 as equationFromSplit:
        witness 0 with equationFromSplit
    case a = successor(predecessor) for some (predecessor : Natural)
           as equationFromSplit:
        witness successor(predecessor) with equationFromSplit
  }

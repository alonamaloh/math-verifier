-- Test/ne_symmetry_test.math
--
-- Locks the ≠-symmetry discharge bridge (pre-Sylvester consolidation T3):
-- a side condition `y ≠ x` must discharge silently from an in-scope
-- `x ≠ y`, with no citation — via the `automatic`
-- `Equality.not_equal_symmetric` in Equality/basics.math.

module Test.ne_symmetry_test

import Logic.basics
import Equality.basics
import Natural.basics

theorem Test.not_equal_flip_discharges (a b : ℕ) (distinct : a ≠ b) : b ≠ a :=
  done

module Test.exists_flattening_test

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order

-- A7 whole-body-by: exists-flattening. A ¬∃ goal cited against a
-- lemma over the witnesses intros the negation, eliminates the
-- existentials, and discharges the legs — the logical plumbing stays
-- off the page.

-- One existential, no conjunction.
theorem Test.flatten_one (f : Natural → Natural)
        (L : (x : Natural) → f(x) = 0 → False)
        : ¬ ∃ (x : Natural). f(x) = 0 :=
  by L

-- One existential, conjunction under it.
theorem Test.flatten_conjunction (f : Natural → Natural)
        (L : (x : Natural) → 1 ≤ x → f(x) = 0 → False)
        : ¬ ∃ (x : Natural). 1 ≤ x ∧ f(x) = 0 :=
  by L

-- Nested existentials.
theorem Test.flatten_nested (g : Natural → Natural → Natural)
        (L : (m n : Natural) → g(m, n) = 0 → False)
        : ¬ ∃ (m n : Natural). g(m, n) = 0 :=
  by L

-- Nested existentials with a nested conjunction — the
-- sqrt_two_irrational shape (conjunctions decompose into their legs
-- the same way the existentials eliminate).
theorem Test.flatten_nested_conjunction (g : Natural → Natural → Natural)
        (L : (m n : Natural) → 1 ≤ m → 1 ≤ n → g(m, n) = 0 → False)
        : ¬ ∃ (m n : Natural). 1 ≤ m ∧ 1 ≤ n ∧ g(m, n) = 0 :=
  by L

-- The existential may also sit INSIDE a conjunction.
theorem Test.flatten_exists_in_conjunction (g : Natural → Natural → Natural)
        (L : (m n : Natural) → 1 ≤ m → g(m, n) = 0 → False)
        : ¬ ∃ (m : Natural). 1 ≤ m ∧ (∃ (n : Natural). g(m, n) = 0) :=
  by L

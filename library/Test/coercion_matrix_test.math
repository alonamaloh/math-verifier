-- Auto-prover / diff-coercion CAPABILITY MATRIX.
--
-- The elaborator closes equality obligations at many syntactic positions,
-- routing each through one of two cores: `autoProveClaim` (goal-in-hand,
-- no supplied proof) or `coerceToExpectedTypeViaDiff` (a supplied term
-- whose type is off by a congruence). What closes WHERE has historically
-- been surprising ‚Äî different positions reach different subsets. This file
-- PINS the matrix: every cell that closes is a bare theorem here, so a
-- regression (a position silently losing a capability) breaks the build,
-- and every known GAP is documented inline with its cause.
--
-- OBLIGATIONS (rows):
--   O1 single   ‚Äî supplied `h : a = b`, goal `f(a) = f(b)` (one diff slot)
--   O2 flip     ‚Äî supplied `h : a = b`, goal `b = a` (symmetry orientation)
--   O3 combine  ‚Äî supplied `h : a = b`, goal `a + c = b + d` with `c = d`
--                 in context (cited fact in one slot, context in the other;
--                 WS5 bounded combining via tryCombineCitedWithContext)
--   O4 auto     ‚Äî NO supplied proof; context has the facts. Sub-cases:
--                 single / multi-position / stepping-stone (transitivity)
--
-- POSITIONS (columns):
--   supplied-proof positions (O1/O2/O3 apply):
--     P1 calc step `by h`            P3 claim `... by h`
--     P5 theorem body `:= h`         P6 function argument
--     P7 `cases` arm body            P9 `‚Ü¶` lambda body
--     P10 `let` value
--   auto positions (O4 applies):
--     P2 by-less calc step           P4 bare `claim`
--
-- P8 `decide` arm body: now UNIFORM with `cases`. `decide`'s arm bodies
-- run the same coerceToExpectedTypeViaDiff that `cases` arms do
-- (elaborator.cpp elaborateArms), so a `decide` arm closes exactly what a
-- `cases` arm closes ‚Äî `decide` being constructor-`cases` on
-- `Logic.Decidable(P)`. (Until 2026-06 this was the one gap: the bespoke
-- decide path skipped arm coercion. Cells P8_* below pin the fix.)
--
-- STAGE 2 AUDIT RESULT: every position with a CONCRETE expected type
-- routes through the single coercion entry coerceToExpectedTypeViaDiff ‚Äî
-- theorem body, function arg, cases arm, decide arm, lambda body, let
-- value, suppose body, obtain body (all pinned below / above). The only
-- residual non-uniformity is an anonymous tuple / constructor component
-- whose type is an INFERRED PARAMETER: the coerce call fires but against
-- an unsolved metavariable, so an off-by-congruence component is not
-- bridged. That is an inference-ordering limitation, not a routing gap;
-- pinned as corpus tuple_component_inferred_param_no_coerce.

module Test.coercion_matrix_test

import Natural.basics
import Natural.classical_decidable
import Natural.peano
import Natural.arithmetic
import Equality.basics
import Logic.basics
import Logic.excluded_middle
import Logic.exists

-- ‚îÄ‚îÄ O1 single-position congruence (supplied h : a = b) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
theorem Test.matrix_O1_P5_body (a b : Natural) (h : a = b)
        : successor(a) = successor(b) := h
theorem Test.matrix_O1_P1_calc (a b : Natural) (h : a = b)
        : successor(a) = successor(b) := calc successor(a) = successor(b) by h
theorem Test.matrix_O1_P3_claim (a b : Natural) (h : a = b) : True := {
  claim step : successor(a) = successor(b) by h;
  True.trivial
}
theorem Test.matrix_O1_P6_arg (a b : Natural) (h : a = b)
        (consume : successor(a) = successor(b) ‚Üí Natural) : Natural := consume(h)
theorem Test.matrix_O1_P7_cases (a b : Natural) (h : a = b) (n : Natural)
        : successor(a) = successor(b) :=
  cases n { | zero => h | successor(m) => h }
theorem Test.matrix_O1_P9_lambda (a b : Natural) (h : a = b)
        : Natural ‚Üí (successor(a) = successor(b)) := (n : Natural) ‚Ü¶ h
theorem Test.matrix_O1_P10_let (a b : Natural) (h : a = b) : True := {
  let step : successor(a) = successor(b) := h;
  True.trivial
}

-- ‚îÄ‚îÄ O2 symmetry flip (supplied h : a = b, goal b = a) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
theorem Test.matrix_O2_P5_body (a b : Natural) (h : a = b) : b = a := h
theorem Test.matrix_O2_P1_calc (a b : Natural) (h : a = b) : b = a :=
  calc b = a by h
theorem Test.matrix_O2_P7_cases (a b : Natural) (h : a = b) (n : Natural)
        : b = a := cases n { | zero => h | successor(m) => h }

-- ‚îÄ‚îÄ O3 bounded combine (cited h : a = b, context ctx : c = d) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
theorem Test.matrix_O3_P5_body (a b c d : Natural) (h : a = b) (ctx : c = d)
        : a + c = b + d := h
theorem Test.matrix_O3_P1_calc (a b c d : Natural) (h : a = b) (ctx : c = d)
        : a + c = b + d := calc a + c = b + d by h
theorem Test.matrix_O3_P6_arg (a b c d : Natural) (h : a = b) (ctx : c = d)
        (consume : (a + c = b + d) ‚Üí Natural) : Natural := consume(h)
theorem Test.matrix_O3_P9_lambda (a b c d : Natural) (h : a = b) (ctx : c = d)
        : Natural ‚Üí (a + c = b + d) := (n : Natural) ‚Ü¶ h
theorem Test.matrix_O3_P7_cases (a b c d : Natural) (h : a = b) (ctx : c = d)
        (n : Natural) : a + c = b + d :=
  cases n { | zero => h | successor(m) => h }

-- ‚îÄ‚îÄ O4 auto from context, NO supplied proof ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
-- single-position (by-less calc P2 / bare claim P4)
theorem Test.matrix_O4single_P2_calc (a b : Natural) (h : a = b)
        : successor(a) = successor(b) := calc successor(a) = successor(b)
theorem Test.matrix_O4single_P4_claim (a b : Natural) (h : a = b) : True := {
  claim step : successor(a) = successor(b);
  True.trivial
}
-- multi-position (proveApplicationDiff)
theorem Test.matrix_O4multi_P2_calc (a b c d : Natural) (h : a = b) (ctx : c = d)
        : a + c = b + d := calc a + c = b + d
theorem Test.matrix_O4multi_P4_claim
        (a b c d : Natural) (h : a = b) (ctx : c = d) : True := {
  claim step : a + c = b + d;
  True.trivial
}
-- stepping-stone (transitivity BFS, no cited fact)
theorem Test.matrix_O4step_P2_calc (a b c : Natural) (h : a = b) (ctx : b = c)
        : a = c := calc a = c
theorem Test.matrix_O4step_P4_claim (a b c : Natural) (h : a = b) (ctx : b = c)
        : True := {
  claim step : a = c;
  True.trivial
}

-- ‚îÄ‚îÄ P8 `decide` arm ‚Äî now coerces like a `cases` arm (gap closed).
-- O1 single-position congruence on a bare cited fact:
theorem Test.matrix_O1_P8_decide (a b : Natural) (h : a = b)
        : successor(a) = successor(b) :=
  decide a = b { | yes _ => h | no _ => h }
-- O3 bounded combine (cited h : a = b, context ctx : c = d):
theorem Test.matrix_O3_P8_decide (a b c d : Natural) (h : a = b) (ctx : c = d)
        : a + c = b + d :=
  decide a = b { | yes _ => h | no _ => h }

-- ‚îÄ‚îÄ O1 at the remaining structured-proof body positions (Stage 2 audit) ‚îÄ‚îÄ
-- P11 suppose body, P12 obtain body ‚Äî both coerce uniformly.
theorem Test.matrix_O1_P11_suppose (a b : Natural)
        : (a = b) ‚Üí (successor(a) = successor(b)) := {
  suppose a = b as h;
  h
}
theorem Test.matrix_O1_P12_obtain (a b : Natural) (ex : ‚àÉ (k : Natural). a = b)
        : successor(a) = successor(b) := {
  obtain ‚ü®k, h‚ü© from ex;
  h
}

-- ‚îÄ‚îÄ Anonymous tuple / constructor component (Stage 2 audit). ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
-- A component coerces when its type is CONCRETE ‚Äî here the `And` parameter
-- is pinned by the exact `h`, so the (trivially exact) component goes
-- through. The diff-coercion of an OFF-by-congruence component does NOT
-- fire when the component's type is an INFERRED parameter (e.g.
-- `‚ü®h, ‚Ä¶‚ü© : successor(a)=successor(b) ‚àß True` from `h : a = b`): the
-- arg coercion runs (elaborator.cpp ~4824) but against an unsolved
-- parameter metavariable, so it is a no-op. That is an inference-ordering
-- limitation (the expected result type isn't unified into the
-- constructor's parameters before its components are elaborated), NOT a
-- missing coercion-routing call ‚Äî distinct from the diff-walker work.
-- Pinned negative: corpus case tuple_component_inferred_param_no_coerce.
theorem Test.matrix_tuple_concrete_component (a b : Natural) (h : a = b)
        : a = b ‚àß True :=
  ‚ü®h, True.trivial‚ü©

-- `construction Name(args) : T := body` is a transparent definition that
-- is additionally registered as a canonical quotient-introduction form.
-- It elaborates exactly like a definition; the value is that proofs (and,
-- via the registry, by_representatives) read in the named form.

module Test.construction_test

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Integer.basics
import Rational.basics

-- Use the construction defined in Rational.basics.
theorem fraction_is_mk (n : Integer) (d : Natural)
        : Rational.fraction(n, d)
          = Quotient.mk(RationalRepresentative.make(n, d)) :=
  -- Transparent: fraction δ-reduces to the underlying mk, so this is
  -- closed by reflexivity.
  reflexivity(Rational, Rational.fraction(n, d))

-- Rational.zero, now defined via fraction, is still def-equal to the raw
-- representative class (two δ-steps: zero → fraction → mk).
theorem zero_is_rep
        : Rational.zero
          = Quotient.mk(RationalRepresentative.make(Integer.zero, zero)) :=
  reflexivity(Rational, Rational.zero)

-- A local construction over the same quotient: the keyword is general,
-- not special-cased to Rational.fraction.
construction Rational.from_integer_fraction (n : Integer) : Rational :=
  Rational.fraction(n, zero)

theorem from_integer_fraction_unfolds (n : Integer)
        : Rational.from_integer_fraction(n)
          = Quotient.mk(RationalRepresentative.make(n, zero)) :=
  reflexivity(Rational, Rational.from_integer_fraction(n))

-- Tests for the disjunction-introduction auto-prover strategy.
-- When the goal is `Or(A, B)`, the auto-prover tries to prove A
-- (via the full dispatch); if that fails, it tries B. The wrapped
-- proof uses `Or.introduceLeft` or `Or.introduceRight` accordingly.

module Test.disjunction_intro_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order

-- (1) Left branch via direct hypothesis: A is in scope, picked
-- first (left-biased).
theorem disj_intro_left_hyp
        (P Q : Proposition) (hP : P) : Or(P, Q) :=
  claim

-- (2) Right branch via hypothesis: A isn't provable (no hyp for P),
-- so the strategy falls through to B.
theorem disj_intro_right_hyp
        (P Q : Proposition) (hQ : Q) : Or(P, Q) :=
  claim

-- (3) Left branch via reflexivity (the equality battery proves
-- `n = n` for the left conjunct).
theorem disj_intro_left_via_eq_battery
        (n : Natural) (other : Proposition) : Or(n = n, other) :=
  claim

-- (4) Right branch via transitivity bridge: left is unprovable,
-- right closes through the BFS chain.
theorem disj_intro_right_via_transitivity
        (other : Proposition) (a b c : Natural)
        (h1 : a ≤ b) (h2 : b ≤ c) : Or(other, a ≤ c) :=
  claim

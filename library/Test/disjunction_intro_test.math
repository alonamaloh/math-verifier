-- Tests for the disjunction-introduction auto-prover strategy.
-- When the goal is `A ∨ B`, the auto-prover tries to prove A
-- (via the full dispatch); if that fails, it tries B. The wrapped
-- proof uses `Or.introduceLeft` or `Or.introduceRight` accordingly.

module Test.disjunction_intro_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order

-- (1) Left branch via direct hypothesis: A is in scope, picked
-- first (left-biased).
theorem disj_intro_left_hyp
        (P Q : Proposition) (hP : P) : P ∨ Q :=
  claim

-- (2) Right branch via hypothesis: A isn't provable (no hyp for P),
-- so the strategy falls through to B.
theorem disj_intro_right_hyp
        (P Q : Proposition) (hQ : Q) : P ∨ Q :=
  claim

-- (3) Left branch via reflexivity (the equality battery proves
-- `n = n` for the left conjunct).
theorem disj_intro_left_via_eq_battery
        (n : Natural) (other : Proposition) : n = n ∨ other :=
  claim

-- (4) Right branch via transitivity bridge: left is unprovable,
-- right closes through the BFS chain.
theorem disj_intro_right_via_transitivity
        (other : Proposition) (a b c : Natural)
        (h1 : a ≤ b) (h2 : b ≤ c) : other ∨ a ≤ c :=
  claim

-- ----------------------------------------------------------------------
-- Disjunction-injection coercion. Distinct from the auto-prover above:
-- here the proof of one disjunct is given EXPLICITLY, and the elaborator
-- recognizes the `A ∨ B` goal and wraps the matching Or.introduce*
-- (a targeted, search-free coercion — no need to name Or.introduceLeft/
-- Right). This is what lets a `cases` arm just state one side.

-- (5) Explicit proof of the left disjunct injects Or.introduceLeft.
theorem disj_inject_left_explicit
        (P Q : Proposition) (hP : P) : P ∨ Q :=
  hP

-- (6) Explicit proof of the right disjunct injects Or.introduceRight —
-- the case the auto-prover would have to search for, given directly.
theorem disj_inject_right_explicit
        (P Q : Proposition) (hQ : Q) : P ∨ Q :=
  hQ

-- (7) The injected proof can itself be a derivation (here a calc), and
-- the disjunct is matched up to definitional equality.
theorem disj_inject_calc
        (a b c : Natural) (other : Proposition)
        (h1 : a = b) (h2 : b = c) : other ∨ a = c :=
  calc a = b = c

-- ----------------------------------------------------------------------
-- `claim by cases` — propositional case-split (disjunction ELIMINATION),
-- including n-ary disjunctions.

-- (8) Two-way: each arm states a proof of the goal under its disjunct.
theorem by_cases_two_way
        (A B G : Proposition) (dichotomy : A ∨ B)
        (fromA : A → G) (fromB : B → G) : G :=
  done by cases {
    case A as a: fromA(a)
    case B as b: fromB(b)
  }

-- (9) n-ary: a three-way disjunction `A ∨ B ∨ C` is eliminated by three
-- arms (right-nested Or, folded into nested Or.eliminate).
theorem by_cases_three_way
        (A B C G : Proposition) (trichotomy : A ∨ B ∨ C)
        (fromA : A → G) (fromB : B → G) (fromC : C → G) : G :=
  done by cases {
    case A as a: fromA(a)
    case B as b: fromB(b)
    case C as c: fromC(c)
  }

-- (10) Four-way, to exercise the fold past one level of nesting.
theorem by_cases_four_way
        (A B C D G : Proposition) (quadchotomy : A ∨ B ∨ C ∨ D)
        (fromA : A → G) (fromB : B → G) (fromC : C → G) (fromD : D → G) : G :=
  done by cases {
    case A as a: fromA(a)
    case B as b: fromB(b)
    case C as c: fromC(c)
    case D as d: fromD(d)
  }

-- (11) Destructuring `as ⟨pattern⟩` in a `by cases` arm: the disjunct is an
-- existential, taken apart in place (witness named, proof bound anonymously).
theorem by_cases_destructure_as
        (n : Natural) (G : Proposition)
        (dichotomy : (n = 0) ∨ (∃ (m : Natural). n = 1 + m))
        (whenZero : n = 0 → G) (whenSucc : ∀ (m : Natural). n = 1 + m → G) : G :=
  done by cases {
    case n = 0 as isZero:                          whenZero(isZero)
    case (∃ (m : Natural). n = 1 + m) as ⟨m, eq⟩:  whenSucc(m, eq)
  }

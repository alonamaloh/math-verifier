module Test.cring_negate_test
import Logic.basics
import Equality.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra

-- unary minus now resolves on a CommutativeRing carrier
theorem cring_negate_left (c : CommutativeRing) (x : CommutativeRing.carrier(c))
        : -x + x = CommutativeRing.zero(c) :=
  CommutativeRing.add_negate_left(c, x)

-- and on a plain Ring carrier
theorem ring_negate_right (r : Ring) (x : Ring.carrier(r))
        : x + -x = Ring.zero(r) :=
  Ring.add_negate_right(r, x)

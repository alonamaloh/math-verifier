-- Regression probes for implicit-structure-argument recovery from
-- projection-typed operands — the mechanism behind the operators on
-- parametrized operations (Track A1). IntegerMod recovers {modulus} from
-- IntegerMod(m) (a direct constructor argument); the harder case is the
-- *projection* one — recovering {r : Ring} from an operand of type
-- Ring.carrier(r), and recovering the CommutativeRing bundle through a
-- definition-alias carrier. These now hold for the real library
-- operators (Ring.add / RingModulo.add / …), so the probes just pin them.
module Test.operator_parametrized_poc

import Logic.basics
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import RingModulo.basics
import RingModulo.operations

-- (1) Direct call: {r} is solved from x : Ring.carrier(r).
theorem Test.recover_direct (s : Ring) (x y : Ring.carrier(s))
        : Ring.add(x, y) = Ring.add(s, x, y) :=
  reflexivity(Ring.carrier(s), Ring.add(s, x, y))

-- (2) Operator dispatch: `x + y` finds the dispatch fn (head
-- `Ring.carrier`) and recovers {r}.
theorem Test.recover_operator (s : Ring) (x y : Ring.carrier(s))
        : x + y = Ring.add(s, x, y) :=
  reflexivity(Ring.carrier(s), Ring.add(s, x, y))

-- (3) Two implicits, the second dependent: recover {c : CommutativeRing}
-- AND {m : CommutativeRing.carrier(c)} from x : RingModulo(c, m).
definition Test.rmAdd {c : CommutativeRing} {m : CommutativeRing.carrier(c)}
        (x y : RingModulo(c, m)) : RingModulo(c, m) :=
  RingModulo.add(x, y)

theorem Test.recover_two (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        (x y : RingModulo(c, m))
        : Test.rmAdd(x, y) = RingModulo.add(x, y) :=
  reflexivity(RingModulo(c, m), RingModulo.add(x, y))

-- (4) The `-` operator dispatches to RingModulo.subtract, recovering
-- both implicits from the operands; subtract δ-reduces to add ∘ negate.
theorem Test.recover_subtract (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        (x y : RingModulo(c, m))
        : x - y = RingModulo.add(x, RingModulo.negate(y)) :=
  reflexivity(RingModulo(c, m), RingModulo.add(x, RingModulo.negate(y)))

-- (5) The `*` operator dispatches to RingModulo.multiply. This is the
-- payoff of indexing by CommutativeRing: the commutativity proof
-- multiply needs is carried by `c`, which is recovered from the operand
-- type — no commutativity argument is threaded at the call site.
theorem Test.recover_multiply (c : CommutativeRing) (m : CommutativeRing.carrier(c))
        (x y : RingModulo(c, m))
        : x * y = RingModulo.multiply(x, y) :=
  reflexivity(RingModulo(c, m), RingModulo.multiply(x, y))

-- Feature test: sign-judgment rules whose premises live as ∧-legs of a
-- bundled hypothesis discharge without projection plumbing — the sign
-- recursion's premise scan falls back to conjunction legs exactly like
-- the monotonicity recursion's (the `choose δ such that δ > 0 ∧ ∀y. …`
-- bundles of the ε-δ files supply the minimum rule's positivity
-- premises directly). Also pins the tactic order: the sign recursion
-- runs before the transitivity bridge, so 0-anchored bookkeeping in a
-- fat context closes cheaply instead of burning the speculative budget
-- on a failed chain search.
module Test.sign_conjunction_leg_test

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Real.interface

theorem Test.minimum_positive_from_conjunction_legs
        (a b : Real)
        (aBundle : a > 0 ∧ a < 1) (bBundle : b > 0 ∧ b < 1)
        : Real.minimum(a, b) > 0 := {
  done
}

theorem Test.minimum_positive_from_chosen_bundle
        (f : Real → Real)
        (fBound : ∃ (d : Real). d > 0 ∧ ∀ (y : Real). f(y) < d)
        (c : Real) (cPositive : c > 0)
        : True := {
  choose d such that d > 0 ∧ ∀ (y : Real). f(y) < d from fBound;
  Real.minimum(c, d) > 0;
  done
}

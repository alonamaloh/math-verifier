-- `Equality.transitivity(P, rewrite(L))` — the second argument is
-- `rewrite(L)`, which would normally need an expected type from
-- context. desugarEqualityTransitivity now synthesizes one
-- (`Equality(carrier, B, B)`) so rewrite can fire.

module Test.transitivity_rewrite_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

theorem transitivity_with_inner_rewrite
        (a b c d : Natural)
        (firstEquality : a = (b + c) + d)
        : a = (c + b) + d :=
  Equality.transitivity(
      firstEquality,
      rewrite(Natural.add_commutative(b, c)))

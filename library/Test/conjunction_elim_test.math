-- Tests for two reasoning conveniences:
--   (1) conjunction-elimination for context facts — a hypothesis `A ∧ B`
--       makes A and B available as facts on their own (no manual projection);
--   (2) `absurd(<proposition>)` — state the contradictory fact directly; it is
--       proved from context (e.g. a conjunction leg) and then contradicted.

module Test.conjunction_elim_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano

-- (1) A context conjunction's left leg closes the goal by itself.
theorem conjunction_left_available (a b : Natural)
        (both : a = b ∧ b = a) : a = b := {
  claim a = b
}

-- (1) … and the right leg.
theorem conjunction_right_available (a b : Natural)
        (both : a = b ∧ b = a) : b = a := {
  claim b = a
}

-- (2) `absurd(<proposition>)` proves the stated fact from the conjunction
-- leg and recognises it as a contradiction (zero = successor).
theorem absurd_proposition_from_conjunction (k : Natural)
        (both : (0 = successor(k)) ∧ (k = k)) : False := {
  absurd(0 = successor(k))
}

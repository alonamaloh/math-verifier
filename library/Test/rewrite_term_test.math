-- Term-level `rewrite(eqProof, term)`. Replaces the 6-arg
-- `Equality.transport_proposition(T, motive, x, y, eq, term)` call
-- with a 2-arg form that recovers T, x, y from `eqProof`'s type and
-- the motive from `term`'s inferred type by locating the unique
-- structural occurrence of x.

module Test.rewrite_term_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order

-- (1) Forward rewrite: given `a = b` and `0 ≤ a`, conclude `0 ≤ b`.
theorem RewriteForward
        (a b : Natural)
        (equality : a = b)
        (smallA : zero ≤ a)
        : zero ≤ b :=
  rewrite(equality, smallA)

-- (2) Same shape, but the rewrite happens deeper inside an
-- expression (the right side of a `≤`).
theorem RewriteOnRightOfRelation
        (a b : Natural)
        (equality : a = b)
        (oneLeAddOne : 1 ≤ Natural.add(a, 1))
        : 1 ≤ Natural.add(b, 1) :=
  rewrite(equality, oneLeAddOne)

-- (3) Verbose form for comparison — equivalent to (1).
theorem RewriteVerbose
        (a b : Natural)
        (equality : a = b)
        (smallA : zero ≤ a)
        : zero ≤ b :=
  Equality.transport_proposition(
      function (rest : Natural) => zero ≤ rest,
      a, b, equality, smallA)

-- (4) Internal β-redex: the term's inferred type contains
-- `(λn. n ≤ n)(a)` — a redex that is NOT at the head (the head
-- is `And`), so head-only WHNF leaves it intact. The LHS of the
-- rewrite (`a ≤ a`) appears only after the inner redex is
-- β-reduced. Regression for the deep-β-reduce combo in the
-- rewrite cascade — the four pre-existing combos all return zero
-- structural matches; the deep-β pass finds the unique match.
theorem RewriteThroughInternalBeta
        (a b : Natural)
        (equalityOfRelations : (a ≤ a) = (b ≤ b))
        (h : And(True, (function (n : Natural) => n ≤ n)(a)))
        : And(True, (function (n : Natural) => n ≤ n)(b)) :=
  rewrite(equalityOfRelations, h)

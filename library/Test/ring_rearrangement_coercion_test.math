-- F2(a) (PLAN_ERGONOMICS.md): argument/body coercion across a ring identity
-- that is provable but not definitional, generalizing strategy (e) beyond
-- Natural. A term proving an ORDER relation (`≤` / `<`) over any ring carrier
-- (ℤ/ℚ/ℝ) drops into a slot expecting the same relation spelled with a
-- commutative-ring rearrangement (`a·b` vs `b·a`, `a+b` vs `b+a`,
-- associativity) — the bridging equality is synthesized by `ring`.
module Test.ring_rearrangement_coercion_test

import Natural.order
import Integer.order
import Rational.order
import Real.order

-- Integer, `≤`, multiplication commuted.
theorem Test.integer_multiply_commute_le (a b c : Integer)
        (h : b * a ≤ c) : a * b ≤ c := h

-- Rational, `<`, multiplication commuted.
theorem Test.rational_multiply_commute_lt (a b c : Rational)
        (h : b * a < c) : a * b < c := h

-- Real, `≤`, addition commuted.
theorem Test.real_add_commute_le (a b c : Real)
        (h : b + a ≤ c) : a + b ≤ c := h

-- Integer, `≤`, addition re-associated.
theorem Test.integer_add_associate_le (a b c d : Integer)
        (h : (a + b) + c ≤ d) : a + (b + c) ≤ d := h

-- Regression: the original Natural additive rearrangement (`1 + n` vs
-- `n + 1`) in a `≤`, which strategy (e) already handled, still bridges.
theorem Test.natural_additive_le (n d : Natural)
        (h : 1 + n ≤ d) : n + 1 ≤ d := h

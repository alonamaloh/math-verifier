-- Sanity-test: use ring/field on Real to see if the error messages
-- guide an LLM through fixes.

module Test.llm_dogfood_test

import Real.basics
import Real.addition
import Real.multiplication
import Real.negation
import Real.ring
import Real.algebra

-- (1) Difference of squares (cross-pair cancellation).
theorem Real.dogfood_difference_of_squares (a b : Real)
        : (a + b) * (a - b) = a * a - b * b := ring

-- (2) Square of sum — the cross terms collect into the coefficient 2.
theorem Real.dogfood_square_of_sum (a b : Real)
        : (a + b) * (a + b) = a * a + (2 : Real) * (a * b) + b * b := ring

-- (3) Triple product expansion.
theorem Real.expand_three (a b c : Real)
        : (a + b) * c = a * c + b * c := ring

-- (4) Negation through product (the derived lemma
-- Real.multiply_negate_left is found through the abstract Ring path).
theorem Real.dogfood_negate_through_product (x y : Real)
        : (-x) * y = -(x * y) := ring

-- Statement-form strong induction (A4): `by_strong_induction on m with
-- hypothesis ih;` — no braces; the REST of the enclosing block is the
-- induction body, exactly like a suppose/take wrapper. The braced
-- expression form still works (regression below).

module Test.strong_induction_statement_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.strong_recursion

-- Flat statement form: everything after the `;` is the body.
theorem Test.zero_le_flat (m : Natural) : 0 ≤ m := {
  by_strong_induction on m with hypothesis anyBelow;
  done by Natural.zero_least
}

-- Braced form still parses (regression).
theorem Test.zero_le_braced (m : Natural) : 0 ≤ m := {
  by_strong_induction on m with hypothesis anyBelow {
    done by Natural.zero_least
  }
}

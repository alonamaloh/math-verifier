module Test.bare_prop_test

import Logic.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.arithmetic

-- (1) Argument position: `f : (N ≤ m) → False` called with the
-- bare proposition `N ≤ m` looks up the hypothesis.
theorem bare_prop_in_arg
        (N m : Natural) (NleqM : N ≤ m)
        (f : N ≤ m → False) : False :=
  f(N ≤ m)

-- (2) Theorem body: return value is the proposition itself.
theorem bare_prop_in_body
        (N m : Natural) (NleqM : N ≤ m) : N ≤ m :=
  N ≤ m

-- (N) A bare proposition stating ONE DISJUNCT of an `Or` goal: the
-- disjunct is auto-proved and the matching `Or.introduce*` is injected.
-- (A non-trivial disjunct can instead be derived with a `calc`, handled
-- by the disjunction-injection coercion.)
theorem bare_prop_disjunct_left
        (P Q : Proposition) (hP : P) : P ∨ Q :=
  P

theorem bare_prop_disjunct_right
        (P Q : Proposition) (hQ : Q) : P ∨ Q :=
  Q

-- The stated disjunct is auto-proved, not merely looked up (here n = n
-- by reflexivity).
theorem bare_prop_disjunct_autoproved
        (n : Natural) (other : Proposition) : n = n ∨ other :=
  n = n

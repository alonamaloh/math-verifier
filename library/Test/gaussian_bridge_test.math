-- Regression: the norm_cast bridge now covers GaussianInteger, via the
-- registered coercion ℤ ↪ ℤ[i] (GaussianInteger.embedInteger) and its
-- ground equalities embedInteger.zero_preserves / one_preserves. A hypothesis in numeral
-- form (`z = (0 : GaussianInteger)`) discharges a goal spelled with the ring
-- quotient's own zero, exactly as the ComplexNumber case does.
module Test.gaussian_bridge_test

import Logic.basics
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.ring
import Polynomial.instances
import RingModulo.basics
import RingModulo.operations
import RingModulo.ring
import RingModulo.instances
import GaussianInteger.basics
import GaussianInteger.reconstruction

theorem Test.gaussian_zero_bridge (z : GaussianInteger)
        (isZero : z = (0 : GaussianInteger))
        : z = RingModulo.zero(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial) :=
  done by isZero

theorem Test.gaussian_one_bridge (z : GaussianInteger)
        (isOne : z = (1 : GaussianInteger))
        : z = RingModulo.one(Integer.polynomial_commutative_ring, GaussianInteger.definingPolynomial) :=
  done by isOne

module Test.no_double_square_idealized

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.add_order
import Natural.compare
import Natural.cancellation
import Natural.multiply_order
import Natural.multiply_bounds
import Natural.divisibility
import Natural.prime
import Natural.prime_two
import Natural.prime_divides_product
import Natural.strong_recursion
import Natural.sqrt_two_irrational

-- The A-part acceptance test: the idealized no_double_square (plan
-- reference target), adapted only where owner decisions
-- diverge from the plan text (done-idiom instead of the contradiction
-- terminal) and where statement-form induction (A3-A5) is not yet
-- built (the by_strong_induction braces stay).
theorem Test.no_double_square (m : Natural)
        : ∀ (n : Natural). 1 ≤ m → 1 ≤ n → m * m = 2 * (n * n) → False :=
  by_strong_induction on m with subject, no_smaller_solution {
    take n : Natural;
    suppose 1 ≤ subject as subjectPositive;
    suppose 1 ≤ n as nPositive;
    suppose subject * subject = 2 * (n * n) as equation;

    2 ∣ (subject * subject);
    2 ∣ subject by Natural.two_divides_root as twoDividesSubject;
    choose k such that subject = 2 * k as subjectEquation from twoDividesSubject;

    suppose k = 0 for contradiction {
      then 1 ≤ subject = 2 * 0 = 0;
      done
    };
    hence 1 ≤ k by Natural.one_le_of_nonzero;

    from equation: (2 * k) * (2 * k) = 2 * (n * n);
    1 ≤ 2;
    then 2 * (2 * (k * k)) = (2 * k) * (2 * k) = 2 * (n * n);
    hence 2 * (k * k) = n * n;
    hence n * n = 2 * (k * k);

    suppose subject ≤ n for contradiction {
      subject * subject ≤ subject * n;
      n * subject ≤ n * n;
      then subject * subject ≤ subject * n = n * subject ≤ n * n;
      1 ≤ n * n;
      successor(n * n) ≤ 2 * (n * n) by Natural.successor_less_or_equal_multiply;
      claim 2 * (n * n) ≤ n * n by substituting equation;
      successor(n * n) ≤ n * n;
      done
    };

    hence n < subject by Natural.lt_of_not_le;
    done by no_smaller_solution
  }

-- Test/recalling_test.math
--
-- `by <lemma> recalling <fact>, …` brings extra named facts into the
-- side-condition discharge scope of a cited lemma, as bounded,
-- context-local hypotheses (no global library search). Lets a lemma be
-- cited by name even when one of its premises is not derivable from the
-- ambient context and is not pinned by the goal.

module Test.recalling_test

import Equality.basics
import Natural.basics
import Natural.order

-- A lemma with a side-condition (`0 ≤ n`) that its conclusion (`n = n`)
-- does not mention — so the obligation cannot be recovered from the goal.
theorem Test.reflexive_when_bounded (n : Natural) (atLeastZero : 0 ≤ n)
        : n = n := reflexivity(n)

-- Bare citation: the conclusion `k = k` pins `n := k`, and the leftover
-- `0 ≤ k` premise is discharged from the `recalling`-bound fact
-- `Natural.zero_least(k)`. No explicit argument list.
theorem Test.recalling_discharges (k : Natural) : k = k := {
  k = k
      by Test.reflexive_when_bounded recalling Natural.zero_least(k) as result;
  result
}

-- Several recalled facts, comma-separated; the discharge picks the one
-- whose type matches the premise.
theorem Test.recalling_multiple (k : Natural) : k = k := {
  k = k
      by Test.reflexive_when_bounded
          recalling reflexivity(k), Natural.zero_least(k) as result;
  result
}

-- Match-and-unify: `subject` appears ONLY in the premise `0 ≤ subject`,
-- never in the conclusion `0 = 0`, so the goal cannot pin it. Unifying
-- the premise against the recalled `Natural.zero_least(k) : 0 ≤ k` solves
-- `subject := k` as a side effect, then discharges the premise with it.
theorem Test.subject_from_bound (subject : Natural) (atLeast : 0 ≤ subject)
        : 0 = 0 := reflexivity(0)

theorem Test.recalling_recovers_value (k : Natural) : 0 = 0 := {
  0 = 0
      by Test.subject_from_bound recalling Natural.zero_least(k) as result;
  result
}

-- Proving a goal headed by a DEFINITION that unfolds to `A ∧ B ∧ C` by
-- proving each leg: `tryConjunctionIntro` WHNFs the goal so it sees the
-- `And` under the definition name (here `Natural.is_gcd`). Mirror of the
-- decomposition side, which already WHNFs a context conjunction.

module Test.conjunction_intro_through_definition_test

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.divisibility
import Natural.gcd

-- All three legs in context as plain hypotheses; `done` assembles the folded
-- `is_gcd` from them (no `⟨…⟩`, no library lemma to cite).
theorem assemble_is_gcd_from_legs (g a b : Natural)
        (dividesFirst : g ∣ b) (dividesSecond : g ∣ a)
        (universal : ∀ (d : Natural). d ∣ b → d ∣ a → d ∣ g)
        : Natural.is_gcd(g, b, a) := { done }

-- A `set`-bound alias must stay substituted through statement-intro forms
-- that introduce their own scope — `choose`, `by cases`, and the like.
-- Regression 1: `substituteSurfaceName` (the engine behind `set`) had no
-- case for `SurfaceChoose`/`SurfaceDecide`, so it stopped at the first such
-- node and left the alias unsubstituted past it (an "unknown identifier"
-- error); worse, descending into those bodies could reach an untyped
-- binding's null type and segfault. Regression 2: its structured-claim arm
-- clone rebuilt arms field-by-field and dropped `isOtherwise`, so an
-- `otherwise:` arm under a `set` became a stated arm with a null
-- proposition (a crash downstream). All fixed; these pin the behaviour.

module Test.set_through_statements_test

import axioms
import Natural.classical_decidable
import Logic.basics
import Logic.exists
import Natural.basics
import Natural.order

-- The alias is used AFTER a `choose`, which binds its own variable.
theorem Test.set_survives_choose
        (Q : Proposition) (hQ : Q)
        (existsNat : ∃ (n : Natural). 1 ≤ n) : Q := {
  set goalAlias := Q;
  choose witnessNat such that 1 ≤ witnessNat from existsNat;
  goalAlias;
  done
}

-- The alias is used inside both arms of a propositional case split.
theorem Test.set_survives_by_cases
        (P Q : Proposition) (hQ : Q) : Q := {
  set goalAlias := Q;
  done by cases {
    case P: { goalAlias; done }
    otherwise: { goalAlias; done }
  }
}

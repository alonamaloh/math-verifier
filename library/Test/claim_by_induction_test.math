-- Tests for the new `P by induction on a [with ih]
-- { case zero: …  case successor(k): … }` form — propositional
-- structural induction parallel to `P by cases { case A: …
-- case B: … }`. The IH binder name is supplied via `with <ih>`
-- after the scrutinee; when omitted, recursive arms see no
-- user-visible IH (matching plain `cases`).

module Test.claim_by_induction_test

import Logic.basics
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.one_plus_induction

-- (1) Smallest test. The zero arm is `0 + 0 = 0` (kernel-defeq);
-- the recursive arm is `successor(predecessor + 0) =
-- successor(predecessor)`, which the auto-prover's diff walker
-- closes by applying `IH : predecessor + 0 = predecessor` under
-- the `successor(_)` wrapper — no explicit `congruenceOf` needed.
theorem Natural.add_zero_right_via_ih (a : Natural) : a + 0 = a :=
  a + 0 = a by induction on a with IH {
    case zero:                   reflexivity
    case successor(predecessor): IH
  }

-- (2) Non-trivial calc inside the recursive arm. Same proof as
-- `Natural.multiply_successor_inductive` in `induction_style_test`
-- but expressed via `… by induction …` so the goal P and
-- the induction subject appear on the same line.
theorem Natural.multiply_successor_claim (a b : Natural)
        : a * successor(b) = a + a * b :=
  a * successor(b) = a + a * b by induction on a with IH {
    case zero:
      done by ring
    case successor(predecessor):
      -- `successor(predecessor) * successor(b)` no longer β-reduces under
      -- opaque `Natural.add`; expose the multiply step, apply the IH, finish
      -- with `ring`.
      successor(predecessor) * successor(b)
         = successor(b) + predecessor * successor(b)
              by Natural.successor_multiply
         = successor(b) + (predecessor + predecessor * b)
              by substituting IH
         = successor(predecessor) + successor(predecessor) * b
              by ring
  }

-- (3) Bare `done by induction on a {…}` — proposition inferred
-- from the surrounding theorem return type, just like `done by
-- cases {…}` does.
theorem Natural.add_zero_right_inferred (a : Natural) : a + 0 = a :=
  done by induction on a with IH {
    case zero:                   reflexivity
    case successor(predecessor): IH
  }

-- (4) `done by induction on a {…}` — uses the `goal` keyword
-- to refer to the surrounding theorem return type without
-- repeating it.
theorem Natural.add_zero_right_goal (a : Natural) : a + 0 = a :=
  done by induction on a with IH {
    case zero:                   reflexivity
    case successor(predecessor): IH
  }

-- (5) `done by cases { … }` — `goal` resolves to the
-- surrounding proposition (here Q) without the user repeating it.
theorem cases_goal_via_lem
        (P Q : Proposition)
        (impliesP : P → Q) (impliesNotP : Not(P) → Q) : Q :=
  done by cases {
    case P:        impliesP(given(P))
    case Not(P):   impliesNotP(given(Not(P)))
  }

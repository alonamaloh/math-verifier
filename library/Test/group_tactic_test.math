-- Test/group_tactic_test.math
--
-- Exercises the `group` and `monoid` decision tactics: associativity
-- flattening, identity elimination, and (group) adjacent-inverse
-- cancellation, against an abstract structure found from an in-scope
-- IsGroup / IsMonoid hypothesis.

module Test.group_tactic_test

import Algebra.monoid
import Algebra.group

-- (1) Pure reassociation.
theorem group_reassociate
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        (a b c : carrier)
        : (a · b) · c = a · (b · c) :=
  group

-- (2) Adjacent inverse cancellation to the identity.
theorem group_inverse_cancels
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        (a : carrier)
        : a⁻¹ · a = identity :=
  group

-- (3) The socks-and-shoes computation — the motivating case.
theorem group_socks_and_shoes
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        (a b : carrier)
        : (a · b) · (b⁻¹ · a⁻¹) = identity :=
  group

-- (4) Identity elimination plus cancellation, reduced word on both sides.
theorem group_mixed
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        (a b c : carrier)
        : a · ((b · b⁻¹) · (c · identity)) = a · c :=
  group

-- (5) As a calc step: an inverse cancels, leaving the tail.
theorem group_calc_step
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        (a b c : carrier)
        : (a · a⁻¹) · (b · c) = b · c :=
  calc (a · a⁻¹) · (b · c)
     = b · c   by group

-- (6) Monoid: associativity + identity only (no inverses available).
theorem monoid_reassociate
        (carrier : Type(0))
        (operation : carrier → carrier → carrier)
        (identity : carrier)
        (monoidProof : IsMonoid(carrier, operation, identity))
        (a b c : carrier)
        : operation(operation(a, b), operation(identity, c))
          = operation(a, operation(b, c)) :=
  monoid

-- (7) Auto-prover: a by-less group `=` step closes automatically (no hint).
theorem group_autoprove
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        (a b : carrier)
        : (a · b) · (b⁻¹ · a⁻¹) = identity :=
  calc (a · b) · (b⁻¹ · a⁻¹)
     = identity

-- (8) Auto-prover: a by-less monoid `=` step closes automatically.
theorem monoid_autoprove
        (carrier : Type(0))
        (operation : carrier → carrier → carrier)
        (identity : carrier)
        (monoidProof : IsMonoid(carrier, operation, identity))
        (a b c : carrier)
        : operation(operation(a, b), c) = operation(a, operation(b, c)) :=
  calc operation(operation(a, b), c)
     = operation(a, operation(b, c))

-- (9) Inverse of a product pushes inward (de Morgan).
theorem group_inverse_product
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        (a b : carrier)
        : (a · b)⁻¹ = b⁻¹ · a⁻¹ :=
  group

-- (10) Inverse of a longer product, nested on the right.
theorem group_inverse_triple
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        (a b c : carrier)
        : ((a · b) · c)⁻¹ = c⁻¹ · (b⁻¹ · a⁻¹) :=
  group

-- (11) Double inverse collapses.
theorem group_double_inverse
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        (x : carrier)
        : (x⁻¹)⁻¹ = x :=
  group

-- (12) A product against the inverse of a product cancels completely.
theorem group_inverse_product_cancels
        (carrier : Type(0))
        ((·) : carrier → carrier → carrier)
        (identity : carrier)
        ((⁻¹) : carrier → carrier)
        (groupProof : IsGroup(carrier, (·), identity, (⁻¹)))
        (a b : carrier)
        : (a · b) · (a · b)⁻¹ = identity :=
  group

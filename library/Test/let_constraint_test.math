-- Tests for `let <name> ∈ <type> [with <predicate>];` — Phase 3
-- object intro with optional constraint hypothesis. The `with`
-- clause adds a second lambda binder for an anonymous constraint
-- proof (referenceable via `given(...)` if needed).

module Test.let_constraint_test

import axioms
import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Integer.basics
import Integer.addition

-- (1) Bare object intro: `let ε ∈ Natural;` is a ∀-intro for an
-- arbitrary Natural. Conclusion type matches the theorem signature.
theorem let_object_intro : ∀ (n : Natural). n = n := {
  let n ∈ Natural;
  n = n
}

-- (2) Object + constraint: `let n ∈ Natural with 1 ≤ n;` introduces
-- both the object binder and an anonymous constraint hypothesis.
-- The signature is the curried form `(n : Natural) → 1 ≤ n → P(n)`.
theorem let_object_with_constraint
        : ∀ (n : Natural). 1 ≤ n → 1 ≤ n := {
  let n ∈ Natural with 1 ≤ n;
  1 ≤ n
}

-- (3) Two `let`s in a row: the second sees the first's binder.
theorem let_chained
        : ∀ (a : Natural). ∀ (b : Natural). a + b = a + b := {
  let a ∈ Natural;
  let b ∈ Natural;
  a + b = a + b
}

-- (4) Real use: object + constraint, then derive a related fact via
-- auto-prover that uses the constraint hypothesis.
theorem let_with_constraint_used
        : ∀ (a b : Integer). a = b → b = a := {
  let a ∈ Integer;
  let b ∈ Integer with a = b;
  b = a
}

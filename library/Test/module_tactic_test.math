-- Test/module_tactic_test.math
--
-- Exercises the `module` free-module normaliser tactic over an abstract
-- vector space. Each theorem states a linear-combination identity that the
-- tactic must close by normalising both sides to a canonical `Σ cᵢ • vᵢ`.

module Test.module_tactic_test

import Algebra.field
import Algebra.vector_space
import Algebra.vector_space_lemmas

-- Reflexive baseline: a goal whose sides are already identical.
theorem module_reflexive_test {f : Field} (V : VectorSpace(f))
        (u v : VectorSpace.carrier(V))
        : u + v = u + v :=
  by module

-- Test/module_tactic_test.math
--
-- Exercises the `module` free-module normaliser tactic over an abstract
-- vector space. Each theorem states a linear-combination identity that the
-- tactic must close by normalising both sides to a canonical `Σ cᵢ • vᵢ`.

module Test.module_tactic_test

import Algebra.field
import Algebra.vector_space
import Algebra.vector_space_lemmas

-- Reflexive baseline: a goal whose sides are already identical.
theorem module_reflexive_test {f : Field} (V : VectorSpace(f))
        (u v : VectorSpace.carrier(V))
        : u + v = u + v :=
  by module

-- Collecting like vectors: the headline case.
theorem module_collect_test {f : Field} (V : VectorSpace(f))
        (a b : Field.carrier(f)) (v : VectorSpace.carrier(V))
        : a • v + b • v = (a + b) • v :=
  by module

-- Distributing a scalar over a sum.
theorem module_distribute_test {f : Field} (V : VectorSpace(f))
        (a : Field.carrier(f)) (u v : VectorSpace.carrier(V))
        : a • (u + v) = a • u + a • v :=
  by module

-- Collapsing nested scales.
theorem module_nested_scale_test {f : Field} (V : VectorSpace(f))
        (a b : Field.carrier(f)) (v : VectorSpace.carrier(V))
        : a • (b • v) = (a * b) • v :=
  by module

-- Reordering (the abelian sort).
theorem module_reorder_test {f : Field} (V : VectorSpace(f))
        (u v : VectorSpace.carrier(V))
        : u + v = v + u :=
  by module

-- Unit scale.
theorem module_one_scale_test {f : Field} (V : VectorSpace(f))
        (v : VectorSpace.carrier(V))
        : Field.one(f) • v = v :=
  by module

-- Cancellation through subtraction (needs negate + zero-drop).
theorem module_cancel_test {f : Field} (V : VectorSpace(f))
        (a : Field.carrier(f)) (v : VectorSpace.carrier(V))
        : a • v - a • v = VectorSpace.zero(V) :=
  by module

-- A larger rearrangement combining distribution and collection.
theorem module_combined_test {f : Field} (V : VectorSpace(f))
        (a b : Field.carrier(f)) (u v : VectorSpace.carrier(V))
        : a • (u + v) + b • u = (a + b) • u + a • v :=
  by module

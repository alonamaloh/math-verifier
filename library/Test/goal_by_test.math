-- Closing the goal: `done` / `okay` are the bare goal-restate closers —
-- read as "and this proves the (expected-type) goal". They take the same
-- `by <hint>` tail as any stated proposition, so `done by L` ≡ `okay by L`
-- ≡ the goal restated bare `<goal> by L`.
-- `goal` itself is only the NAME of the type being proved (a type
-- reference); it is not a standalone closer (`goal by …` is rejected).

module Test.goal_by_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

-- (1) `goal by substitution`.
theorem goal_by_substitution
        (a b : Natural) (aEqB : a = b) (P : Natural → Proposition)
        (hyp : P(a))
        : P(b) :=
  done by substitution

-- (2) `goal by substituting <eq>` — narrowed form, names the
-- equality to use.
theorem goal_by_substituting
        (a b c : Natural) (aEqB : a = b) (bEqC : b = c)
        (P : Natural → Proposition) (hyp : P(b))
        : P(a) :=
  done by substituting aEqB

-- (3) `goal by cases { ... }` — propositional case-split. The
-- arm hypothesis bindings `as hP` / `as hQ` give the disjunct
-- proofs names so the arm bodies can cite them.
theorem goal_by_cases
        (P Q : Proposition) (disj : P ∨ Q)
        (impliesP : P → P) (impliesQ : Q → P)
        : P :=
  done by cases {
    case P  as hP:  impliesP(hP)
    case Q  as hQ:  impliesQ(hQ)
  }

-- (4) `done by <hint>` — the surviving explicit spelling (`claim goal by
-- <hint>` before the A1 Phase 3 retirement of `claim`); the equivalence
-- now reads done/okay/bare-goal-restate, all three taking the same
-- `by <hint>` tail.
theorem claim_goal_by
        (a b : Natural)
        : a + b = b + a :=
  done by Natural.add_commutative

-- Regression: a pattern destructure (`let ⟨…⟩ :=`) on a scrutinee whose
-- TYPE mentions a local `let`-bound alias ζ-unfolds the let and finds the
-- inductive head (it used to error "type's head is not an inductive
-- constant after normalisation").
module Test.destructure_through_let

import Logic.basics
import Natural.basics

theorem Test.destructure_let (P : Proposition) (hp : P) : P := {
  let Q : Proposition := P ∧ P;
  Q by And.introduction(hp, hp) as hq;
  let ⟨a, b⟩ := hq;
  a
}

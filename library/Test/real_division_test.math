-- The Real `/` operator from a consumer: the side condition discharges
-- from a hypothesis in scope, and `Real.divide_cancel` matches the goal by
-- binding its `bNonzero` slot to that hypothesis (the matcher trick for a
-- partial operator without definitional proof irrelevance).

module Test.real_division_test

import Logic.basics
import Equality.basics
import Real.basics
import Real.multiplication
import Real.ring
import Real.order
import Real.apartness
import Real.field
import Real.division

-- `a / b` elaborates (hole → bNonzero) and divide_cancel matches.
theorem use_real_divide_cancel (a b : Real) (bNonzero : b ≠ Real.zero)
        : b * (a / b) = a :=
  done since Real.divide_cancel

-- (a · b) / b = a from a consumer.
theorem use_real_multiply_divide_cancel (a b : Real) (bNonzero : b ≠ Real.zero)
        : (a * b) / b = a :=
  done since Real.multiply_divide_cancel

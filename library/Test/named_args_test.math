-- Named argument syntax: `name := value` inside an argument list
-- reorders the argument to the slot of the parameter with that name.
--
-- Mixed positional and named arguments are allowed; positional args
-- fill the next unfilled slot in order.

module Test.named_args_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.addition

-- A two-parameter function with explicit, named parameters for the
-- named-argument checks. (Integer.add is now defined by-representatives,
-- whose synthesised binder names aren't user-facing, so these use this
-- wrapper instead — the resolver mechanics are what's under test.)
definition Test.namedAdd (firstInteger secondInteger : Integer) : Integer :=
  Integer.add(firstInteger, secondInteger)

-- (1) All-positional baseline.
theorem all_positional (a b : Integer)
        : Test.namedAdd(a, b) = Integer.add(a, b) :=
  reflexivity(Integer, Integer.add(a, b))

-- (2) All-named: parameter names looked up from `Test.namedAdd`'s Pi
-- chain. The signature is `Test.namedAdd : (firstInteger secondInteger
-- : Integer) → Integer`; both names are available.
theorem all_named (a b : Integer)
        : Test.namedAdd(firstInteger := a, secondInteger := b) = Integer.add(a, b) :=
  reflexivity(Integer, Integer.add(a, b))

-- (3) Named args, reordered: same call but with the second-arg name
-- supplied first.
theorem named_reordered (a b : Integer)
        : Test.namedAdd(secondInteger := b, firstInteger := a) = Integer.add(a, b) :=
  reflexivity(Integer, Integer.add(a, b))

-- (4) Mixed: a positional arg first, then a named arg for the
-- remaining parameter.
theorem mixed_positional_and_named (a b : Integer)
        : Test.namedAdd(a, secondInteger := b) = Integer.add(a, b) :=
  reflexivity(Integer, Integer.add(a, b))

-- (5) Named arguments on a desugared call: `Quotient.sound`'s
-- elaborator desugar treats only the last three of its five params as
-- user-facing, so the named-arg resolver tries a suffix window first
-- (T, R are implicit-via-desugar) and matches "x", "y", "proof"
-- against the axiom's last three Pi-binder names.
theorem named_args_on_desugar
        (rep1 rep2 : IntegerRepresentative)
        (proof : IntegerEquivalent(rep1, rep2))
        : Quotient.mk(IntegerRepresentative, IntegerEquivalent, rep1)
          = Quotient.mk(rep2) :=
  Quotient.sound(proof := proof, x := rep1, y := rep2)

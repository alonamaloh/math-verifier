module Test.change_test
import Logic.basics
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.addition
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra

-- `change` swaps the goal to a definitionally-equal spelling, then the
-- body proves that spelling. Here CommutativeRing.add(c,x,y) is defeq to
-- Ring.add(CommutativeRing.ring(c), x, y).
theorem Test.change_swaps_spelling (c : CommutativeRing) (x y : CommutativeRing.carrier(c))
        : CommutativeRing.add(x, y) = CommutativeRing.add(x, y) := {
  change Ring.add(CommutativeRing.ring(c), x, y) = CommutativeRing.add(x, y);
  reflexivity(CommutativeRing.carrier(c), Ring.add(CommutativeRing.ring(c), x, y))
}

-- `change` to a defeq goal that the auto-prover then closes.
theorem Test.change_then_reflexivity (n : Natural)
        : n = n := {
  change n = n;
  reflexivity(Natural, n)
}

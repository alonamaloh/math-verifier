-- Tests for the `opaque definition` modifier and the `unfold` tactic.
-- A transparent definition (the default) δ-unfolds during kernel
-- reduction; an opaque one does not. `unfold X in <body>` temporarily
-- flips X transparent while elaborating <body>.

module Test.opaque_test

import Logic.basics
import Natural.basics
import Natural.peano
import Equality.basics

-- (1) Transparent baseline: `myDoubleT(2)` reduces to 4 by β/ι, so
-- `reflexivity(4)` closes the goal.
definition myDoubleT : Natural → Natural
  | zero         => zero
  | successor(k) => successor(successor(myDoubleT(k)))

theorem myDoubleT_two : myDoubleT(2) = 4 :=
  reflexivity(4)

-- (2) Opaque variant of the same function. The kernel refuses to
-- δ-unfold `myDouble`, so `reflexivity(4)` would now fail —
-- `myDouble(2)` and `4` are not definitionally equal.
opaque definition myDouble : Natural → Natural
  | zero         => zero
  | successor(k) => successor(successor(myDouble(k)))

-- (3) `unfold myDouble in <body>` opts back in to δ-unfolding for
-- the duration of <body>. Original opacity is restored afterwards.
theorem myDouble_two : myDouble(2) = 4 :=
  unfold myDouble in reflexivity(4)

-- (4) Outside an `unfold`, `myDouble` is still opaque — so a proof
-- about it needs lemmas, not reflexivity. Verify by proving the
-- recurrence equation via `unfold` and citing it.
theorem myDouble_succ (k : Natural)
        : myDouble(successor(k)) = successor(successor(myDouble(k))) :=
  unfold myDouble in reflexivity(successor(successor(myDouble(k))))

theorem myDouble_zero : myDouble(zero) = zero :=
  unfold myDouble in reflexivity(zero)

-- (5) Multi-name unfold: pass a comma-separated list.
opaque definition myTripleT : Natural → Natural
  | zero         => zero
  | successor(k) => successor(successor(successor(myTripleT(k))))

theorem mixed_unfold : myDouble(1) = myTripleT(0) + 2 :=
  unfold myDouble, myTripleT in reflexivity(2)

-- ----------------------------------------------------------------------
-- (6) Opacity-tolerant bridges (WS2). Opacity blocks δ during general
-- WHNF (so goal/term SHAPE is preserved for rewrite/matchers), but the
-- kernel and elaborator transparently unfold an opaque head at the
-- points where an equality, a Pi, or an inductive head is genuinely
-- demanded. None of these need `unfold`.

-- (6a) Kernel defeq bridge: the body's type `4 = 4` is checked against
-- the declared `myDouble(2) = 4`; the leaf `myDouble(2)` vs `4` fails
-- structurally, then bridges by unfolding the opaque head.
theorem bridge_reflexivity : myDouble(2) = 4 :=
  reflexivity(4)

-- (6b) inferType application retry: applying a value whose type is an
-- opaque definition that unfolds to a Pi.
opaque definition OpaqueArrow : Proposition := True → True

theorem bridge_apply (h : OpaqueArrow) : True :=
  h(True.trivial)

-- (6c) Anonymous tuple against an opaque expected type whose unfolding
-- is an `Exists` inductive.
opaque definition OpaqueExists : Proposition :=
  Exists(Natural, (n : Natural) ↦ n = n)

theorem bridge_tuple : OpaqueExists :=
  ⟨0, reflexivity(0)⟩

-- (6d) `↦`-lambda body against an opaque expected type whose unfolding
-- is a Pi — the binder domain is read through the opaque head.
opaque definition OpaqueForall : Proposition :=
  (n : Natural) → n = n

theorem bridge_lambda : OpaqueForall :=
  (n : Natural) ↦ reflexivity(n)

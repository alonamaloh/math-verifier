-- F3 — ∣ across the ℕ→ℤ hop: the packet slots
-- `Natural.to_integer.divides_preserves` / `.divides_reflects`
-- (re-homed from Integer.divides_of_natural_divides and its inverse)
-- are `automatic`, so divisibility transports bare in both directions.

module Test.cast_divides_test

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.division
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.divisibility

-- Preserves: n ∣ m at ℕ gives ι n ∣ ι m at ℤ, bare.
theorem Test.cast_divides_test.divides_up (d r : Natural) (h : d ∣ r)
        : Integer.divides((d : Integer), (r : Integer)) := {
  done
}

-- Reflects: ι n ∣ ι m at ℤ descends to n ∣ m at ℕ, bare.
theorem Test.cast_divides_test.divides_down (d r : Natural)
        (h : Integer.divides((d : Integer), (r : Integer))) : d ∣ r := {
  done
}

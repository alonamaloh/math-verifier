-- Stage B acceptance (PLAN_LINEAR_ALGEBRA): vector spaces over a
-- bundled Field work as consumers will use them — the vector-group
-- axioms discharge bare from `instance VectorSpace.is_abelian_group`,
-- `a • v` dispatches over an abstract space (the two-phase implicit
-- recovery: the scalar pins {f}, the vector pins {V}), the scale laws
-- cite by name, Fⁿ is a genuine dependent-indexed instance whose facts
-- reduce pointwise, and a `VectorSpace.carrier` of a concrete bundle
-- dispatches like its underlying carrier.

module Test.vector_space_test

import Logic.basics
import Logic.exists
import Logic.functions
import Equality.basics
import Natural.basics
import Natural.order
import Set.subtype
import Set.finite
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.field
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.field_bundle
import Algebra.vector_space
import Algebra.coordinate_space

-- The vector-group axioms discharge bare from the registered instance.
theorem Test.vector_zero_add (f : Field) (V : VectorSpace(f))
        (v : VectorSpace.carrier(V))
        : VectorSpace.zero(V) + v = v :=
  done

theorem Test.vector_add_commutes (f : Field) (V : VectorSpace(f))
        (u v : VectorSpace.carrier(V))
        : u + v = v + u :=
  done

-- Scalar action over an abstract space: `•` recovers {f} from the
-- scalar and {V} from the vector.
theorem Test.scale_distributes (f : Field) (V : VectorSpace(f))
        (a : Field.carrier(f)) (u v : VectorSpace.carrier(V))
        : a • (u + v) = a • u + a • v :=
  done by VectorSpace.scale_vector_add

theorem Test.scale_composes (f : Field) (V : VectorSpace(f))
        (a b : Field.carrier(f)) (v : VectorSpace.carrier(V))
        : (a * b) • v = a • (b • v) :=
  done by VectorSpace.scale_scalar_multiply

-- Fⁿ: scaling reduces pointwise (the dependent-indexed carrier is
-- honest), and coordinate facts lift through the extensionality bridge.
theorem Test.coordinate_scale_pointwise (f : Field) (n : Natural)
        (a : Field.carrier(f)) (u : CoordinateSpace(f, n))
        (k : NaturalsBelow(n))
        : (a • u)(k) = a * u(k) :=
  done

theorem Test.coordinate_add_commutes (f : Field) (n : Natural)
        (u v : CoordinateSpace(f, n))
        : u + v = v + u :=
  CoordinateSpace.equal_of_pointwise((k : NaturalsBelow(n)) ↦ {
    u(k) + v(k) = v(k) + u(k);
    done
  })

-- The carrier of a concrete bundle dispatches like its underlying
-- carrier (carrierProjectionField reads through VectorSpace.make).
theorem Test.field_space_carrier_reduces (f : Field)
        (x : VectorSpace.carrier(Field.vector_space(f)))
        : x + Field.zero(f) = x :=
  done

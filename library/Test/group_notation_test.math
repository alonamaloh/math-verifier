-- Test/group_notation_test.math
--
-- Probing ergonomic notation for group proofs: the `*` operator (already
-- registered on Group.carrier), the implicit-group `Group.inverse(a)`,
-- and a local `let inv := …` abbreviation.

module Test.group_notation_test

import Logic.basics
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.group_bundle

-- (1) `Group.inverse(a)` infers its group from the operand — no G.
theorem inverse_infers_group (G : Group) (a : Group.carrier(G))
        : Group.inverse(a) = Group.inverse(G, a) :=
  reflexivity(Group.carrier(G), Group.inverse(G, a))

-- (2) The `·` operator restates associativity in the clean notation.
theorem clean_associativity (G : Group) (a b c : Group.carrier(G))
        : (a · b) · c = a · (b · c) :=
  Group.associative(G, a, b, c)

-- (3) A local `inv` abbreviation, combined with `·`, reads like math.
theorem clean_inverse_left (G : Group) (a : Group.carrier(G))
        : Group.inverse(a) · a = Group.identity(G) := {
  let inv : Group.carrier(G) → Group.carrier(G) :=
      (x : Group.carrier(G)) ↦ Group.inverse(G, x);
  -- goal printed with Group.inverse; `inv(a) · a` is ζ/defeq the same term.
  Group.inverse_left(G, a)
}

-- (5) The `·` operator: idiomatic group-operation notation, group
--     inferred from the operands. `a · b` ≡ Group.operation(G, a, b).
theorem dot_is_operation (G : Group) (a b : Group.carrier(G))
        : a · b = Group.operation(G, a, b) :=
  reflexivity(Group.carrier(G), Group.operation(G, a, b))

-- (6) The conjugation pattern that motivated this — `g⁻¹·x·g` reads as
--     `Group.inverse(g) · x · g`, vs the old nested-call spelling.
theorem dot_conjugation (G : Group) (g x : Group.carrier(G))
        : Group.inverse(g) · x · g
          = Group.operation(G,
                Group.operation(G, Group.inverse(G, g), x), g) :=
  reflexivity(Group.carrier(G),
      Group.operation(G, Group.operation(G, Group.inverse(G, g), x), g))

-- (7) The postfix `⁻¹` operator: `a⁻¹` ≡ Group.inverse(a), group
--     inferred. Binds tighter than `·`.
theorem postfix_inverse (G : Group) (a : Group.carrier(G))
        : a⁻¹ = Group.inverse(G, a) :=
  reflexivity(Group.carrier(G), Group.inverse(G, a))

-- (8) The full conjugation in the intended notation: `g⁻¹ · x · g`.
theorem postfix_conjugation (G : Group) (g x : Group.carrier(G))
        : g⁻¹ · x · g
          = Group.operation(G,
                Group.operation(G, Group.inverse(G, g), x), g) :=
  reflexivity(Group.carrier(G),
      Group.operation(G, Group.operation(G, Group.inverse(G, g), x), g))

-- (9) An inverse law restated in the clean notation, proved by the
--     bundle lemma — exercises `⁻¹` and `·` in a real goal, not just
--     a reflexivity check.
theorem postfix_inverse_left (G : Group) (a : Group.carrier(G))
        : a⁻¹ · a = Group.identity(G) :=
  Group.inverse_left(G, a)

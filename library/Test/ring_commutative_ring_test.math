-- `ring` over an abstract bundled commutative ring. The carrier
-- `CommutativeRing.carrier(c)` exposes its operations and laws under the
-- `CommutativeRing.*` namespace (Algebra/commutative_ring_algebra.math),
-- so the ring tactic drives a goal stated purely over the abstract `c`,
-- recovering the structure index `c` from the operand type.
module Test.ring_commutative_ring_test

import Logic.basics
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra

theorem Test.abstract_add_commutative (c : CommutativeRing) (a b : CommutativeRing.carrier(c))
        : a + b = b + a := ring

theorem Test.abstract_add_associative (c : CommutativeRing) (a b d : CommutativeRing.carrier(c))
        : (a + b) + d = a + (b + d) := ring

theorem Test.abstract_multiply_commutative (c : CommutativeRing) (a b : CommutativeRing.carrier(c))
        : a * b = b * a := ring

theorem Test.abstract_distributivity (c : CommutativeRing) (a b d : CommutativeRing.carrier(c))
        : a * (b + d) = a * b + a * d := ring

theorem Test.abstract_mixed (c : CommutativeRing) (a b d : CommutativeRing.carrier(c))
        : (a + b) * d = d * a + b * d := ring

theorem Test.abstract_subtraction (c : CommutativeRing) (a b : CommutativeRing.carrier(c))
        : (a - b) + b = a := ring

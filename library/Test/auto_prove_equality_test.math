-- Tests for the equality battery added to `autoProveClaim`:
-- when `claim P` (no `by`) has an equality goal, the elaborator now
-- runs autoProveCalcStep, which gives reflexivity, single-position
-- diff with `Equality.congruence` wrapping, and AC rearrangement via
-- `ring`. Before this change, none of these strategies fired at top-
-- level claims — only inside calc steps.

module Test.auto_prove_equality_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra

-- (1) Reflexivity for definitionally-equal endpoints. The library
-- scan already had `Equality.reflexivity`; the equality battery
-- closes it faster (no Pi-chain unification) via isDefinitionallyEqual.
theorem refl_test (n : Integer) : n + Integer.zero = n + Integer.zero :=
  claim

-- (2) Commutativity via ring AC. Before this change, `claim` would
-- have failed: no lemma's conclusion is `a + b = b + a` for arbitrary
-- a, b on Integer (there's `Integer.add_commutative` but its
-- conclusion type matches via the library scan path, hmm).
theorem comm_test (a b : Integer) : a + b = b + a :=
  claim

-- (3) Associativity — same story.
theorem assoc_test (a b c : Integer) : (a + b) + c = a + (b + c) :=
  claim

-- (4) Multi-position AC shuffle: not closable by any single lemma,
-- only by ring.
theorem ac_shuffle_test (a b c d : Integer)
        : (a + b) + (c + d) = (b + a) + (d + c) :=
  claim

-- (5) Single-position diff with a local equality hypothesis. Before
-- this change, this would have required `by congruenceOf(...)`.
theorem diff_with_hypothesis (a b : Natural) (eq : a = b)
        : successor(a) = successor(b) :=
  claim

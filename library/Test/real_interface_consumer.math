-- D stage-5 step B: a consumer of the SEALED Real interface — the
-- carrier is abstract, the operator/coercion/fold wiring came copied,
-- and the whole construction theorem surface cites. The measured
-- consumer-bill preview for the eventual library-wide flip.
module Test.real_interface_consumer

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Rational.basics
import Rational.order
import Rational.division
import Algebra.monoid
import Algebra.aggregation
import Real.interface

-- An exported theorem cites argument-free through the sealed view.
theorem Test.sealed_commutativity (x y : Real) : x + y = y + x :=
  done by Real.add_commutative

-- A by-less order step through a sealed AUTOMATIC lemma.
theorem Test.sealed_order_step (a b c : Real) (h : a ≤ b)
        : a + c ≤ b + c := {
  a + c
     ≤ b + c
}

-- The fold binder works over the sealed carrier: the copied
-- fold_operation registry entry points at the sealed witness.
theorem Test.sealed_fold (s : Natural → Real) (n : Natural)
        : (sum k from 0 to n - 1 of s(k)) = Real.partialSum(s, n) :=
  done by Real.fold_as_partialSum

-- Analysis vocabulary survives the seal: `Real.ContinuousAt` is an
-- interface constant, so continuity statements are spellable and the
-- construction's theorems about them cite. (This exact shape was the
-- dangling-vocabulary hole the seal-time closure check now guards.)
theorem Test.sealed_continuity (c x : Real)
        : Real.ContinuousAt((y : Real) ↦ c, x) :=
  done by Real.ContinuousAt.constant

-- A False goal closes UNPROMPTED through a sealed automatic negation
-- lemma (the Not-conclusion pool peel): the done-idiom works sealed.
theorem Test.sealed_done_idiom (c : Real) (h : c < c) : False := done

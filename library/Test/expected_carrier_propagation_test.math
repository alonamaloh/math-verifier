module Test.expected_carrier_propagation_test

import Algebra.escalation
import Rational.embedding
import Rational.order
import Real.field

-- Expected-carrier propagation (PLAN_ELABORATOR_ERGONOMICS.md, step E0).
--
-- These are ELABORATION probes: each states a proposition and asserts only
-- that it elaborates at the intended carrier without an operand annotation.
-- Nothing here is proved, because what is under test is operator and relation
-- DISPATCH, not provability.
--
-- Everything in this file already elaborates today. That is the point: E3
-- (bidirectional relation elaboration) reorders dispatch for expressions that
-- currently compile, so this file is the regression net for that step, not a
-- wish list. The probes that do NOT yet elaborate live in library/ErrorTest as
-- carrier_pending_*.math, and move HERE as E1-E3 land.

-- A syntactic Integer operand seeds the relation; the numeral follows it.
definition Test.carrier_integer_relation (b : ℤ) : Proposition :=
  b * b < 3

-- A positive numeral inherits the Integer carrier across `=`.
definition Test.carrier_integer_equality (b : ℤ) : Proposition :=
  b = 1

-- A Natural VARIABLE lifts, not just a literal — the mechanism must not be
-- numeral-specific.
definition Test.carrier_natural_variable_lifts (b : ℤ) (m : ℕ) : Proposition :=
  b = m

-- The same lift under `+` and `*`, on both sides of the relation.
definition Test.carrier_natural_variable_under_add (b : ℤ) (m : ℕ) : Proposition :=
  b + m = 2

definition Test.carrier_natural_variable_under_multiply (b : ℤ) (m : ℕ) : Proposition :=
  b * m ≤ 5

-- A TWO-EDGE lift (ℕ → ℤ → ℚ), so the mechanism is the coercion registry
-- rather than an Integer special case.
definition Test.carrier_two_edge_lift (q : ℚ) (m : ℕ) : Proposition :=
  q + m = 1

definition Test.carrier_two_edge_numeral (q : ℚ) : Proposition :=
  q ≤ 2

-- A numeral on both sides of an operator whose other operand fixes the carrier.
definition Test.carrier_numeral_both_positions (b : ℤ) : Proposition :=
  b + 1 = 2

-- A matrix entry presents its type through a projection over a CLOSED ring
-- bundle. Shared carrier-head normalization exposes Integer, so the Natural
-- numeral lifts and relation dispatch stays at Integer.
definition Test.carrier_bundled_relation {n : ℕ}
        (M : Matrix(Integer.commutative_ring_bundle, n, n))
        (i : NaturalsBelow(n)) : Proposition :=
  M(i, i) < 3

-- Equality uses the same concrete carrier evidence when coercing its right
-- operand to the left operand's expected type.
definition Test.carrier_bundled_equality {n : ℕ}
        (M : Matrix(Integer.commutative_ring_bundle, n, n))
        (i : NaturalsBelow(n)) : Proposition :=
  M(i, i) = 0

-- Carrier-aware joining is term-general: a computed Natural operand lifts just
-- like a numeral when the opposite matrix entry fixes Integer.
definition Test.carrier_bundled_operand {n : ℕ}
        (M : Matrix(Integer.commutative_ring_bundle, n, n))
        (A : Matrix(Integer.commutative_ring_bundle, n, n))
        (i : NaturalsBelow(n)) : Proposition :=
  M(i, i) * Matrix.truant(A) = 0

-- Expected carriers reach through unary negation to a literal and to a
-- Natural variable; the operand is lifted before `<T>.negate` is selected.
definition Test.carrier_unary_numeral (b : ℤ) : Proposition :=
  b = -1

definition Test.carrier_unary_natural (b : ℤ) (m : ℕ) : Proposition :=
  b = -m

-- Carrier evidence may arrive from the right operand after a left unary
-- expression fails to synthesize on its own.
definition Test.carrier_unary_from_right_operand
        (a : ℤ) (m : ℕ) : Proposition :=
  -m * a = 0

-- The rule is the coercion tower, not an Integer special case.
definition Test.carrier_unary_rational (q : ℚ) (n : ℕ) : Proposition :=
  q < -n

-- E1-normalized expected carriers propagate through unary negation too.
definition Test.carrier_unary_bundled {n : ℕ}
        (M : Matrix(Integer.commutative_ring_bundle, n, n))
        (i : NaturalsBelow(n)) : Proposition :=
  M(i, i) = -1

-- Registered postfix operators use the same expected-carrier rule. The
-- hypothesis supplies the reciprocal's honest nonzero side condition; the
-- operand itself remains a bare Natural numeral.
definition Test.carrier_postfix_expected
        (oneNonzero : ¬(Real.one = Real.zero)) : Real :=
  1⁻¹

-- E3: relation evidence is bidirectional. A bare numeral on the left must not
-- commit `<` to Natural when the right operand independently fixes Integer.
definition Test.carrier_integer_relation_from_right (b : ℤ) : Proposition :=
  3 < b * b

-- The same reverse orientation through a closed bundle projection.
definition Test.carrier_bundled_relation_from_right {n : ℕ}
        (M : Matrix(Integer.commutative_ring_bundle, n, n))
        (i : NaturalsBelow(n)) : Proposition :=
  3 < M(i, i)

definition Test.carrier_bundled_equality_from_right {n : ℕ}
        (M : Matrix(Integer.commutative_ring_bundle, n, n))
        (i : NaturalsBelow(n)) : Proposition :=
  0 = M(i, i)

-- Equality propagates the left type as a hint to the right. If that hint
-- poisons implicit inference (`A := Natural` here), retry the right operand
-- bottom-up: `x` independently determines `A := Integer`, after which the
-- ordinary coercion join lifts the left zero.
definition Test.carrier_equality_right_retry
        (predicate : ℤ → Proposition)
        (x : Subtype(ℤ, predicate)) : Proposition :=
  0 = Subtype.value(x)

-- Cast-normal form is semantic, not cosmetic. When equality lifts the
-- Rational RHS into Real it must distribute the cast through `+`, preserving
-- the intended proposition instead of collapsing both sides to
-- `Rational.to_real(a + b)`.
axiom Test.carrier_equality_cast_normal_form
    : ∀ (a b : ℚ). ((a + b : ℝ) = a + b)

-- Lock for QUIRK Q8 (embed half): an explicit proposition slot accepts an
-- UNAPPLIED ∀-fact even when the callee's leading implicits are still
-- metavariables when that slot elaborates. The fact argument is deferred
-- to the inference second pass (like bare implicit-leading operations),
-- where the by-then-concrete domain lets the by-name citation path solve
-- its arguments from the slot's proposition.

module Test.unapplied_fact_argument_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.order
import Set.finite

definition Probe.sumLeftViaEmbed (n p : ℕ) (element : NaturalsBelow(n)) : NaturalsBelow(n + p) :=
  NaturalsBelow.embed(Natural.less_or_equal_add_right, element)

-- `overload abs := <T.absolute_value>` registers `abs` as a name that
-- dispatches on the argument's type. Confirms the existing
-- `overload <alias> := <function>` declaration form (in lexer + parser
-- + elaborator) actually resolves at call sites when multiple
-- candidates exist.

module Test.overload_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Integer.basics
import Integer.absolute_value
import Rational.basics
import Rational.addition
import Rational.absolute_value

overload abs := Integer.absolute_value
overload abs := Rational.absolute_value

-- abs on Integer → Integer.absolute_value picked.
theorem Test.abs_integer_zero
        : abs(Integer.zero) = Integer.zero :=
  reflexivity(Integer, Integer.zero)

-- abs on Rational → Rational.absolute_value picked.
theorem Test.abs_rational_zero
        : abs(Rational.zero) = Rational.zero :=
  reflexivity(Rational, Rational.zero)

module Test.lc_bundle
import Logic.basics
import Equality.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra

-- Bundle carrier: single hypothesis, subtract a common term.
theorem Test.lcb_single (c : CommutativeRing) (x y k : CommutativeRing.carrier(c))
        (h : x + k = y + k) : x = y :=
  linear_combination(h)

-- Bundle carrier: scaled hypothesis.
theorem Test.lcb_scaled (c : CommutativeRing) (x y z : CommutativeRing.carrier(c))
        (h : x = y) : z * x = z * y :=
  linear_combination(z * h)

-- Bundle carrier: sum of two hypotheses.
theorem Test.lcb_sum (c : CommutativeRing) (x y z : CommutativeRing.carrier(c))
        (h1 : x = z) (h2 : z = y) : x = y :=
  linear_combination(h1 + h2)

-- Bundle carrier: the full c1*h1 + c2*h2 shape.
theorem Test.lcb_two_scaled (c : CommutativeRing)
        (a b d e k1 k2 : CommutativeRing.carrier(c))
        (h1 : a = b) (h2 : d = e)
        : k1 * a + k2 * d = k1 * b + k2 * e :=
  linear_combination(k1 * h1 + k2 * h2)

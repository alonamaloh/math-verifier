-- Feature test: monotonicity rules whose premises are pure sign FORMS
-- (`Real.IsNonneg(c)` on the multiply_by_nonneg family) discharge from an
-- order-spelled hypothesis — the mono recursion hands non-order premises
-- to the sign recursion, whose form bridge crosses IsNonneg ↔ 0 ≤ c.
-- Both the `Real.zero ≤ p` and the numeral `p ≥ 0` spellings must work.
module Test.mono_sign_premise_test

import Logic.basics
import Equality.basics
import Natural.basics
import Real.interface

theorem Test.multiply_by_nonneg_closes_with_zero_spelling
        (q p : Real) (qBelowOne : q ≤ 1) (pNonneg : Real.zero ≤ p)
        : q * p ≤ 1 * p := {
  q * p ≤ 1 * p;
  done
}

theorem Test.multiply_by_nonneg_closes_with_numeral_spelling
        (q p : Real) (qBelowOne : q ≤ 1) (pNonneg : p ≥ 0)
        : q * p ≤ 1 * p := {
  q * p ≤ 1 * p;
  done
}

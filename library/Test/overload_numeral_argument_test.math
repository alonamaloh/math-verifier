-- A numeral literal in an overload's argument coerces to the overload
-- target's parameter type. `conj` expects a ℂ, so `conj(1)` reads the `1`
-- as the complex 1 — the overload resolver, finding no candidate for the
-- bare-Natural argument, retries with numeral positions as wildcards and
-- lets the final re-elaboration coerce via the expected parameter type.

module Test.overload_numeral_argument_test

import Logic.basics
import Equality.basics
import Natural.basics
import Real.interface
import ComplexNumber.basics
import ComplexNumber.embedding
import ComplexNumber.coordinate_map
import ComplexNumber.conjugation

-- `conj(1)` resolves (1 read at ℂ); the plain-function path already did.
theorem Test.conj_numeral : conj(1) = conj(1) :=
  reflexivity(ℂ, conj(1))

-- Re/Im overloads likewise take a numeral complex argument.
theorem Test.re_numeral : Re(1) = Re(1) :=
  reflexivity(ℝ, Re(1))

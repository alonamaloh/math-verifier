-- Test/naturals_below_order_test.math
--
-- Locks the NaturalsBelow order interface (pre-Sylvester consolidation
-- T2): `i < j` / `i ≤ j` on index elements, ℕ order lemmas citable
-- through the operators, and the automatic value-level bridges in both
-- directions.

module Test.naturals_below_order_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.order
import Set.subtype
import Set.equinumerous
import Set.finite

theorem Test.index_transitivity {n : ℕ} (i j k : NaturalsBelow(n))
        (firstBelow : i < j) (secondBelow : j < k) : i < k :=
  done by Natural.lt_transitive

theorem Test.index_less_or_equal_transitivity {n : ℕ} (i j k : NaturalsBelow(n))
        (firstAtMost : i ≤ j) (secondAtMost : j ≤ k) : i ≤ k :=
  done by Natural.LessOrEqual.transitive

theorem Test.index_to_value {n : ℕ} (i j : NaturalsBelow(n))
        (below : i < j) : NaturalsBelow.value(i) < NaturalsBelow.value(j) :=
  done

theorem Test.value_to_index {n : ℕ} (i j : NaturalsBelow(n))
        (below : NaturalsBelow.value(i) < NaturalsBelow.value(j)) : i < j :=
  done

-- The swap-style side condition: distinctness of the underlying values
-- straight from an index comparison (bridge + order lemma + ≠-flip).
theorem Test.value_distinct_of_index_below {n : ℕ} (i j : NaturalsBelow(n))
        (below : i < j) : NaturalsBelow.value(j) ≠ NaturalsBelow.value(i) :=
  done by Natural.not_equal_of_greater_than

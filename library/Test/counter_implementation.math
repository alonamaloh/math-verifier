-- D Phase-1: the toy implementation module. Builds as an ordinary
-- module; the interface (Test.counter_interface) seals it.
implementation module Test.counter_implementation implements Test.counter_interface

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

definition Test.Counter : Type(0) := Natural

definition Test.Counter.start : Test.Counter := 0

definition Test.Counter.tick (c : Test.Counter) : Test.Counter := 1 + c

definition Test.Counter.read (c : Test.Counter) : Natural := c

theorem Test.Counter.read_of_start
        : Test.Counter.read(Test.Counter.start) = 0 :=
  done

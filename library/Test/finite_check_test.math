-- Kernel-certificate tests for the half-open finite_check proof form.
module Test.finite_check_test

import Logic.basics
import Integer.finite_range

theorem Test.finite_check_collects_natural_facts
        (P : ℕ → Proposition)
        (atTwo : P(2)) (atThree : P(3)) (atFour : P(4))
        : ∀ (n : ℕ). 2 ≤ n → n < 5 → P(n) :=
  by finite_check n from 2 until 5

theorem Test.finite_check_collects_integer_facts
        (P : ℤ → Proposition)
        (atMinusTwo : P(-2)) (atMinusOne : P(-1))
        (atZero : P(0)) (atOne : P(1)) (atTwo : P(2))
        : ∀ (z : ℤ). -2 ≤ z → z < 3 → P(z) :=
  by finite_check z from -2 until 3

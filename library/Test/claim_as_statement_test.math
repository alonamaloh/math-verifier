-- Tests for the "structured `claim P [by …];` as a mid-block
-- statement" form. Previously the block parser broke out of its
-- wrapper loop at any non-legacy `claim`, forcing users to either
-- name the binding (`claim h : P by …;`) or rearrange the block.

module Test.claim_as_statement_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

-- (1) Bare `claim P;` mid-block. The auto-prover discharges P; the
-- proof is bound under an anonymous name, and the next statement's
-- auto-prover finds it by structural hypothesis match.
theorem statement_then_claim
        (a b : Natural) (aEqB : a = b)
        : b = a := {
  claim a = b;
  claim b = a
}

-- (2) `claim P by Hint;` mid-block. Same shape with an explicit
-- proof.
theorem statement_with_by
        (a b c : Natural) (aEqB : a = b)
        : a = b := {
  claim a = b by aEqB;
  claim a = b
}

-- (3) Multiple statements followed by a final claim. The block reads
-- top-to-bottom as a sequence of derivations.
theorem statement_chain
        (a b c : Natural) (aEqB : a = b) (bEqC : b = c)
        : a = c := {
  claim a = b;
  claim b = c;
  claim a = c
}

-- (4) Mixed with `suppose`: the suppose binder lands first, then a
-- mid-block `claim` consumes it, then the final claim closes the
-- goal.
theorem statement_with_suppose
        (P Q : Proposition) (impliesPQ : P → Q)
        : P → Q := {
  suppose P as hP;
  claim Q by impliesPQ(hP);
  claim Q
}

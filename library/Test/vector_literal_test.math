-- Expected-type-directed finite vector literals and the compact
-- representation-by-witness interface.

module Test.vector_literal_test

import Algebra.rank_three_truants

definition Test.literalTriple
        : RingVector(Integer.commutative_ring_bundle, 3) :=
  ⟨1, -2, 3⟩

theorem Test.sumOfThreeSquares_represents_six_by_literal
        : Matrix.Represents(Matrix.sumOfThreeSquaresForm, 6) :=
  done by Matrix.represents_by_witness(vector := ⟨2, 1, 1⟩)

-- Probe: ring atom identification across the bundle defeq boundary
-- (fix 1 of the matcher/normalization session).

module Test.ring_bundle_reduct_test

import Logic.basics
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.ring
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.integer_domain

-- (a) `Integer.zero` / `Integer.one` recognised as THE ring constants at
-- the concrete bundle instance.
theorem Probe.bundle_zero_mix
        (x : CommutativeRing.carrier(Integer.commutative_ring_bundle))
        : CommutativeRing.add(Integer.commutative_ring_bundle, x, Integer.zero) = x :=
  ring

theorem Probe.bundle_one_zero_mix
        (x : CommutativeRing.carrier(Integer.commutative_ring_bundle))
        : CommutativeRing.add(Integer.commutative_ring_bundle,
              CommutativeRing.multiply(Integer.commutative_ring_bundle, x, Integer.one),
              Integer.zero)
          = x :=
  ring

-- (b) reduct-spelled OPERATION mixed into a bundle-carrier goal.
theorem Probe.bundle_op_mix
        (x y : CommutativeRing.carrier(Integer.commutative_ring_bundle))
        : CommutativeRing.add(Integer.commutative_ring_bundle, x, y)
          = Integer.add(y, x) :=
  ring

-- (c) non-ring-op reduct atoms: a definition application and its δβ-reduct
-- must land on the SAME atom.
definition Probe.reindex (f : ℕ → ℕ) (k : ℕ) : ℕ := f(1 + k)

theorem Probe.reduct_atom_identified (f : ℕ → ℕ) (k : ℕ)
        : Probe.reindex(f, k) = f(1 + k) :=
  ring

theorem Probe.reduct_atom_in_context (f : ℕ → ℕ) (k : ℕ)
        : Probe.reindex(f, k) + f(1 + k) = 2 * f(1 + k) :=
  ring

-- Test/vector_group_test.math
--
-- The `group` tactic over a vector space's additive abelian group: the
-- reduced word is sorted (commutativity) and re-cancelled, so additive
-- rearrangements, the medial law, and subtract cancellation all close —
-- by `group` and as bare relation-chain steps.

module Test.vector_group_test

import Algebra.field_bundle
import Algebra.vector_space
import Algebra.vector_space_lemmas

-- (1) The medial law — pure abelian rearrangement, no inverses.
theorem vector_medial {f : Field} (V : VectorSpace(f))
        (a b c d : VectorSpace.carrier(V))
        : (a + b) + (c + d) = (a + c) + (b + d) :=
  group

-- (2) Subtract cancellation: (a + b) - a = b (needs unfold + comm + cancel).
theorem vector_subtract_cancel {f : Field} {V : VectorSpace(f)}
        (a b : VectorSpace.carrier(V)) : (a + b) - a = b :=
  group

-- (3) Reassociation + commutativity together.
theorem vector_reassociate_commute {f : Field} (V : VectorSpace(f))
        (a b c : VectorSpace.carrier(V))
        : (a + b) + c = (c + a) + b :=
  group

-- (4) Full cancellation to zero.
theorem vector_cancel_to_zero {f : Field} {V : VectorSpace(f)}
        (a b : VectorSpace.carrier(V))
        : (a + b) - (b + a) = VectorSpace.zero(V) :=
  group

-- (5) As a bare calc step (no `by group`): the additive bridge fires
-- automatically for a vector-carrier rearrangement.
theorem vector_calc_step {f : Field} {V : VectorSpace(f)}
        (a b c : VectorSpace.carrier(V))
        : a + (b + c) = c + (a + b) :=
  a + (b + c)
     = c + (a + b)

-- (6) `a • v` blocks are opaque atoms and still rearrange.
theorem vector_scale_atoms_rearrange {f : Field} {V : VectorSpace(f)}
        (s t : Field.carrier(f)) (u v : VectorSpace.carrier(V))
        : (s • u) + (t • v) = (t • v) + (s • u) :=
  group

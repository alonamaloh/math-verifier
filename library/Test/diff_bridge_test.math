-- Tests for the diff-bridge mechanism. When a term's inferred type
-- differs from the expected type at a single position, AND the local
-- context contains an equation between the differing subterms, the
-- elaborator auto-wraps with `Equality.transport_proposition` so the
-- user can hand over the bare term — no transport plumbing on the page
-- (this bridge is what made retiring the old `rewrite(…)` form possible).

module Test.diff_bridge_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

-- A predicate to host the substitution. Anything that contains a
-- Natural in one position works.
definition Test.IsZero (n : Natural) : Proposition :=
  n = 0

theorem Test.is_zero_at_zero : Test.IsZero(0) :=
  reflexivity(Natural, 0)

-- Baseline: same type both sides, no diff-bridge needed.
theorem Test.diff_bridge_baseline : Test.IsZero(0) :=
  Test.is_zero_at_zero

-- Forward direction: hypothesis `a = 0`, term has type `IsZero(0)`,
-- goal is `IsZero(a)`. Diff at (0, a). Wrap with sym(eq) inside
-- transport. User writes just the term.
theorem Test.diff_bridge_forward
        (a : Natural) (aEqZero : a = 0) : Test.IsZero(a) :=
  Test.is_zero_at_zero

-- Multi-position: motive `λw. w = w` applied to a hypothesis
-- `a = b`. Goal `b = b`. Term type `a = a`. Diff is at the bound-
-- var position (both occurrences). Abstract-all motive gives
-- `λz. z = z`; subset enumeration should find the right one.
theorem Test.diff_bridge_multi_position
        (a b : Natural) (eq : a = b) : b = b :=
  reflexivity(Natural, a)

-- Wrap inside a function call. Argument position with declared type.
theorem Test.diff_bridge_in_arg_position
        (a : Natural) (aEqZero : a = 0)
        (consumer : Test.IsZero(a) → Natural)
        : Natural :=
  consumer(Test.is_zero_at_zero)

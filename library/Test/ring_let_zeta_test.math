-- Test/ring_let_zeta_test.math
--
-- Probes: does `ring` see through `let`-bound abbreviations for the
-- ring's distinguished constants (zero, one) and for atoms?

module Test.ring_let_zeta_test

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.order
import Integer.basics
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.order
import Set.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.instances
import Polynomial.basics
import Polynomial.addition
import Polynomial.negation
import Polynomial.multiplication
import RingModulo.basics
import RingModulo.operations
import ComplexNumber.basics
import ComplexNumber.coordinates
import ComplexNumber.embedding

-- Real: let-bound one inside a ring goal.
theorem Test.ring_let_real_one (x : Real) : x * Real.one = x := {
  let one : Real := Real.one;
  claim x * one = x by ring;
  done
}

-- ℂ: let-bound zero inside a ring goal (the limitSimplifies shape).
theorem Test.ring_let_complex_zero (z : ComplexNumber)
        : z = z + -RingModulo.zero(Real.polynomial_commutative_ring,
                       Complex.definingPolynomial) := {
  let zero : ComplexNumber :=
      RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial);
  claim z = z + -zero by ring;
  done
}

-- ℂ: let-bound atom (not a constant) inside a ring goal.
theorem Test.ring_let_complex_atom (z w : ComplexNumber)
        : z * w + w * z = z * w + z * w := {
  let product : ComplexNumber := z * w;
  claim product + w * z = product + product by ring;
  done
}

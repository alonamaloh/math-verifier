-- Test/bundled_lemma_citation_test.math
--
-- Argument-free citation of a bundled-structure lemma at a concrete
-- carrier: `done by Ring.zero_multiply_left` against
-- `Real.zero * c = Real.zero`. The structure argument r occurs only
-- under projections; resolution comes from the instance registry
-- (`instance Real.ring`) — the carrier-keyed lookup, with the
-- try-each-bundle unique-candidate fallback behind it for slots the
-- carrier key misses.

module Test.bundled_lemma_citation_test

import Logic.basics
import Equality.basics
import Real.sequence
import Real.basics
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.instances
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Polynomial.basics
import ComplexNumber.basics

theorem Test.bundled_zero_multiply_citation (c : Real)
        : Real.zero * c = Real.zero := {
  done by Ring.zero_multiply_left
}

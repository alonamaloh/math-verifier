-- Quick check: does Natural.add reduce under reflexivity?

module Test.whnf_check

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano

-- This should pass if Natural.add(succ(b), Y) WHNF-reduces to succ(Natural.add(b, Y)).
theorem add_succ_reduces (b : Natural) (Y : Natural)
        : Natural.add(successor(b), Y) = successor(Natural.add(b, Y)) :=
  reflexivity(successor(Natural.add(b, Y)))

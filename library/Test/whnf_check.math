-- Quick check: `Natural.add` is now an `opaque definition`, so it does NOT
-- WHNF-reduce under bare reflexivity — the head is sealed at the demand points.

module Test.whnf_check

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano

-- `add(succ(b), Y) = succ(add(b, Y))` no longer holds by reflexivity (add is
-- opaque); the reduction is recovered explicitly under `unfolding Natural.add`.
theorem add_succ_reduces (b : Natural) (Y : Natural)
        : Natural.add(successor(b), Y) = successor(Natural.add(b, Y)) :=
  done by unfolding Natural.add

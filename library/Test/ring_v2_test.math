-- Test the `ring` v2 tactic — handles distributivity, negation, and
-- like-term cancellation that v1 can't bridge.

module Test.ring_v2_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.absolute_value

-- (1) Distributivity left.
theorem v2_distributivity_left (a b c : Integer)
        : a * (b + c) = a * b + a * c := ring

-- (2) Distributivity right.
theorem v2_distributivity_right (a b c : Integer)
        : (a + b) * c = a * c + b * c := ring

-- (3) Both: full quadratic expansion.
theorem v2_distributivity_both (a b c d : Integer)
        : (a + b) * (c + d) = a*c + a*d + b*c + b*d := ring

-- (4) Distributivity plus a commutative swap on one term.
theorem v2_distrib_and_swap (a b c : Integer)
        : (a + b) * c = c * a + b * c := ring

-- (5) Like-term cancellation via negation: b cancels.
theorem v2_cancel (a b c : Integer)
        : (a + -b) + (b + -c) = a + -c := ring

-- (6) Split-via-anchor: introduce b and -b on the RHS.
theorem v2_split_via_anchor (a b : Integer)
        : a = b + (a + -b) := ring

-- (7) Subtract sugar: the carrier's `-` operator is recognised as
-- `add(_, negate(_))` via δ; ring handles it transparently.
theorem v2_subtract_chain (a b c : Integer)
        : (a - b) + (b - c) = a - c := ring

-- (8) Subtract split-via-anchor written with `-` instead of `+ -`.
theorem v2_subtract_split_via_anchor (a b : Integer)
        : a = b + (a - b) := ring

-- (9) Subtract negated.
theorem v2_negate_subtract (right left : Integer)
        : -(right - left) = left - right := ring

-- (10) Subtract zero. The empty-inner-polynomial negate case was
-- a v2 hole (needed a primitive `negate_zero`); now derived inline
-- from add_zero + add_negate_left.
theorem v2_subtract_zero (a : Integer)
        : a - Integer.zero = a := ring

-- (11) Same shape, but the result is itself zero on the LHS.
theorem v2_zero_minus_zero
        : Integer.zero - Integer.zero = Integer.zero := ring

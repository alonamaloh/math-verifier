module Test.cast_order_test

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.order

-- B3.2 — the cast-order tier (PLAN_LANGUAGE_IMPROVEMENT.md): order
-- goals cross the coercion tower by-less. Pull-lowering proves the
-- order at the source carrier and lifts through
-- `<hop>.<Rel>_preserves`; push-retry meets a leaf-cast hypothesis at
-- the normalized spelling.

-- Pull-lowering: the goal is the ι-image of a Natural order fact.
theorem cast_order_pull (q m r j : Natural) (bound : j ≤ q * m + r)
    : (j : Integer) ≤ (q : Integer) * (m : Integer) + (r : Integer) := {
  (j : Integer) ≤ (q : Integer) * (m : Integer) + (r : Integer);
  done
}

-- The strict variant lowers through LessThan.
theorem cast_order_pull_strict (a b : Natural) (bound : a < b)
    : (a : Integer) < (b : Integer) := {
  (a : Integer) < (b : Integer);
  done
}

-- Push-retry: the hypothesis speaks the leaf-cast spelling, the goal
-- lifts the sum as a unit.
theorem cast_order_push (a b : Natural) (c : Integer)
        (bound : (a : Integer) + (b : Integer) ≤ c)
    : ((a + b : Natural) : Integer) ≤ c := {
  ((a + b : Natural) : Integer) ≤ c;
  done
}

-- Reflects-lowering: a cast-level order fact serves the source goal
-- through <hop>.LessOrEqual_reflects.
theorem cast_order_reflects (a b : Natural)
        (bound : (a : Integer) ≤ (b : Integer))
    : a ≤ b := {
  a ≤ b;
  done
}

-- ... including compound images: the fact's sides pull to the goal's.
theorem cast_order_reflects_compound (a b c : Natural)
        (bound : (a : Integer) + (b : Integer) ≤ (c : Integer))
    : a + b ≤ c := {
  a + b ≤ c;
  done
}

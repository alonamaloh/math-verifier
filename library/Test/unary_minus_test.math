-- Unary `-` dispatches on the operand's head type: `-x` for an Integer
-- x desugars to `Integer.negate(x)`; for a Rational it desugars to
-- `Rational.negate(x)`.

module Test.unary_minus_test

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.addition
import Integer.negation
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation

theorem unary_minus_integer (x : Integer) : -x = -x :=
  reflexivity(Integer, -x)

theorem unary_minus_rational (x : Rational) : -x = -x :=
  reflexivity(Rational, -x)

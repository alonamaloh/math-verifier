-- D Phase-1: the toy interface. Declares the public view; the build
-- checks every obligation against the implementation and emits a
-- SEALED cache (abstract type/constants as bodyless axioms, the
-- obligation as a stripped theorem), with the implementation dropped
-- from the dependency list — consumers never load the construction.
interface module Test.counter_interface implemented by Test.counter_implementation

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Test.counter_implementation
import Test.counter_lemmas

type Test.Counter
constant Test.Counter.start : Test.Counter
constant Test.Counter.tick : Test.Counter → Test.Counter
constant Test.Counter.read : Test.Counter → Natural

theorem Test.Counter.read_of_start
        : Test.Counter.read(Test.Counter.start) = 0

export theorems of Test.counter_lemmas

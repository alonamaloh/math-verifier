-- Natural.recursion — the boundary primitive-recursion combinator
-- (PLAN_NATURAL_SEALING Stage 2). A Type-level definition by recursion
-- at the alias, no constructor pattern-matching, and ground values
-- compute through the accelerated table.

module Test.natural_recursion_test

import Natural.basics
import Natural.arithmetic
import Equality.basics

-- Doubling by primitive recursion: double(0) = 0, double(1 + k) = double(k) + 2.
definition Test.double (n : Natural) : Natural :=
  Natural.recursion(0, (k : Natural) ↦ (doubled : Natural) ↦ doubled + 2, n)

-- Ground computation reduces through the combinator and the table.
theorem Test.double_of_three : Test.double(3) = 6 := reflexivity(6)

-- The base and step defining equations hold definitionally.
theorem Test.double_of_zero : Test.double(0) = 0 := reflexivity(0)

theorem Test.double_of_successor (k : Natural)
        : Test.double(successor(k)) = Test.double(k) + 2 :=
  reflexivity(Test.double(k) + 2)

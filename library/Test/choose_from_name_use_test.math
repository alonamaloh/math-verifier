-- Regression: a `claim h : ∃…;` consumed by `choose v from h;` must NOT
-- be flagged `unused name h`. The `from <source>` clause references the
-- hypothesis name (it destructures that specific existential), so the
-- usage tracker must count it as a use — see surfaceMentionsName's
-- SurfaceChoose case (warnings.cpp).

module Test.choose_from_name_use_test

import axioms
import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.order

theorem choose_from_named_claim
        (older : ∃ (n : Natural). n = zero)
        (newer : ∃ (n : Natural). 1 ≤ n)
        : ∃ (n : Natural). n = zero := {
  claim chosenOlder : ∃ (n : Natural). n = zero by older;
  choose z such that z = zero from chosenOlder;
  witness z with done
}

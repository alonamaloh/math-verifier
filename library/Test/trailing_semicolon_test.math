-- A stray trailing `;` on a block's last proof step is ignored: the step is
-- still the block's result, exactly as if the `;` weren't there. (To instead
-- auto-close the goal from the accumulated facts, write `goal` explicitly.)

module Test.trailing_semicolon_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

-- (1) Trailing `;` on a final calc — the calc is still the proof.
theorem trailing_calc (a b c : Natural) (h1 : a = b) (h2 : b = c) : a = c := {
  calc a = b = c;
}

-- (2) Trailing `;` on a final `claim … by …` — its proof is the result.
theorem trailing_claim (P : Proposition) (hP : P) : P := {
  claim P by hP;
}

-- (3) An intermediate fact, then a final claim with a trailing `;`.
theorem trailing_after_step (a b : Natural) (h : a = b) : b = a := {
  claim b = a by Equality.symmetry(h);
}

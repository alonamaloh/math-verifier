-- The equality battery's `field` seat (F2, B3-residue forensics):
-- a division-bearing `=` goal that `ring` cannot see (the reciprocal is
-- an opaque atom to the polynomial normaliser) closes bare — the battery
-- clears denominators via `field`, discharging the nonzero side
-- conditions structurally. Pinned here so the ε/2 idiom of the analysis
-- files (`ε/4 + ε/4 = ε/2`, hintless) stays by-less.

module Test.field_battery_test

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.order
import Integer.basics
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.order
import Rational.reciprocal_function
import Rational.division
import Rational.ground_arithmetic
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.order
import Real.division
import Real.absolute_value

-- The headline shape at ℝ, as a claim.
theorem Test.field_battery_test.quarters_real (ε : Real)
        : ε / 4 + ε / 4 = ε / 2 := {
  done
}

-- The same shape as a bare calc step inside a chain.
theorem Test.field_battery_test.quarters_in_chain (x ε : Real)
        (bound : x ≤ ε / 4 + ε / 4)
        : x ≤ ε / 2 := {
  x
     ≤ ε / 4 + ε / 4
     = ε / 2;
  done
}

-- The ℚ twin (total reciprocal_function under the honest `/`).
theorem Test.field_battery_test.quarters_rational (q : Rational)
        : q / 4 + q / 4 = q / 2 := {
  done
}

-- A reciprocal product: 1/a · 1/b = 1/(a·b) with the nonzero facts in
-- context (the side conditions discharge from the hypotheses).
theorem Test.field_battery_test.reciprocal_product (a b : Real)
        (aNonzero : a ≠ 0) (bNonzero : b ≠ 0)
        : (1 / a) * (1 / b) = 1 / (a * b) := {
  done
}

-- Tests for `by_strong_induction on E with subject, ih { body }` —
-- single-step strong induction with carrier-name lookup of the
-- induction principle. The elaborator builds `<CarrierType>.strong_induction`
-- and uses it as the lemma, so the user writes the math without
-- spelling out the principle.

module Test.by_strong_induction_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.strong_recursion

-- (1) Trivial reflexivity-by-strong-induction: just demonstrates the
-- machinery wires up — the body has the subject and inductionHypothesis
-- in scope and proves the goal at subject. The auto-prover doesn't use
-- the IH here; this is purely a wiring check.
theorem strong_induction_refl (n : Natural) : n = n :=
  by_strong_induction on n with subject, inductionHypothesis {
    reflexivity(subject)
  }

-- (2) Same shape, fixed predicate: the conclusion mentions
-- `subject = subject` so we don't need to compute a motive over a
-- caller-supplied predicate. Demonstrates the wiring with the
-- `subject` binder visible in the body.
theorem strong_induction_self_eq (n : Natural) : n + zero = n + zero :=
  by_strong_induction on n with subject, inductionHypothesis {
    reflexivity(subject + zero)
  }

-- (5) Auto-generalize: `equation : n = 0` depends on the scrutinee `n`.
-- The body uses it refined to `subject = 0` (= the goal at subject), so
-- without auto-generalize the un-reverted `equation : n = 0` would not
-- match. The lemma-based path reverts it automatically (no `refining`).
theorem strong_induction_auto_generalize (n : Natural) (equation : n = 0)
        : n = 0 :=
  by_strong_induction on n with subject, inductionHypothesis {
    equation
  }

-- (6) Outer-parameter motive: the goal `r + n = n + r` mentions an
-- outer binder `r`, so the built motive `λsubject. r + subject = …`
-- references `r`. Regression for the "unbound internal variable r"
-- bug: the lemma-based path inferred the remaining type in OPENED form
-- (outer binders as free variables) and then embedded a sub-term of it
-- as the IH lambda's domain in the returned closed-form term, leaving
-- `r` dangling. Fixed by closing the inferred type back over the local
-- binders before extraction. (The motive-free cases above never
-- exercised this because their motives reference no outer binder.)
theorem strong_induction_outer_parameter_motive
        (r : Natural) (n : Natural)
        : r + n = n + r :=
  by_strong_induction on n with subject, inductionHypothesis {
    Natural.add_commutative(r, subject)
  }

-- (7) Same, with the goal additionally Pi-quantified under the subject
-- AND mentioning the outer parameter — the shape that bit
-- `Polynomial.gcd_bezout` (which had to drop to an explicit
-- `Natural.strong_induction` with a hand-spelled motive).
theorem strong_induction_outer_parameter_pi_motive
        (r : Natural) (n : Natural)
        : (y : Natural) → y ≤ n → r + y = y + r :=
  by_strong_induction on n with subject, inductionHypothesis {
    function (y : Natural) (yBound : y ≤ subject) =>
      Natural.add_commutative(r, y)
  }

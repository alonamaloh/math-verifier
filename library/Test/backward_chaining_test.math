module Test.backward_chaining_test
import Natural.basics
import Natural.order
import Natural.add_order

-- (A) by-less transitivity: does the bridge prove a ≤ c from h1, h2?
theorem Test.bw_bridge (a b c : Natural) (h1 : a ≤ b) (h2 : b ≤ c) : a ≤ c := {
  claim a ≤ c;
}

-- (B) backward-chaining citation: le_antisymmetric needs a≤c (bridge) and c≤a (h3).
theorem Test.bw_antisym (a b c : Natural) (h1 : a ≤ b) (h2 : b ≤ c) (h3 : c ≤ a) : a = c := {
  claim a = c by Natural.le_antisymmetric;
}

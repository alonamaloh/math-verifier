-- The ℂ `/` operator from a consumer: the side condition discharges from
-- a hypothesis in scope, and ComplexNumber.divide_cancel matches the goal
-- by binding its `bNonzero` slot to that hypothesis.

module Test.complex_division_test

import Logic.basics
import Equality.basics
import Real.basics
import Real.instances
import Polynomial.basics
import Polynomial.instances
import RingModulo.basics
import RingModulo.operations
import RingModulo.ring
import RingModulo.instances
import ComplexNumber.basics
import ComplexNumber.division

theorem use_complex_divide_cancel (a b : ComplexNumber)
        (bNonzero : b ≠ RingModulo.zero(Real.polynomial_commutative_ring, Complex.definingPolynomial))
        : b * (a / b) = a :=
  done since ComplexNumber.divide_cancel

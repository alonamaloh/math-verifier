-- Test/det_seven_safe_converse_test.math
--
-- Executable controls for the conservative residue predicate.  The
-- elaborated declaration shapes are checked separately by
-- scripts/check_det7_statement_shapes.sh.

module Test.det_seven_safe_converse_test

import Algebra.det_seven_safe_converse

theorem Test.detSevenSafe_definition_shape (n : ℕ)
        : Natural.IsDetSevenSafe(n)
          = (Natural.modulo(n, 12) ≠ 7
            ∧ Natural.modulo(n, 12) ≠ 10
            ∧ Natural.modulo(n, 49) ≠ 0
            ∧ Natural.modulo(n, 49) ≠ 21
            ∧ Natural.modulo(n, 49) ≠ 35
            ∧ Natural.modulo(n, 49) ≠ 42) :=
  done by unfolding Natural.IsDetSevenSafe

theorem Test.detSevenSafeConverse_definition_shape
        : Matrix.DetSevenSafeConverse
          = (∀ (n : ℕ). n ≥ 1 → Natural.IsDetSevenSafe(n) →
              Matrix.Represents(Matrix.squarePlusDoubleSquareOddForm(4), (n : ℤ))) :=
  done by unfolding Matrix.DetSevenSafeConverse

theorem Test.detSevenSafe_one : Natural.IsDetSevenSafe(1) :=
  done by unfolding Natural.IsDetSevenSafe

theorem Test.detSevenSafe_two : Natural.IsDetSevenSafe(2) :=
  done by unfolding Natural.IsDetSevenSafe

theorem Test.detSevenSafe_thirteen : Natural.IsDetSevenSafe(13) :=
  done by unfolding Natural.IsDetSevenSafe

theorem Test.detSevenSafe_rejects_seven : ¬(Natural.IsDetSevenSafe(7)) :=
  done by unfolding Natural.IsDetSevenSafe

theorem Test.detSevenSafe_rejects_ten : ¬(Natural.IsDetSevenSafe(10)) :=
  done by unfolding Natural.IsDetSevenSafe

theorem Test.detSevenSafe_rejects_twenty_one : ¬(Natural.IsDetSevenSafe(21)) :=
  done by unfolding Natural.IsDetSevenSafe

theorem Test.detSevenSafe_rejects_thirty_five : ¬(Natural.IsDetSevenSafe(35)) :=
  done by unfolding Natural.IsDetSevenSafe

theorem Test.detSevenSafe_rejects_forty_two : ¬(Natural.IsDetSevenSafe(42)) :=
  done by unfolding Natural.IsDetSevenSafe

theorem Test.detSevenSafe_rejects_forty_nine : ¬(Natural.IsDetSevenSafe(49)) :=
  done by unfolding Natural.IsDetSevenSafe

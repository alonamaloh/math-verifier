-- D Phase-1: a consumer sees ONLY the interface view — the obligation
-- theorem cites, and the carrier is abstract (see the sealing
-- ErrorTest for the negative side).
module Test.counter_consumer

import Logic.basics
import Equality.basics
import Natural.basics
import Test.counter_interface

theorem Test.consumer_cites_obligation
        : Test.Counter.read(Test.Counter.start) = 0 :=
  Test.Counter.read_of_start

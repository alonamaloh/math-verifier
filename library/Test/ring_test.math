-- Test the `ring` tactic.
--
-- v1 scope (current): the keyword is wired into the parser and
-- elaborator; the recognizer for pure-multiplication products is in
-- place; canonical-form comparison works. The proof emitter is the
-- remaining piece — for a non-trivial rearrangement v1 reports
-- "factor multiset matches but order differs — v1 does not yet emit
-- the rearrangement proof" and tells the user to fall back to manual
-- chains. The infrastructure is scaffolded for a proper v2 to plug
-- in insertion-sort-style proof generation using
-- `<T>.multiply_commutative` + `<T>.multiply_associative`.
--
-- Until v2 lands, `ring` is most useful as a documentation marker —
-- it identifies goals that *would* close by ring rewrites, and fails
-- loudly enough that calc chains remain the working implementation.

module Test.ring_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.ring

-- (1) Trivial: structurally identical, factors aligned.
theorem ring_reflexive (a : Integer) : a = a := ring

-- (2) Non-trivial rearrangements (placeholder until v2 lands).
theorem ring_product_swap_pending (a b : Integer) : a * b = b * a := sorry
theorem ring_assoc_pending (a b c : Integer)
        : (a * b) * c = a * (b * c) := sorry

-- Test the `ring` tactic — emits a proof chain of associativity +
-- commutativity steps when both sides of the goal flatten to the
-- same multiset of factors (pure-multiplication only; no sums yet).

module Test.ring_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.ring

-- (1) Trivial: structurally identical, factors aligned.
theorem ring_reflexive (a : Integer) : a = a := ring

-- (2) Pure swap.
theorem ring_product_swap (a b : Integer) : a * b = b * a := ring

-- (3) Re-association.
theorem ring_assoc (a b c : Integer) : (a * b) * c = a * (b * c) := ring

-- (4) Multi-factor reordering.
theorem ring_three_factor_swap (a b c : Integer)
        : a * b * c = c * b * a := ring

-- (5) Four factors, full reverse.
theorem ring_four_factor_reverse (a b c d : Integer)
        : a * b * c * d = d * c * b * a := ring

-- (6) Mixed associativity + reordering.
theorem ring_mixed (a b c d : Integer)
        : (a * b) * (c * d) = (d * a) * (b * c) := ring

-- (7) Additive: ring falls back to the .add axioms when the goal is
-- a pure-sum rearrangement.
theorem ring_add_swap (a b : Integer) : a + b = b + a := ring

-- (8) Additive associativity.
theorem ring_add_assoc (a b c : Integer)
        : (a + b) + c = a + (b + c) := ring

-- (9) Additive multi-factor reordering.
theorem ring_add_three_factor_swap (a b c : Integer)
        : a + b + c = c + b + a := ring

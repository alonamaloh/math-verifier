module Test.coercion_packet_audit

-- B3.4 — the morphism-packet audit surface. This module imports every
-- file that houses a coercion-packet lemma, so `make audit-coercions`
-- (which re-verifies it under MATH_AUDIT_COERCION_PACKETS=1) sees the
-- full packet inventory for each registered hop and reports the
-- missing slots. When a packet lemma moves house, update the imports
-- here — the audit report going red on a slot that exists is the
-- signal.

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order
import Integer.basics
import Integer.embedding
import Integer.order
import Integer.sign
import Integer.divisibility
import Rational.basics
import Rational.embedding
import Rational.archimedean
import Real.basics
import Real.embedding
import Real.addition
import Real.multiplication
import Real.embedding_order
import GaussianInteger.basics
import GaussianInteger.norm_natural

theorem coercion_packet_audit_anchor : (0 : Natural) = 0 :=
  reflexivity(Natural, 0)

-- F2 (PLAN_ERGONOMICS.md): an argument-free citation of a generic ring
-- lemma discharges its `IsRing(carrier, …)` premise from the registered
-- canonical `instance` (`Rational.is_ring` / `Integer.is_ring` /
-- `Real.is_ring`), the same way a direct application does — no explicit
-- `claim IsRing(…)` and no positional `..., <carrier>.is_ring, ...`.
module Test.instance_premise_discharge_test

import Rational.instances
import Integer.instances
import Real.instances
import Algebra.ring_lemmas

-- `Ring.zero_multiply : zero · x = zero`; its `ringProof` premise resolves
-- from `instance Rational.is_ring`.
theorem Test.rational_zero_multiply (x : Rational)
        : Rational.zero * x = Rational.zero := {
  done by Ring.zero_multiply
}

theorem Test.integer_zero_multiply (x : Integer)
        : Integer.zero * x = Integer.zero := {
  done by Ring.zero_multiply
}

theorem Test.real_zero_multiply (x : Real)
        : Real.zero * x = Real.zero := {
  done by Ring.zero_multiply
}

-- The `_right` twin and a negate lemma, to exercise more of the premise
-- discharge (multiple sibling binders pinned through the instance).
theorem Test.rational_multiply_zero (x : Rational)
        : x * Rational.zero = Rational.zero := {
  done by Ring.multiply_zero
}

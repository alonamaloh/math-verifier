-- Smoke tests for the p-adic construction.

module Test.padic_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.prime
import Natural.prime_two
import Rational.basics
import PAdic.absolute_value
import PAdic.basics
import PAdic.embedding

-- 2-adic absolute value, zero/one constants exist.
theorem padic_two_zero_is_padic
        : PAdic.zero(2, Natural.is_prime_two)
          = PAdic.zero(2, Natural.is_prime_two) :=
  reflexivity(PAdic(2, Natural.is_prime_two),
              PAdic.zero(2, Natural.is_prime_two))

theorem padic_two_one_is_padic
        : PAdic.one(2, Natural.is_prime_two)
          = PAdic.one(2, Natural.is_prime_two) :=
  reflexivity(PAdic(2, Natural.is_prime_two),
              PAdic.one(2, Natural.is_prime_two))

-- Embedding from Rational is well-typed for prime p (witnessed by
-- a primality proof).
theorem padic_embedding_well_typed
        (p : Natural) (primality : Natural.is_prime(p)) (q : Rational)
        : Rational.to_padic(p, primality, q)
          = Rational.to_padic(p, primality, q) :=
  reflexivity(PAdic(p, primality), Rational.to_padic(p, primality, q))

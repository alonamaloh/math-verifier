-- Smoke tests for the p-adic construction.

module Test.padic_test

import Logic.basics
import Equality.basics
import Natural.basics
import Rational.basics
import PAdic.absolute_value
import PAdic.basics
import PAdic.embedding

-- 2-adic absolute value, zero/one constants exist.
theorem padic_two_zero_is_padic : PAdic.zero(2) = PAdic.zero(2) :=
  reflexivity(PAdic(2), PAdic.zero(2))

theorem padic_two_one_is_padic : PAdic.one(2) = PAdic.one(2) :=
  reflexivity(PAdic(2), PAdic.one(2))

-- Embedding from Rational is well-typed for arbitrary primes.
theorem padic_embedding_well_typed (p : Natural) (q : Rational)
        : Rational.to_padic(p, q) = Rational.to_padic(p, q) :=
  reflexivity(PAdic(p), Rational.to_padic(p, q))

-- Feature test: B4 order automation — monotonicity rules indexed by
-- head symbol; single-position-diff ≤/< calc steps close BY-LESS the
-- way = steps do, with structural recursion through nested heads.

module Test.monotonicity_index_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Rational.basics
import Rational.embedding
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.order
import Real.absolute_value

-- Nested by-less order step: peels add-monotonicity twice, then the
-- hypothesis. (Natural.add_preserves_LessOrEqual-style rules register
-- from their statement shape automatically.)
theorem Test.nested_order_step (a b c d : Natural) (h : a ≤ b)
        : c + (d + a) ≤ c + (d + b) := {
  calc c + (d + a)
     ≤ c + (d + b)
}

-- Strict at Natural, nested — the new add_left_strict_monotone peels
-- twice by-less (this was a library gap the B4 audit exposed).
theorem Test.strict_natural_step (a b c d : Natural) (h : a < b)
        : c + (d + a) < c + (d + b) := {
  calc c + (d + a)
     < c + (d + b)
}

-- Strict version through one layer, at another carrier (Real's
-- right-addend lemma registers under (lt, Real.LessThan, Real.add)).
theorem Test.strict_order_step (a b c : Real) (h : a < b)
        : a + c < b + c := {
  calc a + c
     < b + c
}

-- One-sided rule (bare left side): x < x + e from 0 < e — the starred
-- key binds the bare side to the goal's left operand.
theorem Test.one_sided_step (x e : Real) (h : 0 < e)
        : x < x + e := {
  calc x
     < x + e
}

-- Mixed-head rule: the triangle inequality (abs vs +) as a by-less step.
theorem Test.mixed_head_step (x y : Real)
        : Real.absolute_value(x + y) ≤ Real.absolute_value(x) + Real.absolute_value(y) := {
  calc Real.absolute_value(x + y)
     ≤ Real.absolute_value(x) + Real.absolute_value(y)
}

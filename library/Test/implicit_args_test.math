-- Test that implicit-argument syntax `{x : T}` works on
-- definitions and theorems (not just axioms).

module Test.implicit_args_test

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics

-- A trivial polymorphic identity function with the type implicit.
definition identity_implicit {T : Type(0)} (x : T) : T :=
  x

-- Use it: don't pass T.
theorem identity_implicit_test (n : Natural) : Natural :=
  identity_implicit(n)

-- Polymorphic theorem with implicit T: refl.
theorem refl_implicit {T : Type(0)} (x : T) : x = x :=
  reflexivity(T, x)

theorem refl_implicit_test (n : Natural) : n = n :=
  refl_implicit(n)

-- ----------------------------------------------------------------------
-- Leading-implicit insertion: a function `f {m} (x : C(m))` must get
-- `{m}` inserted and inferred even when no expected type guides the
-- call. `Tagged` is a parameterized type standing in for IntegerMod(m)
-- and friends.

inductive Tagged (m : Natural) : Type(0) where
  | Tagged.make : Tagged(m)

definition tagged_identity {m : Natural} (x : Tagged(m)) : Tagged(m) :=
  x

-- Direct call with the implicit recovered from the argument's type,
-- under a polymorphic head that supplies NO concrete expected type to
-- the inner call (forward inference, not backward).
theorem tagged_identity_no_expected (m : Natural) (x : Tagged(m))
        : Tagged(m) :=
  identity_implicit(tagged_identity(x))

-- Bare implicit-leading function handed to a higher-order parameter:
-- `tagged_identity` is passed where `Tagged(m) → Tagged(m)` is expected,
-- so the leading `{m}` is inserted by backward unification against that
-- expected function type.
definition apply_unary (m : Natural)
        (f : Tagged(m) → Tagged(m)) (x : Tagged(m)) : Tagged(m) :=
  f(x)

theorem tagged_identity_bare_higher_order (m : Natural) (x : Tagged(m))
        : Tagged(m) :=
  apply_unary(m, tagged_identity, x)

-- ----------------------------------------------------------------------
-- Forward leading-implicit inference for a Definition-headed domain with
-- NO expected type: a lemma whose implicit shape args appear only inside
-- the proof arguments' types, called nested under a polymorphic head, so
-- {a, b, c, d} are recovered by forward unification from the proof args
-- alone. (`Related` is a Definition standing in for `≤`.) This covers the
-- forward path generally; the specific "structural attempt before WHNF"
-- ordering in inferLeadingArguments is exercised by the Rational order
-- lemmas (LessOrEqual.sum, LessThan.weaken/distinct, now stated with
-- implicit shape args) and their use sites in Real/supremum.math, where a
-- relation that unfolds to `∃ k. (b - a) = (k : R)` needs the FOLDED `≤`
-- head matched before WHNF strips it.

definition Related (a b : Natural) : Type(0) := ∃ (anyNatural : Natural). a = b

theorem related_combine {a b c d : Natural}
        (first : Related(a, b)) (second : Related(c, d))
        : Related(a, b) :=
  first

theorem related_combine_no_expected
        (p q : Natural) (h1 : Related(p, q)) (h2 : Related(q, p))
        : Related(p, q) :=
  -- identity_implicit elaborates its argument with no concrete expected
  -- type, so {a, b, c, d} of related_combine can only be recovered by
  -- forward unification against h1 : Related(p, q) and h2 : Related(q, p).
  identity_implicit(related_combine(h1, h2))

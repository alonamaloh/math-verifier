module Test.numeral_table_check

-- Surface module for the numeral-table self-check (`make tests` runs
-- `MATH_CHECK_NUMERAL_TABLE=1` against it): imports every Natural
-- operation the kernel's accelerated GMP table covers, so the check
-- can evaluate each library definition and compare (PLAN_FAST_NUMERALS §B).

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.monus
import Natural.power
import Natural.floor_divide
import Natural.factorial
import Natural.maximum

theorem Test.numeral_table_surface : (0 : Natural) = 0 :=
  done

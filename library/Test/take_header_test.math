-- `take ε > 0;` (A6 acceptance opener): the combined take header. It
-- desugars EXACTLY to the two-statement analytic opener — `take ε;`
-- (the binder type inferred from the goal's Π) followed by an anonymous
-- `suppose ε > 0;` (statement-addressable, no `as` clause). The five
-- relations `>`, `≥`, `<`, `≤`, `≠` select the form; `>`/`≥` reverse
-- onto `<`/`≤` exactly as any relation does.

module Test.take_header_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order

-- The canonical opener: a genuine ∀-ε-with-positivity Π whose codomain
-- is an implication. `take ε > 0;` introduces both ε and its positivity.
theorem Test.take_header_positivity
        : (ε : Natural) → ε > 0 → ε > 0 := {
  take ε > 0;
  done
}

-- `≥` desugars through the same reversal the relation parser uses.
theorem Test.take_header_geq
        : (ε : Natural) → ε ≥ 1 → ε ≥ 1 := {
  take ε ≥ 1;
  done
}

-- `≤` and `<`, the un-reversed relations.
theorem Test.take_header_leq
        : (n : Natural) → n ≤ 5 → n ≤ 5 := {
  take n ≤ 5;
  done
}

theorem Test.take_header_less
        : (n : Natural) → n < 5 → n < 5 := {
  take n < 5;
  done
}

-- `≠` lives at the equality level but selects the header just the same.
theorem Test.take_header_neq
        : (n : Natural) → n ≠ 0 → n ≠ 0 := {
  take n ≠ 0;
  done
}

-- The anonymous hypothesis is statement-addressable: a later step picks
-- it up by type to discharge a differently-spelled goal.
theorem Test.take_header_used_downstream
        : (ε : Natural) → ε > 0 → 0 < ε := {
  take ε > 0;
  done
}

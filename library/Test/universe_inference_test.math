-- Test/universe_inference_test.math
--
-- Probe whether Stage 2 universe-argument inference handles the common
-- universe-polymorphic constants without `.{u}` annotations. Each
-- declaration that compiles is one fewer place where `.{0}` is forced
-- on user code.

module Test.universe_inference_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics

-- (1) `Equality(...)` without `.{0}`: must infer u=0 from `Natural`.
theorem inference_equality (a : Natural) : a = a :=
  reflexivity(Natural, a)

-- (2) `Equality.symmetry(...)` without `.{0}`: must infer u from the
-- proof's Equality.
theorem inference_symmetry (a b : Natural)
        (proof : a = b)
        : b = a :=
  Equality.symmetry(proof)

-- (3) `Equality.transitivity(...)` without `.{0}`: must infer u from
-- the first proof.
theorem inference_transitivity (a b c : Natural)
        (proof1 : a = b)
        (proof2 : b = c)
        : a = c :=
  Equality.transitivity(proof1, proof2)

-- (4) `Quotient.mk(T, R, x)` without `.{u}`: must infer u from T.
theorem inference_quotient_mk
        (T : Type(0)) (R : T → T → Proposition) (x : T)
        : Quotient(T, R) :=
  Quotient.mk(T, R, x)

-- (5) `Quotient.sound(T, R, x, y, h)` without `.{u}`: must infer u from
-- T or from the proof's relation type.
theorem inference_quotient_sound
        (T : Type(0)) (R : T → T → Proposition)
        (x y : T) (h : R(x, y))
        : Equality(Quotient(T, R), Quotient.mk(T, R, x), Quotient.mk(T, R, y)) :=
  Quotient.sound(T, R, x, y, h)

-- (6) `Quotient.induct(T, R, motive, f, q)` without `.{u}`.
theorem inference_quotient_induct
        (T : Type(0)) (R : T → T → Proposition)
        (motive : Quotient(T, R) → Proposition)
        (f : (x : T) → motive(Quotient.mk(T, R, x)))
        (q : Quotient(T, R))
        : motive(q) :=
  Quotient.induct(T, R, motive, f, q)

-- (7) `Quotient.lift(T, R, U, f, h, q)` without `.{u, v}`: must infer
-- BOTH universes — `u` from T and `v` from U.
theorem inference_quotient_lift
        (T : Type(0)) (R : T → T → Proposition) (U : Type(0))
        (f : T → U)
        (h : (x y : T) → R(x, y) → f(x) = f(y))
        (q : Quotient(T, R))
        : U :=
  Quotient.lift(T, R, U, f, h, q)

-- (8) `Quotient(T, R)` as a type expression. Used inside `definition
-- Integer := Quotient(...)` style declarations.
definition inference_quotient_type
        (T : Type(0)) (R : T → T → Proposition)
        : Type(0) :=
  Quotient(T, R)

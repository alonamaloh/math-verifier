module Test.square_notation

-- The postfix `²` notation: `E²` is parse-time sugar for `E * E`, so it
-- means squaring at any carrier with a `*` operator, binds tighter than
-- every binary operator, and is interchangeable with the spelled-out
-- product in statements and citations.

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order
import Real.interface

-- Identical to the spelled-out form, definitionally and syntactically.
theorem Test.square_is_product (k : Natural) : k² = k * k :=
  done

-- Binds tighter than `*`: 2 * n² is 2 * (n * n).
theorem Test.square_precedence (n : Natural) : 2 * n² = 2 * (n * n) :=
  done

-- Compound bases parenthesize; ring reasons through the sugar.
theorem Test.square_compound (a b : Natural)
        : (a + b)² = a² + 2 * (a * b) + b² :=
  ring

-- Any carrier with `*`: the sealed Real interface included.
theorem Test.square_at_real (x : Real) : x² = x * x :=
  done

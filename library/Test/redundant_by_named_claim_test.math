-- Regression: the redundant-`by` warning on a NAMED claim names the
-- claim (several multi-line claims in a row make an unnamed warning
-- easy to pin on the wrong one).
module Test.redundant_by_named_claim_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

theorem Test.named_redundant_by_warning (a b : Natural) (h : a = b)
        : 0 = 0 := {
  claim restated : a = b by h;
  claim restated2 : b = a by Equality.symmetry(Natural, a, b, restated);
  done
}

-- Regression: the redundant-`by` warning on a NAMED statement names the
-- statement (several multi-line named statements in a row make an unnamed
-- warning easy to pin on the wrong one).
module Test.redundant_by_named_claim_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

theorem Test.named_redundant_by_warning (a b : Natural) (h : a = b)
        : 0 = 0 := {
  a = b by h as restated;
  b = a by Equality.symmetry(Natural, a, b, restated) as restated2;
  done
}

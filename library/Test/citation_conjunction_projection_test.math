-- Feature test (A2 stage 2): citing a fact whose conclusion is a
-- conjunction proves a goal matching ONE leg — the citation machinery
-- instantiates the fact and wraps the matching projection, so the
-- unused leg never reaches the page.
module Test.citation_conjunction_projection_test

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order

-- Left leg of a quantified conjunction.
theorem Test.project_left (P Q : Natural → Proposition) (m : Natural)
        (h : ∀ (k : Natural). P(k) ∧ Q(k))
        : P(m) := {
  P(m) by h;
  done
}

-- Right leg.
theorem Test.project_right (P Q : Natural → Proposition) (m : Natural)
        (h : ∀ (k : Natural). P(k) ∧ Q(k))
        : Q(m) := {
  Q(m) by h;
  done
}

-- The fact's premises discharge from context as usual.
theorem Test.project_through_premise (P Q : Natural → Proposition)
        (m : Natural)
        (mPositive : 1 ≤ m)
        (h : ∀ (k : Natural). 1 ≤ k → P(k) ∧ Q(k))
        : P(m) := {
  P(m) by h;
  done
}

-- Whole-proof citation form.
theorem Test.project_whole_body (P Q : Natural → Proposition) (m : Natural)
        (h : ∀ (k : Natural). P(k) ∧ Q(k))
        : Q(m) := by h

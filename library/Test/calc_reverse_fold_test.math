-- Regression for the calc whole-endpoint reverse fold (PLAN_READABILITY
-- B5). A `by <forward-lemma>` whose type is `A = B` closes a step stated
-- `B = A` — the elaborator wraps it in Equality.symmetry. The structural
-- congruence diff-walk cannot bridge this case (the endpoints have
-- different heads — `add` vs `Sum` — and match only up to opaque `monus`
-- reduction under the summation lambda); the symmetric pre-check does.
-- Before the fix this required `by Equality.symmetry(?, ?, <lemma>)`.

module Test.calc_reverse_fold_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.monus
import Algebra.monoid
import Algebra.ring
import Algebra.ring_bundle
import Polynomial.basics
import Algebra.ring_summation

theorem Test.reverse_fold_with_monus
        (r : Ring) (f : Natural → Ring.carrier(r)) (k : Natural)
        : Ring.add(r, f(Natural.monus(successor(k), 0)),
              Ring.Sum(r, (j : Natural) ↦ f(Natural.monus(k, j)), k))
          = Ring.Sum(r, (i : Natural) ↦ f(Natural.monus(successor(k), i)), successor(k)) :=
  {
  -- Reindex the tail by monus_succ_succ (pointwise under the Σ), then the
  -- add-vs-Sum endpoints match by Sum.shift up to symmetry.
  claim tailReindex
      : Ring.Sum(r, (j : Natural) ↦ f(Natural.monus(k, j)), k)
        = Ring.Sum(r, (j : Natural) ↦ f(Natural.monus(successor(k), successor(j))), k)
    by Ring.Sum.extensional(r,
           (j : Natural) ↦ f(Natural.monus(k, j)),
           (j : Natural) ↦ f(Natural.monus(successor(k), successor(j))),
           (j : Natural) ↦
               calc f(Natural.monus(k, j))
                  = f(Natural.monus(successor(k), successor(j)))
                      by substituting Natural.monus_succ_succ,
           k);
  calc Ring.add(r, f(Natural.monus(successor(k), 0)),
           Ring.Sum(r, (j : Natural) ↦ f(Natural.monus(k, j)), k))
     = Ring.add(r, f(Natural.monus(successor(k), 0)),
           Ring.Sum(r, (j : Natural) ↦ f(Natural.monus(successor(k), successor(j))), k))
         by substituting tailReindex
     = Ring.Sum(r, (i : Natural) ↦ f(Natural.monus(successor(k), i)), successor(k))
         by Ring.Sum.shift(r,
                (i : Natural) ↦ f(Natural.monus(successor(k), i)), k)
  }

-- Simplest reverse fold (already worked via the per-level symmetric leaf,
-- kept so the easy case is covered too): lemma `a + b = c`, step `c = a + b`.
theorem Test.reverse_fold_simple
        (a b c : Natural) (lemma : a + b = c)
        : c = a + b :=
  calc c = a + b   by lemma

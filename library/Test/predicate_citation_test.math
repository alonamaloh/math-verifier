-- Citing a lemma whose conclusion is `P(x)` for a quantified predicate P:
-- the conclusion can't pin anything (its head is the predicate itself),
-- so the premises must recover P and x — including through a definition
-- that folds the premise's rigid head (coprime_residues vs filter).

module Test.predicate_citation_test

import axioms
import Logic.basics
import Natural.basics
import Natural.order
import Natural.gcd
import Natural.totient
import Lists.list
import Lists.range
import Lists.filter

-- The general filter lemma, cited argument-free at a folded list.
theorem predicate_cite_through_definition (n j : Natural)
        (jMember : List.member(Natural, j, Natural.coprime_residues(n)))
        : Natural.coprime(j, n) := {
  claim Natural.coprime(j, n) by List.filter_member_property;
  done
}

-- Same, with the membership conclusion (subset direction).
theorem predicate_cite_subset (n j : Natural)
        (jMember : List.member(Natural, j, Natural.coprime_residues(n)))
        : List.member(Natural, j, List.range_down(n)) := {
  claim List.member(Natural, j, List.range_down(n))
      by List.filter_member_subset;
  done
}

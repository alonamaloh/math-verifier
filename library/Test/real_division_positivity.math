module Test.real_division_positivity

-- Honest (partial) division on Real is ergonomic when the denominator is
-- manifestly positive: the `/` operator's `b ≠ 0` obligation is discharged by
-- the auto-prover, which routes `b ≠ 0` through the automatic
-- `Real.nonzero_of_positive` and recursively proves `0 < b`. For a CAST
-- denominator this needs the positivity tower automatic — the per-hop
-- `positive_preserves` rungs (`Natural.to_integer`, `Integer.to_rational`,
-- `Rational.to_real`) chained by the auto-prover.

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.order
import Rational.basics
import Rational.embedding
import Rational.order
import Rational.archimedean
import Real.basics
import Real.embedding
import Real.embedding_order
import Real.order
import Real.apartness
import Real.reciprocal
import Real.field
import Real.division

-- Generic: ANY positive natural casts to a positive/nonzero real, and can be
-- divided by — for a bound variable, discharged from the hypothesis alone.
theorem Test.generic_positive (n : Natural) (nPositive : 0 < n)
        : Real.zero < ((n : Natural) : Real) :=
  done

definition Test.generic_reciprocal (n : Natural) (nPositive : 0 < n) : Real :=
  (1 : Real) / ((n : Natural) : Real)

-- The `1 + k` special case (no hypothesis — positivity of 1 + k is automatic).
theorem Test.one_plus_positive (k : Natural)
        : Real.zero < ((1 + k : Natural) : Real) :=
  done

definition Test.reciprocal_term (k : Natural) : Real :=
  (1 : Real) / ((1 + k : Natural) : Real)

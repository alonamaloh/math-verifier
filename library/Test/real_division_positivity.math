module Test.real_division_positivity

-- Honest (partial) division on Real: the `/` operator's `b ≠ 0` obligation is
-- discharged automatically. Literal and hypothesis denominators go through the
-- general auto-prover. A CAST denominator is beyond its backward-chain depth
-- cap, so a dedicated structural fallback (`tryProveNonzero`, in the
-- elaborator) walks the cast tower — peeling `to_real`/`to_rational`/
-- `to_integer` and citing the per-hop `positive_preserves` rungs — down to a
-- Natural-level base fact the auto-prover CAN establish. Note the bare
-- positivity claims themselves (`Real.zero < (n : Real)` by `done`) are NOT
-- automatic — the tactic hooks only the `/` side-condition.

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.order
import Rational.basics
import Rational.embedding
import Rational.order
import Rational.archimedean
import Real.basics
import Real.embedding
import Real.embedding_order
import Real.order
import Real.apartness
import Real.reciprocal
import Real.field
import Real.division

-- ANY positive natural casts to a nonzero real and can be divided by: the
-- tower walk bottoms out at the `0 < n` hypothesis.
definition Test.generic_reciprocal (n : Natural) (nPositive : 0 < n) : Real :=
  1 / (n : Real)

-- The `1 + k` case, no hypothesis: the base fact `1 ≤ 1 + k` is automatic.
definition Test.reciprocal_term (k : Natural) : Real :=
  1 / (1 + k : Real)

-- Non-cast denominators, still through the general auto-prover: a literal and
-- a positivity hypothesis.
definition Test.recip_two : Real := (1 : Real) / (2 : Real)

definition Test.recip_hypothesis (x : Real) (xPositive : Real.zero < x) : Real :=
  (1 : Real) / x

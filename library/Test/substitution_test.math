-- Tests for the `claim P by substitution` and
-- `claim P by substituting <eq>` tactics — sugar over the equality
-- bridge that auto-finds equation + body in scope (or uses the
-- supplied equation).

module Test.substitution_test

import Logic.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Equality.basics

-- (1) Simplest case: one equality in scope, one body whose type
-- substitutes via it.
theorem subst_one_eq
        (a b : Natural) (aEqB : a = b) (P : Natural → Proposition)
        (hyp : P(a))
        : P(b) :=
  claim P(b) by substitution

-- (2) `claim by substitution` — works at any goal position.
theorem subst_with_goal
        (a b : Natural) (aEqB : a = b) (P : Natural → Proposition)
        (hyp : P(a))
        : P(b) :=
  claim by substitution

-- (3) Narrowed: supply the equation explicitly. Useful when
-- multiple equalities are in scope and you want to pin one.
theorem subst_narrowed
        (a b c : Natural) (aEqB : a = b) (bEqC : b = c)
        (P : Natural → Proposition) (hyp : P(b))
        : P(a) :=
  claim P(a) by substituting aEqB

-- (4) Reverse direction works too — the tactic tries both
-- directions of the supplied equality.
theorem subst_reverse_direction
        (a b : Natural) (aEqB : a = b) (P : Natural → Proposition)
        (hyp : P(b))
        : P(a) :=
  claim P(a) by substituting aEqB

-- (5) A calc step accepts `by substituting <eq>` exactly like a claim:
-- claim and calc-step `by` share one hint parser, so anything that works
-- on `claim P by H` works on a calc step `= P by H` and vice versa.
theorem subst_in_calc_step
        (a b c : Natural) (aEqB : a = b)
        : a + c = b + c :=
  calc a + c
     = b + c   by substituting aEqB

-- (6) Multiple occurrences in one calc step — the substitution rewrites
-- them all (where the by-lemma diff bridge, single-position only, can't).
theorem subst_multi_occurrence_calc
        (a b : Natural) (aEqB : a = b)
        : a + a = b + b :=
  calc a + a
     = b + b   by substituting aEqB

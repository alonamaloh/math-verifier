module Test.abstract_ring_ac_test

import Logic.basics
import Equality.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_difference
import Algebra.commutative_ring_bundle
import Algebra.integral_domain

-- The auto-prover's abstract-ring AC normaliser (proveAbstractRingAC,
-- fingerprint plan Phase 1). Over an ABSTRACT carrier `Ring.carrier(r)` the
-- registered-carrier `ring` tactic declines, and these by-less +/·
-- rearrangements used to fall through to the multi-second context-equality
-- bridge. They now close by direct AC normalisation: `+` is associative-
-- commutative in every ring, `·` is associative — and crucially NO
-- ·-commutativity is assumed (see the multiply_is_not_commuted note below).

-- A sum of products that is BOTH commuted (summands swapped) and internally
-- reassociated — beyond the single-position congruence walker, so it routes
-- to the AC normaliser.
theorem abstract_ring_ac_sum_of_products
        (r : Ring) (a b c d e f : Ring.carrier(r))
        : (a * b) * c + (d * e) * f = d * (e * f) + a * (b * c) := {
  calc (a * b) * c + (d * e) * f
     = d * (e * f) + a * (b * c);
}

-- Pure additive commutativity + associativity (four-term shuffle).
theorem abstract_ring_ac_add_shuffle
        (r : Ring) (a b c d : Ring.carrier(r))
        : (a + b) + (c + d) = (d + c) + (b + a) := {
  calc (a + b) + (c + d)
     = (d + c) + (b + a);
}

-- Multiplicative reassociation alone (no reordering), nested three deep.
-- (The normaliser does NOT sort `·` factors, so a goal needing genuine
-- ·-commutativity like `a * b = b * a` correctly does not close here — the
-- factor sequences differ and there is no commutative axiom to appeal to.)
theorem abstract_ring_ac_multiply_reassociate
        (r : Ring) (a b c d : Ring.carrier(r))
        : ((a * b) * c) * d = a * (b * (c * d)) := {
  calc ((a * b) * c) * d
     = a * (b * (c * d));
}

-- The SURFACE `ring` tactic now drives an abstract `Ring.carrier(r)` goal
-- (Phase 2): the registered-carrier normaliser declines such a carrier, so
-- `ring` routes to the non-commutative AC normaliser. (`Ring.add_four_swap`
-- in Algebra/ring_bundle is now `:= ring` on the strength of this.)
theorem abstract_ring_tactic_add (r : Ring) (a b c d : Ring.carrier(r))
        : (a + b) + (c + d) = (a + c) + (b + d) := ring

theorem abstract_ring_tactic_mixed (r : Ring) (a b c : Ring.carrier(r))
        : (a * b) * c + a = a + a * (b * c) := ring

-- Distributivity (Phase 2 increment 2a): products of sums expand to sums of
-- products over an abstract `Ring.carrier(r)`, via distributivity_left/right.
theorem abstract_ring_distribute_left (r : Ring) (a b c : Ring.carrier(r))
        : a * (b + c) = a * b + a * c := ring

theorem abstract_ring_distribute_both (r : Ring) (a b c d : Ring.carrier(r))
        : (a + b) * (c + d) = ((a * c + a * d) + b * c) + b * d := ring

-- Non-commutative square: the cross terms x·y and y·x stay DISTINCT (the
-- normaliser never reorders `·` factors), so this holds in every ring.
theorem abstract_ring_noncommutative_square (r : Ring) (x y : Ring.carrier(r))
        : (x + y) * (x + y) = ((x * x + x * y) + y * x) + y * y := ring

-- Identity elimination (Phase 2 increment 2b): drop additive `0`,
-- multiplicative `1`, annihilate `·0`, and `-0` — combined with
-- distributivity in one `ring` call.
theorem abstract_ring_identity_drop (r : Ring) (a b : Ring.carrier(r))
        : (a + Ring.zero(r)) * (Ring.one(r) + b) = a + a * b := ring

theorem abstract_ring_annihilate (r : Ring) (a b : Ring.carrier(r))
        : a * Ring.zero(r) + b = b := ring

-- Negation / subtraction (Phase 2 increment 2c): subtractions unfold,
-- negation pushes over sums, and additive-inverse pairs cancel.
theorem abstract_ring_negate_distribute (s : Ring) (a b : Ring.carrier(s))
        : Ring.negate(s, a + b) = Ring.negate(s, a) + Ring.negate(s, b) := ring

theorem abstract_ring_telescope (s : Ring) (g h k : Ring.carrier(s))
        : (g - h) + (h - k) = g - k := ring

theorem abstract_ring_three_cycle (s : Ring) (a b c : Ring.carrier(s))
        : (a - b) + (b - c) + (c - a) = Ring.zero(s) := ring

-- Double negation and sign extraction (Phase 2 follow-ups): negation
-- collapses, and a sign pulls out of a product to the monomial head so the
-- middle terms of a distributed difference cancel.
theorem abstract_ring_double_negate (s : Ring) (a : Ring.carrier(s))
        : Ring.negate(s, Ring.negate(s, a)) = a := ring

theorem abstract_ring_sign_extract (s : Ring) (a b : Ring.carrier(s))
        : Ring.negate(s, a) * b = Ring.negate(s, a * b) := ring

theorem abstract_ring_difference_multiply (s : Ring) (a a' b b' : Ring.carrier(s))
        : (a - a') * b + a' * (b - b') = a * b - a' * b' := ring

-- Commutativity from a bundle witness (Phase 4): over `Ring.carrier(s)` where
-- `s` is a commutative bundle (CommutativeRing / IntegralDomain), `ring`
-- sources the commutativity witness and sorts `·` factors, proving genuine
-- commutative-ring rearrangements. (Over a plain `Ring` these correctly do
-- NOT close — see plain_comm_should_fail in the kernel tests.)
theorem abstract_ring_commutative_swap
        (c : CommutativeRing) (a b : Ring.carrier(CommutativeRing.ring(c)))
        : a * b = b * a := ring

theorem abstract_ring_integral_domain_rearrange
        (d : IntegralDomain) (a b e : Ring.carrier(IntegralDomain.ring(d)))
        : (a * b) * e = e * (b * a) := ring

theorem abstract_ring_commutative_expand
        (c : CommutativeRing) (a b : Ring.carrier(CommutativeRing.ring(c)))
        : (a + b) * (a + b) = (a * a + b * b) + (a * b + a * b) := ring

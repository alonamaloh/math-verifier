-- `claim <proofTerm>;` — the mirror of the proposition-as-proof coercion.
-- A proof position may take a proposition (auto-proved); symmetrically, the
-- `claim` proposition position may take a PROOF, and the claim is its type.
-- So a named fact enters context without restating its (possibly long) type.

module Test.claim_proof_term_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano

-- A hypothesis proof: `claim h;` introduces `h`'s type, so its legs are usable.
theorem claim_proof_brings_fact (a b : Natural) (h : a = b ∧ b = a) : a = b := {
  claim h;        -- h : a = b ∧ b = a — its legs are now usable
  done
}

-- A conjunction assembled from named proofs — the `IsField` shape. Each
-- `claim <proof>` adds the exact-typed fact, so `done` conjoins them cheaply
-- (no decomposition / search), the way `⟨p, q⟩` would but without the tuple.
theorem claim_proof_assembles_conjunction
        (a b : Natural) (p : a = b) (q : b = a) : a = b ∧ b = a := {
  claim p;
  claim q;
  done
}

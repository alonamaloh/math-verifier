-- Test/forgetful_test.math
--
-- The forgetful (derived) instance: `Group.*` lemmas resolve their
-- `IsGroup` proof automatically from an in-scope `IsRing` via the registered
-- `IsRing.additive_group` projection — no explicit `claim IsGroup(…)`.

module Test.forgetful_test

import Logic.basics
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.ring

-- groupProof is IMPLICIT in Group.cancel_left; the operations come from the
-- hypothesis `h`, leaving identity/inverse to be read off the ring.
theorem forgetful_cancel_left
        (carrier : Type(0))
        ((+) : carrier → carrier → carrier)
        (zero : carrier)
        ((-) : carrier → carrier)
        ((·) : carrier → carrier → carrier)
        (one : carrier)
        (ringProof : IsRing(carrier, (+), zero, (-), (·), one))
        (a b : carrier)
        (h : a + b = a + zero)
        : b = zero :=
  done since Group.cancel_left

-- groupProof is EXPLICIT in Group.left_inverse_unique (Step 5b/5c path).
theorem forgetful_left_inverse_unique
        (carrier : Type(0))
        ((+) : carrier → carrier → carrier)
        (zero : carrier)
        ((-) : carrier → carrier)
        ((·) : carrier → carrier → carrier)
        (one : carrier)
        (ringProof : IsRing(carrier, (+), zero, (-), (·), one))
        (a b : carrier)
        (h : b + a = zero)
        : b = -a :=
  done since Group.left_inverse_unique

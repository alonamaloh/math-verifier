-- `witness w with P` builds the anonymous tuple `⟨w, P⟩` for an
-- existential goal. The proof component `P` may be written either as an
-- actual proof term or — exercised here — as the *proposition* it should
-- prove: when that proposition is the obligation `predicate(w)`, the
-- elaborator hands it to the auto-prover (the "bare proposition as proof"
-- coercion), so `witness 3 with 6 = 2 * 3` closes `2 ∣ 6` directly.
--
-- This mirrors the coercion already available in ordinary function-call
-- argument positions; the test pins it down for the constructor /
-- anonymous-tuple path used by `witness`, and for the goal-driven
-- hole-inference path (`f(?, …)`) below.

module Test.witness_bare_proposition_test

import axioms
import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.divisibility

-- The motivating case: the second component is the equation itself, and
-- the auto-prover discharges the arithmetic.
theorem Test.witness_divides_bare : 2 ∣ 6 :=
  witness 3 with 6 = 2 * 3

-- Works inside a bare existential goal too (not only behind `∣`).
theorem Test.witness_exists_bare : ∃ (n : Natural). 6 = n + 4 :=
  witness 2 with 6 = 2 + 4

-- An explicit proof term in the same slot still works — the coercion
-- no-ops when the component already has proof type.
theorem Test.witness_divides_explicit : 2 ∣ 6 := {
  claim sixIsTwoTimesThree : 6 = 2 * 3;
  witness 3 with sixIsTwoTimesThree
}

-- Hole-inference path: a call with `?` arguments routes through a separate
-- elaborator path. Here the `?`s are solved from the goal (a = 1,
-- b = successor(n)), and the final argument — the hypothesis the lemma
-- needs — is written as the *proposition* `2 = successor(successor(n))`
-- rather than naming `h`; the auto-prover finds `h` in scope to discharge
-- it. Compare Test/hole_test.math, which passes the proof `h` directly.
theorem Test.hole_call_bare (n : Natural) (h : 2 = successor(successor(n)))
        : 1 = successor(n) :=
  Natural.successor_injective(?, ?, 2 = successor(successor(n)))

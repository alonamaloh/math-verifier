-- `instance Real.ring` makes the ring/polynomial operators dispatch at
-- the CONCRETE carrier spelling `Polynomial(Real, Real.zero)`: the `+`
-- target `Polynomial.add {r : Ring}` recovers `r` from the canonical-
-- bundle registry for the carrier `Real`. Before the registration this
-- was the Item C asymmetry (worked at Integer, failed at Real with
-- "the function expects: Ring / but this argument is: Real") — see
-- PLAN_ELABORATOR_SEAMS.md and error-message corpus #13.

module Test.real_ring_dispatch_test

import Logic.basics
import Logic.product
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Algebra.ring
import Algebra.ring_bundle
import Real.basics
import Real.addition
import Real.multiplication
import Real.negation
import Real.ring
import Real.algebra
import Real.instances
import Polynomial.basics
import Polynomial.addition
import Polynomial.multiplication
import ComplexNumber.basics

-- `+` and `*` in a STATEMENT at the concrete spelling (the Fix-A repro
-- shape, now elaborating), and `+` in a body.
definition Test.polynomial_sum (p q : Polynomial(Real, Real.zero))
    : Polynomial(Real, Real.zero) :=
  p + q

theorem polynomial_sum_unfolds (p q : Polynomial(Real, Real.zero))
    : Test.polynomial_sum(p, q) = p + q := {
  done
}

theorem product_left_argument (p q : Polynomial(Real, Real.zero))
    : (p * q) + (p * q) = (p * q) + (p * q) := {
  done
}

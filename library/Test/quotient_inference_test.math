-- Test the implicit-T-R inference for the quotient operations.

module Test.quotient_inference_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.addition

-- (1) `Quotient.class_of(rep)` — R inferred from expected type.
theorem mk_test (rep : IntegerRepresentative) : Integer :=
  Quotient.class_of(rep)

-- (2) `Quotient.equivalent_implies_equal(x, y, proof)` — T from x, R from proof. The
-- `=` desugar elaborates the left side first and passes its type as
-- the expected type for the right, so the right `Quotient.class_of(rep2)`
-- can back-infer R. The left still needs explicit T, R since it has
-- no prior expected type.
theorem sound_test
        (rep1 rep2 : IntegerRepresentative)
        (proof : IntegerEquivalent(rep1, rep2))
        : Quotient.class_of(IntegerRepresentative, IntegerEquivalent, rep1) = Quotient.class_of(rep2) :=
  Quotient.equivalent_implies_equal(rep1, rep2, proof)

-- (3) When the LEFT side has a fixable type from elsewhere — for
-- instance an outer expected type passed to `:` — both sides can be
-- implicit. Here the theorem's signature is the expected type but
-- since the carrier is `Integer`, both `Quotient.class_of` calls back-infer.
theorem both_implicit_test
        (rep1 rep2 : IntegerRepresentative)
        (proof : IntegerEquivalent(rep1, rep2))
        : Integer.zero = Integer.zero :=
  reflexivity(Integer.zero)

-- (4) `Quotient.induct_three(motive, atReps, q1, q2, q3)` — the
-- 5-arg short form. All six T/R parameters are inferred from the
-- three quotient arguments. We test the simplest possible 3-arg
-- motive: `λ x y z. x = x`, which only uses the first quotient.
theorem induct_three_test (x y z : Integer) : x = x :=
  Quotient.induct_three(
      (xArg yArg zArg : Integer) ↦ xArg = xArg,
      (rep_x rep_y rep_z : IntegerRepresentative) ↦
          reflexivity(Integer,
              Quotient.class_of(IntegerRepresentative, IntegerEquivalent, rep_x)),
      x, y, z)

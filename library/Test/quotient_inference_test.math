-- Test the implicit-T-R inference for the quotient operations.

module Test.quotient_inference_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Integer.basics

-- (1) `Quotient.mk(rep)` — R inferred from expected type.
theorem mk_test (rep : IntegerRepresentative) : Integer :=
  Quotient.mk(rep)

-- (2) `Quotient.sound(x, y, proof)` — T from x, R from proof. We
-- introduce `Quotient.mk`'s targets via `let` to give them an expected
-- type; otherwise `Equality(Integer, _, _)` elaborates its two
-- endpoints without expected types and `Quotient.mk` can't infer `R`.
theorem sound_test
        (rep1 rep2 : IntegerRepresentative)
        (proof : IntegerEquivalent(rep1, rep2))
        : Equality(Integer,
              Quotient.mk(IntegerRepresentative, IntegerEquivalent, rep1),
              Quotient.mk(IntegerRepresentative, IntegerEquivalent, rep2)) :=
  Quotient.sound(rep1, rep2, proof)

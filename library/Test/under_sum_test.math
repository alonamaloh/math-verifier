module Test.under_sum_test
import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Algebra.ring
import Algebra.ring_bundle
import Polynomial.basics
import Polynomial.addition
import Polynomial.summation

-- Rewrite-under-Σ: prove Σ f = Σ g by a pointwise `(i) => f(i) = g(i)`,
-- desugaring to Sum.extensional (f, g read off the endpoints).
theorem Test.under_sum (r : Ring) (f g : Natural → Ring.carrier(r)) (n : Natural)
        (pw : (i : Natural) → f(i) = g(i))
        : Polynomial.Sum(r, f, n) = Polynomial.Sum(r, g, n) :=
  calc Polynomial.Sum(r, f, n)
     = Polynomial.Sum(r, g, n)   by (i : Natural) ↦ pw(i)

-- The registry is generic over the function head: register a custom
-- congruence lemma for an arbitrary `MyFold` and rewrite under its binder.
axiom MyFold : (Natural → Natural) → Natural
axiom MyFold.congruence
        : (f g : Natural → Natural)
          → ((i : Natural) → f(i) = g(i))
          → MyFold(f) = MyFold(g)
congruence_under_binder MyFold := MyFold.congruence

theorem Test.under_custom_binder
        (f g : Natural → Natural) (pw : (i : Natural) → f(i) = g(i))
        : MyFold(f) = MyFold(g) :=
  calc MyFold(f)
     = MyFold(g)   by ((i : Natural) ↦ pw(i))

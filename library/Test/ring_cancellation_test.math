-- `ring` with cross-pair cancellation: when distributing a product the
-- cross terms collide and cancel (or combine), e.g. (a+b)(a−b) = a²−b².
-- The product expansion is merged into canonical form by the same
-- signed-monomial-sum merge the additive path uses, so opposite-sign
-- like terms cancel and same-sign ones combine.
module Test.ring_cancellation_test

import Logic.basics
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.instances
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra

-- Difference of squares (the cross terms +ab and −ba cancel).
theorem Test.difference_of_squares (a b : Integer)
        : (a + b) * (a - b) = a*a - b*b := ring

theorem Test.difference_of_squares_flipped (a b : Integer)
        : (a - b) * (a + b) = a*a - b*b := ring

-- Same, over an abstract bundled commutative ring (exercises the
-- abstract multiply_negate / IsRing-instance path).
theorem Test.difference_of_squares_abstract (c : CommutativeRing)
        (a b : CommutativeRing.carrier(c))
        : (a + b) * (a - b) = a*a - b*b := ring

-- Square: the cross terms combine to a coefficient-2 like term.
theorem Test.square_of_sum (a b : Integer)
        : (a + b) * (a + b) = a*a + (a*b + (b*a + b*b)) := ring

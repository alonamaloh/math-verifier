-- Equation-shaped induction arms (A4): induction blocks share the
-- by-cases clause grammar — the arm states the constructor form as an
-- equation on the inducted variable:
--   `case n = 0:` / `case n = k + 1 for some k, with IH:`
-- `for some k` is documentation (the pattern binds k); `, with IH`
-- names THIS arm's induction hypothesis (overriding the header name).
-- The constructor-pattern arms (`case zero:` / `case successor(k):`)
-- remain legal.

module Test.induction_equation_arms_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.list_product
import Lists.list

-- Both arms equation-shaped, `k + 1` offset spelling, per-arm IH name.
theorem Test.add_zero_right_equation_arms (n : Natural) : n + 0 = n :=
  by induction on n with IH {
    case n = 0: done
    case n = k + 1 for some k, with additionAtK: {
        k + 0 = k by additionAtK;
        done
      }
  }

-- The `1 + k` offset spelling and the header IH name.
theorem Test.zero_le_equation_arms (n : Natural) : 0 ≤ n :=
  by induction on n with IH {
    case n = 0: done
    case n = 1 + k: done by Natural.zero_least
  }

-- Multi-binder witness arm: inducting over a 2-argument constructor. The
-- `for some head, tail` list names both fields (documentation; the
-- constructor equation binds them), reaching parity with `by cases`.
-- `head`, `tail`, and the per-arm `ih` are all in scope in the body.
theorem Test.product_self_multi_binder (xs : List(Natural)) :
    Natural.listProduct(xs) = Natural.listProduct(xs) :=
  by induction on xs {
    case xs = List.empty: done
    case xs = List.prepend(head, tail) for some head, tail, with ih: {
        Natural.listProduct(tail) = Natural.listProduct(tail) by ih;
        done
      }
  }

-- The arm goal follows the arm's own offset spelling. With a motive that
-- embeds a count-dependent hypothesis (∀ j. j + count = h → …), the
-- `1 + k` arm routes through `induction_on_one_plus`, so the arm's
-- `suppose j + (1 + k) = h` matches the goal premise byte-for-byte —
-- `1 + k` is not definitionally `successor(k)`, and the old
-- constructor-lemma routing rejected the arm outright.
theorem Test.equation_arm_hypothesis_bearing_motive (h count : Natural)
        : ∀ (j : Natural). j + count = h → j ≤ h :=
  by induction on count with IH {
    case count = 0: {
        take j : Natural;
        suppose j + 0 = h as jEquation;
        j
           = j + 0
           = h;
        done by Natural.LessOrEqual.reflexive
      }
    case count = 1 + k: {
        take j : Natural;
        suppose j + (1 + k) = h as jEquation;
        (1 + j) + k
           = j + (1 + k)
           = h
           as shifted;
        j ≤ 1 + j;
        1 + j ≤ h by IH(1 + j, shifted);
        done by Natural.LessOrEqual.transitive
      }
  }

-- Test that Quotient.class_of(rep) short form works inside a Quotient.lift
-- body. Previously suspected to fail.

module Test.quotient_lift_short_test

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Integer.basics

-- The classical "identity lift": λ rep => mk(rep), respecting equiv
-- pointwise. This lift should be the identity on Integer.
theorem id_lift_test (x : Integer) : Integer :=
  Quotient.lift(
      (rep : IntegerRepresentative) ↦
          Quotient.class_of(rep),       -- ← does the short form work here?
      (rep1 rep2 : IntegerRepresentative)
               (eq : IntegerEquivalent(rep1, rep2)) ↦
          Quotient.equivalent_implies_equal(rep1, rep2, eq),
      x)

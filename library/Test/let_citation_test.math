-- Test/let_citation_test.math
--
-- Citation matching sees through `let` abbreviations (fallback pass):
-- the goal mixes the let name `m` with its unfolded value, so the
-- lemma's conclusion can only unify after zeta-unfolding. Historically
-- "let-opacity" forced spelling the full term instead.

module Test.let_citation_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

theorem Test.probe_let_citation (n : Natural) : 0 + successor(n) = successor(n) := {
  let m : Natural := successor(n);
  0 + successor(n) = m by Natural.zero_add as mixed;
  done by mixed
}

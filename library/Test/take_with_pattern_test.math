-- Test `take x as <pattern> : T;` and `suppose <type> as <pattern>;`
-- statement-level sugar. The pattern is destructured immediately, with
-- elaborator dispatch on T's head (inductive → cases; Quotient → quotient
-- representative cases).

module Test.take_with_pattern_test

import axioms
import Logic.basics
import Equality.basics
import Logic.exists
import Natural.basics
import Integer.basics
import Integer.addition

-- (1) `take` with the quotient-representative pattern (A5 spelling):
-- destructure x as a representative right at the intro, no constructor
-- name on the page.
theorem take_quotient_destructure : ∀ (x : Integer). x = x := {
  take x as representative(a, b) : Integer;
  reflexivity(Integer,
      (Quotient.class_of(IntegerRepresentative.make(a, b)) : Integer))
}

-- (2) `take` with quotient pattern, two binders.
theorem take_quotient_two_destructure
        : ∀ (x y : Integer). x + y = x + y := {
  take x as IntegerRepresentative.make(a, b) : Integer;
  take y as IntegerRepresentative.make(c, d) : Integer;
  reflexivity(Integer,
      (Quotient.class_of(IntegerRepresentative.make(a, b)) : Integer)
      + (Quotient.class_of(IntegerRepresentative.make(c, d)) : Integer))
}

-- (3) `take` without pattern still works (regression).
theorem take_no_pattern : ∀ (x : Integer). x = x := {
  take x : Integer;
  reflexivity(Integer, x)
}

-- (4) `suppose` with And destructure pattern.
theorem suppose_and_destructure
        (P Q : Proposition)
        : P ∧ Q → P := {
  suppose P ∧ Q as ⟨p, q⟩;
  p
}

-- (5) `suppose` with Exists destructure.
theorem suppose_exists_destructure
        (P : Natural → Proposition)
        : (∃ (n : Natural). P(n)) → ∃ (m : Natural). P(m) := {
  suppose ∃ (n : Natural). P(n) as ⟨witnessValue, witnessProof⟩;
  witness witnessValue with witnessProof
}

-- (6) `suppose` with bare name (regression).
theorem suppose_bare_name
        (P : Proposition)
        : P → P := {
  suppose P as h;
  h
}

-- (7) `let ⟨a, b⟩ := h;` — destructure an inductive DATA value
-- (non-Quotient) via the pattern-let; the tuple resolves the sole
-- constructor from the type.
theorem let_inductive_destructure
        (h : IntegerRepresentative)
        : IntegerRepresentative := {
  let ⟨a, b⟩ := h;
  IntegerRepresentative.make(a, b)
}

-- (8) `cases x { | representative(a, b) => … }` — the A5 quotient
-- destructure of a given value. Goes through the cases-on-Quotient
-- path with the carrier's constructor resolved from the type.
theorem cases_quotient_representative (x : Integer) : x = x :=
  by_representatives x as ⟨a, b⟩ =>
    reflexivity(Integer,
        (Quotient.class_of(IntegerRepresentative.make(a, b)) : Integer))

-- (9) Multi-hypothesis auto-generalize on a Quotient scrutinee (h1 and
-- h2 both depend on x). Confirms the fix to elaborateCasesWithRefining
-- (the inner-loop over-lift bug), which the auto path routes through.
theorem generalize_multi_name_on_quotient
        (x : Integer) (h1 : x = x) (h2 : x = x)
        : x = x :=
  by_representatives x as rep => h1

-- `by <lemma>` recovers a lemma's arguments even when they appear only in its
-- HYPOTHESES, not its conclusion — by unifying each premise against the
-- context (and discharging equality premises by reflexivity). See
-- NaturalList.all_prime_prepend for the full (premise-match + reflexivity)
-- case; this file isolates the premise-match part.

module Test.citation_back_inference_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano

-- The data args a, b appear only in the hypothesis `a = b`, never in the
-- conclusion `g`. Citing it must back-infer a, b by matching that premise
-- against an in-scope equality.
theorem back_inference_premise
        (a b : Natural) (g : Proposition)
        (equalityHypothesis : a = b) (proofOfG : g) : g :=
  proofOfG

theorem cite_back_inference
        (x y : Natural) (Q : Proposition)
        (xEqualsY : x = y) (proofQ : Q) : Q :=
  claim by back_inference_premise

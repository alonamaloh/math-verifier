-- Feature test: A2 by-cases transport — statement addressing inside an
-- equation-shaped case arm finds outer facts MODULO the arm's equation.
module Test.case_transport_test

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

-- Address an outer fact by its REFINED statement inside a case arm:
-- h is stated about n; the arm knows n = successor(k) via its stated
-- equation; given(P(successor(k))) must transport h silently.
theorem Test.transported_address (P : Natural → Proposition) (n : Natural)
        (h : P(n))
        : n = n :=
  done by cases {
    case n = 0: reflexivity(n)
    case n = successor(k) for some (k : Natural): {
        P(successor(k)) by given(P(successor(k)));
        reflexivity(n)
      }
  }

-- The transport is not limited to a single occurrence: the scrutinee may
-- appear several times in the addressed fact.
theorem Test.transported_address_multi_occurrence
        (P : Natural → Natural → Proposition) (n : Natural)
        (h : P(n, n))
        : n = n :=
  done by cases {
    case n = 0: reflexivity(n)
    case n = successor(k) for some (k : Natural): {
        P(successor(k), successor(k)) by given(P(successor(k), successor(k)));
        reflexivity(n)
      }
  }

-- Occurrences at different nesting depths (bare and under `1 + ·`).
theorem Test.transported_address_nested_occurrence
        (P : Natural → Natural → Proposition) (n : Natural)
        (h : P(n, 1 + n))
        : n = n :=
  done by cases {
    case n = 0: reflexivity(n)
    case n = successor(k) for some (k : Natural): {
        P(successor(k), 1 + successor(k)) by given(P(successor(k), 1 + successor(k)));
        reflexivity(n)
      }
  }

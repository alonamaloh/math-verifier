-- Probe: is `successor(a) * b = b + a * b` a definitional equality
-- that `reflexivity` can prove directly?

module Test.multiply_reduction_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano

theorem multiply_succ_left_is_defeq (a b : Natural)
        : successor(a) * b = b + a * b :=
  reflexivity(b + a * b)

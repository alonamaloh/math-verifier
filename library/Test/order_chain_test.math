-- The bounded order-chain closure (the multi-premise successor to B4):
-- mixed-strictness transitive chaining, ≠ from a strict chain, and
-- False from a strict cycle — all bare, no hints, from in-scope facts.

module Test.order_chain_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.order
import Rational.basics
import Rational.addition
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.ring
import Real.order

-- Mixed ≤/< chains (transitive_left / transitive_right shapes).
theorem Test.chain_weak_strict (x y z : Real) (h1 : x ≤ y) (h2 : y < z) : x < z := {
  x < z;
}

theorem Test.chain_strict_weak (x y z : Real) (h1 : x < y) (h2 : y ≤ z) : x < z := {
  x < z;
}

-- A longer mixed chain, strict∘strict included (weakened internally).
theorem Test.chain_long (a b c d e : Real)
        (h1 : a ≤ b) (h2 : b < c) (h3 : c < d) (h4 : d ≤ e) : a < e := {
  a < e;
}

-- A strict chain serves a weak goal (weaken at the end).
theorem Test.chain_weakened (x y z : Rational) (h1 : x < y) (h2 : y ≤ z) : x ≤ z := {
  x ≤ z;
}

-- ≠ from a strict chain, through LessThan.distinct.
theorem Test.chain_distinct (x y z : Real) (h1 : x ≤ y) (h2 : y < z) : ¬(x = z) := {
  ¬(x = z);
}

-- False from a strict cycle: x < y ≤ x refutes via irreflexive. The
-- IVT shape: `0 < f(y)` chained against `f(y) ≤ 0` closes `done` bare.
theorem Test.cycle_contradiction (x y : Real) (h1 : x < y) (h2 : y ≤ x) : False := {
  done
}

-- The exact IVT ending: two strict facts and a weak return edge.
theorem Test.ivt_shape (u v w : Real)
        (h1 : u < v) (h2 : v < w) (h3 : w ≤ u) : False := {
  done
}

-- Conjunction legs feed the chain (collectLocalBinderFacts decomposes).
theorem Test.chain_from_conjunction (x y z : Rational)
        (h : x < y ∧ y ≤ z) : x < z := {
  x < z;
}

-- Tests for the bare relation-chain statement grammar (`<chain>;` and
-- `<chain> as NAME;` — the `calc` keyword is retired). Both desugar to
-- a TypedLet binding the chain-recovered equation `first = last` into
-- local scope, so the auto-prover can find them when later chain steps
-- need them.

module Test.calc_statement_test

import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Equality.basics

-- Named form: `<chain> as someEquation;` introduces `someEquation` of
-- type matching the chain's endpoints.
theorem Test.calc_as_named (a b c : Natural)
        (firstStep : a = b) (secondStep : b = c)
        : a = c := {
  a = b
    = c                                                     as bridge;
  bridge
}

-- Anonymous form: `<chain>;` introduces an anonymous binding; later
-- chain steps still pick it up via the local-hypothesis matcher.
theorem Test.calc_anonymous_via_lookup
        (a b c d : Natural)
        (firstStep : a = b) (secondStep : b = c) (thirdStep : c = d)
        : a = d := {
  -- Anonymous chain registers an equation `a = c` in scope.
  a = b
    = c;
  -- The next chain step `a → c` finds it without an explicit `by`.
  a = c
    = d
}

-- Mix: named bridge used explicitly by name later.
theorem Test.calc_named_used_explicitly
        (a b c d : Natural)
        (firstStep : a = b) (secondStep : b = c) (thirdStep : c = d)
        : a = d := {
  a = b
    = c                                                     as bridge;
  -- Reference by name (no auto-prover involved here).
  Equality.transitivity(bridge, thirdStep)
}

-- Mixed-relation chain statement: a chain of `=` and `≤` produces a
-- non-strict ≤ binding.
theorem Test.calc_as_named_le
        (a b c d : Natural)
        (firstStep : a = b) (secondStep : b ≤ c) (thirdStep : c = d)
        : a ≤ d := {
  a = b
    ≤ c                     by secondStep
    = d                                                     as bound;
  bound
}

-- (Strict `<` on Natural would need the operator registered; the ≤
-- case above covers the non-strict branch of the type-recovery logic.)

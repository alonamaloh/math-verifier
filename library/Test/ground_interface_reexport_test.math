-- The ground-relation tier is ambient for consumers of the sealed ℝ
-- interface: Real.interface re-exports Integer/Rational.ground_arithmetic,
-- so ground facts at ℤ/ℚ (and cast side conditions at ℝ) close silently
-- with no direct ground_arithmetic imports in the consumer.
module Test.ground_interface_reexport_test

import Logic.basics
import Equality.basics
import Natural.basics
import Integer.basics
import Rational.basics
import Rational.order
import Rational.division
import Real.interface

theorem Test.reexported_rational_ground : (1 : Rational) / 3 + 1 / 6 = 1 / 2 := done

theorem Test.reexported_integer_ground : -(3 : Integer) ≤ 2 := done

theorem Test.reexported_real_cast_positive : (0 : Real) < 2 := done

-- Stage A acceptance (PLAN_LINEAR_ALGEBRA): the bundled `Field` works
-- as the scalar structure the vector-space layer will consume —
-- `ring` normalises over an abstract `Field.carrier(f)` (the
-- computeRingScheme Field branch + the flattened law layer), the
-- direct axioms discharge bare from `instance Field.is_ring`, the
-- reciprocal is an honest function with its characterizing lemma, and
-- the ℝ/ℚ instances are `Field` values whose projections reduce to the
-- concrete carriers.

module Test.field_bundle_test

import Logic.basics
import Logic.exists
import Equality.basics
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.field
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.field_bundle
import Rational.basics
import Rational.addition
import Rational.negation
import Rational.multiplication
import Rational.ring
import Rational.instances
import Rational.ring_bundle
import Rational.field_bundle
import Real.basics
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.instances
import Real.ring_bundle
import Real.field_bundle

-- `ring` over the abstract field carrier: needs associativity,
-- commutativity (the bundle's field), distributivity, and negation
-- pushing — the full law-name battery.
theorem Test.field_ring_normalises (f : Field) (a b : Field.carrier(f))
        : (a + b) * (a - b) = a * a - b * b := ring

-- Direct axioms discharge bare from the registered instance.
theorem Test.field_axioms_bare (f : Field) (x : Field.carrier(f))
        : Field.one(f) * x = x :=
  done

-- The reciprocal cancels its argument, by-less: `x⁻¹` spells the
-- reciprocal with the nonzero side condition discharged from the
-- hypothesis in scope, and the prover finds `reciprocal_multiplies`.
theorem Test.field_reciprocal_cancels (f : Field) (x : Field.carrier(f))
        (nonzero : x ≠ Field.zero(f))
        : x * x⁻¹ = Field.one(f) :=
  done

-- The concrete instances are honest `Field` values: their carriers
-- reduce to ℝ / ℚ, so concrete facts state directly at the projected
-- spelling.
theorem Test.real_field_carrier_is_real
        (x : Field.carrier(Real.field)) : x + Real.zero = x :=
  done

theorem Test.rational_field_carrier_is_rational
        (q : Field.carrier(Rational.field)) : q * Rational.one = q :=
  done

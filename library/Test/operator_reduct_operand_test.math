-- Lock for fix 4 of the 2026-07-19 matcher session: operator dispatch on
-- an operand whose ANNOTATED type is a reduct of the registered carrier.
-- `let d : ℤ` is defeq to `CommutativeRing.carrier(Integer.commutative_
-- ring_bundle)` but its head never unfolds TO the registered name; the
-- unique half-match on the RingVector side adopts `RingVector.scale`.

module Test.operator_reduct_operand_test

import Logic.basics
import Logic.functions
import Equality.basics
import Natural.basics
import Natural.order
import Natural.classical_decidable
import Set.finite
import Lists.list
import Lists.map
import Integer.basics
import Integer.ring
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.commutative_ring_aggregation
import Algebra.integer_domain
import Algebra.matrix
import Algebra.matrix_ring
import Algebra.matrix_transpose
import Algebra.matrix_vector

theorem Probe.scale_on_integer_annotated_let {m : ℕ}
        (x : RingVector(Integer.commutative_ring_bundle, m)) (i : NaturalsBelow(m))
        : (2 : ℤ) • x = (2 : ℤ) • x := {
  let d : ℤ := (2 : ℤ);
  d • x = d • x;
  done
}

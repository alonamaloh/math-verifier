-- The ground-relation tier discharges GROUND premises during the
-- speculative context scan: a bare step citing an automatic lemma whose
-- numeral premise (here `2 ≤ 5` for lt_multiply_of_two_le) has no
-- premise-free automatic fact still closes — the tier is the search-free
-- discharge, replacing the retired per-numeral stop-gaps
-- (Natural.one_le_two).
module Test.ground_premise_scan_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.multiply_order

theorem Test.ground_premise_under_scan (y : Natural) (yAtLeastOne : 1 ≤ y) : y < 5 * y := done

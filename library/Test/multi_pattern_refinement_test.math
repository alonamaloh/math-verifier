-- Multi-pattern refinement: a constructor pattern at a non-scrutinee
-- position destructures its variable AND refines the types of any
-- LATER function arguments whose declared types depend on it.
--
-- Before this elaborator change, the inner destructure (via a wrapped
-- `cases`) refined only the body's expected type — the dependent
-- hypothesis kept its unrefined type. The workaround was a helper
-- chain: one theorem per inner pattern position. With the fix in
-- place, each chain collapses into a single theorem.

module Test.multi_pattern_refinement_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Integer.basics

-- (1) Dependent hypothesis refinement — the headline use case.
-- `eq`'s declared type mentions `firstRepresentative`. Destructuring
-- the second position to `make(c, d)` simultaneously refines `eq`
-- from `IntegerEquivalent(make(a, b), firstRepresentative)` to the
-- Natural-level equation `a + d = b + c`, which we hand to the
-- existing kernel lemma. Without the fix the body wouldn't type-check
-- because the hypothesis would still be the IntegerEquivalent form.
theorem multiPatternSymmetric
        : (x y : IntegerRepresentative)
          → IntegerEquivalent(x, y)
          → IntegerEquivalent(y, x)
  | IntegerRepresentative.make(a, b),
    IntegerRepresentative.make(c, d),
    eq =>
      done by IntegerEquivalent.symmetric_natural unfolding IntegerEquivalent

-- (2) Three-position destructure threading hypotheses across two
-- inner positions. Both `hyp1` and `hyp2` depend on the destructured
-- middle/right reps, and both must refine simultaneously for the
-- call to the natural-level kernel below to type-check.
theorem multiPatternTransitive
        : (x y z : IntegerRepresentative)
          → IntegerEquivalent(x, y)
          → IntegerEquivalent(y, z)
          → IntegerEquivalent(x, z)
  | IntegerRepresentative.make(a, b),
    IntegerRepresentative.make(c, d),
    IntegerRepresentative.make(e, f),
    hyp1, hyp2 =>
      done by IntegerEquivalent.transitive_natural unfolding IntegerEquivalent

-- (3) Refines a hypothesis whose type involves only the OUTERMOST
-- destructured position, while another bare position sits between
-- them. Verifies that bare positions interspersed with constructor
-- destructures don't disturb the refinement chain.
theorem multiPatternBareInTheMiddle
        : (x y : IntegerRepresentative)
          → Natural
          → IntegerEquivalent(x, y)
          → IntegerEquivalent(y, x)
  | IntegerRepresentative.make(a, b),
    IntegerRepresentative.make(c, d),
    _unused,
    eq =>
      done by IntegerEquivalent.symmetric_natural unfolding IntegerEquivalent

-- Test/disjunct_test.math
--
-- Goal-directed injection into a right-associated disjunction.

module Test.disjunct_test

import Logic.basics

definition Test.FourWay (A B C D : Proposition) : Proposition :=
  A ∨ B ∨ C ∨ D

definition Test.Pair (A B : Proposition) : Proposition :=
  A ∨ B

theorem Test.disjunct_first
        (A B C D : Proposition) (proof : A)
        : Test.FourWay(A, B, C, D) := {
  done by disjunct(proof)
}

theorem Test.disjunct_middle
        (A B C D : Proposition) (proof : C)
        : Test.FourWay(A, B, C, D) := {
  done by disjunct(proof)
}

theorem Test.disjunct_last
        (A B C D : Proposition) (proof : D)
        : Test.FourWay(A, B, C, D) := {
  done by disjunct(proof)
}

theorem Test.disjunct_computed_proof
        (A B C : Proposition) (proof : A) (toB : A → B)
        : A ∨ B ∨ C := {
  done by disjunct(toB(proof))
}

theorem Test.disjunct_named_right_branch
        (A B C : Proposition) (proof : Test.Pair(B, C))
        : A ∨ Test.Pair(B, C) := {
  done by disjunct(proof)
}

-- Regression: operator dispatch resolves a carrier PROJECTION over a
-- concrete ring to the concrete carrier head (PLAN_READABILITY §4). A
-- value typed `Ring.carrier(Real.polynomial_ring)` (e.g. from a `divides`
-- existential) is defeq to `Polynomial(...)` but has a different head, so
-- syntactic operator dispatch used to fail; the carrier-projection
-- resolver (carrierProjectionField) bridges it, WITHOUT over-reducing
-- `Polynomial(...)` to its underlying `Quotient(...)`.

module Test.operator_carrier_projection_test

import Logic.basics
import Logic.exists
import Equality.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_divisibility
import Real.basics
import Real.ring
import Real.instances
import Polynomial.basics
import Polynomial.multiplication
import Polynomial.instances
import ComplexNumber.basics
import ComplexNumber.modulus

-- `quotient : Ring.carrier(Real.polynomial_ring)`, `Complex.modulus :
-- Polynomial(...)` — mixed heads. `*` must dispatch to Polynomial.multiply.
theorem Test.carrier_projection_mixed_heads
        (quotient : Ring.carrier(Real.polynomial_ring))
        : Complex.modulus * quotient
          = Polynomial.multiply(Real.ring, Complex.modulus, quotient) :=
  reflexivity(Polynomial(Ring.carrier(Real.ring), Ring.zero(Real.ring)),
      Polynomial.multiply(Real.ring, Complex.modulus, quotient))

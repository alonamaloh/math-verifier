module Test.block_autoclose_test

import Real.order

-- Closing a block engages the auto-prover on the goal — no `done` needed.
-- And the trailing `;` is pure punctuation: these three are identical.
theorem close_with_semicolon    (c : Real) (h : c < c) : False := { claim c < c by h; }
theorem close_without_semicolon (c : Real) (h : c < c) : False := { claim c < c by h }
theorem close_with_explicit_done (c : Real) (h : c < c) : False := { claim c < c by h; done }

-- A bare close also discharges a goal that is itself an in-scope fact.
theorem close_finds_goal_fact (P : Proposition) (hp : P) : P := { claim P by hp }

-- A reductio with no `done` anywhere: the inner for-contradiction block
-- closes its `False` goal on `}`, and the outer block closes the real goal
-- from the established hypothesis on its own `}`.
theorem reductio_without_done (a b c : Real) (h : c < c) : a ≤ b := {
  suppose ¬(a ≤ b) for contradiction {
    claim c < c by h
  }
}

-- A final `calc` is the block's proof directly; the trailing `;` is optional,
-- and the relation may be one the binding-path type synthesis can't represent
-- (here `∣`), so the direct path is what makes that work.
theorem calc_eq_no_semi (a b : Real) (h : a = b) : a = b := { calc a = b by h }
theorem calc_eq_semi    (a b : Real) (h : a = b) : a = b := { calc a = b by h; }

-- A quotient calc closes through the auto-prover (no direct path): the calc
-- binds the representative cross-equation and the implicit `done` bridges it to
-- the class equality via tryCoerceFactToGoal — the same way `done` would.

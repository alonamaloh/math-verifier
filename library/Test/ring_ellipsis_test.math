-- Ellipsis notation at an abstract ring carrier (fold_operation on
-- Ring.carrier), including the Cauchy-product convolution: the ellipsis
-- elaborates to Algebra.Fold, which is one δ-step from Ring.Sum, so the
-- convolution bridge lemma cites across the two spellings.

module Test.ring_ellipsis_test

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.monus
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.ring_bundle
import Algebra.aggregation
import Algebra.ring_summation
import Polynomial.basics
import Polynomial.addition
import Polynomial.negation
import Polynomial.additive_group
import Polynomial.multiplication

-- The ellipsis form IS the Sum, definitionally.
theorem ring_ellipsis_is_sum (r : Ring) (f : Natural → Ring.carrier(r)) (k : Natural)
        : f(0) + ... + f(k) = Ring.Sum(r, f, k) :=
  reflexivity(Ring.carrier(r), Ring.Sum(r, f, k))

-- The Cauchy product, stated the way an algebra text writes it:
-- (p·q)_k = p₀·q_{k∸0} + … + p_k·q_{k∸k}. The term function is read by
-- anti-unifying the prefix term against the general term; the cited
-- bridge lemma concludes in the Ring.Sum spelling, one δ-step away.
theorem convolution_by_ellipsis (r : Ring)
        (p q : Polynomial.Coefficients(Ring.carrier(r))) (k : Natural)
        : (p * q)[k] = p[0] * q[k ∸ 0] + ... + p[k] * q[k ∸ k] :=
  by Polynomial.nth_multiply

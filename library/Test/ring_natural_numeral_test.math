-- Test `ring` numeral support on the Natural carrier: Peano numerals
-- (successor towers) fold into polynomial constants instead of opaque
-- atoms, and `successor(e)` is read as `1 + e`.

module Test.ring_natural_numeral_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic

-- (1) Pure constants.
theorem natural_numeral_constant_sum : 1 + 2 = 3 := ring

-- (2) Numeral coefficients combine across like terms.
theorem natural_numeral_coefficient_sum (t : Natural)
        : 2 * t + 2 * t = 4 * t := ring

-- (3) A numeral coefficient expands into repeated addition.
theorem natural_numeral_expand (t : Natural)
        : 4 * t = (t + t) + (t + t) := ring

-- (4) Adding the literal zero.
theorem natural_numeral_add_zero (t : Natural) : t + 0 = t := ring

-- (5) Distributing a numeral over a sum with a constant.
theorem natural_numeral_distribute (t : Natural)
        : 2 * (t + 3) = 2 * t + 6 := ring

-- (6) successor(e) is 1 + e.
theorem natural_successor_as_add (a b : Natural)
        : successor(a + b) = a + (1 + b) := ring

-- (7) successor under multiplication.
theorem natural_successor_multiply (t : Natural)
        : successor(t) * 2 = (t + t) + 2 := ring

-- (8) Numerals interact with distributivity and commutativity at once.
theorem natural_numeral_mixed (a b : Natural)
        : (1 + a) * (1 + b) = 1 + (b + (a + a * b)) := ring

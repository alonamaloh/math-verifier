-- `obtain ⟨…⟩ by <lemma>` — destructure a lemma's existential result with
-- the lemma's arguments inferred (its premises recovered from context), no
-- positional application.
module Test.obtain_by_test

import Natural.basics
import Natural.order
import Natural.subtraction
import Logic.exists

-- subtraction_witness : (b a) → b ≤ a → ∃ c. a = b + c. With a single ≤
-- hypothesis in scope, `by` recovers b, a and the proof from context.
theorem obtain_by_witness (j m : Natural) (lessOrEqual : j ≤ m)
        : ∃ (c : Natural). m = j + c := {
  obtain ⟨c, equation⟩ by Natural.subtraction_witness;
  witness c with equation
}

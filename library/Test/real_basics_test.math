-- Smoke tests for the Real-number construction.
--
-- The constructions in library/Real/ are scaffolded with sorry's for
-- the analytic respect / Cauchy proofs; these tests check the
-- TYPE-level plumbing (definitions exist, operators dispatch,
-- coercions compose).

module Test.real_basics_test

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.multiplication
import Real.negation

-- Real type exists and has zero/one constants.
theorem real_zero_is_real : Real.zero = Real.zero :=
  reflexivity(Real, Real.zero)

theorem real_one_is_real : Real.one = Real.one :=
  reflexivity(Real, Real.one)

-- The Rational → Real coercion is transitively-closed with the
-- Natural → Integer → Rational chain, so `(n : Real)` works for any
-- Natural `n`.
theorem natural_coerces_to_real (n : Natural) : (n : Real) = (n : Real) :=
  reflexivity(Real, (n : Real))

-- Real.add is well-typed at concrete inputs.
theorem real_add_is_total (x y : Real) : x + y = x + y :=
  reflexivity(Real, x + y)

-- Real.multiply is well-typed.
theorem real_multiply_is_total (x y : Real) : x * y = x * y :=
  reflexivity(Real, x * y)

-- Real.negate is well-typed.
theorem real_negate_is_total (x : Real) : -x = -x :=
  reflexivity(Real, -x)

-- Real.subtract is well-typed.
theorem real_subtract_is_total (x y : Real) : x - y = x - y :=
  reflexivity(Real, x - y)

-- Citing a lemma against a Pi-typed goal: the elaborator introduces the
-- goal's binders and runs the citation on the core goal — no
-- `(x)(h) ↦ { done by Lemma }` wrapper needed.

module Test.pi_goal_citation_test

import axioms
import Logic.basics
import Natural.basics
import Natural.order

-- The cited lemma's premise consumes the introduced hypothesis.
theorem pi_cite_with_premise (n : Natural)
        : (m : Natural) → successor(n) ≤ m → n ≤ m := {
  claim helper : (m : Natural) → successor(n) ≤ m → n ≤ m
      by Natural.less_or_equal_predecessor_less_or_equal;
  helper
}

-- Two introduced binders, conclusion-driven unification.
theorem pi_cite_two_binders
        : (a : Natural) → (b : Natural) → a ≤ a + b := {
  claim helper : (a : Natural) → (b : Natural) → a ≤ a + b
      by Natural.less_or_equal_add_right;
  helper
}

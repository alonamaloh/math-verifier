-- Test/not_symmetry_citation_test.math
--
-- Citing a fact/lemma of type Not(b = a) against a goal Not(a = b):
-- the citation engine bridges via (h : a = b) ↦ cited(symmetry(h)).
-- Before the bridge, only the bare-claim auto-prover crossed this gap,
-- so authors had to drop the explanatory `since <lemma>`.

module Test.not_symmetry_citation_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order

theorem Test.probe_not_flip (x : Natural) (notEqual : ¬(successor(x) = 0))
        : ¬(0 = successor(x)) := {
  done by notEqual
}

theorem Test.probe_not_flip_lemma (x : Natural)
        : ¬(0 = successor(x)) := {
  done by Natural.successor_not_zero
}

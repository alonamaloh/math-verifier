-- Tests for the classical LEM bridge: when a term has type
-- Not(Not(P)) and the expected type is P, the elaborator silently
-- wraps with Logic.double_negation_eliminate. This is what makes the
-- textbook reductio-ad-absurdum pattern work without explicit DNE.

module Test.dne_bridge_test

import axioms
import Logic.basics
import Logic.exists
import Logic.excluded_middle

-- (1) Direct: the body is literally a term of type Not(Not(P)) but
-- the theorem signature stipulates P. coerceToExpectedTypeViaDiff
-- inserts the DNE wrapper.
theorem dne_bridge_direct (P : Proposition) (notNotP : Not(Not(P))) : P :=
  notNotP

-- (2) RAA via suppose-then-False. The block's type is Not(P) →
-- False, i.e. Not(Not(P)). The theorem expects P. Bridge fires at
-- the theorem-body boundary. The `claim False` inside closes via
-- the unified fact match: `notNotP : Not(Not(P))` applied to the
-- in-scope `notP : Not(P)` produces False; autoFillHintForClaim
-- discovers the application without an explicit `by`.
theorem dne_bridge_via_block
        (P : Proposition) (notNotP : Not(Not(P))) : P := {
  suppose Not(P) as notP;
  claim False
}

module Test.factorial_notation

-- The postfix `!` notation: `k!` is Natural.factorial(k), binds tighter than
-- any binary operator, works on numerals and compound arguments, and composes
-- with the cast tower and honest `/`.

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.order
import Natural.factorial
import Rational.basics
import Rational.embedding
import Rational.archimedean
import Real.basics
import Real.embedding
import Real.embedding_order
import Real.order
import Real.apartness
import Real.reciprocal
import Real.field
import Real.division
import Real.exponential

theorem Test.factorial_bang_is_factorial (k : Natural) : k! = Natural.factorial(k) :=
  done

theorem Test.factorial_bang_recurrence (n : Natural) : (1 + n)! = (1 + n) * n! :=
  done since Natural.factorial_add_one

theorem Test.factorial_bang_at_least_one (n : Natural) : 1 ≤ n! :=
  done

definition Test.factorial_reciprocal (k : Natural) : Real := 1 / (k! : Real)

theorem Test.factorial_binds_tighter (n : Natural) : 1 + n! = 1 + Natural.factorial(n) :=
  done

-- Expected-type-driven operand coercion: with the ambient type Real, the
-- natural operands of `/` lift to ℝ and the division is honest Real division —
-- the same term the ascribed spellings produce.
definition Test.factorial_reciprocal_bare (k : Natural) : Real := 1 / k!

definition Test.half_bare : Real := 1 / 2

theorem Test.bare_reciprocal_matches_ascribed (k : Natural)
        : Test.factorial_reciprocal_bare(k) = 1 / (k! : Real) :=
  done

theorem Test.bare_half_matches_ascribed : Test.half_bare = 1 / (2 : Real) :=
  done

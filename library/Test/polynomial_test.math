-- Smoke test: Polynomial instantiates at a concrete ring (Integer).
module Test.polynomial_test

import Natural.basics
import Integer.basics
import Integer.addition
import Polynomial.basics

-- Polynomials over the integers form a type.
definition test_integer_polynomial : Type(0) :=
  Polynomial(Integer, Integer.zero)

-- The constant polynomial a0 = 1 (the list [1]).
definition test_constant_one : Polynomial(Integer, Integer.zero) :=
  Polynomial.make(Integer, Integer.zero,
      Polynomial.Coefficients.cons(Integer, Integer.one,
          Polynomial.Coefficients.nil(Integer)))

-- The linear polynomial 0 + 1·x (the list [0, 1]).
definition test_linear : Polynomial(Integer, Integer.zero) :=
  Polynomial.make(Integer, Integer.zero,
      Polynomial.Coefficients.cons(Integer, Integer.zero,
          Polynomial.Coefficients.cons(Integer, Integer.one,
              Polynomial.Coefficients.nil(Integer))))

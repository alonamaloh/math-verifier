-- Smoke test: Polynomial over a concrete bundled ring (the integers).
module Test.polynomial_test

import Natural.basics
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.instances
import Algebra.group
import Algebra.ring_bundle
import Polynomial.basics
import Polynomial.addition
import Polynomial.negation
import Polynomial.additive_group
import Polynomial.multiplication
import Polynomial.multiply_laws
import Polynomial.instances
import Integer.multiplication
import Polynomial.commutative

-- The integers as a bundled ring.
definition integerRing : Ring :=
  Ring.make(Integer, Integer.add, Integer.zero, Integer.negate,
      Integer.multiply, Integer.one, Integer.is_ring)

-- Its carrier projects back to Integer (definitionally).
theorem integerRing_carrier : Ring.carrier(integerRing) = Integer :=
  reflexivity(Type(0), Integer)

-- Polynomials over the integers form a type.
definition test_integer_polynomial : Type(0) :=
  Polynomial(Ring.carrier(integerRing), Ring.zero(integerRing))

-- The constant polynomial 1.
definition test_constant_one
        : Polynomial(Ring.carrier(integerRing), Ring.zero(integerRing)) :=
  Polynomial.one(integerRing)

-- Polynomials over the integers form an additive abelian group.
theorem test_polynomial_abelian_group
        : IsAbelianGroup(
              Polynomial(Ring.carrier(integerRing), Ring.zero(integerRing)),
              Polynomial.add(integerRing),
              Polynomial.zero(integerRing),
              Polynomial.negate(integerRing)) :=
  Polynomial.add_is_abelian_group(integerRing)

-- Polynomials over the integers form a ring.
theorem test_polynomial_is_ring
        : IsRing(
              Polynomial(Ring.carrier(integerRing), Ring.zero(integerRing)),
              Polynomial.add(integerRing), Polynomial.zero(integerRing),
              Polynomial.negate(integerRing), Polynomial.multiply(integerRing),
              Polynomial.one(integerRing)) :=
  Polynomial.is_ring(integerRing)

-- Polynomials over the integers form a COMMUTATIVE ring (Z is commutative).
theorem test_polynomial_is_commutative_ring
        : IsCommutativeRing(
              Polynomial(Ring.carrier(integerRing), Ring.zero(integerRing)),
              Polynomial.add(integerRing), Polynomial.zero(integerRing),
              Polynomial.negate(integerRing), Polynomial.multiply(integerRing),
              Polynomial.one(integerRing)) :=
  Polynomial.is_commutative_ring(integerRing, Integer.multiply_commutative)

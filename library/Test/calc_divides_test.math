module Test.calc_divides_test

import Natural.basics
import Natural.divisibility

-- Pure divisibility chain, folded via Natural.divides_transitive.
theorem Test.divides_chain (a b c : Natural) (hab : a ∣ b) (hbc : b ∣ c)
        : a ∣ c :=
  calc a
     ∣ b   by hab
     ∣ c   by hbc

-- Trailing `=` step absorbed by transport.
theorem Test.divides_then_eq (a b c d : Natural)
        (hab : a ∣ b) (hbc : b ∣ c) (hcd : c = d)
        : a ∣ d :=
  calc a
     ∣ b   by hab
     ∣ c   by hbc
     = d   by hcd

-- Leading `=` prefix absorbed by transport.
theorem Test.eq_then_divides (a b c : Natural)
        (hab : a = b) (hbc : b ∣ c)
        : a ∣ c :=
  calc a
     = b   by hab
     ∣ c   by hbc

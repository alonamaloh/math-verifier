module Test.calc_divides_test

import Natural.basics
import Natural.divisibility

-- Pure divisibility chain, folded via Natural.divides_transitive.
theorem Test.divides_chain (a b c : Natural) (hab : a ∣ b) (hbc : b ∣ c)
        : a ∣ c :=
  calc a
     ∣ b   by hab
     ∣ c   by hbc

-- Trailing `=` step absorbed by transport.
theorem Test.divides_then_eq (a b c d : Natural)
        (hab : a ∣ b) (hbc : b ∣ c) (hcd : c = d)
        : a ∣ d :=
  calc a
     ∣ b   by hab
     ∣ c   by hbc
     = d   by hcd

-- Leading `=` prefix absorbed by transport.
theorem Test.eq_then_divides (a b c : Natural)
        (hab : a = b) (hbc : b ∣ c)
        : a ∣ c :=
  calc a
     = b   by hab
     ∣ c   by hbc

-- Regression: a divisibility calc inside a STRUCTURAL cases/recursor body
-- is rebuilt by rewriteRecursiveCalls (the recursive-self-call rewrite),
-- which must preserve the relation tag — else the `∣` step silently
-- degrades to `=`. (This is the path prime_divides_product hit.)
theorem Test.divides_calc_in_recursor (a b : Natural) (hab : a ∣ b)
        : ∀ (n : Natural). a ∣ b
  | zero => calc a ∣ b by hab
  | successor(k) => calc a ∣ b by hab

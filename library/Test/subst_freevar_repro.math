-- Regression: `by substituting <eq>` when the equation's RHS (the term
-- substituted IN) itself mentions bound variables, and the rewrite target
-- occurs several times.
--
-- The substitution bridge searches subsets of the occurrences (Phase 1).
-- `abstractStructuralOccurrenceMasked` used to return a NON-selected
-- occurrence of the target unshifted, on the false assumption that the
-- target is closed. When the target carries bound variables (here the
-- coordinates of `z`, `w`), those indices were left one level too shallow;
-- the subsequent `substitute(.., 0, toSide)` then decremented them, turning
-- `gaussianProduct(coords z, coords w)` into the ill-typed
-- `gaussianProduct(coords w, coords eq)` (eq is a proof!). The mangled
-- masked goals sent the auto-prover into an expensive search that blew the
-- effort budget before the full-rewrite mask could close the step.

module Test.subst_freevar_repro

import Logic.basics
import Logic.product
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.ring
import Integer.algebra
import GaussianInteger.basics
import GaussianInteger.coordinates
import GaussianInteger.coordinate_map
import GaussianInteger.coordinate_multiplicative
import GaussianInteger.norm
import Rational.basics
import Rational.embedding
import Real.basics
import Real.embedding

-- Sanity: simple two-occurrence rewrite whose RHS mentions the binders.
theorem subst_simple_freevar (z w : Natural) (eq : z * w = w * z)
        : (z * w) + (z * w) = (w * z) + (w * z) :=
  (z * w) + (z * w)
     = (w * z) + (w * z)   by substituting eq

-- The real reproducer: `eq` a local claim whose RHS is the nested
-- `gaussianProduct(coords z, coords w)`, and the target `coords(z·w)`
-- occurs four times. Must close at the default auto-prover budget.
theorem subst_nested_freevar_multioccurrence (z w : GaussianInteger)
        : Product.first(coords(z * w)) * Product.first(coords(z * w))
          + Product.second(coords(z * w)) * Product.second(coords(z * w))
          = Product.first(GaussianInteger.gaussianProduct(coords(z), coords(w)))
                * Product.first(GaussianInteger.gaussianProduct(coords(z), coords(w)))
            + Product.second(GaussianInteger.gaussianProduct(coords(z), coords(w)))
                * Product.second(GaussianInteger.gaussianProduct(coords(z), coords(w))) := {
  coords(z * w) = GaussianInteger.gaussianProduct(coords(z), coords(w))
      by GaussianInteger.coordinates_multiply as eq;
  Product.first(coords(z * w)) * Product.first(coords(z * w))
       + Product.second(coords(z * w)) * Product.second(coords(z * w))
     = Product.first(GaussianInteger.gaussianProduct(coords(z), coords(w)))
           * Product.first(GaussianInteger.gaussianProduct(coords(z), coords(w)))
       + Product.second(GaussianInteger.gaussianProduct(coords(z), coords(w)))
           * Product.second(GaussianInteger.gaussianProduct(coords(z), coords(w)))
         by substituting eq
}

-- Regression: `by substituting <eq>` rewriting a `Natural` variable that
-- sits under the `Natural → Integer → Rational → Real` coercion tower.
-- `substituting` tries both rewrite directions and several goal forms,
-- including a deep-WHNF one. That deep form δ-reduces the transparent
-- `Integer.from_difference` construction past the OPAQUE `Integer` boundary,
-- leaving a raw `Quotient.class_of IntegerRepresentative` where `Integer.to_rational`
-- expects an `Integer`. The stray-numeral (`0`) rewrite direction matched
-- inside that expansion and built an ill-typed goal; the prover then assembled
-- a proof term that only the FINAL kernel check rejected ("expects: Integer /
-- but this argument is: Quotient.{0} IntegerRepresentative …"). The fix
-- type-checks each rewritten goal, so the bad (form, direction) is skipped and
-- the intended `m → 0` rewrite (well-typed) closes via `pf`.
theorem subst_through_coercion_tower
        (m : Natural) (h : m = 0) (target : Real) (pf : (0 : Real) = target)
        : (m : Real) = target := done by substituting h

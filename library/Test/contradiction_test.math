-- Tests for the contradiction auto-prover strategy. If the in-scope
-- hypotheses contain `False` (or a pair `(h : P, h' : Not(P))`), the
-- elaborator closes any goal via `False.eliminate_proposition`.

module Test.contradiction_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano

-- (1) Direct False in scope: any goal closes.
theorem contradiction_from_false
        (P : Proposition) (h : False) : P :=
  claim

-- (2) Classic (h : P, h' : ¬P) pair. The auto-prover builds h'(h)
-- to derive False, then eliminates to the goal.
theorem contradiction_from_pair
        (P Q : Proposition) (h : P) (hNotP : Not(P)) : Q :=
  claim

-- (3) Contradiction lets us prove any equality too. The restricted
-- contradiction strategy only fires when the contradiction fact is
-- the most-recent binder, so `h` is listed last.
theorem contradiction_from_pair_equality
        (m n : Natural) (h : False) : m = n :=
  claim

-- (4) Contradiction with a concrete impossible: a hypothesis of
-- type `0 = 1` is contradictory via
-- `Natural.zero_not_successor`. The auto-prover doesn't search
-- arbitrary inequalities, but this still demonstrates that an
-- explicit `Not(P)` paired with `P` works.
theorem contradiction_from_explicit
        (Q : Proposition)
        (h_eq : 0 = 1)
        (h_neq : Not(0 = 1))
        : Q :=
  claim

module Test.disjunctive_syllogism_test

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order

-- Disjunctive syllogism (PLAN_LANGUAGE_IMPROVEMENT.md, prover block):
-- `A ∨ B` with `¬A` in scope concludes B by-less — the Or-elimination
-- a mathematician performs without announcing a case split.

-- The right side survives when the left is refuted.
theorem syllogism_right (A B : Proposition) (either : A ∨ B) (notLeft : Not(A)) : B := {
  B;
  done
}

-- The left side survives when the right is refuted.
theorem syllogism_left (A B : Proposition) (either : A ∨ B) (notRight : Not(B)) : A := {
  A;
  done
}

-- Conjunction legs participate: the disjunction and the refutation may
-- both arrive inside an ∧-package.
theorem syllogism_through_conjunction (A B C : Proposition)
        (packaged : (A ∨ B) ∧ C) (refutation : Not(B) ∧ C) : A := {
  A;
  done
}

-- The concrete shape the lint triage saw: a totality split with the
-- strict arm refuted by an in-scope negation.
theorem syllogism_totality (n m : Natural)
        (total : n < m ∨ m ≤ n) (notBelow : Not(n < m)) : m ≤ n := {
  m ≤ n;
  done
}

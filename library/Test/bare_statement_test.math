-- A1 stage 1: keyword-free claims. A bare stated proposition at
-- statement position reads exactly as a `claim`: verified by the
-- auto-prover (or an attached `by`), then in scope for later steps.
-- The block-final expression (no `;`, or `;}`) keeps its old meaning.
module Test.bare_statement_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order

-- A bare proposition is a claim; the next statement sees it.
theorem Test.bare_statement_binds (a b : Natural)
        (h : a ≤ b) : a ≤ b + 0 := {
  b + 0 = b;
  done
}

-- With a `by` hint, and named via `as` for a later citation.
theorem Test.bare_statement_by_and_as (a b c : Natural)
        (h1 : a ≤ b) (h2 : b ≤ c) : a ≤ c := {
  a ≤ c by Natural.LessOrEqual.transitive as conclusion;
  done by conclusion
}

-- A bare PROOF TERM states its type (the claim-of-a-proof mirror).
theorem Test.bare_proof_term (a b : Natural)
        (h : a + b = b + a) : a + b = b + a := {
  h;
  done
}

-- Ending a block by restating the goal (the "therefore, P. ∎" form):
-- the final expression is a proposition equal to the goal.
theorem Test.block_ends_by_restating (a : Natural) (h : a ≤ 3)
        : a ≤ 3 := {
  a ≤ 3
}

-- A sequence of bare statements, including cited ones.
theorem Test.bare_statement_sequence (a b c : Natural)
        (h1 : a ≤ b) (h2 : b ≤ c) : a ≤ c + 0 := {
  c + 0 = c;
  a ≤ c by Natural.LessOrEqual.transitive;
  a ≤ c + 0;
  done
}

-- A keyword-free relation CHAIN is a calc with no anchor word — the
-- blackboard `m = 2 * 0 = 0` shape.
theorem Test.bare_chain (m : Natural) (h : m = 2 * 0) : m = 0 := {
  m = 2 * 0 = 0;
  done
}

-- The structured hint forms work on bare statements too — the same
-- shared tail parser as `claim`.
theorem Test.bare_by_substituting (a b : Natural)
        (h : a ≤ 5) (eq : a = b) : b ≤ 5 := {
  b ≤ 5 by substituting eq;
  done
}

theorem Test.bare_by_cases (a b : Natural)
        (split : a = 0 ∨ 1 ≤ a) : a ≤ a + b := {
  a ≤ a + b by cases {
    case a = 0: { done }
    case 1 ≤ a: { done }
  };
  done
}

-- Mixed relations chain too; the strongest relation is the bound fact.
theorem Test.bare_mixed_chain (a b c : Natural)
        (h1 : a ≤ b) (h2 : b < c) : a < c + 0 := {
  a ≤ b < c = c + 0;
  done
}

-- A mid-block bare statement followed by a bare FINAL restate (no
-- explicit `done`): the auto-prover closes the goal by structural
-- hypothesis match against the earlier statement.
theorem Test.bare_statement_then_bare_restate
        (a b : Natural) (aEqB : a = b)
        : b = a := {
  a = b;
  b = a
}

-- Same shape with an explicit `by` hint on the mid-block statement.
theorem Test.bare_statement_by_then_bare_restate
        (a b c : Natural) (aEqB : a = b)
        : a = b := {
  a = b by aEqB;
  a = b
}

-- A chain of mid-block statements followed by a bare final restate.
theorem Test.bare_statement_chain_then_bare_restate
        (a b c : Natural) (aEqB : a = b) (bEqC : b = c)
        : a = c := {
  a = b;
  b = c;
  a = c
}

-- Mixed with `suppose`: the suppose binder lands first, then a
-- mid-block bare statement consumes it, then a bare final restate
-- closes the goal.
theorem Test.bare_statement_with_suppose
        (P Q : Proposition) (impliesPQ : P → Q)
        : P → Q := {
  suppose P as hP;
  Q by impliesPQ(hP);
  Q
}

-- A7 `from <fact>: <instance>;` — restate a hypothesis after
-- substituting in-scope equations into it. The source fact is named
-- first; the transformed statement is what sits on the page.
module Test.from_instance_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order

-- The instance is the fact with an in-scope equation substituted.
theorem Test.from_transports (a b c : Natural)
        (h : a + c ≤ 7) (eq : a = b) : b + c ≤ 7 := {
  from h: b + c ≤ 7;
  done
}

-- `as NAME` binds the instance for later citation by name.
theorem Test.from_binds_name (a b : Natural)
        (h : a ≤ 5) (eq : a = b) : b + 0 ≤ 5 := {
  from h: b ≤ 5 as bBound;
  calc b + 0
     = b
     ≤ 5     by bBound
}

-- The degenerate case: the instance IS the fact (no rewriting needed).
theorem Test.from_identity (a : Natural) (h : a ≤ 3) : a ≤ 3 := {
  from h: a ≤ 3;
  done
}

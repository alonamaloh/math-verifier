-- F4 — ≠ across the coercion tower (tryCastNotEqualTier): a goal
-- `ι a ≠ ι b` closes bare from an in-scope `a ≠ b` through the hop's
-- `injective` lemma (iterated down the tower), and the reflects twin
-- `a ≠ b` closes from `ι a ≠ ι b` through ι-congruence. Pinned here so
-- the hand-built `suppose … for contradiction` blocks of
-- `LessThan_preserves`-style proofs stay unnecessary.

module Test.cast_not_equal_test

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.order
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.archimedean

-- Preserves, one hop: ℤ → ℚ.
theorem Test.cast_not_equal_test.preserves_one_hop (a b : Integer)
        (distinct : a ≠ b) : (a : Rational) ≠ (b : Rational) := {
  done
}

-- Preserves, two hops: ℕ → ℤ → ℚ (the injective chain iterates).
theorem Test.cast_not_equal_test.preserves_two_hops (m n : Natural)
        (distinct : m ≠ n) : (m : Rational) ≠ (n : Rational) := {
  done
}

-- Preserves with the fact stated the other way around.
theorem Test.cast_not_equal_test.preserves_swapped (a b : Integer)
        (distinct : b ≠ a) : (a : Rational) ≠ (b : Rational) := {
  done
}

-- Reflects, one hop: the ≠ at the image carrier refutes the source
-- equality through ι-congruence — no packet lemma involved.
theorem Test.cast_not_equal_test.reflects_one_hop (a b : Integer)
        (castDistinct : (a : Rational) ≠ (b : Rational)) : a ≠ b := {
  done
}

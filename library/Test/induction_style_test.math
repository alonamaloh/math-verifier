-- Test the by_induction-on-cases proof style. Should let us write
-- `a * succ(b) = a + a*b` in a mathematician-friendly induction
-- form. The existing parser already supports
--   by_induction on EXPR with IH_NAME { case ... }
-- where the IH is injected as an extra binder on each recursive
-- constructor pattern.

module Test.induction_style_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

-- The user's theorem, rewritten in the induction-tactic style.
-- This uses the EXISTING infrastructure:
--   by_induction on a with IH { case zero: ... case successor(p): ... }
-- The IH is injected as an extra binder on each recursive constructor;
-- inside `case successor(predecessor)`, the name `IH` refers to
-- `predecessor * successor(b) = predecessor + predecessor * b`.
theorem Natural.multiply_successor_inductive (a b : Natural)
        : a * successor(b) = a + a * b :=
  by_induction on a with IH {
    case zero:
      reflexivity(zero);
    case successor(predecessor):
      -- (Original verbose version below; the un-reduced form follows
      -- as `Natural.multiply_successor_unreduced`.)
      -- The kernel β-reduces both sides of the goal:
      --   LHS = successor(predecessor) * successor(b)
      --       ≡ successor(b) + predecessor * successor(b)
      --       ≡ successor(b + predecessor * successor(b))
      --   RHS = successor(predecessor) + successor(predecessor) * b
      --       ≡ successor(predecessor + successor(predecessor) * b)
      --       ≡ successor(predecessor + (b + predecessor * b))
      -- So the visible goal is
      --   successor(b + predecessor * successor(b))
      --   = successor(predecessor + (b + predecessor * b))
      -- which we prove by rewriting under the `successor(_)` wrapper.
      calc successor(b + predecessor * successor(b))
         = successor(b + (predecessor + predecessor * b))
              by rewrite(IH)
         = successor((b + predecessor) + predecessor * b)
              by Natural.add_associative(
                     b, predecessor, predecessor * b)
         = successor((predecessor + b) + predecessor * b)
              by rewrite(Natural.add_commutative(b, predecessor))
         = successor(predecessor + (b + predecessor * b))
              by rewrite(Natural.add_associative(
                  predecessor, b, predecessor * b));
  }

-- Same proof, written with the calc LHS in its un-reduced surface
-- form. Each step is honest about whether it's a β-reduction (only
-- the kernel's definitional equality is needed) or a real rewrite
-- (needs an explicit lemma).
theorem Natural.multiply_successor_unreduced (a b : Natural)
        : a * successor(b) = a + a * b :=
  by_induction on a with IH {
    case zero:
      reflexivity(zero);
    case successor(predecessor):
      -- IH : predecessor * successor(b) = predecessor + predecessor * b
      calc successor(predecessor) * successor(b)
         -- β of * on the LHS exposes the IH-shaped subterm.
         = successor(b) + predecessor * successor(b)
              by reflexivity(successor(b) + predecessor * successor(b))
         -- Apply IH under successor(b) + _.
         = successor(b) + (predecessor + predecessor * b)
              by rewrite(IH)
         -- Algebra of +: re-associate and swap.
         = successor((b + predecessor) + predecessor * b)
              by congruenceOf(
                     successor,
                     Equality.symmetry(Natural.add_associative(
                         b, predecessor, predecessor * b)))
         = successor((predecessor + b) + predecessor * b)
              by congruenceOf(
                     (rest : Natural) ↦
                         successor(rest + predecessor * b),
                     Natural.add_commutative(b, predecessor))
         = successor(predecessor + (b + predecessor * b))
              by congruenceOf(
                     successor,
                     Natural.add_associative(
                         predecessor, b, predecessor * b))
         -- β of * on the RHS, in reverse.
         = successor(predecessor) + successor(predecessor) * b
              by reflexivity(successor(predecessor + (b + predecessor * b)));
  }

-- Same proof, but using bare `reflexivity` (no args) — the
-- elaborator infers the subject from the calc step's expected
-- equality type and closes the step when both sides are
-- definitionally equal.
theorem Natural.multiply_successor_bare_reflexivity (a b : Natural)
        : a * successor(b) = a + a * b :=
  by_induction on a with IH {
    case zero: reflexivity;
    case successor(predecessor):
      calc successor(predecessor) * successor(b)
         = successor(b) + predecessor * successor(b)             by reflexivity
         = successor(b) + (predecessor + predecessor * b)        by rewrite(IH)
         = successor((b + predecessor) + predecessor * b)
              by congruenceOf(
                     successor,
                     Equality.symmetry(Natural.add_associative(
                         b, predecessor, predecessor * b)))
         = successor((predecessor + b) + predecessor * b)
              by congruenceOf(
                     (rest : Natural) ↦
                         successor(rest + predecessor * b),
                     Natural.add_commutative(b, predecessor))
         = successor(predecessor + (b + predecessor * b))
              by congruenceOf(
                     successor,
                     Natural.add_associative(
                         predecessor, b, predecessor * b))
         = successor(predecessor) + successor(predecessor) * b   by reflexivity;
  }

-- The manual `congruenceOf` chunks above deliberately exercise the
-- rewrite-under-successor idioms; `ring` closes the same identity
-- outright (on Natural, numerals fold and successor(e) reads as 1 + e),
-- no induction needed:
theorem Natural.multiply_successor_by_ring (a b : Natural)
        : a * successor(b) = a + a * b := ring

-- `rewrite` doesn't see through goal-side β-reductions, so the
-- inner-of-successor algebra needs explicit `congruenceOf`. With a
-- WHNF-aware structural matcher (or definitional-equality fallback in
-- abstractStructuralOccurrence), the three congruenceOf lines below
-- would collapse to three `by rewrite(...)` lines.

-- Smallest test: `=` step with no `by` clause. The auto-prover
-- closes when the two sides are definitionally equal.
theorem calc_no_by_reflexive (a b : Natural)
        : a + b = a + b :=
  calc a + b
     = a + b

-- One-step calc with `by` omitted, relying on the kernel β of
-- Natural.add for successor in the first argument.
theorem calc_no_by_beta (b : Natural) (Y : Natural)
        : Natural.add(successor(b), Y) = successor(Natural.add(b, Y)) :=
  calc Natural.add(successor(b), Y)
     = successor(Natural.add(b, Y))

-- Commutativity at a single position, no `by` clause.
-- The auto-prover detects subL = op(a, b), subR = op(b, a) and looks
-- up Natural.add as commutative.
theorem calc_no_by_commutative (a b : Natural)
        : a + b = b + a :=
  calc a + b
     = b + a

-- Associativity at a single position.
theorem calc_no_by_associative (a b c : Natural)
        : (a + b) + c = a + (b + c) :=
  calc (a + b) + c
     = a + (b + c)

-- Associativity reversed: uses Equality.symmetry under the hood.
theorem calc_no_by_associative_reverse (a b c : Natural)
        : a + (b + c) = (a + b) + c :=
  calc a + (b + c)
     = (a + b) + c

-- Commutativity at a nested position: inside successor(_).
-- Exercises the path-aware congruence wrapping.
theorem calc_no_by_commutative_nested (a b : Natural)
        : successor(a + b) = successor(b + a) :=
  calc successor(a + b)
     = successor(b + a)

-- Multi-step chain mixing commutativity, associativity, and
-- definitional equality, all without `by`. This is the form we
-- want the multiply_successor proof to eventually shrink down to.
theorem calc_no_by_chain (a b c : Natural)
        : (a + b) + c = c + (a + b) :=
  calc (a + b) + c
     = c + (a + b)

-- Same algebraic chain as multiply_successor's nested rearrangement,
-- with all `by ...` clauses dropped. The auto-prover should classify
-- each step (associativity / commutativity / associativity-reverse)
-- and wrap with congruence under `successor(_)`.
theorem calc_no_by_multiply_successor_inner (b predecessor : Natural)
        : successor(b + (predecessor + predecessor * b))
        = successor(predecessor + (b + predecessor * b)) :=
  calc successor(b + (predecessor + predecessor * b))
     = successor((b + predecessor) + predecessor * b)
     = successor((predecessor + b) + predecessor * b)
     = successor(predecessor + (b + predecessor * b))

-- Multiply-successor with NO `by` clauses anywhere. The auto-prover
-- closes each step via reflexivity (β/ι/δ definitional equality),
-- IH lookup (local-hypothesis match), or commutativity/associativity
-- recognition + path-aware congruence.
theorem Natural.multiply_successor_no_by (a b : Natural)
        : a * successor(b) = a + a * b :=
  by_induction on a with IH {
    case zero: reflexivity;
    case successor(predecessor):
      calc successor(predecessor) * successor(b)
         = successor(b) + predecessor * successor(b)
         = successor(b) + (predecessor + predecessor * b)
         = successor((b + predecessor) + predecessor * b)
                by congruenceOf(
                       successor,
                       Equality.symmetry(Natural.add_associative(
                           b, predecessor, predecessor * b)))
         = successor((predecessor + b) + predecessor * b)
         = successor(predecessor + (b + predecessor * b))
         = successor(predecessor) + successor(predecessor) * b;
  }

-- Identity lemma: Natural.add_zero : (a) → a + 0 = a is auto-
-- detected (1 binder, conclusion op(BV(0), unit) = BV(0)). The
-- auto-prover should close `a + 0 = a` and the symmetric `a = a + 0`.
theorem calc_no_by_add_zero (a : Natural) : a + zero = a :=
  calc a + zero
     = a

theorem calc_no_by_add_zero_reverse (a : Natural) : a = a + zero :=
  calc a
     = a + zero

-- Identity at a sub-position: `successor(a + zero)` to `successor(a)`.
theorem calc_no_by_add_zero_nested (a : Natural)
        : successor(a + zero) = successor(a) :=
  calc successor(a + zero)
     = successor(a)

-- Multi-position AC rearrangement: `(a+b) + (c+d) = (b+a) + (d+c)`
-- changes the order of args in two places simultaneously. The single-
-- position diff walker bails because both function and argument
-- differ at the top level; the Phase-2 `ring` fallback succeeds by
-- flattening both sides and comparing multisets of leaves.
theorem calc_no_by_ac_multi_position (a b c d : Natural)
        : (a + b) + (c + d) = (b + a) + (d + c) :=
  calc (a + b) + (c + d)
     = (b + a) + (d + c)

-- Deeply nested AC rearrangement: `((a+b)+c)+d = a + (b + (c + d))`.
-- All four leaves preserved; structure completely re-balanced.
theorem calc_no_by_ac_reassociation (a b c d : Natural)
        : ((a + b) + c) + d = a + (b + (c + d)) :=
  calc ((a + b) + c) + d
     = a + (b + (c + d))

-- Definitional equality at calc step level: `succ(b) + X ≡
-- succ(b + X)` reduces in the kernel, so the def-eq strategy of the
-- auto-prover (its first pass) closes this without descent.
theorem calc_no_by_beta_at_head (b X : Natural)
        : Natural.add(successor(b), X) = successor(Natural.add(b, X)) :=
  calc Natural.add(successor(b), X)
     = successor(Natural.add(b, X))

-- Multi-level classification: the diff is at an INTERMEDIATE level
-- (not the deepest single-position diff). With `sumEq : x + z = y + z`
-- in scope, the auto-prover should match the hyp at the (x + z, y + z)
-- level instead of descending to (x, y). Regression test for the gap
-- the parallel-refactor agent surfaced.
theorem calc_intermediate_local_hyp_match
        (x y z : Natural) (sumEq : x + z = y + z)
        : (x + z) + z = (y + z) + z :=
  calc (x + z) + z
     = (y + z) + z

-- Version with bare `by IH` (auto-rewrite fallback).
theorem Natural.multiply_successor_by_IH (a b : Natural)
        : a * successor(b) = a + a * b :=
  by_induction on a with IH {
    case zero: reflexivity;
    case successor(predecessor):
      calc successor(predecessor) * successor(b)
         = successor(b) + predecessor * successor(b)             by reflexivity
         = successor(b) + (predecessor + predecessor * b)        by IH
         = successor((b + predecessor) + predecessor * b)
              by congruenceOf(
                     successor,
                     Equality.symmetry(Natural.add_associative(
                         b, predecessor, predecessor * b)))
         = successor((predecessor + b) + predecessor * b)
              by congruenceOf(
                     (rest : Natural) ↦
                         successor(rest + predecessor * b),
                     Natural.add_commutative(b, predecessor))
         = successor(predecessor + (b + predecessor * b))
              by congruenceOf(
                     successor,
                     Natural.add_associative(
                         predecessor, b, predecessor * b))
         = successor(predecessor) + successor(predecessor) * b   by reflexivity;
  }

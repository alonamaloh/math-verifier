-- Feature test: higher-order (reflexive) recursion in the kernel recursor.
--
-- `Accessible`'s constructor has a HIGHER-ORDER recursive field — the
-- recursive occurrence sits under `(predecessor : A) → r(predecessor, subject) →`.
-- The recursor must therefore hand each minor premise an induction hypothesis
-- for that field (`belowRecursion`), and its ι-reduction must supply the
-- matching recursive-call function. This exercises both the recursor's TYPE
-- (buildCaseType) and its REDUCTION (buildIotaReduction).
--
-- Lives under Test/ for now: the lean4 exporter does not yet emit reflexive
-- recursors, so `Accessible` cannot be a real library module until that lands.

module Test.well_founded_test

import Logic.basics
import Natural.basics
import Equality.basics

inductive Accessible.{u} (A : Type(u)) (r : A → A → Proposition) : A → Type(u) where
  | Accessible.introduce
      : (subject : A)
        → ((predecessor : A) → r(predecessor, subject) → Accessible(A, r, predecessor))
        → Accessible(A, r, subject)

definition WellFounded.{u} (A : Type(u)) (r : A → A → Proposition) : Type(u) :=
  (subject : A) → Accessible(A, r, subject)

-- The recursor hands `step` the recursion for every predecessor
-- (`belowRecursion`) — this only type-checks if buildCaseType generated the
-- higher-order induction hypothesis.
definition WellFounded.recursionFromAccessible.{u, w}
        (A : Type(u)) (r : A → A → Proposition) (C : A → Type(w))
        (step : (subject : A)
                → ((predecessor : A) → r(predecessor, subject) → C(predecessor))
                → C(subject))
        (subject : A) (accessibility : Accessible(A, r, subject))
        : C(subject) :=
  Accessible_recursor(
    A, r,
    (element : A) (_ : Accessible(A, r, element)) ↦ C(element),
    (element : A)
        (below : (predecessor : A) → r(predecessor, element)
                 → Accessible(A, r, predecessor))
        (belowRecursion : (predecessor : A) → r(predecessor, element)
                          → C(predecessor)) ↦
      step(element, belowRecursion),
    subject, accessibility)

-- Every element is accessible under the empty relation (no predecessors).
definition alwaysAccessible (n : Natural)
        : Accessible(Natural, (first second : Natural) ↦ False, n) :=
  Accessible.introduce(Natural, (first second : Natural) ↦ False, n,
      (predecessor : Natural) (impossible : False) ↦
          False.eliminate(Accessible(Natural, (first second : Natural) ↦ False, predecessor),
              impossible))

-- A well-founded recursion whose step ignores the recursion and returns 0.
definition Test.constantlyZero (n : Natural) : Natural :=
  WellFounded.recursionFromAccessible(
      Natural, (first second : Natural) ↦ False, (_ : Natural) ↦ Natural,
      (subject : Natural)
          (belowRecursion : (predecessor : Natural) → False → Natural) ↦ 0,
      n, alwaysAccessible(n))

-- ι-reduction check: recursing over the concrete `Accessible.introduce` value
-- must reduce, so this closes by computation.
theorem Test.constantlyZero_reduces (n : Natural)
        : Test.constantlyZero(n) = 0 :=
  done by unfolding Test.constantlyZero, alwaysAccessible

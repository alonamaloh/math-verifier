-- Test motive inference for Quotient.induct / induct_two / induct_three.
-- The motive argument can be `_` (explicit hole) or omitted entirely
-- (the 2 / 3 / 4-arg forms). The elaborator synthesises the motive by
-- abstracting the scrutinees in the expected type.

module Test.quotient_motive_inference_test

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.addition

-- (1) Quotient.induct: motive inferred (omitted, 2-arg form).
theorem induct_inferred_omitted (x : Integer) : x = x :=
  Quotient.induct(
      function (rep_x : IntegerRepresentative) =>
          reflexivity(Integer, (Quotient.mk(rep_x) : Integer)),
      x)

-- (2) Quotient.induct: motive inferred via explicit `_`.
theorem induct_inferred_underscore (x : Integer) : x = x :=
  Quotient.induct(
      _,
      function (rep_x : IntegerRepresentative) =>
          reflexivity(Integer, (Quotient.mk(rep_x) : Integer)),
      x)

-- (3) Quotient.induct_two: motive omitted (3-arg form). Goal mentions
-- BOTH scrutinees so motive abstraction has to fire on each.
theorem induct_two_inferred_omitted
        (x y : Integer)
        : x + y = x + y :=
  Quotient.induct_two(
      function (rep_x rep_y : IntegerRepresentative) =>
          reflexivity(
              Integer,
              (Quotient.mk(rep_x) : Integer) + (Quotient.mk(rep_y) : Integer)),
      x, y)

-- (4) Quotient.induct_two: motive via `_`.
theorem induct_two_inferred_underscore
        (x y : Integer)
        : x + y = x + y :=
  Quotient.induct_two(
      _,
      function (rep_x rep_y : IntegerRepresentative) =>
          reflexivity(
              Integer,
              (Quotient.mk(rep_x) : Integer) + (Quotient.mk(rep_y) : Integer)),
      x, y)

-- (5) Quotient.induct_three: motive omitted (4-arg form). Goal mentions
-- all three.
theorem induct_three_inferred_omitted
        (x y z : Integer)
        : x + y + z = x + y + z :=
  Quotient.induct_three(
      function (rep_x rep_y rep_z : IntegerRepresentative) =>
          reflexivity(
              Integer,
              (Quotient.mk(rep_x) : Integer)
              + (Quotient.mk(rep_y) : Integer)
              + (Quotient.mk(rep_z) : Integer)),
      x, y, z)

-- (6) Goal mentions only ONE scrutinee — the motive's constant-fallback
-- path fires for the others.
theorem induct_two_partial_goal
        (x y : Integer)
        : x = x :=
  Quotient.induct_two(
      function (rep_x rep_y : IntegerRepresentative) =>
          reflexivity(Integer, (Quotient.mk(rep_x) : Integer)),
      x, y)

-- (7) `cases x { | rep_x => body }` on a Quotient scrutinee — bare-name
-- pattern (no Quotient.mk wrap). Equivalent to the existing
-- Quotient.mk(rep_x) form but reads more directly.
theorem cases_bare_name (x : Integer) : x = x :=
  cases x {
    | rep_x => reflexivity(Integer, (Quotient.mk(rep_x) : Integer))
  }

-- (8) `cases x { | IntegerRepresentative.make(a, b) => body }` —
-- destructure the representative directly without writing
-- `Quotient.mk(IntegerRepresentative.make(a, b))`.
theorem cases_direct_destructure (x : Integer) : x = x :=
  cases x {
    | IntegerRepresentative.make(a, b) =>
        reflexivity(Integer,
            (Quotient.mk(IntegerRepresentative.make(a, b)) : Integer))
  }

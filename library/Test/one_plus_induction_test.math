-- Exercises the `1 + n` form of `by induction` (the successor-sealing
-- keystone, PLAN_LUX_TRANSITION.md): `case base:` / `case step(k):`
-- routes to `Natural.induction_on_one_plus`, the step goal is `P(1 + k)`
-- with `IH : P(k)`, and no `successor` token appears.

module Test.one_plus_induction_test

import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.one_plus_induction
import Equality.basics
import Logic.basics

-- Mechanism: motive build + base + step + assembly, fully kernel-checked.
-- (If the step goal weren't P(1+k) or IH weren't P(k), the assembled
-- induction_on_one_plus application would fail to typecheck.)
theorem Test.reflexive_one_plus (n : Natural) : n = n :=
  by induction on n with IH {
    case base:    done
    case step(k): done
  }

-- IH usage: the step goal is genuinely `(1 + k) + 0 = 1 + k` and the
-- hypothesis is `IH : k + 0 = k`.
theorem Test.add_zero_one_plus (a : Natural) : a + 0 = a :=
  unfold Natural.add in
  by induction on a with IH {
    case base:    done
    case step(k): done
  }

-- Pi-returning goal + lambda step body: the function-typed motive case.
theorem Test.pi_goal_one_plus (n : Natural) : ∀ (k : Natural). k = k :=
  by induction on n with IH {
    case base:    (k : Natural) ↦ done
    case step(p): (k : Natural) ↦ done
  }

-- `refining` with the `1 + n` form: the named hypothesis (whose type
-- mentions the induction variable) is reverted into the motive, so it is
-- refined per case — `∀ j. j < 0 → P(j)` in base, `∀ j. j < 1 + k → P(j)`
-- in step — and the IH becomes a function expecting it. Before the refining
-- port to `induction_on_one_plus`, the hypothesis stayed pinned at the
-- original `n`, so `case step`'s body failed to typecheck against the goal.
theorem Test.refining_one_plus
        (P : Natural → Proposition)
        (n : Natural)
        (hypothesis : ∀ (j : Natural). j < n → P(j))
        : ∀ (j : Natural). j < n → P(j) :=
  by induction on n with IH refining hypothesis {
    case base:    hypothesis
    case step(k): hypothesis
  }

-- ∀-target scrutinee: the induction variable is bound by the GOAL's
-- leading `∀`, not a local parameter — `by induction on j` peels the Pi,
-- runs the induction with `j` in scope, and re-wraps in a lambda. The raw
-- recursor (`case zero`/`case successor`) always handled this; the `1 + n`
-- form needed the Pi-introduction added to `elaborateByInductionOnePlus`.
theorem Test.forall_target_one_plus : ∀ (j : Natural). j + 0 = j :=
  unfold Natural.add in
  by induction on j with IH {
    case base:    done
    case step(k): done
  }

-- Regression: a parametric goal `P(k)` (a bound-variable-headed
-- application) with a nested `cases` in the step body. This exposed the
-- base-binder de Bruijn bug — the step type is extracted from under the
-- (unused) `base` argument of induction_on_one_plus, so its localBinder
-- indices must be strengthened by one or the cases motive references a
-- loose variable (P at the wrong index).
theorem Test.parametric_goal_with_cases
        (P : Natural → Proposition) (give : ∀ (q : Natural). P(q))
        (n : Natural) : ∀ (k : Natural). P(k) :=
  by induction on n with IH {
    case base: (k : Natural) ↦ give(k)
    case step(p): (k : Natural) ↦ {
      claim orFact : (k = k) ∨ (k = k) by Or.introduceLeft(done);
      cases orFact {
        | Or.introduceLeft(e)  => give(k)
        | Or.introduceRight(e) => give(k)
      }
    }
  }

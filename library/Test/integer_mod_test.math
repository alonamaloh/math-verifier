-- Test/integer_mod_test.math
--
-- Smoke tests for IntegerMod: the operators dispatch, the commutative
-- ring instance holds for an arbitrary modulus, and F_2 is a field.

module Test.integer_mod_test

import Natural.basics
import Natural.prime
import Natural.prime_two
import Algebra.ring
import Algebra.field
import IntegerMod.basics
import IntegerMod.operations
import IntegerMod.instances
import IntegerMod.field

-- The +, *, − operators dispatch on IntegerMod.
definition test_add (x y : IntegerMod(5)) : IntegerMod(5) := x + y
definition test_multiply (x y : IntegerMod(5)) : IntegerMod(5) := x * y
definition test_subtract (x y : IntegerMod(5)) : IntegerMod(5) := x - y

-- IntegerMod(m) is a commutative ring for every modulus.
theorem test_is_commutative_ring (m : Natural)
        : IsCommutativeRing(IntegerMod(m),
                            IntegerMod.add,
                            IntegerMod.zero(m), IntegerMod.negate,
                            IntegerMod.multiply,
                            IntegerMod.one(m)) :=
  IntegerMod.is_commutative_ring(m)

-- F_2 is a field.
theorem test_F2_is_field
        : IsField(IntegerMod(2),
                  IntegerMod.add,
                  IntegerMod.zero(2), IntegerMod.negate,
                  IntegerMod.multiply,
                  IntegerMod.one(2)) :=
  IntegerMod.is_field(2, Natural.is_prime_two)

-- ----------------------------------------------------------------------
-- Short Quotient.{mk,sound,lift} over the PARAMETERIZED alias
-- IntegerMod(modulus). These regress the over-unfolding bug where the
-- short forms recovered the relation by WHNF-ing IntegerMod(modulus)
-- past Integer.CongruentModulo into the underlying Integer.divides
-- existential (Quotient.sound leaked the `modulus` BoundVariable; the
-- proof-fallback recovered `Exists` as the relation head).

-- short Quotient.mk against a parameterized expected type
definition short_mk (modulus : Natural) (a : Integer) : IntegerMod(modulus) :=
  Quotient.mk(a)

-- short Quotient.sound, relation recovered from the expected Equality
theorem short_sound (modulus : Natural) (a b : Integer)
        (h : Integer.CongruentModulo(modulus, a, b))
        : (Quotient.mk(a) : IntegerMod(modulus)) = Quotient.mk(b) :=
  Quotient.sound(a, b, h)

-- (Short Quotient.lift over IntegerMod, including a respect handler whose
-- inner short Quotient.sound gets NO propagated expected type — relation
-- recovered structurally from the proof's type — is exercised directly by
-- IntegerMod.negate / IntegerMod.add / IntegerMod.multiply in
-- IntegerMod/operations.math.)

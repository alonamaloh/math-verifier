-- Demonstration: the geometric series 1 + 1/2 + 1/4 + … = 2, written in
-- the trailing-ellipsis series notation, closed by
-- Real.geometric_series_converges at r = 1/2, L = 2.

module Test.geometric_half_demo

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Algebra.monoid
import Algebra.aggregation
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.order
import Real.order_field
import Real.division
import Real.reciprocal
import Real.absolute_value
import Real.absolute_value_order
import Real.power
import Real.sequence
import Real.convergence
import Real.series

theorem Test.geometric_half_sums_to_two
        : (1/2 : Real)^0 + (1/2 : Real)^1 + ... + (1/2 : Real)^k + ...
          = (2 : Real) := {
  (1/2 : Real) > 0;
  (1/2 : Real) ≥ 0;
  Real.IsNonneg((1/2 : Real));
  (1/2 : Real) < 1;
  abs((1/2 : Real))
     = (1/2 : Real)               by Real.absolute_value_when_nonneg
     < 1
     = Real.one
     as ratioBelowOne;
  (Real.one - (1/2 : Real)) * 2 = Real.one   by field   as inverseHolds;
  done by Real.geometric_series_converges(
      r := 1/2, L := 2, rSmall := ratioBelowOne, inverseProperty := inverseHolds)
}

-- D stage-5: implementation-side lemmas about Counter, stated in
-- interface vocabulary — bulk-exported by the interface via
-- `export theorems of Test.counter_lemmas`.
module Test.counter_lemmas

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Test.counter_implementation

theorem Test.Counter.read_of_tick (c : Test.Counter)
        : Test.Counter.read(Test.Counter.tick(c)) = 1 + Test.Counter.read(c) :=
  done

automatic theorem Test.Counter.tick_read_positive (c : Test.Counter)
        : 1 ≤ Test.Counter.read(Test.Counter.tick(c)) := {
  calc 1
     ≤ 1 + Test.Counter.read(c)
     = Test.Counter.read(Test.Counter.tick(c))   by Test.Counter.read_of_tick
}

-- A definition stated purely in interface vocabulary — the transparent
-- re-export candidate (`export definitions Test.Counter.double`).
definition Test.Counter.double (c : Test.Counter) : Natural :=
  Test.Counter.read(c) + Test.Counter.read(c)

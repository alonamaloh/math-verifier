-- Smoke test: the generic RingModulo construction over a concrete
-- bundled ring. RingModulo(integerRing, m) is Z modulo the ideal (m) —
-- the same object IntegerMod(n) builds by hand — recovered here as an
-- instance of the generic "ring modulo a principal ideal" construction.
module Test.ring_modulo_test

import Natural.basics
import Logic.basics
import Equality.basics
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.instances
import Algebra.monoid
import Algebra.group
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import RingModulo.basics
import RingModulo.operations
import RingModulo.ring
import RingModulo.instances

-- The integers as a bundled commutative ring. Commutativity is exactly
-- Integer.multiply_commutative, read as a Ring.MultiplyCommutative.
definition integerCommutativeRing : CommutativeRing :=
  CommutativeRing.make(
      Ring.make(Integer, Integer.add, Integer.zero, Integer.negate,
          Integer.multiply, Integer.one, Integer.is_ring),
      Integer.multiply_commutative)

-- Z/(m) is a type for every integer m.
definition test_quotient_type (m : Integer) : Type(0) :=
  RingModulo(integerCommutativeRing, m)

-- Z/(m) is a commutative ring — the same object IntegerMod(n) builds by
-- hand, recovered from the generic principal-ideal quotient.
theorem test_quotient_is_commutative_ring (m : Integer)
        : IsCommutativeRing(
              RingModulo(integerCommutativeRing, m),
              RingModulo.add,
              RingModulo.zero(integerCommutativeRing, m),
              RingModulo.negate,
              RingModulo.multiply,
              RingModulo.one(integerCommutativeRing, m)) :=
  RingModulo.is_commutative_ring(integerCommutativeRing, m)

-- ----------------------------------------------------------------------
-- The `ring` tactic at RingModulo carriers (regression: the operation
-- recognizer used to be a `<T>.add` naming convention, which no
-- RingModulo quotient satisfies — operations live under `RingModulo`
-- with the base ring and modulus as leading arguments).

theorem test_ring_tactic_at_quotient (m : Integer)
        (x y : RingModulo(integerCommutativeRing, m))
        : x * (y + x) = x * y + x * x := ring

-- Subtraction and unary negation unfold (also regression for unary `-`
-- dispatching through the alias chain to `RingModulo.negate`).
theorem test_ring_tactic_subtract (m : Integer)
        (x y : RingModulo(integerCommutativeRing, m))
        : y - x = -(x - y) := ring

theorem test_ring_tactic_cancel (m : Integer)
        (x y : RingModulo(integerCommutativeRing, m))
        : (x + y) - x = y := ring

-- Operators dispatch inside a pattern-DEFINITION body (the recursive
-- self-reference's induction-hypothesis binder used to carry a stuck
-- motive application instead of the declared alias type).
definition test_quotient_partial_sums (m : Integer)
        (s : Natural → RingModulo(integerCommutativeRing, m))
        : Natural → RingModulo(integerCommutativeRing, m)
  | zero => RingModulo.zero(integerCommutativeRing, m)
  | successor(n) => test_quotient_partial_sums(m, s, n) + s(n)

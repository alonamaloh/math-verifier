-- Test/center_test.math
--
-- The abstract center (Algebra/center) against a concrete group: in the
-- abelian group (ℤ, +) every element commutes with every other, so the
-- center is the whole group. We prove arbitrary z is central — the
-- centrality law z·g = g·z is the commutativity of integer addition,
-- closed by `ring` (the bundle's Group.operation reduces to Integer.add
-- by definitional equality, exactly as in group_theory_test).
--
-- We then read off, with no extra work, that the identity 0 is central
-- via the generic `Group.center.contains_identity`.

module Test.center_test

import Logic.basics
import Equality.basics
import Set.basics
import Integer.basics
import Integer.addition
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.instances
import Algebra.group
import Algebra.group_bundle
import Algebra.center

-- Every integer is central in (ℤ, +): z + g = g + z for all g.
theorem Integer.every_element_central (z : Integer)
        : z ∈ Group.center(Integer.additive_group) :=
  (g : Integer) ↦
    (ring : z + g = g + z)

-- The identity (0) is central — straight from the generic lemma.
theorem Integer.zero_central
        : Integer.zero ∈ Group.center(Integer.additive_group) :=
  Group.center.contains_identity(Integer.additive_group)

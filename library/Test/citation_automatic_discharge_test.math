-- Feature test: citation premise discharge falls back to the bare
-- prover (budget-capped), so a premise that is not a stated hypothesis
-- but closes from `automatic` lemmas — here `start ≤ start + c` via
-- Natural.less_or_equal_add_right — no longer forces a scaffolding
-- claim before the citation. (The A7 known-gap fix; the pattern is the
-- one hit while proving Algebra.Fold_pointwise.)
module Test.citation_automatic_discharge_test
import Logic.basics
import Equality.basics
import Natural.basics
import Natural.order

theorem Test.guarded_citation_discharges (f g : Natural → Natural)
        (start c : Natural)
        (pointwiseEqual : ∀ (j : Natural). start ≤ j → f(j) = g(j))
        : f(start + c) = g(start + c) := {
  done by pointwiseEqual
}

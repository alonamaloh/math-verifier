-- Step 1 of the structured-proof feature: parser scaffolding for
-- `claim` at expression position. Real elaboration is Step 2; these
-- tests verify only that the parser accepts the new syntax. Each
-- theorem body elaborates to `sorry` for now and emits the standard
-- unresolved-proof warning at verify time.

module Test.structured_proof_test

import axioms
import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order

-- (1) Bare terminal claim: discharge the current goal by lookup.
theorem BareClaim (n : Natural) (h : zero ≤ n) : zero ≤ n :=
  claim

-- (2) Terminal claim with `by`: discharge the goal from a named lemma.
theorem ClaimByHint (n : Natural) : zero ≤ n :=
  claim by Natural.zero_le

-- (3) Non-terminal claim with explicit proposition.
theorem ClaimWithProposition (n : Natural) : zero ≤ n :=
  claim zero ≤ n by Natural.zero_le

-- (4) Disjunctive claim with arms. Future Step 4 will desugar this
-- into an `Or.eliminate`; for now each piece is just a parser test.
theorem DisjunctiveClaim (n : Natural) : zero ≤ n :=
  claim zero = n ∨ zero ≤ n {
    in (zero = n): claim
    in (zero ≤ n): claim
  }

-- (5) Disjunctive claim with `by` for the disjunction (Future: lookup
-- finds the inversion lemma) and per-arm bodies.
theorem DisjunctiveClaimWithHint (p m : Natural)
        (succP_le_succM : successor(p) ≤ successor(m))
        : p ≤ m :=
  claim p = m ∨ successor(p) ≤ m by Natural.less_or_equal_successor_successor_inversion {
    in (p = m): claim
    in (successor(p) ≤ m): claim by Natural.less_or_equal_predecessor_less_or_equal
  }

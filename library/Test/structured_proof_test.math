-- Structured-proof Step 2: `claim P by Hint` and `claim by Hint`
-- elaborate by auto-filling the hint's arguments. Step 1's parser
-- scaffolding covers all forms, but only the `by`-equipped ones
-- elaborate end-to-end at this point. Bare `claim` / `claim P`
-- (Step 5 lookup) and disjunctive arms (Step 4) are deferred.

module Test.structured_proof_test

import axioms
import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.strong_recursion

-- (1) Fully-applied hint: the hint's type already matches the goal.
theorem ClaimByFullyApplied (n : Natural) : zero ≤ n :=
  claim by Natural.zero_least(n)

-- (2) Bare-identifier hint: the hint's type is `(n : Natural) → zero ≤ n`;
-- the goal pins down `n`. The elaborator should fill it.
theorem ClaimByBareIdentifier (n : Natural) : zero ≤ n :=
  claim by Natural.zero_least

-- (3) Hint with a hypothesis argument: the hint's type is
-- `(a b : Natural) (h : succ(a) ≤ b) : a ≤ b`. The goal pins down
-- `a` and `b`; `h` comes from a local binder.
theorem ClaimByHintWithHypothesis (p m : Natural)
        (succPLeM : successor(p) ≤ m)
        : p ≤ m :=
  claim by Natural.less_or_equal_predecessor_less_or_equal

-- (4) Non-terminal claim with an explicit proposition.
theorem ClaimWithProposition (n : Natural) : zero ≤ n :=
  claim zero ≤ n by Natural.zero_least

-- (5) Step 4: disjunctive claim with arms. The user-facing shape
-- discussed in the design conversation. Each arm gets its disjunct
-- as an anonymous hypothesis (currently bound under the internal
-- name `_disjunct_hypothesis`; Step 3 will add `the (P)` lookup);
-- the body proves the surrounding goal. `Or.eliminate` is
-- synthesized at the kernel.
theorem ClaimDisjunctiveArms (p m : Natural)
        (succP_le_succM : successor(p) ≤ successor(m))
        : p ≤ m :=
  claim (p = m) ∨ (successor(p) ≤ m)
      by Natural.less_or_equal_successor_successor_inversion {
    in (p = m):
        Equality.transport_proposition(
            Natural,
            function (rightEnd : Natural) => p ≤ rightEnd,
            p, m, _disjunct_hypothesis,
            LessOrEqual.reflexivity(p))
    in (successor(p) ≤ m):
        claim by Natural.less_or_equal_predecessor_less_or_equal
  }

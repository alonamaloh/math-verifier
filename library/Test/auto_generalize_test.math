-- C1/A4: `cases`/`by induction` auto-generalize. When the scrutinee has
-- an in-scope hypothesis depending on it, the plain form reverts it into
-- the motive automatically, so the body sees the hypothesis refined per
-- case (and an IH quantifies over it). `generalizing b, c` is the
-- explicit form for induction LOADING — extra binders the IH must
-- quantify over.
module Test.auto_generalize_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Lists.basics

-- `equation : n = 0` depends on the scrutinee `n`. In the successor case
-- it is refined to `successor(k) = 0`, which is exactly the goal there —
-- so the body uses the refined hypothesis directly. Without auto-
-- generalize this fails, because the un-reverted `equation : n = 0`
-- does not match `successor(k) = 0`.
theorem Test.uses_refined_hypothesis (n : Natural) (equation : n = 0)
        : n = 0 :=
  done by cases {
    case n = 0: equation
    case n = successor(k) for some (k : Natural): equation
  }

-- Regression: a hypothesis whose type is a recursive predicate over a
-- non-Natural inductive scrutinee. The plain auto-generalize path used to
-- NON-TERMINATE (unbounded-memory loop → could crash the machine) on such
-- a hypothesis instead of failing fast; it must route straight to the
-- reverted path and terminate. (`member(0, list)` depends on the
-- scrutinee `list`.)
theorem Test.list_dependent_hypothesis (list : NaturalList)
        (h : NaturalList.member(0, list)) : True :=
  by induction on list with IH {
    case NaturalList.empty: True.trivial
    case NaturalList.prepend(head, tail): True.trivial
  }

-- Auto-generalize on the ONE-PLUS route (`case base:` / `case step():`):
-- aBound depends on the inducted variable, so it is reverted and the IH
-- takes the refined bound as an argument — no clause on the page.
theorem Test.one_plus_auto_generalize (b : Natural)
        : ∀ (a : Natural). a ≤ b → a ≤ b + 0 :=
  by induction on b with IH {
    case base: {
        take a : Natural;
        suppose a ≤ 0 as aBound;
        done
      }
    case step(k): {
        take a : Natural;
        suppose a ≤ 1 + k as aBound;
        done
      }
  }

-- `generalizing` (induction loading): the listed binder is lifted into
-- the motive, so the IH quantifies over it. (The full semantic exercise
-- — an IH applied at a DIFFERENT value of the loaded binder — is
-- `Natural.distance_respects_integer_equivalent` in the library.)
theorem Test.generalizing_loads_ih (a m : Natural) : 0 ≤ a + m :=
  by induction on a with IH generalizing m {
    case zero:         done by Natural.zero_least
    case successor(k): done by Natural.zero_least
  }

-- Bundle-operation citation bridge: a goal spelled with a carrier's OWN
-- operations (`Integer.multiply`, `Matrix.multiply`) accepts a citation
-- of the abstract `Ring.*` lemma — the matcher recovers the canonical
-- bundle (`Integer.ring_bundle`, `Matrix.ring(c, n)`) from the concrete
-- carrier and bridges `Ring.op(bundle, …)` to the concrete operation.
-- Before the bridge these citations failed ("arguments could not be
-- inferred") and had to be written as fully positional applications.
module Test.bundle_operation_citation_test

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.classical_decidable
import Integer.basics
import Integer.multiplication
import Integer.instances
import Set.finite
import Lists.list
import Algebra.monoid
import Algebra.group
import Algebra.group_lemmas
import Algebra.ring
import Algebra.ring_bundle
import Algebra.ring_lemmas
import Algebra.integer_domain
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.commutative_ring_aggregation
import Algebra.permutation_enumeration
import Algebra.matrix
import Algebra.matrix_ring

-- Parameterless bundle: ℤ's ring is `instance Integer.ring_bundle`.
theorem Test.integer_ring_lemma_bridges (x : ℤ) : x * (0 : ℤ) = (0 : ℤ) :=
  by Ring.multiply_zero_right

-- Parameterized bundle: the matrix ring `Matrix.ring(c, n)`.
theorem Test.matrix_ring_lemma_bridges {c : CommutativeRing} {n : ℕ}
        (X : Matrix(c, n, n))
        : X * Matrix.zero(c, n, n) = Matrix.zero(c, n, n) :=
  by Ring.multiply_zero_right

-- A three-operand law at the matrix bundle, cited argument-free where
-- the Cayley–Hamilton assembly previously needed the full positional
-- application.
theorem Test.matrix_ring_subtract_bridges {c : CommutativeRing} {n : ℕ}
        (X Y Z : Matrix(c, n, n))
        : X * (Y - Z) = X * Y - X * Z :=
  by Ring.multiply_subtract

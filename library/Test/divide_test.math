module Test.divide_test
import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.embedding
import Rational.basics

-- (1) Decidable side condition: the auto-prover proves `(2:Integer) ≠ 0`.
definition half : Rational := (1 : Integer) / (2 : Integer)

-- (2) Variable denominator, nonzeroness from a hypothesis in scope.
definition quotient_with_hypothesis
        (a : Integer) (b : Integer) (bNonzero : b ≠ Integer.zero) : Rational :=
  a / b

-- (3) The result really is the fraction a/b.
theorem divide_is_fraction
        (a : Integer) (b : Integer) (bNonzero : b ≠ Integer.zero)
        : a / b = Rational.fraction(a, b, bNonzero) :=
  reflexivity(Rational, a / b)

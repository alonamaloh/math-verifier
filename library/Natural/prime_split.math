-- Natural/prime_split.math
--
-- Proves Natural.prime_or_proper_divisor: for every n ≥ 2, either n is
-- prime or n has a proper divisor d with 2 ≤ d ≤ n-1. The proof goes
-- through a bounded search over candidate divisors in [2, n-1]. Each
-- candidate is tested using `Natural.decides_divides`, which is taken
-- as an axiom in this module (it's provable via a bounded search over
-- quotients in [0, n], using `q ≤ d·q when d ≥ 1` to cap the search;
-- the full proof would add another ~150 lines of bounded-induction
-- boilerplate).

module Natural.prime_split

import Natural.basics
import Natural.peano
import Natural.order
import Natural.divisibility
import Natural.prime
import Natural.strong_recursion
import Natural.decide
import Natural.decide_divides
import Equality.basics
import Logic.basics
import Logic.exists

-- Natural.decides_divides is now proven, not axiomatized — see
-- Natural.decide_divides. Bounded quotient search plus the cap
-- `q ≤ d·q when d ≥ 1`.

-- Searches for a divisor of n in the range [2, candidateBound] (with
-- candidateBound an inclusive upper bound). Returns either a witness
-- (the divisor in the range, with proofs that it's ≥ 2, ≤ bound, and
-- divides n) or a "no such divisor" function.
theorem Natural.search_proper_divisor_up_to (n : Natural)
        : (candidateBound : Natural)
          → Or(Exists(Natural, function (divisor : Natural) =>
                  2 ≤ divisor ∧ divisor ≤ candidateBound ∧ divisor ∣ n),
                (divisor : Natural)
                → 2 ≤ divisor
                → divisor ≤ candidateBound
                → ¬divisor ∣ n)
  | zero =>
      -- candidateBound = 0: range [2, 0] is empty, no candidate
      -- divisor exists. Anyone claiming 2 ≤ d ≤ 0 hits a contradiction
      -- (2 ≤ 0 is impossible).
      Or.introduceRight(
          function (divisor : Natural)
              (twoLessOrEqualDivisor : 2 ≤ divisor)
              (divisorLessOrEqualZero : divisor ≤ zero)
              (_ : divisor ∣ n) =>
            Natural.not_less_or_equal_successor_zero(1,
                Equality.transport_proposition(
                    Natural,
                    function (rightEnd : Natural) =>
                        2 ≤ rightEnd,
                    divisor, zero,
                    Natural.less_or_equal_zero_implies_equals_zero(
                        divisor, divisorLessOrEqualZero),
                    twoLessOrEqualDivisor)))
  | successor(predecessorOfBound) =>
      Or.eliminate(
          Exists(Natural, function (divisor : Natural) =>
              2 ≤ divisor ∧ divisor ≤ predecessorOfBound ∧ divisor ∣ n),
          (divisor : Natural)
              → 2 ≤ divisor
              → divisor ≤ predecessorOfBound
              → ¬divisor ∣ n,
          Or(Exists(Natural, function (divisor : Natural) =>
                  2 ≤ divisor ∧ divisor ≤ successor(predecessorOfBound) ∧ divisor ∣ n),
              (divisor : Natural)
                → 2 ≤ divisor
                → divisor ≤ successor(predecessorOfBound)
                → ¬divisor ∣ n),
          function (foundEarlier : Exists(Natural,
                  function (divisor : Natural) =>
                      2 ≤ divisor ∧ divisor ≤ predecessorOfBound ∧ divisor ∣ n)) =>
              Exists.eliminate(
                  Natural,
                  function (divisor : Natural) =>
                      2 ≤ divisor ∧ divisor ≤ predecessorOfBound ∧ divisor ∣ n,
                  Or(Exists(Natural, function (divisor : Natural) =>
                          2 ≤ divisor ∧ divisor ≤ successor(predecessorOfBound) ∧ divisor ∣ n),
                      (divisor : Natural)
                        → 2 ≤ divisor
                        → divisor ≤ successor(predecessorOfBound)
                        → ¬divisor ∣ n),
                  function (divisor : Natural)
                      (combined : 2 ≤ divisor ∧ divisor ≤ predecessorOfBound ∧ divisor ∣ n) =>
                    And.eliminate(
                        2 ≤ divisor,
                        divisor ≤ predecessorOfBound ∧ divisor ∣ n,
                        Or(Exists(Natural, function (d : Natural) =>
                                2 ≤ d ∧ d ≤ successor(predecessorOfBound) ∧ d ∣ n),
                            (d : Natural)
                              → 2 ≤ d
                              → d ≤ successor(predecessorOfBound)
                              → ¬d ∣ n),
                        function (twoLessOrEqualDivisor : 2 ≤ divisor)
                            (rest : divisor ≤ predecessorOfBound ∧ divisor ∣ n) =>
                          And.eliminate(
                              divisor ≤ predecessorOfBound,
                              divisor ∣ n,
                              Or(Exists(Natural, function (d : Natural) =>
                                      2 ≤ d ∧ d ≤ successor(predecessorOfBound) ∧ d ∣ n),
                                  (d : Natural)
                                    → 2 ≤ d
                                    → d ≤ successor(predecessorOfBound)
                                    → ¬d ∣ n),
                              function (divLePredBound : divisor ≤ predecessorOfBound)
                                  (divDivides : divisor ∣ n) =>
                                Or.introduceLeft(
                                    Exists.introduce(
                                        divisor,
                                        And.introduction(
                                            twoLessOrEqualDivisor,
                                            And.introduction(
                                                LessOrEqual.step(
                                                    divisor, predecessorOfBound,
                                                    divLePredBound),
                                                divDivides)))),
                              rest),
                        combined),
                  foundEarlier),
          function (noEarlierDivisor :
                  (divisor : Natural)
                  → 2 ≤ divisor
                  → divisor ≤ predecessorOfBound
                  → ¬divisor ∣ n) =>
              -- induction hypothesis says no divisor in [2, predecessorOfBound]. Check the boundary
              -- candidate successor(predecessorOfBound): either ≥ 2 and divides n
              -- (in which case we have a witness), or doesn't divide
              -- (in which case combined with induction hypothesis no candidate ≤ successor(predecessorOfBound)
              -- works), or < 2 (so the range [2, successor(predecessorOfBound)] still
              -- only includes [2, predecessorOfBound]).
              Or.eliminate(
                  2 ≤ successor(predecessorOfBound),
                  ¬2 ≤ successor(predecessorOfBound),
                  Or(Exists(Natural, function (d : Natural) =>
                          2 ≤ d ∧ d ≤ successor(predecessorOfBound) ∧ d ∣ n),
                      (d : Natural)
                        → 2 ≤ d
                        → d ≤ successor(predecessorOfBound)
                        → ¬d ∣ n),
                  function (twoLeSuccPredBound :
                          2 ≤ successor(predecessorOfBound)) =>
                      Or.eliminate(
                          successor(predecessorOfBound) ∣ n,
                          ¬successor(predecessorOfBound) ∣ n,
                          Or(Exists(Natural, function (d : Natural) =>
                                  2 ≤ d ∧ d ≤ successor(predecessorOfBound) ∧ d ∣ n),
                              (d : Natural)
                                → 2 ≤ d
                                → d ≤ successor(predecessorOfBound)
                                → ¬d ∣ n),
                          function (successorPredecessorBoundDivides :
                                  successor(predecessorOfBound) ∣ n) =>
                              Or.introduceLeft(
                                  Exists.introduce(
                                      successor(predecessorOfBound),
                                      And.introduction(
                                          twoLeSuccPredBound,
                                          And.introduction(
                                              LessOrEqual.reflexivity(
                                                  successor(predecessorOfBound)),
                                              successorPredecessorBoundDivides)))),
                          function (successorPredecessorBoundDoesNotDivide :
                                  ¬successor(predecessorOfBound) ∣ n) =>
                              Or.introduceRight(
                                  function (divisor : Natural)
                                      (twoLessOrEqualDivisor : 2 ≤ divisor)
                                      (divisorLessOrEqualSuccessorPredecessorBound :
                                          divisor ≤ successor(predecessorOfBound))
                                      (divDividesN : divisor ∣ n) =>
                                    -- divisor ≤ successor(predecessorOfBound). Either
                                    -- divisor ≤ predecessorOfBound (use induction hypothesis) or
                                    -- divisor = successor(predecessorOfBound) (use this
                                    -- case's negation).
                                    Or.eliminate(
                                        divisor = successor(predecessorOfBound),
                                        Exists(Natural,
                                            function (bPredecessor : Natural) =>
                                                successor(predecessorOfBound) =
                                                        successor(bPredecessor) ∧ divisor ≤ bPredecessor),
                                        False,
                                        function (divisorEqualsSuccessorPredecessorBound :
                                                divisor = successor(predecessorOfBound)) =>
                                            successorPredecessorBoundDoesNotDivide(
                                                Equality.transport_proposition(
                                                    Natural,
                                                    function (rightEnd : Natural) =>
                                                        rightEnd ∣ n,
                                                    divisor,
                                                    successor(predecessorOfBound),
                                                    divisorEqualsSuccessorPredecessorBound,
                                                    divDividesN)),
                                        function (existsProof :
                                                Exists(Natural,
                                                    function (bPredecessor : Natural) =>
                                                        successor(predecessorOfBound) =
                                                                successor(bPredecessor) ∧ divisor ≤ bPredecessor)) =>
                                            Exists.eliminate(
                                                Natural,
                                                function (bPredecessor : Natural) =>
                                                    successor(predecessorOfBound) =
                                                            successor(bPredecessor) ∧ divisor ≤ bPredecessor,
                                                False,
                                                function (bPredecessor : Natural)
                                                    (combined : successor(predecessorOfBound) =
                                                                        successor(bPredecessor) ∧ divisor ≤ bPredecessor) =>
                                                  And.eliminate(
                                                      successor(predecessorOfBound) =
                                                          successor(bPredecessor),
                                                      divisor ≤ bPredecessor,
                                                      False,
                                                      function (successorEquals :
                                                              successor(predecessorOfBound) =
                                                                  successor(bPredecessor))
                                                          (divisorLessOrEqualBPredecessor :
                                                              divisor ≤ bPredecessor) =>
                                                          noEarlierDivisor(
                                                              divisor,
                                                              twoLessOrEqualDivisor,
                                                              Equality.transport_proposition(
                                                                  Natural,
                                                                  function (rightEnd : Natural) =>
                                                                      divisor ≤ rightEnd,
                                                                  bPredecessor,
                                                                  predecessorOfBound,
                                                                  Equality.symmetry(
                                                                      Natural.successor_injective(
                                                                          predecessorOfBound,
                                                                          bPredecessor,
                                                                          successorEquals)),
                                                                  divisorLessOrEqualBPredecessor),
                                                              divDividesN),
                                                      combined),
                                                existsProof),
                                        LessOrEqual.invert(
                                            divisor,
                                            successor(predecessorOfBound),
                                            divisorLessOrEqualSuccessorPredecessorBound))),
                          Natural.decides_divides(
                              successor(predecessorOfBound), n)),
                  function (notTwoLeSuccPredBound :
                          ¬2 ≤ successor(predecessorOfBound)) =>
                      -- successor(predecessorOfBound) < 2, so the range [2, successor(predecessorOfBound)]
                      -- only contains things ≤ predecessorOfBound. Same conclusion
                      -- as noEarlierDivisor but extended to the wider
                      -- range — we just have to derive d ≤ predecessorOfBound from
                      -- d ≤ successor(predecessorOfBound).
                      Or.introduceRight(
                          function (divisor : Natural)
                              (twoLessOrEqualDivisor : 2 ≤ divisor)
                              (divisorLessOrEqualSuccessorPredecessorBound :
                                  divisor ≤ successor(predecessorOfBound))
                              (divDividesN : divisor ∣ n) =>
                            notTwoLeSuccPredBound(
                                LessOrEqual.transitive(
                                    2, divisor, successor(predecessorOfBound),
                                    divisorLessOrEqualSuccessorPredecessorBound,
                                    twoLessOrEqualDivisor))),
                  Natural.decides_less_or_equal(2, successor(predecessorOfBound))),
          Natural.search_proper_divisor_up_to(n, predecessorOfBound))

-- d ≠ 0 implies 1 ≤ d.
theorem Natural.geq_one_when_not_zero
        : (d : Natural) → ¬d = zero → 1 ≤ d
  | zero, notZero =>
      False.eliminate_proposition(
          1 ≤ zero,
          notZero(reflexivity(zero)))
  | successor(predD), _ =>
      Natural.successor_less_or_equal_successor(
          zero, predD, Natural.zero_least(predD))

-- Helper: if d is neither 0 nor 1, then 2 ≤ d. Pattern-match on d.
theorem Natural.geq_two_when_not_zero_or_one
        : (d : Natural)
          → ¬d = zero → ¬d = 1 → 2 ≤ d
  | zero, notZero, _ =>
      False.eliminate_proposition(
          2 ≤ zero,
          notZero(reflexivity(zero)))
  | successor(predD), _, notOne =>
      Natural.successor_less_or_equal_successor(
          1, predD,
          Natural.geq_one_when_not_zero(predD,
              function (predecessorEqualsZero : predD = zero) =>
                  notOne(congruenceOf(successor, predecessorEqualsZero))))

-- Antisymmetry-like: if a ≤ b and ¬successor(a) ≤ b, then a = b.
-- (Equivalently, ≤ is total and ¬less than gives equality.)
theorem Natural.equals_when_less_or_equal_and_not_less_than (a b : Natural)
        (aLessOrEqualB : a ≤ b)
        (notSuccessorALessOrEqualB : ¬successor(a) ≤ b)
        : a = b :=
  Or.eliminate(
      a = b,
      Exists(Natural, function (bPredecessor : Natural) =>
          b = successor(bPredecessor) ∧ a ≤ bPredecessor),
      a = b,
      function (equality : a = b) => equality,
      function (existsProof : Exists(Natural,
              function (bPredecessor : Natural) =>
                  b = successor(bPredecessor) ∧ a ≤ bPredecessor)) =>
          False.eliminate_proposition(
              a = b,
              Exists.eliminate(
                  Natural,
                  function (bPredecessor : Natural) =>
                      b = successor(bPredecessor) ∧ a ≤ bPredecessor,
                  False,
                  function (bPredecessor : Natural)
                      (combined : b = successor(bPredecessor) ∧ a ≤ bPredecessor) =>
                    And.eliminate(
                        b = successor(bPredecessor),
                        a ≤ bPredecessor,
                        False,
                        function (bEqualsSuccessor :
                                b = successor(bPredecessor))
                            (aLessOrEqualBPredecessor : a ≤ bPredecessor) =>
                          notSuccessorALessOrEqualB(
                              Equality.transport_proposition(
                                  Natural,
                                  function (rightEnd : Natural) =>
                                      successor(a) ≤ rightEnd,
                                  successor(bPredecessor), b,
                                  Equality.symmetry(bEqualsSuccessor),
                                  Natural.successor_less_or_equal_successor(
                                      a, bPredecessor, aLessOrEqualBPredecessor))),
                        combined),
                  existsProof)),
      LessOrEqual.invert(a, b, aLessOrEqualB))

-- Helper: classify a divisor of `successor(predecessorOfN)` given that we
-- know no divisor in [2, predecessorOfN] divides it. Each divisor d is either
-- 0 (impossible since the dividend is nonzero), 1, or > 1 (in which
-- case d ≤ successor(predecessorOfN) bounds it, and if d ≠ successor(predecessorOfN) then
-- d ≤ predecessorOfN — contradicting the "no divisor in [2, predecessorOfN]" hypothesis).
theorem Natural.classify_divisor_when_no_proper
        (predecessorOfN : Natural)
        (noProperDivisor :
            (divisor : Natural)
            → 2 ≤ divisor
            → divisor ≤ predecessorOfN
            → ¬divisor ∣ successor(predecessorOfN))
        (divisor : Natural)
        (divDivides : divisor ∣ successor(predecessorOfN))
        : Or(divisor = 1, divisor = successor(predecessorOfN)) :=
  Or.eliminate(
      divisor = zero,
      ¬divisor = zero,
      Or(divisor = 1, divisor = successor(predecessorOfN)),
      function (divisorIsZero : divisor = zero) =>
          -- divisor = 0 → divides(0, successor(predecessorOfN)) means
          -- successor(predecessorOfN) = 0, but successor ≠ zero.
          False.eliminate_proposition(
              Or(divisor = 1, divisor = successor(predecessorOfN)),
              Exists.eliminate(
                  Natural,
                  function (q : Natural) =>
                      successor(predecessorOfN) = divisor * q,
                  False,
                  function (q : Natural)
                      (equality : successor(predecessorOfN) = divisor * q) =>
                      Natural.successor_not_zero(
                          predecessorOfN,
                          Equality.transitivity(
                              equality,
                              Equality.transitivity(
                                  congruenceOf(
                                      function (rightEnd : Natural) =>
                                          Natural.multiply(rightEnd, q),
                                      divisorIsZero),
                                  -- 0 * q = 0 (definitional via
                                  -- multiply's first-case rule).
                                  reflexivity(zero)))),
                  divDivides)),
      function (divisorNotZero : ¬divisor = zero) =>
          Or.eliminate(
              divisor = 1,
              ¬divisor = 1,
              Or(divisor = 1, divisor = successor(predecessorOfN)),
              function (divisorIsOne : divisor = 1) =>
                  Or.introduceLeft(divisorIsOne),
              function (divisorNotOne : ¬divisor = 1) =>
                  -- divisor ≥ 2 (it's neither 0 nor 1). Now classify
                  -- against successor(predecessorOfN): either successor(divisor) ≤ successor(predecessorOfN)
                  -- (i.e. divisor ≤ predecessorOfN) leading to a contradiction
                  -- via noProperDivisor, or NOT(successor(divisor) ≤ successor(predecessorOfN))
                  -- combined with divisor ≤ successor(predecessorOfN) (from
                  -- divides_le_or_zero) forces divisor = successor(predecessorOfN).
                  Or.eliminate(
                      successor(divisor) ≤ successor(predecessorOfN),
                      ¬successor(divisor) ≤ successor(predecessorOfN),
                      Or(divisor = 1, divisor = successor(predecessorOfN)),
                      function (successorDivisorLessOrEqualSuccessorPredecessorOfN :
                              successor(divisor) ≤ successor(predecessorOfN)) =>
                          -- successor(divisor) ≤ successor(predecessorOfN) iff divisor ≤ predecessorOfN.
                          -- Then noProperDivisor applies if divisor ≥ 2.
                          False.eliminate_proposition(
                              Or(divisor = 1,
                                  divisor = successor(predecessorOfN)),
                              noProperDivisor(
                                  divisor,
                                  -- Need 2 ≤ divisor.
                                  -- divisor is neither 0 nor 1.
                                  -- Pattern-match-style: this is exactly
                                  -- the role of `decides_equality` results,
                                  -- but we need to get the inequality.
                                  Natural.geq_two_when_not_zero_or_one(
                                      divisor, divisorNotZero, divisorNotOne),
                                  Natural.less_or_equal_successor_successor_descend(
                                      divisor, predecessorOfN,
                                      successorDivisorLessOrEqualSuccessorPredecessorOfN),
                                  divDivides)),
                      function (notSuccessorDivisorLessOrEqualSuccessorPredecessorOfN :
                              ¬successor(divisor) ≤ successor(predecessorOfN)) =>
                          -- divisor ≤ successor(predecessorOfN) from divides_le_or_zero.
                          -- Combined with NOT(successor(divisor) ≤ successor(predecessorOfN)),
                          -- forces divisor = successor(predecessorOfN).
                          Or.introduceRight(
                              Natural.equals_when_less_or_equal_and_not_less_than(
                                  divisor, successor(predecessorOfN),
                                  Or.eliminate(
                                      successor(predecessorOfN) = zero,
                                      divisor ≤ successor(predecessorOfN),
                                      divisor ≤ successor(predecessorOfN),
                                      function (successorPredecessorEqualsZero :
                                              successor(predecessorOfN) = zero) =>
                                          False.eliminate_proposition(
                                              divisor ≤ successor(predecessorOfN),
                                              Natural.successor_not_zero(
                                                  predecessorOfN,
                                                  successorPredecessorEqualsZero)),
                                      function (divisorLessOrEqual : divisor ≤ successor(predecessorOfN)) =>
                                          divisorLessOrEqual,
                                      Natural.divides_less_or_equal_or_zero(
                                          divisor, successor(predecessorOfN),
                                          divDivides)),
                                  notSuccessorDivisorLessOrEqualSuccessorPredecessorOfN)),
                      Natural.decides_less_or_equal(
                          successor(divisor), successor(predecessorOfN))),
              Natural.decides_equality(divisor, 1)),
      Natural.decides_equality(divisor, zero))

-- The main split: for n ≥ 2, n is prime or has a proper divisor.
theorem Natural.prime_or_proper_divisor
        : (n : Natural)
          → 2 ≤ n
          → Or(Natural.is_prime(n),
                Exists(Natural, function (divisor : Natural) =>
                    2 ≤ divisor ∧ successor(divisor) ≤ n ∧ divisor ∣ n))
  | zero, atLeastTwo =>
      False.eliminate_proposition(
          Or(Natural.is_prime(zero),
              Exists(Natural, function (divisor : Natural) =>
                  2 ≤ divisor ∧ successor(divisor) ≤ zero ∧ divisor ∣ zero)),
          Natural.not_less_or_equal_successor_zero(1, atLeastTwo))
  | successor(predecessorOfN), atLeastTwo =>
      Or.eliminate(
          Exists(Natural, function (divisor : Natural) =>
              2 ≤ divisor ∧ divisor ≤ predecessorOfN ∧ divisor ∣ successor(predecessorOfN)),
          (divisor : Natural)
              → 2 ≤ divisor
              → divisor ≤ predecessorOfN
              → ¬divisor ∣ successor(predecessorOfN),
          Or(Natural.is_prime(successor(predecessorOfN)),
              Exists(Natural, function (divisor : Natural) =>
                  2 ≤ divisor ∧ successor(divisor) ≤ successor(predecessorOfN) ∧ divisor ∣ successor(predecessorOfN))),
          function (foundDivisor : Exists(Natural,
                  function (divisor : Natural) =>
                      2 ≤ divisor ∧ divisor ≤ predecessorOfN ∧ divisor ∣ successor(predecessorOfN))) =>
              Exists.eliminate(
                  Natural,
                  function (divisor : Natural) =>
                      2 ≤ divisor ∧ divisor ≤ predecessorOfN ∧ divisor ∣ successor(predecessorOfN),
                  Or(Natural.is_prime(successor(predecessorOfN)),
                      Exists(Natural, function (divisor : Natural) =>
                          2 ≤ divisor ∧ successor(divisor) ≤ successor(predecessorOfN) ∧ divisor ∣ successor(predecessorOfN))),
                  function (divisor : Natural)
                      (combined : 2 ≤ divisor ∧ divisor ≤ predecessorOfN ∧ divisor ∣ successor(predecessorOfN)) =>
                    And.eliminate(
                        2 ≤ divisor,
                        divisor ≤ predecessorOfN ∧ divisor ∣ successor(predecessorOfN),
                        Or(Natural.is_prime(successor(predecessorOfN)),
                            Exists(Natural, function (d : Natural) =>
                                2 ≤ d ∧ successor(d) ≤ successor(predecessorOfN) ∧ d ∣ successor(predecessorOfN))),
                        function (twoLessOrEqualDivisor : 2 ≤ divisor)
                            (rest : divisor ≤ predecessorOfN ∧ divisor ∣ successor(predecessorOfN)) =>
                          And.eliminate(
                              divisor ≤ predecessorOfN,
                              divisor ∣ successor(predecessorOfN),
                              Or(Natural.is_prime(successor(predecessorOfN)),
                                  Exists(Natural, function (d : Natural) =>
                                      2 ≤ d ∧ successor(d) ≤ successor(predecessorOfN) ∧ d ∣ successor(predecessorOfN))),
                              function (divisorLessOrEqualPredecessorOfN : divisor ≤ predecessorOfN)
                                  (divDivides :
                                      divisor ∣ successor(predecessorOfN)) =>
                                Or.introduceRight(
                                    Exists.introduce(
                                        divisor,
                                        And.introduction(
                                            twoLessOrEqualDivisor,
                                            And.introduction(
                                                Natural.successor_less_or_equal_successor(
                                                    divisor, predecessorOfN,
                                                    divisorLessOrEqualPredecessorOfN),
                                                divDivides)))),
                              rest),
                        combined),
                  foundDivisor),
          function (noProperDivisor :
                  (divisor : Natural)
                  → 2 ≤ divisor
                  → divisor ≤ predecessorOfN
                  → ¬divisor ∣ successor(predecessorOfN)) =>
              Or.introduceLeft(
                  And.introduction(
                      atLeastTwo,
                      function (divisor : Natural)
                          (divDivides : divisor ∣ successor(predecessorOfN)) =>
                        Natural.classify_divisor_when_no_proper(
                            predecessorOfN, noProperDivisor, divisor,
                            divDivides))),
          Natural.search_proper_divisor_up_to(
              successor(predecessorOfN), predecessorOfN))

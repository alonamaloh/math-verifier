-- Natural/prime_split.math
--
-- Proves Natural.prime_or_proper_divisor: for every n ≥ 2, either n is
-- prime or n has a proper divisor d with 2 ≤ d ≤ n-1. The proof goes
-- through a bounded search over candidate divisors in [2, n-1]. Each
-- candidate is tested using `Natural.decides_divides`, which is taken
-- as an axiom in this module (it's provable via a bounded search over
-- quotients in [0, n], using `q ≤ d·q when d ≥ 1` to cap the search;
-- the full proof would add another ~150 lines of bounded-induction
-- boilerplate).

module Natural.prime_split

import Natural.basics
import Natural.peano
import Natural.order
import Natural.divisibility
import Natural.prime
import Natural.strong_recursion
import Natural.decide
import Natural.decide_divides
import Equality.basics
import Logic.basics
import Logic.exists

-- Natural.decides_divides is now proven, not axiomatized — see
-- Natural.decide_divides. Bounded quotient search plus the cap
-- `q ≤ d·q when d ≥ 1`.

-- Searches for a divisor of n in the range [2, candidateBound] (with
-- candidateBound an inclusive upper bound). Returns either a witness
-- (the divisor in the range, with proofs that it's ≥ 2, ≤ bound, and
-- divides n) or a "no such divisor" function.
theorem Natural.search_proper_divisor_up_to (n : Natural)
        : (candidateBound : Natural)
          → Exists(Natural, (divisor : Natural) ↦
                  2 ≤ divisor ∧ divisor ≤ candidateBound ∧ divisor ∣ n) ∨ ((divisor : Natural)
                → 2 ≤ divisor
                → divisor ≤ candidateBound
                → divisor ∤ n)
  | zero =>
      -- candidateBound = 0: range [2, 0] is empty, no candidate
      -- divisor exists. Anyone claiming 2 ≤ d ≤ 0 hits a contradiction
      -- (2 ≤ 0 is impossible).
      Or.introduceRight(
          (divisor : Natural)
              (twoLessOrEqualDivisor : 2 ≤ divisor)
              (divisorLessOrEqualZero : divisor ≤ 0)
              (_ : divisor ∣ n) ↦ {
            claim divisorIsZero : divisor = 0
                by Natural.less_or_equal_zero_implies_equals_zero;
            claim twoLessOrEqualZero : (2 : Natural) ≤ 0 by substituting divisorIsZero;
            absurd(twoLessOrEqualZero)
          })
  | successor(predecessorOfBound) =>
      cases Natural.search_proper_divisor_up_to(n, predecessorOfBound) {
        | Or.introduceLeft(foundEarlier) => {
            obtain ⟨divisor, twoLessOrEqualDivisor,
                    divLePredBound, divDivides⟩
                from foundEarlier;
            Or.introduceLeft(
                witness divisor with
                    ⟨twoLessOrEqualDivisor,
                     Natural.le_step(
                         divisor, predecessorOfBound,
                         divLePredBound),
                     divDivides⟩)
          }
        | Or.introduceRight(noEarlierDivisor) =>
              -- induction hypothesis says no divisor in [2, predecessorOfBound]. Check the boundary
              -- candidate successor(predecessorOfBound): either ≥ 2 and divides n
              -- (in which case we have a witness), or doesn't divide
              -- (in which case combined with induction hypothesis no candidate ≤ successor(predecessorOfBound)
              -- works), or < 2 (so the range [2, successor(predecessorOfBound)] still
              -- only includes [2, predecessorOfBound]).
              cases Natural.decides_less_or_equal(2, successor(predecessorOfBound)) {
                | Or.introduceLeft(twoLeSuccPredBound) =>
                    cases Natural.decides_divides(successor(predecessorOfBound), n) {
                      | Or.introduceLeft(successorPredecessorBoundDivides) =>
                          Or.introduceLeft(
                              witness successor(predecessorOfBound) with
                                  ⟨twoLeSuccPredBound,
                                   done,
                                   successorPredecessorBoundDivides⟩)
                      | Or.introduceRight(successorPredecessorBoundDoesNotDivide) =>
                          Or.introduceRight(
                              (divisor : Natural)
                                  (twoLessOrEqualDivisor : 2 ≤ divisor)
                                  (divisorLessOrEqualSuccessorPredecessorBound :
                                      divisor ≤ successor(predecessorOfBound))
                                  (divDividesN : divisor ∣ n) ↦
                                -- divisor ≤ successor(predecessorOfBound). Either
                                -- divisor ≤ predecessorOfBound (use induction hypothesis) or
                                -- divisor = successor(predecessorOfBound) (use this
                                -- case's negation).
                                cases LessOrEqual.invert(divisor,
                                          successor(predecessorOfBound),
                                          divisorLessOrEqualSuccessorPredecessorBound) {
                                  | Or.introduceLeft(divisorEqualsSuccessorPredecessorBound) => {
                                      claim succPredBoundDivides
                                            : successor(predecessorOfBound) ∣ n
                                          by substituting divisorEqualsSuccessorPredecessorBound;
                                      successorPredecessorBoundDoesNotDivide(succPredBoundDivides)
                                    }
                                  | Or.introduceRight(existsProof) => {
                                      obtain ⟨bPredecessor, successorEquals,
                                              divisorLessOrEqualBPredecessor⟩
                                          from existsProof;
                                      -- successor is injective, so predecessorOfBound = bPredecessor,
                                      -- hence divisor ≤ predecessorOfBound — a candidate the
                                      -- induction hypothesis already ruled out.
                                      claim predecessorEqualsBPredecessor
                                            : predecessorOfBound = bPredecessor
                                          by Natural.successor_injective;
                                      claim divisorLessOrEqualPredecessorOfBound
                                            : divisor ≤ predecessorOfBound
                                          by substituting predecessorEqualsBPredecessor;
                                      noEarlierDivisor(
                                          divisor,
                                          twoLessOrEqualDivisor,
                                          divisorLessOrEqualPredecessorOfBound,
                                          divDividesN)
                                    }
                                }
                          )
                    }
                | Or.introduceRight(notTwoLeSuccPredBound) =>
                    -- successor(predecessorOfBound) < 2, so the range [2, successor(predecessorOfBound)]
                    -- only contains things ≤ predecessorOfBound.
                    Or.introduceRight(
                        (divisor : Natural)
                            (twoLessOrEqualDivisor : 2 ≤ divisor)
                            (divisorLessOrEqualSuccessorPredecessorBound :
                                divisor ≤ successor(predecessorOfBound))
                            (divDividesN : divisor ∣ n) ↦ {
                          calc (2 : Natural)
                             ≤ divisor
                             ≤ successor(predecessorOfBound) as twoLessOrEqualSuccessorPredecessorBound;
                          notTwoLeSuccPredBound(twoLessOrEqualSuccessorPredecessorBound)
                        })
              }
      }

-- d ≠ 0 implies 1 ≤ d.
theorem Natural.geq_one_when_not_zero
        : (d : Natural) → d ≠ 0 → 1 ≤ d
  | zero, notZero =>
      absurd(notZero(done))
  | successor(predD), _ =>
      done

-- Helper: if d is neither 0 nor 1, then 2 ≤ d. Pattern-match on d.
theorem Natural.geq_two_when_not_zero_or_one
        : (d : Natural)
          → d ≠ 0 → d ≠ 1 → 2 ≤ d
  | zero, notZero, _ =>
      absurd(notZero(done))
  | successor(predD), _, notOne => {
      claim predD ≠ 0 by (predecessorEqualsZero : predD = 0) ↦ notOne(predecessorEqualsZero);
      claim 1 ≤ predD by Natural.geq_one_when_not_zero;
      done by Natural.successor_less_or_equal_successor
    }

-- Antisymmetry-like: if a ≤ b and successor(a) ≰ b, then a = b.
-- (Equivalently, ≤ is total and ¬less than gives equality.)
theorem Natural.equals_when_less_or_equal_and_not_less_than (a b : Natural)
        (aLessOrEqualB : a ≤ b)
        (notSuccessorALessOrEqualB : successor(a) ≰ b)
        : a = b :=
  claim (a = b)
      ∨ (∃ (bPredecessor : Natural). b = successor(bPredecessor) ∧ a ≤ bPredecessor)
  claim by cases {
    in (a = b) as equality:
        equality
    in (∃ (bPredecessor : Natural). b = successor(bPredecessor) ∧ a ≤ bPredecessor) as existsProof: {
        obtain ⟨bPredecessor, bEqualsSuccessor, aLessOrEqualBPredecessor⟩
            from existsProof;
        -- successor(a) ≤ successor(bPredecessor) = b, contradicting the
        -- hypothesis that successor(a) ≰ b.
        claim successorALessOrEqualB : successor(a) ≤ b by substituting bEqualsSuccessor;
        absurd(notSuccessorALessOrEqualB(successorALessOrEqualB))
    }
  }

-- Helper: classify a divisor of `successor(predecessorOfN)` given that we
-- know no divisor in [2, predecessorOfN] divides it. Each divisor d is either
-- 0 (impossible since the dividend is nonzero), 1, or > 1 (in which
-- case d ≤ successor(predecessorOfN) bounds it, and if d ≠ successor(predecessorOfN) then
-- d ≤ predecessorOfN — contradicting the "no divisor in [2, predecessorOfN]" hypothesis).
theorem Natural.classify_divisor_when_no_proper
        (predecessorOfN : Natural)
        (noProperDivisor :
            (divisor : Natural)
            → 2 ≤ divisor
            → divisor ≤ predecessorOfN
            → divisor ∤ successor(predecessorOfN))
        (divisor : Natural)
        (divDivides : divisor ∣ successor(predecessorOfN))
        : divisor = 1 ∨ divisor = successor(predecessorOfN) :=
  claim (divisor = 0) ∨ (divisor ≠ 0)
  claim by cases {
    in (divisor = 0) as divisorIsZero: {
        -- divisor = 0 → divides(0, successor(predecessorOfN)) means
        -- successor(predecessorOfN) = 0, but successor ≠ zero.
        obtain ⟨q, equality⟩ from divDivides;
        calc successor(predecessorOfN)
           = divisor * q
           = 0 * q
           = 0;
        claim False by Natural.successor_not_zero;
        done
    }
    in (divisor ≠ 0) as divisorNotZero:
        cases Natural.decides_equality(divisor, 1) {
          | Or.introduceLeft(divisorIsOne) =>
              Or.introduceLeft(divisorIsOne)
          | Or.introduceRight(divisorNotOne) =>
              -- divisor ≥ 2 (it's neither 0 nor 1). Classify against
              -- successor(predecessorOfN): either successor(divisor) ≤
              -- successor(predecessorOfN) leading to a contradiction via
              -- noProperDivisor, or NOT — combined with divisor ≤
              -- successor(predecessorOfN) (from divides_le_or_zero)
              -- forces divisor = successor(predecessorOfN).
              cases Natural.decides_less_or_equal(
                        successor(divisor), successor(predecessorOfN)) {
                | Or.introduceLeft(successorDivisorLessOrEqualSuccessorPredecessorOfN) => {
                    claim twoLessOrEqualDivisor : 2 ≤ divisor
                        by Natural.geq_two_when_not_zero_or_one;
                    claim divisorLessOrEqualPredecessorOfN : divisor ≤ predecessorOfN
                        by Natural.less_or_equal_successor_successor_descend;
                    absurd(noProperDivisor(divisor, twoLessOrEqualDivisor,
                        divisorLessOrEqualPredecessorOfN, divDivides))
                  }
                | Or.introduceRight(notSuccessorDivisorLessOrEqualSuccessorPredecessorOfN) => {
                    -- divisor divides successor(predecessorOfN) and is nonzero, so
                    -- divisor ≤ successor(predecessorOfN); with successor(divisor) ≰
                    -- successor(predecessorOfN) that forces divisor = successor(predecessorOfN).
                    let _ : divisor ≤ successor(predecessorOfN)
                        := cases by Natural.divides_less_or_equal_or_zero {
                          | Or.introduceLeft(successorPredecessorEqualsZero) =>
                              absurd(successorPredecessorEqualsZero)
                          | Or.introduceRight(divisorLessOrEqual) =>
                              divisorLessOrEqual
                        };
                    claim divisor = successor(predecessorOfN)
                        by Natural.equals_when_less_or_equal_and_not_less_than;
                    done
                  }
              }
        }
  }

-- The main split: for n ≥ 2, n is prime or has a proper divisor.
theorem Natural.prime_or_proper_divisor
        : (n : Natural)
          → 2 ≤ n
          → Natural.is_prime(n) ∨ Exists(Natural, (divisor : Natural) ↦
                    2 ≤ divisor ∧ successor(divisor) ≤ n ∧ divisor ∣ n)
  | zero, atLeastTwo =>
      absurd(atLeastTwo)
  | successor(predecessorOfN), atLeastTwo =>
      claim (∃ (divisor : Natural). 2 ≤ divisor ∧ divisor ≤ predecessorOfN ∧ divisor ∣ successor(predecessorOfN))
          ∨ ((divisor : Natural) → 2 ≤ divisor → divisor ≤ predecessorOfN → divisor ∤ successor(predecessorOfN))
      claim by cases {
        in (∃ (divisor : Natural). 2 ≤ divisor ∧ divisor ≤ predecessorOfN ∧ divisor ∣ successor(predecessorOfN)) as foundDivisor: {
            obtain ⟨divisor, twoLessOrEqualDivisor,
                    divisorLessOrEqualPredecessorOfN, divDivides⟩
                from foundDivisor;
            Or.introduceRight(
                witness divisor with
                    ⟨twoLessOrEqualDivisor,
                     done,
                     divDivides⟩)
        }
        in ((divisor : Natural) → 2 ≤ divisor → divisor ≤ predecessorOfN → divisor ∤ successor(predecessorOfN)) as noProperDivisor:
            Or.introduceLeft(
                ⟨atLeastTwo,
                 (divisor : Natural)
                     (divDivides : divisor ∣ successor(predecessorOfN)) ↦
                   done by Natural.classify_divisor_when_no_proper⟩)
      }

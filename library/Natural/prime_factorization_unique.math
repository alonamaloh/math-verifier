-- Natural/prime_factorization_unique.math
--
-- The Fundamental Theorem of Arithmetic (Freek #80): every n ≥ 1 is a
-- product of primes, uniquely up to order.
--
-- Factorizations are `List(Natural)`; `listProduct` folds multiplication.
-- Existence is strong induction on n (peel off a prime divisor and
-- recurse on the quotient). Uniqueness reuses the polymorphic permutation
-- machinery (`Lists/permutation.math`): two prime lists with equal
-- product are *permutations* of each other. Because the only unit of ℕ is
-- 1 and primes are ≥ 2, "associate" collapses to "equal", so the
-- permutation is exact — no up-to-units bookkeeping (unlike the general
-- integral-domain statement in Algebra/unique_factorization.math).

module Natural.prime_factorization_unique

import axioms
import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.cancellation
import Natural.divisibility
import Natural.strong_recursion
import Natural.prime
import Natural.prime_divides_product
import Natural.prime_divisor
import Natural.euclid
import Natural.factorization
import Lists.list
import Lists.permutation

-- ----------------------------------------------------------------------
-- Product of a list of naturals.

definition Natural.listProduct (list : List(Natural)) : Natural :=
  List.product(Natural, (a b : Natural) ↦ a * b, 1, list)

theorem Natural.listProduct_empty
        : Natural.listProduct(List.empty(Natural)) = 1 :=
  done

theorem Natural.listProduct_prepend (head : Natural) (tail : List(Natural))
        : Natural.listProduct(List.prepend(Natural, head, tail))
          = head * Natural.listProduct(tail) :=
  done

theorem Natural.listProduct_permutation_invariant
        (l1 l2 : List(Natural))
        (perm : List.Permutation(Natural, l1, l2))
        : Natural.listProduct(l1) = Natural.listProduct(l2) :=
  { done by List.Permutation.product_invariant }

-- ----------------------------------------------------------------------
-- Two primes, one dividing the other, are equal.

theorem Natural.prime_equals_of_prime_divides (p q : Natural)
        (pPrime : Natural.is_prime(p)) (qPrime : Natural.is_prime(q))
        (pDividesQ : p ∣ q)
        : p = q := {
  p = 1 ∨ p = q;
  claim by cases {
    case p = 1 as pEqualsOne: {
      (2 : Natural) ≤ 1 by substituting pEqualsOne;
      False by Natural.not_two_less_or_equal_one;
      done
    }
    case p = q as pEqualsQ:
      pEqualsQ
  }
}

-- ----------------------------------------------------------------------
-- Euclid over a list: a prime dividing a prime list's product is a member.

theorem Natural.prime_member_of_divides_product (p : Natural)
        (pPrime : Natural.is_prime(p)) (list : List(Natural))
        : (∀ (k : Natural). List.member(Natural, k, list) → Natural.is_prime(k))
          → p ∣ Natural.listProduct(list)
          → List.member(Natural, p, list) :=
  by_induction on list with inductionHypothesis {
    case List.empty: {
      suppose (∀ (k : Natural). List.member(Natural, k, List.empty(Natural)) → Natural.is_prime(k)) as _;
      suppose p ∣ Natural.listProduct(List.empty(Natural)) as _;
      p ∣ 1;
      p = 1 as pEqualsOne;
      (2 : Natural) ≤ 1 by substituting pEqualsOne;
      False by Natural.not_two_less_or_equal_one;
      done
    }
    case List.prepend(head, tail): {
      suppose (∀ (k : Natural). List.member(Natural, k, List.prepend(Natural, head, tail)) → Natural.is_prime(k)) as allPrime;
      suppose p ∣ Natural.listProduct(List.prepend(Natural, head, tail)) as _;
      p ∣ head * Natural.listProduct(tail);
      (p ∣ head) ∨ (p ∣ Natural.listProduct(tail)) by Natural.prime_divides_product;
      claim by cases {
        case p ∣ head as pDividesHead: {
          List.member(Natural, head, List.prepend(Natural, head, tail));
          Natural.is_prime(head);
          p = head;
          done by substitution
        }
        case p ∣ Natural.listProduct(tail) as pDividesTail: {
          ∀ (k : Natural). List.member(Natural, k, tail) → Natural.is_prime(k) by {
            take k : Natural;
            suppose List.member(Natural, k, tail) as _;
            List.member(Natural, k, List.prepend(Natural, head, tail));
            done
          };
          List.member(Natural, p, tail) by inductionHypothesis;
          done
        }
      }
    }
  }

-- ----------------------------------------------------------------------
-- A prime list with product 1 is empty.

theorem Natural.prime_list_product_one_implies_empty (list : List(Natural))
        : (∀ (k : Natural). List.member(Natural, k, list) → Natural.is_prime(k))
          → Natural.listProduct(list) = 1
          → list = List.empty(Natural) :=
  cases list {
    | List.empty => {
        suppose (∀ (k : Natural). List.member(Natural, k, List.empty(Natural)) → Natural.is_prime(k)) as _;
        suppose Natural.listProduct(List.empty(Natural)) = 1 as _;
        done
      }
    | List.prepend(head, tail) => {
        suppose (∀ (k : Natural). List.member(Natural, k, List.prepend(Natural, head, tail)) → Natural.is_prime(k)) as allPrime;
        suppose Natural.listProduct(List.prepend(Natural, head, tail)) = 1 as _;
        List.member(Natural, head, List.prepend(Natural, head, tail));
        Natural.is_prime(head);
        head ∣ 1 by witness Natural.listProduct(tail) with calc (1 : Natural) = head * Natural.listProduct(tail);
        head = 1 as headEqualsOne;
        (2 : Natural) ≤ 1 by substituting headEqualsOne;
        False by Natural.not_two_less_or_equal_one;
        done
      }
  }

-- ----------------------------------------------------------------------
-- Existence: every n ≥ 1 is a product of primes.

theorem Natural.prime_factorization_exists_list (n : Natural) (atLeastOne : 1 ≤ n)
        : ∃ (list : List(Natural)).
            (∀ (k : Natural). List.member(Natural, k, list) → Natural.is_prime(k))
            ∧ Natural.listProduct(list) = n :=
  (by_induction on n using Natural.strong_induction with subject, inductionHypothesis {
     suppose 1 ≤ subject as _;
     claim by cases {
       case subject = 1 as subjectEqualsOne:
           witness List.empty(Natural) with {
             (∀ (k : Natural). List.member(Natural, k, List.empty(Natural)) → Natural.is_prime(k)) by {
               take k : Natural;
               suppose List.member(Natural, k, List.empty(Natural)) as _;
               False by List.no_member_empty;
               done
             };
             Natural.listProduct(List.empty(Natural)) = subject;
             done
           }
       case 2 ≤ subject as subjectAtLeastTwo: {
           choose prime such that Natural.is_prime(prime) ∧ prime ∣ subject
               from Natural.has_prime_divisor;
           prime ∣ subject as primeDividesSubject;
           choose quotient such that subject = prime * quotient from primeDividesSubject;
           2 ≤ prime;
           1 ≤ quotient as quotientAtLeastOne;
           quotient < prime * quotient;
           quotient < subject;
           choose tail such that
               (∀ (k : Natural). List.member(Natural, k, tail) → Natural.is_prime(k))
               ∧ Natural.listProduct(tail) = quotient
               from inductionHypothesis(quotient, (quotient < subject))(quotientAtLeastOne);
           witness List.prepend(Natural, prime, tail) with {
             (∀ (k : Natural). List.member(Natural, k, List.prepend(Natural, prime, tail)) → Natural.is_prime(k)) by {
               take k : Natural;
               suppose List.member(Natural, k, List.prepend(Natural, prime, tail)) as _;
               k = prime ∨ List.member(Natural, k, tail) by List.member_prepend_invert;
               claim by cases {
                 case k = prime as kEqualsPrime:
                     done by substituting kEqualsPrime
                 case List.member(Natural, k, tail) as memberTail:
                     done
               }
             };
             Natural.listProduct(List.prepend(Natural, prime, tail))
                = prime * Natural.listProduct(tail)
                = prime * quotient
                = subject;
             done
           }
         }
     }
   }
   : 1 ≤ n
     → ∃ (list : List(Natural)).
         (∀ (k : Natural). List.member(Natural, k, list) → Natural.is_prime(k))
         ∧ Natural.listProduct(list) = n
   )(atLeastOne)

-- ----------------------------------------------------------------------
-- Uniqueness: prime lists with equal product are permutations.

theorem Natural.prime_factorization_unique (l1 : List(Natural))
        : ∀ (l2 : List(Natural)).
          (∀ (k : Natural). List.member(Natural, k, l1) → Natural.is_prime(k))
          → (∀ (k : Natural). List.member(Natural, k, l2) → Natural.is_prime(k))
          → Natural.listProduct(l1) = Natural.listProduct(l2)
          → List.Permutation(Natural, l1, l2) :=
  by_induction on l1 with inductionHypothesis {
    case List.empty: {
      take l2 : List(Natural);
      suppose (∀ (k : Natural). List.member(Natural, k, List.empty(Natural)) → Natural.is_prime(k)) as _;
      suppose (∀ (k : Natural). List.member(Natural, k, l2) → Natural.is_prime(k)) as _;
      suppose Natural.listProduct(List.empty(Natural)) = Natural.listProduct(l2) as _;
      l2 = List.empty(Natural) by Natural.prime_list_product_one_implies_empty as l2Empty;
      done by substituting l2Empty
    }
    case List.prepend(p, rest1): {
      take l2 : List(Natural);
      suppose (∀ (k : Natural). List.member(Natural, k, List.prepend(Natural, p, rest1)) → Natural.is_prime(k)) as allPrime1;
      suppose (∀ (k : Natural). List.member(Natural, k, l2) → Natural.is_prime(k)) as allPrime2;
      suppose Natural.listProduct(List.prepend(Natural, p, rest1)) = Natural.listProduct(l2) as _;
      List.member(Natural, p, List.prepend(Natural, p, rest1));
      Natural.is_prime(p);
      p ∣ Natural.listProduct(l2)
          by witness Natural.listProduct(rest1) with
              calc Natural.listProduct(l2) = p * Natural.listProduct(rest1);
      List.member(Natural, p, l2);
      -- Rotate p to the front of l2, then cancel it.
      ∃ (rest : List(Natural)). List.Permutation(Natural, l2, List.prepend(Natural, p, rest))
          by List.Permutation.extract;
      choose l2rest such that List.Permutation(Natural, l2, List.prepend(Natural, p, l2rest));
      Natural.listProduct(l2)
                = Natural.listProduct(List.prepend(Natural, p, l2rest))
                = p * Natural.listProduct(l2rest);
      p * Natural.listProduct(rest1)
         = Natural.listProduct(l2)
         = p * Natural.listProduct(l2rest);
      1 ≤ p by Natural.is_prime.positive;
      Natural.listProduct(rest1) = Natural.listProduct(l2rest) by Natural.multiply_cancel_left;
      ∀ (k : Natural). List.member(Natural, k, rest1) → Natural.is_prime(k) by {
        take k : Natural;
        suppose List.member(Natural, k, rest1) as _;
        List.member(Natural, k, List.prepend(Natural, p, rest1));
        done
      };
      ∀ (k : Natural). List.member(Natural, k, l2rest) → Natural.is_prime(k) by {
        take k : Natural;
        suppose List.member(Natural, k, l2rest) as memberL2rest;
        List.Permutation(Natural, List.prepend(Natural, p, l2rest), l2) by List.Permutation.symmetric;
        List.member(Natural, k, List.prepend(Natural, p, l2rest));
        List.member(Natural, k, l2) by List.Permutation.member_forward;
        done
      };
      List.Permutation(Natural, rest1, l2rest) by inductionHypothesis;
      List.Permutation(Natural, List.prepend(Natural, p, l2rest), l2)
          by List.Permutation.symmetric;
      List.Permutation(Natural, List.prepend(Natural, p, rest1), List.prepend(Natural, p, l2rest));
      done
    }
  }

-- ----------------------------------------------------------------------
-- The Fundamental Theorem of Arithmetic: existence + uniqueness.

theorem Natural.fundamental_theorem_of_arithmetic (n : Natural) (atLeastOne : 1 ≤ n)
        : (∃ (list : List(Natural)).
              (∀ (k : Natural). List.member(Natural, k, list) → Natural.is_prime(k))
              ∧ Natural.listProduct(list) = n)
          ∧ (∀ (l1 l2 : List(Natural)).
                (∀ (k : Natural). List.member(Natural, k, l1) → Natural.is_prime(k))
                → (∀ (k : Natural). List.member(Natural, k, l2) → Natural.is_prime(k))
                → Natural.listProduct(l1) = n
                → Natural.listProduct(l2) = n
                → List.Permutation(Natural, l1, l2)) := {
  (∃ (list : List(Natural)).
            (∀ (k : Natural). List.member(Natural, k, list) → Natural.is_prime(k))
            ∧ Natural.listProduct(list) = n);
  (∀ (l1 l2 : List(Natural)).
            (∀ (k : Natural). List.member(Natural, k, l1) → Natural.is_prime(k))
            → (∀ (k : Natural). List.member(Natural, k, l2) → Natural.is_prime(k))
            → Natural.listProduct(l1) = n
            → Natural.listProduct(l2) = n
            → List.Permutation(Natural, l1, l2)) by {
    take l1 : List(Natural);
    take l2 : List(Natural);
    suppose (∀ (k : Natural). List.member(Natural, k, l1) → Natural.is_prime(k)) as _;
    suppose (∀ (k : Natural). List.member(Natural, k, l2) → Natural.is_prime(k)) as _;
    suppose Natural.listProduct(l1) = n as _;
    suppose Natural.listProduct(l2) = n as _;
    Natural.listProduct(l1) = n = Natural.listProduct(l2);
    done
  };
  done
}

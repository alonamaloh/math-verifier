-- Natural/prime_factorization_unique.math
--
-- The Fundamental Theorem of Arithmetic (Freek #80): every n ≥ 1 is a
-- product of primes, uniquely up to order.
--
-- Factorizations are `List(Natural)`; `listProduct` folds multiplication.
-- Existence is strong induction on n (peel off a prime divisor and
-- recurse on the quotient). Uniqueness reuses the polymorphic permutation
-- machinery (`Lists/permutation.math`): two prime lists with equal
-- product are *permutations* of each other. Because the only unit of ℕ is
-- 1 and primes are ≥ 2, "associate" collapses to "equal", so the
-- permutation is exact — no up-to-units bookkeeping (unlike the general
-- integral-domain statement in Algebra/unique_factorization.math).

module Natural.prime_factorization_unique

import axioms
import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.cancellation
import Natural.divisibility
import Natural.strong_recursion
import Natural.prime
import Natural.prime_divides_product
import Natural.prime_divisor
import Natural.euclid
import Natural.factorization
import Lists.list
import Lists.permutation

-- ----------------------------------------------------------------------
-- Product of a list of naturals.

definition Natural.listProduct (list : List(Natural)) : Natural :=
  List.product(Natural, (a b : Natural) ↦ a * b, 1, list)

theorem Natural.listProduct_empty
        : Natural.listProduct(List.empty(Natural)) = 1 :=
  done

theorem Natural.listProduct_prepend (head : Natural) (tail : List(Natural))
        : Natural.listProduct(List.prepend(Natural, head, tail))
          = head * Natural.listProduct(tail) :=
  done

theorem Natural.listProduct_permutation_invariant
        (l1 l2 : List(Natural))
        (perm : List.Permutation(Natural, l1, l2))
        : Natural.listProduct(l1) = Natural.listProduct(l2) :=
  { done by List.Permutation.product_invariant }

-- ----------------------------------------------------------------------
-- Two primes, one dividing the other, are equal.

theorem Natural.prime_equals_of_prime_divides (p q : Natural)
        (pPrime : Natural.is_prime(p)) (qPrime : Natural.is_prime(q))
        (pDividesQ : p ∣ q)
        : p = q := {
  let ⟨_, qDivisorClassification⟩ := qPrime;
  cases qDivisorClassification(p, pDividesQ) {
    | Or.introduceLeft(pEqualsOne) => {
        claim (2 : Natural) ≤ 1 by substituting pEqualsOne;
        claim False by Natural.not_two_less_or_equal_one;
        done
      }
    | Or.introduceRight(pEqualsQ) => pEqualsQ
  }
}

-- ----------------------------------------------------------------------
-- Euclid over a list: a prime dividing a prime list's product is a member.

theorem Natural.prime_member_of_divides_product (p : Natural)
        (pPrime : Natural.is_prime(p))
        : ∀ (list : List(Natural)).
          (∀ (k : Natural). List.member(Natural, k, list) → Natural.is_prime(k))
          → p ∣ Natural.listProduct(list)
          → List.member(Natural, p, list)
  | List.empty, allPrime, pDividesProduct => {
      -- p ∣ 1 forces p = 1, impossible for a prime.
      claim p ∣ 1;
      claim pEqualsOne : p = 1 by Natural.divides_one_implies_equals_one;
      claim (2 : Natural) ≤ 1 by substituting pEqualsOne;
      claim False by Natural.not_two_less_or_equal_one;
      done
    }
  | List.prepend(head, tail), allPrime, pDividesProduct => {
      claim p ∣ head * Natural.listProduct(tail);
      cases by Natural.prime_divides_product {
        | Or.introduceLeft(pDividesHead) => {
            claim Natural.is_prime(head)
                by allPrime(head, List.member.here(Natural, head, tail));
            -- p and head are both prime with p ∣ head, so p = head, which
            -- is the list's first element.
            claim pEqualsHead : p = head;
            done by substituting pEqualsHead
          }
        | Or.introduceRight(pDividesTail) => {
            claim allPrimeTail
                : ∀ (k : Natural). List.member(Natural, k, tail) → Natural.is_prime(k) by sorry;
            List.member.there(Natural, p, head, tail,
                Natural.prime_member_of_divides_product(p, pPrime, tail,
                    allPrimeTail, pDividesTail))
          }
      }
    }

-- ----------------------------------------------------------------------
-- A prime list with product 1 is empty.

theorem Natural.prime_list_product_one_implies_empty
        : ∀ (list : List(Natural)).
          (∀ (k : Natural). List.member(Natural, k, list) → Natural.is_prime(k))
          → Natural.listProduct(list) = 1
          → list = List.empty(Natural)
  | List.empty, allPrime, productIsOne =>
      done
  | List.prepend(head, tail), allPrime, productIsOne => {
      claim Natural.is_prime(head)
          by allPrime(head, List.member.here(Natural, head, tail));
      -- head ∣ 1 (= product), so head = 1, contradicting head ≥ 2.
      claim head ∣ 1
          by ⟨Natural.listProduct(tail),
              calc (1 : Natural)
                 = head * Natural.listProduct(tail)⟩;
      claim headEqualsOne : head = 1 by Natural.divides_one_implies_equals_one;
      claim (2 : Natural) ≤ 1 by substituting headEqualsOne;
      claim False by Natural.not_two_less_or_equal_one;
      done
    }

-- ----------------------------------------------------------------------
-- Existence: every n ≥ 1 is a product of primes.

theorem Natural.prime_factorization_exists_list (n : Natural) (atLeastOne : 1 ≤ n)
        : ∃ (list : List(Natural)).
            (∀ (k : Natural). List.member(Natural, k, list) → Natural.is_prime(k))
            ∧ Natural.listProduct(list) = n :=
  (by_induction on n using Natural.strong_induction with subject, inductionHypothesis {
     (subjectAtLeastOne : 1 ≤ subject) ↦ {
       claim by cases {
         in (subject = 1) as subjectEqualsOne:
             ⟨List.empty(Natural),
              ⟨(k : Natural)
                  (memberEmpty : List.member(Natural, k, List.empty(Natural))) ↦ {
                    claim False by List.no_member_empty;
                    done
                  },
               calc Natural.listProduct(List.empty(Natural)) = subject⟩⟩
         in (2 ≤ subject) as subjectAtLeastTwo: {
             obtain ⟨prime, primeIsPrime, primeDividesSubject⟩
                 by Natural.has_prime_divisor;
             obtain ⟨quotient, subjectEqualsPrimeTimesQuotient⟩
                 from primeDividesSubject;
             claim 2 ≤ prime;
             claim quotientAtLeastOne : 1 ≤ quotient;
             claim successor(quotient) ≤ subject;
             claim quotient < subject by Natural.lt_of_successor_le;
             obtain ⟨tail, allPrimeTail, tailProductEqualsQuotient⟩
                 from inductionHypothesis(quotient, (quotient < subject))(
                          quotientAtLeastOne);
             ⟨List.prepend(Natural, prime, tail),
              ⟨(k : Natural)
                  (memberProof :
                      List.member(Natural, k,
                          List.prepend(Natural, prime, tail))) ↦
                    cases List.member_prepend_invert(Natural, k, prime, tail,
                              memberProof) {
                      | Or.introduceLeft(kEqualsPrime) =>
                          sorry
                      | Or.introduceRight(memberTail) =>
                          allPrimeTail(k, memberTail)
                    },
               calc Natural.listProduct(List.prepend(Natural, prime, tail))
                  = prime * Natural.listProduct(tail)
                  = prime * quotient
                  = subject⟩⟩
           }
       }
     }
   }
   : 1 ≤ n
     → ∃ (list : List(Natural)).
         (∀ (k : Natural). List.member(Natural, k, list) → Natural.is_prime(k))
         ∧ Natural.listProduct(list) = n
   )(atLeastOne)

-- ----------------------------------------------------------------------
-- Uniqueness: prime lists with equal product are permutations.

theorem Natural.prime_factorization_unique
        : ∀ (l1 l2 : List(Natural)).
          (∀ (k : Natural). List.member(Natural, k, l1) → Natural.is_prime(k))
          → (∀ (k : Natural). List.member(Natural, k, l2) → Natural.is_prime(k))
          → Natural.listProduct(l1) = Natural.listProduct(l2)
          → List.Permutation(Natural, l1, l2)
  | List.empty, l2, allPrime1, allPrime2, productEqual => {
      -- listProduct(l2) = listProduct(empty) = 1, so l2 is empty.
      claim l2Empty : l2 = List.empty(Natural)
          by Natural.prime_list_product_one_implies_empty;
      done by substituting l2Empty
    }
  | List.prepend(p, rest1), l2, allPrime1, allPrime2, productEqual => {
      claim Natural.is_prime(p)
          by allPrime1(p, List.member.here(Natural, p, rest1));
      -- p divides listProduct(l2), so it is a member of l2.
      claim p ∣ Natural.listProduct(l2)
          by ⟨Natural.listProduct(rest1),
              calc Natural.listProduct(l2)
                 = p * Natural.listProduct(rest1)⟩;
      claim List.member(Natural, p, l2);
      -- Rotate p to the front of l2.
      claim extracted
          : ∃ (rest : List(Natural)). List.Permutation(Natural, l2, List.prepend(Natural, p, rest))
          by List.Permutation.extract;
      obtain ⟨l2rest, permL2⟩ from extracted;
      -- Cancel p: listProduct(rest1) = listProduct(l2rest).
      calc Natural.listProduct(l2)
                = Natural.listProduct(List.prepend(Natural, p, l2rest))
                      since Natural.listProduct_permutation_invariant
                = p * Natural.listProduct(l2rest);
      calc p * Natural.listProduct(rest1)
         = Natural.listProduct(l2)
         = p * Natural.listProduct(l2rest);
      claim 1 ≤ p by Natural.is_prime.positive;
      claim restProductsEqual
          : Natural.listProduct(rest1) = Natural.listProduct(l2rest)
          by Natural.multiply_cancel_left;
      -- Recurse and assemble.
      claim allPrimeRest1
          : ∀ (k : Natural). List.member(Natural, k, rest1) → Natural.is_prime(k) by sorry;
      claim allPrimeL2rest
          : ∀ (k : Natural). List.member(Natural, k, l2rest) → Natural.is_prime(k) by sorry;
      claim restPermutation : List.Permutation(Natural, rest1, l2rest)
          by Natural.prime_factorization_unique(rest1, l2rest, allPrimeRest1,
                 allPrimeL2rest, restProductsEqual);
      claim permutationL2restToL2 : List.Permutation(Natural, List.prepend(Natural, p, l2rest), l2)
          by List.Permutation.symmetric;
      List.Permutation.transitive(Natural,
          List.prepend(Natural, p, rest1),
          List.prepend(Natural, p, l2rest),
          l2,
          List.Permutation.skip(Natural, p, rest1, l2rest, restPermutation),
          permutationL2restToL2)
    }

-- ----------------------------------------------------------------------
-- The Fundamental Theorem of Arithmetic: existence + uniqueness.

theorem Natural.fundamental_theorem_of_arithmetic (n : Natural) (atLeastOne : 1 ≤ n)
        : (∃ (list : List(Natural)).
              (∀ (k : Natural). List.member(Natural, k, list) → Natural.is_prime(k))
              ∧ Natural.listProduct(list) = n)
          ∧ (∀ (l1 l2 : List(Natural)).
                (∀ (k : Natural). List.member(Natural, k, l1) → Natural.is_prime(k))
                → (∀ (k : Natural). List.member(Natural, k, l2) → Natural.is_prime(k))
                → Natural.listProduct(l1) = n
                → Natural.listProduct(l2) = n
                → List.Permutation(Natural, l1, l2)) :=
  ⟨done by Natural.prime_factorization_exists_list,
   (l1 l2 : List(Natural))
   (allPrime1 : ∀ (k : Natural). List.member(Natural, k, l1) → Natural.is_prime(k))
   (allPrime2 : ∀ (k : Natural). List.member(Natural, k, l2) → Natural.is_prime(k))
   (l1Product : Natural.listProduct(l1) = n)
   (l2Product : Natural.listProduct(l2) = n) ↦ {
     calc Natural.listProduct(l1) = n = Natural.listProduct(l2);
     done by Natural.prime_factorization_unique
   }⟩

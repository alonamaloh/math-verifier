-- Natural/prime_factorization_unique.math
--
-- The Fundamental Theorem of Arithmetic (Freek #80): every n ≥ 1 is a
-- product of primes, uniquely up to order.
--
-- Factorizations are `List(ℕ)`; `listProduct` folds multiplication.
-- Existence is strong induction on n (peel off a prime divisor and
-- recurse on the quotient). Uniqueness reuses the polymorphic permutation
-- machinery (`Lists/permutation.math`): two prime lists with equal
-- product are *permutations* of each other. Because the only unit of ℕ is
-- 1 and primes are ≥ 2, "associate" collapses to "equal", so the
-- permutation is exact — no up-to-units bookkeeping (unlike the general
-- integral-domain statement in Algebra/unique_factorization.math).

module Natural.prime_factorization_unique

import axioms
import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.cancellation
import Natural.divisibility
import Natural.strong_recursion
import Natural.prime
import Natural.prime_divides_product
import Natural.prime_divisor
import Natural.euclid
import Natural.factorization
import Natural.list_product
import Lists.list
import Lists.permutation

-- ----------------------------------------------------------------------
-- Two primes, one dividing the other, are equal.

theorem Natural.prime_equals_of_prime_divides (p q : ℕ)
        (pPrime : Natural.is_prime(p)) (qPrime : Natural.is_prime(q))
        (pDividesQ : p ∣ q)
        : p = q := {
  p = 1 ∨ p = q;
  done by cases {
    case p = 1 as pEqualsOne: {
      (2 : ℕ) ≤ 1;
      False;
      done
    }
    case p = q as pEqualsQ:
      pEqualsQ
  }
}

-- ----------------------------------------------------------------------
-- Euclid over a list: a prime dividing a prime list's product is a member.

theorem Natural.prime_member_of_divides_product (p : ℕ)
        (pPrime : Natural.is_prime(p)) (list : List(ℕ))
        : (∀ (k : ℕ). k ∈ list → Natural.is_prime(k))
          → p ∣ Natural.listProduct(list)
          → p ∈ list :=
  by induction on list with inductionHypothesis {
    case List.empty: {
      suppose (∀ (k : ℕ). k ∈ List.empty(ℕ) → Natural.is_prime(k)) as _;
      suppose p ∣ Natural.listProduct(List.empty(ℕ)) as _;
      p ∣ 1;
      p = 1;
      (2 : ℕ) ≤ 1;
      False;
      done
    }
    case List.prepend(head, tail): {
      suppose (∀ (k : ℕ). k ∈ List.prepend(ℕ, head, tail) → Natural.is_prime(k)) as allPrime;
      suppose p ∣ Natural.listProduct(List.prepend(ℕ, head, tail)) as _;
      p ∣ head * Natural.listProduct(tail);
      (p ∣ head) ∨ (p ∣ Natural.listProduct(tail)) by Natural.prime_divides_product;
      done by cases {
        case p ∣ head as pDividesHead: {
          head ∈ List.prepend(ℕ, head, tail);
          Natural.is_prime(head);
          p = head;
          done
        }
        case p ∣ Natural.listProduct(tail) as pDividesTail: {
          ∀ (k : ℕ). k ∈ tail → Natural.is_prime(k) by {
            take k : ℕ;
            suppose k ∈ tail as _;
            k ∈ List.prepend(ℕ, head, tail);
            done
          };
          p ∈ tail by inductionHypothesis;
          done
        }
      }
    }
  }

-- ----------------------------------------------------------------------
-- A prime list with product 1 is empty.

theorem Natural.prime_list_product_one_implies_empty (list : List(ℕ))
        : (∀ (k : ℕ). k ∈ list → Natural.is_prime(k))
          → Natural.listProduct(list) = 1
          → list = List.empty(ℕ) :=
  done by cases {
    case list = List.empty(ℕ): {
        suppose (∀ (k : ℕ). k ∈ List.empty(ℕ) → Natural.is_prime(k)) as _;
        suppose Natural.listProduct(List.empty(ℕ)) = 1 as _;
        done
      }
    case list = List.prepend(ℕ, head, tail) for some (head : ℕ), (tail : List(ℕ)): {
        suppose (∀ (k : ℕ). k ∈ List.prepend(ℕ, head, tail) → Natural.is_prime(k)) as allPrime;
        suppose Natural.listProduct(List.prepend(ℕ, head, tail)) = 1 as _;
        head ∈ List.prepend(ℕ, head, tail);
        Natural.is_prime(head);
        head ∣ 1 by witness Natural.listProduct(tail) with { (1 : ℕ) = head * Natural.listProduct(tail) };
        head = 1;
        (2 : ℕ) ≤ 1;
        False;
        done
      }
  }

-- ----------------------------------------------------------------------
-- Existence: every n ≥ 1 is a product of primes.

theorem Natural.prime_factorization_exists_list (n : ℕ) (atLeastOne : 1 ≤ n)
        : ∃ (list : List(ℕ)).
            (∀ (k : ℕ). k ∈ list → Natural.is_prime(k))
            ∧ Natural.listProduct(list) = n :=
  (by induction on n using Natural.strong_induction with subject, inductionHypothesis {
     suppose 1 ≤ subject as _;
     done by cases {
       case subject = 1 as subjectEqualsOne:
           witness List.empty(ℕ) with {
             (∀ (k : ℕ). k ∈ List.empty(ℕ) → Natural.is_prime(k)) by {
               take k : ℕ;
               suppose k ∈ List.empty(ℕ) as _;
               False by List.no_member_empty;
               done
             };
             Natural.listProduct(List.empty(ℕ)) = subject;
             done
           }
       case 2 ≤ subject as subjectAtLeastTwo: {
           choose prime such that Natural.is_prime(prime) ∧ prime ∣ subject
               from Natural.has_prime_divisor;
           prime ∣ subject as primeDividesSubject;
           choose quotient such that subject = prime * quotient from primeDividesSubject;
           2 ≤ prime;
           1 ≤ quotient as quotientAtLeastOne;
           quotient < prime * quotient;
           quotient < subject;
           choose tail such that
               (∀ (k : ℕ). k ∈ tail → Natural.is_prime(k))
               ∧ Natural.listProduct(tail) = quotient
               from inductionHypothesis(quotient, (quotient < subject))(quotientAtLeastOne);
           witness List.prepend(ℕ, prime, tail) with {
             (∀ (k : ℕ). k ∈ List.prepend(ℕ, prime, tail) → Natural.is_prime(k)) by {
               take k : ℕ;
               suppose k ∈ List.prepend(ℕ, prime, tail) as _;
               k = prime ∨ k ∈ tail by List.member_prepend_invert;
               done by cases {
                 case k = prime as kEqualsPrime:
                     done
                 case k ∈ tail as memberTail:
                     done
               }
             };
             Natural.listProduct(List.prepend(ℕ, prime, tail))
                = prime * Natural.listProduct(tail)
                = prime * quotient
                = subject;
             done
           }
         }
     }
   }
   : 1 ≤ n
     → ∃ (list : List(ℕ)).
         (∀ (k : ℕ). k ∈ list → Natural.is_prime(k))
         ∧ Natural.listProduct(list) = n
   )(atLeastOne)

-- ----------------------------------------------------------------------
-- Uniqueness: prime lists with equal product are permutations.

theorem Natural.prime_factorization_unique (l1 : List(ℕ))
        : ∀ (l2 : List(ℕ)).
          (∀ (k : ℕ). k ∈ l1 → Natural.is_prime(k))
          → (∀ (k : ℕ). k ∈ l2 → Natural.is_prime(k))
          → Natural.listProduct(l1) = Natural.listProduct(l2)
          → List.Permutation(ℕ, l1, l2) :=
  by induction on l1 with inductionHypothesis {
    case List.empty: {
      take l2 : List(ℕ);
      suppose (∀ (k : ℕ). k ∈ List.empty(ℕ) → Natural.is_prime(k)) as _;
      suppose (∀ (k : ℕ). k ∈ l2 → Natural.is_prime(k)) as _;
      suppose Natural.listProduct(List.empty(ℕ)) = Natural.listProduct(l2) as _;
      l2 = List.empty(ℕ) by Natural.prime_list_product_one_implies_empty;
      done
    }
    case List.prepend(p, rest1): {
      take l2 : List(ℕ);
      suppose (∀ (k : ℕ). k ∈ List.prepend(ℕ, p, rest1) → Natural.is_prime(k)) as allPrime1;
      suppose (∀ (k : ℕ). k ∈ l2 → Natural.is_prime(k)) as allPrime2;
      suppose Natural.listProduct(List.prepend(ℕ, p, rest1)) = Natural.listProduct(l2) as _;
      p ∈ List.prepend(ℕ, p, rest1);
      Natural.is_prime(p);
      p ∣ Natural.listProduct(l2)
          by witness Natural.listProduct(rest1) with
              { Natural.listProduct(l2) = p * Natural.listProduct(rest1) };
      p ∈ l2;
      -- Rotate p to the front of l2, then cancel it.
      ∃ (rest : List(ℕ)). List.Permutation(ℕ, l2, List.prepend(ℕ, p, rest))
          by List.Permutation.extract;
      choose l2rest such that List.Permutation(ℕ, l2, List.prepend(ℕ, p, l2rest));
      Natural.listProduct(l2)
                = Natural.listProduct(List.prepend(ℕ, p, l2rest))
                = p * Natural.listProduct(l2rest);
      p * Natural.listProduct(rest1)
         = Natural.listProduct(l2)
         = p * Natural.listProduct(l2rest);
      1 ≤ p;
      Natural.listProduct(rest1) = Natural.listProduct(l2rest);
      ∀ (k : ℕ). k ∈ rest1 → Natural.is_prime(k) by {
        take k : ℕ;
        suppose k ∈ rest1 as _;
        k ∈ List.prepend(ℕ, p, rest1);
        done
      };
      ∀ (k : ℕ). k ∈ l2rest → Natural.is_prime(k) by {
        take k : ℕ;
        suppose k ∈ l2rest as memberL2rest;
        List.Permutation(ℕ, List.prepend(ℕ, p, l2rest), l2) by List.Permutation.symmetric;
        k ∈ List.prepend(ℕ, p, l2rest);
        k ∈ l2 by List.Permutation.member_forward;
        done
      };
      List.Permutation(ℕ, rest1, l2rest) by inductionHypothesis;
      List.Permutation(ℕ, List.prepend(ℕ, p, l2rest), l2)
          by List.Permutation.symmetric;
      List.Permutation(ℕ, List.prepend(ℕ, p, rest1), List.prepend(ℕ, p, l2rest));
      done
    }
  }

-- ----------------------------------------------------------------------
-- The Fundamental Theorem of Arithmetic: existence + uniqueness.

theorem Natural.fundamental_theorem_of_arithmetic (n : ℕ) (atLeastOne : 1 ≤ n)
        : (∃ (list : List(ℕ)).
              (∀ (k : ℕ). k ∈ list → Natural.is_prime(k))
              ∧ Natural.listProduct(list) = n)
          ∧ (∀ (l1 l2 : List(ℕ)).
                (∀ (k : ℕ). k ∈ l1 → Natural.is_prime(k))
                → (∀ (k : ℕ). k ∈ l2 → Natural.is_prime(k))
                → Natural.listProduct(l1) = n
                → Natural.listProduct(l2) = n
                → List.Permutation(ℕ, l1, l2)) := {
  (∃ (list : List(ℕ)).
            (∀ (k : ℕ). k ∈ list → Natural.is_prime(k))
            ∧ Natural.listProduct(list) = n);
  (∀ (l1 l2 : List(ℕ)).
            (∀ (k : ℕ). k ∈ l1 → Natural.is_prime(k))
            → (∀ (k : ℕ). k ∈ l2 → Natural.is_prime(k))
            → Natural.listProduct(l1) = n
            → Natural.listProduct(l2) = n
            → List.Permutation(ℕ, l1, l2)) by {
    take l1 : List(ℕ);
    take l2 : List(ℕ);
    suppose (∀ (k : ℕ). k ∈ l1 → Natural.is_prime(k)) as _;
    suppose (∀ (k : ℕ). k ∈ l2 → Natural.is_prime(k)) as _;
    suppose Natural.listProduct(l1) = n as _;
    suppose Natural.listProduct(l2) = n as _;
    Natural.listProduct(l1) = n = Natural.listProduct(l2);
    done
  };
  done
}

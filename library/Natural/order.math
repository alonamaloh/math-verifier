-- Natural/order.math
--
-- The order on Natural, founded on a successor-free, opaque strict order.
--
--   `a < b`   is   `вҲғ c. a + (1 + c) = b`   вҖ” b exceeds a by at least one.
--   `a вүӨ b`   is   `a < b вҲЁ a = b`           вҖ” mere notation on top of `<`.
--
-- `<` is OPAQUE: its `вҲғ` body is touched only in the thin boundary layer
-- at the top of this file вҖ” `lt_intro` / `lt_elim` and the two atomic facts
-- (`lt_one_plus` / `lt_successor`, which supply the witness `0` directly).
-- Everything past them reasons through the interface, never the `вҲғ`.
-- `вүӨ` is TRANSPARENT вҖ” `< вҲЁ =` *is* its meaning.
--
-- Both relations are ordinary registered operators (like Integer/Rational/
-- Real). With the strict-order `weaken`/`transitive_left`/`transitive_right`
-- lemmas below, `<` is a full `calc` citizen, so the whole order interface
-- reads as mixed `<`/`вүӨ`/`=` chains.

module Natural.order

import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.one_plus_induction
import Logic.basics
import Logic.exists
import Equality.basics

-- в”Җв”Җ The strict-order foundation в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

-- `a < b` iff b exceeds a by at least one. Successor-free (only `+`/`1`),
-- and opaque вҖ” its body is seen ONLY by the two boundary lemmas below.
opaque definition Natural.LessThan (a b : в„•) : Proposition :=
  вҲғ (c : в„•). a + (1 + c) = b

operator (<) on (Natural, Natural) := Natural.LessThan

-- в”Җв”Җ Boundary: the general `<` intro / elim (sees the `вҲғ` body) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- A gap `c` with `a + (1 + c) = b` witnesses `a < b`, and conversely.
theorem Natural.lt_intro (a b c : в„•) (h : a + (1 + c) = b) : a < b :=
  unfold Natural.LessThan in witness c with h

theorem Natural.lt_elim (a b : в„•) (h : a < b)
        : вҲғ (c : в„•). a + (1 + c) = b :=
  unfold Natural.LessThan in h

-- в”Җв”Җ `вүӨ` as transparent notation on top of `<` в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
definition Natural.LessOrEqual (a b : в„•) : Proposition :=
  a < b вҲЁ a = b

operator (вүӨ) on (Natural, Natural) := Natural.LessOrEqual

-- в”Җв”Җ The two atomic strict facts (supply the witness `0` directly) в”Җв”Җв”Җв”Җв”Җ

-- a < 1 + a вҖ” the gap is 0.
theorem Natural.lt_one_plus (a : в„•) : a < 1 + a :=
  unfold Natural.LessThan in witness 0 with ring

-- a < successor(a) вҖ” the same fact in successor form.
automatic theorem Natural.lt_successor (a : в„•) : a < successor(a) :=
  unfold Natural.LessThan in witness 0 with { a + (1 + 0) = successor(a) }

-- Nothing lies strictly below zero. A gap `c` with `k + (1 + c) = 0` makes
-- the left side a successor of `k + c`, which is never zero.
-- Implementation note: opaque `<` has no Decidable instance, so `absurd`
-- cannot refute `k < 0` on its own; consumers cite this lemma instead вҖ”
-- e.g. `NaturalsBelow(0)` is empty.
theorem Natural.not_less_than_zero (k : в„•) : В¬(k < 0) := {
  suppose k < 0 as _;
  choose gap such that k + (1 + gap) = 0 from Natural.lt_elim;
  successor(k + gap)
     = k + (1 + gap)
     = 0;
  done
}

-- Irreflexivity: a value never lies strictly below itself. A gap `c` with
-- `a + (1 + c) = a` cancels `a` to force `1 + c = 0`, i.e. `successor(c) = 0`.
-- Marked `automatic` so a reductio ending in `x < x` closes with a bare
-- `done`, matching Real.LessThan.irreflexive.
automatic theorem Natural.lt_irreflexive (a : в„•) : В¬ (a < a) := {
  suppose a < a as _;
  choose gap such that a + (1 + gap) = a from Natural.lt_elim;
  a + (1 + gap)
     = a
     = a + 0;
  1 + gap = 0;
  successor(gap)
     = 1 + gap
     = 0;
  done
}

-- Transitivity of `<`: stacking the two gaps gives a gap for a < c. This is
-- the one composition proven directly from the witnesses; the `calc`
-- interface below is then built on it.
theorem Natural.lt_transitive (a b c : в„•)
        (aLessThanB : a < b) (bLessThanC : b < c) : a < c := {
  choose gapAB such that a + (1 + gapAB) = b from Natural.lt_elim;
  choose gapBC such that b + (1 + gapBC) = c from Natural.lt_elim;
  a + (1 + (gapAB + (1 + gapBC)))
     = (a + (1 + gapAB)) + (1 + gapBC)
     = b + (1 + gapBC)
     = c;
  done
}

-- в”Җв”Җ The `calc` interface for `<` (the names `calc` resolves through the
-- registered operator). With these, mixed `<`/`вүӨ`/`=` chains compose. в”Җв”Җ

-- A strict inequality is in particular a weak one (disjunction injection).
theorem Natural.LessThan.weaken (a b : в„•) (h : a < b) : a вүӨ b := {
  done
}

-- a вүӨ b with a вү  b strengthens to a < b.
theorem Natural.lt_of_le_of_ne (a b : в„•) (lessOrEqual : a вүӨ b) (notEqual : В¬(a = b)) : a < b :=
  done

-- Strictly comparable values are unequal, in both orientations. These are
-- the disequality witnesses the ground-relation decision procedure emits
-- for numeral goals like `4 вү  5` (PLAN_FAST_NUMERALS В§D).
theorem Natural.not_equal_of_less_than (a b : в„•) (h : a < b) : В¬(a = b) := {
  suppose a = b as aEqualsB;
  a < a;
  done
}

theorem Natural.not_equal_of_greater_than (a b : в„•) (h : b < a) : В¬(a = b) := {
  suppose a = b as aEqualsB;
  b < b;
  done
}

-- A positive natural is nonzero вҖ” the в„• face of the `/` side-condition
-- family (the в„ҡ/в„қ twins live beside their division operators).
automatic theorem Natural.nonzero_of_positive (n : в„•) (positive : n > 0) : В¬(n = 0) :=
  done

-- a вүӨ b and b < c give a < c.
theorem Natural.LessThan.transitive_left (a b c : в„•)
        (aLessOrEqualB : a вүӨ b) (bLessThanC : b < c) : a < c :=
  done by cases {
    case a < b: done
    case a = b: done
  }

-- a < b and b вүӨ c give a < c.
theorem Natural.LessThan.transitive_right (a b c : в„•)
        (aLessThanB : a < b) (bLessOrEqualC : b вүӨ c) : a < c :=
  done by cases {
    case b < c: done
    case b = c: done
  }

-- в”Җв”Җ The `calc` interface for `вүӨ` в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

automatic theorem Natural.LessOrEqual.reflexive (a : в„•) : a вүӨ a := {
  a = a;
  done
}

theorem Natural.LessOrEqual.transitive (a b c : в„•)
        (aLessOrEqualB : a вүӨ b) (bLessOrEqualC : b вүӨ c) : a вүӨ c :=
  done by cases {
    case b < c: {
        a < c;
        done
      }
    case b = c: done
  }

-- в”Җв”Җ Order facts, now as `calc` chains в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

-- n вүӨ successor(n).
automatic theorem Natural.le_successor (n : в„•) : n вүӨ successor(n) := {
  n < successor(n);
  done
}

-- Right-extension by one (the role the old `LessOrEqual.step` constructor
-- played): smaller вүӨ larger вүӨ successor(larger).
automatic theorem Natural.le_step (smaller larger : в„•) (proof : smaller вүӨ larger)
        : smaller вүӨ successor(larger) :=
  smaller
     вүӨ larger
     вүӨ successor(larger)

-- a вүӨ a + b.
automatic theorem Natural.less_or_equal_add_right (a b : в„•) : a вүӨ a + b :=
  done by cases {
    case b = 0: {
        a = a + 0;
        done
      }
    case b = successor(predecessor) for some predecessor: {
        a + (1 + predecessor)
           = a + successor(predecessor);
        a < a + successor(predecessor);
        done
      }
  }

-- Zero is at most every natural number: 0 вүӨ 0 + upperBound = upperBound.
automatic theorem Natural.zero_least (upperBound : в„•) : 0 вүӨ upperBound :=
  0
     вүӨ 0 + upperBound
     = upperBound

theorem Natural.lt_trichotomy_successor_step (predecessor b : в„•)
        (predecessorComparison : predecessor < b вҲЁ predecessor = b вҲЁ b < predecessor)
        : 1 + predecessor < b вҲЁ 1 + predecessor = b вҲЁ b < 1 + predecessor :=
  done by cases {
    case predecessor < b: {
        choose gap such that predecessor + (1 + gap) = b from Natural.lt_elim;
        done by cases {
          case gap = 0: {
              -- the gap was exactly one: 1 + predecessor = b.
              1 + predecessor
                 = predecessor + (1 + 0)
                 = b;
              done
            }
          case gap = 1 + gapPredecessor for some gapPredecessor: {
              -- the gap exceeds one: 1 + predecessor < b.
              (1 + predecessor) + (1 + gapPredecessor)
                 = predecessor + (1 + (1 + gapPredecessor))
                 = b;
              1 + predecessor < b;
              done
            }
        }
      }
    case predecessor = b вҲЁ b < predecessor: {
        done by cases {
          case predecessor = b: {
              b
                 = predecessor
                 < 1 + predecessor;
              done
            }
          case b < predecessor: {
              b
                 < predecessor
                 < 1 + predecessor;
              done
            }
        }
      }
  }

-- Trichotomy: the strict-order elimination principle (any two naturals
-- compare as `<`, `=`, or `>`). Induction on a, b universal.
theorem Natural.lt_trichotomy (a : в„•)
        : вҲҖ (b : в„•). a < b вҲЁ a = b вҲЁ b < a :=
  by induction on a with IH {
    case base: (b : в„•) вҶҰ
      done by cases {
        case b = 0: {
            0 = 0;
            done
          }
        case b = 1 + predecessor for some predecessor:
            0
               вүӨ predecessor
               < 1 + predecessor
      }
    case step(predecessor): (b : в„•) вҶҰ {
      predecessor < b вҲЁ predecessor = b вҲЁ b < predecessor;
      done by Natural.lt_trichotomy_successor_step
    }
  }

-- The trichotomy bridge the reductio idiom leans on: a failed вүӨ flips
-- to a strict < the other way.
theorem Natural.lt_of_not_le (a b : в„•)
        (notLessOrEqual : В¬(a вүӨ b)) : b < a := {
  a < b вҲЁ a = b вҲЁ b < a by Natural.lt_trichotomy;
  done by cases {
    case a < b as aBelowB: {
        a вүӨ b;
        done
      }
    case a = b вҲЁ b < a as equalOrAbove: {
        done by cases {
          case a = b as equal: {
              a вүӨ b;
              done
            }
          case b < a as bBelowA: { done }
        }
      }
  }
}

-- Dual of `lt_of_not_le`: a strict order that fails to hold gives the
-- reverse `вүӨ`. The decidability of the Natural order вҖ” the fact that makes
-- `cases Natural.compare_strict вҖҰ` avoidable, proving an order by refuting
-- its opposite (`В¬(a < b) by { вҖҰ }; b вүӨ a`) instead of case-splitting the
-- comparison.
theorem Natural.less_or_equal_of_not_less_than (a b : в„•)
        (notLessThan : В¬(a < b)) : b вүӨ a := {
  a < b вҲЁ a = b вҲЁ b < a by Natural.lt_trichotomy;
  done by cases {
    case a < b as aBelowB: done
    case a = b вҲЁ b < a as equalOrAbove:
        done by cases {
          case a = b as equal: { b вүӨ a; done }
          case b < a as bBelowA: { b вүӨ a; done }
        }
  }
}

-- Successor preserves вүӨ.
automatic theorem Natural.successor_less_or_equal_successor (a b : в„•)
        (proof : a вүӨ b) : successor(a) вүӨ successor(b) :=
  done by cases {
    case a < b: {
        choose gap such that a + (1 + gap) = b from Natural.lt_elim;
        successor(a) + (1 + gap)
           = successor(a + (1 + gap))
           = successor(b);
        successor(a) < successor(b);
        done
      }
    case a = b: done
  }

-- 1 вүӨ successor(k): `successor` monotonicity applied at 0 (`1` is `successor(0)`).
automatic theorem Natural.successor_positive (k : в„•) : 1 вүӨ successor(k) := {
  0 вүӨ k;
  done
}

-- 1 вүӨ k + 1: the `n + 1` form of successor_positive.
theorem Natural.one_le_add_one (k : в„•) : 1 вүӨ k + 1 :=
  (1 : в„•)
     вүӨ successor(k)
     = k + 1

-- 1 вүӨ 1 + k: the `1 + n` face of the same fact.
theorem Natural.one_le_one_plus (k : в„•) : 1 вүӨ 1 + k :=
  (1 : в„•)
     вүӨ k + 1
     = 1 + k

-- 1 вүӨ 2.
automatic theorem Natural.one_less_or_equal_two : 1 вүӨ 2 :=
  done

-- A nonzero natural is at least one. Lets consumers turn "вү  0" straight into
-- the positive-multiplier hypothesis `1 вүӨ n` without a structural successor
-- case-split of their own.
theorem Natural.one_le_of_nonzero (n : в„•) (nonzero : n вү  0) : 1 вүӨ n :=
  done by cases {
    case n = 0 as isZero: { False; done }
    case n = successor(k) for some k: done
  }

-- successor(p) вүӨ upperBound implies p вүӨ upperBound.
automatic theorem Natural.less_or_equal_predecessor_less_or_equal
        (p upperBound : в„•) (successorLessOrEqual : successor(p) вүӨ upperBound)
        : p вүӨ upperBound := {
  p
     < successor(p)
     вүӨ upperBound;
  done
}

-- в”Җв”Җ The `<` вҶ” `successor вүӨ` bridge в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- Under the old foundation `a < b` was DEFINITIONALLY `successor(a) вүӨ b`;
-- now `<` is the opaque `вҲғ`-relation, so the equivalence is a (cheap)
-- theorem. Code that used to lean on the defeq routes through these.

-- в”Җв”Җ The `+ 1` / `<` public order interface в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- The strict-order bridges between `<` and `вүӨ`, stated with only `<`, `вүӨ`,
-- and `+ 1` вҖ” never the `successor` constructor. `<` is `вҲғc. a + (1 + c) = b`
-- and `вүӨ` is `< вҲЁ =`, so `+ 1` is the native spelling; consumers reason
-- entirely in it and the `successor` constructor stays confined to the
-- recursion-level modules in `Natural/`.

-- a < a + 1 вҖ” the atomic strict fact, in `+ 1` form (gap 0).
theorem Natural.lt_add_one (a : в„•) : a < a + 1 := {
  a < 1 + a;
  done
}

-- k < n  вҹ№  k + 1 вүӨ n.
automatic theorem Natural.add_one_le_of_lt (k n : в„•) (h : k < n) : k + 1 вүӨ n := {
  choose gap such that k + (1 + gap) = n from Natural.lt_elim;
  (k + 1) + gap
     = k + (1 + gap)
     = n;
  k + 1
     вүӨ (k + 1) + gap
     = n
}

-- k + 1 вүӨ n  вҹ№  k < n: k < k + 1 вүӨ n.
automatic theorem Natural.lt_of_add_one_le (k n : в„•) (h : k + 1 вүӨ n) : k < n :=
  k
     < k + 1
     вүӨ n

-- k < n + 1  вҹ№  k вүӨ n: the gap collapses once the `+ 1` is cancelled.
theorem Natural.le_of_lt_add_one (k n : в„•) (h : k < n + 1) : k вүӨ n := {
  choose gap such that k + (1 + gap) = n + 1 from Natural.lt_elim;
  (k + gap) + 1 = n + 1;
  k + gap = n by Natural.add_cancel_right;
  k
     вүӨ k + gap
     = n
}

-- k < 1 + n  вҹ№  k вүӨ n: the `1 + n` face of the same collapse.
theorem Natural.le_of_lt_one_plus (k n : в„•) (h : k < 1 + n) : k вүӨ n := {
  k < n + 1;
  done
}

-- 1 вүӨ m  вҹ№  0 < m: positivity in `<` form.
theorem Natural.zero_lt_of_one_le (m : в„•) (h : 1 вүӨ m) : 0 < m := {
  0 + 1 вүӨ m;
  done
}

-- a < n  вҹ№  a < n + 1 (the strict-order step, `+ 1` form).
theorem Natural.lt_add_one_of_lt (a n : в„•) (h : a < n) : a < n + 1 :=
  a
     < n
     < n + 1

-- a вүӨ n  вҹ№  a вүӨ n + 1 (the weak-order step, `+ 1` form).
theorem Natural.le_add_one_of_le (a n : в„•) (h : a вүӨ n) : a вүӨ n + 1 :=
  a
     вүӨ n
     вүӨ n + 1

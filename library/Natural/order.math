-- Natural/order.math
--
-- LessOrEqual: the inductive ≤ relation on Natural. Two constructors:
-- reflexivity gives n ≤ n; step lifts n ≤ m to n ≤ successor(m).

module Natural.order

import Natural.basics

inductive LessOrEqual : Natural → Natural → Proposition where
  | LessOrEqual.reflexivity
      : (naturalNumber : Natural)
        → LessOrEqual(naturalNumber, naturalNumber)
  | LessOrEqual.step
      : (smaller larger : Natural)
        → LessOrEqual(smaller, larger)
        → LessOrEqual(smaller, successor(larger))

-- Zero is at most every natural number. Pattern-matched proof by
-- induction on the right operand.
definition Natural.zero_least
        : (upperBound : Natural) → zero ≤ upperBound
  | zero         => LessOrEqual.reflexivity(zero)
  | successor(predecessor) =>
      LessOrEqual.step(zero, predecessor,
                        Natural.zero_least(predecessor))

-- ≤ is transitive. Pattern-match on the second proof (b ≤ c);
-- the first proof is threaded as a function argument that comes after
-- the scrutinee so the motive abstracts over its type. That way the
-- reflexivity case (which forces b = c) automatically specialises the
-- first proof's type to a ≤ c.
theorem LessOrEqual.transitive (a b c : Natural)
        : b ≤ c
          → a ≤ b
          → a ≤ c
  | LessOrEqual.reflexivity(_), firstProof =>
      firstProof
  | LessOrEqual.step(_, cPredecessor, secondProofSubdivided), firstProof =>
      LessOrEqual.step(a, cPredecessor,
          LessOrEqual.transitive(
              a, b, cPredecessor,
              secondProofSubdivided, firstProof))

-- Successor preserves ≤: a ≤ b implies successor(a) ≤ successor(b). By induction
-- on the proof.
--
-- In the case bodies we use the DESTRUCTURED names (commonValue,
-- smallerD, etc.) rather than the outer binder names a and b. The
-- motive substitutes the constructor's specific index values into
-- the case's expected type, but the case body's local context still
-- resolves `a` and `b` to the OUTER binders (which kernel-level
-- aren't equal to the destructured values, even though they are
-- propositionally so in each case).
theorem Natural.successor_less_or_equal_successor (a b : Natural)
        : a ≤ b
          → successor(a) ≤ successor(b)
  | LessOrEqual.reflexivity(commonValue) =>
      LessOrEqual.reflexivity(successor(commonValue))
  | LessOrEqual.step(smallerD, largerPredecessor, subproof) =>
      LessOrEqual.step(
          successor(smallerD), successor(largerPredecessor),
          Natural.successor_less_or_equal_successor(smallerD, largerPredecessor, subproof))

-- 1 ≤ succ(k). Lifts `0 ≤ k` (zero_least) under `successor_le_successor`.
-- Appears constantly in analytic proofs as a positivity witness.
theorem Natural.successor_positive (k : Natural) : 1 ≤ successor(k) :=
  Natural.successor_less_or_equal_successor(zero, k, Natural.zero_least(k))

-- a ≤ a + b. Induction on a, using that successor(_) + m and zero + m
-- reduce definitionally on the first argument.
theorem Natural.less_or_equal_add_right
        : (a b : Natural) → a ≤ a + b
  | zero, b =>
      Natural.zero_least(b)
  | successor(predecessor), b =>
      Natural.successor_less_or_equal_successor(
          predecessor, predecessor + b,
          Natural.less_or_equal_add_right(predecessor, b))

-- successor(p) ≤ upperBound implies p ≤ upperBound. Transitive via the
-- single-step `p ≤ successor(p)`.
theorem Natural.less_or_equal_predecessor_less_or_equal (p upperBound : Natural)
        : successor(p) ≤ upperBound
          → p ≤ upperBound :=
  function (successorLessOrEqual : successor(p) ≤ upperBound) =>
    LessOrEqual.transitive(
        p, successor(p), upperBound,
        successorLessOrEqual,
        LessOrEqual.step(p, p, LessOrEqual.reflexivity(p)))

-- n ≤ successor(n). The one-step right-extension that calc chains
-- over Natural reach for constantly. Built from reflexivity by
-- stepping the upper bound once.
theorem Natural.le_successor (n : Natural) : n ≤ successor(n) :=
  LessOrEqual.step(n, n, LessOrEqual.reflexivity(n))

-- 1 ≤ 2. Direct corollary.
theorem Natural.one_less_or_equal_two : 1 ≤ 2 :=
  Natural.le_successor(1)

-- Natural/order.math
--
-- LessOrEqual: the inductive ≤ relation on Natural. Two constructors:
-- reflexivity gives n ≤ n; step lifts n ≤ m to n ≤ successor(m).

module Natural.order

import Natural.basics

inductive LessOrEqual : Natural → Natural → Proposition where
  | LessOrEqual.reflexivity
      : (naturalNumber : Natural)
        → LessOrEqual(naturalNumber, naturalNumber)
  | LessOrEqual.step
      : (smaller larger : Natural)
        → LessOrEqual(smaller, larger)
        → LessOrEqual(smaller, successor(larger))

-- Strict order. `a < b` means `successor(a) ≤ b`. It is defined via
-- `successor` so it is DEFINITIONALLY equal to the `successor(a) ≤ b` form
-- the core proofs already use — order lemmas and the induction principles
-- can then be restated with `<` without reworking their proofs, while the
-- `successor` constructor stays sealed behind the `<` notation for
-- everything downstream. (`a > b` desugars to `b < a` automatically, and
-- `a ≥ b` to `b ≤ a`, so no separate `>`/`≥` declarations are needed.)
definition Natural.LessThan (a b : Natural) : Proposition :=
  successor(a) ≤ b

operator (<) on (Natural, Natural) := Natural.LessThan

-- Zero is at most every natural number. By induction on the upper bound:
-- 0 ≤ 0 reflexively, and 0 ≤ predecessor lifts to 0 ≤ successor(predecessor)
-- by stepping the bound once.
definition Natural.zero_least (upperBound : Natural) : 0 ≤ upperBound :=
  unfold Natural.add in
  by_induction on upperBound with IH {
    case zero:
        done
    case successor(predecessor):
        LessOrEqual.step(0, predecessor, IH)
  }

-- ≤ is transitive. By induction on the derivation of b ≤ c, carrying the
-- proof of a ≤ b (refined as the induction varies b).
theorem LessOrEqual.transitive (a b c : Natural)
        (bc : b ≤ c) (ab : a ≤ b) : a ≤ c :=
  unfold Natural.add in
  by_induction on bc with IH refining ab {
    case LessOrEqual.reflexivity(_):
        -- b = c, so a ≤ b already is a ≤ c.
        ab
    case LessOrEqual.step(_, cPredecessor, _):
        -- c = successor(cPredecessor) with b ≤ cPredecessor; the IH gives
        -- a ≤ cPredecessor, then one more step reaches a ≤ c.
        LessOrEqual.step(a, cPredecessor, IH(ab))
  }

-- Successor preserves ≤: a ≤ b implies successor(a) ≤ successor(b). By
-- induction on the derivation of a ≤ b. The case bodies use the
-- DESTRUCTURED names (commonValue, smallerD) — the constructor's specific
-- index values — not the outer binders a and b.
theorem Natural.successor_less_or_equal_successor (a b : Natural)
        (proof : a ≤ b) : successor(a) ≤ successor(b) :=
  unfold Natural.add in
  by_induction on proof with IH {
    case LessOrEqual.reflexivity(commonValue):
        done
    case LessOrEqual.step(smallerD, largerPredecessor, _):
        LessOrEqual.step(
            successor(smallerD), successor(largerPredecessor), IH)
  }

-- 1 ≤ succ(k). Appears constantly in analytic proofs as a positivity witness.
theorem Natural.successor_positive (k : Natural) : 1 ≤ successor(k) := {
  -- 0 ≤ k since zero is least; then 1 ≤ successor(k) (i.e.
  -- successor(0) ≤ successor(k)) because successor is monotone.
  claim 0 ≤ k since Natural.zero_least;
  done since Natural.successor_less_or_equal_successor
}

-- a ≤ a + b. By induction on a (successor(_) + b and zero + b reduce
-- definitionally on the first argument).
theorem Natural.less_or_equal_add_right (a b : Natural) : a ≤ a + b :=
  unfold Natural.add in
  by_induction on a with IH {
    case zero:
        -- 0 + b ≡ b, and zero is least.
        done by Natural.zero_least
    case successor(predecessor): {
        -- predecessor ≤ predecessor + b by the IH; successor is monotone.
        claim predecessor ≤ predecessor + b by IH;
        done by Natural.successor_less_or_equal_successor
      }
  }

-- n ≤ successor(n). The one-step right-extension that calc chains
-- over Natural reach for constantly. Built from reflexivity by
-- stepping the upper bound once.
theorem Natural.le_successor (n : Natural) : n ≤ successor(n) :=
  LessOrEqual.step(n, n, done)

-- 1 ≤ 2. Direct corollary.
theorem Natural.one_less_or_equal_two : 1 ≤ 2 :=
  { done by Natural.le_successor }

-- successor(p) ≤ upperBound implies p ≤ upperBound. Transitive via the
-- single-step `p ≤ successor(p)`.
theorem Natural.less_or_equal_predecessor_less_or_equal
        (p upperBound : Natural) (successorLessOrEqual : successor(p) ≤ upperBound)
        : p ≤ upperBound :=
  calc p
     ≤ successor(p)
     ≤ upperBound

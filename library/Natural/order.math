-- Natural/order.math
--
-- The order on Natural, founded on a successor-free, opaque strict order.
--
--   `a < b`   is   `‚àÉ c. a + (1 + c) = b`   ‚Äî b exceeds a by at least one.
--   `a ‚â§ b`   is   `a < b ‚à® a = b`           ‚Äî mere notation on top of `<`.
--
-- `<` is OPAQUE: its body is visible only to the two boundary lemmas
-- `lt_intro` / `lt_elim`. Everything below them reasons through the
-- interface, never the `‚àÉ`. `‚â§` is TRANSPARENT ‚Äî `< ‚à® =` *is* its meaning.
--
-- Both relations are ordinary registered operators (like Integer/Rational/
-- Real). With the strict-order `weaken`/`transitive_left`/`transitive_right`
-- lemmas below, `<` is a full `calc` citizen, so the whole order interface
-- reads as mixed `<`/`‚â§`/`=` chains.

module Natural.order

import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.one_plus_induction
import Logic.basics
import Logic.exists
import Equality.basics

-- ‚îÄ‚îÄ The strict-order foundation ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

-- `a < b` iff b exceeds a by at least one. Successor-free (only `+`/`1`),
-- and opaque ‚Äî its body is seen ONLY by the two boundary lemmas below.
opaque definition Natural.LessThan (a b : Natural) : Proposition :=
  ‚àÉ (c : Natural). a + (1 + c) = b

operator (<) on (Natural, Natural) := Natural.LessThan

-- ‚îÄ‚îÄ Boundary (the only place `<`'s body is seen) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
-- A gap `c` with `a + (1 + c) = b` witnesses `a < b`, and conversely.
theorem Natural.lt_intro (a b c : Natural) (h : a + (1 + c) = b) : a < b :=
  unfold Natural.LessThan in ‚ü®c, h‚ü©

theorem Natural.lt_elim (a b : Natural) (h : a < b)
        : ‚àÉ (c : Natural). a + (1 + c) = b :=
  unfold Natural.LessThan in h

-- ‚îÄ‚îÄ `‚â§` as transparent notation on top of `<` ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
definition Natural.LessOrEqual (a b : Natural) : Proposition :=
  a < b ‚à® a = b

operator (‚â§) on (Natural, Natural) := Natural.LessOrEqual

-- ‚îÄ‚îÄ The two atomic strict facts (the only consumers of `lt_intro`) ‚îÄ‚îÄ‚îÄ‚îÄ

-- a < 1 + a ‚Äî the gap is 0.
theorem Natural.lt_one_plus (a : Natural) : a < 1 + a :=
  unfold Natural.LessThan in witness 0 with ring

-- a < successor(a) ‚Äî the same fact in successor form.
theorem Natural.lt_successor (a : Natural) : a < successor(a) :=
  unfold Natural.LessThan in witness 0 with
      (calc a + (1 + 0)
          = 1 + a          by ring
          = successor(a)   by Natural.one_add(a))

-- Irreflexivity: a value never lies strictly below itself. A gap `c` with
-- `a + (1 + c) = a` cancels `a` to force `1 + c = 0`, i.e. `successor(c) = 0`.
theorem Natural.lt_irreflexive (a : Natural) : ¬¨ (a < a) := {
  suppose a < a as _;
  obtain ‚ü®gap, equation‚ü© by Natural.lt_elim;
  calc a + (1 + gap)
     = a       by equation
     = a + 0   by Natural.add_zero(a);
  claim 1 + gap = 0 by Natural.add_cancel_left;
  absurd((calc successor(gap)
            = 1 + gap   by Natural.one_add(gap)
            = 0         by (1 + gap = 0)))
}

-- Transitivity of `<`: stacking the two gaps gives a gap for a < c. This is
-- the one composition proven directly from the witnesses; the `calc`
-- interface below is then built on it.
theorem Natural.lt_transitive (a b c : Natural)
        (aLessThanB : a < b) (bLessThanC : b < c) : a < c := {
  choose gapAB such that a + (1 + gapAB) = b from Natural.lt_elim;
  choose gapBC such that b + (1 + gapBC) = c from Natural.lt_elim;
  calc a + (1 + (gapAB + (1 + gapBC)))
     = (a + (1 + gapAB)) + (1 + gapBC)   by ring
     = b + (1 + gapBC)                   by substituting (a + (1 + gapAB) = b)
     = c                                 by substituting (b + (1 + gapBC) = c)
     as combinedGap;
  done by Natural.lt_intro(c := gapAB + (1 + gapBC), h := combinedGap)
}

-- ‚îÄ‚îÄ The `calc` interface for `<` (the names `calc` resolves through the
-- registered operator). With these, mixed `<`/`‚â§`/`=` chains compose. ‚îÄ‚îÄ

-- A strict inequality is in particular a weak one (disjunction injection).
theorem Natural.LessThan.weaken (a b : Natural) (h : a < b) : a ‚â§ b := {
  done
}

-- a ‚â§ b and b < c give a < c.
theorem Natural.LessThan.transitive_left (a b c : Natural)
        (aLessOrEqualB : a ‚â§ b) (bLessThanC : b < c) : a < c :=
  cases aLessOrEqualB {
    | Or.introduceLeft(aLessThanB) => done by Natural.lt_transitive
    | Or.introduceRight(aEqualB)   => done by substituting aEqualB
  }

-- a < b and b ‚â§ c give a < c.
theorem Natural.LessThan.transitive_right (a b c : Natural)
        (aLessThanB : a < b) (bLessOrEqualC : b ‚â§ c) : a < c :=
  cases bLessOrEqualC {
    | Or.introduceLeft(bLessThanC) => done by Natural.lt_transitive
    | Or.introduceRight(bEqualC)   => done by substituting bEqualC
  }

-- ‚îÄ‚îÄ The `calc` interface for `‚â§` ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

theorem Natural.LessOrEqual.reflexive (a : Natural) : a ‚â§ a := {
  claim a = a;
  done
}

theorem Natural.LessOrEqual.transitive (a b c : Natural)
        (aLessOrEqualB : a ‚â§ b) (bLessOrEqualC : b ‚â§ c) : a ‚â§ c :=
  cases bLessOrEqualC {
    | Or.introduceLeft(bLessThanC) => {
        claim a < c by Natural.LessThan.transitive_left;
        done
      }
    | Or.introduceRight(bEqualC) => done by substituting bEqualC
  }

-- ‚îÄ‚îÄ Order facts, now as `calc` chains ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

-- n ‚â§ successor(n).
theorem Natural.le_successor (n : Natural) : n ‚â§ successor(n) := {
  claim n < successor(n) by Natural.lt_successor;
  done
}

-- Right-extension by one (the role the old `LessOrEqual.step` constructor
-- played): smaller ‚â§ larger ‚â§ successor(larger).
theorem Natural.le_step (smaller larger : Natural) (proof : smaller ‚â§ larger)
        : smaller ‚â§ successor(larger) :=
  calc smaller
     ‚â§ larger              by proof
     ‚â§ successor(larger)   by Natural.le_successor

-- a ‚â§ a + b.
theorem Natural.less_or_equal_add_right (a b : Natural) : a ‚â§ a + b :=
  cases b {
    | zero => {
        calc a = a + 0   by Natural.add_zero(a);
        done
      }
    | successor(predecessor) => {
        calc a + (1 + predecessor)
           = a + successor(predecessor)   by Natural.one_add(predecessor)
           as addGap;
        claim a < a + successor(predecessor) by Natural.lt_intro(c := predecessor, h := addGap);
        done
      }
  }

-- Zero is at most every natural number: 0 ‚â§ 0 + upperBound = upperBound.
theorem Natural.zero_least (upperBound : Natural) : 0 ‚â§ upperBound :=
  calc 0
     ‚â§ 0 + upperBound   by Natural.less_or_equal_add_right
     = upperBound        by Natural.zero_add(upperBound)

-- Trichotomy: the strict-order elimination principle (any two naturals
-- compare as `<`, `=`, or `>`). Induction on a, b universal.
theorem Natural.lt_trichotomy (a : Natural)
        : (b : Natural) ‚Üí a < b ‚à® a = b ‚à® b < a :=
  by_induction on a with IH {
    case base: (b : Natural) ‚Ü¶
      cases b {
        | zero => {
            claim 0 = 0;
            done
          }
        | successor(predecessor) =>
            calc 0
               ‚â§ predecessor          by Natural.zero_least
               < successor(predecessor)   by Natural.lt_successor
      }
    case step(predecessor): (b : Natural) ‚Ü¶
      cases IH(b) {
        | Or.introduceLeft(predecessorLessThanB) => {
            obtain ‚ü®gap, equation‚ü© by Natural.lt_elim;
            cases gap refining equation {
              | zero => {
                  -- the gap was exactly one: 1 + predecessor = b.
                  calc 1 + predecessor
                     = predecessor + (1 + 0)   by ring
                     = b                        by equation;
                  done
                }
              | successor(gapPredecessor) => {
                  -- the gap exceeds one: 1 + predecessor < b.
                  calc (1 + predecessor) + (1 + gapPredecessor)
                     = predecessor + (1 + successor(gapPredecessor))   by ring
                     = b                                                by equation
                     as wideGap;
                  claim 1 + predecessor < b by Natural.lt_intro(c := gapPredecessor, h := wideGap);
                  done
                }
            }
          }
        | Or.introduceRight(predecessorEqualOrAbove) =>
            cases predecessorEqualOrAbove {
              | Or.introduceLeft(predecessorEqualB) => {
                  calc b
                     = predecessor          by (predecessor = b)
                     < 1 + predecessor      by Natural.lt_one_plus;
                  done
                }
              | Or.introduceRight(bLessThanPredecessor) => {
                  calc b
                     < predecessor          by bLessThanPredecessor
                     < 1 + predecessor      by Natural.lt_one_plus;
                  done
                }
            }
      }
  }

-- Successor preserves ‚â§.
theorem Natural.successor_less_or_equal_successor (a b : Natural)
        (proof : a ‚â§ b) : successor(a) ‚â§ successor(b) :=
  cases proof {
    | Or.introduceLeft(aLessThanB) => {
        obtain ‚ü®gap, equation‚ü© by Natural.lt_elim;
        calc successor(a) + (1 + gap)
           = successor(a + (1 + gap))   by Natural.successor_add(a, 1 + gap)
           = successor(b)               by substituting equation
           as successorGap;
        claim successor(a) < successor(b) by Natural.lt_intro(c := gap, h := successorGap);
        done
      }
    | Or.introduceRight(aEqualB) => {
        calc successor(a) = successor(b)   by aEqualB;
        done
      }
  }

-- 1 ‚â§ successor(k): `successor` monotonicity applied at 0 (`1` is `successor(0)`).
theorem Natural.successor_positive (k : Natural) : 1 ‚â§ successor(k) := {
  claim 0 ‚â§ k by Natural.zero_least;
  done by Natural.successor_less_or_equal_successor
}

-- 1 ‚â§ 2.
theorem Natural.one_less_or_equal_two : 1 ‚â§ 2 :=
  done by Natural.le_successor

-- successor(p) ‚â§ upperBound implies p ‚â§ upperBound.
theorem Natural.less_or_equal_predecessor_less_or_equal
        (p upperBound : Natural) (successorLessOrEqual : successor(p) ‚â§ upperBound)
        : p ‚â§ upperBound := {
  calc p
     < successor(p)   by Natural.lt_successor
     ‚â§ upperBound     by successorLessOrEqual;
  done
}

-- ‚îÄ‚îÄ The `<` ‚Üî `successor ‚â§` bridge ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
-- Under the old foundation `a < b` was DEFINITIONALLY `successor(a) ‚â§ b`;
-- now `<` is the opaque `‚àÉ`-relation, so the equivalence is a (cheap)
-- theorem. Code that used to lean on the defeq routes through these.

-- k < n  ‚üπ  successor(k) ‚â§ n.
theorem Natural.successor_le_of_lt (k n : Natural) (h : k < n) : successor(k) ‚â§ n := {
  obtain ‚ü®gap, equation‚ü© by Natural.lt_elim;
  calc successor(k) + gap
     = (1 + k) + gap        by Natural.one_add(k)
     = k + (1 + gap)        by ring
     = n                     by equation
     as shifted;
  calc successor(k)
     ‚â§ successor(k) + gap   by Natural.less_or_equal_add_right
     = n                     by shifted
}

-- successor(k) ‚â§ n  ‚üπ  k < n: k < successor(k) ‚â§ n.
theorem Natural.lt_of_successor_le (k n : Natural) (h : successor(k) ‚â§ n) : k < n :=
  calc k
     < successor(k)   by Natural.lt_successor
     ‚â§ n              by h

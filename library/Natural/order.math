-- Natural/order.math
--
-- The order on Natural, founded on a successor-free, opaque strict order.
--
--   `a < b`   is   `вҲғ c. a + (1 + c) = b`   вҖ” b exceeds a by at least one.
--   `a вүӨ b`   is   `a < b вҲЁ a = b`           вҖ” mere notation on top of `<`.
--
-- `<` is OPAQUE: its `вҲғ` body is touched only in the thin boundary layer
-- at the top of this file вҖ” `lt_intro` / `lt_elim` and the two atomic facts
-- (`lt_one_plus` / `lt_successor`, which supply the witness `0` directly).
-- Everything past them reasons through the interface, never the `вҲғ`.
-- `вүӨ` is TRANSPARENT вҖ” `< вҲЁ =` *is* its meaning.
--
-- Both relations are ordinary registered operators (like Integer/Rational/
-- Real). With the strict-order `weaken`/`transitive_left`/`transitive_right`
-- lemmas below, `<` is a full `calc` citizen, so the whole order interface
-- reads as mixed `<`/`вүӨ`/`=` chains.

module Natural.order

import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.one_plus_induction
import Logic.basics
import Logic.exists
import Equality.basics

-- в”Җв”Җ The strict-order foundation в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

-- `a < b` iff b exceeds a by at least one. Successor-free (only `+`/`1`),
-- and opaque вҖ” its body is seen ONLY by the two boundary lemmas below.
opaque definition Natural.LessThan (a b : Natural) : Proposition :=
  вҲғ (c : Natural). a + (1 + c) = b

operator (<) on (Natural, Natural) := Natural.LessThan

-- в”Җв”Җ Boundary: the general `<` intro / elim (sees the `вҲғ` body) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- A gap `c` with `a + (1 + c) = b` witnesses `a < b`, and conversely.
theorem Natural.lt_intro (a b c : Natural) (h : a + (1 + c) = b) : a < b :=
  unfold Natural.LessThan in witness c with h

theorem Natural.lt_elim (a b : Natural) (h : a < b)
        : вҲғ (c : Natural). a + (1 + c) = b :=
  unfold Natural.LessThan in h

-- в”Җв”Җ `вүӨ` as transparent notation on top of `<` в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
definition Natural.LessOrEqual (a b : Natural) : Proposition :=
  a < b вҲЁ a = b

operator (вүӨ) on (Natural, Natural) := Natural.LessOrEqual

-- в”Җв”Җ The two atomic strict facts (supply the witness `0` directly) в”Җв”Җв”Җв”Җв”Җ

-- a < 1 + a вҖ” the gap is 0.
theorem Natural.lt_one_plus (a : Natural) : a < 1 + a :=
  unfold Natural.LessThan in witness 0 with ring

-- a < successor(a) вҖ” the same fact in successor form.
automatic theorem Natural.lt_successor (a : Natural) : a < successor(a) :=
  unfold Natural.LessThan in witness 0 with (calc a + (1 + 0) = successor(a))

-- Nothing lies strictly below zero. A gap `c` with `k + (1 + c) = 0` makes
-- the left side a successor of `k + c`, which is never zero.
-- Implementation note: opaque `<` has no Decidable instance, so `absurd`
-- cannot refute `k < 0` on its own; consumers cite this lemma instead вҖ”
-- e.g. `NaturalsBelow(0)` is empty.
theorem Natural.not_less_than_zero (k : Natural) : В¬(k < 0) := {
  suppose k < 0 as _;
  choose gap such that k + (1 + gap) = 0 from Natural.lt_elim;
  absurd((calc successor(k + gap)
            = k + (1 + gap)
            = 0            by (k + (1 + gap) = 0)))
}

-- Irreflexivity: a value never lies strictly below itself. A gap `c` with
-- `a + (1 + c) = a` cancels `a` to force `1 + c = 0`, i.e. `successor(c) = 0`.
theorem Natural.lt_irreflexive (a : Natural) : В¬ (a < a) := {
  suppose a < a as _;
  choose gap such that a + (1 + gap) = a from Natural.lt_elim;
  calc a + (1 + gap)
     = a
     = a + 0;
  claim 1 + gap = 0 by Natural.add_cancel_left;
  absurd((calc successor(gap)
            = 1 + gap
            = 0         by (1 + gap = 0)))
}

-- Transitivity of `<`: stacking the two gaps gives a gap for a < c. This is
-- the one composition proven directly from the witnesses; the `calc`
-- interface below is then built on it.
theorem Natural.lt_transitive (a b c : Natural)
        (aLessThanB : a < b) (bLessThanC : b < c) : a < c := {
  choose gapAB such that a + (1 + gapAB) = b from Natural.lt_elim;
  choose gapBC such that b + (1 + gapBC) = c from Natural.lt_elim;
  calc a + (1 + (gapAB + (1 + gapBC)))
     = (a + (1 + gapAB)) + (1 + gapBC)
     = b + (1 + gapBC)
     = c;
  done by Natural.lt_intro
}

-- в”Җв”Җ The `calc` interface for `<` (the names `calc` resolves through the
-- registered operator). With these, mixed `<`/`вүӨ`/`=` chains compose. в”Җв”Җ

-- A strict inequality is in particular a weak one (disjunction injection).
theorem Natural.LessThan.weaken (a b : Natural) (h : a < b) : a вүӨ b := {
  done
}

-- a вүӨ b with a вү  b strengthens to a < b.
theorem Natural.lt_of_le_of_ne (a b : Natural) (lessOrEqual : a вүӨ b) (notEqual : В¬(a = b)) : a < b := {
  cases lessOrEqual {
    | Or.introduceLeft(less) => less
    | Or.introduceRight(equal) => absurd(notEqual(equal))
  }
}

-- a вүӨ b and b < c give a < c.
theorem Natural.LessThan.transitive_left (a b c : Natural)
        (aLessOrEqualB : a вүӨ b) (bLessThanC : b < c) : a < c :=
  claim by cases {
    in (a < b): done by Natural.lt_transitive
    in (a = b): done by substitution
  }

-- a < b and b вүӨ c give a < c.
theorem Natural.LessThan.transitive_right (a b c : Natural)
        (aLessThanB : a < b) (bLessOrEqualC : b вүӨ c) : a < c :=
  claim by cases {
    in (b < c): done by Natural.lt_transitive
    in (b = c): done by substitution
  }

-- в”Җв”Җ The `calc` interface for `вүӨ` в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

automatic theorem Natural.LessOrEqual.reflexive (a : Natural) : a вүӨ a := {
  claim a = a;
  done
}

theorem Natural.LessOrEqual.transitive (a b c : Natural)
        (aLessOrEqualB : a вүӨ b) (bLessOrEqualC : b вүӨ c) : a вүӨ c :=
  claim by cases {
    in (b < c): {
        claim a < c by Natural.LessThan.transitive_left;
        done
      }
    in (b = c): done by substitution
  }

-- в”Җв”Җ Order facts, now as `calc` chains в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

-- n вүӨ successor(n).
automatic theorem Natural.le_successor (n : Natural) : n вүӨ successor(n) := {
  claim n < successor(n) by Natural.lt_successor;
  done
}

-- Right-extension by one (the role the old `LessOrEqual.step` constructor
-- played): smaller вүӨ larger вүӨ successor(larger).
automatic theorem Natural.le_step (smaller larger : Natural) (proof : smaller вүӨ larger)
        : smaller вүӨ successor(larger) :=
  calc smaller
     вүӨ larger              by proof
     вүӨ successor(larger)   by Natural.le_successor

-- a вүӨ a + b.
automatic theorem Natural.less_or_equal_add_right (a b : Natural) : a вүӨ a + b :=
  cases b {
    | zero => {
        calc a = a + 0;
        done
      }
    | successor(predecessor) => {
        calc a + (1 + predecessor)
           = a + successor(predecessor);
        claim a < a + successor(predecessor) by Natural.lt_intro;
        done
      }
  }

-- Zero is at most every natural number: 0 вүӨ 0 + upperBound = upperBound.
automatic theorem Natural.zero_least (upperBound : Natural) : 0 вүӨ upperBound :=
  calc 0
     вүӨ 0 + upperBound   by Natural.less_or_equal_add_right
     = upperBound

theorem Natural.lt_trichotomy_successor_step (predecessor b : Natural)
        (predecessorComparison : predecessor < b вҲЁ predecessor = b вҲЁ b < predecessor)
        : 1 + predecessor < b вҲЁ 1 + predecessor = b вҲЁ b < 1 + predecessor :=
  claim by cases {
    in (predecessor < b): {
        choose gap such that predecessor + (1 + gap) = b as equation from Natural.lt_elim;
        cases gap refining equation {
          | zero => {
              -- the gap was exactly one: 1 + predecessor = b.
              calc 1 + predecessor
                 = predecessor + (1 + 0)
                 = b                        by equation;
              done
            }
          | successor(gapPredecessor) => {
              -- the gap exceeds one: 1 + predecessor < b.
              calc (1 + predecessor) + (1 + gapPredecessor)
                 = predecessor + (1 + successor(gapPredecessor))
                 = b                                                by equation;
              claim 1 + predecessor < b by Natural.lt_intro;
              done
            }
        }
      }
    in (predecessor = b вҲЁ b < predecessor): {
        claim by cases {
          in (predecessor = b): {
              calc b
                 = predecessor          by (predecessor = b)
                 < 1 + predecessor      by Natural.lt_one_plus;
              done
            }
          in (b < predecessor): {
              calc b
                 < predecessor
                 < 1 + predecessor      by Natural.lt_one_plus;
              done
            }
        }
      }
  }

-- Trichotomy: the strict-order elimination principle (any two naturals
-- compare as `<`, `=`, or `>`). Induction on a, b universal.
theorem Natural.lt_trichotomy (a : Natural)
        : вҲҖ (b : Natural). a < b вҲЁ a = b вҲЁ b < a :=
  by_induction on a with IH {
    case base: (b : Natural) вҶҰ
      cases b {
        | zero => {
            claim 0 = 0;
            done
          }
        | successor(predecessor) =>
            calc 0
               вүӨ predecessor              by Natural.zero_least
               < successor(predecessor)   by Natural.lt_successor
      }
    case step(predecessor): (b : Natural) вҶҰ {
      claim predecessor < b вҲЁ predecessor = b вҲЁ b < predecessor;
      done by Natural.lt_trichotomy_successor_step
    }
  }

-- Successor preserves вүӨ.
automatic theorem Natural.successor_less_or_equal_successor (a b : Natural)
        (proof : a вүӨ b) : successor(a) вүӨ successor(b) :=
  claim by cases {
    in (a < b): {
        choose gap such that a + (1 + gap) = b as equation from Natural.lt_elim;
        calc successor(a) + (1 + gap)
           = successor(a + (1 + gap))
           = successor(b)               by equation;
        claim successor(a) < successor(b) by Natural.lt_intro;
        done
      }
    in (a = b): done by substitution
  }

-- 1 вүӨ successor(k): `successor` monotonicity applied at 0 (`1` is `successor(0)`).
automatic theorem Natural.successor_positive (k : Natural) : 1 вүӨ successor(k) := {
  claim 0 вүӨ k by Natural.zero_least;
  done by Natural.successor_less_or_equal_successor
}

-- 1 вүӨ k + 1: the `n + 1` form of successor_positive.
theorem Natural.one_le_add_one (k : Natural) : 1 вүӨ k + 1 :=
  calc (1 : Natural)
     вүӨ successor(k)   by Natural.successor_positive
     = k + 1          by Natural.add_one

-- 1 вүӨ 2.
automatic theorem Natural.one_less_or_equal_two : 1 вүӨ 2 :=
  done by Natural.le_successor

-- A nonzero natural is at least one. Lets consumers turn "вү  0" straight into
-- the positive-multiplier hypothesis `1 вүӨ n` without a structural successor
-- case-split of their own.
theorem Natural.one_le_of_nonzero (n : Natural) (nonzero : n вү  0) : 1 вүӨ n :=
  cases n refining nonzero {
    | zero          => absurd(nonzero(reflexivity(0)))
    | successor(k)  => done by Natural.successor_positive
  }

-- successor(p) вүӨ upperBound implies p вүӨ upperBound.
automatic theorem Natural.less_or_equal_predecessor_less_or_equal
        (p upperBound : Natural) (successorLessOrEqual : successor(p) вүӨ upperBound)
        : p вүӨ upperBound := {
  calc p
     < successor(p)   by Natural.lt_successor
     вүӨ upperBound     by successorLessOrEqual;
  done
}

-- в”Җв”Җ The `<` вҶ” `successor вүӨ` bridge в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- Under the old foundation `a < b` was DEFINITIONALLY `successor(a) вүӨ b`;
-- now `<` is the opaque `вҲғ`-relation, so the equivalence is a (cheap)
-- theorem. Code that used to lean on the defeq routes through these.

-- k < n  вҹ№  successor(k) вүӨ n.
automatic theorem Natural.successor_le_of_lt (k n : Natural) (h : k < n) : successor(k) вүӨ n := {
  choose gap such that k + (1 + gap) = n from Natural.lt_elim;
  calc successor(k) + gap
     = k + (1 + gap)
     = n
     as shifted;
  calc successor(k)
     вүӨ successor(k) + gap   by Natural.less_or_equal_add_right
     = n                     by shifted
}

-- successor(k) вүӨ n  вҹ№  k < n: k < successor(k) вүӨ n.
automatic theorem Natural.lt_of_successor_le (k n : Natural) (h : successor(k) вүӨ n) : k < n :=
  calc k
     < successor(k)   by Natural.lt_successor
     вүӨ n              by h

-- в”Җв”Җ The `+ 1` / `<` public order interface в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- These are the `successor`-free counterparts of the strict-order
-- bridges above: clean names and statements (only `<`, `вүӨ`, `+ 1`), so
-- consumers in other modules never have to name the constructor. The
-- `successor` constructor stays confined to `Natural/`.

-- a < a + 1 вҖ” the atomic strict fact, in `+ 1` form (gap 0).
theorem Natural.lt_add_one (a : Natural) : a < a + 1 := {
  claim a < 1 + a by Natural.lt_one_plus;
  done by substituting (ring : a + 1 = 1 + a)
}

-- k < n  вҹ№  k + 1 вүӨ n.
theorem Natural.add_one_le_of_lt (k n : Natural) (h : k < n) : k + 1 вүӨ n := {
  choose gap such that k + (1 + gap) = n from Natural.lt_elim;
  calc (k + 1) + gap
     = k + (1 + gap)
     = n              as shifted;
  calc k + 1
     вүӨ (k + 1) + gap   by Natural.less_or_equal_add_right
     = n               by shifted
}

-- k + 1 вүӨ n  вҹ№  k < n: k < k + 1 вүӨ n.
theorem Natural.lt_of_add_one_le (k n : Natural) (h : k + 1 вүӨ n) : k < n :=
  calc k
     < k + 1   by Natural.lt_add_one
     вүӨ n        by h

-- k < n + 1  вҹ№  k вүӨ n: the gap collapses once the `+ 1` is cancelled.
theorem Natural.le_of_lt_add_one (k n : Natural) (h : k < n + 1) : k вүӨ n := {
  choose gap such that k + (1 + gap) = n + 1 from Natural.lt_elim;
  claim (k + gap) + 1 = n + 1;
  claim k + gap = n by Natural.add_cancel_right;
  calc k
     вүӨ k + gap   by Natural.less_or_equal_add_right
     = n
}

-- 1 вүӨ m  вҹ№  0 < m: positivity in `<` form.
theorem Natural.zero_lt_of_one_le (m : Natural) (h : 1 вүӨ m) : 0 < m := {
  claim 0 + 1 вүӨ m by substituting (ring : 0 + 1 = 1);
  done
}

-- a < n  вҹ№  a < n + 1 (the strict-order step, `+ 1` form).
theorem Natural.lt_add_one_of_lt (a n : Natural) (h : a < n) : a < n + 1 :=
  calc a
     < n        by h
     < n + 1    by Natural.lt_add_one

-- a вүӨ n  вҹ№  a вүӨ n + 1 (the weak-order step, `+ 1` form).
theorem Natural.le_add_one_of_le (a n : Natural) (h : a вүӨ n) : a вүӨ n + 1 :=
  calc a
     вүӨ n        by h
     вүӨ n + 1    by Natural.less_or_equal_add_right

-- Natural/prime_divisor_v2.math
--
-- Every natural number ≥ 2 has a prime divisor — Phase 1 surface
-- syntax with implicit-argument inference for under-applied calls.
-- Compare with Natural/prime_divisor.math for the equivalent proof in
-- the original eliminator-chain form. The structural shape of the
-- proof is now visible at a glance:
--
--   strong-induction on subject; cases on prime-or-proper-divisor.
--     prime case  → witness subject.
--     composite   → unpack divisor, recurse, witness prime.
--
-- Surface affordances exercised here:
--   * `cases` for case-split on Or.
--   * `let ⟨…⟩ := …` (1-level destructuring let) for And and Exists.
--   * Anonymous tuple `⟨…⟩` for Exists.introduce / And.introduction
--     with right-associate flattening into nested And.
--   * Implicit-argument inference at theorem call sites: trailing args
--     determine the leading ones via unification. So
--     `Natural.divides_transitive(p_div_d, d_div_n)` no longer needs
--     the prime/divisor/subject naturals spelled out.

module Natural.prime_divisor_v2

import Natural.basics
import Natural.order
import Natural.divisibility
import Natural.prime
import Natural.strong_recursion
import Natural.prime_split
import Logic.basics
import Logic.exists

theorem Natural.has_prime_divisor_v2 (n : Natural)
        (atLeastTwo : 2 ≤ n)
        : ∃ (prime : Natural). Natural.is_prime(prime) ∧ prime ∣ n :=
  Natural.strong_induction(
    (subject : Natural) ↦
        2 ≤ subject
        → ∃ (prime : Natural). Natural.is_prime(prime) ∧ prime ∣ subject,
    (subject : Natural)
        (inductionHypothesis :
            (smaller : Natural)
            → successor(smaller) ≤ subject
            → 2 ≤ smaller
            → ∃ (prime : Natural). Natural.is_prime(prime) ∧ prime ∣ smaller)
        (subjectAtLeastTwo : 2 ≤ subject) ↦
      cases Natural.prime_or_proper_divisor(subject, subjectAtLeastTwo) {
        | Or.introduceLeft(subjectIsPrime) =>
            ⟨subject, subjectIsPrime, Natural.divides_reflexive(subject)⟩
        | Or.introduceRight(properDivisorWitness) =>
            let ⟨divisor, divisorAtLeastTwo,
                  divisorBelowSubject, divisorDividesSubject⟩
                := properDivisorWitness
            in
            let ⟨prime, primeIsPrime, primeDividesDivisor⟩
                := inductionHypothesis(
                       divisor, divisorBelowSubject, divisorAtLeastTwo)
            in
            ⟨prime, primeIsPrime,
              Natural.divides_transitive(
                  primeDividesDivisor, divisorDividesSubject)⟩
      },
    n,
    atLeastTwo)

-- Natural/decide.math
--
-- Decision procedures on Natural: decidable equality, decidable
-- ordering, decidable divisibility. Each procedure returns an
-- `positive proof ∨ negative proof`, giving the constructive
-- analogue of a Boolean test along with a proof of the result.
--
-- The proofs go through 1-level pattern matches and explicit helper
-- definitions because our pattern matching can only destructure 1
-- scrutinee at a time. Helpers that "remember" the predecessor of an
-- earlier pattern take the inductive hypothesis explicitly so that
-- recursion on the predecessor is structural.

module Natural.decide

import Natural.basics
import Natural.peano
import Natural.order
import Natural.strong_recursion
import Equality.basics
import Logic.basics

-- decidable equality, with zero as the left operand.
theorem Natural.decides_equality_zero_against
        : (other : Natural) → zero = other ∨ zero ≠ other
  | zero =>
      Or.introduceLeft(reflexivity(zero))
  | successor(predecessor) =>
      Or.introduceRight(Natural.zero_not_successor(predecessor))

-- decidable equality, with successor(predecessor) as the left operand,
-- given a decision procedure for predecessor.
theorem Natural.decides_equality_successor_against
        (predecessor : Natural)
        (decidePredecessor :
            (other : Natural)
            → predecessor = other ∨ predecessor ≠ other)
        : (other : Natural)
          → successor(predecessor) = other ∨ successor(predecessor) ≠ other
  | zero =>
      Or.introduceRight(
          function (impossible : successor(predecessor) = zero) =>
              Natural.successor_not_zero(predecessor, impossible))
  | successor(otherPredecessor) =>
      claim (predecessor = otherPredecessor) ∨ (predecessor ≠ otherPredecessor)
          by decidePredecessor(otherPredecessor)
      claim by cases {
        in (predecessor = otherPredecessor) as predEqOther:
            Or.introduceLeft(
                congruenceOf(successor, predEqOther))
        in (predecessor ≠ otherPredecessor) as predNeqOther:
            Or.introduceRight(
                function (successorEquals : successor(predecessor) = successor(otherPredecessor)) =>
                    predNeqOther(
                        Natural.successor_injective(
                            predecessor, otherPredecessor,
                            successorEquals)))
      }

-- Decidable equality on Natural.
theorem Natural.decides_equality
        : (a b : Natural) → a = b ∨ a ≠ b
  | zero, b =>
      Natural.decides_equality_zero_against(b)
  | successor(predecessor), b =>
      Natural.decides_equality_successor_against(
          predecessor,
          Natural.decides_equality(predecessor),
          b)

-- decidable ≤, with zero as the left operand: always true.
theorem Natural.decides_less_or_equal_zero_against (other : Natural)
        : zero ≤ other ∨ zero ≰ other :=
  Or.introduceLeft(Natural.zero_least(other))

-- decidable ≤, successor case.
theorem Natural.decides_less_or_equal_successor_against
        (predecessor : Natural)
        (decidePredecessor :
            (other : Natural)
            → predecessor ≤ other ∨ predecessor ≰ other)
        : (other : Natural)
          → successor(predecessor) ≤ other ∨ successor(predecessor) ≰ other
  | zero =>
      Or.introduceRight(Natural.not_less_or_equal_successor_zero(predecessor))
  | successor(otherPredecessor) =>
      claim (predecessor ≤ otherPredecessor) ∨ (predecessor ≰ otherPredecessor)
          by decidePredecessor(otherPredecessor)
      claim by cases {
        in (predecessor ≤ otherPredecessor) as predecessorLessOrEqual:
            Or.introduceLeft(
                Natural.successor_less_or_equal_successor(
                    predecessor, otherPredecessor, predecessorLessOrEqual))
        in (predecessor ≰ otherPredecessor) as predecessorNotLessOrEqual:
            Or.introduceRight(
                function (successorLessOrEqual :
                        successor(predecessor) ≤ successor(otherPredecessor)) =>
                    predecessorNotLessOrEqual(
                        Natural.less_or_equal_successor_successor_descend(
                            predecessor, otherPredecessor, successorLessOrEqual)))
      }

-- Decidable ≤ on Natural.
theorem Natural.decides_less_or_equal
        : (a b : Natural)
          → a ≤ b ∨ a ≰ b
  | zero, b =>
      Natural.decides_less_or_equal_zero_against(b)
  | successor(predecessor), b =>
      Natural.decides_less_or_equal_successor_against(
          predecessor,
          Natural.decides_less_or_equal(predecessor),
          b)


-- Natural/divides_subtract.math
--
-- Arithmetic facts about divisibility involving "removing a divisor
-- summand from a sum". Used by Bezout (via is_gcd_remainder_lift) to
-- show that any common divisor of (first, second) also divides the
-- remainder when first = quotient · second + remainder.
--
-- The core lemma is `Natural.divides_subtract_from_sum`:
--     d ∣ (firstSummand + secondSummand) → d ∣ firstSummand
--     → d ∣ secondSummand.
-- Proof: peel `firstSummand = d · q` one divisor at a time. The two
-- "peel" lemmas (`_after_remove_one`, `_after_remove_multiple`) factor
-- through a case-split on the witness of the parent divides claim.
-- A tiny add-zero lemma (`add_equals_zero_right`) closes the bottom
-- of the zero-witness branch.

module Natural.divides_subtract

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.divisibility
import Natural.gcd

-- ----------------------------------------------------------------------
-- a + b = 0 implies b = 0. Mirror lemma; only the right-side variant
-- is used downstream.
theorem Natural.add_equals_zero_right (a b : Natural) (equation : a + b = 0) : b = 0 :=
  cases a refining equation {
    | zero => equation
    | successor(predA) => {
        claim isZero : successor(predA + b) = 0 by substituting Natural.successor_add;
        absurd(isZero)
      }
  }

-- ----------------------------------------------------------------------
-- "Peel one divisor" lemmas. Two case-helpers, then the main statement
-- via a case-split on the witness.

theorem Natural.divides_after_remove_one_witness_zero
        (divisor secondSummand : Natural)
        (equation : divisor + secondSummand = divisor * 0)
        : divisor ∣ secondSummand := {
    claim divisor + secondSummand = 0;
    claim secondEqualsZero : secondSummand = 0;
    claim divisor ∣ secondSummand by substituting secondEqualsZero
}

theorem Natural.divides_after_remove_one_witness_successor
        (divisor secondSummand : Natural) (predQ : Natural)
        (equation : divisor + secondSummand = divisor * successor(predQ))
        : divisor ∣ secondSummand := {
    -- divisor + secondSummand = divisor + divisor * predQ
    claim divisor + secondSummand = divisor + divisor * predQ;
    claim secondEqualsMultiple
            : secondSummand = divisor * predQ;
    witness predQ with secondEqualsMultiple
}

theorem Natural.divides_after_remove_one
        (divisor secondSummand : Natural)
        (divisorDividesEnlargedSum : divisor ∣ (divisor + secondSummand))
        : divisor ∣ secondSummand := {
  choose q such that divisor + secondSummand = divisor * q as equation from divisorDividesEnlargedSum;
  cases q refining equation {
    | zero =>
        done by Natural.divides_after_remove_one_witness_zero
    | successor(predQ) =>
        done by Natural.divides_after_remove_one_witness_successor
  }
}

-- ----------------------------------------------------------------------
-- "Peel q copies of divisor": iterate the one-divisor peel by induction
-- on q. The successor case reshapes `divisor * successor(q') + s` into
-- `divisor + (divisor * q' + s)` so the one-step peel applies, then
-- recurses on q'.

theorem Natural.divides_after_remove_multiple
        (divisor q : Natural)
        : ∀ (secondSummand : Natural).
          divisor ∣ (divisor * q + secondSummand)
          → divisor ∣ secondSummand :=
  by_induction on q with IH {
    case zero: {
        take secondSummand : Natural;
        suppose divisor ∣ (divisor * 0 + secondSummand) as dividesEnlargedSum;
        calc divisor * 0 + secondSummand
           = secondSummand;
        claim divisor ∣ secondSummand by substitution
      }
    case successor(predQ): {
        take secondSummand : Natural;
        suppose divisor ∣ (divisor * successor(predQ) + secondSummand)
            as dividesEnlargedSum;
        -- Reshape divisor·(predQ+1) + s into divisor + (divisor·predQ + s),
        -- peel one divisor, then recurse on predQ via the IH.
        calc divisor * successor(predQ) + secondSummand
           = divisor + (divisor * predQ + secondSummand);
        claim divisor ∣ (divisor + (divisor * predQ + secondSummand))
            by substitution;
        claim peeled : divisor ∣ (divisor * predQ + secondSummand)
            since Natural.divides_after_remove_one;
        IH(secondSummand, peeled)
      }
  }

-- ----------------------------------------------------------------------
-- Main lemma: if d divides a sum and divides one of the summands, then
-- d divides the other summand. Extract witnesses from the two divides
-- hypotheses, rewrite the first summand as `divisor * q`, then call
-- the `_after_remove_multiple` lemma.

theorem Natural.divides_subtract_from_sum
        (divisor firstSummand secondSummand : Natural)
        (dividesSum : divisor ∣ (firstSummand + secondSummand))
        (dividesFirst : divisor ∣ firstSummand)
        : divisor ∣ secondSummand := {
  choose q such that firstSummand = divisor * q as firstEquation from dividesFirst;
  claim divisor ∣ (divisor * q + secondSummand)
      by substituting firstEquation;
  done since Natural.divides_after_remove_multiple
}

-- ----------------------------------------------------------------------
-- is_gcd remainder lift: from `first = quotient · second + remainder`
-- and `is_gcd(g, second, remainder)`, conclude `is_gcd(g, first,
-- second)`. The forward direction (g ∣ first) uses divides_add and
-- divides_multiple_left; the universal-property direction uses
-- divides_subtract_from_sum to descend from "d divides first" plus
-- "d divides second" to "d divides remainder".

theorem Natural.is_gcd_remainder_lift
        (gcdValue first second quotient remainder : Natural)
        (decomposition : first = quotient * second + remainder)
        (gcdOfSecondRemainder : Natural.is_gcd(gcdValue, second, remainder))
        : Natural.is_gcd(gcdValue, first, second) := {
    claim gcdValue ∣ second;
    claim gcdValue ∣ remainder;
    claim gcdValue ∣ (quotient * second) since Natural.divides_multiple_left;
    claim gcdValue ∣ (quotient * second + remainder) since Natural.divides_add;
    claim gcdValue ∣ first by substituting decomposition;
    -- a common divisor of (first, second) divides remainder = first − quotient·second.
    claim universalForward : ∀ (d : Natural). d ∣ second → d ∣ remainder → d ∣ gcdValue;
    claim ∀ (commonDivisor : Natural).
            commonDivisor ∣ first → commonDivisor ∣ second → commonDivisor ∣ gcdValue by {
      take commonDivisor : Natural;
      suppose commonDivisor ∣ first as dDividesFirst;
      suppose commonDivisor ∣ second as dDividesSecond;
      claim commonDivisor ∣ (quotient * second) since Natural.divides_multiple_left;
      claim commonDivisor ∣ (quotient * second + remainder) by substituting decomposition;
      claim dDividesRemainder : commonDivisor ∣ remainder since Natural.divides_subtract_from_sum;
      universalForward(commonDivisor, dDividesSecond, dDividesRemainder)
    };
    done
}

-- Natural/monus.math
--
-- Truncated subtraction on Natural: `monus(a, b) = max(0, a - b)`.
-- Structural on the second argument. Provides the order test used by
-- Type-level decision procedures: `monus(p, n) = zero` iff p ≤ n.

module Natural.monus

import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.strong_recursion
import Equality.basics
import Logic.basics

-- monus(a, b) = a -̇ b, defined by recursion on the SUBTRAHEND: taking
-- away `successor(k)` takes away `k` and then one more predecessor. The
-- helper is subtrahend-first so the recursion drives its (matched) first
-- argument; `monus` restores the minuend-first argument order. The
-- recursion lives at the raw floor (self-contained, below the seal).
--
-- The wrapper is `opaque` so the kernel won't δ-unfold `monus` during
-- typechecking. Downstream proofs reason about monus through the
-- characterising lemmas below (`monus_zero_left`, `monus_zero`,
-- `monus_succ_succ`) rather than by relying on β/ι firing through
-- the recursion equations. Insulates the proof structure from the
-- definitional shape — e.g. `rewrite` finds the un-reduced form
-- `monus(succ(k), succ(predD))` in goal types because the kernel
-- leaves it as a stuck `monus(_, _)` application.
definition Natural.Raw.predecessor : Natural.Raw → Natural.Raw
  | Natural.Raw.zero         => Natural.Raw.zero
  | Natural.Raw.successor(k) => k

definition Natural.Raw.monusHelper : Natural.Raw → Natural.Raw → Natural.Raw
  | Natural.Raw.zero,         a => a
  | Natural.Raw.successor(k), a => Natural.Raw.predecessor(Natural.Raw.monusHelper(k, a))

definition Natural.Raw.monus (minuend subtrahend : Natural.Raw) : Natural.Raw :=
  Natural.Raw.monusHelper(subtrahend, minuend)

opaque definition Natural.monus : Natural → Natural → Natural :=
  unfold Natural in Natural.Raw.monus

-- Truncated subtraction, written with the dot: `a ∸ b` is a − b when
-- b ≤ a and 0 otherwise. (Honest `a - b` lives in ℤ — see
-- Integer/natural_subtraction.math and PLAN_NATURAL_NARROWING.md.)
operator (∸) on (Natural, Natural) := Natural.monus

-- ----------------------------------------------------------------------
-- Characterising lemmas. The `by unfolding Natural.monus` here is
-- the ONLY place that peeks at monus's body — every later proof
-- (in this file and downstream) cites these lemmas instead. That's
-- the discipline the opacity declaration is meant to enforce.

-- a ∸ zero = a. Subtracting nothing (definitional).
theorem Natural.monus_zero (a : Natural) : a ∸ 0 = a :=
  done by unfolding Natural.monus

-- The recursion equation: subtracting successor(b) is one more predecessor.
theorem Natural.monus_successor (a b : Natural)
        : a ∸ successor(b) = Natural.predecessor(a ∸ b) :=
  done by unfolding Natural.monus, Natural.predecessor, Natural.Raw.predecessor, Natural

-- zero ∸ b = zero. Every predecessor of zero is zero.
theorem Natural.monus_zero_left (b : Natural) : 0 ∸ b = 0 :=
  by induction on b with IH {
    case zero: done by Natural.monus_zero
    case successor(k):
        0 ∸ successor(k)
           = Natural.predecessor(0 ∸ k)   by Natural.monus_successor
           = Natural.predecessor(0)                      by IH
           = 0
  }

-- successor(k) ∸ zero = successor(k).
theorem Natural.monus_succ_zero (k : Natural)
        : successor(k) ∸ 0 = successor(k) :=
  done by unfolding Natural.monus

-- successor(k) ∸ successor(j) = k ∸ j. The recursive
-- step. Lets downstream proofs "subtract a 1 from both sides." Induct
-- on j, peeling one predecessor off each side via the recursion equation.
theorem Natural.monus_succ_succ (k j : Natural)
        : successor(k) ∸ successor(j) = k ∸ j :=
  by induction on j with IH {
    case zero:
        successor(k) ∸ successor(0)
           = Natural.predecessor(successor(k) ∸ 0)   by Natural.monus_successor
           = Natural.predecessor(successor(k))                      by Natural.monus_succ_zero
           = k
           = k ∸ 0                                    by Natural.monus_zero
    case successor(m):
        successor(k) ∸ successor(successor(m))
           = Natural.predecessor(successor(k) ∸ successor(m))   by Natural.monus_successor
           = Natural.predecessor(k ∸ m)                          by IH
           = k ∸ successor(m)                                    by Natural.monus_successor
  }

-- The `1 + n` forms of the two recursive-step characterising lemmas, so
-- downstream proofs peel a 1 off monus without naming the constructor.
theorem Natural.monus_one_plus_zero (k : Natural)
        : (1 + k) ∸ 0 = 1 + k :=
  (1 + k) ∸ 0
     = successor(k) ∸ 0
     = successor(k)                      by Natural.monus_succ_zero
     = 1 + k

theorem Natural.monus_one_plus_one_plus (k j : Natural)
        : (1 + k) ∸ (1 + j) = k ∸ j :=
  (1 + k) ∸ (1 + j)
     = successor(k) ∸ successor(j)
     = k ∸ j                          by Natural.monus_succ_succ

-- a ∸ a = zero. Induct on a, using monus_one_plus_one_plus to peel
-- a 1 off both sides.
theorem Natural.monus_self (a : Natural) : a ∸ a = 0 :=
  by induction on a with IH {
    case base: done
    case step(k):
        (1 + k) ∸ (1 + k)
           = k ∸ k
           = 0                     by IH
  }

-- Subtracting a summand recovers the other: (b + c) − b = c. Induct on b.
theorem Natural.monus_add_left (b : Natural)
        : ∀ (c : Natural). (b + c) ∸ b = c :=
  by induction on b with IH {
    case base: {
        take c : Natural;
        (0 + c) ∸ 0
           = c
      }
    case step(bPredecessor): {
        take c : Natural;
        ((1 + bPredecessor) + c) ∸ (1 + bPredecessor)
           = (1 + (bPredecessor + c)) ∸ (1 + bPredecessor)
           = (bPredecessor + c) ∸ bPredecessor
           = c by IH(c)
      }
  }

-- Cancelling a common left summand: (a + c) − (a + d) = c − d. Induct on a,
-- peeling a 1 off both arguments with monus_one_plus_one_plus each step.
theorem Natural.monus_add_common_left (a : Natural)
        : ∀ (c d : Natural). (a + c) ∸ (a + d) = c ∸ d :=
  by induction on a with IH {
    case base: {
        take c : Natural;
        take d : Natural;
        (0 + c) ∸ (0 + d)
           = c ∸ d
      }
    case step(k): {
        take c : Natural;
        take d : Natural;
        ((1 + k) + c) ∸ ((1 + k) + d)
           = (1 + (k + c)) ∸ (1 + (k + d))
           = (k + c) ∸ (k + d)
           = c ∸ d by IH(c, d)
      }
  }

-- The right-hand companion: (a + c) − (b + c) = a − b. Reorder each side
-- to a common left summand, then cancel it.
theorem Natural.monus_add_common_right (a b c : Natural)
        : (a + c) ∸ (b + c) = a ∸ b :=
  (a + c) ∸ (b + c)
     = (c + a) ∸ (c + b)
     = a ∸ b

-- If a ≤ b, then a ∸ b = zero. Induct on b, inner case on a.
-- All access to monus is via the characterising lemmas above —
-- monus_zero_left for the b=0 / a=0 corners, monus_succ_succ to
-- peel both sides in the recursive case.
theorem Natural.le_implies_monus_zero (b : Natural)
        : ∀ (a : Natural). a ≤ b → a ∸ b = 0 :=
  by induction on b with IH {
    case base: {
        take a : Natural;
        suppose a ≤ 0 as aLessOrEqualZero;
        a ∸ 0
           = 0 ∸ 0
           = 0
      }
    case step(predecessorB): {
        take a : Natural;
        suppose a ≤ 1 + predecessorB as aBound;
        by induction on a with innerIH {
          case base:
              done
          case step(k): {
              -- peel a 1 off both sides, then recurse (outer IH at
              -- predecessorB on the descended bound 1 + k ≤ 1 + predecessorB).
              k ≤ predecessorB by Natural.le_cancel_one_plus as descended;
              (1 + k) ∸ (1 + predecessorB)
                 = k ∸ predecessorB
                 = 0                                 by IH(k, descended)
            }
        }
      }
  }

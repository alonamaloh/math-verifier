-- Natural/instances.math
--
-- Natural is a commutative monoid under both addition and
-- multiplication (it's a commutative semiring once we have a
-- predicate for that). Not a group: no additive inverses, only
-- truncated subtraction.

module Natural.instances

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Algebra.monoid

-- Natural is a monoid under (+, 0).
theorem Natural.add_is_monoid
        : IsMonoid(Natural, Natural.add, 0) :=
    ⟨Natural.add_associative,
     Natural.zero_add,
     Natural.add_zero⟩

-- Natural is a commutative monoid under (+, 0).
theorem Natural.add_is_commutative_monoid
        : IsCommutativeMonoid(Natural, Natural.add, 0) :=
    ⟨Natural.add_is_monoid, Natural.add_commutative⟩

-- Natural is a monoid under (·, 1).
theorem Natural.multiply_is_monoid
        : IsMonoid(Natural, Natural.multiply, 1) :=
    ⟨Natural.multiply_associative,
     Natural.one_multiply,
     Natural.multiply_one⟩

-- Natural is a commutative monoid under (·, 1).
theorem Natural.multiply_is_commutative_monoid
        : IsCommutativeMonoid(Natural, Natural.multiply, 1) :=
    ⟨Natural.multiply_is_monoid, Natural.multiply_commutative⟩


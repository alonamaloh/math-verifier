-- Natural/decide_divides.math
--
-- Proves Natural.decides_divides — the final axiom on the path to
-- has_prime_divisor. Three building blocks:
--
--   1. Natural.le_q_d_mult_q: for d ≥ 1, q ≤ d·q. This bounds any
--      candidate quotient by n.
--
--   2. Natural.search_quotient_witness_up_to: bounded structural
--      recursion on a quotient upper bound. Either find a q ≤ bound
--      with n = d·q, or rule out every such q.
--
--   3. Natural.decides_divides itself: for d = 0, dispatch via
--      decides_equality(n, 0); for d = successor(dPredecessor), invoke the bounded
--      search at bound = n. The "no quotient in [0, n]" branch
--      combines with the cap lemma to give "no quotient anywhere".

module Natural.decide_divides

import Natural.basics
import Natural.arithmetic
import Natural.peano
import Natural.order
import Natural.divisibility
import Natural.strong_recursion
import Natural.decide
import Equality.basics
import Logic.basics
import Logic.exists

-- Cap lemma: q ≤ d·q when d ≥ 1. Pattern-match on d; the
-- successor(predD) case uses that multiply(successor(_), _) reduces
-- definitionally on the first argument, so d·q ≡ q + predD·q, and
-- q ≤ q + (anything) by le_add_right.
theorem Natural.le_q_d_mult_q
        : (d q : Natural) → LessOrEqual(one, d)
          → LessOrEqual(q, Natural.multiply(d, q))
  | zero, q, oneLessOrEqualZero =>
      False.eliminate_proposition(
          LessOrEqual(q, Natural.multiply(zero, q)),
          Natural.not_less_or_equal_successor_zero(zero, oneLessOrEqualZero))
  | successor(predD), q, _ =>
      Natural.less_or_equal_add_right(q, Natural.multiply(predD, q))

-- Bounded quotient search. Returns either a witness q ≤ bound with
-- n = d·q, or a function rejecting every such q.
theorem Natural.search_quotient_witness_up_to (d n : Natural)
        : (quotientBound : Natural)
          → Or(Exists(Natural, function (q : Natural) =>
                  And(LessOrEqual(q, quotientBound),
                      n = Natural.multiply(d, q))),
                (q : Natural)
                → LessOrEqual(q, quotientBound)
                → Not(n = Natural.multiply(d, q)))
  | zero =>
      Or.eliminate(
          n = Natural.multiply(d, zero),
          Not(n = Natural.multiply(d, zero)),
          Or(Exists(Natural, function (q : Natural) =>
                  And(LessOrEqual(q, zero),
                      n = Natural.multiply(d, q))),
              (q : Natural)
                → LessOrEqual(q, zero)
                → Not(n = Natural.multiply(d, q))),
          function (nEqualsDTimesZero : n = Natural.multiply(d, zero)) =>
              Or.introduceLeft(
                  Exists.introduce(
                      zero,
                      And.introduction(
                          LessOrEqual.reflexivity(zero),
                          nEqualsDTimesZero))),
          function (nNotDTimesZero :
                  Not(n = Natural.multiply(d, zero))) =>
              Or.introduceRight(
                  function (q : Natural)
                      (quotientLessOrEqualZero : LessOrEqual(q, zero))
                      (nEqualsDTimesQuotient : n = Natural.multiply(d, q)) =>
                    nNotDTimesZero(
                        Equality.transport_proposition(
                            Natural,
                            function (qValue : Natural) =>
                                n = Natural.multiply(d, qValue),
                            q, zero,
                            Natural.less_or_equal_zero_implies_equals_zero(
                                q, quotientLessOrEqualZero),
                            nEqualsDTimesQuotient))),
          Natural.decides_equality(n, Natural.multiply(d, zero)))
  | successor(prevBound) =>
      Or.eliminate(
          Exists(Natural, function (q : Natural) =>
              And(LessOrEqual(q, prevBound),
                  n = Natural.multiply(d, q))),
          (q : Natural)
              → LessOrEqual(q, prevBound)
              → Not(n = Natural.multiply(d, q)),
          Or(Exists(Natural, function (q : Natural) =>
                  And(LessOrEqual(q, successor(prevBound)),
                      n = Natural.multiply(d, q))),
              (q : Natural)
                → LessOrEqual(q, successor(prevBound))
                → Not(n = Natural.multiply(d, q))),
          -- Found earlier: propagate, boosting the bound proof.
          function (foundEarlier : Exists(Natural,
                  function (q : Natural) =>
                      And(LessOrEqual(q, prevBound),
                          n = Natural.multiply(d, q)))) =>
              Exists.eliminate(
                  Natural,
                  function (q : Natural) =>
                      And(LessOrEqual(q, prevBound),
                          n = Natural.multiply(d, q)),
                  Or(Exists(Natural, function (q : Natural) =>
                          And(LessOrEqual(q, successor(prevBound)),
                              n = Natural.multiply(d, q))),
                      (q : Natural)
                        → LessOrEqual(q, successor(prevBound))
                        → Not(n = Natural.multiply(d, q))),
                  function (q : Natural)
                      (combined : And(LessOrEqual(q, prevBound),
                                       n = Natural.multiply(d, q))) =>
                    And.eliminate(
                        LessOrEqual(q, prevBound),
                        n = Natural.multiply(d, q),
                        Or(Exists(Natural, function (qInner : Natural) =>
                                And(LessOrEqual(qInner,
                                                 successor(prevBound)),
                                    n = Natural.multiply(d, qInner))),
                            (qInner : Natural)
                              → LessOrEqual(qInner, successor(prevBound))
                              → Not(n = Natural.multiply(d, qInner))),
                        function (qLePrevBound : LessOrEqual(q, prevBound))
                            (nEqualsDTimesQuotient : n = Natural.multiply(d, q)) =>
                          Or.introduceLeft(
                              Exists.introduce(
                                  q,
                                  And.introduction(
                                      LessOrEqual.step(
                                          q, prevBound, qLePrevBound),
                                      nEqualsDTimesQuotient))),
                        combined),
                  foundEarlier),
          -- Not found in [0, prevBound]: check q = successor(prevBound).
          function (noneEarlier :
                  (q : Natural)
                  → LessOrEqual(q, prevBound)
                  → Not(n = Natural.multiply(d, q))) =>
              Or.eliminate(
                  n = Natural.multiply(d, successor(prevBound)),
                  Not(n = Natural.multiply(d, successor(prevBound))),
                  Or(Exists(Natural, function (qInner : Natural) =>
                          And(LessOrEqual(qInner, successor(prevBound)),
                              n = Natural.multiply(d, qInner))),
                      (qInner : Natural)
                        → LessOrEqual(qInner, successor(prevBound))
                        → Not(n = Natural.multiply(d, qInner))),
                  function (nEqualsDTimesSuccessorPrevious :
                          n = Natural.multiply(d, successor(prevBound))) =>
                      Or.introduceLeft(
                          Exists.introduce(
                              successor(prevBound),
                              And.introduction(
                                  LessOrEqual.reflexivity(
                                      successor(prevBound)),
                                  nEqualsDTimesSuccessorPrevious))),
                  function (nNotDTimesSuccessorPrevious :
                          Not(n = Natural.multiply(d, successor(prevBound)))) =>
                      Or.introduceRight(
                          function (q : Natural)
                              (quotientLessOrEqualSuccessorPrevious :
                                  LessOrEqual(q, successor(prevBound)))
                              (nEqualsDTimesQuotient : n = Natural.multiply(d, q)) =>
                            -- q ≤ successor(prevBound): either q = successor(prevBound)
                            -- (contradicts nNotDTimesSuccessorPrevious) or q ≤ prevBound
                            -- (contradicts noneEarlier).
                            Or.eliminate(
                                q = successor(prevBound),
                                Exists(Natural,
                                    function (bPredecessor : Natural) =>
                                        And(successor(prevBound) =
                                                successor(bPredecessor),
                                             LessOrEqual(q, bPredecessor))),
                                False,
                                function (quotientEqualsSuccessorPrevious :
                                        q = successor(prevBound)) =>
                                    nNotDTimesSuccessorPrevious(
                                        Equality.transport_proposition(
                                            Natural,
                                            function (qValue : Natural) =>
                                                n = Natural.multiply(d, qValue),
                                            q, successor(prevBound),
                                            quotientEqualsSuccessorPrevious,
                                            nEqualsDTimesQuotient)),
                                function (existsProof :
                                        Exists(Natural,
                                            function (bPredecessor : Natural) =>
                                                And(successor(prevBound) =
                                                        successor(bPredecessor),
                                                     LessOrEqual(q, bPredecessor)))) =>
                                    Exists.eliminate(
                                        Natural,
                                        function (bPredecessor : Natural) =>
                                            And(successor(prevBound) =
                                                    successor(bPredecessor),
                                                 LessOrEqual(q, bPredecessor)),
                                        False,
                                        function (bPredecessor : Natural)
                                            (combined : And(successor(prevBound) =
                                                                successor(bPredecessor),
                                                             LessOrEqual(q,
                                                                          bPredecessor))) =>
                                          And.eliminate(
                                              successor(prevBound) =
                                                  successor(bPredecessor),
                                              LessOrEqual(q, bPredecessor),
                                              False,
                                              function (successorEquals :
                                                      successor(prevBound) =
                                                          successor(bPredecessor))
                                                  (quotientLessOrEqualBPredecessor :
                                                      LessOrEqual(q,
                                                                   bPredecessor)) =>
                                                  noneEarlier(
                                                      q,
                                                      Equality.transport_proposition(
                                                          Natural,
                                                          function (rightEnd : Natural) =>
                                                              LessOrEqual(q,
                                                                           rightEnd),
                                                          bPredecessor,
                                                          prevBound,
                                                          Equality.symmetry(
                                                              Natural.successor_injective(
                                                                  prevBound,
                                                                  bPredecessor,
                                                                  successorEquals)),
                                                          quotientLessOrEqualBPredecessor),
                                                      nEqualsDTimesQuotient),
                                              combined),
                                        existsProof),
                                LessOrEqual.invert(
                                    q, successor(prevBound),
                                    quotientLessOrEqualSuccessorPrevious))),
                  Natural.decides_equality(
                      n,
                      Natural.multiply(d, successor(prevBound)))),
          Natural.search_quotient_witness_up_to(d, n, prevBound))

-- Decidable divisibility on Natural. For d = 0, dispatches via
-- decides_equality(n, 0). For d = successor(dPredecessor), runs the bounded search
-- at bound = n; the "not found" branch combines with the cap lemma
-- to rule out any q (because q > n would force d·q > n).
theorem Natural.decides_divides
        : (d n : Natural)
          → Or(Natural.divides(d, n), Not(Natural.divides(d, n)))
  | zero, n =>
      Or.eliminate(
          n = zero,
          Not(n = zero),
          Or(Natural.divides(zero, n), Not(Natural.divides(zero, n))),
          function (nEqualsZero : n = zero) =>
              -- divides(0, n) with witness q = 0: need n = 0*0 = 0.
              Or.introduceLeft(
                  Exists.introduce(
                      zero,
                      nEqualsZero)),
          function (nNotEqualZero : Not(n = zero)) =>
              Or.introduceRight(
                  function (divProof : Natural.divides(zero, n)) =>
                      Exists.eliminate(
                          Natural,
                          function (q : Natural) =>
                              n = Natural.multiply(zero, q),
                          False,
                          function (q : Natural)
                              (nEqMulZeroQ :
                                  n = Natural.multiply(zero, q)) =>
                              -- multiply(zero, q) reduces to zero
                              -- definitionally (first-argument rule of
                              -- multiply), so nEqMulZeroQ : n = zero.
                              nNotEqualZero(nEqMulZeroQ),
                          divProof)),
          Natural.decides_equality(n, zero))
  | successor(predD), n =>
      Or.eliminate(
          Exists(Natural, function (q : Natural) =>
              And(LessOrEqual(q, n),
                  n = Natural.multiply(successor(predD), q))),
          (q : Natural)
              → LessOrEqual(q, n)
              → Not(n = Natural.multiply(successor(predD), q)),
          Or(Natural.divides(successor(predD), n),
              Not(Natural.divides(successor(predD), n))),
          function (foundWitness : Exists(Natural,
                  function (q : Natural) =>
                      And(LessOrEqual(q, n),
                          n = Natural.multiply(successor(predD), q)))) =>
              Exists.eliminate(
                  Natural,
                  function (q : Natural) =>
                      And(LessOrEqual(q, n),
                          n = Natural.multiply(successor(predD), q)),
                  Or(Natural.divides(successor(predD), n),
                      Not(Natural.divides(successor(predD), n))),
                  function (q : Natural)
                      (combined : And(LessOrEqual(q, n),
                                       n = Natural.multiply(successor(predD), q))) =>
                    And.eliminate(
                        LessOrEqual(q, n),
                        n = Natural.multiply(successor(predD), q),
                        Or(Natural.divides(successor(predD), n),
                            Not(Natural.divides(successor(predD), n))),
                        function (_ : LessOrEqual(q, n))
                            (nEqualsDTimesQuotient :
                                n = Natural.multiply(successor(predD), q)) =>
                          Or.introduceLeft(
                              Exists.introduce(
                                  q,
                                  nEqualsDTimesQuotient)),
                        combined),
                  foundWitness),
          function (noQuotientInRange :
                  (q : Natural)
                  → LessOrEqual(q, n)
                  → Not(n = Natural.multiply(successor(predD), q))) =>
              Or.introduceRight(
                  function (divProof : Natural.divides(successor(predD), n)) =>
                      Exists.eliminate(
                          Natural,
                          function (q : Natural) =>
                              n = Natural.multiply(successor(predD), q),
                          False,
                          function (q : Natural)
                              (nEqualsDTimesQuotient :
                                  n = Natural.multiply(successor(predD), q)) =>
                            -- We have q : Natural and n = d·q. Cap
                            -- lemma gives q ≤ d·q = n, so q ≤ n.
                            -- Then noQuotientInRange contradicts.
                            noQuotientInRange(
                                q,
                                Equality.transport_proposition(
                                    Natural,
                                    function (rightEnd : Natural) =>
                                        LessOrEqual(q, rightEnd),
                                    Natural.multiply(successor(predD), q),
                                    n,
                                    Equality.symmetry(nEqualsDTimesQuotient),
                                    Natural.le_q_d_mult_q(
                                        successor(predD), q,
                                        Natural.successor_less_or_equal_successor(
                                            zero, predD,
                                            Natural.zero_least(predD)))),
                                nEqualsDTimesQuotient),
                          divProof)),
          Natural.search_quotient_witness_up_to(
              successor(predD), n, n))

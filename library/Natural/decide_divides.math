-- Natural/decide_divides.math
--
-- Proves Natural.decides_divides — the final axiom on the path to
-- has_prime_divisor. Three building blocks:
--
--   1. Natural.le_q_d_mult_q: for d ≥ 1, q ≤ d·q. This bounds any
--      candidate quotient by n.
--
--   2. Natural.search_quotient_witness_up_to: bounded structural
--      recursion on a quotient upper bound. Either find a q ≤ bound
--      with n = d·q, or rule out every such q.
--
--   3. Natural.decides_divides itself: for d = 0, dispatch via
--      decides_equality(n, 0); for d = successor(dPredecessor), invoke the bounded
--      search at bound = n. The "no quotient in [0, n]" branch
--      combines with the cap lemma to give "no quotient anywhere".

module Natural.decide_divides

import Natural.basics
import Natural.arithmetic
import Natural.peano
import Natural.order
import Natural.divisibility
import Natural.strong_recursion
import Natural.decide
import Equality.basics
import Logic.basics
import Logic.exists

-- Cap lemma: q ≤ d·q when d ≥ 1. Cases on d: the zero case is
-- absurd (no 1 ≤ 0); the successor(predD) case uses that
-- multiply(successor(_), _) reduces definitionally on the first
-- argument, so d·q ≡ q + predD·q, and q ≤ q + (anything) by
-- le_add_right.
theorem Natural.le_q_d_mult_q
        (d q : Natural) (oneLessOrEqualD : 1 ≤ d)
        : q ≤ d * q :=
  cases d {
    case zero:            absurd(oneLessOrEqualD)
    case successor(predD):
        q
           ≤ q + predD * q
           = successor(predD) * q
  }

-- Bounded quotient search. Returns either a witness q ≤ bound with
-- n = d·q, or a function rejecting every such q.
theorem Natural.search_quotient_witness_up_to
        (d n quotientBound : Natural)
        : (∃ (q : Natural). q ≤ quotientBound ∧ n = d * q) ∨ (∀ (q : Natural).
              q ≤ quotientBound
              → n ≠ d * q) :=
  by induction on quotientBound with IH {
    case zero: {
        (n = d * 0) ∨ (n ≠ d * 0);
        done by cases {
          case n = d * 0 as nEqualsDTimesZero: {
              ∃ (q : Natural). q ≤ 0 ∧ n = d * q by {
                witness 0 with (0 ≤ 0 ∧ n = d * 0)
              };
              done
          }
          case n ≠ d * 0 as nNotDTimesZero: {
              ∀ (q : Natural). q ≤ 0 → n ≠ d * q by {
                take q : Natural;
                suppose q ≤ 0 as quotientLessOrEqualZero;
                suppose n = d * q as nEqualsDTimesQuotient;
                q = 0 as qIsZero;
                n = d * 0 by substituting qIsZero;
                done
              };
              done
          }
        }
      }
    case successor(prevBound): {
        done by cases {
          case ∃ (q : Natural). q ≤ prevBound ∧ n = d * q as foundEarlier: {
              choose q such that q ≤ prevBound ∧ n = d * q from foundEarlier;
              ∃ (qNext : Natural). qNext ≤ successor(prevBound) ∧ n = d * qNext by {
                q ≤ successor(prevBound);
                witness q with (q ≤ successor(prevBound) ∧ n = d * q)
              };
              done
          }
          case ∀ (q : Natural). q ≤ prevBound → n ≠ d * q as noneEarlier: {
              (n = d * successor(prevBound)) ∨ (n ≠ d * successor(prevBound));
              done by cases {
                case n = d * successor(prevBound) as nEqualsDTimesSuccessorPrevious: {
                    ∃ (q : Natural). q ≤ successor(prevBound) ∧ n = d * q by {
                      witness successor(prevBound)
                          with (successor(prevBound) ≤ successor(prevBound) ∧ n = d * successor(prevBound))
                    };
                    done
                }
                case n ≠ d * successor(prevBound) as nNotDTimesSuccessorPrevious: {
                    ∀ (q : Natural). q ≤ successor(prevBound) → n ≠ d * q by {
                      take q : Natural;
                      suppose q ≤ successor(prevBound) as quotientLessOrEqualSuccessorPrevious;
                      suppose n = d * q as nEqualsDTimesQuotient;
                      -- q ≤ successor(prevBound) means q = successor(prevBound) (contradicts
                      -- this branch's hypothesis) or q ≤ prevBound (contradicts noneEarlier).
                      (q = successor(prevBound))
                            ∨ (∃ (bPredecessor : Natural).
                                  successor(prevBound) = successor(bPredecessor) ∧ q ≤ bPredecessor);
                      done by cases {
                        case q = successor(prevBound) as quotientEqualsSuccessorPrevious: {
                            n = d * successor(prevBound) by substituting quotientEqualsSuccessorPrevious;
                            done
                        }
                        case ∃ (bPredecessor : Natural).
                              successor(prevBound) = successor(bPredecessor) ∧ q ≤ bPredecessor
                            as smallerBound: {
                            choose bPredecessor such that
                                successor(prevBound) = successor(bPredecessor) ∧ q ≤ bPredecessor
                                from smallerBound;
                            prevBound = bPredecessor as prevBoundEqualsBPredecessor;
                            q ≤ prevBound by substituting prevBoundEqualsBPredecessor;
                            done
                        }
                      }
                    };
                    done
                }
              }
          }
        }
      }
  }

-- Decidable divisibility on Natural. Cases on d: zero dispatches
-- via decides_equality(n, 0); successor(predD) runs the bounded
-- search at bound = n, and the "not found" branch combines with
-- the cap lemma to rule out any q (because q > n would force
-- d·q > n).
automatic theorem Natural.decides_divides
        (d n : Natural) : d ∣ n ∨ d ∤ n :=
  cases d {
    | zero => {
        (n = 0) ∨ (n ≠ 0);
        done by cases {
          case n = 0 as nEqualsZero: {
              -- 0 ∣ n with witness q = 0: 0 · 0 = 0 = n.
              0 ∣ n;
              done
          }
          case n ≠ 0 as nNotEqualZero: {
              -- A divisibility witness would give n = 0 · q = 0,
              -- contradicting nNotEqualZero.
              0 ∤ n by {
                suppose 0 ∣ n as divProof;
                choose q such that n = 0 * q as nEqualsZeroTimesQuotient from divProof;
                n = 0 by substituting nEqualsZeroTimesQuotient;
                done
              };
              done
          }
        }
      }
    | successor(predD) => {
        (∃ (q : Natural). q ≤ n ∧ n = successor(predD) * q)
              ∨ (∀ (q : Natural). q ≤ n → n ≠ successor(predD) * q);
        done by cases {
          case ∃ (q : Natural). q ≤ n ∧ n = successor(predD) * q as foundWitness: {
              -- Witness found; that's the divisor.
              choose q such that q ≤ n ∧ n = successor(predD) * q from foundWitness;
              successor(predD) ∣ n;
              done
          }
          case ∀ (q : Natural). q ≤ n → n ≠ successor(predD) * q as noQuotientInRange: {
              -- A divisibility witness gives some q with n = d · q; the cap
              -- lemma forces q ≤ d · q = n, which noQuotientInRange forbids.
              successor(predD) ∤ n by {
                suppose successor(predD) ∣ n as divProof;
                choose q such that n = successor(predD) * q as nEqualsDTimesQuotient
                    from divProof;
                1 ≤ successor(predD);
                q ≤ successor(predD) * q;
                q ≤ n by substituting nEqualsDTimesQuotient;
                done
              };
              done
          }
        }
      }
  }

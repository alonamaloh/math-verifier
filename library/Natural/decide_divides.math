-- Natural/decide_divides.math
--
-- Proves Natural.decides_divides — the final axiom on the path to
-- has_prime_divisor. Three building blocks:
--
--   1. Natural.le_q_d_mult_q: for d ≥ 1, q ≤ d·q. This bounds any
--      candidate quotient by n.
--
--   2. Natural.search_quotient_witness_up_to: bounded structural
--      recursion on a quotient upper bound. Either find a q ≤ bound
--      with n = d·q, or rule out every such q.
--
--   3. Natural.decides_divides itself: for d = 0, dispatch via
--      decides_equality(n, 0); for d = successor(dPredecessor), invoke the bounded
--      search at bound = n. The "no quotient in [0, n]" branch
--      combines with the cap lemma to give "no quotient anywhere".

module Natural.decide_divides

import Natural.basics
import Natural.arithmetic
import Natural.peano
import Natural.order
import Natural.divisibility
import Natural.strong_recursion
import Natural.decide
import Equality.basics
import Logic.basics
import Logic.exists

-- Cap lemma: q ≤ d·q when d ≥ 1. Pattern-match on d; the
-- successor(predD) case uses that multiply(successor(_), _) reduces
-- definitionally on the first argument, so d·q ≡ q + predD·q, and
-- q ≤ q + (anything) by le_add_right.
theorem Natural.le_q_d_mult_q
        : (d q : Natural) → 1 ≤ d
          → q ≤ d * q
  | zero, q, oneLessOrEqualZero =>
      absurd(oneLessOrEqualZero)
  | successor(predD), q, _ =>
      Natural.less_or_equal_add_right(q, predD * q)

-- Bounded quotient search. Returns either a witness q ≤ bound with
-- n = d·q, or a function rejecting every such q.
theorem Natural.search_quotient_witness_up_to (d n : Natural)
        : (quotientBound : Natural)
          → Or(∃ (q : Natural). q ≤ quotientBound ∧ n = d * q,
                (q : Natural)
                → q ≤ quotientBound
                → n ≠ d * q)
  | zero =>
      claim (n = d * 0) ∨ (n ≠ d * 0)
      claim by cases {
        in (n = d * 0) as nEqualsDTimesZero:
            Or.introduceLeft(
                Exists.introduce(
                    0,
                    And.introduction(
                        LessOrEqual.reflexivity(0),
                        nEqualsDTimesZero)))
        in (n ≠ d * 0) as nNotDTimesZero:
            Or.introduceRight(
                function (q : Natural)
                    (quotientLessOrEqualZero : q ≤ 0)
                    (nEqualsDTimesQuotient : n = d * q) =>
                  nNotDTimesZero(
                      rewrite(
                          Natural.less_or_equal_zero_implies_equals_zero(
                              q, quotientLessOrEqualZero),
                          nEqualsDTimesQuotient)))
      }
  | successor(prevBound) =>
      cases Natural.search_quotient_witness_up_to(d, n, prevBound) {
        | Or.introduceLeft(foundEarlier) => {
            -- Found earlier: propagate, boosting the bound proof.
            obtain ⟨q, qLePrevBound, nEqualsDTimesQuotient⟩ from foundEarlier;
            Or.introduceLeft(
                witness q with
                    ⟨LessOrEqual.step(q, prevBound, qLePrevBound),
                     nEqualsDTimesQuotient⟩)
          }
        | Or.introduceRight(noneEarlier) => {
            -- Not found in [0, prevBound]: check q = successor(prevBound).
            claim (n = d * successor(prevBound)) ∨ (n ≠ d * successor(prevBound))
            claim by cases {
              in (n = d * successor(prevBound)) as nEqualsDTimesSuccessorPrevious:
                  Or.introduceLeft(
                      Exists.introduce(
                          successor(prevBound),
                          And.introduction(
                              LessOrEqual.reflexivity(
                                  successor(prevBound)),
                              nEqualsDTimesSuccessorPrevious)))
              in (n ≠ d * successor(prevBound)) as nNotDTimesSuccessorPrevious:
                  Or.introduceRight(
                      function (q : Natural)
                          (quotientLessOrEqualSuccessorPrevious :
                              q ≤ successor(prevBound))
                          (nEqualsDTimesQuotient : n = d * q) => {
                            -- q ≤ successor(prevBound): either q = successor(prevBound)
                            -- (contradicts nNotDTimesSuccessorPrevious) or q ≤ prevBound
                            -- (contradicts noneEarlier).
                            claim (q = successor(prevBound))
                                  ∨ (∃ (bPredecessor : Natural). successor(prevBound) =
                                                  successor(bPredecessor) ∧ q ≤ bPredecessor)
                                by LessOrEqual.invert(
                                       q, successor(prevBound),
                                       quotientLessOrEqualSuccessorPrevious)
                            claim by cases {
                              in (q = successor(prevBound)) as quotientEqualsSuccessorPrevious:
                                  nNotDTimesSuccessorPrevious(
                                      rewrite(
                                          quotientEqualsSuccessorPrevious,
                                          nEqualsDTimesQuotient))
                              in (∃ (bPredecessor : Natural). successor(prevBound) =
                                                  successor(bPredecessor) ∧ q ≤ bPredecessor) as existsProof: {
                                  obtain ⟨bPredecessor, successorEquals,
                                          quotientLessOrEqualBPredecessor⟩
                                      from existsProof;
                                  noneEarlier(
                                      q,
                                      rewrite(
                                          Equality.symmetry(
                                              Natural.successor_injective(
                                                  prevBound,
                                                  bPredecessor,
                                                  successorEquals)),
                                          quotientLessOrEqualBPredecessor),
                                      nEqualsDTimesQuotient)
                              }
                            }
                          })
            }
          }
      }

-- Decidable divisibility on Natural. For d = 0, dispatches via
-- decides_equality(n, 0). For d = successor(dPredecessor), runs the bounded search
-- at bound = n; the "not found" branch combines with the cap lemma
-- to rule out any q (because q > n would force d·q > n).
theorem Natural.decides_divides
        : (d n : Natural)
          → d ∣ n ∨ d ∤ n
  | zero, n =>
      claim (n = 0) ∨ (n ≠ 0)
      claim by cases {
        in (n = 0) as nEqualsZero:
            -- 0 ∣ n with witness q = 0: 0 · 0 = 0 = n.
            Or.introduceLeft(⟨0, nEqualsZero⟩)
        in (n ≠ 0) as nNotEqualZero:
            -- A divisibility witness would give n = 0 · q = 0,
            -- contradicting nNotEqualZero.
            Or.introduceRight(function (divProof : 0 ∣ n) => {
              obtain ⟨q, nEqMulZeroQ⟩ from divProof;
              nNotEqualZero(nEqMulZeroQ)
            })
      }
  | successor(predD), n =>
      claim (∃ (q : Natural). q ≤ n ∧ n = successor(predD) * q)
          ∨ ((q : Natural) → q ≤ n → n ≠ successor(predD) * q)
          by Natural.search_quotient_witness_up_to(
                 successor(predD), n, n)
      claim by cases {
        in (∃ (q : Natural). q ≤ n ∧ n = successor(predD) * q)
            as foundWitness:
            -- Witness found; that's the divisor.
            { obtain ⟨q, _, nEqualsDTimesQuotient⟩ from foundWitness;
              Or.introduceLeft(⟨q, nEqualsDTimesQuotient⟩) }
        in ((q : Natural) → q ≤ n → n ≠ successor(predD) * q)
            as noQuotientInRange:
            -- A divisibility witness gives some q with n = d · q.
            -- The cap lemma forces q ≤ d · q = n; then
            -- noQuotientInRange contradicts.
            Or.introduceRight(
                function (divProof : successor(predD) ∣ n) => {
              obtain ⟨q, nEqualsDTimesQuotient⟩ from divProof;
              claim qLeN : q ≤ n
                  by rewrite(
                         Equality.symmetry(nEqualsDTimesQuotient),
                         Natural.le_q_d_mult_q(
                             successor(predD), q,
                             Natural.successor_less_or_equal_successor(
                                 0, predD,
                                 Natural.zero_least(predD))));
              noQuotientInRange(q, qLeN, nEqualsDTimesQuotient)
            })
      }

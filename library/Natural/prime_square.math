-- Natural/prime_square.math
--
-- A factorization fact about prime squares used by the Gaussian-integer
-- sum-of-two-squares descent: if a·b = p² with p prime and both factors
-- at least 2, then a = p. (p divides one factor; the other is then a
-- divisor of p forced up to p, and cancelling p pins the first factor.)

module Natural.prime_square

import Logic.basics
import Logic.sum
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.order
import Natural.add_order
import Natural.cancellation
import Natural.divisibility
import Natural.prime
import Natural.prime_divides_product

theorem Natural.prime_square_factor (p a b : Natural)
        (primality : Natural.is_prime(p))
        (aAtLeastTwo : 2 ≤ a) (bAtLeastTwo : 2 ≤ b)
        (product : a * b = p * p)
        : a = p := {
  let ⟨pAtLeastTwo, divisorClause⟩ := primality;
  1 ≤ p by Natural.is_prime.positive;
  p ∣ a * b;
  (p ∣ a) ∨ (p ∣ b) by Natural.prime_divides_product;
  done by cases {
    case p ∣ a as pDividesA: {
        choose k such that a = p * k from pDividesA;
        p * p = a * b = (p * k) * b = p * (k * b);
        p = k * b;
        b ∣ p by ⟨k, { p = k * b = b * k }⟩;
        b = 1 ∨ b = p;
        done by cases {
          case b = 1 as bEqualOne: {
              2 ≤ 1 by substituting bEqualOne;
              False;
              done
            }
          case b = p as bEqualP: {
              (1 : Natural) * p = p = k * b = k * p;
              1 = k by Natural.multiply_cancel_right;
              a = p * k = p * 1 = p
            }
        }
      }
    case p ∣ b as pDividesB: {
        choose k such that b = p * k from pDividesB;
        p * p = a * b = a * (p * k) = p * (a * k);
        p = a * k;
        a ∣ p;
        a = 1 ∨ a = p;
        done by cases {
          case a = 1 as aEqualOne: {
              2 ≤ 1 by substituting aEqualOne;
              False;
              done
            }
          case a = p as aEqualP: aEqualP
        }
      }
  }
}

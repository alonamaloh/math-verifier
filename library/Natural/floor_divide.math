-- Natural/floor_divide.math
--
-- Floor `Natural → Natural → Natural` division and modulo functions
-- via fuel-based recursion. (`Natural.divide` is the honest ℚ-valued
-- division, defined above ℚ in Rational/natural_division.math.) Pattern-matches on `Natural.monus(p, n)`
-- (a Natural) to decide "does p fit in n?" — Type-safe case analysis
-- on a Natural rather than on a Proposition proof. With fuel = n,
-- the result is correct for any (p, n) with p ≥ 1 (since each
-- iteration strips at least one p from n, and n iterations are
-- always enough).
--
-- Argument order and edge conventions match Lean's `Nat.div`/`Nat.mod`
-- (PLAN_KERNEL_EXPORT Stage 1): `floor_divide(dividend, divisor)`,
-- `floor_divide(n, 0) = 0`, `modulo(n, 0) = n`.

module Natural.floor_divide

import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.monus
import Natural.divisibility
import Logic.exists

-- floor_divide_step(fuel, divisor, dividend): fuel-bounded floor division.
-- Fuel first so the structural recursion is on it. The Pi-binder
-- names are user-facing for named-argument calls from outside the
-- recursion. (Recursive calls inside the pattern body use positional
-- args because the elaborator's induction-hypothesis handling doesn't
-- expose the parameter names.)
--
-- The recursions live at the raw floor; the arm bodies call the PUBLIC
-- `Natural.monus` so the reducts keep the spelling the characterising
-- proofs below substitute along. The wrappers are `opaque`: downstream
-- proofs reason through the characterising lemmas (`*_zero_fuel`,
-- `*_succ_fits`, `*_succ_too_big`) rather than letting the kernel
-- reduce through a fully concrete fuel/dividend.
-- Pick `ifZero` when the overshoot `monus(divisor, dividend)` is zero (i.e.
-- divisor ≤ dividend), else `ifSuccessor`. Pattern-matching the overshoot
-- ARGUMENT keeps the step functions free of a `cases` on the computed `monus`,
-- while the characterising lemmas still ι-reduce: `substituting` the overshoot
-- to `0` / `successor(_)` selects the matching arm. Both branches are formed
-- eagerly; the recursive call discarded in the too-big case is on strictly
-- smaller fuel, so the recursion stays structural.
definition Natural.Raw.select_on_zero
        : (overshoot ifZero ifSuccessor : Natural.Raw) → Natural.Raw
  | zero,         ifZero, _           => ifZero
  | successor(_), _,      ifSuccessor => ifSuccessor

definition Natural.Raw.floor_divide_step
        : (fuel divisor dividend : Natural.Raw) → Natural.Raw
  | zero,            _,       _        => Natural.Raw.zero
  | successor(fuel), divisor, dividend =>
      unfold Natural in
      Natural.Raw.select_on_zero(
          Natural.monus(divisor, dividend),
          -- divisor ≤ dividend: recurse with dividend - divisor, count one more.
          successor(
              Natural.Raw.floor_divide_step(
                  fuel, divisor, Natural.monus(dividend, divisor))),
          -- divisor > dividend: stop.
          0)

opaque definition Natural.floor_divide_step
        : (fuel divisor dividend : Natural) → Natural :=
  unfold Natural in Natural.Raw.floor_divide_step

definition Natural.Raw.modulo_step
        : (fuel divisor dividend : Natural.Raw) → Natural.Raw
  | zero,            _,       dividend => dividend
  | successor(fuel), divisor, dividend =>
      unfold Natural in
      Natural.Raw.select_on_zero(
          Natural.monus(divisor, dividend),
          -- divisor ≤ dividend: carry on with dividend - divisor.
          Natural.Raw.modulo_step(
              fuel, divisor, Natural.monus(dividend, divisor)),
          -- divisor > dividend: the remainder is the dividend.
          dividend)

opaque definition Natural.modulo_step
        : (fuel divisor dividend : Natural) → Natural :=
  unfold Natural in Natural.Raw.modulo_step

-- Top-level functions in Lean's argument order (dividend, divisor),
-- with fuel = dividend (always enough since each iteration reduces the
-- dividend by at least 1 when divisor ≥ 1). Division by zero is 0 by
-- an explicit `cases` guard — the fuel recursion would otherwise count
-- the fuel out and return the dividend; modulo needs no guard because
-- carrying the dividend is exactly Lean's `n % 0 = n`.
--
-- These are `opaque`: the fuel-threaded `*_step` machinery is an
-- implementation detail that callers should never see. Downstream code
-- reasons about divide/modulo only through their user-facing lemmas
-- (`floor_divide_modulo_decompose`, `modulo_bound`, `divides_implies_modulo_zero`,
-- `modulo_zero_implies_divides`); the `unfold` that bridges to the `*_step`
-- lemmas is confined to those theorems here.
opaque definition Natural.floor_divide (dividend : Natural) : Natural → Natural
  | zero => 0
  | successor(predecessor) =>
      Natural.floor_divide_step(
          fuel := dividend, divisor := successor(predecessor), dividend := dividend)

opaque definition Natural.modulo (dividend divisor : Natural) : Natural :=
  Natural.modulo_step(
      fuel := dividend, divisor := divisor, dividend := dividend)

-- ----------------------------------------------------------------------
-- Recursive characterization at the step level.

-- ----------------------------------------------------------------------
-- Characterising lemmas for the opaque step functions. Each uses
-- `unfold` to peek at the body and prove a single equation —
-- downstream proofs use these lemmas, never reflexivity directly.

-- Zero fuel: both step functions return their non-recursing branch.
theorem Natural.floor_divide_step_zero_fuel (p n : Natural)
        : Natural.floor_divide_step(0, p, n) = 0 :=
  done by unfolding Natural.floor_divide_step

theorem Natural.modulo_step_zero_fuel (p n : Natural)
        : Natural.modulo_step(0, p, n) = n :=
  done by unfolding Natural.modulo_step

-- Successor fuel, p ≤ n (monus(p, n) = 0): strip one p and recurse.
-- Unfolding `floor_divide_step` exposes a `cases monus(p, n) { … }`;
-- substituting along `pFits` makes the scrutinee `0`, selecting the
-- zero arm and closing the goal via ι-reduction.
theorem Natural.floor_divide_step_succ_fits
        (fuel p n : Natural)
        (pFits : Natural.monus(p, n) = 0)
        : Natural.floor_divide_step(successor(fuel), p, n)
          = successor(Natural.floor_divide_step(fuel, p, Natural.monus(n, p))) :=
  done by substituting pFits unfolding Natural.floor_divide_step, Natural

theorem Natural.modulo_step_succ_fits
        (fuel p n : Natural)
        (pFits : Natural.monus(p, n) = 0)
        : Natural.modulo_step(successor(fuel), p, n)
          = Natural.modulo_step(fuel, p, Natural.monus(n, p)) :=
  done by substituting pFits unfolding Natural.modulo_step, Natural

-- Successor fuel, p > n (monus(p, n) = successor(predM)): no
-- recursion; divide returns 0, modulo carries n. Substituting along
-- `pTooBig` selects the `successor(_)` arm.
theorem Natural.floor_divide_step_succ_too_big
        (fuel p n predM : Natural)
        (pTooBig : Natural.monus(p, n) = successor(predM))
        : Natural.floor_divide_step(successor(fuel), p, n) = 0 :=
  done by substituting pTooBig unfolding Natural.floor_divide_step, Natural

theorem Natural.modulo_step_succ_too_big
        (fuel p n predM : Natural)
        (pTooBig : Natural.monus(p, n) = successor(predM))
        : Natural.modulo_step(successor(fuel), p, n) = n :=
  done by substituting pTooBig unfolding Natural.modulo_step, Natural

-- ----------------------------------------------------------------------
-- The division-by-zero conventions, aligned with Lean's `Nat.div`/`Nat.mod`:
-- n / 0 = 0 (the `cases` guard) and n % 0 = n (a zero divisor always
-- "fits", so the step recursion carries the dividend until the fuel
-- runs out).

theorem Natural.floor_divide_zero_divisor (n : Natural)
        : Natural.floor_divide(n, 0) = 0 :=
  done by unfolding Natural.floor_divide

theorem Natural.modulo_step_zero_divisor (fuel : Natural)
        : ∀ (n : Natural). Natural.modulo_step(fuel, 0, n) = n :=
  by induction on fuel with IH {
    case zero: {
        take n : Natural;
        done
      }
    case successor(f): {
        take n : Natural;
        Natural.monus(0, n) = 0;
        Natural.modulo_step(successor(f), 0, n)
           = Natural.modulo_step(f, 0, Natural.monus(n, 0))
           = Natural.modulo_step(f, 0, n)
           = n   by IH(n)
      }
  }

theorem Natural.modulo_zero_divisor (n : Natural)
        : Natural.modulo(n, 0) = n :=
  done by Natural.modulo_step_zero_divisor unfolding Natural.modulo

-- ----------------------------------------------------------------------
-- Divide/modulo correctness: divisor * divide + modulo = dividend.
-- Holds unconditionally on fuel: when fuel is exhausted, divide=0 and
-- modulo carries the unprocessed dividend, so 0*divisor + dividend = dividend.

-- Helper: divisor ≤ dividend (i.e., monus(divisor, dividend) = 0)
-- means dividend = divisor + (dividend - divisor) (using monus).
-- Single-pattern on divisor; nested case on dividend with a dependent
-- motive so the kernel reduces monus through both constructor matches.
theorem Natural.monus_zero_implies_decompose (divisor : Natural)
        : ∀ (dividend : Natural).
          Natural.monus(divisor, dividend) = 0
          → dividend = divisor + Natural.monus(dividend, divisor) :=
  unfold Natural.add, Natural in
  by induction on divisor with IH {
    case zero: {
        take dividend : Natural;
        suppose Natural.monus(0, dividend) = 0;
        -- divisor = 0: dividend = 0 + monus(dividend, 0) = 0 + dividend.
        dividend
           = 0 + Natural.monus(dividend, 0)
      }
    case successor(predDivisor): {
        take dividend : Natural;
        suppose Natural.monus(successor(predDivisor), dividend) = 0
            as monusEqZero;
        done by cases {
          case dividend = 0: {
              -- monus(succ _, 0) = succ _, so succ(predDivisor) = 0, absurd.
              successor(predDivisor) = 0 as succEqZero;
              absurd(succEqZero)
            }
          case dividend = successor(predDividend) for some predDividend: {
              -- Peel via monus_succ_succ so the IH applies to the inner
              -- monus(predDivisor, predDividend).
              Natural.monus(predDivisor, predDividend) = 0 as innerMonusZero;
              successor(predDividend)
                 = successor(predDivisor
                             + Natural.monus(predDividend, predDivisor))
                        by IH(predDividend, innerMonusZero)
                 = successor(predDivisor)
                       + Natural.monus(successor(predDividend),
                                        successor(predDivisor))
            }
        }
      }
  }

-- Main correctness: divisor * floor_divide_step(fuel, divisor, dividend)
-- + modulo_step(fuel, divisor, dividend) = dividend. Induct on fuel.
theorem Natural.floor_divide_modulo_step_decompose (fuel : Natural)
        : ∀ (divisor dividend : Natural).
          divisor * Natural.floor_divide_step(fuel, divisor, dividend)
                + Natural.modulo_step(fuel, divisor, dividend)
            = dividend :=
  by induction on fuel with IH {
    case zero: {
        take divisor : Natural;
        take dividend : Natural;
        -- Zero fuel: floor_divide_step returns 0, modulo_step carries the dividend.
        divisor * Natural.floor_divide_step(0, divisor, dividend)
                 + Natural.modulo_step(0, divisor, dividend)
           = divisor * 0 + dividend
           = dividend
      }
    case successor(fuel): {
        take divisor : Natural;
        take dividend : Natural;
        done by cases {
          case Natural.monus(divisor, dividend) = 0 as monusEq:
              -- divisor ≤ dividend: floor_divide_step / modulo_step reduce via
              -- *_succ_fits (monusEq supplies their precondition), then the
              -- induction hypothesis decomposes the recursive remainder.
              divisor
                       * Natural.floor_divide_step(
                             successor(fuel), divisor, dividend)
                   + Natural.modulo_step(
                             successor(fuel), divisor, dividend)
                 = divisor
                       * successor(Natural.floor_divide_step(
                             fuel, divisor, Natural.monus(dividend, divisor)))
                   + Natural.modulo_step(
                             fuel, divisor, Natural.monus(dividend, divisor))
                 = divisor
                   + (divisor
                        * Natural.floor_divide_step(
                              fuel, divisor, Natural.monus(dividend, divisor))
                      + Natural.modulo_step(
                            fuel, divisor, Natural.monus(dividend, divisor)))
                 = divisor + Natural.monus(dividend, divisor)
                         by IH(divisor, Natural.monus(dividend, divisor))
                 = dividend
          case Natural.monus(divisor, dividend) = successor(predM)
                 for some (predM : Natural) as monusEq:
              -- divisor > dividend: floor_divide_step returns 0 and modulo_step
              -- carries the dividend, via *_succ_too_big (monusEq, predM).
              divisor
                       * Natural.floor_divide_step(
                             successor(fuel), divisor, dividend)
                   + Natural.modulo_step(
                             successor(fuel), divisor, dividend)
                 = divisor * 0 + dividend
                 = dividend
        }
      }
  }

-- Top-level decomposition: divisor * divide(n, d) + modulo(n, d) = n.
-- A zero divisor contributes nothing and the remainder carries the
-- whole dividend; a positive divisor ι-reduces past the `cases` guard
-- to the step functions, where the fuel-level decomposition applies.
theorem Natural.floor_divide_modulo_decompose (dividend divisor : Natural)
        : divisor * Natural.floor_divide(dividend, divisor)
              + Natural.modulo(dividend, divisor)
          = dividend :=
  done by cases {
    case divisor = 0: {
        0 * Natural.floor_divide(dividend, 0) + Natural.modulo(dividend, 0)
           = 0 * Natural.floor_divide(dividend, 0) + dividend
           = dividend
      }
    case divisor = successor(k) for some k:
        done by Natural.floor_divide_modulo_step_decompose
             unfolding Natural.floor_divide, Natural.modulo
  }

-- ----------------------------------------------------------------------
-- Connection to Natural.divides.

-- ----------------------------------------------------------------------
-- modulo bound and related fuel monotonicity.

-- monus(n, d) ≤ n. Truncated subtraction can only decrease. With
-- monus opaque, we bridge via the characterising lemmas to align
-- the kernel goal type with the in-hand proof.
automatic theorem Natural.monus_le_self (n : Natural)
        : ∀ (d : Natural). Natural.monus(n, d) ≤ n :=
  unfold Natural.add, Natural in
  by induction on n with IH {
    case zero: {
        take d : Natural;
        Natural.monus(0, d)
           = 0
           ≤ 0
      }
    case successor(k): {
        take d : Natural;
        done by cases {
          case d = 0:
              Natural.monus(successor(k), 0)
                 = successor(k)
                 ≤ successor(k)
          case d = successor(j) for some j:
              Natural.monus(successor(k), successor(j))
                 = Natural.monus(k, j)
                 ≤ k   by IH(j)
                 ≤ successor(k)
        }
      }
  }

-- Helper: if monus(d, n) = succ(predM), then succ(n) ≤ d.
theorem Natural.monus_succ_implies_gt (d : Natural)
        : ∀ (n predM : Natural).
          Natural.monus(d, n) = successor(predM)
          → successor(n) ≤ d :=
  unfold Natural.add, Natural in
  by induction on d with IH {
    case zero: {
        take n : Natural;
        take predM : Natural;
        suppose Natural.monus(0, n) = successor(predM) as monusEq;
        -- monus(0, n) = 0 ≠ successor(predM).
        successor(predM)
           = Natural.monus(0, n)
           = 0;
        False;
        done
      }
    case successor(d'): {
        take n : Natural;
        take predM : Natural;
        suppose Natural.monus(successor(d'), n) = successor(predM) as monusEq;
        done by cases {
          case n = 0: {
              0 ≤ d';
              successor(0) ≤ successor(d')
            }
          case n = successor(k) for some k: {
              Natural.monus(d', k) = successor(predM);
              successor(k) ≤ d';
              successor(successor(k)) ≤ successor(d')
            }
        }
      }
  }

-- Step bound: modulo_step(fuel, d, n) < d when d ≥ 1 and fuel ≥ n.
-- Induction on fuel.
theorem Natural.modulo_step_lt_divisor (fuel : Natural)
        : ∀ (d n : Natural).
          successor(0) ≤ d
          → successor(n) ≤ successor(fuel)
          → successor(Natural.modulo_step(fuel, d, n)) ≤ d :=
  by induction on fuel with IH {
    case zero: {
        take d : Natural;
        take n : Natural;
        suppose successor(0) ≤ d as dPositive;
        suppose successor(n) ≤ successor(0) as nLeFuel;
        -- fuel = 0 forces n = 0; modulo_step(0, d, 0) = 0, so the goal is
        -- successor(0) ≤ d, which is dPositive.
        n ≤ 0;
        n = 0;
        successor(Natural.modulo_step(0, d, n))
           = successor(0)
           ≤ d
      }
    case successor(f): {
        take d : Natural;
        take n : Natural;
        suppose successor(0) ≤ d as dPositive;
        suppose successor(n) ≤ successor(successor(f)) as nLeSuccFuel;
        done by cases {
          case Natural.monus(d, n) = 0 as monusEq: {
              -- d ≤ n: modulo_step(succ(f), d, n) = modulo_step(f, d, n - d).
              -- The fuel bound succ(n - d) ≤ succ(f) holds since n - d ≤ n - 1
              -- ≤ f; case-split on d (positive) and n to peel the monus.
              successor(Natural.monus(n, d)) ≤ successor(f)
                  by cases on d {
                    case zero: absurd(dPositive)
                    case successor(predD):
                        done by cases on n {
                            case zero:
                                successor(
                                    Natural.monus(0, successor(predD)))
                                   = successor(0)
                                   ≤ successor(f)
                            case successor(k):
                                successor(
                                    Natural.monus(successor(k),
                                                  successor(predD)))
                                   = successor(Natural.monus(k, predD))
                                   ≤ successor(k)
                                   ≤ successor(f)
                        }
                } as monusBoundedByFuel;
              successor(Natural.modulo_step(successor(f), d, n))
                 = successor(Natural.modulo_step(f, d, Natural.monus(n, d)))
                 ≤ d   by IH(d, Natural.monus(n, d), dPositive, monusBoundedByFuel)
          }
          case Natural.monus(d, n) = successor(predM)
                 for some (predM : Natural) as monusEq:
              -- d > n: modulo_step returns n and monus_succ_implies_gt gives
              -- succ(n) ≤ d directly.
              successor(Natural.modulo_step(successor(f), d, n))
                 = successor(n)
                 ≤ d
        }
      }
  }


-- Top-level: modulo(n, d) < d for d ≥ 1.
theorem Natural.modulo_bound
        (dividend divisor : Natural)
        (divisorPositive : successor(0) ≤ divisor)
        : successor(Natural.modulo(dividend, divisor)) ≤ divisor :=
  done by Natural.modulo_step_lt_divisor unfolding Natural.modulo

-- The remainder is strictly below a nonzero divisor. This is the decrease
-- witness a Euclidean recursion needs (`gcd(a, b) = gcd(b, a mod b)
-- decreasing b`): the second argument strictly shrinks. The `divisor ≠ 0`
-- premise is exactly the negation the `else` branch of the guard `b = 0`
-- supplies, so the obligation closes with no case split. Marked `automatic`
-- so it discharges unprompted.
automatic theorem Natural.modulo_lt
        (dividend divisor : Natural)
        (divisorNonzero : divisor ≠ 0)
        : Natural.modulo(dividend, divisor) < divisor := {
  1 ≤ divisor by Natural.one_le_of_nonzero;
  Natural.modulo(dividend, divisor) + 1 ≤ divisor by Natural.modulo_bound;
  done by Natural.lt_of_add_one_le
}

-- ----------------------------------------------------------------------
-- Reverse direction: if d | n (i.e., n = d * q), then modulo(d, n) = 0.

-- Helper: monus(a + b, a) = b. Subtracting `a` from `a + b` gives `b`.
theorem Natural.monus_add_cancel (a : Natural)
        : ∀ (b : Natural). Natural.monus(a + b, a) = b :=
  unfold Natural.add, Natural in
  by induction on a with IH {
    case zero: {
        take b : Natural;
        done
      }
    case successor(k): {
        take b : Natural;
        Natural.monus(successor(k) + b, successor(k))
           = b
      }
  }

-- Helper: monus(d, d + m) = 0 (d ≤ d + m, so subtraction is zero).
theorem Natural.monus_self_plus (d : Natural)
        : ∀ (m : Natural). Natural.monus(d, d + m) = 0 :=
  unfold Natural.add, Natural in
  by induction on d with IH {
    case zero: {
        take m : Natural;
        done
      }
    case successor(k): {
        take m : Natural;
        Natural.monus(successor(k), successor(k) + m)
           = Natural.monus(k, k + m)
           = 0 by IH(m)
      }
  }

-- Step-level: modulo_step(fuel, d, d * q) = 0 when d ≥ 1 and fuel ≥ q.
theorem Natural.modulo_step_at_multiple (q : Natural)
        : ∀ (fuel d : Natural).
          successor(0) ≤ d → successor(q) ≤ successor(fuel)
          → Natural.modulo_step(fuel, d, d * q) = 0 :=
  by induction on q with IH {
    case zero: {
        take fuel : Natural;
        take d : Natural;
        suppose successor(0) ≤ d as dPositive;
        suppose successor(0) ≤ successor(fuel) as _;
        -- d * 0 = 0, so the goal reduces to modulo_step(fuel, d, 0) = 0.
        -- Either fuel is exhausted (zero-fuel lemma) or d = succ(predD) makes
        -- monus(d, 0) positive, sending modulo_step to its "too big" branch.
        Natural.modulo_step(fuel, d, 0) = 0
            by cases on fuel {
              case zero: done
              case successor(f):
                  done by cases {
                    case d = 0 as dZero: {
                        successor(0)
                           ≤ d
                           = 0;
                        False; done
                      }
                    case d = successor(predD) for some predD: {
                        Natural.monus(successor(predD), 0) = successor(predD);
                        done
                      }
                  }
            };
        Natural.modulo_step(fuel, d, d * 0)
           = Natural.modulo_step(fuel, d, 0)
           = 0
      }
    case successor(q'): {
        take fuel : Natural;
        take d : Natural;
        suppose successor(0) ≤ d as dPositive;
        suppose successor(successor(q')) ≤ successor(fuel) as succQLeSuccFuel;
        -- d * succ(q') = d + d*q'. For d ≥ 1, monus(d, d + d*q') = 0, so the
        -- "fits" branch peels one d: modulo_step(f, d, monus(d + d*q', d)) =
        -- modulo_step(f, d, d*q'), which the induction hypothesis sends to 0.
        done by cases {
          case fuel = 0: {
              successor(q') ≤ 0 as succQLeZero;
              absurd(succQLeZero)
            }
          case fuel = successor(f) for some f: {
              successor(q') ≤ successor(f) as succQLeFuel;
              Natural.monus(d, d + d * q') = 0;
              Natural.modulo_step(successor(f), d, d * successor(q'))
                 = Natural.modulo_step(successor(f), d, d + d * q')
                 = Natural.modulo_step(f, d, Natural.monus(d + d * q', d))
                 = Natural.modulo_step(f, d, d * q')
                 = 0   by IH(f, d, dPositive, succQLeFuel)
            }
        }
      }
  }

-- Top-level: if d | n, then modulo(n, d) = 0.
theorem Natural.divides_implies_modulo_zero
        (dividend divisor : Natural)
        (divisorPositive : successor(0) ≤ divisor)
        (dividesProof : Natural.divides(divisor, dividend))
        : Natural.modulo(dividend, divisor) = 0 :=
  unfold Natural.modulo in {
  choose q such that dividend = divisor * q from dividesProof;
  -- With dividend = divisor * q, modulo(divisor*q, divisor) is a multiple,
  -- which modulo_step_at_multiple sends to 0. Its fuel premise
  -- succ(q) ≤ succ(divisor*q) follows from q ≤ divisor*q (divisor ≥ 1).
  Natural.monus(successor(0), divisor) = 0;
  q
     = successor(0) * q
     ≤ successor(0) * q + Natural.monus(divisor, successor(0)) * q
     = (successor(0) + Natural.monus(divisor, successor(0))) * q
     = divisor * q;
  successor(q) ≤ successor(divisor * q);
  Natural.modulo(dividend, divisor)
     = Natural.modulo(divisor * q, divisor)
     = 0   by Natural.modulo_step_at_multiple
}

-- If modulo(n, d) = 0, then d divides n. The decomposition gives
-- d * divide(n, d) + 0 = n, i.e., n = d * divide(n, d).
theorem Natural.modulo_zero_implies_divides
        (dividend divisor : Natural)
        (moduloZero : Natural.modulo(dividend, divisor) = 0)
        : Natural.divides(divisor, dividend) :=
  witness Natural.floor_divide(dividend, divisor) with
      dividend
         = divisor * Natural.floor_divide(dividend, divisor)
               + Natural.modulo(dividend, divisor)
         = divisor * Natural.floor_divide(dividend, divisor) + 0
         = divisor * Natural.floor_divide(dividend, divisor)

-- Natural/gcd.math
--
-- Greatest common divisor of two naturals, characterised via the
-- divisibility lattice: `is_gcd(g, a, b)` says g is a common divisor
-- of a and b that every common divisor of a and b divides. This is
-- the universal-property style — no need to fix a "canonical
-- algorithm" up front.
--
-- Existence of a gcd for every (a, b) is settled in
-- Natural/euclidean_algorithm.math, where `Natural.gcd` is the honest
-- recursive function and `gcd_is_gcd : is_gcd(gcd(a, b), a, b)` connects it
-- to the predicate here. (Bezout, chapter F-4, additionally exhibits the
-- gcd as an integer linear combination.)

module Natural.gcd

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.divisibility

-- Common-divisor predicate: g divides both a and b, and any common
-- divisor of (a, b) divides g.
definition Natural.is_gcd (g a b : Natural) : Proposition :=
  g ∣ a
  ∧ g ∣ b
  ∧ (∀ (d : Natural). d ∣ a → d ∣ b → d ∣ g)

-- Symmetry: gcd of (a, b) is also gcd of (b, a). Trivial reshuffle of
-- the three components.
theorem Natural.is_gcd_symmetric (g a b : Natural)
        (gcdProof : Natural.is_gcd(g, a, b))
        : Natural.is_gcd(g, b, a) := {
  -- the three legs of `gcdProof`, with the two arguments swapped throughout.
  g ∣ b;
  g ∣ a;
  ∀ (d : Natural). d ∣ a → d ∣ b → d ∣ g as universalProperty;
  ∀ (d : Natural). d ∣ b → d ∣ a → d ∣ g by {
    take d : Natural;
    suppose d ∣ b as dDividesB;
    suppose d ∣ a as dDividesA;
    universalProperty(d, dDividesA, dDividesB)
  };
  done
}

theorem Natural.is_gcd_zero_left (b : Natural)
        : Natural.is_gcd(b, 0, b) := {
  b ∣ 0;
  b ∣ b;
  ∀ (d : Natural). d ∣ 0 → d ∣ b → d ∣ b by {
    take d : Natural;
    suppose d ∣ 0 as _;
    suppose d ∣ b as dDividesB;
    dDividesB
  };
  done
}

theorem Natural.is_gcd_zero_right (a : Natural)
        : Natural.is_gcd(a, a, 0) := {
  a ∣ a;
  a ∣ 0;
  ∀ (d : Natural). d ∣ a → d ∣ 0 → d ∣ a by {
    take d : Natural;
    suppose d ∣ a as dDividesA;
    suppose d ∣ 0 as _;
    dDividesA
  };
  done
}

theorem Natural.is_gcd_one_right (a : Natural)
        : Natural.is_gcd(1, a, 1) := {
  1 ∣ a by Natural.one_divides;
  1 ∣ 1;
  ∀ (d : Natural). d ∣ a → d ∣ 1 → d ∣ 1 by {
    take d : Natural;
    suppose d ∣ a as _;
    suppose d ∣ 1 as dDividesOne;
    dDividesOne
  };
  done
}

-- Natural/strong_recursion.math
--
-- Proves Natural.strong_induction from the ordinary recursor. The
-- derivation goes through three small lemmas:
--
--   1. LessOrEqual.invert (a "view" theorem): every `s ≤ b`
--      is either `s = b` (reflexivity case) or `b = successor(bPredecessor) ∧ s ≤ bPredecessor`
--      for some `bPredecessor` (step case).
--   2. Natural.not_less_or_equal_successor_zero: `successor(k) ≰ zero`.
--      Both reflexivity and step cases lead to `successor(_) = zero`, which
--      Natural.successor_not_zero rules out.
--   3. The "below" predicate `for_all_below n` asserts P holds for every
--      k with `successor(k) ≤ n`. Build it by ordinary induction on n, using
--      (1) to decompose `successor(k) ≤ successor(m)` and (2) to reject
--      `successor(k) ≤ 0`.
--
-- Then `strong_induction` applies `step` to `for_all_below n`, bridging the
-- caller's `<`-step to the `successor ≤` form through `successor_le_of_lt`.

module Natural.strong_recursion

import Natural.basics
import Natural.arithmetic
import Natural.one_plus_induction
import Natural.order
import Natural.peano
import Equality.basics
import Logic.basics
import Logic.exists

-- View lemma: any `s ≤ b` is either an equality or has an upper bound that
-- is `successor` of something. With `≤` now `< ∨ =`, the equality case is
-- the right disjunct directly; the strict case turns its witness `c`
-- (`s + (1 + c) = b`) into `b = successor(s + c)` with `s ≤ s + c`.
theorem LessOrEqual.invert (s b : Natural)
        : s ≤ b
          → s = b ∨ ∃ (bPredecessor : Natural). b = successor(bPredecessor) ∧ s ≤ bPredecessor :=
  (proof : s ≤ b) ↦
    cases proof {
      | Or.introduceLeft(lessThan) => {
          choose c such that s + (1 + c) = b as equation from Natural.lt_elim;
          claim s ≤ s + c since Natural.less_or_equal_add_right;
          calc b
             = s + (1 + c)        since equation
             = successor(s + c)
             as bIsSuccessor;
          Or.introduceRight(
              witness (s + c) with
                  And.introduction(bIsSuccessor, (s ≤ s + c)))
        }
      | Or.introduceRight(equal) =>
          Or.introduceLeft(equal)
    }

-- successor(k) ≰ 0. Apply invert and discharge both disjuncts via
-- Natural.successor_not_zero.
theorem Natural.not_less_or_equal_successor_zero (k : Natural)
        : successor(k) ≤ 0 → False :=
  (impossible : successor(k) ≤ 0) ↦
    claim by cases {
      in (successor(k) = 0) as successorKEqualsZero:
          done by Natural.successor_not_zero
      in (∃ (bPredecessor : Natural). 0 = successor(bPredecessor) ∧ successor(k) ≤ bPredecessor) as existsProof: {
          choose bPredecessor such that 0 = successor(bPredecessor) ∧ successor(k) ≤ bPredecessor from existsProof;
          absurd(0 = successor(bPredecessor))
      }
    }

-- Inversion specifically for `successor(k) ≤ successor(m)`: either `k = m` or
-- `successor(k) ≤ m`. Derived from LessOrEqual.invert plus
-- successor_injective.
theorem Natural.less_or_equal_successor_successor_inversion (k m : Natural)
        : successor(k) ≤ successor(m)
          → k = m ∨ successor(k) ≤ m :=
  (successorKLessOrEqualSuccessorMProof : successor(k) ≤ successor(m)) ↦
    claim by cases {
      in (successor(k) = successor(m)) as successorKEqualsSuccessorM: {
          -- strip the successors: k = m, the left disjunct.
          claim k = m since Natural.successor_injective;
          done
        }
      in (∃ (bPredecessor : Natural). successor(m) = successor(bPredecessor) ∧ successor(k) ≤ bPredecessor) as existsProof:
          {
            choose bPredecessor such that
                successor(m) = successor(bPredecessor) ∧ successor(k) ≤ bPredecessor
                from existsProof;
            -- m = bPredecessor by injectivity; substitute it back so
            -- successor(k) ≤ bPredecessor becomes successor(k) ≤ m.
            claim mEqualsBPredecessor : m = bPredecessor
                by Natural.successor_injective;
            claim successor(k) ≤ m by substituting mEqualsBPredecessor;
            done
          }
    }

-- for_all_below n : P holds for every k with successor(k) ≤ n. Ordinary
-- induction on n.
theorem Natural.for_all_below
        (P : Natural → Proposition)
        (step : ∀ (n : Natural).
                (∀ (k : Natural).
                    successor(k) ≤ n → P(k))
                → P(n))
        (n : Natural)
        : ∀ (k : Natural). successor(k) ≤ n → P(k) :=
  by_induction on n with IH {
    case base:
        (k : Natural) (impossible : successor(k) ≤ 0) ↦
          absurd(impossible)
    case step(predecessor):
        (k : Natural)
            (successorKLessOrEqualOnePlus :
                successor(k) ≤ 1 + predecessor) ↦ {
          -- The step bound `1 + predecessor` is not defeq to
          -- `successor(predecessor)`, but the successor-form inversion lemma
          -- still applies — its premise is discharged up to `one_add`.
          claim inversionResult
                  : k = predecessor ∨ successor(k) ≤ predecessor
              since Natural.less_or_equal_successor_successor_inversion;
          cases inversionResult {
            | Or.introduceLeft(kEqualsPredecessor) =>
                -- We need P(k). step(predecessor, IH) gives P(predecessor);
                -- the diff-bridge auto-lifts via kEqualsPredecessor in scope.
                step(predecessor, IH)
            | Or.introduceRight(successorKLessOrEqualPredecessor) =>
                -- Recurse on the predecessor level via the IH.
                IH(k, successorKLessOrEqualPredecessor)
          }
        }
  }

-- q ≤ 0 forces q = 0. Apply LessOrEqual.invert and discharge the
-- step disjunct via zero_not_successor.
theorem Natural.less_or_equal_zero_implies_equals_zero (q : Natural)
        : q ≤ 0 → q = 0 :=
  (quotientLessOrEqualZero : q ≤ 0) ↦
    claim by cases {
      in (q = 0) as quotientEqualsZero:
          quotientEqualsZero
      in (∃ (bPredecessor : Natural). 0 = successor(bPredecessor) ∧ q ≤ bPredecessor) as existsProof: {
          choose bPredecessor such that 0 = successor(bPredecessor) ∧ q ≤ bPredecessor from existsProof;
          absurd(0 = successor(bPredecessor))
      }
    }

-- `successor(p) ≤ successor(otherPredecessor)` descends to
-- `p ≤ otherPredecessor`: invert to `p = otherPredecessor` or
-- `successor(p) ≤ otherPredecessor`; both yield `p ≤ otherPredecessor`.
theorem Natural.less_or_equal_successor_successor_descend
        (p otherPredecessor : Natural)
        (successorPLessOrEqualSuccessor : successor(p) ≤ successor(otherPredecessor))
        : p ≤ otherPredecessor :=
  claim by cases {
    in (p = otherPredecessor):              done
    in (successor(p) ≤ otherPredecessor):   done since Natural.less_or_equal_predecessor_less_or_equal
  }

-- Strong induction: combine for_all_below with the step at level n.
-- The public principle's interface uses `<` (sealing `successor` from
-- callers); `k < n` is defeq to the `successor(k) ≤ n` form `for_all_below`
-- is stated with, so the body — and every existing caller's `step` — type-
-- checks unchanged.
theorem Natural.strong_induction
        (P : Natural → Proposition)
        (step : ∀ (n : Natural).
                (∀ (k : Natural).
                    k < n → P(k))
                → P(n))
        (n : Natural)
        : P(n) := {
  -- `for_all_below` is stated with the `successor(k) ≤ m` step form; bridge
  -- the caller's `<`-step to it (and the `<`-result back) through
  -- `successor_le_of_lt` — `<` is no longer defeq to `successor ≤`.
  claim ∀ (m : Natural). (∀ (k : Natural). successor(k) ≤ m → P(k)) → P(m)
      by (m : Natural) (belowM : ∀ (k : Natural). successor(k) ≤ m → P(k)) ↦
          step(m, (k : Natural) (kLessThanM : k < m) ↦ {
            claim successor(k) ≤ m since Natural.successor_le_of_lt;
            belowM(k, (successor(k) ≤ m))
          });
  claim below : ∀ (k : Natural). k < n → P(k)
      by (k : Natural) (kLessThanN : k < n) ↦ {
        claim successor(k) ≤ n since Natural.successor_le_of_lt;
        done since Natural.for_all_below
      };
  step(n, below)
}

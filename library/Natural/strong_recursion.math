-- Natural/induction.math
--
-- Proves Natural.strong_induction from the ordinary recursor. The
-- derivation goes through three small lemmas:
--
--   1. LessOrEqual.invert (a "view" theorem): every `LessOrEqual(s, b)`
--      is either `s = b` (reflexivity case) or `b = successor(bPredecessor) ∧ s ≤ bPredecessor`
--      for some `bPredecessor` (step case).
--   2. Natural.not_less_or_equal_successor_zero: `Not(LessOrEqual(successor(k), zero))`.
--      Both reflexivity and step cases lead to `successor(_) = zero`, which
--      Natural.successor_not_zero rules out.
--   3. The "below" predicate `forAllBelow n` asserts P holds for every
--      k < n. Build it by ordinary induction on n, using (1) to
--      decompose `successor(k) ≤ successor(m)` and (2) to reject `successor(k) ≤ 0`.
--
-- Then `strong_induction n := step n (forAllBelow n)`.

module Natural.strong_recursion

import Natural.basics
import Natural.order
import Natural.peano
import Equality.basics
import Logic.basics
import Logic.exists

-- View lemma: any LessOrEqual proof is either an equality (reflexivity
-- constructor) or has an upper bound that is `successor` of something.
theorem LessOrEqual.invert (s b : Natural)
        : LessOrEqual(s, b)
          → Or(s = b,
                Exists(Natural, function (bPredecessor : Natural) =>
                    And(b = successor(bPredecessor),
                         LessOrEqual(s, bPredecessor))))
  | LessOrEqual.reflexivity(commonValue) =>
      Or.introduceLeft(reflexivity(commonValue))
  | LessOrEqual.step(_, bPredecessorD, subproof) =>
      Or.introduceRight(
          Exists.introduce(
              bPredecessorD,
              And.introduction(
                  reflexivity(successor(bPredecessorD)),
                  subproof)))

-- Not(successor(k) ≤ 0). Apply invert and discharge both disjuncts via
-- Natural.successor_not_zero.
theorem Natural.not_less_or_equal_successor_zero (k : Natural)
        : LessOrEqual(successor(k), zero) → False :=
  function (impossible : LessOrEqual(successor(k), zero)) =>
    Or.eliminate(
        successor(k) = zero,
        Exists(Natural, function (bPredecessor : Natural) =>
            And(zero = successor(bPredecessor),
                 LessOrEqual(successor(k), bPredecessor))),
        False,
        function (successorKEqualsZero : successor(k) = zero) =>
            Natural.successor_not_zero(k, successorKEqualsZero),
        function (existsProof : Exists(Natural,
                function (bPredecessor : Natural) =>
                    And(zero = successor(bPredecessor),
                         LessOrEqual(successor(k), bPredecessor)))) =>
            Exists.eliminate(
                Natural,
                function (bPredecessor : Natural) =>
                    And(zero = successor(bPredecessor),
                         LessOrEqual(successor(k), bPredecessor)),
                False,
                function (bPredecessor : Natural)
                    (combined : And(zero = successor(bPredecessor),
                                     LessOrEqual(successor(k),
                                                  bPredecessor))) =>
                  And.eliminate(
                      zero = successor(bPredecessor),
                      LessOrEqual(successor(k), bPredecessor),
                      False,
                      function (zeroEqualsSucc :
                              zero = successor(bPredecessor))
                          (_ : LessOrEqual(successor(k), bPredecessor)) =>
                          Natural.zero_not_successor(
                              bPredecessor, zeroEqualsSucc),
                      combined),
                existsProof),
        LessOrEqual.invert(successor(k), zero, impossible))

-- Inversion specifically for `successor(k) ≤ successor(m)`: either `k = m` or
-- `successor(k) ≤ m`. Derived from LessOrEqual.invert plus
-- successor_injective.
theorem Natural.less_or_equal_successor_successor_inversion (k m : Natural)
        : LessOrEqual(successor(k), successor(m))
          → Or(k = m, LessOrEqual(successor(k), m)) :=
  function (successorKLessOrEqualSuccessorMProof : LessOrEqual(successor(k), successor(m))) =>
    Or.eliminate(
        successor(k) = successor(m),
        Exists(Natural, function (bPredecessor : Natural) =>
            And(successor(m) = successor(bPredecessor),
                 LessOrEqual(successor(k), bPredecessor))),
        Or(k = m, LessOrEqual(successor(k), m)),
        function (successorKEqualsSuccessorM : successor(k) = successor(m)) =>
            Or.introduceLeft(
                Natural.successor_injective(k, m, successorKEqualsSuccessorM)),
        function (existsProof : Exists(Natural,
                function (bPredecessor : Natural) =>
                    And(successor(m) = successor(bPredecessor),
                         LessOrEqual(successor(k), bPredecessor)))) =>
            Exists.eliminate(
                Natural,
                function (bPredecessor : Natural) =>
                    And(successor(m) = successor(bPredecessor),
                         LessOrEqual(successor(k), bPredecessor)),
                Or(k = m, LessOrEqual(successor(k), m)),
                function (bPredecessor : Natural)
                    (combined : And(successor(m) = successor(bPredecessor),
                                     LessOrEqual(successor(k),
                                                  bPredecessor))) =>
                  And.eliminate(
                      successor(m) = successor(bPredecessor),
                      LessOrEqual(successor(k), bPredecessor),
                      Or(k = m, LessOrEqual(successor(k), m)),
                      function (successorMEqualsSuccessorBPredecessor :
                              successor(m) = successor(bPredecessor))
                          (successorKLessOrEqualBPredecessor :
                              LessOrEqual(successor(k), bPredecessor)) =>
                          -- We have m = bPredecessor by injectivity,
                          -- and successor(k) ≤ bPredecessor. Transport
                          -- successorKLessOrEqualBPredecessor along the symmetry of
                          -- successor_injective to get successor(k) ≤ m.
                          Or.introduceRight(
                              Equality.transport_proposition(
                                  Natural,
                                  function (rightEnd : Natural) =>
                                      LessOrEqual(successor(k), rightEnd),
                                  bPredecessor, m,
                                  Equality.symmetry(
                                      Natural.successor_injective(
                                          m, bPredecessor, successorMEqualsSuccessorBPredecessor)),
                                  successorKLessOrEqualBPredecessor)),
                      combined),
                existsProof),
        LessOrEqual.invert(
            successor(k), successor(m), successorKLessOrEqualSuccessorMProof))

-- forAllBelow n : for every k < n, P holds. Ordinary induction on n.
theorem Natural.for_all_below
        (P : Natural → Proposition)
        (step : (n : Natural)
                → ((k : Natural)
                    → LessOrEqual(successor(k), n) → P(k))
                → P(n))
        : (n : Natural) → (k : Natural)
          → LessOrEqual(successor(k), n) → P(k)
  | zero =>
      function (k : Natural)
          (impossible : LessOrEqual(successor(k), zero)) =>
        False.eliminate_proposition(
            P(k),
            Natural.not_less_or_equal_successor_zero(k, impossible))
  | successor(predecessor) =>
      function (k : Natural)
          (successorKLessOrEqualSuccessorM : LessOrEqual(successor(k), successor(predecessor))) =>
        Or.eliminate(
            k = predecessor,
            LessOrEqual(successor(k), predecessor),
            P(k),
            function (kEqualsPredecessor : k = predecessor) =>
                -- We need P(k). Use step(predecessor,
                -- for_all_below(predecessor)) to get P(predecessor),
                -- then transport along k = predecessor reversed.
                Equality.transport_proposition(
                    Natural,
                    P,
                    predecessor, k,
                    Equality.symmetry(kEqualsPredecessor),
                    step(predecessor,
                          Natural.for_all_below(
                              P, step, predecessor))),
            function (successorKLessOrEqualPredecessor : LessOrEqual(successor(k),
                                                   predecessor)) =>
                -- Recurse on the predecessor level: for_all_below for
                -- `predecessor` directly handles k with successor(k) ≤
                -- predecessor.
                Natural.for_all_below(
                    P, step, predecessor, k, successorKLessOrEqualPredecessor),
            Natural.less_or_equal_successor_successor_inversion(
                k, predecessor, successorKLessOrEqualSuccessorM))

-- q ≤ 0 forces q = 0. Apply LessOrEqual.invert and discharge the
-- step disjunct via zero_not_successor.
theorem Natural.less_or_equal_zero_implies_equals_zero (q : Natural)
        : LessOrEqual(q, zero) → q = zero :=
  function (quotientLessOrEqualZero : LessOrEqual(q, zero)) =>
    Or.eliminate(
        q = zero,
        Exists(Natural, function (bPredecessor : Natural) =>
            And(zero = successor(bPredecessor),
                 LessOrEqual(q, bPredecessor))),
        q = zero,
        function (quotientEqualsZero : q = zero) => quotientEqualsZero,
        function (existsProof : Exists(Natural,
                function (bPredecessor : Natural) =>
                    And(zero = successor(bPredecessor),
                         LessOrEqual(q, bPredecessor)))) =>
            Exists.eliminate(
                Natural,
                function (bPredecessor : Natural) =>
                    And(zero = successor(bPredecessor),
                         LessOrEqual(q, bPredecessor)),
                q = zero,
                function (bPredecessor : Natural)
                    (combined : And(zero = successor(bPredecessor),
                                     LessOrEqual(q, bPredecessor))) =>
                  And.eliminate(
                      zero = successor(bPredecessor),
                      LessOrEqual(q, bPredecessor),
                      q = zero,
                      function (zeroEqualsSuccessor :
                              zero = successor(bPredecessor))
                          (_ : LessOrEqual(q, bPredecessor)) =>
                          False.eliminate_proposition(
                              q = zero,
                              Natural.zero_not_successor(
                                  bPredecessor, zeroEqualsSuccessor)),
                      combined),
                existsProof),
        LessOrEqual.invert(q, zero, quotientLessOrEqualZero))

-- Inversion of `successor(p) ≤ successor(otherPredecessor)`: yields `p ≤ otherPredecessor`. Combines
-- le_succ_succ_inversion with le_predecessor_le.
theorem Natural.less_or_equal_successor_successor_descend (p otherPredecessor : Natural)
        : LessOrEqual(successor(p), successor(otherPredecessor))
          → LessOrEqual(p, otherPredecessor) :=
  function (successorLessOrEqual : LessOrEqual(successor(p), successor(otherPredecessor))) =>
    Or.eliminate(
        p = otherPredecessor,
        LessOrEqual(successor(p), otherPredecessor),
        LessOrEqual(p, otherPredecessor),
        function (equality : p = otherPredecessor) =>
            Equality.transport_proposition(
                Natural,
                function (rightEnd : Natural) => LessOrEqual(p, rightEnd),
                p, otherPredecessor, equality,
                LessOrEqual.reflexivity(p)),
        function (successorPLessOrEqualOtherPredecessor : LessOrEqual(successor(p), otherPredecessor)) =>
            Natural.less_or_equal_predecessor_less_or_equal(p, otherPredecessor, successorPLessOrEqualOtherPredecessor),
        Natural.less_or_equal_successor_successor_inversion(p, otherPredecessor, successorLessOrEqual))

-- Strong induction: combine for_all_below with the step at level n.
theorem Natural.strong_induction
        (P : Natural → Proposition)
        (step : (n : Natural)
                → ((k : Natural)
                    → LessOrEqual(successor(k), n) → P(k))
                → P(n))
        (n : Natural)
        : P(n) :=
  step(n, Natural.for_all_below(P, step, n))

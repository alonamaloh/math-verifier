-- Natural/strong_recursion.math
--
-- Proves Natural.strong_induction from the ordinary recursor. The
-- derivation goes through three small lemmas:
--
--   1. LessOrEqual.invert (a "view" theorem): every `s ‚Č§ b`
--      is either `s = b` (reflexivity case) or `b = successor(bPredecessor) ‚ąß s ‚Č§ bPredecessor`
--      for some `bPredecessor` (step case).
--   2. Natural.not_less_or_equal_successor_zero: `successor(k) ‚Čį zero`.
--      Both reflexivity and step cases lead to `successor(_) = zero`, which
--      Natural.successor_not_zero rules out.
--   3. The "below" predicate `for_all_below n` asserts P holds for every
--      k with `successor(k) ‚Č§ n`. Build it by ordinary induction on n, using
--      (1) to decompose `successor(k) ‚Č§ successor(m)` and (2) to reject
--      `successor(k) ‚Č§ 0`.
--
-- Then `strong_induction` applies `step` to `for_all_below n`, bridging the
-- caller's `<`-step to the `+ 1 ‚Č§` form through `add_one_le_of_lt`.

module Natural.strong_recursion

import Natural.basics
import Natural.arithmetic
import Natural.one_plus_induction
import Natural.order
import Natural.peano
import Equality.basics
import Logic.basics
import Logic.exists

-- View lemma: any `s ‚Č§ b` is either an equality or has an upper bound that
-- is `successor` of something. With `‚Č§` now `< ‚ą® =`, the equality case is
-- the right disjunct directly; the strict case turns its witness `c`
-- (`s + (1 + c) = b`) into `b = successor(s + c)` with `s ‚Č§ s + c`.
automatic theorem LessOrEqual.invert (s b : ‚Ąē)
        : s ‚Č§ b
          ‚Üí s = b ‚ą® ‚ąÉ (bPredecessor : ‚Ąē). b = successor(bPredecessor) ‚ąß s ‚Č§ bPredecessor :=
  (proof : s ‚Č§ b) ‚Ü¶
    done by cases {
      case s < b: {
          choose c such that s + (1 + c) = b from Natural.lt_elim;
          s ‚Č§ s + c;
          b
             = s + (1 + c)
             = successor(s + c);
          ‚ąÉ (bPredecessor : ‚Ąē). b = successor(bPredecessor) ‚ąß s ‚Č§ bPredecessor
              by witness (s + c) with (b = successor(s + c) ‚ąß s ‚Č§ s + c);
          done
        }
      case s = b: done
    }

-- successor(k) ‚Čį 0. Apply invert and discharge both disjuncts via
-- Natural.successor_not_zero.
automatic theorem Natural.not_less_or_equal_successor_zero (k : ‚Ąē)
        : successor(k) ‚Č§ 0 ‚Üí False :=
  (impossible : successor(k) ‚Č§ 0) ‚Ü¶
    done by cases {
      case successor(k) = 0:
          done
      case ‚ąÉ (bPredecessor : ‚Ąē). 0 = successor(bPredecessor) ‚ąß successor(k) ‚Č§ bPredecessor as existsProof: {
          choose bPredecessor such that 0 = successor(bPredecessor) ‚ąß successor(k) ‚Č§ bPredecessor from existsProof;
          absurd(0 = successor(bPredecessor))
      }
    }

-- Inversion specifically for `successor(k) ‚Č§ successor(m)`: either `k = m` or
-- `successor(k) ‚Č§ m`. Derived from LessOrEqual.invert plus
-- successor_injective.
theorem Natural.less_or_equal_successor_successor_inversion (k m : ‚Ąē)
        : successor(k) ‚Č§ successor(m)
          ‚Üí k = m ‚ą® successor(k) ‚Č§ m :=
  (successorKLessOrEqualSuccessorMProof : successor(k) ‚Č§ successor(m)) ‚Ü¶
    done by cases {
      case successor(k) = successor(m): {
          k = m;
          done
        }
      case ‚ąÉ (bPredecessor : ‚Ąē). successor(m) = successor(bPredecessor) ‚ąß successor(k) ‚Č§ bPredecessor as existsProof:
          {
            choose bPredecessor such that
                successor(m) = successor(bPredecessor) ‚ąß successor(k) ‚Č§ bPredecessor
                from existsProof;
            -- m = bPredecessor by injectivity; substitute it back so
            -- successor(k) ‚Č§ bPredecessor becomes successor(k) ‚Č§ m.
            m = bPredecessor;
            successor(k) ‚Č§ m;
            done
          }
    }

-- for_all_below n : P holds for every k with successor(k) ‚Č§ n. Ordinary
-- induction on n.
theorem Natural.for_all_below
        (P : ‚Ąē ‚Üí Proposition)
        (step : ‚ąÄ (n : ‚Ąē).
                (‚ąÄ (k : ‚Ąē).
                    successor(k) ‚Č§ n ‚Üí P(k))
                ‚Üí P(n))
        (n : ‚Ąē)
        : ‚ąÄ (k : ‚Ąē). successor(k) ‚Č§ n ‚Üí P(k) :=
  by induction on n with IH {
    case base:
        (k : ‚Ąē) (impossible : successor(k) ‚Č§ 0) ‚Ü¶
          absurd(impossible)
    case step(predecessor):
        (k : ‚Ąē)
            (successorKLessOrEqualOnePlus :
                successor(k) ‚Č§ 1 + predecessor) ‚Ü¶ {
          -- The step bound `1 + predecessor` is not defeq to
          -- `successor(predecessor)`, but the successor-form inversion lemma
          -- still applies ‚ÄĒ its premise is discharged up to `one_add`.
          k = predecessor ‚ą® successor(k) ‚Č§ predecessor
              by Natural.less_or_equal_successor_successor_inversion;
          done by cases {
            case k = predecessor:
                -- We need P(k). step(predecessor, IH) gives P(predecessor);
                -- the diff-bridge auto-lifts via the equality in scope.
                step(predecessor, IH)
            case successor(k) ‚Č§ predecessor as successorKLessOrEqualPredecessor:
                IH(k, successorKLessOrEqualPredecessor)
          }
        }
  }

-- q ‚Č§ 0 forces q = 0. Apply LessOrEqual.invert and discharge the
-- step disjunct via zero_not_successor.
theorem Natural.less_or_equal_zero_implies_equals_zero (q : ‚Ąē)
        : q ‚Č§ 0 ‚Üí q = 0 :=
  (quotientLessOrEqualZero : q ‚Č§ 0) ‚Ü¶
    done by cases {
      case q = 0:
          done
      case ‚ąÉ (bPredecessor : ‚Ąē). 0 = successor(bPredecessor) ‚ąß q ‚Č§ bPredecessor as existsProof: {
          choose bPredecessor such that 0 = successor(bPredecessor) ‚ąß q ‚Č§ bPredecessor from existsProof;
          absurd(0 = successor(bPredecessor))
      }
    }

-- `successor(p) ‚Č§ successor(otherPredecessor)` descends to
-- `p ‚Č§ otherPredecessor`: invert to `p = otherPredecessor` or
-- `successor(p) ‚Č§ otherPredecessor`; both yield `p ‚Č§ otherPredecessor`.
automatic theorem Natural.less_or_equal_successor_successor_descend
        (p otherPredecessor : ‚Ąē)
        (successorPLessOrEqualSuccessor : successor(p) ‚Č§ successor(otherPredecessor))
        : p ‚Č§ otherPredecessor :=
  done by cases {
    case p = otherPredecessor:              done
    case successor(p) ‚Č§ otherPredecessor:   done
  }

-- `1 + p ‚Č§ 1 + q ‚üĻ p ‚Č§ q` ‚ÄĒ the successor-free face of the descend lemma,
-- so consumers cancel a leading `1 +` (the form `by induction`'s `case
-- step(k)` produces) without naming the constructor.
theorem Natural.le_cancel_one_plus (p q : ‚Ąē) (bound : 1 + p ‚Č§ 1 + q)
        : p ‚Č§ q := {
  successor(p)
     = 1 + p
     ‚Č§ 1 + q
     = successor(q);
  done
}

-- Strong induction: combine for_all_below with the step at level n.
-- The public principle's interface uses `<` (sealing `successor` from
-- callers); `k < n` is defeq to the `successor(k) ‚Č§ n` form `for_all_below`
-- is stated with, so the body ‚ÄĒ and every existing caller's `step` ‚ÄĒ type-
-- checks unchanged.
theorem Natural.strong_induction
        (P : ‚Ąē ‚Üí Proposition)
        (step : ‚ąÄ (n : ‚Ąē).
                (‚ąÄ (k : ‚Ąē).
                    k < n ‚Üí P(k))
                ‚Üí P(n))
        (n : ‚Ąē)
        : P(n) := {
  -- `for_all_below` is stated with the `successor(k) ‚Č§ m` step form; bridge
  -- the caller's `<`-step to it (and the `<`-result back) ‚ÄĒ `<` is no
  -- longer defeq to `successor ‚Č§`.
  ‚ąÄ (m : ‚Ąē). (‚ąÄ (k : ‚Ąē). successor(k) ‚Č§ m ‚Üí P(k)) ‚Üí P(m)
      by (m : ‚Ąē) (belowM : ‚ąÄ (k : ‚Ąē). successor(k) ‚Č§ m ‚Üí P(k)) ‚Ü¶
          step(m, (k : ‚Ąē) (kLessThanM : k < m) ‚Ü¶ {
            successor(k) ‚Č§ m;
            belowM(k, (successor(k) ‚Č§ m))
          });
  ‚ąÄ (k : ‚Ąē). k < n ‚Üí P(k)
      by (k : ‚Ąē) (kLessThanN : k < n) ‚Ü¶ {
        successor(k) ‚Č§ n;
        done
      } as below;
  step(n, below)
}

-- Natural/induction.math
--
-- Proves Natural.strong_induction from the ordinary recursor. The
-- derivation goes through three small lemmas:
--
--   1. LessOrEqual.invert (a "view" theorem): every `LessOrEqual(s, b)`
--      is either `s = b` (reflexivity case) or `b = succ(bPred) ∧ s ≤ bPred`
--      for some `bPred` (step case).
--   2. Natural.not_le_succ_zero: `Not(LessOrEqual(successor(k), zero))`.
--      Both reflexivity and step cases lead to `succ(_) = zero`, which
--      Natural.successor_not_zero rules out.
--   3. The "below" predicate `forAllBelow n` asserts P holds for every
--      k < n. Build it by ordinary induction on n, using (1) to
--      decompose `succ(k) ≤ succ(m)` and (2) to reject `succ(k) ≤ 0`.
--
-- Then `strong_induction n := step n (forAllBelow n)`.

module Natural.strong_recursion

import Natural.basics
import Natural.order
import Natural.peano
import Equality.basics
import Logic.basics
import Logic.exists

-- View lemma: any LessOrEqual proof is either an equality (reflexivity
-- constructor) or has an upper bound that is `succ` of something.
theorem LessOrEqual.invert (s b : Natural)
        : LessOrEqual(s, b)
          → Or(s = b,
                Exists(Natural, fun (bPredecessor : Natural) =>
                    And(b = successor(bPredecessor),
                         LessOrEqual(s, bPredecessor))))
  | LessOrEqual.reflexivity(commonValue) =>
      Or.introduceLeft(reflexivity(commonValue))
  | LessOrEqual.step(_, bPredecessorD, subproof) =>
      Or.introduceRight(
          Exists.introduce(
              bPredecessorD,
              And.introduction(
                  reflexivity(successor(bPredecessorD)),
                  subproof)))

-- Not(succ(k) ≤ 0). Apply invert and discharge both disjuncts via
-- Natural.successor_not_zero.
theorem Natural.not_le_succ_zero (k : Natural)
        : LessOrEqual(successor(k), zero) → False :=
  fun (impossible : LessOrEqual(successor(k), zero)) =>
    Or.eliminate(
        successor(k) = zero,
        Exists(Natural, fun (bPredecessor : Natural) =>
            And(zero = successor(bPredecessor),
                 LessOrEqual(successor(k), bPredecessor))),
        False,
        fun (succKEqualsZero : successor(k) = zero) =>
            Natural.successor_not_zero(k, succKEqualsZero),
        fun (existsProof : Exists(Natural,
                fun (bPredecessor : Natural) =>
                    And(zero = successor(bPredecessor),
                         LessOrEqual(successor(k), bPredecessor)))) =>
            Exists.eliminate(
                Natural,
                fun (bPredecessor : Natural) =>
                    And(zero = successor(bPredecessor),
                         LessOrEqual(successor(k), bPredecessor)),
                False,
                fun (bPredecessor : Natural)
                    (combined : And(zero = successor(bPredecessor),
                                     LessOrEqual(successor(k),
                                                  bPredecessor))) =>
                  And.eliminate(
                      zero = successor(bPredecessor),
                      LessOrEqual(successor(k), bPredecessor),
                      False,
                      fun (zeroEqualsSucc :
                              zero = successor(bPredecessor))
                          (_ : LessOrEqual(successor(k), bPredecessor)) =>
                          Natural.zero_not_successor(
                              bPredecessor, zeroEqualsSucc),
                      combined),
                existsProof),
        LessOrEqual.invert(successor(k), zero, impossible))

-- Inversion specifically for `succ(k) ≤ succ(m)`: either `k = m` or
-- `succ(k) ≤ m`. Derived from LessOrEqual.invert plus
-- successor_injective.
theorem Natural.le_succ_succ_inversion (k m : Natural)
        : LessOrEqual(successor(k), successor(m))
          → Or(k = m, LessOrEqual(successor(k), m)) :=
  fun (succKLeSuccMProof : LessOrEqual(successor(k), successor(m))) =>
    Or.eliminate(
        successor(k) = successor(m),
        Exists(Natural, fun (bPredecessor : Natural) =>
            And(successor(m) = successor(bPredecessor),
                 LessOrEqual(successor(k), bPredecessor))),
        Or(k = m, LessOrEqual(successor(k), m)),
        fun (succKEqSuccM : successor(k) = successor(m)) =>
            Or.introduceLeft(
                Natural.successor_injective(k, m, succKEqSuccM)),
        fun (existsProof : Exists(Natural,
                fun (bPredecessor : Natural) =>
                    And(successor(m) = successor(bPredecessor),
                         LessOrEqual(successor(k), bPredecessor)))) =>
            Exists.eliminate(
                Natural,
                fun (bPredecessor : Natural) =>
                    And(successor(m) = successor(bPredecessor),
                         LessOrEqual(successor(k), bPredecessor)),
                Or(k = m, LessOrEqual(successor(k), m)),
                fun (bPredecessor : Natural)
                    (combined : And(successor(m) = successor(bPredecessor),
                                     LessOrEqual(successor(k),
                                                  bPredecessor))) =>
                  And.eliminate(
                      successor(m) = successor(bPredecessor),
                      LessOrEqual(successor(k), bPredecessor),
                      Or(k = m, LessOrEqual(successor(k), m)),
                      fun (succMEqSuccBP :
                              successor(m) = successor(bPredecessor))
                          (succKLeBP :
                              LessOrEqual(successor(k), bPredecessor)) =>
                          -- We have m = bPredecessor by injectivity,
                          -- and succ(k) ≤ bPredecessor. Transport
                          -- succKLeBP along the symmetry of
                          -- successor_injective to get succ(k) ≤ m.
                          Or.introduceRight(
                              Equality.transport_proposition(
                                  Natural,
                                  fun (rightEnd : Natural) =>
                                      LessOrEqual(successor(k), rightEnd),
                                  bPredecessor, m,
                                  Equality.symmetry(
                                      Natural.successor_injective(
                                          m, bPredecessor, succMEqSuccBP)),
                                  succKLeBP)),
                      combined),
                existsProof),
        LessOrEqual.invert(
            successor(k), successor(m), succKLeSuccMProof))

-- forAllBelow n : for every k < n, P holds. Ordinary induction on n.
theorem Natural.for_all_below
        (P : Natural → Proposition)
        (step : (n : Natural)
                → ((k : Natural)
                    → LessOrEqual(successor(k), n) → P(k))
                → P(n))
        : (n : Natural) → (k : Natural)
          → LessOrEqual(successor(k), n) → P(k)
  | zero =>
      fun (k : Natural)
          (impossible : LessOrEqual(successor(k), zero)) =>
        False.eliminate_proposition(
            P(k),
            Natural.not_le_succ_zero(k, impossible))
  | successor(predecessor) =>
      fun (k : Natural)
          (succKLeSuccM : LessOrEqual(successor(k), successor(predecessor))) =>
        Or.eliminate(
            k = predecessor,
            LessOrEqual(successor(k), predecessor),
            P(k),
            fun (kEqualsPredecessor : k = predecessor) =>
                -- We need P(k). Use step(predecessor,
                -- for_all_below(predecessor)) to get P(predecessor),
                -- then transport along k = predecessor reversed.
                Equality.transport_proposition(
                    Natural,
                    P,
                    predecessor, k,
                    Equality.symmetry(kEqualsPredecessor),
                    step(predecessor,
                          Natural.for_all_below(
                              P, step, predecessor))),
            fun (succKLePredecessor : LessOrEqual(successor(k),
                                                   predecessor)) =>
                -- Recurse on the predecessor level: for_all_below for
                -- `predecessor` directly handles k with succ(k) ≤
                -- predecessor.
                Natural.for_all_below(
                    P, step, predecessor, k, succKLePredecessor),
            Natural.le_succ_succ_inversion(
                k, predecessor, succKLeSuccM))

-- Inversion of `succ(p) ≤ succ(oP)`: yields `p ≤ oP`. Combines
-- le_succ_succ_inversion with le_predecessor_le.
theorem Natural.le_succ_succ_descend (p oP : Natural)
        : LessOrEqual(successor(p), successor(oP))
          → LessOrEqual(p, oP) :=
  fun (succLe : LessOrEqual(successor(p), successor(oP))) =>
    Or.eliminate(
        p = oP,
        LessOrEqual(successor(p), oP),
        LessOrEqual(p, oP),
        fun (eq : p = oP) =>
            Equality.transport_proposition(
                Natural,
                fun (rightEnd : Natural) => LessOrEqual(p, rightEnd),
                p, oP, eq,
                LessOrEqual.reflexivity(p)),
        fun (succPLeOP : LessOrEqual(successor(p), oP)) =>
            Natural.le_predecessor_le(p, oP, succPLeOP),
        Natural.le_succ_succ_inversion(p, oP, succLe))

-- Strong induction: combine for_all_below with the step at level n.
theorem Natural.strong_induction
        (P : Natural → Proposition)
        (step : (n : Natural)
                → ((k : Natural)
                    → LessOrEqual(successor(k), n) → P(k))
                → P(n))
        (n : Natural)
        : P(n) :=
  step(n, Natural.for_all_below(P, step, n))

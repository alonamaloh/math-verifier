-- Natural/strong_recursion.math
--
-- Proves Natural.strong_induction from the ordinary recursor. The
-- derivation goes through three small lemmas:
--
--   1. LessOrEqual.invert (a "view" theorem): every `s â‰¤ b`
--      is either `s = b` (reflexivity case) or `b = successor(bPredecessor) âˆ§ s â‰¤ bPredecessor`
--      for some `bPredecessor` (step case).
--   2. Natural.not_less_or_equal_successor_zero: `successor(k) â‰° zero`.
--      Both reflexivity and step cases lead to `successor(_) = zero`, which
--      Natural.successor_not_zero rules out.
--   3. The "below" predicate `for_all_below n` asserts P holds for every
--      k with `successor(k) â‰¤ n`. Build it by ordinary induction on n, using
--      (1) to decompose `successor(k) â‰¤ successor(m)` and (2) to reject
--      `successor(k) â‰¤ 0`.
--
-- Then `strong_induction` applies `step` to `for_all_below n`, bridging the
-- caller's `<`-step to the `successor â‰¤` form through `successor_le_of_lt`.

module Natural.strong_recursion

import Natural.basics
import Natural.arithmetic
import Natural.one_plus_induction
import Natural.order
import Natural.peano
import Equality.basics
import Logic.basics
import Logic.exists

-- View lemma: any `s â‰¤ b` is either an equality or has an upper bound that
-- is `successor` of something. With `â‰¤` now `< âˆ¨ =`, the equality case is
-- the right disjunct directly; the strict case turns its witness `c`
-- (`s + (1 + c) = b`) into `b = successor(s + c)` with `s â‰¤ s + c`.
automatic theorem LessOrEqual.invert (s b : Natural)
        : s â‰¤ b
          â†’ s = b âˆ¨ âˆƒ (bPredecessor : Natural). b = successor(bPredecessor) âˆ§ s â‰¤ bPredecessor :=
  (proof : s â‰¤ b) â†¦
    claim by cases {
      case s < b: {
          choose c such that s + (1 + c) = b from Natural.lt_elim;
          s â‰¤ s + c;
          b
             = s + (1 + c)
             = successor(s + c);
          âˆƒ (bPredecessor : Natural). b = successor(bPredecessor) âˆ§ s â‰¤ bPredecessor
              by witness (s + c) with (b = successor(s + c) âˆ§ s â‰¤ s + c);
          done
        }
      case s = b: done
    }

-- successor(k) â‰° 0. Apply invert and discharge both disjuncts via
-- Natural.successor_not_zero.
automatic theorem Natural.not_less_or_equal_successor_zero (k : Natural)
        : successor(k) â‰¤ 0 â†’ False :=
  (impossible : successor(k) â‰¤ 0) â†¦
    claim by cases {
      case successor(k) = 0:
          done by Natural.successor_not_zero
      case âˆƒ (bPredecessor : Natural). 0 = successor(bPredecessor) âˆ§ successor(k) â‰¤ bPredecessor as existsProof: {
          choose bPredecessor such that 0 = successor(bPredecessor) âˆ§ successor(k) â‰¤ bPredecessor from existsProof;
          absurd(0 = successor(bPredecessor))
      }
    }

-- Inversion specifically for `successor(k) â‰¤ successor(m)`: either `k = m` or
-- `successor(k) â‰¤ m`. Derived from LessOrEqual.invert plus
-- successor_injective.
theorem Natural.less_or_equal_successor_successor_inversion (k m : Natural)
        : successor(k) â‰¤ successor(m)
          â†’ k = m âˆ¨ successor(k) â‰¤ m :=
  (successorKLessOrEqualSuccessorMProof : successor(k) â‰¤ successor(m)) â†¦
    claim by cases {
      case successor(k) = successor(m): {
          k = m;
          done
        }
      case âˆƒ (bPredecessor : Natural). successor(m) = successor(bPredecessor) âˆ§ successor(k) â‰¤ bPredecessor as existsProof:
          {
            choose bPredecessor such that
                successor(m) = successor(bPredecessor) âˆ§ successor(k) â‰¤ bPredecessor
                from existsProof;
            -- m = bPredecessor by injectivity; substitute it back so
            -- successor(k) â‰¤ bPredecessor becomes successor(k) â‰¤ m.
            m = bPredecessor as mEqualsBPredecessor;
            successor(k) â‰¤ m by substituting mEqualsBPredecessor;
            done
          }
    }

-- for_all_below n : P holds for every k with successor(k) â‰¤ n. Ordinary
-- induction on n.
theorem Natural.for_all_below
        (P : Natural â†’ Proposition)
        (step : âˆ€ (n : Natural).
                (âˆ€ (k : Natural).
                    successor(k) â‰¤ n â†’ P(k))
                â†’ P(n))
        (n : Natural)
        : âˆ€ (k : Natural). successor(k) â‰¤ n â†’ P(k) :=
  by induction on n with IH {
    case base:
        (k : Natural) (impossible : successor(k) â‰¤ 0) â†¦
          absurd(impossible)
    case step(predecessor):
        (k : Natural)
            (successorKLessOrEqualOnePlus :
                successor(k) â‰¤ 1 + predecessor) â†¦ {
          -- The step bound `1 + predecessor` is not defeq to
          -- `successor(predecessor)`, but the successor-form inversion lemma
          -- still applies â€” its premise is discharged up to `one_add`.
          k = predecessor âˆ¨ successor(k) â‰¤ predecessor
              by Natural.less_or_equal_successor_successor_inversion;
          claim by cases {
            case k = predecessor:
                -- We need P(k). step(predecessor, IH) gives P(predecessor);
                -- the diff-bridge auto-lifts via the equality in scope.
                step(predecessor, IH)
            case successor(k) â‰¤ predecessor as successorKLessOrEqualPredecessor:
                IH(k, successorKLessOrEqualPredecessor)
          }
        }
  }

-- q â‰¤ 0 forces q = 0. Apply LessOrEqual.invert and discharge the
-- step disjunct via zero_not_successor.
theorem Natural.less_or_equal_zero_implies_equals_zero (q : Natural)
        : q â‰¤ 0 â†’ q = 0 :=
  (quotientLessOrEqualZero : q â‰¤ 0) â†¦
    claim by cases {
      case q = 0:
          done
      case âˆƒ (bPredecessor : Natural). 0 = successor(bPredecessor) âˆ§ q â‰¤ bPredecessor as existsProof: {
          choose bPredecessor such that 0 = successor(bPredecessor) âˆ§ q â‰¤ bPredecessor from existsProof;
          absurd(0 = successor(bPredecessor))
      }
    }

-- `successor(p) â‰¤ successor(otherPredecessor)` descends to
-- `p â‰¤ otherPredecessor`: invert to `p = otherPredecessor` or
-- `successor(p) â‰¤ otherPredecessor`; both yield `p â‰¤ otherPredecessor`.
automatic theorem Natural.less_or_equal_successor_successor_descend
        (p otherPredecessor : Natural)
        (successorPLessOrEqualSuccessor : successor(p) â‰¤ successor(otherPredecessor))
        : p â‰¤ otherPredecessor :=
  claim by cases {
    case p = otherPredecessor:              done
    case successor(p) â‰¤ otherPredecessor:   done
  }

-- `1 + p â‰¤ 1 + q âŸ¹ p â‰¤ q` â€” the successor-free face of the descend lemma,
-- so consumers cancel a leading `1 +` (the form `by induction`'s `case
-- step(k)` produces) without naming the constructor.
theorem Natural.le_cancel_one_plus (p q : Natural) (bound : 1 + p â‰¤ 1 + q)
        : p â‰¤ q := {
  successor(p)
     = 1 + p
     â‰¤ 1 + q
     = successor(q);
  done
}

-- Strong induction: combine for_all_below with the step at level n.
-- The public principle's interface uses `<` (sealing `successor` from
-- callers); `k < n` is defeq to the `successor(k) â‰¤ n` form `for_all_below`
-- is stated with, so the body â€” and every existing caller's `step` â€” type-
-- checks unchanged.
theorem Natural.strong_induction
        (P : Natural â†’ Proposition)
        (step : âˆ€ (n : Natural).
                (âˆ€ (k : Natural).
                    k < n â†’ P(k))
                â†’ P(n))
        (n : Natural)
        : P(n) := {
  -- `for_all_below` is stated with the `successor(k) â‰¤ m` step form; bridge
  -- the caller's `<`-step to it (and the `<`-result back) â€” `<` is no
  -- longer defeq to `successor â‰¤`.
  âˆ€ (m : Natural). (âˆ€ (k : Natural). successor(k) â‰¤ m â†’ P(k)) â†’ P(m)
      by (m : Natural) (belowM : âˆ€ (k : Natural). successor(k) â‰¤ m â†’ P(k)) â†¦
          step(m, (k : Natural) (kLessThanM : k < m) â†¦ {
            successor(k) â‰¤ m;
            belowM(k, (successor(k) â‰¤ m))
          });
  âˆ€ (k : Natural). k < n â†’ P(k)
      by (k : Natural) (kLessThanN : k < n) â†¦ {
        successor(k) â‰¤ n;
        done
      } as below;
  step(n, below)
}

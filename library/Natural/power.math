-- Natural/power.math
--
-- Exponentiation on Natural by recursion on the exponent.
--   base^0 = 1, base^(k+1) = base * base^k.
-- Plus the basic algebraic lemmas (power_zero, power_one, power_add,
-- power_positive) needed by the p-adic absolute value.

module Natural.power

import Logic.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.subtraction
import Logic.exists
import Equality.basics

-- Base first, recursion on the exponent — the same shape as
-- `Real.power`, so `Natural.power(base, k) = base^k`.
--
-- Opaque: downstream proofs reason through `power_zero` /
-- `power_succ` rather than letting the kernel ι-reduce on
-- constructor-shaped exponents. The two characterising lemmas
-- below are the only places that touch the body.
opaque definition Natural.power (base : Natural) : Natural → Natural
  | zero         => successor(zero)
  | successor(k) => base * Natural.power(base, k)

operator (^) on (Natural, Natural) := Natural.power

-- base^0 = 1.
theorem Natural.power_zero (base : Natural) : Natural.power(base, 0) = successor(0) :=
  done by unfolding Natural.power

-- base^(k+1) = base * base^k. The successor-equation lemma.
theorem Natural.power_succ (base k : Natural)
        : Natural.power(base, successor(k)) = base * Natural.power(base, k) :=
  done by unfolding Natural.power

-- base^1 = base. Stepping through power_succ + power_zero + multiply_one;
-- the auto-prover finds each lemma by library scan.
theorem Natural.power_one (base : Natural) : Natural.power(base, successor(0)) = base :=
  Natural.power(base, successor(0))
     = base * 1
     = base

-- base^(a + b) = base^a * base^b. Induct on a; opaqueness means the
-- recursive step uses power_succ to peel a successor instead of
-- riding the kernel's ι.
theorem Natural.power_add (base a b : Natural)
        : Natural.power(base, a + b) = Natural.power(base, a) * Natural.power(base, b) :=
  unfold Natural.add in
  by induction on a with IH {
    case zero:
        -- 0 + b reduces to b; one_multiply restores the leading 1 and
        -- power_zero recasts it as base^0.
        Natural.power(base, 0 + b)
           = Natural.power(base, b)
           = 1 * Natural.power(base, b)
           = Natural.power(base, 0) * Natural.power(base, b)
    case successor(k):
        -- successor(k) + b reduces to successor(k + b); peel via power_succ,
        -- recurse via the IH, then re-roll the leading successor on the left.
        Natural.power(base, successor(k) + b)
           = base * Natural.power(base, k + b)
           = base * (Natural.power(base, k) * Natural.power(base, b)) by IH
           = (base * Natural.power(base, k)) * Natural.power(base, b)
           = Natural.power(base, successor(k)) * Natural.power(base, b)
  }

-- Subtraction-witness extractor for `1 ≤ base^k`: provides a Natural m
-- with base^k = succ(m). Useful for showing strict positivity.
theorem Natural.power_succ_form (base k : Natural) (basePositive : 1 ≤ base)
        : ∃ (m : Natural). Natural.power(base, k) = successor(m) :=
  unfold Natural.add in
  by induction on k with IH {
    case zero:
        -- base^0 = 1 = successor(0) via power_zero.
        witness 0 with Natural.power(base, 0) = successor(0)
    case successor(j): {
        -- IH: there's an m with base^j = succ(m).
        choose m such that Natural.power(base, j) = successor(m) from IH;
        -- base ≥ 1, so base = 1 + c for some c (and `1 + c` reduces to succ(c)).
        choose c such that base = 1 + c from Natural.subtraction_witness;
        witness c + base * m with
            Natural.power(base, successor(j))
               = base * Natural.power(base, j)
               = base * successor(m)
               = base + base * m
               = (1 + c) + base * m
               = successor(c + base * m)
      }
  }

-- base^k ≥ 1 for base ≥ 1. From the succ form.
theorem Natural.power_positive
        (base k : Natural) (basePositive : 1 ≤ base)
        : 1 ≤ Natural.power(base, k) := {
  ∃ (m : Natural). Natural.power(base, k) = successor(m) as succForm;
  choose m such that Natural.power(base, k) = successor(m) from succForm;
  -- 1 ≤ successor(m) = base^k.
  1
     ≤ successor(m)
     = Natural.power(base, k)
}

-- Natural/power.math
--
-- Exponentiation on Natural by recursion on the exponent.
--   p^0 = 1, p^(k+1) = p * p^k.
-- Plus the basic algebraic lemmas (power_zero, power_one, power_add,
-- power_positive) needed by the p-adic absolute value.

module Natural.power

import Logic.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.subtraction
import Logic.exists
import Equality.basics

-- Exponent first so structural recursion is on the first argument.
-- `Natural.power(k, p) = p^k`.
--
-- Opaque: downstream proofs reason through `power_zero` /
-- `power_succ` rather than letting the kernel ι-reduce on
-- constructor-shaped exponents. The two characterising lemmas
-- below are the only places that touch the body.
opaque definition Natural.power : Natural → Natural → Natural
  | zero,         _ => successor(zero)
  | successor(k), p => p * Natural.power(k, p)

-- p^0 = 1.
theorem Natural.power_zero (p : Natural) : Natural.power(0, p) = successor(0) :=
  done by unfolding Natural.power

-- p^(k+1) = p * p^k. The successor-equation lemma.
theorem Natural.power_succ (k p : Natural)
        : Natural.power(successor(k), p) = p * Natural.power(k, p) :=
  done by unfolding Natural.power

-- p^1 = p. Stepping through power_succ + power_zero + multiply_one;
-- the auto-prover finds each lemma by library scan.
theorem Natural.power_one (p : Natural) : Natural.power(successor(0), p) = p :=
  calc Natural.power(successor(0), p)
     = p * 1
     = p

-- p^(a + b) = p^a * p^b. With exponent first: power(a + b, p) =
-- power(a, p) * power(b, p). Induct on a; opaqueness means the
-- recursive step uses power_succ to peel a successor instead of
-- riding the kernel's ι.
theorem Natural.power_add (a b p : Natural)
        : Natural.power(a + b, p) = Natural.power(a, p) * Natural.power(b, p) :=
  by_induction on a with IH {
    case zero:
        -- 0 + b reduces to b; one_multiply restores the leading 1 and
        -- power_zero recasts it as power(0, p).
        calc Natural.power(0 + b, p)
           = Natural.power(b, p)
           = 1 * Natural.power(b, p)
           = Natural.power(0, p) * Natural.power(b, p)
    case successor(k):
        -- successor(k) + b reduces to successor(k + b); peel via power_succ,
        -- recurse via the IH, then re-roll the leading successor on the right.
        calc Natural.power(successor(k) + b, p)
           = p * Natural.power(k + b, p)
           = p * (Natural.power(k, p) * Natural.power(b, p)) by IH
           = (p * Natural.power(k, p)) * Natural.power(b, p)
           = Natural.power(successor(k), p) * Natural.power(b, p)
  }

-- Subtraction-witness extractor for `1 ≤ p^k`: provides a Natural m
-- with p^k = succ(m). Useful for showing strict positivity.
theorem Natural.power_succ_form (k p : Natural) (pPositive : 1 ≤ p)
        : ∃ (m : Natural). Natural.power(k, p) = successor(m) :=
  by_induction on k with IH {
    case zero:
        -- power(0, p) = 1 = successor(0) via power_zero.
        witness 0 with calc Natural.power(0, p) = successor(0)
    case successor(j): {
        -- IH: there's an m with power(j, p) = succ(m).
        obtain ⟨m, powerIsSucc⟩ from IH;
        -- p ≥ 1, so p = 1 + c for some c (and `1 + c` reduces to succ(c)).
        obtain ⟨c, pEqualsOnePlusC⟩ by Natural.subtraction_witness;
        witness c + p * m with
            calc Natural.power(successor(j), p)
               = p * Natural.power(j, p)
               = p * successor(m)
               = p + p * m
               = (1 + c) + p * m
               = successor(c + p * m)
      }
  }

-- p^k ≥ 1 for p ≥ 1. From the succ form.
theorem Natural.power_positive
        (k p : Natural) (pPositive : 1 ≤ p)
        : 1 ≤ Natural.power(k, p) := {
  claim succForm
        : ∃ (m : Natural). Natural.power(k, p) = successor(m)
      by Natural.power_succ_form;
  obtain ⟨m, eq⟩ from succForm;
  -- 1 ≤ successor(m) = power(k, p).
  calc 1
     ≤ successor(m)
     = Natural.power(k, p)
}

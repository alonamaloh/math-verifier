-- Natural/list_product.math
--
-- The product of a `List(ℕ)`: the multiplicative fold with unit 1.
-- `List.product` is the general list fold (parameterised by the operation and
-- identity — it imposes nothing on the element type); this names its Natural
-- instance and records the divisibility fact Euclid and factorisation need.
-- The canonical home for what `prime_factorization_unique` and the retired
-- `NaturalList` each used to define independently.

module Natural.list_product

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.divisibility
import Lists.list
import Lists.permutation

definition Natural.listProduct (list : List(ℕ)) : ℕ :=
  List.product((a b : ℕ) ↦ a * b, 1, list)

theorem Natural.listProduct_empty
        : Natural.listProduct(List.empty(ℕ)) = 1 :=
  done

theorem Natural.listProduct_prepend (head : ℕ) (tail : List(ℕ))
        : Natural.listProduct(List.prepend(ℕ, head, tail))
          = head * Natural.listProduct(tail) :=
  done

theorem Natural.listProduct_permutation_invariant (l1 l2 : List(ℕ))
        (perm : List.Permutation(ℕ, l1, l2))
        : Natural.listProduct(l1) = Natural.listProduct(l2) :=
  done by List.Permutation.product_invariant

-- Any member of the list divides its product. Induct on the membership
-- derivation: the head divides its own multiple; a tail member divides the
-- tail product, hence the head-scaled whole.
theorem Natural.member_divides_listProduct (n : ℕ) (list : List(ℕ))
        (memberProof : n ∈ list)
        : n ∣ Natural.listProduct(list) :=
  by induction on memberProof with IH {
    case List.member.here(rest): {
        n ∣ n * Natural.listProduct(rest);
        done
      }
    case List.member.there(head, rest, subMember): {
        n ∣ Natural.listProduct(rest) by IH;
        n ∣ head * Natural.listProduct(rest) by Natural.divides_multiple_left;
        done
      }
  }

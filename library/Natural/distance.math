-- Natural/distance.math
--
-- Symmetric difference (≈ "absolute value of a − b") on Naturals.
-- Defined recursively, decrementing both arguments simultaneously
-- until one side hits 0. Used to define Integer.absolute_value:
-- the absolute value of the representative `(a, b)` is
-- `distance(a, b)`.
--
-- Implementation note: written as a single pattern on the first
-- argument with an explicit `cases` on the second — the kernel only
-- reduces multi-constructor patterns when the inner case is explicit,
-- so a `| 1 + k, 1 + m => …` clause would not fire reduction at
-- definition use sites. Patterns therefore keep the raw
-- `successor(…)` constructor form; expressions in proof bodies
-- prefer the more readable `1 + …` notation (definitionally equal).

module Natural.distance

import axioms
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Equality.basics

definition Natural.distance : Natural → Natural → Natural
  | zero,         b => b
  | successor(k), b =>
      cases b {
        | zero         => 1 + k
        | successor(m) => Natural.distance(k, m)
      }

-- distance(0, b) = b.
theorem Natural.distance_zero_left (b : Natural)
        : Natural.distance(0, b) = b :=
  reflexivity(b)

-- distance(a, 0) = a. Case-split a; both arms reduce kernel-side.
theorem Natural.distance_zero_right (a : Natural) : Natural.distance(a, 0) = a :=
  cases a {
    | zero         => reflexivity(0)
    | successor(k) => reflexivity(1 + k)
  }

-- distance(a, a) = 0. Induction on a; the recursive arm uses the IH.
theorem Natural.distance_self (a : Natural) : Natural.distance(a, a) = 0 :=
  by_induction on a with IH {
    case zero:                   reflexivity(0)
    case successor(predecessor): IH
  }

-- distance is symmetric. Induction on the first argument; the IH
-- needs to be polymorphic in the second arg, so we bind `b` INSIDE
-- the inductive body rather than as an outer parameter — that way
-- the IH at the successor step has type `(b : Natural) → distance(k,
-- b) = distance(b, k)` and we can specialise it per inner case.
theorem Natural.distance_symmetric (a : Natural)
        : (b : Natural) → Natural.distance(a, b) = Natural.distance(b, a) :=
  by_induction on a with IH {
    case zero:
        function (b : Natural) =>
          Equality.symmetry(Natural.distance_zero_right(b))
    case successor(k):
        function (b : Natural) =>
          by_cases on b {
            case zero:         reflexivity(1 + k)
            case successor(m): IH(m)
          }
  }

-- Helper: distance(a + b, b) = a. Walking off the rightmost `b`
-- decrements both sides by 1, leaving `(a, 0)` whose distance is `a`.
-- Induction on b (a is a free parameter).
theorem Natural.distance_add_self_right (a b : Natural)
        : Natural.distance(a + b, b) = a :=
  by_induction on b with IH {
    case zero:
        calc Natural.distance(a + 0, 0)
           = Natural.distance(a, 0)
           = a
    case successor(predecessor):
        calc Natural.distance(a + (1 + predecessor), 1 + predecessor)
           = Natural.distance(1 + (a + predecessor), 1 + predecessor)
                  by Natural.add_successor(a, predecessor)
           = Natural.distance(a + predecessor, predecessor)
           = a   by IH
  }

-- The symmetric companion: distance(b, a + b) = a. Symmetry of
-- distance reduces it to the previous lemma.
theorem Natural.distance_self_add_right (a b : Natural)
        : Natural.distance(b, a + b) = a :=
  calc Natural.distance(b, a + b)
     = Natural.distance(a + b, b)
     = a

-- distance(a, b) ≤ a + b. Triangle inequality at Natural level.
-- Induction on a; b stays polymorphic in the IH by binding it
-- inside the inductive body.
theorem Natural.distance_le_add (a : Natural)
        : (b : Natural) → Natural.distance(a, b) ≤ a + b :=
  by_induction on a with IH {
    case zero:
        function (b : Natural) =>
          -- Both sides reduce to b.
          LessOrEqual.reflexivity(b)
    case successor(k):
        function (b : Natural) =>
          by_cases on b {
            case zero:
                -- distance(1+k, 0) = 1+k ≤ 1+k = (1+k) + 0.
                calc Natural.distance(1 + k, 0)
                   = 1 + k
                   ≤ 1 + k         by LessOrEqual.reflexivity(1 + k)
                   = (1 + k) + 0
            case successor(m):
                -- distance(1+k, 1+m) = distance(k, m) (kernel ι);
                -- IH(m) gives the recursive bound; climb twice
                -- via le_successor; the last step undoes add's
                -- successor on the right with add_successor.
                calc Natural.distance(1 + k, 1 + m)
                   = Natural.distance(k, m)
                   ≤ k + m                by IH(m)
                   ≤ 1 + (k + m)          by Natural.le_successor(k + m)
                   ≤ 2 + (k + m)          by Natural.le_successor(1 + (k + m))
                   = (1 + k) + (1 + m)
                          by Equality.symmetry(Natural.add_successor(k, m))
          }
  }

-- Cancellation on the left: distance(b + c, b + d) = distance(c, d).
-- Induct on b. (1 + b') + c reduces to 1 + (b' + c) via add's
-- first-arg recursion; distance on succ, succ reduces via inner ι.
theorem Natural.distance_add_left_cancel (b c d : Natural)
        : Natural.distance(b + c, b + d) = Natural.distance(c, d) :=
  by_induction on b with IH {
    case zero:                 reflexivity(Natural, Natural.distance(c, d))
    case successor(predecessor): IH
  }

-- Cancellation on the right: distance(a + b, c + b) = distance(a, c).
-- Reduce to the left form via add_commutative.
theorem Natural.distance_add_right_cancel (a b c : Natural)
        : Natural.distance(a + b, c + b) = Natural.distance(a, c) :=
  calc Natural.distance(a + b, c + b)
     = Natural.distance(b + a, c + b)
     = Natural.distance(b + a, b + c)
     = Natural.distance(a, c)

-- Key inequality: a ≤ b + distance(a, b). One direction of the
-- "distance ≤ z iff a ≤ c + z and c ≤ a + z" characterisation;
-- proved standalone. Induction on a with b bound inside so the IH
-- is polymorphic in b.
theorem Natural.le_add_distance (a : Natural)
        : (b : Natural) → a ≤ b + Natural.distance(a, b) :=
  by_induction on a with IH {
    case zero:
        function (b : Natural) =>
          -- 0 ≤ b + distance(0, b) = b + b.
          Natural.zero_least(b + b)
    case successor(k):
        function (b : Natural) =>
          by_cases on b {
            case zero:
                -- 1+k ≤ 0 + distance(1+k, 0) = 1+k. Reflexive.
                LessOrEqual.reflexivity(1 + k)
            case successor(m):
                -- 1+k ≤ (1+m) + distance(1+k, 1+m). Both sides
                -- have a leading successor we can peel; IH(m)
                -- gives k ≤ m + distance(k, m), then bump via
                -- successor_less_or_equal_successor.
                Natural.successor_less_or_equal_successor(
                    k, m + Natural.distance(k, m), IH(m))
          }
  }

-- Metric triangle inequality: distance(a, c) ≤ distance(a, b) +
-- distance(b, c). Induct on a; inner case-splits on c and b. Base
-- cases use `le_add_distance` and `distance_le_add`; the recursive
-- case (1+k, 1+b', 1+c') reduces all three distances by 1.
theorem Natural.distance_triangle (a : Natural)
        : (b c : Natural)
          → Natural.distance(a, c)
            ≤ Natural.distance(a, b) + Natural.distance(b, c) :=
  by_induction on a with IH {
    case zero:
        function (b c : Natural) => {
          -- distance(0, c) = c. distance(0, b) = b. Want: c ≤ b +
          -- distance(b, c). le_add_distance(c, b) gives c ≤ b +
          -- distance(c, b) — symmetric form; substitute distance
          -- direction.
          claim c ≤ b + Natural.distance(c, b)
              by Natural.le_add_distance(c, b)
          claim goal
              by substituting Natural.distance_symmetric(c, b)
        }
    case successor(k):
        function (b c : Natural) =>
          by_cases on c {
            case zero:
                -- distance(1+k, 0) = 1+k. By le_add_distance(1+k, b):
                -- 1+k ≤ b + distance(1+k, b). Commute, rewrite
                -- distance(b, 0) = b.
                calc Natural.distance(1 + k, 0)
                   = 1 + k
                   ≤ b + Natural.distance(1 + k, b)
                          by Natural.le_add_distance(1 + k, b)
                   = Natural.distance(1 + k, b) + b
                   = Natural.distance(1 + k, b) + Natural.distance(b, 0)
            case successor(c'):
                by_cases on b {
                  case zero:
                      -- distance(0, 1+c') = 1+c'; the LHS reduces
                      -- to distance(k, c'). Climb from
                      -- distance_le_add: distance(k, c') ≤ k + c'
                      -- ≤ 1+(k+c') ≤ 2+(k+c') = (1+k) + (1+c').
                      calc Natural.distance(1 + k, 1 + c')
                         = Natural.distance(k, c')
                         ≤ k + c'         by Natural.distance_le_add(k, c')
                         ≤ 1 + (k + c')   by Natural.le_successor(k + c')
                         ≤ 2 + (k + c')   by Natural.le_successor(1 + (k + c'))
                         = (1 + k) + (1 + c')
                                by Equality.symmetry(
                                       Natural.add_successor(k, c'))
                  case successor(b'):
                      -- All three distances drop by one. IH(b', c').
                      IH(b', c')
                }
          }
  }

-- distance(a + c, b + d) ≤ distance(a, b) + distance(c, d). Triangle
-- through b + c, then cancellation on each summand. Bridges Natural-
-- level metric structure to the Integer triangle inequality.
theorem Natural.distance_add_triangle (a b c d : Natural)
        : Natural.distance(a + c, b + d)
          ≤ Natural.distance(a, b) + Natural.distance(c, d) :=
  calc Natural.distance(a + c, b + d)
     ≤ Natural.distance(a + c, b + c) + Natural.distance(b + c, b + d)
            by Natural.distance_triangle(a + c, b + c, b + d)
     = Natural.distance(a, b) + Natural.distance(b + c, b + d)
     = Natural.distance(a, b) + Natural.distance(c, d)

-- Respect lemma: if `a + d = b + c`, then `distance(a, b) =
-- distance(c, d)`. Load-bearing for Integer.absolute_value's lift.
--
-- Induction on `a`, then case-split on `b` in the successor case.
-- `refining b, c, d, hypothesis` lifts those binders into the
-- recursor's motive: the IH at the successor step then takes them
-- as arguments (so the inner case-on-b can pass `bPredecessor` for
-- `b`), and the inner by_cases-refining gets the hypothesis with `b`
-- already specialised per arm.
theorem Natural.distance_respects_integer_equivalent
        (a b c d : Natural) (hypothesis : a + d = b + c)
        : Natural.distance(a, b) = Natural.distance(c, d) :=
  by_induction on a with IH refining b, c, d, hypothesis {
    case zero:
        -- hypothesis : 0 + d = b + c  (i.e. d = b + c by 0 + d → d).
        calc Natural.distance(0, b)
           = b
           = Natural.distance(c, b + c)
                  by Equality.symmetry(
                         Natural.distance_self_add_right(b, c))
           = Natural.distance(c, d)
    case successor(k):
        by_cases on b refining hypothesis {
          case zero:
              -- hypothesis : (1+k) + d = c  (0 + c reduces to c).
              -- Walk d off the right of distance((1+k) + d, d), then
              -- swap (1+k) + d for c via the hypothesis.
              calc Natural.distance(1 + k, 0)
                 = 1 + k
                 = Natural.distance((1 + k) + d, d)
                 = Natural.distance(c, d)
          case successor(bPredecessor): {
              -- hypothesis (after add's kernel β on succ): 1+(k+d) =
              -- 1+(bPredecessor+c). Drop the 1+ via successor_injective
              -- so IH can close on the smaller a (with bPredecessor
              -- in place of b).
              claim peeled : k + d = bPredecessor + c
                by Natural.successor_injective(
                       k + d, bPredecessor + c, hypothesis);
              IH(bPredecessor, c, d, peeled)
            }
        }
  }

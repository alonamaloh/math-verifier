-- Natural/basics.math
--
-- Natural numbers with constructors zero and successor, and the
-- core arithmetic operations defined by structural recursion.

module Natural.basics

-- The raw inductive, out of the public namespace with qualified
-- constructors, mirroring `IntegerRepresentative.make`
-- (PLAN_NATURAL_SEALING). The kernel's literal machinery and the
-- export trail key on these qualified names.
inductive Natural.Raw : Type(0) where
  | Natural.Raw.zero : Natural.Raw
  | Natural.Raw.successor : Natural.Raw → Natural.Raw

-- The public type is SEALED over the raw inductive (Stage 4 of
-- PLAN_NATURAL_SEALING): consumers cannot pattern-match on it or reach
-- the raw recursor — structural recursion and case analysis go through
-- `Natural.recursion` and the boundary theorems
-- (`Natural.induction_on_successor`, `Natural.cases_on_successor`,
-- `Natural.induction_on_one_plus`, …), exactly as ℤ/ℚ/ℝ are reasoned
-- about through their boundaries. The raw floor pierces the seal with
-- `unfold Natural in`.
opaque definition Natural : Type(0) := Natural.Raw

-- The constructors under their historical bare names, re-exposed AT THE
-- ALIAS. Transparent on purpose: they δ-reduce onto the raw
-- constructors, so kernel defeq and literal compaction see through
-- them, while every consumer spelling `successor(n)` keeps inferring
-- the public carrier `Natural`. The `unfold Natural in` lets the raw
-- constructor sit at the alias type once the alias is sealed.
definition zero : Natural := unfold Natural in Natural.Raw.zero
definition successor : Natural → Natural :=
  unfold Natural in Natural.Raw.successor

-- Small constants used throughout the library.
definition one : Natural := successor(zero)
definition two : Natural := successor(one)

-- Addition, defined by structural recursion at the raw floor and
-- re-exposed at the alias. The raw body is self-contained, so it stays
-- entirely below the seal.
--
-- Definitional reduction rules (visible to the kernel after elaboration):
--   add(zero, m)         ≡ m
--   add(successor(k), m) ≡ successor(add(k, m))
definition Natural.Raw.add : Natural.Raw → Natural.Raw → Natural.Raw
  | zero,         m  =>  m
  | successor(k), m  =>  Natural.Raw.successor(Natural.Raw.add(k, m))

opaque definition Natural.add : Natural → Natural → Natural :=
  unfold Natural in Natural.Raw.add

-- Multiplication. The recursive arm calls the PUBLIC `Natural.add`, so
-- the reduct of `multiply(successor(k), m)` keeps the spelling every
-- downstream proof reads (a raw-`add` reduct was measured to break
-- defeq-shaped proofs — PLAN_NATURAL_SEALING §Mechanism).
--
-- Definitional reduction rules:
--   multiply(zero, m)         ≡ zero
--   multiply(successor(k), m) ≡ add(m, multiply(k, m))
definition Natural.Raw.multiply : Natural.Raw → Natural.Raw → Natural.Raw
  | zero,         _  =>  Natural.Raw.zero
  | successor(k), m  =>
      unfold Natural in Natural.add(m, Natural.Raw.multiply(k, m))

definition Natural.multiply : Natural → Natural → Natural :=
  unfold Natural in Natural.Raw.multiply

-- Primitive recursion into Type — the boundary form of structural
-- recursion on a Natural, and what `definition … | 0 => … | 1 + k => …`
-- compiles onto for consumers of the sealed alias. The step speaks
-- `successor` (the wrapper): a Type-valued result cannot ride the
-- propositional `1 + k = successor(k)` bridge, so the constructor-defeq
-- spelling is the honest one here.
definition Natural.recursion.{u}
    {C : Natural → Type(u)}
    (base : C(0))
    (step : ∀ (k : Natural). C(k) → C(successor(k)))
    (n : Natural)
    : C(n) :=
  unfold Natural in Natural.Raw_recursor(C, base, step, n)

-- Operator overloads: `+` and `*` on Naturals route here.
operator (+) on (Natural, Natural) := Natural.add
operator (*) on (Natural, Natural) := Natural.multiply

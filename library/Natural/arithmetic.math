-- Natural/arithmetic.math
--
-- Identities about Natural arithmetic. Builds toward the
-- "Natural is a commutative semiring" claim.
--
-- Surface sugar in play:
--   a + b                                desugars to  Natural.add(a, b)
--   a * b                                desugars to  Natural.multiply(a, b)
--   a = b                                desugars to  Equality.{u}(typeOfA, a, b)
--   reflexivity(x)                       desugars to  reflexivity.{u}(typeOfX, x)
--   congruenceOf(f, h)                   desugars to  Equality.congruence
--   Equality.symmetry(h)                 desugars to  Equality.symmetry.{u}(A, x, y, h)
--   Equality.transitivity(h1, h2)        desugars to  Equality.transitivity.{u}(A, x, y, z, h1, h2)

module Natural.arithmetic

import Natural.basics
import Equality.basics

-- Theorem: 0 + a = a. Definitional.
theorem Natural.zero_add(a : Natural) : zero + a = a :=
  reflexivity(a)

-- Theorem: a + 0 = a. Induction on a.
theorem Natural.add_zero : (a : Natural) → a + zero = a
  | zero         => reflexivity(zero)
  | successor(k) => congruenceOf(successor, Natural.add_zero(k))

-- Theorem: 1 + a = successor(a). Definitional.
theorem Natural.one_add(a : Natural) : one + a = successor(a) :=
  reflexivity(successor(a))

-- Theorem: a + successor(b) = successor(a + b). Mirror of the definitional
-- rule for add on the first argument.
theorem Natural.add_successor
        : (a b : Natural) → a + successor(b) = successor(a + b)
  | zero,         b => reflexivity(successor(b))
  | successor(k), b => congruenceOf(successor, Natural.add_successor(k, b))

-- Theorem: a + b = b + a. Induction on a.
theorem Natural.add_commutative : (a b : Natural) → a + b = b + a
  | zero, b =>
      Equality.symmetry(Natural.add_zero(b))
  | successor(k), b =>
      Equality.transitivity(
          congruenceOf(successor, Natural.add_commutative(k, b)),
          Equality.symmetry(Natural.add_successor(b, k)))

-- Theorem: 0 * a = 0. Definitional.
theorem Natural.zero_multiply(a : Natural) : zero * a = zero :=
  reflexivity(zero)

-- Theorem: a * 0 = 0. By induction on a.
theorem Natural.multiply_zero : (a : Natural) → a * zero = zero
  | zero         => reflexivity(zero)
  | successor(k) => Natural.multiply_zero(k)

-- Theorem: 1 * a = a. Reduces to add_zero on a.
theorem Natural.one_multiply(a : Natural) : one * a = a :=
  Natural.add_zero(a)

-- Theorem: a * successor(b) = a + (a * b).
-- Axiomatised — its proof requires arithmetic chains not yet at hand.
axiom Natural.multiply_successor
        : (a b : Natural) → a * successor(b) = a + a * b

-- Theorem: a * b = b * a. Induction on a.
theorem Natural.multiply_commutative
        : (a b : Natural) → a * b = b * a
  | zero, b =>
      Equality.symmetry(Natural.multiply_zero(b))
  | successor(k), b =>
      Equality.transitivity(
          congruenceOf(fun x => b + x,
                       Natural.multiply_commutative(k, b)),
          Equality.symmetry(Natural.multiply_successor(b, k)))

-- Theorem: (a + b) + c = a + (b + c). Induction on a.
theorem Natural.add_associative
        : (a b c : Natural) → (a + b) + c = a + (b + c)
  | zero,         b, c => reflexivity(b + c)
  | successor(k), b, c =>
      congruenceOf(successor, Natural.add_associative(k, b, c))

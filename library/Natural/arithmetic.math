-- Natural/arithmetic.math
--
-- Identities about Natural arithmetic. Builds toward the
-- "Natural is a commutative semiring" claim.
--
-- Surface sugar in play:
--   a + b        desugars to  Natural.add(a, b)
--   a * b        desugars to  Natural.multiply(a, b)
--   1 + n        is the preferred spelling of successor(n) (kernel-defeq)
-- The proofs themselves stay in math-like form — `calc`, `substituting`,
-- `by_induction`, `ring` — and never reach for the raw transport primitives.
--
-- We use single-letter `a`, `b`, `c` for generic operand parameters of
-- arithmetic theorems (math convention, no specific role beyond "a
-- natural number"). In pattern destructuring of `successor(...)` the
-- bound argument is named `predecessor` since that IS its role.

module Natural.arithmetic

import Natural.basics
import Natural.peano
import Equality.basics

-- Theorem: 0 + a = a. Definitional.
theorem Natural.zero_add(a : Natural) : 0 + a = a :=
  done by unfolding Natural.add

-- Theorem: a + 0 = a. By induction on a.
theorem Natural.add_zero (a : Natural) : a + 0 = a :=
  unfold Natural.add in
  by_induction on a with IH {
    case zero: done
    case successor(predecessor): IH
  }

-- Theorem: 1 + a = successor(a). Definitional.
automatic theorem Natural.one_add(a : Natural) : 1 + a = successor(a) :=
  done by unfolding Natural.add

-- Theorem: a + successor(b) = successor(a + b). Mirror of the definitional
-- rule for add on the first argument.
theorem Natural.add_successor (a b : Natural)
        : a + successor(b) = successor(a + b) :=
  unfold Natural.add in
  by_induction on a with IH {
    case zero: done
    case successor(predecessor): IH
  }

-- Theorem: successor(a) + b = successor(a + b). Definitional —
-- `Natural.add` recurses on the first arg's successor pattern. Exposed
-- as a lemma so the hammer can rewrite via it without relying on the
-- elaborator to perform deep definitional reduction.
theorem Natural.successor_add (a b : Natural)
        : successor(a) + b = successor(a + b) :=
  done by unfolding Natural.add

-- Theorem: a + 1 = successor(a). The mirror of `one_add` with the unit on
-- the right; needed because `Natural.add` recurses on its first argument,
-- so `a + 1` does not reduce on its own. (The `ring` tactic's numeral
-- machinery cites this to bridge a literal to its add-form under opacity.)
theorem Natural.add_one (a : Natural) : a + 1 = successor(a) :=
  calc a + 1
     = successor(a + 0)
     = successor(a)

-- Theorem: (a + b) + c = a + (b + c). Induction on a.
theorem Natural.add_associative (a b c : Natural)
        : (a + b) + c = a + (b + c) :=
  unfold Natural.add in
  by_induction on a with IH {
    case zero: done
    case successor(predecessor): IH
  }

-- Theorem: a + b = b + a. Induction on a.
automatic theorem Natural.add_commutative (a b : Natural) : a + b = b + a :=
  unfold Natural.add in
  by_induction on a with IH {
    case zero:
        calc 0 + b
           = b
           = b + 0
    case successor(predecessor):
        -- successor(predecessor) + b ≡ successor(predecessor + b), so the
        -- calc chain starts with the reduced form.
        calc successor(predecessor + b)
           = successor(b + predecessor) since IH
           = b + successor(predecessor)
  }

-- Theorem: 0 * a = 0. Definitional.
theorem Natural.zero_multiply(a : Natural) : 0 * a = 0 :=
  done by unfolding Natural.add

-- Theorem: a * 0 = 0. By induction on a.
theorem Natural.multiply_zero (a : Natural) : a * 0 = 0 :=
  unfold Natural.add in
  by_induction on a with IH {
    case zero: done
    case successor(predecessor): IH
  }

-- Theorem: 1 * a = a. 1 * a reduces to a + 0, which is a.
theorem Natural.one_multiply(a : Natural) : 1 * a = a :=
  calc 1 * a
     = a + 0
     = a

-- Theorem: successor(a) * b = b + a * b. Definitional —
-- `Natural.multiply` recurses on the first arg's successor pattern.
-- Exposed as a lemma so the hammer can rewrite via it without
-- relying on the elaborator to perform deep ι-reduction.
theorem Natural.successor_multiply (a b : Natural)
        : successor(a) * b = b + a * b :=
  done by unfolding Natural.add

-- Theorem: a * successor(b) = a + a * b. By induction on a. The successor
-- case rewrites predecessor * successor(b) via the IH, then rearranges by
-- single-position associativity/commutativity (auto-closed).
theorem Natural.multiply_successor (a b : Natural)
        : a * successor(b) = a + a * b :=
  unfold Natural.add in
  by_induction on a with IH {
    case zero: done
    case successor(predecessor):
        calc successor(b + predecessor * successor(b))
           = successor(b + (predecessor + predecessor * b)) since IH
           = successor((b + predecessor) + predecessor * b)
           = successor((predecessor + b) + predecessor * b)
           = successor(predecessor + (b + predecessor * b))
  }

-- Theorem: a * b = b * a. Induction on a.
automatic theorem Natural.multiply_commutative (a b : Natural) : a * b = b * a :=
  unfold Natural.add in
  by_induction on a with IH {
    case zero:
        calc 0 * b
           = 0
           = b * 0
    case successor(predecessor):
        -- successor(predecessor) * b ≡ b + predecessor * b. Rewrite the
        -- right summand via IH, then collapse to b * successor(predecessor)
        -- (the reverse of multiply_successor).
        calc b + predecessor * b
           = b + b * predecessor since IH
           = b * successor(predecessor)
  }

-- Theorem: a * 1 = a. From commutativity + one_multiply.
theorem Natural.multiply_one(a : Natural) : a * 1 = a :=
  calc a * 1
     = 1 * a
     = a

-- Distributivity (right): (a + b) * c = a * c + b * c. Induction on a.
-- Leverages that successor(_) * m and zero * m reduce definitionally
-- on the first argument; the only non-definitional step is the
-- inductive hypothesis and a single add_associative rearrangement.
theorem Natural.distributivity_right (a b c : Natural)
        : (a + b) * c = a * c + b * c :=
  unfold Natural.add in
  by_induction on a with IH {
    case zero: done
    case successor(predecessor):
        -- (successor(p) + b) * c ≡ c + (p + b) * c. Apply the IH on
        -- (p + b) * c, then re-associate.
        calc c + (predecessor + b) * c
           = c + (predecessor * c + b * c) since IH
           = (c + predecessor * c) + b * c
  }

-- Distributivity (left): a * (b + c) = a * b + a * c. From the right
-- version and commutativity. `ring` looks this name up directly (it
-- expects both distributivity_left and distributivity_right registered
-- for a carrier), so its absence is what stopped `ring` from normalising
-- products of sums over Natural.
theorem Natural.distributivity_left (a b c : Natural)
        : a * (b + c) = a * b + a * c :=
  calc a * (b + c)
     = (b + c) * a
     = b * a + c * a
     = a * b + c * a
     = a * b + a * c

-- Theorem: (a * b) * c = a * (b * c). Induction on a, using
-- distributivity_right for the successor case.
automatic theorem Natural.multiply_associative (a b c : Natural)
        : (a * b) * c = a * (b * c) :=
  unfold Natural.add in
  by_induction on a with IH {
    case zero: done
    case successor(predecessor):
        calc (b + predecessor * b) * c
           = b * c + (predecessor * b) * c
           = b * c + predecessor * (b * c) since IH
  }

-- Cancellation on the left of addition. Proof by induction on `a`:
-- the zero case is definitional (zero + x ≡ x for any x), and the
-- successor case rewrites both sides of the equation to
-- successor(predecessor + …) form (also definitional) and peels off
-- the successor with successor_injective before recursing.
automatic theorem Natural.add_cancel_left (a b c : Natural)
        (equalityHypothesis : a + b = a + c) : b = c :=
  unfold Natural.add in
  by_induction on a with IH refining b, c, equalityHypothesis {
    case zero:
        -- 0 + b ≡ b and 0 + c ≡ c, so the hypothesis is already b = c.
        equalityHypothesis
    case successor(predecessor): {
        -- successor(predecessor) + x ≡ successor(predecessor + x), so the
        -- hypothesis is successor(predecessor + b) = successor(predecessor + c);
        -- strip the leading successor, then cancel predecessor inductively.
        claim predecessor + b = predecessor + c;
        done since IH
      }
  }

-- Cancel the common right-hand summand. Reuses add_cancel_left after
-- rotating both sides via commutativity.
theorem Natural.add_cancel_right (a b c : Natural)
        (equality : a + c = b + c) : a = b := {
  calc c + a
     = a + c
     = b + c
     = c + b;
  done since Natural.add_cancel_left
}

-- Left distributivity: d * (a + b) = d * a + d * b. Derived from
-- right distributivity plus commutativity.
theorem Natural.multiply_distributes_left_over_add
        (d a b : Natural)
        : d * (a + b) = d * a + d * b :=
  calc d * (a + b)
     = (a + b) * d
     = a * d + b * d
     = d * a + d * b

-- "Two-pair swap": (p + q) + (r + s) = (p + r) + (q + s). Swap the
-- inner two elements between the outer pairs. Used in quotient
-- equivalence-respect proofs where we want `(a + b') + (c + d)`
-- forms from `(a + c) + (b' + d)`.
theorem Natural.add_two_two_swap (p q r s : Natural)
        : (p + q) + (r + s) = (p + r) + (q + s) := ring

-- "Four-term swap": (a + b) + (c + d) = (a + d) + (c + b). Useful
-- whenever we have a sum of two sums and want to rearrange which
-- elements pair up. Proof is a calc chain of associativity and
-- commutativity moves.
theorem Natural.add_four_swap (a b c d : Natural)
        : (a + b) + (c + d) = (a + d) + (c + b) := ring

-- ----------------------------------------------------------------------
-- A sum/product is zero only if a factor is. (Relocated from
-- Integer/sign.math, where they were declared but are pure-Natural facts;
-- a Natural lemma belongs in a Natural/ module.)

-- a + b = 0 implies a = 0.
theorem Natural.add_eq_zero_left_zero
        : ∀ (a b : Natural). a + b = 0 → a = 0
  | zero, _, _ =>
      done
  | successor(k), b, equation => {
      claim isZero : successor(k + b) = 0 by substituting Natural.successor_add;
      absurd(isZero)
    }

-- And the right component.
automatic theorem Natural.add_eq_zero_right_zero
        (a b : Natural) (equation : a + b = 0) : b = 0 :=
  { done by Natural.add_eq_zero_left_zero }

-- Every natural is either zero or one more than its predecessor — the
-- `n + 1` form of zero_or_successor, so consumers split a Natural without
-- naming the constructor.
theorem Natural.zero_or_add_one (n : Natural)
        : n = 0 ∨ ∃ (k : Natural). n = k + 1 :=
  cases n {
    | zero         => done
    | successor(k) => {
        claim successorEq : successor(k) = k + 1 by substituting Natural.add_one;
        claim ∃ (predecessor : Natural). successor(k) = predecessor + 1
            by witness k with successorEq;
        done
      }
  }

-- a * (d + 1) = 0 implies a = 0.
theorem Natural.multiply_add_one_eq_zero_left_zero
        : ∀ (a d : Natural). a * (d + 1) = 0 → a = 0
  | zero, _, _ =>
      done
  | successor(k), d, equation => {
      -- (k + 1) * (d + 1) reduces to a successor — never zero.
      claim isZero : successor(d + k * successor(d)) = 0;
      absurd(isZero)
    }

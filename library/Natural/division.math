-- Natural/division.math
--
-- Division-with-remainder on Natural: for any divisor b ≥ 1 and
-- dividend a, there is a unique pair (q, r) with a = q·b + r and
-- r < b. We do not name `quotient` and `mod` directly; we prove the
-- existential and let callers `choose` the witnesses where needed.
--
-- The proof is by strong induction on a: if a < b, take q = 0, r = a;
-- otherwise b ≤ a, so subtraction gives c with a = b + c, the
-- induction hypothesis at c gives (q', r'), and (q' + 1, r') witnesses
-- the conclusion at a.
--
-- One helper (`Natural.trichotomy`) goes here too: the dichotomy
-- "a < b ∨ b ≤ a" is the case-split needed at every induction step.

module Natural.division

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.subtraction
import Natural.strong_recursion
import Natural.multiply_order

-- ----------------------------------------------------------------------
-- Trichotomy: for every pair of naturals, either the first is strictly
-- less than the second, or the second is ≤ the first.

theorem Natural.trichotomy_zero_against (b : Natural)
        : successor(0) ≤ b ∨ b ≤ 0 :=
  cases b {
    | zero => {
        -- 0 ≤ 0, the right disjunct.
        (0 : Natural) ≤ 0;
        done
      }
    | successor(predB) => {
        -- 1 ≤ successor(predB) since 0 ≤ predB, the left disjunct.
        0 ≤ predB;
        successor(0) ≤ successor(predB);
        done
      }
  }

theorem Natural.trichotomy_successor_against
        (predA : Natural)
        (trichotomyPredA :
            ∀ (b : Natural). successor(predA) ≤ b ∨ b ≤ predA)
        (b : Natural)
        : successor(successor(predA)) ≤ b ∨ b ≤ successor(predA) :=
  cases b {
    | zero => {
        -- 0 ≤ successor(predA), the right disjunct.
        (0 : Natural) ≤ successor(predA);
        done
      }
    | successor(predB) => {
        (successor(predA) ≤ predB) ∨ (predB ≤ predA);
        done by cases {
          case successor(predA) ≤ predB as predAStrictlyBelowPredB: {
              successor(successor(predA)) ≤ successor(predB);
              done
            }
          case predB ≤ predA as predBLessOrEqualPredA: {
              successor(predB) ≤ successor(predA);
              done
            }
        }
      }
  }

theorem Natural.trichotomy (a : Natural)
        : ∀ (b : Natural). successor(a) ≤ b ∨ b ≤ a :=
  by induction on a with IH {
    case zero: {
        take b : Natural;
        done
      }
    case successor(predA): {
        take b : Natural;
        -- IH gives trichotomy at predA; the successor helper lifts it.
        done
      }
  }

-- The successor-free trichotomy: a < b or b ≤ a.
theorem Natural.lt_or_le (a b : Natural) : a < b ∨ b ≤ a := {
  successor(a) ≤ b ∨ b ≤ a;
  done by cases {
    case successor(a) ≤ b as successorLessOrEqual: {
        a < b;
        done
      }
    case b ≤ a as lessOrEqual: done
  }
}

-- ----------------------------------------------------------------------
-- The division-with-remainder predicate. Existence of a quotient/
-- remainder pair for the given divisor and dividend.
definition Natural.has_quotient_remainder
        (divisor dividend : Natural) : Proposition :=
    ∃ (quotient : Natural). ∃ (remainder : Natural).
        dividend = quotient * divisor + remainder
        ∧ remainder < divisor

-- ----------------------------------------------------------------------
-- Recurse-case kernel: from `dividend = divisor + smallerDividend` and
-- a quotient/remainder decomposition of `smallerDividend`, build the
-- decomposition of `dividend` by bumping the quotient.
--
-- Algebraically:
--   dividend = divisor + (q' · divisor + r')
--            = (divisor + q' · divisor) + r'
--            = successor(q') · divisor + r'         (definitional)
theorem Natural.divide_with_remainder_recurse_step
        (divisor dividend smallerDividend
            recursedQuotient recursedRemainder : Natural)
        (dividendEqualsDivisorPlusSmaller
            : dividend = divisor + smallerDividend)
        (smallerDecomposition
            : smallerDividend
              = recursedQuotient * divisor + recursedRemainder)
        : dividend = successor(recursedQuotient) * divisor + recursedRemainder :=
  dividend
     = divisor + smallerDividend
     = divisor + (recursedQuotient * divisor + recursedRemainder)
     = (divisor + recursedQuotient * divisor) + recursedRemainder
     = successor(recursedQuotient) * divisor + recursedRemainder

-- Given a decomposition `dividend = divisor + smallerDividend` and the
-- IH at smallerDividend, build the quotient/remainder witness for
-- dividend. Just unpacks the nested existentials and re-wraps with the
-- bumped quotient.
theorem Natural.divide_with_remainder_recurse_case
        (divisor : Natural) (dividend smallerDividend : Natural)
        (dividendEqualsDivisorPlusSmaller
            : dividend = divisor + smallerDividend)
        (smallerWitness
            : Natural.has_quotient_remainder(divisor, smallerDividend))
        : Natural.has_quotient_remainder(divisor, dividend) := {
    choose recursedQuotient such that
        ∃ (remainder : Natural).
            smallerDividend = recursedQuotient * divisor + remainder
            ∧ remainder < divisor
        from smallerWitness;
    choose recursedRemainder such that
        smallerDividend = recursedQuotient * divisor + recursedRemainder
        ∧ recursedRemainder < divisor;
    -- Bump the quotient by one to absorb the extra `divisor`.
    dividend = successor(recursedQuotient) * divisor + recursedRemainder
        ∧ recursedRemainder < divisor
        as decomposition;
    witness successor(recursedQuotient) with witness recursedRemainder with decomposition
}

-- Base case: dividend < divisor. Take quotient = 0 and remainder =
-- dividend. The equation `dividend = 0 · divisor + dividend` reduces
-- definitionally to `dividend = dividend` (multiply on zero first arg
-- reduces to zero, and add on zero first arg is the identity).
theorem Natural.divide_with_remainder_base_case
        (divisor dividend : Natural)
        (dividendBelowDivisor : dividend < divisor)
        : Natural.has_quotient_remainder(divisor, dividend) :=
  witness 0 with witness dividend with done

-- Strong-induction step. With the IH covering every k < dividend,
-- and the trichotomy between dividend and divisor, dispatch to the
-- base case or the recurse case.
theorem Natural.divide_with_remainder_step
        (divisor : Natural) (positiveDivisor : 1 ≤ divisor)
        (dividend : Natural)
        (inductionHypothesis :
            ∀ (k : Natural).
            k < dividend
            → Natural.has_quotient_remainder(divisor, k))
        : Natural.has_quotient_remainder(divisor, dividend) := {
  (successor(dividend) ≤ divisor) ∨ (divisor ≤ dividend);
  done by cases {
    case successor(dividend) ≤ divisor as dividendBelowDivisor: {
        dividend < divisor;
        done
      }
    case divisor ≤ dividend as divisorBelowOrEqualDividend: {
        choose smallerDividend such that dividend = divisor + smallerDividend
            from Natural.subtraction_witness;
        -- smallerDividend < dividend (since divisor ≥ 1), so the IH applies.
        successor(smallerDividend) ≤ smallerDividend + divisor;
        dividend
           = divisor + smallerDividend
           = smallerDividend + divisor
          as dividendEqualsSmallerPlusDivisor;
        successor(smallerDividend) ≤ dividend
            by substituting dividendEqualsSmallerPlusDivisor;
        smallerDividend < dividend;
        Natural.has_quotient_remainder(divisor, smallerDividend)
            by inductionHypothesis;
        done
      }
  }
}

-- Main theorem: division-with-remainder.
theorem Natural.divide_with_remainder
        (divisor : Natural) (positiveDivisor : 1 ≤ divisor)
        (dividend : Natural)
        : Natural.has_quotient_remainder(divisor, dividend) :=
  by induction on dividend using Natural.strong_induction
      with subject, inductionHypothesis {
    done
  }

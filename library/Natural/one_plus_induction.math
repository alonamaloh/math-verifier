-- Natural/induction.math
--
-- The `1 + n` induction principle — the keystone of the successor-sealing
-- transition (PLAN_LUX_TRANSITION.md, Phase 0). It proves a motive for
-- every Natural from its value at `0` and a step that goes from `k` to
-- `1 + k`, never naming the `successor` constructor. `by induction` will
-- desugar to this so that a consumer's inductive step proves `P(1 + k)`
-- from `IH : P(k)` and no `successor` token ever appears in user space.
--
-- This is the *one* place the constructor-level recursor is legitimately
-- visible outside the core: we bootstrap the `1 + n` principle from the
-- ordinary (successor-form) induction here, bridging `1 + k = successor(k)`
-- with the definitional `Natural.one_add`.

module Natural.one_plus_induction

import Natural.basics
import Natural.arithmetic
import Equality.basics

-- The step yields `P(1 + k)`; the recursor's successor case demands
-- `P(successor(k))`. They are bridged by `Natural.one_add : 1 + k =
-- successor(k)`, transporting the step's result onto the constructor form.
theorem Natural.induction_on_one_plus
        {P : ℕ → Proposition}
        (base : P(0))
        (step : ∀ (k : ℕ). P(k) → P(1 + k))
        (n : ℕ) : P(n) :=
  unfold ℕ in
  by induction on n with IH {
    case zero: base
    case successor(k): {
        -- the step gives P(1 + k); `1 + k = successor(k)` bridges to the
        -- constructor form the recursor demands.
        P(1 + k) by step(k, IH);
        done
      }
  }

-- The `n + 1` twin: the same principle with the step stated in the
-- `k + 1` spelling, so consumers pick whichever form their goal speaks
-- (there is no house preference between `1 + n` and `n + 1`).
theorem Natural.induction_on_plus_one
        {P : ℕ → Proposition}
        (base : P(0))
        (step : ∀ (k : ℕ). P(k) → P(k + 1))
        (n : ℕ) : P(n) :=
  unfold ℕ in
  by induction on n with IH {
    case zero: base
    case successor(k): {
        P(k + 1) by step(k, IH);
        done
      }
  }

-- Case analysis without an induction hypothesis: every natural is `0`
-- or `1 + k`. The boundary form of `cases` on a Natural — proofs that
-- only need the split cite this and never touch the constructors.
theorem Natural.cases_on_one_plus
        {P : ℕ → Proposition}
        (base : P(0))
        (step : ∀ (k : ℕ). P(1 + k))
        (n : ℕ) : P(n) :=
  unfold ℕ in
  by induction on n with IH {
    case base:    base
    case step(k): step(k)
  }

-- The constructor-spelled principle: what a `by induction` block in the
-- `case zero:` / `case successor(k):` vocabulary (or the equation
-- spellings that desugar to it) elaborates through wherever this lemma
-- is in scope, so the raw recursor stays confined to this module.
-- Proved from the `1 + n` principle — the explicit `base`/`step`
-- vocabulary below routes there, never to this theorem itself.
theorem Natural.induction_on_successor
        {P : ℕ → Proposition}
        (base : P(0))
        (step : ∀ (k : ℕ). P(k) → P(successor(k)))
        (n : ℕ) : P(n) :=
  unfold ℕ in
  by induction on n with IH {
    case base: base
    case step(k): {
        P(successor(k)) by step(k, IH);
        done
      }
  }

-- Its case-analysis twin, for a `by cases { case n = 0: … case n =
-- successor(k) for some k: … }` split — no induction hypothesis.
theorem Natural.cases_on_successor
        {P : ℕ → Proposition}
        (base : P(0))
        (step : ∀ (k : ℕ). P(successor(k)))
        (n : ℕ) : P(n) :=
  unfold ℕ in
  by induction on n with IH {
    case base: base
    case step(k): {
        P(successor(k)) by step(k);
        done
      }
  }

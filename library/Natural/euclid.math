-- Natural/euclid.math
--
-- Euclid's theorem: for any list of primes, there exists a prime not
-- in the list — so the primes are not finitely enumerable.
--
-- Construction: take N = successor(productOf(primes)). N ≥ 2 because
-- the product of a list of primes is ≥ 1. By `has_prime_divisor`, N
-- has a prime divisor q. Then q is not in the list: if it were, q
-- would divide the product, and also divides N = product + 1; by
-- `Natural.divides_consecutive_implies_one`, q would divide 1,
-- contradicting q ≥ 2 (from primality).
--
-- One helper lemma lives here too: `NaturalList.productOf_at_least_one`
-- (positivity of the list product when every element is prime). The
-- closely-related `Natural.multiply_at_least_one` lives in
-- `Natural/multiply_order.math` since both Euclid and factorization
-- use it.

module Natural.euclid

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.divisibility
import Natural.strong_recursion
import Natural.multiply_order
import Natural.prime
import Natural.prime_divisor
import Lists.basics

-- The product of a list of primes is at least 1. Empty case is
-- reflexivity on 1; prepend case multiplies head (≥ 2 because prime)
-- with the induction hypothesis on the tail.
theorem NaturalList.productOf_at_least_one
        : (list : NaturalList)
          → ((p : Natural) → NaturalList.member(p, list)
              → Natural.is_prime(p))
          → 1 ≤ NaturalList.productOf(list)
  | NaturalList.empty, _ =>
      LessOrEqual.reflexivity(1)
  | NaturalList.prepend(head, tail), allPrime =>
      Natural.multiply_at_least_one(
          head, NaturalList.productOf(tail),
          LessOrEqual.transitive(1, 2, head,
            And.left(?, ?,
                allPrime(head, NaturalList.member.here(tail))),
            Natural.one_less_or_equal_two),
          NaturalList.productOf_at_least_one(tail,
            function (p : Natural)
                (memberOfTail : NaturalList.member(p, tail)) =>
              allPrime(p,
                NaturalList.member.there(head, tail, memberOfTail))))

-- Euclid's theorem. Let n be the product of all the primes, plus one.
-- By has_prime_divisor, n has a prime divisor q. q is our witness: it
-- is prime, and we show it is not in `primes` by contradiction —
-- suppose otherwise; then q divides the product, and also divides
-- n = product + 1, so q divides 1 — but q ≥ 2 from primality.
theorem Natural.infinitely_many_primes
        (primes : NaturalList)
        (allPrime : ∀ (p : Natural).
                      NaturalList.member(p, primes)
                      → Natural.is_prime(p))
        : ∃ (q : Natural).
            Natural.is_prime(q) ∧ ¬NaturalList.member(q, primes) := {
  set n := successor(NaturalList.productOf(primes));
  claim nAtLeastTwo : 2 ≤ n
    by Natural.successor_less_or_equal_successor(?, ?,
           NaturalList.productOf_at_least_one(primes, allPrime));
  obtain ⟨q, qIsPrime, qDividesN⟩
    from Natural.has_prime_divisor(n, nAtLeastTwo);
  witness q with ⟨qIsPrime, {
    suppose NaturalList.member(q, primes) as qInPrimes;
    claim qAtLeastTwo : 2 ≤ q
      by And.left(?, ?, qIsPrime);
    cases Natural.divides_less_or_equal_or_zero(?, ?,
              Natural.divides_consecutive_implies_one(
                  q, NaturalList.productOf(primes),
                  NaturalList.member_divides_product(
                      q, primes, qInPrimes),
                  qDividesN)) {
      case Or.introduceLeft(oneEqualsZero):
          Natural.successor_not_zero(?, oneEqualsZero);
      case Or.introduceRight(qLessOrEqualOne):
          Natural.not_less_or_equal_successor_zero(
              0,
              Natural.less_or_equal_successor_successor_descend(
                  1, 0,
                  LessOrEqual.transitive(
                      2, q, 1, qLessOrEqualOne, qAtLeastTwo)));
    }
  }⟩
}

-- Natural/euclid.math
--
-- Euclid's theorem: for any list of primes, there exists a prime not
-- in the list — so the primes are not finitely enumerable.
--
-- Construction: take N = 1 + productOf(primes). N ≥ 2 because
-- the product of a list of primes is ≥ 1. By `has_prime_divisor`, N
-- has a prime divisor q. Then q is not in the list: if it were, q
-- would divide the product, and also divides N = product + 1; by
-- `Natural.divides_consecutive_implies_one`, q would equal 1,
-- contradicting q ≥ 2 (from primality).
--
-- One helper lemma lives here too: `NaturalList.productOf_at_least_one`
-- (positivity of the list product when every element is prime). The
-- closely-related `Natural.multiply_at_least_one` lives in
-- `Natural/multiply_order.math` since both Euclid and factorization
-- use it.

module Natural.euclid

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.divisibility
import Natural.strong_recursion
import Natural.multiply_order
import Natural.prime
import Natural.prime_divisor
import Lists.basics

-- The product of a list of primes is at least 1. Empty case is
-- reflexivity on 1; prepend case multiplies head (≥ 2 because prime)
-- with the induction hypothesis on the tail.
theorem NaturalList.productOf_at_least_one (list : NaturalList)
        (allPrime : ∀ (p : Natural). NaturalList.member(p, list)
                    → Natural.is_prime(p))
        : 1 ≤ NaturalList.productOf(list) :=
  by_induction on list with IH refining allPrime {
    case NaturalList.empty:
        done
    case NaturalList.prepend(head, tail): {
        -- head is prime, so 2 ≤ head, hence 1 ≤ head; and 1 ≤ productOf(tail)
        -- by the IH on the tail (every tail member is also a list member).
        Natural.is_prime(head)
            by allPrime(head, NaturalList.member.here(tail));
        1 ≤ 2 ≤ head;
        1 ≤ NaturalList.productOf(tail)
            by IH((p : Natural)
                       (memberOfTail : NaturalList.member(p, tail)) ↦
                     allPrime(p,
                         NaturalList.member.there(head, tail, memberOfTail)));
        -- productOf(prepend(head, tail)) ≡ head * productOf(tail).
        change 1 ≤ head * NaturalList.productOf(tail);
        done
      }
  }

-- No natural number is both at least 2 and at most 1: descend `2 ≤ 1` to
-- `1 ≤ 0`, which `absurd` refutes.
theorem Natural.not_two_less_or_equal_one : ¬(2 ≤ 1) := {
  suppose 2 ≤ 1 as twoLessOrEqualOne;
  1 ≤ 0 as oneLessOrEqualZero;
  absurd(oneLessOrEqualZero)
}

-- 1 is the only divisor of 1. `divides_less_or_equal_or_zero` bounds the
-- divisor by 1 (the "1 = 0" alternative is vacuous); casing on it rules
-- out 0 (a zero divisor would force 1 = 0) and leaves exactly 1.
theorem Natural.one_is_only_divisor_of_one (d : Natural) (dividesOne : d ∣ 1)
        : d = 1 := {
  (1 : Natural) = 0 ∨ d ≤ 1;
  claim by cases {
    in ((1 : Natural) = 0) as oneEqualsZero: absurd(oneEqualsZero)
    in (d ≤ 1) as dAtMostOne:
        cases d refining dAtMostOne, dividesOne {
          | zero => {
              choose quotient such that (1 : Natural) = 0 * quotient from dividesOne;
              absurd(calc (1 : Natural) = 0 * quotient = 0)
            }
          | successor(dPredecessor) => {
              -- d ≤ 1 forces dPredecessor ≤ 0, so dPredecessor = 0 and d = 1.
              dPredecessor ≤ 0;
              dPredecessor = 0;
              done
            }
        }
  }
}

-- Euclid's theorem. Let n be the product of all the primes, plus one.
-- By has_prime_divisor, n has a prime divisor q. q is our witness: it
-- is prime, and we show it is not in `primes` by contradiction —
-- suppose otherwise; then q divides the product, and also divides
-- n = product + 1, so q divides 1 — but q ≥ 2 from primality.
theorem Natural.infinitely_many_primes
        (primes : NaturalList)
        (allPrime : ∀ (p : Natural).
                      NaturalList.member(p, primes)
                      → Natural.is_prime(p))
        : ∃ (q : Natural).
            Natural.is_prime(q) ∧ ¬NaturalList.member(q, primes) := {
  -- Let n be one more than the product of all the listed primes.
  set n := 1 + NaturalList.productOf(primes);
  1 ≤ NaturalList.productOf(primes);
  -- Then n ≥ 2, so it has a prime divisor q.
  2 ≤ n;
  choose q such that Natural.is_prime(q) ∧ q ∣ n from Natural.has_prime_divisor;
  -- q is our witness: it is prime, and we show it is not in the list.
  witness q with {
    ¬NaturalList.member(q, primes) by {
      -- Suppose, for contradiction, that q is already listed. Then q divides
      -- the product of the list, and also divides n = product + 1, so q
      -- divides 1, forcing q = 1 — but q ≥ 2 since q is prime.
      suppose NaturalList.member(q, primes) as qInPrimes;
      q ∣ NaturalList.productOf(primes) by NaturalList.member_divides_product;
      q = 1 by Natural.divides_consecutive_implies_one as qEqualsOne;
      2 ≤ q;
      2 ≤ 1 by substituting qEqualsOne;
      done by Natural.not_two_less_or_equal_one
    };
    done
  }
}

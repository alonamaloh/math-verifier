-- Natural/factorization.math
--
-- Existence of prime factorization: every n ≥ 1 can be written as a
-- product of primes (allowing the empty product, which is 1).
--
-- Construction is strong induction on n. The base case (n = 1) returns
-- the empty list — its product is 1. For n ≥ 2, `has_prime_divisor`
-- supplies a prime p dividing n; the quotient q = n/p satisfies
-- 1 ≤ q < n, so the induction hypothesis gives a factorization of q;
-- prepending p produces a factorization of n.

module Natural.factorization

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.divisibility
import Natural.strong_recursion
import Natural.multiply_order
import Natural.prime
import Natural.prime_divisor
import Lists.basics

-- ----------------------------------------------------------------------
-- Helpers (arithmetic + order facts not yet in the upstream modules).

-- Every natural is either zero or ≥ 1.
theorem Natural.is_zero_or_at_least_one
        : ∀ (k : Natural). k = 0 ∨ 1 ≤ k
  | zero                    => okay
  | successor(kPredecessor) => {
      claim 1 ≤ successor(kPredecessor) by Natural.successor_positive;
      done
    }

-- 1 ≤ n splits into n = 1 ∨ 2 ≤ n. Pattern-match on n: zero
-- contradicts the hypothesis, successor(predN) re-splits via
-- is_zero_or_at_least_one on predN.
theorem Natural.equals_one_or_at_least_two
        : ∀ (n : Natural). 1 ≤ n → n = 1 ∨ 2 ≤ n
  | zero, oneLessOrEqualZero =>
      absurd(oneLessOrEqualZero)
  | successor(nPredecessor), _ =>
      claim by cases {
        in (nPredecessor = 0) as predecessorIsZero:
            -- n = successor(0) = 1, the left disjunct.
            calc successor(nPredecessor) = 1
        in (1 ≤ nPredecessor) as predecessorPositive: {
            -- 1 ≤ nPredecessor lifts to 2 ≤ successor(nPredecessor), the right.
            claim 2 ≤ successor(nPredecessor)
                by Natural.successor_less_or_equal_successor;
            done
          }
      }

-- If 1 ≤ n and n = p * q, then 1 ≤ q. By cases on q: q = 0 forces
-- n = p * 0 = 0, contradicting 1 ≤ n. (p and n live outside the
-- pattern-match so the inducted-on argument q is in first position.)
theorem Natural.right_factor_at_least_one
        (p n : Natural)
        : ∀ (q : Natural). 1 ≤ n → n = p * q → 1 ≤ q
  | zero, oneLessOrEqualN, nEqualsPTimesZero =>
      calc 1 ≤ n = p * 0 = 0
  | successor(qPredecessor), _, _ =>
      okay

-- ----------------------------------------------------------------------
-- "All-prime" lift across `prepend`: if the head is prime and all
-- elements of `tail` are prime, then all elements of `prepend(head,
-- tail)` are prime. Pattern-matching on the `member` proof needs the
-- scrutinee's list-index to be a local variable, so we take `list` as
-- an outer binder with an equality witness `list = prepend(head, tail)`
-- and apply prepend-injectivity inside each branch.

theorem NaturalList.all_prime_under_prepend_equality
        (head : Natural) (tail : NaturalList)
        (headIsPrime : Natural.is_prime(head))
        (allPrimeTail : ∀ (k : Natural).
                        NaturalList.member(k, tail)
                        → Natural.is_prime(k))
        (candidate : Natural) (list : NaturalList)
        : NaturalList.member(candidate, list)
          → list = NaturalList.prepend(head, tail)
          → Natural.is_prime(candidate)
  | NaturalList.member.here(rest), listEquality => {
      -- From `here`, list = prepend(candidate, rest); combined with
      -- listEquality, prepend(candidate, rest) = prepend(head, tail),
      -- so candidate = head and is_prime(candidate) = is_prime(head).
      claim candidateEqualsHead : candidate = head;
      claim Natural.is_prime(candidate) by substituting candidateEqualsHead
    }
  | NaturalList.member.there(headInList, restInList, subMembership),
    listEquality => {
      -- From `there`, list = prepend(headInList, restInList); combined
      -- with listEquality, restInList = tail, so subMembership lifts to
      -- member(candidate, tail) via Equality.transport.
      claim restInListEqualsTail : restInList = tail;
      claim memberTail : NaturalList.member(candidate, tail)
        by substituting restInListEqualsTail;
      allPrimeTail(candidate, memberTail)
    }

-- Thin wrapper specialising the list to `prepend(head, tail)`. The citation
-- infers every argument from the hypotheses: matching the lemma's
-- `member(candidate, list)` premise against `membership` pins `list`, and
-- `headIsPrime` / `allPrimeTail` pin `head` / `tail`.
theorem NaturalList.all_prime_prepend
        (head : Natural) (tail : NaturalList)
        (headIsPrime : Natural.is_prime(head))
        (allPrimeTail : ∀ (k : Natural).
                        NaturalList.member(k, tail)
                        → Natural.is_prime(k))
        (candidate : Natural)
        (membership :
            NaturalList.member(candidate, NaturalList.prepend(head, tail)))
        : Natural.is_prime(candidate) :=
  claim

-- ----------------------------------------------------------------------
-- The main theorem.

theorem Natural.prime_factorization_exists
        (n : Natural) (atLeastOne : 1 ≤ n)
        : ∃ (list : NaturalList).
            (∀ (k : Natural).
             NaturalList.member(k, list)
             → Natural.is_prime(k))
            ∧ NaturalList.productOf(list) = n :=
  (by_induction on n using Natural.strong_induction
       with subject, inductionHypothesis {
     (subjectAtLeastOne : 1 ≤ subject) ↦ {
       claim by cases {
         -- subject = 1: the empty list works (its product is 1 = subject).
         in (subject = 1) as subjectEqualsOne:
             witness NaturalList.empty
                 with ⟨(k : Natural)
                                (memberOfEmpty :
                                    NaturalList.member(k, NaturalList.empty)) ↦ {
                         claim noMember : False by NaturalList.no_member_in_empty;
                         absurd(noMember)
                       },
                       calc NaturalList.productOf(NaturalList.empty) = subject⟩
         -- subject ≥ 2: peel off a prime divisor and recurse on the quotient.
         in (2 ≤ subject) as subjectAtLeastTwo: {
             obtain ⟨prime, primeIsPrime, primeDividesSubject⟩
               by Natural.has_prime_divisor;
             obtain ⟨quotient, subjectEqualsPrimeTimesQuotient⟩
               from primeDividesSubject;
             claim 2 ≤ prime;
             claim quotientAtLeastOne : 1 ≤ quotient;
             -- quotient < subject: subject = prime·quotient ≥ 2·quotient > quotient.
             claim successor(quotient) ≤ subject;
             claim quotient < subject by Natural.lt_of_successor_le;
             obtain ⟨tail, allPrimeTail, productOfTailEqualsQuotient⟩
               from inductionHypothesis(quotient, (quotient < subject))(
                        quotientAtLeastOne);
             witness NaturalList.prepend(prime, tail)
                 with ⟨(k : Natural)
                                (memberProof :
                                    NaturalList.member(
                                        k, NaturalList.prepend(prime, tail))) ↦ {
                         claim Natural.is_prime(k) by NaturalList.all_prime_prepend
                       },
                       calc prime * NaturalList.productOf(tail)
                          = prime * quotient
                          = subject⟩
         }
       }
     }
   }
   : 1 ≤ n
     → ∃ (list : NaturalList).
         (∀ (k : Natural).
          NaturalList.member(k, list)
          → Natural.is_prime(k))
         ∧ NaturalList.productOf(list) = n
   )(atLeastOne)

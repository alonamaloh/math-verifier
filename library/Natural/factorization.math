-- Natural/factorization.math
--
-- Existence of prime factorization: every n ≥ 1 can be written as a
-- product of primes (allowing the empty product, which is 1).
--
-- Construction is strong induction on n. The base case (n = 1) returns
-- the empty list — its product is 1. For n ≥ 2, `has_prime_divisor`
-- supplies a prime p dividing n; the quotient q = n/p satisfies
-- 1 ≤ q < n, so the induction hypothesis gives a factorization of q;
-- prepending p produces a factorization of n.

module Natural.factorization

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.divisibility
import Natural.strong_recursion
import Natural.multiply_order
import Natural.prime
import Natural.prime_divisor
import Natural.list_product
import Lists.list

-- ----------------------------------------------------------------------
-- Helpers (arithmetic + order facts not yet in the upstream modules).

-- Every natural is either zero or ≥ 1.
theorem Natural.is_zero_or_at_least_one (k : Natural) : k = 0 ∨ 1 ≤ k :=
  done by cases {
    case k = 0: okay
    case k = successor(kPredecessor) for some kPredecessor: {
        1 ≤ successor(kPredecessor);
        done
      }
  }

-- 1 ≤ n splits into n = 1 ∨ 2 ≤ n. Case-split on n: zero
-- contradicts the hypothesis, successor(nPredecessor) re-splits via
-- is_zero_or_at_least_one on nPredecessor.
automatic theorem Natural.equals_one_or_at_least_two
        (n : Natural) (positivity : 1 ≤ n) : n = 1 ∨ 2 ≤ n :=
  done by cases {
    case n = 0: {
        1 ≤ 0;
        False; done
      }
    case n = successor(nPredecessor) for some nPredecessor:
        done by cases {
          case nPredecessor = 0: done
          case 1 ≤ nPredecessor as predecessorPositive: {
              2 ≤ successor(nPredecessor);
              done
            }
        }
  }

-- If 1 ≤ n and n = p * q, then 1 ≤ q. By cases on q: q = 0 forces
-- n = p * 0 = 0, contradicting 1 ≤ n.
automatic theorem Natural.right_factor_at_least_one
        (p n : Natural) (q : Natural) (oneLessOrEqualN : 1 ≤ n) (nEqualsPTimesQ : n = p * q)
        : 1 ≤ q :=
  done by cases {
    case q = 0: 1 ≤ n = p * 0 = 0
    case q = successor(qPredecessor) for some qPredecessor: okay
  }

-- ----------------------------------------------------------------------
-- "All-prime" lift across `prepend`: if the head is prime and all
-- elements of `tail` are prime, then all elements of `prepend(head,
-- tail)` are prime. Pattern-matching on the `member` proof needs the
-- scrutinee's list-index to be a local variable, so we take `list` as
-- an outer binder with an equality witness `list = prepend(head, tail)`
-- and apply prepend-injectivity inside each branch.

theorem Natural.list_all_prime_under_prepend_equality
        (head : Natural) (tail : List(Natural))
        (headIsPrime : Natural.is_prime(head))
        (allPrimeTail : ∀ (k : Natural).
                        k ∈ tail
                        → Natural.is_prime(k))
        (candidate : Natural) (list : List(Natural))
        (memberProof : candidate ∈ list)
        : list = List.prepend(Natural, head, tail)
          → Natural.is_prime(candidate) :=
  by induction on memberProof {
    case List.member.here(rest):
        (listEquality : List.prepend(Natural, candidate, rest)
                        = List.prepend(Natural, head, tail)) ↦ {
          -- From `here`, list = prepend(candidate, rest); combined with
          -- listEquality, prepend(candidate, rest) = prepend(head, tail),
          -- so candidate = head and is_prime(candidate) = is_prime(head).
          candidate = head by List.prepend_injective_head;
          Natural.is_prime(candidate)
        }
    case List.member.there(headInList, restInList, subMembership):
        (listEquality : List.prepend(Natural, headInList, restInList)
                        = List.prepend(Natural, head, tail)) ↦ {
          -- From `there`, list = prepend(headInList, restInList); combined
          -- with listEquality, restInList = tail, so subMembership lifts to
          -- member(candidate, tail) via Equality.transport.
          restInList = tail by List.prepend_injective_tail;
          candidate ∈ tail as memberTail;
          allPrimeTail(candidate, memberTail)
        }
  }

-- Thin wrapper specialising the list to `prepend(head, tail)`. The citation
-- infers every argument from the hypotheses: matching the lemma's
-- `member(candidate, list)` premise against `membership` pins `list`, and
-- `headIsPrime` / `allPrimeTail` pin `head` / `tail`.
theorem Natural.list_all_prime_prepend
        (head : Natural) (tail : List(Natural))
        (headIsPrime : Natural.is_prime(head))
        (allPrimeTail : ∀ (k : Natural).
                        k ∈ tail
                        → Natural.is_prime(k))
        (candidate : Natural)
        (membership :
            candidate ∈ List.prepend(Natural, head, tail))
        : Natural.is_prime(candidate) :=
  done

-- ----------------------------------------------------------------------
-- The main theorem.

-- Strong induction needs the motive to carry the `1 ≤ subject` premise, so
-- the recursion lives in this helper; the public theorem below just feeds it
-- the hypothesis.
theorem Natural.prime_factorization_exists_helper (n : Natural)
        : 1 ≤ n
          → ∃ (list : List(Natural)).
              (∀ (k : Natural).
               k ∈ list
               → Natural.is_prime(k))
              ∧ Natural.listProduct(list) = n :=
  by induction on n using Natural.strong_induction
       with subject, inductionHypothesis {
     (subjectAtLeastOne : 1 ≤ subject) ↦
       done by cases {
         -- subject = 1: the empty list works (its product is 1 = subject).
         case subject = 1 as subjectEqualsOne:
             witness List.empty(Natural) with {
                 ∀ (k : Natural).
                         k ∈ List.empty(Natural) → Natural.is_prime(k)
                     by (k : Natural)
                            (memberOfEmpty : k ∈ List.empty(Natural)) ↦ {
                         False by List.no_member_empty as noMember;
                         absurd(noMember)
                       };
                 Natural.listProduct(List.empty(Natural)) = subject;
                 done
               }
         -- subject ≥ 2: peel off a prime divisor and recurse on the quotient.
         case 2 ≤ subject as subjectAtLeastTwo: {
             choose prime such that Natural.is_prime(prime) ∧ prime ∣ subject
               from Natural.has_prime_divisor;
             ∃ (factor : Natural). subject = prime * factor;
             choose quotient such that subject = prime * quotient;
             2 ≤ prime;
             1 ≤ quotient;
             quotient < prime * quotient;
             quotient < subject;
             choose tail such that
                 (∀ (k : Natural).
                  k ∈ tail → Natural.is_prime(k))
                 ∧ Natural.listProduct(tail) = quotient
               from inductionHypothesis(quotient, (quotient < subject))(1 ≤ quotient);
             witness List.prepend(Natural, prime, tail) with {
                 ∀ (k : Natural).
                         k ∈ List.prepend(Natural, prime, tail)
                         → Natural.is_prime(k);
                 Natural.listProduct(List.prepend(Natural, prime, tail))
                    = prime * Natural.listProduct(tail)
                    = prime * quotient
                    = subject;
                 done
               }
         }
       }
   }

theorem Natural.prime_factorization_exists
        (n : Natural) (atLeastOne : 1 ≤ n)
        : ∃ (list : List(Natural)).
            (∀ (k : Natural).
             k ∈ list
             → Natural.is_prime(k))
            ∧ Natural.listProduct(list) = n :=
  done by Natural.prime_factorization_exists_helper

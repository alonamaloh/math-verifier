-- Natural/maximum.math
--
-- Maximum of two Naturals, defined by recursion on the first arg with
-- an explicit `cases` on the second (the kernel only reduces multi-
-- constructor patterns when the inner case is explicit). Provides the
-- two key inequalities: a ≤ max(a, b) and b ≤ max(a, b).

module Natural.maximum

import axioms
import Natural.basics
import Natural.peano
import Natural.order
import Equality.basics

definition Natural.maximum : Natural → Natural → Natural
  | zero,         b => b
  | successor(k), b =>
      cases b {
        | zero         => successor(k)
        | successor(m) => successor(Natural.maximum(k, m))
      }

-- a ≤ max(a, b). By induction on a (b stays universally quantified so the IH
-- applies at the inner case-split's m), case-split b in the successor case.
-- The standard name, freed by renaming the universe-level keyword to
-- MaxUniverse (2026-06-12): max is an ordinary overload like min/abs.
overload max := Natural.maximum

theorem Natural.left_le_max (a : Natural)
        : ∀ (b : Natural). a ≤ Natural.maximum(a, b) :=
  by_induction on a with IH {
    case zero: {
        -- max(0, b) ≡ b, and zero is least.
        take b : Natural;
        done by Natural.zero_least
      }
    case successor(k): {
        take b : Natural;
        cases b {
          | zero =>
              -- max(s(k), 0) ≡ s(k).
              done
          | successor(m) => {
              -- max(s(k), s(m)) ≡ s(max(k, m)); successor-monotone on the IH.
              claim k ≤ Natural.maximum(k, m) since IH(m);
              done by Natural.successor_less_or_equal_successor
            }
        }
      }
  }

-- b ≤ max(a, b). Symmetric induction.
theorem Natural.right_le_max (a : Natural)
        : ∀ (b : Natural). b ≤ Natural.maximum(a, b) :=
  by_induction on a with IH {
    case zero: {
        -- max(0, b) ≡ b.
        take b : Natural;
        done
      }
    case successor(k): {
        take b : Natural;
        cases b {
          | zero =>
              -- max(s(k), 0) ≡ s(k); 0 is least.
              done by Natural.zero_least
          | successor(m) => {
              -- max(s(k), s(m)) ≡ s(max(k, m)); successor-monotone on the IH.
              claim m ≤ Natural.maximum(k, m) since IH(m);
              done by Natural.successor_less_or_equal_successor
            }
        }
      }
  }

-- max(a, b) ≤ x ⇒ a ≤ x. Composes left_le_max with transitivity.
-- Pairs naturally with le_through_max_right to project either side of a
-- nested-max bound — the situation analytic-proof preambles hit when
-- combining several Cauchy / bound indices via repeated `maximum`.
theorem Natural.le_through_max_left
        (a b x : Natural) (maxLeqX : Natural.maximum(a, b) ≤ x)
        : a ≤ x :=
  calc a
     ≤ Natural.maximum(a, b)
     ≤ x

-- max(a, b) ≤ x ⇒ b ≤ x. Symmetric to le_through_max_left.
theorem Natural.le_through_max_right
        (a b x : Natural) (maxLeqX : Natural.maximum(a, b) ≤ x)
        : b ≤ x :=
  calc b
     ≤ Natural.maximum(a, b)
     ≤ x

-- Natural/maximum.math
--
-- Maximum of two Naturals as `a + (b ∸ a)`: the truncated difference
-- lifts `a` up to `b` when `b` is larger and contributes nothing when
-- it is not. Provides the two key inequalities: a ≤ max(a, b) and
-- b ≤ max(a, b).

module Natural.maximum

import axioms
import Natural.basics
import Natural.peano
import Natural.order
import Natural.monus
import Natural.subtraction
import Equality.basics

definition Natural.maximum (a b : Natural) : Natural := a + (b ∸ a)

overload max := Natural.maximum

-- a ≤ max(a, b): adding the truncated difference only grows a.
automatic theorem Natural.left_le_max (a b : Natural) : a ≤ Natural.maximum(a, b) :=
  a ≤ a + (b ∸ a) = Natural.maximum(a, b)

-- b ≤ max(a, b). When a ≤ b the difference lifts a exactly up to b;
-- when b ≤ a the difference is zero and max is a ≥ b.
automatic theorem Natural.right_le_max (a b : Natural) : b ≤ Natural.maximum(a, b) := {
  a ≤ b ∨ b ≤ a;
  done by cases {
    case a ≤ b as aLeB: {
        choose c such that b = a + c from Natural.subtraction_witness(a, b, aLeB);
        b
           = a + c
           = a + ((a + c) ∸ a)
           = a + (b ∸ a)
           = Natural.maximum(a, b);
        done
      }
    case b ≤ a: {
        b ∸ a = 0;
        b
           ≤ a
           = a + (b ∸ a)
           = Natural.maximum(a, b);
        done
      }
  }
}

-- max(a, b) ≤ x ⇒ a ≤ x. Composes left_le_max with transitivity.
-- Pairs naturally with le_through_max_right to project either side of a
-- nested-max bound — the situation analytic-proof preambles hit when
-- combining several Cauchy / bound indices via repeated `maximum`.
automatic theorem Natural.le_through_max_left
        (a b x : Natural) (maxLeqX : Natural.maximum(a, b) ≤ x)
        : a ≤ x :=
  a
     ≤ Natural.maximum(a, b)
     ≤ x

-- max(a, b) ≤ x ⇒ b ≤ x. Symmetric to le_through_max_left.
automatic theorem Natural.le_through_max_right
        (a b x : Natural) (maxLeqX : Natural.maximum(a, b) ≤ x)
        : b ≤ x :=
  b
     ≤ Natural.maximum(a, b)
     ≤ x

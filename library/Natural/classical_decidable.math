module Natural.classical_decidable

-- Demotes `Logic.classical_decidable` from an axiom to a THEOREM: classical
-- (Type-level) decidability is derivable from excluded middle + the
-- definite-description axiom `Logic.the`, so it need not be assumed.
--
-- The naive route — `cases excluded_middle(P)` into a `Decidable(P)` value —
-- is blocked by CIC's no-large-elimination-from-Prop rule (`P ∨ ¬P` is a
-- Proposition). The standard workaround: encode the decision as an indicator
-- n ∈ {0,1} with `Q(n) := (n = 1 ∧ P) ∨ (n = 0 ∧ ¬P)`, which has a UNIQUE
-- solution under EM; `Logic.the` extracts that n as an honest Natural, and the
-- Type-level decision is then a structural match on n (allowed) rather than a
-- forbidden elimination of the Prop disjunction.
--
-- Lives in the Natural layer (not Logic/) because the construction needs
-- `Natural`; the declared name stays `Logic.classical_decidable` since the
-- `decide` tactic desugars to `cases Logic.classical_decidable(P)`.

import axioms
import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano

-- Read the classical decision off the indicator n (1 ⇒ P, 0 ⇒ ¬P) and its
-- evidence. Currying n before the evidence makes the evidence's type refine to
-- the branch's n automatically.
definition Logic.decidable_from_indicator (P : Proposition)
        : ∀ (n : ℕ).
            ((n = 1 ∧ P) ∨ (n = 0 ∧ Not(P))) → Logic.Decidable(P)
  | zero => (evidence : ((0 : ℕ) = 1 ∧ P) ∨ ((0 : ℕ) = 0 ∧ Not(P))) ↦ {
        Not(P) by cases {
          case (0 : ℕ) = 1 ∧ P as leftCase: {
              (0 : ℕ) = 1;
              (0 : ℕ) ≠ 1;
              False;
              done
          }
          case (0 : ℕ) = 0 ∧ Not(P) as rightCase: { done }
        } as notP;
        Logic.Decidable.no(notP)
    }
  | successor(predecessor) =>
      (evidence : (successor(predecessor) = 1 ∧ P)
                 ∨ (successor(predecessor) = 0 ∧ Not(P))) ↦ {
        P by cases {
          case successor(predecessor) = 1 ∧ P as leftCase: { done }
          case successor(predecessor) = 0 ∧ Not(P) as rightCase: {
              successor(predecessor) = 0;
              successor(predecessor) ≠ 0;
              False;
              done
          }
        } as p;
        Logic.Decidable.yes(p)
    }

-- The full demotion: classical decidability from excluded middle + the
-- definite-description axiom. `the` launders the classical choice of the
-- indicator into an honest Natural; the helper reads the decision off it.
theorem Logic.classical_decidable (P : Proposition) : Logic.Decidable(P) := {
  ∃ (n : ℕ). (n = 1 ∧ P) ∨ (n = 0 ∧ Not(P))
      by cases {
        case P as holds: witness 1 with { (1 : ℕ) = 1 ∧ P; done }
        case Not(P) as notHolds: witness 0 with { (0 : ℕ) = 0 ∧ Not(P); done }
      } as existence;
  ∀ (a b : ℕ).
      ((a = 1 ∧ P) ∨ (a = 0 ∧ Not(P)))
      → ((b = 1 ∧ P) ∨ (b = 0 ∧ Not(P)))
      → a = b
      by {
           take a : ℕ;
           take b : ℕ;
           suppose (a = 1 ∧ P) ∨ (a = 0 ∧ Not(P)) as qa;
           suppose (b = 1 ∧ P) ∨ (b = 0 ∧ Not(P)) as qb;
           a = b by cases {
             case a = 1 ∧ P as aOne: {
                 a = b by cases {
                   case b = 1 ∧ P as bOne: {
                       a = 1;
                       b = 1;
                       done
                   }
                   case b = 0 ∧ Not(P) as bZero: {
                       P;
                       Not(P);
                       False;
                       done
                   }
                 };
                 done
             }
             case a = 0 ∧ Not(P) as aZero: {
                 a = b by cases {
                   case b = 1 ∧ P as bOne: {
                       P;
                       Not(P);
                       False;
                       done
                   }
                   case b = 0 ∧ Not(P) as bZero: {
                       a = 0;
                       b = 0;
                       done
                   }
                 };
                 done
             }
           };
           done
         } as uniqueness;
  let indicator : ℕ :=
      Logic.the(Natural,
          (n : ℕ) ↦ (n = 1 ∧ P) ∨ (n = 0 ∧ Not(P)),
          existence, uniqueness);
  (indicator = 1 ∧ P) ∨ (indicator = 0 ∧ Not(P))
      by Logic.the_satisfies(Natural,
          (n : ℕ) ↦ (n = 1 ∧ P) ∨ (n = 0 ∧ Not(P)),
          existence, uniqueness) as indicatorEvidence;
  Logic.decidable_from_indicator(P, indicator, indicatorEvidence)
}

-- The characterizing equations of the value-level conditional: when the
-- condition holds the conditional is its `then` branch, otherwise its
-- `else` branch. These two lemmas are the QUARANTINE BOUNDARY for
-- scrutinee refinement — the one place a proof case-analyzes the
-- `classical_decidable(P)` term inside a conditional so the kernel can
-- ι-reduce it. Every conditional definition in the library gets its
-- characterizing equations by citing these; consumers never re-decide.
theorem Logic.if_positive.{u}
        (P : Proposition) (T : Type(u)) (a b : T) (holds : P)
        : (if P then a else b : T) = a :=
  if P
  then { note goal : a = a; done }
  else { False; done }

theorem Logic.if_negative.{u}
        (P : Proposition) (T : Type(u)) (a b : T) (fails : ¬P)
        : (if P then a else b : T) = b :=
  if P
  then { False; done }
  else { note goal : b = b; done }

-- Dependent counterparts: the branches may USE the branch hypothesis (the
-- then branch sees a proof of P, the else branch a proof of ¬P). This is the
-- conditional a `decreasing` recursion compiles to — its else branch's
-- decrease witness cites the guard's negation — so these two are the
-- quarantine boundary for THAT scrutinee refinement, exactly as
-- `if_positive`/`if_negative` are for the proof-independent conditional.
-- Proof irrelevance makes `a` at the decision's internal proof and at the
-- caller's `holds` definitionally equal, so the same case split closes both.
theorem Logic.if_positive_dependent.{u}
        (P : Proposition) (T : Type(u))
        (a : P → T) (b : Not(P) → T) (holds : P)
        : Logic.Decidable_recursor(P, (_ : Logic.Decidable(P)) ↦ T, a, b,
              Logic.classical_decidable(P))
          = a(holds) :=
  if P
  then { note goal : a(holds) = a(holds); done }
  else { False; done }

theorem Logic.if_negative_dependent.{u}
        (P : Proposition) (T : Type(u))
        (a : P → T) (b : Not(P) → T) (fails : Not(P))
        : Logic.Decidable_recursor(P, (_ : Logic.Decidable(P)) ↦ T, a, b,
              Logic.classical_decidable(P))
          = b(fails) :=
  if P
  then { False; done }
  else { note goal : b(fails) = b(fails); done }

-- Natural/divisibility.math
--
-- The divides relation on natural numbers: `d тИг n` holds when some
-- quotient `q` satisfies `n = d ┬╖ q`. Together with its basic
-- reflexivity, transitivity, and arithmetic-compatibility facts.

module Natural.divisibility

import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.subtraction
import Equality.basics
import Logic.basics
import Logic.exists

-- `d тИг n` exactly when some quotient witnesses `n = d ┬╖ q`.
definition Natural.divides(divisor dividend : Natural) : Proposition :=
  тИГ (quotient : Natural). dividend = divisor * quotient

operator (тИг) on (Natural, Natural) := Natural.divides

-- Every natural divides itself, with quotient 1.
automatic theorem Natural.divides_reflexive(n : Natural) : n тИг n :=
  witness 1 with n = n * 1

-- One divides every natural, with quotient that natural.
theorem Natural.one_divides(n : Natural) : 1 тИг n :=
  witness n with n = 1 * n

-- Every natural divides zero, with quotient 0.
automatic theorem Natural.divides_zero(n : Natural) : n тИг 0 :=
  witness 0 with 0 = n * 0

-- Divisibility is transitive. From `b = a ┬╖ qтВБ` and `c = b ┬╖ qтВВ` we get
-- `c = a ┬╖ (qтВБ ┬╖ qтВВ)`, so `qтВБ ┬╖ qтВВ` witnesses `a тИг c`.
automatic theorem Natural.divides_transitive (a b c : Natural)
        (aDividesB : a тИг b) (bDividesC : b тИг c)
        : a тИг c := {
  choose firstQuotient such that b = a * firstQuotient from aDividesB;
  choose secondQuotient such that c = b * secondQuotient from bDividesC;
  witness firstQuotient * secondQuotient with
    c
       = b * secondQuotient
       = (a * firstQuotient) * secondQuotient
       = a * (firstQuotient * secondQuotient)
}

-- If `d тИг n` then either `n = 0` or `d тЙд n` тАФ because when the quotient
-- is a successor, `n = d ┬╖ (qтА▓ + 1) = d + d ┬╖ qтА▓ тЙе d`.
automatic theorem Natural.divides_less_or_equal_or_zero (d n : Natural)
        (dDividesN : d тИг n)
        : n = 0 тИи d тЙд n :=
  -- `add` is opaque; unfold it so the case-split's `1 + qm1` is visible as a
  -- `successor` (and `d┬╖(1+qm1) = d + d┬╖qm1` reduces) for the auto-prover.
  unfold Natural.add in {
  choose quotient such that n = d * quotient from dDividesN;
  done by cases {
    case quotient = 0:
        n = d * quotient = d * 0 = 0
    case тИГ (qm1 : Natural). quotient = 1 + qm1 as quotientIsPositive: {
        choose qm1 such that quotient = 1 + qm1 from quotientIsPositive;
        d тЙд d + d * qm1
              = d * (1 + qm1)
              = d * quotient
              = n
      }
  }
}

-- A number divides any multiple of itself: `n тИг n ┬╖ m`, with quotient `m`.
automatic theorem Natural.divides_self_multiple (n m : Natural)
        : n тИг n * m :=
  witness m with done

-- Divisibility passes to multiples: if `d тИг m` then `d тИг k ┬╖ m`. From
-- `m = d ┬╖ q`, `k ┬╖ m = k ┬╖ (d ┬╖ q) = d ┬╖ (k ┬╖ q)`.
theorem Natural.divides_multiple_left (d k m : Natural)
        (dDividesM : d тИг m)
        : d тИг k * m := {
  choose quotient such that m = d * quotient from dDividesM;
  witness k * quotient with
    k * m
       = k * (d * quotient)
       = d * (k * quotient)
}

-- Divisibility is preserved by addition: if `d тИг a` and `d тИг b` then
-- `d тИг a + b`. From `a = d ┬╖ qтВБ` and `b = d ┬╖ qтВВ`,
-- `a + b = d ┬╖ qтВБ + d ┬╖ qтВВ = d ┬╖ (qтВБ + qтВВ)`.
theorem Natural.divides_add (d a b : Natural)
        (dDividesA : d тИг a) (dDividesB : d тИг b)
        : d тИг (a + b) := {
  choose firstQuotient such that a = d * firstQuotient from dDividesA;
  choose secondQuotient such that b = d * secondQuotient from dDividesB;
  witness firstQuotient + secondQuotient with
    a + b
       = d * firstQuotient + d * secondQuotient
       = d * (firstQuotient + secondQuotient)
}

-- When two multiples of `d` are consecutive тАФ `d ┬╖ qтВВ = (d ┬╖ qтВБ) + 1` тАФ
-- the gap `1` must itself be a multiple of `d`, so `d тИг 1`. Proved by
-- structural recursion on `qтВБ`.
--
--   qтВБ = 0                         тЖТ 1 = 1 + d ┬╖ 0 = d ┬╖ qтВВ; witness qтВВ.
--   qтВБ = qтВБтА▓ + 1, qтВВ = 0           тЖТ a successor equals 0, impossible.
--   qтВБ = qтВБтА▓ + 1, qтВВ = qтВВтА▓ + 1     тЖТ cancel a `d` from each side
--                                    (`d + (1 + d┬╖qтВБтА▓) = d + d┬╖qтВВтА▓`) and
--                                    recurse on `qтВБтА▓, qтВВтА▓`.
theorem Natural.divides_one_of_consecutive_multiples
        (d q1 : Natural)
        : тИА (q2 : Natural).
          successor(d * q1) = d * q2
          тЖТ d тИг 1 :=
  by induction on q1 with IH {
    case zero: {
        take q2 : Natural;
        suppose successor(d * 0) = d * q2 as equalityProof;
        witness q2 with successor(0)
                = successor(d * 0)
                = d * q2
      }
    case successor(q1Predecessor): {
        take q2 : Natural;
        suppose successor(d * successor(q1Predecessor)) = d * q2 as equalityProof;
        cases q2 {
          | zero => {
              successor(d * successor(q1Predecessor))
                 = d * 0
                 = 0;
              False;
              done
            }
          | successor(q2Predecessor) => {
              d + successor(d * q1Predecessor)
                 = successor(d * successor(q1Predecessor))
                 = d * successor(q2Predecessor)
                 = d + d * q2Predecessor;
              successor(d * q1Predecessor) = d * q2Predecessor as peeled;
              IH(q2Predecessor, peeled)
            }
        }
      }
  }

-- If `d` divides two consecutive numbers `a` and `a + 1`, then `d тИг 1`.
-- The witnesses give `a = d ┬╖ qтВБ` and `a + 1 = d ┬╖ qтВВ`, hence
-- `(d ┬╖ qтВБ) + 1 = d ┬╖ qтВВ`; `divides_one_of_consecutive_multiples` finishes.
theorem Natural.divides_consecutive_implies_one
        (d a : Natural) (dDividesA : d тИг a) (dDividesSuccessorA : d тИг successor(a))
        : d = 1 := {
  choose firstQuotient such that a = d * firstQuotient from dDividesA;
  choose secondQuotient such that successor(a) = d * secondQuotient from dDividesSuccessorA;
  successor(d * firstQuotient)
     = successor(a)
     = d * secondQuotient;
  d тИг 1 by Natural.divides_one_of_consecutive_multiples;
  -- d тИг 1 with d тЙа 0 forces 1 тЙд d; antisymmetry against d тЙд 1 pins d = 1.
  suppose d = 0 as dIsZero for contradiction {
    successor(a)
       = d * secondQuotient
       = 0 * secondQuotient
       = 0;
    False as impossible;
    impossible
  };
  1 тЙд d;
  1 = 0 тИи d тЙд 1;
  d тЙд 1;
  done by Natural.le_antisymmetric
}

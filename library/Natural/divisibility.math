-- Natural/divisibility.math
--
-- The divides relation on natural numbers: `divides(divisor, dividend)`
-- holds when there is some `quotient` such that
-- `dividend = divisor * quotient`. Plus a few basic facts.

module Natural.divisibility

import Natural.basics
import Natural.arithmetic
import Natural.order
import Equality.basics
import Logic.basics
import Logic.exists

-- The divisor divides the dividend exactly when some quotient witnesses
-- their product relation.
definition Natural.divides(divisor dividend : Natural) : Proposition :=
  Exists(Natural,
          function (quotient : Natural)
              => dividend = divisor * quotient)

-- Every natural divides itself: the quotient is one, and the proof
-- that `naturalNumber = naturalNumber * 1` comes from multiply_one
-- (reversed).
theorem Natural.divides_reflexive(naturalNumber : Natural)
        : Natural.divides(naturalNumber, naturalNumber) :=
  Exists.introduce(
    Natural,
    function (quotient : Natural) => naturalNumber = naturalNumber * quotient,
    one,
    Equality.symmetry(Natural.multiply_one(naturalNumber)))

-- One divides every natural: the quotient is the natural itself, and
-- the proof that `naturalNumber = 1 * naturalNumber` comes from
-- one_multiply (reversed).
theorem Natural.one_divides(naturalNumber : Natural)
        : Natural.divides(one, naturalNumber) :=
  Exists.introduce(
    Natural,
    function (quotient : Natural) => naturalNumber = one * quotient,
    naturalNumber,
    Equality.symmetry(Natural.one_multiply(naturalNumber)))

-- Every natural divides zero: the quotient is zero, and the proof
-- that `0 = candidate * 0` comes from multiply_zero (reversed).
theorem Natural.divides_zero(candidate : Natural)
        : Natural.divides(candidate, zero) :=
  Exists.introduce(
    Natural,
    function (quotient : Natural) => zero = candidate * quotient,
    zero,
    Equality.symmetry(Natural.multiply_zero(candidate)))

-- Divisibility is transitive: if a | b and b | c, then a | c. With
-- witnesses q1 (b = a*q1) and q2 (c = b*q2), the witness for a | c
-- is q1*q2, by multiply_associative.
--
-- The proof goes through a helper because we can only pattern-match
-- on one scrutinee at a time; we destructure the first divisibility
-- proof in `divides_transitive` and the second in the helper.
theorem Natural.divides_transitive_helper
        (a b c : Natural) (firstQuotient : Natural)
        (firstEquality : b = a * firstQuotient)
        : Natural.divides(b, c) → Natural.divides(a, c)
  | Exists.introduce(secondQuotient, secondEquality) =>
      Exists.introduce(
          firstQuotient * secondQuotient,
          Equality.transitivity(
              secondEquality,
              Equality.transitivity(
                  congruenceOf(
                      function (rest : Natural) => rest * secondQuotient,
                      firstEquality),
                  Natural.multiply_associative(
                      a, firstQuotient, secondQuotient))))

theorem Natural.divides_transitive (a b c : Natural)
        : Natural.divides(a, b)
          → Natural.divides(b, c)
          → Natural.divides(a, c)
  | Exists.introduce(firstQuotient, firstEquality), secondDivides =>
      Natural.divides_transitive_helper(
          a, b, c, firstQuotient, firstEquality, secondDivides)

-- If d divides n, then either n is zero (with witness quotient also
-- zero) or d ≤ n (because n = d * q ≥ d when q ≥ 1). Helper that
-- pattern-matches the witness quotient.
theorem Natural.divides_less_or_equal_or_zero_helper (d n : Natural)
        : (quotient : Natural)
          → Equality(Natural, n, Natural.multiply(d, quotient))
          → Or(n = zero, LessOrEqual(d, n))
  | zero, equalityProof =>
      Or.introduceLeft(
          Equality.transitivity(equalityProof,
              Natural.multiply_zero(d)))
  | successor(quotientPredecessor), equalityProof =>
      Or.introduceRight(
          -- LessOrEqual(d, d + d*quotientPredecessor) by le_add_right.
          -- d + d*quotientPredecessor = d * successor(quotientPredecessor) = n via multiply_successor and the
          -- given equality (reversed).
          Equality.transport_proposition(
              Natural,
              function (transportPoint : Natural) =>
                  LessOrEqual(d, transportPoint),
              Natural.add(d, Natural.multiply(d, quotientPredecessor)),
              n,
              Equality.symmetry(
                  Equality.transitivity(equalityProof,
                      Natural.multiply_successor(d, quotientPredecessor))),
              Natural.less_or_equal_add_right(
                  d, Natural.multiply(d, quotientPredecessor))))

-- And the main statement: if d divides n, either n is zero or d ≤ n.
theorem Natural.divides_less_or_equal_or_zero (d n : Natural)
        : Natural.divides(d, n)
          → Or(n = zero, LessOrEqual(d, n))
  | Exists.introduce(quotient, equalityProof) =>
      Natural.divides_less_or_equal_or_zero_helper(
          d, n, quotient, equalityProof)

-- A number divides any multiple of itself: n ∣ (n * m). Witness is m.
theorem Natural.divides_self_multiple (n m : Natural)
        : Natural.divides(n, n * m) :=
  ⟨m, reflexivity(n * m)⟩

-- If d divides m, then d divides any multiple k * m. Witness is k * q
-- where q comes from the input proof; the equality is a chain of
-- congruence + associativity + commutativity moves:
--   k * m = k * (d * q)           (substituting m)
--         = (k * d) * q           (assoc, reversed)
--         = (d * k) * q           (commutativity inside)
--         = d * (k * q)           (assoc, forward)
theorem Natural.divides_multiple_left (d k m : Natural)
        (h : Natural.divides(d, m))
        : Natural.divides(d, k * m) := {
  let ⟨q, equation⟩ := h;
  ⟨k * q,
    Equality.transitivity(
      congruenceOf(function (x : Natural) => k * x, equation),
      Equality.transitivity(
        Equality.symmetry(Natural.multiply_associative(k, d, q)),
        Equality.transitivity(
          congruenceOf(
              function (x : Natural) => x * q,
              Natural.multiply_commutative(k, d)),
          Natural.multiply_associative(d, k, q))))⟩
}

-- Helper: if successor(d * q1) = d * q2, then d divides one. The
-- structurally decreasing argument is q1. In the q1 = successor case
-- we use Natural_recursor directly on q2 — the surface `cases`
-- expression's recursive-call rewriter doesn't yet descend into
-- cases bodies, so we expand the q2-split into an explicit recursor
-- application whose case lambdas the rewriter can see through.
--
--   q1 = 0          → successor(d*0) = successor(0) = 1; witness q2.
--   q1 = successor, q2=0 → successor(_) cannot equal d*0 = 0, contradiction.
--   q1 = successor, q2=successor → cancel `d` from both sides of
--                        d + successor(d*q1') = d + d*q2' to reduce to
--                        successor(d*q1') = d*q2' and recurse.
theorem Natural.divides_one_of_consecutive_helper
        (d : Natural)
        : (q1 q2 : Natural)
          → Equality(Natural, successor(d * q1), d * q2)
          → Natural.divides(d, one)
  | zero, q2, equalityProof =>
      Exists.introduce(
          Natural,
          function (quotient : Natural) => one = d * quotient,
          q2,
          Equality.transitivity(
              congruenceOf(successor,
                  Equality.symmetry(Natural.multiply_zero(d))),
              equalityProof))
  | successor(q1Predecessor), q2, equalityProof =>
      Natural_recursor.{0}(
          function (q2_value : Natural) =>
              Equality(Natural,
                       successor(d * successor(q1Predecessor)),
                       d * q2_value)
              → Natural.divides(d, one),
          function (zeroEquality : Equality(Natural,
                                       successor(d * successor(q1Predecessor)),
                                       d * zero)) =>
              False.eliminate_proposition(
                  Natural.divides(d, one),
                  Natural.successor_not_zero(
                      d * successor(q1Predecessor),
                      Equality.transitivity(zeroEquality,
                          Natural.multiply_zero(d)))),
          function (q2Predecessor : Natural)
              (_inductionHypothesis :
                  Equality(Natural,
                           successor(d * successor(q1Predecessor)),
                           d * q2Predecessor)
                  → Natural.divides(d, one))
              (successorEquality :
                  Equality(Natural,
                           successor(d * successor(q1Predecessor)),
                           d * successor(q2Predecessor))) =>
              Natural.divides_one_of_consecutive_helper(d, q1Predecessor, q2Predecessor,
                  Natural.add_cancel_left(
                      d, successor(d * q1Predecessor), d * q2Predecessor,
                      Equality.transitivity(
                          Natural.add_successor(d, d * q1Predecessor),
                          Equality.transitivity(
                              congruenceOf(successor,
                                  Equality.symmetry(
                                      Natural.multiply_successor(d, q1Predecessor))),
                              Equality.transitivity(
                                  successorEquality,
                                  Natural.multiply_successor(d, q2Predecessor)))))),
          q2,
          equalityProof)

-- If d divides both a and a+1, then d divides 1. Destructure both
-- divisibility witnesses (a = d*q1, successor(a) = d*q2) into the equation
-- successor(d*q1) = d*q2 and delegate to the helper. We pattern-match
-- on the successor-side proof and destructure the a-side proof in the
-- body, because the pattern-match form only allows constructor
-- patterns in the scrutinee position.
theorem Natural.divides_consecutive_implies_one
        (d a : Natural) (firstDivides : Natural.divides(d, a))
        : Natural.divides(d, successor(a))
          → Natural.divides(d, one)
  | Exists.introduce(q2, secondEquality) => {
      let ⟨q1, firstEquality⟩ := firstDivides;
      Natural.divides_one_of_consecutive_helper(d, q1, q2,
          Equality.transitivity(
              congruenceOf(successor,
                  Equality.symmetry(firstEquality)),
              secondEquality))
  }

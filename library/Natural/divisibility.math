-- Natural/divisibility.math
--
-- The divides relation on natural numbers: `divides(divisor, dividend)`
-- holds when there is some `quotient` such that
-- `dividend = divisor * quotient`. Plus a few basic facts.

module Natural.divisibility

import Natural.basics
import Natural.arithmetic
import Equality.basics
import Logic.exists

-- The divisor divides the dividend exactly when some quotient witnesses
-- their product relation.
definition Natural.divides(divisor dividend : Natural) : Prop :=
  Exists(Natural,
          fun (quotient : Natural)
              => dividend = divisor * quotient)

-- Every natural divides itself: the quotient is one, and the proof
-- that `naturalNumber = naturalNumber * 1` comes from multiply_one
-- (reversed).
theorem Natural.divides_reflexive(naturalNumber : Natural)
        : Natural.divides(naturalNumber, naturalNumber) :=
  Exists.introduce(
    Natural,
    fun (quotient : Natural) => naturalNumber = naturalNumber * quotient,
    one,
    Equality.symmetry(Natural.multiply_one(naturalNumber)))

-- One divides every natural: the quotient is the natural itself, and
-- the proof that `naturalNumber = 1 * naturalNumber` comes from
-- one_multiply (reversed).
theorem Natural.one_divides(naturalNumber : Natural)
        : Natural.divides(one, naturalNumber) :=
  Exists.introduce(
    Natural,
    fun (quotient : Natural) => naturalNumber = one * quotient,
    naturalNumber,
    Equality.symmetry(Natural.one_multiply(naturalNumber)))

-- Every natural divides zero: the quotient is zero, and the proof
-- that `0 = candidate * 0` comes from multiply_zero (reversed).
theorem Natural.divides_zero(candidate : Natural)
        : Natural.divides(candidate, zero) :=
  Exists.introduce(
    Natural,
    fun (quotient : Natural) => zero = candidate * quotient,
    zero,
    Equality.symmetry(Natural.multiply_zero(candidate)))

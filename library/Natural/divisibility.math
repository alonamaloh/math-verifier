-- Natural/divisibility.math
--
-- The divides relation on natural numbers: `d ∣ n` holds when some
-- quotient `q` satisfies `n = d · q`. Together with its basic
-- reflexivity, transitivity, and arithmetic-compatibility facts.

module Natural.divisibility

import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.subtraction
import Equality.basics
import Logic.basics
import Logic.exists

-- `d ∣ n` exactly when some quotient witnesses `n = d · q`.
definition Natural.divides(divisor dividend : Natural) : Proposition :=
  ∃ (quotient : Natural). dividend = divisor * quotient

-- Every natural divides itself, with quotient 1.
theorem Natural.divides_reflexive(n : Natural) : n ∣ n :=
  witness 1 with calc n = n * 1

-- One divides every natural, with quotient that natural.
theorem Natural.one_divides(n : Natural) : 1 ∣ n :=
  witness n with calc n = 1 * n

-- Every natural divides zero, with quotient 0.
theorem Natural.divides_zero(n : Natural) : n ∣ 0 :=
  witness 0 with calc 0 = n * 0

-- Divisibility is transitive. From `b = a · q₁` and `c = b · q₂` we get
-- `c = a · (q₁ · q₂)`, so `q₁ · q₂` witnesses `a ∣ c`.
theorem Natural.divides_transitive (a b c : Natural)
        (aDividesB : a ∣ b) (bDividesC : b ∣ c)
        : a ∣ c := {
  choose firstQuotient such that b = a * firstQuotient as bEqualsAtimesFirst from aDividesB;
  choose secondQuotient such that c = b * secondQuotient as cEqualsBtimesSecond from bDividesC;
  witness firstQuotient * secondQuotient with
    calc c
       = b * secondQuotient
       = (a * firstQuotient) * secondQuotient
       = a * (firstQuotient * secondQuotient)
}

-- If `d ∣ n` then either `n = 0` or `d ≤ n` — because when the quotient
-- is a successor, `n = d · (q′ + 1) = d + d · q′ ≥ d`.
theorem Natural.divides_less_or_equal_or_zero (d n : Natural)
        (dDividesN : d ∣ n)
        : n = 0 ∨ d ≤ n :=
  -- `add` is opaque; unfold it so the case-split's `1 + qm1` is visible as a
  -- `successor` (and `d·(1+qm1) = d + d·qm1` reduces) for the auto-prover.
  unfold Natural.add in {
  choose quotient such that n = d * quotient as nEqualsDtimesQuotient from dDividesN;
  claim by cases {
    -- The quotient is zero: n = d·quotient = d·0 = 0.
    in (quotient = 0):
        calc n = d * quotient = d * 0 = 0
    -- The quotient is 1 + p: n = d·(1 + p) = d + d·p ≥ d.
    in (∃ (qm1 : Natural). quotient = 1 + qm1) as ⟨qm1, _⟩:
        calc d ≤ d + d * qm1
              = d * (1 + qm1)
              = d * quotient
              = n
  }
}

-- A number divides any multiple of itself: `n ∣ n · m`, with quotient `m`.
theorem Natural.divides_self_multiple (n m : Natural)
        : n ∣ n * m :=
  witness m with done

-- Divisibility passes to multiples: if `d ∣ m` then `d ∣ k · m`. From
-- `m = d · q`, `k · m = k · (d · q) = d · (k · q)`.
theorem Natural.divides_multiple_left (d k m : Natural)
        (dDividesM : d ∣ m)
        : d ∣ k * m := {
  choose quotient such that m = d * quotient as mEqualsDtimesQuotient from dDividesM;
  witness k * quotient with
    calc k * m
       = k * (d * quotient)
       = d * (k * quotient)
}

-- Divisibility is preserved by addition: if `d ∣ a` and `d ∣ b` then
-- `d ∣ a + b`. From `a = d · q₁` and `b = d · q₂`,
-- `a + b = d · q₁ + d · q₂ = d · (q₁ + q₂)`.
theorem Natural.divides_add (d a b : Natural)
        (dDividesA : d ∣ a) (dDividesB : d ∣ b)
        : d ∣ (a + b) := {
  choose firstQuotient such that a = d * firstQuotient as aEqualsDtimesFirst from dDividesA;
  choose secondQuotient such that b = d * secondQuotient as bEqualsDtimesSecond from dDividesB;
  witness firstQuotient + secondQuotient with
    calc a + b
       = d * firstQuotient + d * secondQuotient
       = d * (firstQuotient + secondQuotient)
}

-- When two multiples of `d` are consecutive — `d · q₂ = (d · q₁) + 1` —
-- the gap `1` must itself be a multiple of `d`, so `d ∣ 1`. Proved by
-- structural recursion on `q₁`.
--
--   q₁ = 0                         → 1 = 1 + d · 0 = d · q₂; witness q₂.
--   q₁ = q₁′ + 1, q₂ = 0           → a successor equals 0, impossible.
--   q₁ = q₁′ + 1, q₂ = q₂′ + 1     → cancel a `d` from each side
--                                    (`d + (1 + d·q₁′) = d + d·q₂′`) and
--                                    recurse on `q₁′, q₂′`.
theorem Natural.divides_one_of_consecutive_multiples
        (d q1 : Natural)
        : ∀ (q2 : Natural).
          successor(d * q1) = d * q2
          → d ∣ 1 :=
  by_induction on q1 with IH {
    case zero: {
        take q2 : Natural;
        suppose successor(d * 0) = d * q2 as equalityProof;
        witness q2 with calc successor(0)
                = successor(d * 0)
                = d * q2
      }
    case successor(q1Predecessor): {
        take q2 : Natural;
        suppose successor(d * successor(q1Predecessor)) = d * q2 as equalityProof;
        cases q2 refining equalityProof {
          | zero =>
              absurd(
                  calc successor(d * successor(q1Predecessor))
                     = d * 0
                     = 0)
          | successor(q2Predecessor) => {
              -- Cancel a leading `d` from each side, then recurse on the
              -- smaller pair via the induction hypothesis.
              calc d + successor(d * q1Predecessor)
                 = successor(d * successor(q1Predecessor))
                 = d * successor(q2Predecessor)
                 = d + d * q2Predecessor;
              claim peeled : successor(d * q1Predecessor) = d * q2Predecessor
                  since Natural.add_cancel_left;
              IH(q2Predecessor, peeled)
            }
        }
      }
  }

-- If `d` divides two consecutive numbers `a` and `a + 1`, then `d ∣ 1`.
-- The witnesses give `a = d · q₁` and `a + 1 = d · q₂`, hence
-- `(d · q₁) + 1 = d · q₂`; `divides_one_of_consecutive_multiples` finishes.
theorem Natural.divides_consecutive_implies_one
        (d a : Natural) (dDividesA : d ∣ a) (dDividesSuccessorA : d ∣ successor(a))
        : d ∣ 1 := {
  choose firstQuotient such that a = d * firstQuotient as aEqualsDtimesFirst from dDividesA;
  choose secondQuotient such that successor(a) = d * secondQuotient as successorAEqualsDtimesSecond from dDividesSuccessorA;
  calc successor(d * firstQuotient)
     = successor(a)
     = d * secondQuotient;
  done since Natural.divides_one_of_consecutive_multiples
}

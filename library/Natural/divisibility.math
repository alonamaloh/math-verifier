-- Natural/divisibility.math
--
-- The divides relation on natural numbers: `divides(divisor, dividend)`
-- holds when there is some `quotient` such that
-- `dividend = divisor * quotient`. Plus a few basic facts.

module Natural.divisibility

import Natural.basics
import Natural.arithmetic
import Natural.order
import Equality.basics
import Logic.basics
import Logic.exists

-- The divisor divides the dividend exactly when some quotient witnesses
-- their product relation.
definition Natural.divides(divisor dividend : Natural) : Proposition :=
  Exists(Natural,
          fun (quotient : Natural)
              => dividend = divisor * quotient)

-- Every natural divides itself: the quotient is one, and the proof
-- that `naturalNumber = naturalNumber * 1` comes from multiply_one
-- (reversed).
theorem Natural.divides_reflexive(naturalNumber : Natural)
        : Natural.divides(naturalNumber, naturalNumber) :=
  Exists.introduce(
    Natural,
    fun (quotient : Natural) => naturalNumber = naturalNumber * quotient,
    one,
    Equality.symmetry(Natural.multiply_one(naturalNumber)))

-- One divides every natural: the quotient is the natural itself, and
-- the proof that `naturalNumber = 1 * naturalNumber` comes from
-- one_multiply (reversed).
theorem Natural.one_divides(naturalNumber : Natural)
        : Natural.divides(one, naturalNumber) :=
  Exists.introduce(
    Natural,
    fun (quotient : Natural) => naturalNumber = one * quotient,
    naturalNumber,
    Equality.symmetry(Natural.one_multiply(naturalNumber)))

-- Every natural divides zero: the quotient is zero, and the proof
-- that `0 = candidate * 0` comes from multiply_zero (reversed).
theorem Natural.divides_zero(candidate : Natural)
        : Natural.divides(candidate, zero) :=
  Exists.introduce(
    Natural,
    fun (quotient : Natural) => zero = candidate * quotient,
    zero,
    Equality.symmetry(Natural.multiply_zero(candidate)))

-- Divisibility is transitive: if a | b and b | c, then a | c. With
-- witnesses q1 (b = a*q1) and q2 (c = b*q2), the witness for a | c
-- is q1*q2, by multiply_associative.
--
-- The proof goes through a helper because we can only pattern-match
-- on one scrutinee at a time; we destructure the first divisibility
-- proof in `divides_transitive` and the second in the helper.
theorem Natural.divides_transitive_helper
        (a b c : Natural) (firstQuotient : Natural)
        (firstEquality : b = a * firstQuotient)
        : Natural.divides(b, c) → Natural.divides(a, c)
  | Exists.introduce(secondQuotient, secondEquality) =>
      Exists.introduce(
          firstQuotient * secondQuotient,
          Equality.transitivity(
              secondEquality,
              Equality.transitivity(
                  congruenceOf(
                      fun (rest : Natural) => rest * secondQuotient,
                      firstEquality),
                  Natural.multiply_associative(
                      a, firstQuotient, secondQuotient))))

theorem Natural.divides_transitive (a b c : Natural)
        : Natural.divides(a, b)
          → Natural.divides(b, c)
          → Natural.divides(a, c)
  | Exists.introduce(firstQuotient, firstEquality), secondDivides =>
      Natural.divides_transitive_helper(
          a, b, c, firstQuotient, firstEquality, secondDivides)

-- If d divides n, then either n is zero (with witness quotient also
-- zero) or d ≤ n (because n = d * q ≥ d when q ≥ 1). Helper that
-- pattern-matches the witness quotient.
theorem Natural.divides_le_or_zero_helper (d n : Natural)
        : (quotient : Natural)
          → Equality(Natural, n, Natural.multiply(d, quotient))
          → Or(n = zero, LessOrEqual(d, n))
  | zero, equalityProof =>
      Or.introduceLeft(
          Equality.transitivity(equalityProof,
              Natural.multiply_zero(d)))
  | successor(quotientPredecessor), equalityProof =>
      Or.introduceRight(
          -- LessOrEqual(d, d + d*qP) by le_add_right.
          -- d + d*qP = d * succ(qP) = n via multiply_successor and the
          -- given equality (reversed).
          Equality.transport_proposition(
              Natural,
              fun (transportPoint : Natural) =>
                  LessOrEqual(d, transportPoint),
              Natural.add(d, Natural.multiply(d, quotientPredecessor)),
              n,
              Equality.symmetry(
                  Equality.transitivity(equalityProof,
                      Natural.multiply_successor(d, quotientPredecessor))),
              Natural.le_add_right(
                  d, Natural.multiply(d, quotientPredecessor))))

-- And the main statement: if d divides n, either n is zero or d ≤ n.
theorem Natural.divides_le_or_zero (d n : Natural)
        : Natural.divides(d, n)
          → Or(n = zero, LessOrEqual(d, n))
  | Exists.introduce(quotient, equalityProof) =>
      Natural.divides_le_or_zero_helper(
          d, n, quotient, equalityProof)

-- A number divides any multiple of itself: n ∣ (n * m). Witness is m.
theorem Natural.divides_self_multiple (n m : Natural)
        : Natural.divides(n, n * m) :=
  ⟨m, reflexivity(n * m)⟩

-- If d divides m, then d divides any multiple k * m. Witness is k * q
-- where q comes from the input proof; the equality is a chain of
-- congruence + associativity + commutativity moves:
--   k * m = k * (d * q)           (substituting m)
--         = (k * d) * q           (assoc, reversed)
--         = (d * k) * q           (commutativity inside)
--         = d * (k * q)           (assoc, forward)
theorem Natural.divides_multiple_left (d k m : Natural)
        (h : Natural.divides(d, m))
        : Natural.divides(d, k * m) := {
  let ⟨q, equation⟩ := h;
  ⟨k * q,
    Equality.transitivity(
      congruenceOf(fun (x : Natural) => k * x, equation),
      Equality.transitivity(
        Equality.symmetry(Natural.multiply_associative(k, d, q)),
        Equality.transitivity(
          congruenceOf(
              fun (x : Natural) => x * q,
              Natural.multiply_commutative(k, d)),
          Natural.multiply_associative(d, k, q))))⟩
}

-- If d divides both a and a+1, then d divides 1. Used in Euclid's
-- proof to derive a contradiction when a prime candidate would have
-- to divide both N = product + 1 and the product itself.
--
-- TODO(arithmetic): prove this from the underlying witnesses. The
-- proof sketch is: open d ∣ a and d ∣ succ(a) into d*q1 = a and
-- d*q2 = succ(a); from these d*q2 = d*q1 + 1; case on d. d=0 is
-- impossible (succ(a) ≠ 0); for d ≥ 1 the relationship q2 = q1 + 1
-- forces d ≤ 1, so d = 1, and divides(1, 1) is the witness with
-- quotient 1. The proof is ~100 lines of arithmetic and is
-- axiomatised here so the Euclid result can land first.
axiom Natural.divides_consecutive_implies_one
        : (d a : Natural)
          → Natural.divides(d, a)
          → Natural.divides(d, successor(a))
          → Natural.divides(d, one)

-- Natural/multiply_bounds.math
--
-- Elementary multiplicative bounds, stated once so consumers stay free
-- of arithmetic bookkeeping:
--   * multiplication is monotone in its right factor,
--   * the quotient and remainder of a division are unique (the counting
--     bijection in Set/finite_product.math leans on both), and
--   * the small-square bounds — which roots square below 2, 4, 6, 10, and
--     which small values are not sums of two squares / of m² + 2n².

module Natural.multiply_bounds

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Natural.subtraction
import Natural.monus
import Natural.compare
import Natural.floor_divide

-- Multiplication is monotone in its right factor: if a ≤ b then c*a ≤ c*b.
-- Write b as a + s (its excess over a); then c*b = c*a + c*s, which is at
-- least c*a.
automatic theorem Natural.multiply_monotone_left (c a b : ℕ) (aLeB : a ≤ b) : c * a ≤ c * b := {
  choose excess such that b = a + excess from Natural.subtraction_witness;
  c * a
     ≤ c * a + c * excess
     = c * (a + excess)
     = c * b
}

-- ----------------------------------------------------------------------
-- Uniqueness of quotient and remainder.

-- The asymmetric core. If the two divisions agree as
-- `divisor*qLow + rLow = divisor*qHigh + rHigh` while `qLow < qHigh`,
-- then the low remainder is forced up to at least `divisor`, contradicting
-- its bound. Concretely qHigh = qLow + (1 + gap), so
-- `divisor*qHigh = divisor*qLow + divisor + divisor*gap`; cancelling the
-- common `divisor*qLow` leaves `rLow = divisor + divisor*gap + rHigh`,
-- whence `divisor ≤ rLow`, forcing `rLow` strictly below itself (via `rLow + 1 ≤ divisor`).
theorem Natural.quotient_strict_absurd
        (divisor quotientLow remainderLow quotientHigh remainderHigh : ℕ)
        (remainderLowBound : remainderLow + 1 ≤ divisor)
        (strictlyBelow : quotientLow < quotientHigh)
        (equation : divisor * quotientLow + remainderLow = divisor * quotientHigh + remainderHigh)
        : False := {
  choose gap such that quotientLow + (1 + gap) = quotientHigh
       from Natural.lt_elim;
  -- Cancel divisor*quotientLow from the equation, exposing rLow on the left
  -- and divisor + divisor*gap + rHigh on the right.
  divisor * quotientLow + remainderLow
     = divisor * quotientHigh + remainderHigh
     = divisor * (quotientLow + (1 + gap)) + remainderHigh
     = divisor * quotientLow + (divisor + divisor * gap + remainderHigh);
  remainderLow = divisor + divisor * gap + remainderHigh;
  -- So divisor ≤ rLow, forcing rLow strictly below itself.
  divisor
        ≤ divisor + (divisor * gap + remainderHigh)
        = divisor + divisor * gap + remainderHigh
        = remainderLow;
  remainderLow < divisor ≤ remainderLow;
  done
}

-- Quotients are unique: same divisor, equal `quotient*divisor + remainder`
-- with both remainders below the divisor force equal quotients. Compare the
-- two quotients; either strict order would contradict the matching remainder
-- bound (the helper above), so they are equal by antisymmetry.
theorem Natural.quotient_remainder_unique
        (divisor quotientOne remainderOne quotientTwo remainderTwo : ℕ)
        (remOneBound : remainderOne + 1 ≤ divisor)
        (remTwoBound : remainderTwo + 1 ≤ divisor)
        (equation : divisor * quotientOne + remainderOne = divisor * quotientTwo + remainderTwo)
        : quotientOne = quotientTwo := {
  -- compare_strict(quotientTwo, quotientOne): the `below` branch is
  -- quotientTwo < quotientOne (refuted), the `atLeast` branch is exactly
  -- quotientOne ≤ quotientTwo.
  suppose quotientTwo < quotientOne for contradiction {
    divisor * quotientTwo + remainderTwo
       = divisor * quotientOne + remainderOne;
    False;
    done
  };
  quotientOne ≤ quotientTwo by Natural.less_or_equal_of_not_less_than;
  suppose quotientOne < quotientTwo for contradiction { False; done };
  quotientTwo ≤ quotientOne by Natural.less_or_equal_of_not_less_than;
  done by Natural.le_antisymmetric
}

-- With equal quotients, the remainders are equal too: cancel the common
-- `divisor*quotient` from the equation.
theorem Natural.remainder_unique
        (divisor quotientOne remainderOne quotientTwo remainderTwo : ℕ)
        (remOneBound : remainderOne + 1 ≤ divisor)
        (remTwoBound : remainderTwo + 1 ≤ divisor)
        (equation : divisor * quotientOne + remainderOne = divisor * quotientTwo + remainderTwo)
        : remainderOne = remainderTwo := {
  quotientOne = quotientTwo;
  divisor * quotientTwo + remainderOne
     = divisor * quotientOne + remainderOne
     = divisor * quotientTwo + remainderTwo;
  done
}

-- x ≤ p * x when p ≥ 1. From p = 1 + (p ∸ 1): p*x = x + (p∸1)*x ≥ x.
-- (Rehomed from the deleted Natural.padic_valuation, and made successor-free.)
theorem Natural.le_multiply_when_factor_at_least_one
        (x p : ℕ) (pPositive : 1 ≤ p)
        : x ≤ p * x := {
  1 ∸ p = 0;
  p = 1 + (p ∸ 1);
  x
     ≤ x + (p ∸ 1) * x
     = (1 + (p ∸ 1)) * x
     = p * x
}

-- Below 2 there is only 0 and 1 — the base of the small-value splits
-- the square bounds below run on.
theorem Natural.below_two (m : ℕ) (bound : m < 2) : m = 0 ∨ m = 1 := {
  m = 0 ∨ ∃ (k : ℕ). m = 1 + k;
  done by cases {
    case m = 0: done
    case ∃ (k : ℕ). m = 1 + k: {
        choose k such that m = 1 + k;
        1 ≤ m;
        m ≤ 1 by Natural.le_of_lt_one_plus;
        m = 1 by Natural.le_antisymmetric;
        done
      }
  }
}

-- Every positive value below 5 is one of 1, 2, 3, 4.
theorem Natural.positive_below_five (m : ℕ) (positive : m ≥ 1) (bound : m < 5)
        : m = 1 ∨ m = 2 ∨ m = 3 ∨ m = 4 := {
  m < 4 ∨ m = 4 ∨ 4 < m by Natural.lt_trichotomy;
  done by cases {
    case m < 4 as belowFour: {
        m < 3 ∨ m = 3 ∨ 3 < m by Natural.lt_trichotomy;
        done by cases {
          case m < 3 as belowThree: {
              m < 2 ∨ m = 2 ∨ 2 < m by Natural.lt_trichotomy;
              done by cases {
                case m < 2: {
                    m ≤ 1 by Natural.le_of_lt_one_plus;
                    m = 1 by Natural.le_antisymmetric;
                    done
                  }
                case m = 2: done
                case 2 < m: {
                    3 ≤ m;
                    m < 3 ≤ m;
                    False by Natural.lt_irreflexive;
                    done
                  }
              }
            }
          case m = 3: done
          case 3 < m: {
              4 ≤ m;
              m < 4 ≤ m;
              False by Natural.lt_irreflexive;
              done
            }
        }
      }
    case m = 4: done
    case 4 < m: {
        5 ≤ m;
        m < 5 ≤ m;
        False by Natural.lt_irreflexive;
        done
      }
  }
}

-- Every positive value below 6 is one of 1, 2, 3, 4, 5.
theorem Natural.positive_below_six (m : ℕ) (positive : m ≥ 1) (bound : m < 6)
        : m = 1 ∨ m = 2 ∨ m = 3 ∨ m = 4 ∨ m = 5 := {
  m < 5 ∨ m = 5 ∨ 5 < m by Natural.lt_trichotomy;
  done by cases {
    case m < 5: {
        m = 1 ∨ m = 2 ∨ m = 3 ∨ m = 4
            by Natural.positive_below_five;
        done by cases {
          case m = 1: done
          case m = 2 ∨ m = 3 ∨ m = 4: done by cases {
              case m = 2: done
              case m = 3 ∨ m = 4: done by cases {
                  case m = 3: done
                  case m = 4: done
                }
            }
        }
      }
    case m = 5: done
    case 5 < m: {
        6 ≤ m;
        m < 6 ≤ m;
        False by Natural.lt_irreflexive;
        done
      }
  }
}

-- Every positive value below 7 is one of 1, 2, 3, 4, 5, 6.
theorem Natural.positive_below_seven (m : ℕ) (positive : m ≥ 1) (bound : m < 7)
        : m = 1 ∨ m = 2 ∨ m = 3 ∨ m = 4 ∨ m = 5 ∨ m = 6 := {
  m < 6 ∨ m = 6 ∨ 6 < m by Natural.lt_trichotomy;
  done by cases {
    case m < 6: {
        m = 1 ∨ m = 2 ∨ m = 3 ∨ m = 4 ∨ m = 5
            by Natural.positive_below_six;
        done by cases {
          case m = 1: done
          case m = 2 ∨ m = 3 ∨ m = 4 ∨ m = 5: done by cases {
              case m = 2: done
              case m = 3 ∨ m = 4 ∨ m = 5: done by cases {
                  case m = 3: done
                  case m = 4 ∨ m = 5: done by cases {
                      case m = 4: done
                      case m = 5: done
                    }
                }
            }
        }
      }
    case m = 6: done
    case 6 < m: {
        7 ≤ m;
        m < 7 ≤ m;
        False by Natural.lt_irreflexive;
        done
      }
  }
}

-- A strict bound by a successor splits at its predecessor. This keeps the
-- longer finite positive-range enumerations below from repeating the
-- impossible upper branch of trichotomy at every step.
theorem Natural.below_successor_or_equal (m k : ℕ) (bound : m < k + 1)
        : m < k ∨ m = k := {
  m < k ∨ m = k ∨ k < m by Natural.lt_trichotomy;
  done by cases {
    case m < k: done
    case m = k: done
    case k < m: {
        k + 1 ≤ m;
        m < k + 1 ≤ m;
        False by Natural.lt_irreflexive;
        done
      }
  }
}

-- Every positive value below 14 is one of 1 through 13.
theorem Natural.positive_below_fourteen
        (m : ℕ) (positive : m ≥ 1) (bound : m < 14)
        : m = 1 ∨ m = 2 ∨ m = 3 ∨ m = 4 ∨ m = 5 ∨ m = 6
          ∨ m = 7 ∨ m = 8 ∨ m = 9 ∨ m = 10 ∨ m = 11 ∨ m = 12
          ∨ m = 13 := {
  m < 13 ∨ m = 13 by Natural.below_successor_or_equal;
  done by cases {
    case m < 13: {
        m < 12 ∨ m = 12 by Natural.below_successor_or_equal;
        done by cases {
          case m < 12: {
              m < 11 ∨ m = 11 by Natural.below_successor_or_equal;
              done by cases {
                case m < 11: {
                    m < 10 ∨ m = 10 by Natural.below_successor_or_equal;
                    done by cases {
                      case m < 10: {
                          m < 9 ∨ m = 9 by Natural.below_successor_or_equal;
                          done by cases {
                            case m < 9: {
                                m < 8 ∨ m = 8
                                    by Natural.below_successor_or_equal;
                                done by cases {
                                  case m < 8: {
                                      m < 7 ∨ m = 7
                                          by Natural.below_successor_or_equal;
                                      done by cases {
                                        case m < 7: {
                                            m = 1 ∨ m = 2 ∨ m = 3
                                              ∨ m = 4 ∨ m = 5 ∨ m = 6
                                                by Natural.positive_below_seven;
                                            done by cases {
                                              case m = 1: done
                                              case m = 2 ∨ m = 3 ∨ m = 4
                                                  ∨ m = 5 ∨ m = 6:
                                                done by cases {
                                                  case m = 2: done
                                                  case m = 3 ∨ m = 4
                                                      ∨ m = 5 ∨ m = 6:
                                                    done by cases {
                                                      case m = 3: done
                                                      case m = 4 ∨ m = 5
                                                          ∨ m = 6:
                                                        done by cases {
                                                          case m = 4: done
                                                          case m = 5 ∨ m = 6:
                                                            done by cases {
                                                              case m = 5: done
                                                              case m = 6: done
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                          }
                                        case m = 7: done
                                      }
                                    }
                                  case m = 8: done
                                }
                              }
                            case m = 9: done
                          }
                        }
                      case m = 10: done
                    }
                  }
                case m = 11: done
              }
            }
          case m = 12: done
        }
      }
    case m = 13: done
  }
}

-- A square below 2 has root 0 or 1: any root of at least 2 squares to at
-- least 4.
theorem Natural.square_below_two (m : ℕ) (bound : m * m < 2) : m = 0 ∨ m = 1 := {
  m < 2 ∨ m = 2 ∨ 2 < m by Natural.lt_trichotomy;
  done by cases {
    case m < 2 as mSmall: {
        m ≤ 1 by Natural.le_of_lt_one_plus;
        m = 0 ∨ ∃ (k : ℕ). m = 1 + k;
        done by cases {
          case m = 0: done
          case ∃ (k : ℕ). m = 1 + k as mPositive: {
              choose k such that m = 1 + k from mPositive;
              1 ≤ 1 + k;
              1 ≤ m by substituting (m = 1 + k);
              m = 1 by Natural.le_antisymmetric;
              done
            }
        }
      }
    case m = 2 ∨ 2 < m as mLarge: {
        2 ≤ m by cases {
            case m = 2: done
            case 2 < m: done by Natural.LessThan.weaken
          };
        2 * 2 ≤ 2 * m by Natural.multiply_monotone_left
              = m * 2
              ≤ m * m by Natural.multiply_monotone_left as fourBelowSquare;
        m * m < 2 ≤ 2 * 2 ≤ m * m by fourBelowSquare;
        False by Natural.lt_irreflexive;
        done
      }
  }
}

-- A square below 4 also has root 0 or 1 — 4 is itself the next square.
theorem Natural.square_below_four (m : ℕ) (bound : m * m < 4)
        : m = 0 ∨ m = 1 := {
  m < 2 ∨ m = 2 ∨ 2 < m by Natural.lt_trichotomy;
  done by cases {
    case m < 2: done by Natural.below_two
    case m = 2 ∨ 2 < m: {
        2 ≤ m by cases {
            case m = 2: done
            case 2 < m: done by Natural.LessThan.weaken
          };
        2 * 2 ≤ 2 * m by Natural.multiply_monotone_left
              = m * 2
              ≤ m * m by Natural.multiply_monotone_left;
        m * m < 4 = 2 * 2 ≤ m * m;
        False by Natural.lt_irreflexive;
        done
      }
  }
}

-- A square below 6 has root 0, 1, or 2: the next square up is 9.
theorem Natural.square_below_six (m : ℕ) (bound : m * m < 6)
        : m = 0 ∨ m = 1 ∨ m = 2 := {
  m < 3 ∨ m = 3 ∨ 3 < m by Natural.lt_trichotomy;
  done by cases {
    case m < 3 as belowThree: {
        m < 2 ∨ m = 2 ∨ 2 < m by Natural.lt_trichotomy;
        done by cases {
          case m < 2: {
              m = 0 ∨ m = 1 by Natural.below_two;
              done by cases {
                case m = 0: done
                case m = 1: done
              }
            }
          case m = 2: done
          case 2 < m: {
              3 ≤ m;
              m < 3 ≤ m;
              False by Natural.lt_irreflexive;
              done
            }
        }
      }
    case m = 3 ∨ 3 < m: {
        3 ≤ m by cases {
            case m = 3: done
            case 3 < m: done by Natural.LessThan.weaken
          };
        3 * 3 ≤ 3 * m by Natural.multiply_monotone_left
              = m * 3
              ≤ m * m by Natural.multiply_monotone_left;
        m * m < 6 < 3 * 3 ≤ m * m;
        False by Natural.lt_irreflexive;
        done
      }
  }
}

-- A square below 10 has root 0, 1, 2, or 3: the next square is 16.
theorem Natural.square_below_ten (m : ℕ) (bound : m * m < 10)
        : m = 0 ∨ m = 1 ∨ m = 2 ∨ m = 3 := {
  m < 4 ∨ m = 4 ∨ 4 < m by Natural.lt_trichotomy;
  done by cases {
    case m < 4 as belowFour: {
        m < 3 ∨ m = 3 ∨ 3 < m by Natural.lt_trichotomy;
        done by cases {
          case m < 3 as belowThree: {
              m < 2 ∨ m = 2 ∨ 2 < m by Natural.lt_trichotomy;
              done by cases {
                case m < 2: {
                    m = 0 ∨ m = 1 by Natural.below_two;
                    done by cases {
                      case m = 0: done
                      case m = 1: done
                    }
                  }
                case m = 2: done
                case 2 < m: {
                    3 ≤ m;
                    m < 3 ≤ m;
                    False by Natural.lt_irreflexive;
                    done
                  }
              }
            }
          case m = 3: done
          case 3 < m: {
              4 ≤ m;
              m < 4 ≤ m;
              False;
              done
            }
        }
      }
    case m = 4 ∨ 4 < m: {
        4 ≤ m by cases {
            case m = 4: done
            case 4 < m: done
          };
        4 * 4 ≤ 4 * m by Natural.multiply_monotone_left
              = m * 4
              ≤ m * m by Natural.multiply_monotone_left;
        m * m < 10 < 4 * 4 ≤ m * m;
        False;
        done
      }
  }
}

-- A square strictly below 16 has root 0, 1, 2, or 3.
theorem Natural.square_below_sixteen (m : ℕ) (bound : m * m < 16)
        : m = 0 ∨ m = 1 ∨ m = 2 ∨ m = 3 := {
  m < 4 ∨ m = 4 ∨ 4 < m by Natural.lt_trichotomy;
  done by cases {
    case m < 4 as belowFour: {
        m < 3 ∨ m = 3 ∨ 3 < m by Natural.lt_trichotomy;
        done by cases {
          case m < 3: {
              m < 2 ∨ m = 2 ∨ 2 < m by Natural.lt_trichotomy;
              done by cases {
                case m < 2: {
                    m = 0 ∨ m = 1 by Natural.below_two;
                    done by cases {
                      case m = 0: done
                      case m = 1: done
                    }
                  }
                case m = 2: done
                case 2 < m: {
                    3 ≤ m;
                    m < 3 ≤ m;
                    False by Natural.lt_irreflexive;
                    done
                  }
              }
            }
          case m = 3: done
          case 3 < m: {
              4 ≤ m;
              m < 4 ≤ m;
              False by Natural.lt_irreflexive;
              done
            }
        }
      }
    case m = 4 ∨ 4 < m: {
        4 ≤ m by cases {
            case m = 4: done
            case 4 < m: done
          };
        4 * 4 ≤ 4 * m by Natural.multiply_monotone_left
              = m * 4
              ≤ m * m by Natural.multiply_monotone_left;
        m * m < 16 = 4 * 4 ≤ m * m;
        False by Natural.lt_irreflexive;
        done
      }
  }
}

-- A square strictly below 18 has root at most 4: the next square is 25.
theorem Natural.square_below_eighteen (m : ℕ) (bound : m * m < 18)
        : m = 0 ∨ m = 1 ∨ m = 2 ∨ m = 3 ∨ m = 4 := {
  m < 5 ∨ m = 5 ∨ 5 < m by Natural.lt_trichotomy;
  done by cases {
    case m < 5 as belowFive: {
      m = 0 ∨ ∃ (predecessor : ℕ). m = 1 + predecessor by Natural.zero_or_one_plus;
      done by cases {
        case m = 0: done
        case ∃ (predecessor : ℕ). m = 1 + predecessor as positiveShape: {
          choose predecessor such that m = 1 + predecessor from positiveShape;
          1 ≤ 1 + predecessor;
          1 ≤ m by substituting (m = 1 + predecessor);
          m = 1 ∨ m = 2 ∨ m = 3 ∨ m = 4 by Natural.positive_below_five;
          done by cases {
            case m = 1: done
            case m = 2 ∨ m = 3 ∨ m = 4: done by cases {
              case m = 2: done
              case m = 3 ∨ m = 4: done by cases {
                case m = 3: done
                case m = 4: done
              }
            }
          }
        }
      }
    }
    case m = 5 ∨ 5 < m: {
      5 ≤ m by cases {
        case m = 5: done
        case 5 < m: done by Natural.LessThan.weaken
      };
      5 * 5 ≤ 5 * m by Natural.multiply_monotone_left
            = m * 5
            ≤ m * m by Natural.multiply_monotone_left;
      m * m < 18 < 5 * 5 ≤ m * m;
      False by Natural.lt_irreflexive;
      done
    }
  }
}

-- A square strictly below 36 has root at most 5.  This larger cutoff is
-- useful for finite boxes arising from rank-four Schur bounds.
theorem Natural.square_below_thirty_six (m : ℕ) (bound : m * m < 36)
        : m = 0 ∨ m = 1 ∨ m = 2 ∨ m = 3 ∨ m = 4 ∨ m = 5 := {
  m < 6 ∨ m = 6 ∨ 6 < m by Natural.lt_trichotomy;
  done by cases {
    case m < 6 as belowSix: {
      m = 0 ∨ ∃ (predecessor : ℕ). m = 1 + predecessor by Natural.zero_or_one_plus;
      done by cases {
        case m = 0: done
        case ∃ (predecessor : ℕ). m = 1 + predecessor as positiveShape: {
          choose predecessor such that m = 1 + predecessor from positiveShape;
          1 ≤ 1 + predecessor;
          1 ≤ m by substituting (m = 1 + predecessor);
          m = 1 ∨ m = 2 ∨ m = 3 ∨ m = 4 ∨ m = 5 by Natural.positive_below_six;
          done by cases {
            case m = 1: done
            case m = 2 ∨ m = 3 ∨ m = 4 ∨ m = 5: done by cases {
              case m = 2: done
              case m = 3 ∨ m = 4 ∨ m = 5: done by cases {
                case m = 3: done
                case m = 4 ∨ m = 5: done by cases { case m = 4: done case m = 5: done }
              }
            }
          }
        }
      }
    }
    case m = 6 ∨ 6 < m: {
      6 ≤ m by cases { case m = 6: done case 6 < m: done };
      6 * 6 ≤ 6 * m by Natural.multiply_monotone_left
            = m * 6
            ≤ m * m by Natural.multiply_monotone_left;
      m * m < 36 = 6 * 6 ≤ m * m;
      False by Natural.lt_irreflexive;
      done
    }
  }
}

-- 2 lies strictly between the consecutive squares 1 and 4, so it is not a
-- square: a root would be at most 1 (square too small) or at least 2
-- (square too large).
theorem Natural.two_is_not_a_square (m : ℕ) : ¬(m * m = 2) := {
  suppose m * m = 2 as squareIsTwo;
  m < 2 ∨ m = 2 ∨ 2 < m by Natural.lt_trichotomy;
  done by cases {
    case m < 2 as mSmall: {
        m ≤ 1 by Natural.le_of_lt_one_plus;
        2 = m * m ≤ m * 1 by Natural.multiply_monotone_left = m ≤ 1;
        done
    }
    case m = 2 as mIsTwo: {
        2 * 2 = m * m by substituting mIsTwo = 2 by squareIsTwo;
        done
    }
    case 2 < m as mLarge: {
        2 ≤ m by Natural.LessThan.weaken;
        m * m = 2 by squareIsTwo < 4 ≤ 2 * m by Natural.multiply_monotone_left = m * 2 ≤ m * m by Natural.multiply_monotone_left;
        done
    }
  }
}

-- 3 is not a sum of two squares: both roots are below 2 (each square is
-- at most 3), and 0, 1, 2 are the only reachable sums.
theorem Natural.three_not_sum_of_two_squares (m n : ℕ)
        : ¬(m * m + n * n = 3) := {
  suppose m * m + n * n = 3 as sumIsThree;
  m * m ≤ m * m + n * n = 3 < 4;
  n * n ≤ n * n + m * m = m * m + n * n by Natural.add_commutative = 3 < 4;
  m = 0 ∨ m = 1 by Natural.square_below_four;
  n = 0 ∨ n = 1 by Natural.square_below_four;
  done by cases {
    case m = 0 as mZero: done by cases {
        case n = 0 as nZero: {
            3 = m * m + n * n by sumIsThree
              = 0 * 0 + n * n by substituting mZero
              = 0 * 0 + 0 * 0 by substituting nZero
              = 0;
            done
          }
        case n = 1 as nOne: {
            3 = m * m + n * n by sumIsThree
              = 0 * 0 + n * n by substituting mZero
              = 0 * 0 + 1 * 1 by substituting nOne
              = 1;
            done
          }
      }
    case m = 1 as mOne: done by cases {
        case n = 0 as nZero: {
            3 = m * m + n * n by sumIsThree
              = 1 * 1 + n * n by substituting mOne
              = 1 * 1 + 0 * 0 by substituting nZero
              = 1;
            done
          }
        case n = 1 as nOne: {
            3 = m * m + n * n by sumIsThree
              = 1 * 1 + n * n by substituting mOne
              = 1 * 1 + 1 * 1 by substituting nOne
              = 2;
            done
          }
      }
  }
}

-- 6 is not a sum of two squares. Each square is below 9, so each root
-- is 0, 1, or 2; the resulting nine ground cases miss 6.
theorem Natural.six_not_sum_of_two_squares (m n : ℕ)
        : ¬(m * m + n * n = 6) := {
  suppose m * m + n * n = 6 as sumIsSix;
  m * m ≤ m * m + n * n = 6 < 9 < 10;
  n * n ≤ n * n + m * m = m * m + n * n by Natural.add_commutative = 6 < 9 < 10;
  m = 0 ∨ m = 1 ∨ m = 2 ∨ m = 3 by Natural.square_below_ten;
  n = 0 ∨ n = 1 ∨ n = 2 ∨ n = 3 by Natural.square_below_ten;
  m = 0 ∨ m = 1 ∨ m = 2 by cases {
      case m = 0: done
      case m = 1 ∨ m = 2 ∨ m = 3: done by cases {
          case m = 1: done
          case m = 2: done
          case m = 3: {
              9 = m * m by substituting (m = 3)
                ≤ m * m + n * n
                = 6 by sumIsSix;
              9 ≤ 6 < 9;
              False by Natural.lt_irreflexive;
              done
            }
        }
    };
  n = 0 ∨ n = 1 ∨ n = 2 by cases {
      case n = 0: done
      case n = 1 ∨ n = 2 ∨ n = 3: done by cases {
          case n = 1: done
          case n = 2: done
          case n = 3: {
              9 = n * n by substituting (n = 3)
                ≤ n * n + m * m
                = m * m + n * n by Natural.add_commutative
                = 6 by sumIsSix;
              9 ≤ 6 < 9;
              False by Natural.lt_irreflexive;
              done
            }
        }
    };
  done by cases {
    case m = 0: done by cases {
        case n = 0: {
            6 = m * m + n * n by sumIsSix
              = 0 * 0 + 0 * 0 by substitution
              = 0;
            done
          }
        case n = 1: {
            6 = m * m + n * n by sumIsSix
              = 0 * 0 + 1 * 1 by substitution
              = 1;
            done
          }
        case n = 2: {
            6 = m * m + n * n by sumIsSix
              = 0 * 0 + 2 * 2 by substitution
              = 4;
            done
          }
      }
    case m = 1: done by cases {
        case n = 0: {
            6 = m * m + n * n by sumIsSix
              = 1 * 1 + 0 * 0 by substitution
              = 1;
            done
          }
        case n = 1: {
            6 = m * m + n * n by sumIsSix
              = 1 * 1 + 1 * 1 by substitution
              = 2;
            done
          }
        case n = 2: {
            6 = m * m + n * n by sumIsSix
              = 1 * 1 + 2 * 2 by substitution
              = 5;
            done
          }
      }
    case m = 2: done by cases {
        case n = 0: {
            6 = m * m + n * n by sumIsSix
              = 2 * 2 + 0 * 0 by substitution
              = 4;
            done
          }
        case n = 1: {
            6 = m * m + n * n by sumIsSix
              = 2 * 2 + 1 * 1 by substitution
              = 5;
            done
          }
        case n = 2: {
            6 = m * m + n * n by sumIsSix
              = 2 * 2 + 2 * 2 by substitution
              = 8;
            done
          }
      }
  }
}

-- 7 is not a sum of two squares. As for 6, each root is at most 2,
-- and the nine remaining ground cases miss 7.
theorem Natural.seven_not_sum_of_two_squares (m n : ℕ)
        : ¬(m * m + n * n = 7) := {
  suppose m * m + n * n = 7 as sumIsSeven;
  m * m ≤ m * m + n * n = 7 < 9 < 10;
  n * n ≤ n * n + m * m = m * m + n * n by Natural.add_commutative = 7 < 9 < 10;
  m = 0 ∨ m = 1 ∨ m = 2 ∨ m = 3 by Natural.square_below_ten;
  n = 0 ∨ n = 1 ∨ n = 2 ∨ n = 3 by Natural.square_below_ten;
  m = 0 ∨ m = 1 ∨ m = 2 by cases {
      case m = 0: done
      case m = 1 ∨ m = 2 ∨ m = 3: done by cases {
          case m = 1: done
          case m = 2: done
          case m = 3: {
              9 = m * m by substituting (m = 3)
                ≤ m * m + n * n
                = 7 by sumIsSeven;
              9 ≤ 7 < 9;
              False by Natural.lt_irreflexive;
              done
            }
        }
    };
  n = 0 ∨ n = 1 ∨ n = 2 by cases {
      case n = 0: done
      case n = 1 ∨ n = 2 ∨ n = 3: done by cases {
          case n = 1: done
          case n = 2: done
          case n = 3: {
              9 = n * n by substituting (n = 3)
                ≤ n * n + m * m
                = m * m + n * n by Natural.add_commutative
                = 7 by sumIsSeven;
              9 ≤ 7 < 9;
              False by Natural.lt_irreflexive;
              done
            }
        }
    };
  done by cases {
    case m = 0: done by cases {
        case n = 0: {
            7 = m * m + n * n by sumIsSeven
              = 0 * 0 + 0 * 0 by substitution
              = 0;
            done
          }
        case n = 1: {
            7 = m * m + n * n by sumIsSeven
              = 0 * 0 + 1 * 1 by substitution
              = 1;
            done
          }
        case n = 2: {
            7 = m * m + n * n by sumIsSeven
              = 0 * 0 + 2 * 2 by substitution
              = 4;
            done
          }
      }
    case m = 1: done by cases {
        case n = 0: {
            7 = m * m + n * n by sumIsSeven
              = 1 * 1 + 0 * 0 by substitution
              = 1;
            done
          }
        case n = 1: {
            7 = m * m + n * n by sumIsSeven
              = 1 * 1 + 1 * 1 by substitution
              = 2;
            done
          }
        case n = 2: {
            7 = m * m + n * n by sumIsSeven
              = 1 * 1 + 2 * 2 by substitution
              = 5;
            done
          }
      }
    case m = 2: done by cases {
        case n = 0: {
            7 = m * m + n * n by sumIsSeven
              = 2 * 2 + 0 * 0 by substitution
              = 4;
            done
          }
        case n = 1: {
            7 = m * m + n * n by sumIsSeven
              = 2 * 2 + 1 * 1 by substitution
              = 5;
            done
          }
        case n = 2: {
            7 = m * m + n * n by sumIsSeven
              = 2 * 2 + 2 * 2 by substitution
              = 8;
            done
          }
      }
  }
}

-- Neither 12 nor 14 is a sum of two squares. In either case both roots
-- square below 16, so the sixteen possible pairs can be checked directly.
theorem Natural.twelve_or_fourteen_not_sum_of_two_squares
        (m n target : ℕ) (targetCase : target = 12 ∨ target = 14)
        : ¬(m * m + n * n = target) := {
  suppose m * m + n * n = target as sumReads;
  target < 16 by cases {
      case target = 12: done
      case target = 14: done
    };
  m * m ≤ m * m + n * n = target < 16;
  n * n ≤ n * n + m * m
      = m * m + n * n by Natural.add_commutative
      = target < 16;
  m = 0 ∨ m = 1 ∨ m = 2 ∨ m = 3 by Natural.square_below_sixteen;
  n = 0 ∨ n = 1 ∨ n = 2 ∨ n = 3 by Natural.square_below_sixteen;
  done by cases {
    case m = 0: done by cases {
        case n = 0: {
            target = 0 * 0 + 0 * 0 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 0 * 0 + 0 * 0 = 0;
                  done
                }
              case target = 14: {
                  14 = target = 0 * 0 + 0 * 0 = 0;
                  done
                }
            }
          }
        case n = 1: {
            target = 0 * 0 + 1 * 1 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 0 * 0 + 1 * 1 = 1;
                  done
                }
              case target = 14: {
                  14 = target = 0 * 0 + 1 * 1 = 1;
                  done
                }
            }
          }
        case n = 2: {
            target = 0 * 0 + 2 * 2 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 0 * 0 + 2 * 2 = 4;
                  done
                }
              case target = 14: {
                  14 = target = 0 * 0 + 2 * 2 = 4;
                  done
                }
            }
          }
        case n = 3: {
            target = 0 * 0 + 3 * 3 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 0 * 0 + 3 * 3 = 9;
                  done
                }
              case target = 14: {
                  14 = target = 0 * 0 + 3 * 3 = 9;
                  done
                }
            }
          }
      }
    case m = 1: done by cases {
        case n = 0: {
            target = 1 * 1 + 0 * 0 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 1 * 1 + 0 * 0 = 1;
                  done
                }
              case target = 14: {
                  14 = target = 1 * 1 + 0 * 0 = 1;
                  done
                }
            }
          }
        case n = 1: {
            target = 1 * 1 + 1 * 1 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 1 * 1 + 1 * 1 = 2;
                  done
                }
              case target = 14: {
                  14 = target = 1 * 1 + 1 * 1 = 2;
                  done
                }
            }
          }
        case n = 2: {
            target = 1 * 1 + 2 * 2 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 1 * 1 + 2 * 2 = 5;
                  done
                }
              case target = 14: {
                  14 = target = 1 * 1 + 2 * 2 = 5;
                  done
                }
            }
          }
        case n = 3: {
            target = 1 * 1 + 3 * 3 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 1 * 1 + 3 * 3 = 10;
                  done
                }
              case target = 14: {
                  14 = target = 1 * 1 + 3 * 3 = 10;
                  done
                }
            }
          }
      }
    case m = 2: done by cases {
        case n = 0: {
            target = 2 * 2 + 0 * 0 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 2 * 2 + 0 * 0 = 4;
                  done
                }
              case target = 14: {
                  14 = target = 2 * 2 + 0 * 0 = 4;
                  done
                }
            }
          }
        case n = 1: {
            target = 2 * 2 + 1 * 1 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 2 * 2 + 1 * 1 = 5;
                  done
                }
              case target = 14: {
                  14 = target = 2 * 2 + 1 * 1 = 5;
                  done
                }
            }
          }
        case n = 2: {
            target = 2 * 2 + 2 * 2 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 2 * 2 + 2 * 2 = 8;
                  done
                }
              case target = 14: {
                  14 = target = 2 * 2 + 2 * 2 = 8;
                  done
                }
            }
          }
        case n = 3: {
            target = 2 * 2 + 3 * 3 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 2 * 2 + 3 * 3 = 13;
                  done
                }
              case target = 14: {
                  14 = target = 2 * 2 + 3 * 3 = 13;
                  done
                }
            }
          }
      }
    case m = 3: done by cases {
        case n = 0: {
            target = 3 * 3 + 0 * 0 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 3 * 3 + 0 * 0 = 9;
                  done
                }
              case target = 14: {
                  14 = target = 3 * 3 + 0 * 0 = 9;
                  done
                }
            }
          }
        case n = 1: {
            target = 3 * 3 + 1 * 1 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 3 * 3 + 1 * 1 = 10;
                  done
                }
              case target = 14: {
                  14 = target = 3 * 3 + 1 * 1 = 10;
                  done
                }
            }
          }
        case n = 2: {
            target = 3 * 3 + 2 * 2 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 3 * 3 + 2 * 2 = 13;
                  done
                }
              case target = 14: {
                  14 = target = 3 * 3 + 2 * 2 = 13;
                  done
                }
            }
          }
        case n = 3: {
            target = 3 * 3 + 3 * 3 by substituting sumReads;
            done by cases {
              case target = 12: {
                  12 = target = 3 * 3 + 3 * 3 = 18;
                  done
                }
              case target = 14: {
                  14 = target = 3 * 3 + 3 * 3 = 18;
                  done
                }
            }
          }
      }
  }
}

theorem Natural.twelve_not_sum_of_two_squares (m n : ℕ)
        : ¬(m * m + n * n = 12) := {
  done by Natural.twelve_or_fourteen_not_sum_of_two_squares
}

theorem Natural.fourteen_not_sum_of_two_squares (m n : ℕ)
        : ¬(m * m + n * n = 14) := {
  done by Natural.twelve_or_fourteen_not_sum_of_two_squares
}

-- 5 is not of the form m² + 2n²: both roots are below 3, and the nine
-- reachable values are 0, 1, 2, 3, 4, 6, 8, 9, 12.
theorem Natural.five_not_square_plus_double_square (m n : ℕ)
        : ¬(m * m + 2 * (n * n) = 5) := {
  suppose m * m + 2 * (n * n) = 5 as sumIsFive;
  m * m ≤ m * m + 2 * (n * n) = 5 < 6;
  n * n ≤ 2 * (n * n) by Natural.le_multiply_when_factor_at_least_one
        ≤ m * m + 2 * (n * n) by Natural.less_or_equal_add_left
        = 5 < 6;
  m = 0 ∨ m = 1 ∨ m = 2 by Natural.square_below_six;
  n = 0 ∨ n = 1 ∨ n = 2 by Natural.square_below_six;
  done by cases {
    case m = 0 as mZero: done by cases {
        case n = 0 as nZero: {
            5 = m * m + 2 * (n * n) by sumIsFive
              = 0 * 0 + 2 * (n * n) by substituting mZero
              = 0 * 0 + 2 * (0 * 0) by substituting nZero
              = 0;
            done
          }
        case n = 1 ∨ n = 2: done by cases {
            case n = 1 as nOne: {
                5 = m * m + 2 * (n * n) by sumIsFive
                  = 0 * 0 + 2 * (n * n) by substituting mZero
                  = 0 * 0 + 2 * (1 * 1) by substituting nOne
                  = 2;
                done
              }
            case n = 2 as nTwo: {
                5 = m * m + 2 * (n * n) by sumIsFive
                  = 0 * 0 + 2 * (n * n) by substituting mZero
                  = 0 * 0 + 2 * (2 * 2) by substituting nTwo
                  = 8;
                done
              }
          }
      }
    case m = 1 ∨ m = 2: done by cases {
        case m = 1 as mOne: done by cases {
            case n = 0 as nZero: {
                5 = m * m + 2 * (n * n) by sumIsFive
                  = 1 * 1 + 2 * (n * n) by substituting mOne
                  = 1 * 1 + 2 * (0 * 0) by substituting nZero
                  = 1;
                done
              }
            case n = 1 ∨ n = 2: done by cases {
                case n = 1 as nOne: {
                    5 = m * m + 2 * (n * n) by sumIsFive
                      = 1 * 1 + 2 * (n * n) by substituting mOne
                      = 1 * 1 + 2 * (1 * 1) by substituting nOne
                      = 3;
                    done
                  }
                case n = 2 as nTwo: {
                    5 = m * m + 2 * (n * n) by sumIsFive
                      = 1 * 1 + 2 * (n * n) by substituting mOne
                      = 1 * 1 + 2 * (2 * 2) by substituting nTwo
                      = 9;
                    done
                  }
              }
          }
        case m = 2 as mTwo: done by cases {
            case n = 0 as nZero: {
                5 = m * m + 2 * (n * n) by sumIsFive
                  = 2 * 2 + 2 * (n * n) by substituting mTwo
                  = 2 * 2 + 2 * (0 * 0) by substituting nZero
                  = 4;
                done
              }
            case n = 1 ∨ n = 2: done by cases {
                case n = 1 as nOne: {
                    5 = m * m + 2 * (n * n) by sumIsFive
                      = 2 * 2 + 2 * (n * n) by substituting mTwo
                      = 2 * 2 + 2 * (1 * 1) by substituting nOne
                      = 6;
                    done
                  }
                case n = 2 as nTwo: {
                    5 = m * m + 2 * (n * n) by sumIsFive
                      = 2 * 2 + 2 * (n * n) by substituting mTwo
                      = 2 * 2 + 2 * (2 * 2) by substituting nTwo
                      = 12;
                    done
                  }
              }
          }
      }
  }
}

definition Natural.IsSquarePlusDoubleSquareValueBelowSixteen
        (value : ℕ) : Proposition :=
  (value = 0 ∨ value = 1 ∨ value = 4 ∨ value = 9)
    ∨ (value = 2 ∨ value = 3 ∨ value = 6 ∨ value = 11)
    ∨ (value = 8 ∨ value = 9 ∨ value = 12)

theorem Natural.square_plus_double_square_values_below_sixteen
        (m n : ℕ) (bound : m * m + 2 * (n * n) < 16)
        : Natural.IsSquarePlusDoubleSquareValueBelowSixteen(
            m * m + 2 * (n * n)) := {
  m * m ≤ m * m + 2 * (n * n) < 16;
  n * n
     ≤ 2 * (n * n) by Natural.le_multiply_when_factor_at_least_one
     ≤ m * m + 2 * (n * n) by Natural.less_or_equal_add_left
     < 16;
  m = 0 ∨ m = 1 ∨ m = 2 ∨ m = 3
      by Natural.square_below_sixteen;
  n = 0 ∨ n = 1 ∨ n = 2 ∨ n = 3
      by Natural.square_below_sixteen;
  done by cases {
    case n = 0 as nZero: done by cases {
        case m = 0 as mZero: {
            m * m + 2 * (n * n) = 0
                by substituting mZero as valueReads;
            done by Or.introduceLeft(Or.introduceLeft(valueReads))
          }
        case m = 1 ∨ m = 2 ∨ m = 3: done by cases {
            case m = 1 as mOne: {
                m * m + 2 * (n * n)
                   = 1 * 1 + 2 * (n * n) by substituting mOne
                   = 1 * 1 + 2 * (0 * 0) by substituting nZero
                   = 1
                as valueReads;
                done by Or.introduceLeft(
                    Or.introduceRight(Or.introduceLeft(valueReads)))
              }
            case m = 2 ∨ m = 3: done by cases {
                case m = 2 as mTwo: {
                    m * m + 2 * (n * n)
                       = 2 * 2 + 2 * (n * n) by substituting mTwo
                       = 2 * 2 + 2 * (0 * 0) by substituting nZero
                       = 4
                    as valueReads;
                    done by Or.introduceLeft(Or.introduceRight(
                        Or.introduceRight(Or.introduceLeft(valueReads))))
                  }
                case m = 3 as mThree: {
                    m * m + 2 * (n * n)
                       = 3 * 3 + 2 * (n * n) by substituting mThree
                       = 3 * 3 + 2 * (0 * 0) by substituting nZero
                       = 9
                    as valueReads;
                    done by Or.introduceLeft(Or.introduceRight(
                        Or.introduceRight(Or.introduceRight(valueReads))))
                  }
              }
          }
      }
    case n = 1 ∨ n = 2 ∨ n = 3: done by cases {
        case n = 1 as nOne: done by cases {
            case m = 0 as mZero: {
                m * m + 2 * (n * n)
                   = 0 * 0 + 2 * (n * n) by substituting mZero
                   = 0 * 0 + 2 * (1 * 1) by substituting nOne
                   = 2
                as valueReads;
                done by Or.introduceRight(
                    Or.introduceLeft(Or.introduceLeft(valueReads)))
              }
            case m = 1 ∨ m = 2 ∨ m = 3: done by cases {
                case m = 1 as mOne: {
                    m * m + 2 * (n * n)
                       = 1 * 1 + 2 * (n * n) by substituting mOne
                       = 1 * 1 + 2 * (1 * 1) by substituting nOne
                       = 3
                    as valueReads;
                    done by Or.introduceRight(Or.introduceLeft(
                        Or.introduceRight(Or.introduceLeft(valueReads))))
                  }
                case m = 2 ∨ m = 3: done by cases {
                    case m = 2 as mTwo: {
                        m * m + 2 * (n * n)
                           = 2 * 2 + 2 * (n * n) by substituting mTwo
                           = 2 * 2 + 2 * (1 * 1) by substituting nOne
                           = 6
                        as valueReads;
                        done by Or.introduceRight(Or.introduceLeft(
                            Or.introduceRight(
                              Or.introduceRight(Or.introduceLeft(valueReads)))))
                      }
                    case m = 3 as mThree: {
                        m * m + 2 * (n * n)
                           = 3 * 3 + 2 * (n * n) by substituting mThree
                           = 3 * 3 + 2 * (1 * 1) by substituting nOne
                           = 11
                        as valueReads;
                        done by Or.introduceRight(Or.introduceLeft(
                            Or.introduceRight(
                              Or.introduceRight(Or.introduceRight(valueReads)))))
                      }
                  }
              }
          }
        case n = 2 ∨ n = 3: done by cases {
            case n = 2 as nTwo: done by cases {
                case m = 0 as mZero: {
                    m * m + 2 * (n * n)
                       = 0 * 0 + 2 * (n * n) by substituting mZero
                       = 0 * 0 + 2 * (2 * 2) by substituting nTwo
                       = 8
                    as valueReads;
                    done by Or.introduceRight(
                        Or.introduceRight(Or.introduceLeft(valueReads)))
                  }
                case m = 1 ∨ m = 2 ∨ m = 3: done by cases {
                    case m = 1 as mOne: {
                        m * m + 2 * (n * n)
                           = 1 * 1 + 2 * (n * n) by substituting mOne
                           = 1 * 1 + 2 * (2 * 2) by substituting nTwo
                           = 9
                        as valueReads;
                        done by Or.introduceRight(Or.introduceRight(
                            Or.introduceRight(Or.introduceLeft(valueReads))))
                      }
                    case m = 2 ∨ m = 3: done by cases {
                        case m = 2 as mTwo: {
                            m * m + 2 * (n * n)
                               = 2 * 2 + 2 * (n * n)
                                     by substituting mTwo
                               = 2 * 2 + 2 * (2 * 2)
                                     by substituting nTwo
                               = 12
                            as valueReads;
                            done by Or.introduceRight(Or.introduceRight(
                                Or.introduceRight(Or.introduceRight(valueReads))))
                          }
                        case m = 3 as mThree: {
                            17
                               = 3 * 3 + 2 * (2 * 2)
                               = m * m + 2 * (2 * 2)
                                     by substituting mThree
                               = m * m + 2 * (n * n)
                                     by substituting nTwo
                               < 16 by bound
                               < 17;
                            False by Natural.lt_irreflexive;
                            done
                          }
                      }
                  }
              }
            case n = 3 as nThree: done by cases {
                case m = 0 as mZero: {
                    18
                       = 0 * 0 + 2 * (3 * 3)
                       = m * m + 2 * (3 * 3) by substituting mZero
                       = m * m + 2 * (n * n) by substituting nThree
                       < 16 by bound
                       < 18;
                    False by Natural.lt_irreflexive;
                    done
                  }
                case m = 1 ∨ m = 2 ∨ m = 3: done by cases {
                    case m = 1 as mOne: {
                        19
                           = 1 * 1 + 2 * (3 * 3)
                           = m * m + 2 * (3 * 3) by substituting mOne
                           = m * m + 2 * (n * n) by substituting nThree
                           < 16 by bound
                           < 19;
                        False by Natural.lt_irreflexive;
                        done
                      }
                    case m = 2 ∨ m = 3: done by cases {
                        case m = 2 as mTwo: {
                            22
                               = 2 * 2 + 2 * (3 * 3)
                               = m * m + 2 * (3 * 3)
                                     by substituting mTwo
                               = m * m + 2 * (n * n)
                                     by substituting nThree
                               < 16 by bound
                               < 22;
                            False by Natural.lt_irreflexive;
                            done
                          }
                        case m = 3 as mThree: {
                            27
                               = 3 * 3 + 2 * (3 * 3)
                               = m * m + 2 * (3 * 3)
                                     by substituting mThree
                               = m * m + 2 * (n * n)
                                     by substituting nThree
                               < 16 by bound
                               < 27;
                            False by Natural.lt_irreflexive;
                            done
                          }
                      }
                  }
              }
          }
      }
  }
}

theorem Natural.not_square_plus_double_square_below_sixteen
        (m n target : ℕ)
        (targetBelow : target < 16)
        (notSmallValue :
            ¬(Natural.IsSquarePlusDoubleSquareValueBelowSixteen(target)))
        : ¬(m * m + 2 * (n * n) = target) := {
  suppose m * m + 2 * (n * n) = target as valueReads;
  m * m + 2 * (n * n) < 16 by substituting valueReads;
  Natural.IsSquarePlusDoubleSquareValueBelowSixteen(
      m * m + 2 * (n * n))
      by Natural.square_plus_double_square_values_below_sixteen;
  Natural.IsSquarePlusDoubleSquareValueBelowSixteen(target)
      by substituting valueReads;
  done
}

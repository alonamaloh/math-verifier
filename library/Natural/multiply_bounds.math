-- Natural/multiply_bounds.math
--
-- Two arithmetic facts the product rule of counting leans on:
--   * multiplication is monotone in its right factor, and
--   * the quotient and remainder of a division are unique.
-- Both are elementary, but stating them once here keeps the counting
-- bijection (Set/finite_product.math) free of arithmetic bookkeeping.

module Natural.multiply_bounds

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Natural.subtraction
import Natural.monus
import Natural.compare
import Natural.floor_divide

-- Multiplication is monotone in its right factor: if a ≤ b then c*a ≤ c*b.
-- Write b as a + s (its excess over a); then c*b = c*a + c*s, which is at
-- least c*a.
automatic theorem Natural.multiply_monotone_left (c a b : ℕ) (aLeB : a ≤ b) : c * a ≤ c * b := {
  choose excess such that b = a + excess from Natural.subtraction_witness;
  c * a
     ≤ c * a + c * excess
     = c * (a + excess)
     = c * b
}

-- ----------------------------------------------------------------------
-- Uniqueness of quotient and remainder.

-- The asymmetric core. If the two divisions agree as
-- `divisor*qLow + rLow = divisor*qHigh + rHigh` while `qLow < qHigh`,
-- then the low remainder is forced up to at least `divisor`, contradicting
-- its bound. Concretely qHigh = qLow + (1 + gap), so
-- `divisor*qHigh = divisor*qLow + divisor + divisor*gap`; cancelling the
-- common `divisor*qLow` leaves `rLow = divisor + divisor*gap + rHigh`,
-- whence `divisor ≤ rLow`, forcing `rLow` strictly below itself (via `rLow + 1 ≤ divisor`).
theorem Natural.quotient_strict_absurd
        (divisor quotientLow remainderLow quotientHigh remainderHigh : ℕ)
        (remainderLowBound : remainderLow + 1 ≤ divisor)
        (strictlyBelow : quotientLow < quotientHigh)
        (equation : divisor * quotientLow + remainderLow = divisor * quotientHigh + remainderHigh)
        : False := {
  choose gap such that quotientLow + (1 + gap) = quotientHigh
       from Natural.lt_elim;
  -- Cancel divisor*quotientLow from the equation, exposing rLow on the left
  -- and divisor + divisor*gap + rHigh on the right.
  divisor * quotientLow + remainderLow
     = divisor * quotientHigh + remainderHigh
     = divisor * (quotientLow + (1 + gap)) + remainderHigh
     = divisor * quotientLow + (divisor + divisor * gap + remainderHigh);
  remainderLow = divisor + divisor * gap + remainderHigh;
  -- So divisor ≤ rLow, forcing rLow strictly below itself.
  divisor
        ≤ divisor + (divisor * gap + remainderHigh)
        = divisor + divisor * gap + remainderHigh
        = remainderLow;
  remainderLow < divisor ≤ remainderLow;
  done
}

-- Quotients are unique: same divisor, equal `quotient*divisor + remainder`
-- with both remainders below the divisor force equal quotients. Compare the
-- two quotients; either strict order would contradict the matching remainder
-- bound (the helper above), so they are equal by antisymmetry.
theorem Natural.quotient_remainder_unique
        (divisor quotientOne remainderOne quotientTwo remainderTwo : ℕ)
        (remOneBound : remainderOne + 1 ≤ divisor)
        (remTwoBound : remainderTwo + 1 ≤ divisor)
        (equation : divisor * quotientOne + remainderOne = divisor * quotientTwo + remainderTwo)
        : quotientOne = quotientTwo := {
  -- compare_strict(quotientTwo, quotientOne): the `below` branch is
  -- quotientTwo < quotientOne (refuted), the `atLeast` branch is exactly
  -- quotientOne ≤ quotientTwo.
  suppose quotientTwo < quotientOne for contradiction {
    divisor * quotientTwo + remainderTwo
       = divisor * quotientOne + remainderOne;
    False;
    done
  };
  quotientOne ≤ quotientTwo by Natural.less_or_equal_of_not_less_than;
  suppose quotientOne < quotientTwo for contradiction { False; done };
  quotientTwo ≤ quotientOne by Natural.less_or_equal_of_not_less_than;
  done by Natural.le_antisymmetric
}

-- With equal quotients, the remainders are equal too: cancel the common
-- `divisor*quotient` from the equation.
theorem Natural.remainder_unique
        (divisor quotientOne remainderOne quotientTwo remainderTwo : ℕ)
        (remOneBound : remainderOne + 1 ≤ divisor)
        (remTwoBound : remainderTwo + 1 ≤ divisor)
        (equation : divisor * quotientOne + remainderOne = divisor * quotientTwo + remainderTwo)
        : remainderOne = remainderTwo := {
  quotientOne = quotientTwo;
  divisor * quotientTwo + remainderOne
     = divisor * quotientOne + remainderOne
     = divisor * quotientTwo + remainderTwo;
  done
}

-- x ≤ p * x when p ≥ 1. From p = 1 + (p ∸ 1): p*x = x + (p∸1)*x ≥ x.
-- (Rehomed from the deleted Natural.padic_valuation, and made successor-free.)
theorem Natural.le_multiply_when_factor_at_least_one
        (x p : ℕ) (pPositive : 1 ≤ p)
        : x ≤ p * x := {
  1 ∸ p = 0;
  p = 1 + (p ∸ 1);
  x
     ≤ x + (p ∸ 1) * x
     = (1 + (p ∸ 1)) * x
     = p * x
}

-- A square below 2 has root 0 or 1: any root of at least 2 squares to at
-- least 4.
theorem Natural.square_below_two (m : ℕ) (bound : m * m < 2) : m = 0 ∨ m = 1 := {
  m < 2 ∨ m = 2 ∨ 2 < m by Natural.lt_trichotomy;
  done by cases {
    case m < 2 as mSmall: {
        m ≤ 1 by Natural.le_of_lt_one_plus;
        m = 0 ∨ ∃ (k : ℕ). m = 1 + k;
        done by cases {
          case m = 0: done
          case ∃ (k : ℕ). m = 1 + k as mPositive: {
              choose k such that m = 1 + k from mPositive;
              1 ≤ 1 + k;
              1 ≤ m by substituting (m = 1 + k);
              m = 1 by Natural.le_antisymmetric;
              done
            }
        }
      }
    case m = 2 ∨ 2 < m as mLarge: {
        2 ≤ m by cases {
            case m = 2: done
            case 2 < m: done by Natural.LessThan.weaken
          };
        2 * 2 ≤ 2 * m by Natural.multiply_monotone_left
              = m * 2
              ≤ m * m by Natural.multiply_monotone_left as fourBelowSquare;
        m * m < 2 ≤ 2 * 2 ≤ m * m by fourBelowSquare;
        False by Natural.lt_irreflexive;
        done
      }
  }
}

-- 2 lies strictly between the consecutive squares 1 and 4, so it is not a
-- square: a root would be at most 1 (square too small) or at least 2
-- (square too large).
theorem Natural.two_is_not_a_square (m : ℕ) : ¬(m * m = 2) := {
  suppose m * m = 2 as squareIsTwo;
  m < 2 ∨ m = 2 ∨ 2 < m by Natural.lt_trichotomy;
  done by cases {
    case m < 2 as mSmall: {
        m ≤ 1 by Natural.le_of_lt_one_plus;
        2 = m * m ≤ m * 1 by Natural.multiply_monotone_left = m ≤ 1;
        done
    }
    case m = 2 as mIsTwo: {
        2 * 2 = m * m by substituting mIsTwo = 2 by squareIsTwo;
        done
    }
    case 2 < m as mLarge: {
        2 ≤ m by Natural.LessThan.weaken;
        m * m = 2 by squareIsTwo < 4 ≤ 2 * m by Natural.multiply_monotone_left = m * 2 ≤ m * m by Natural.multiply_monotone_left;
        done
    }
  }
}

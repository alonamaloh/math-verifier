-- Natural/peano.math
--
-- Peano-style facts about Natural that go beyond what the inductive
-- type itself encodes: in particular, that `successor` is never `zero`,
-- which we use to extract False from `2 = 0` and similar absurd
-- equalities. The standard trick is to define a discriminator
-- (`is_successor`) and transport `True.trivial` along the false
-- equality via the Equality recursor.

module Natural.peano

import Natural.basics
import Equality.basics
import Logic.basics

-- successor(n) ≠ zero. The hammer's constructor-disjointness
-- heuristic synthesises the proof: build a discriminator
-- `λ x : Natural. recursor_with_constant_True_on_successor_else_False x`
-- and transport `True.trivial` along the hypothetical equality via
-- Equality_recursor — the reduced form on the RHS is False.
theorem Natural.successor_not_zero (n : Natural)
        : successor(n) ≠ zero := ?

-- And the symmetric form — same heuristic handles both directions.
theorem Natural.zero_not_successor (n : Natural)
        : zero ≠ successor(n) := ?

-- Predecessor: returns zero for zero (an arbitrary choice — predecessor
-- isn't really defined there), and the inner argument for successor.
-- Used by `successor_injective` below.
definition Natural.predecessor : Natural → Natural
  | zero         => zero
  | successor(k) => k

-- successor is injective: if successor(a) = successor(b) then a = b.
-- Proof by congruence: apply `predecessor` to both sides of the
-- equality. predecessor(successor(x)) reduces definitionally to x,
-- so the result is exactly `a = b`.
theorem Natural.successor_injective (a b : Natural)
        : successor(a) = successor(b) → a = b :=
  function (equalityProof : successor(a) = successor(b)) =>
    congruenceOf(Natural.predecessor, equalityProof)

-- Useful corollary: `2 = successor(successor(successor(_)))` is absurd.
-- (Two successor_injective steps plus zero_not_successor.) Reads as
-- "2 is never of the form 3 + n", which we'll use to rule out the
-- d ≥ 3 case when classifying divisors of 2.
theorem Natural.two_not_three_plus (n : Natural)
        : Not(2 = successor(successor(successor(n)))) :=
  function (equalityProof : 2 = successor(successor(successor(n)))) =>
    Natural.zero_not_successor(n,
        Natural.successor_injective(zero, successor(n),
            Natural.successor_injective(1, successor(successor(n)),
                equalityProof)))

-- Natural/peano.math
--
-- Peano-style facts about Natural that go beyond what the inductive
-- type itself encodes: in particular, that `successor` is never `zero`,
-- which we use to extract False from `2 = 0` and similar absurd
-- equalities. The standard trick is to define a discriminator
-- (`is_successor`) and transport `True.trivial` along the false
-- equality via the Equality recursor.

module Natural.peano

import Natural.basics
import Equality.basics
import Logic.basics
import Logic.exists

-- Discriminator for `zero` vs. `successor(_)`. A Proposition-valued
-- function that is `True` at `zero` and `False` at every successor;
-- by ι-reduction `Natural.is_zero(successor(n))` *is* `False`. This
-- is the bridge that lets us turn the hypothetical equality
-- `zero = successor(n)` into a proof of `False`.
definition Natural.is_zero : Natural → Proposition
  | zero         => True
  | successor(_) => False

-- successor(n) ≠ zero. Reductio. Assume `successor(n) = zero`. The
-- trivial proof `True.trivial` inhabits `Natural.is_zero(zero)` for
-- free. Substituting along the assumed equality slides it to
-- `Natural.is_zero(successor(n))`, which by definition is `False` —
-- and that is exactly what we needed.
automatic theorem Natural.successor_not_zero (n : Natural) : successor(n) ≠ zero := {
  suppose successor(n) = zero as successorEqualsZero;
  claim Natural.is_zero(successor(n)) by substituting successorEqualsZero
}

-- Symmetric direction. Same reductio; the substituting tactic tries
-- both directions of the equality, so it doesn't matter that the
-- hypothesis here is `zero = successor(n)` rather than its mirror.
automatic theorem Natural.zero_not_successor (n : Natural) : zero ≠ successor(n) := {
  suppose zero = successor(n) as zeroEqualsSuccessor;
  claim Natural.is_zero(successor(n)) by substituting zeroEqualsSuccessor
}

-- Predecessor: returns zero for zero (an arbitrary choice — predecessor
-- isn't really defined there), and the inner argument for successor.
-- Used by `successor_injective` below.
definition Natural.predecessor : Natural → Natural
  | zero         => zero
  | successor(k) => k

-- successor is injective: if successor(a) = successor(b) then a = b.
automatic theorem Natural.successor_injective (a b : Natural)
        (equalityProof : successor(a) = successor(b)) : a = b :=
  calc a
     = Natural.predecessor(successor(a))
     = Natural.predecessor(successor(b))
     = b

-- Useful corollary: `2 = successor(successor(successor(_)))` is absurd.
-- Peel two successors via injectivity to reach `0 = successor(n)`, then
-- the bare `zero_not_successor`. Reads as "2 is never of the form 3 + n";
-- used to rule out the d ≥ 3 case when classifying divisors of 2.
theorem Natural.two_not_three_plus (n : Natural)
        : 2 ≠ successor(successor(successor(n))) := {
  suppose 2 = successor(successor(successor(n))) as twoEqualsThreePlus;
  1 = successor(successor(n));
  0 = successor(n) as zeroEqualsSuccessor;
  absurd(zeroEqualsSuccessor)
}

-- Every natural is either zero or the successor of some predecessor.
-- The expected disjunction for splitting a Natural propositionally:
-- `claim goal by cases { case n = 0: …  case ∃ k. n = successor(k): … }`
-- — finds this lemma via the unified hammer.
automatic theorem Natural.zero_or_successor (n : Natural)
        : n = 0 ∨ ∃ (k : Natural). n = successor(k) :=
  cases n {
    | zero         => done
    | successor(k) => {
        ∃ (predecessor : Natural). successor(k) = successor(predecessor)
            by witness k with done;
        done
      }
  }

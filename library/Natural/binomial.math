-- Natural/binomial.math
--
-- Binomial coefficients by the Pascal recursion, with the overflow
-- rule C(n, k) = 0 for k > n.

module Natural.binomial

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Natural.strong_recursion
import Natural.multiply_order
import Natural.decide
import Natural.classical_decidable
import Natural.divisibility
import Natural.factorial

-- Binomial coefficients (Pascal's triangle), written as a formula over named
-- arguments: the k = 0 edge of every row is 1, and off that edge C(n, k) is the
-- sum of the two entries one row up. The `if n = 0` guard desugars to the
-- structural recursion on the first argument (see the named-argument recursion
-- desugaring in the elaborator), and the `if k = 0` edge test is a classical
-- `if` — so consumers compute through the characterizing lemmas below
-- (binomial_zero_right, binomial_zero_succ, binomial_pascal), not by unfolding.
definition Natural.binomial (n k : Natural) : Natural :=
  if n = 0
    then (if k = 0 then 1 else 0)
    else if k = 0
      then 1
      else Natural.binomial(Natural.monus(n, 1), Natural.monus(k, 1))
             + Natural.binomial(Natural.monus(n, 1), k)

-- The k = 0 edge of every row is 1. Either way binomial(n, 0) = if 0 = 0 then 1,
-- so both cases close by if_positive; the split just exposes that `if`. The
-- constructor arms are deliberate: the `if` guard needs the scrutinee's
-- structure (an equation arm's `1 + k` goal is opaque-add-stuck).
theorem Natural.binomial_zero_right (n : Natural) : Natural.binomial(n, 0) = 1 :=
  unfold Natural in
  by induction on n {
    case zero:         done by Logic.if_positive
    case successor(k): done by Logic.if_positive
  }

-- The top row is empty off its first entry: C(0, k+1) = 0.
theorem Natural.binomial_zero_succ (k : Natural)
        : Natural.binomial(0, 1 + k) = 0 := {
  ¬(1 + k = 0);
  done by Logic.if_negative
}

-- Pascal's rule: C(n+1, k+1) = C(n, k) + C(n, k+1). The `k+1 = 0` test fails,
-- so the coefficient is the else branch, with monus(k+1, 1) = k.
theorem Natural.binomial_pascal (n k : Natural)
        : Natural.binomial(1 + n, 1 + k)
          = Natural.binomial(n, k) + Natural.binomial(n, 1 + k) :=
  unfold Natural.add, Natural in
  if 1 + k = 0
  then { 1 + k ≠ 0; done }
  else {
    Natural.monus(1 + k, 1) = k;
    done
  }

-- Above the diagonal the coefficients vanish.
theorem Natural.binomial_overflow (n : Natural)
        : ∀ (k : Natural). 1 + n ≤ k → Natural.binomial(n, k) = 0 :=
  by induction on n with IH {
    case zero:
        (k : Natural) (overflow : 1 + 0 ≤ k) ↦
          done by cases {
            case k = 0 as kIsZero: {
                1 + 0 ≤ k by overflow = 0 by kIsZero;
                unfold Natural.add, Natural in {
                  False;
                  done
                }
              }
            case k = 1 + kPredecessor for some kPredecessor: {
                Natural.binomial(0, 1 + kPredecessor) = 0 by Natural.binomial_zero_succ;
                done
              }
          }
    case 1 + nPredecessor:
        (k : Natural) (overflow : 1 + (1 + nPredecessor) ≤ k) ↦
          done by cases {
            case k = 0 as kIsZero: {
                1 + (1 + nPredecessor) ≤ k by overflow = 0 by kIsZero;
                unfold Natural.add, Natural in {
                  False;
                  done
                }
              }
            case k = 1 + kPredecessor for some kPredecessor as kIsSuccessor: {
                1 + (1 + nPredecessor) ≤ k by overflow = 1 + kPredecessor by kIsSuccessor;
                1 + nPredecessor ≤ kPredecessor as innerOverflow;
                1 + nPredecessor ≤ 1 + kPredecessor as outerOverflow;
                Natural.binomial(nPredecessor, kPredecessor) = 0
                    by IH(kPredecessor, innerOverflow);
                Natural.binomial(nPredecessor, 1 + kPredecessor) = 0
                    by IH(1 + kPredecessor, outerOverflow);
                Natural.binomial(1 + nPredecessor, 1 + kPredecessor)
                   = Natural.binomial(nPredecessor, kPredecessor)
                     + Natural.binomial(nPredecessor, 1 + kPredecessor)
                         by Natural.binomial_pascal
                   = 0 + Natural.binomial(nPredecessor, 1 + kPredecessor)
                   = 0 + 0
                   = 0
              }
          }
  }

-- The closed form, stated additively to keep the subtraction honest:
-- C(j + n, j) · j! · n! = (j + n)!. The outer recursion is on j (Pascal's
-- rule splits the coefficient); each new row is proved by recursion on n
-- with the whole previous row in hand, since the second Pascal summand
-- lives one column back in the same row.

-- One row step: row i (in full) gives row i + 1.
theorem Natural.binomial_factorial_row (i : Natural)
        (previousRow : ∀ (n : Natural). Natural.binomial(i + n, i) * (i! * n!) = (i + n)!)
        (n : Natural)
        : Natural.binomial((1 + i) + n, 1 + i) * ((1 + i)! * n!) = ((1 + i) + n)! :=
  by induction on n with IH {
    case n = 0: unfold Natural.add, Natural in {
        i + 0 = i;
        (1 + (i + 0)) ≤ 1 + i;
        Natural.binomial(i + 0, 1 + i) = 0;
        Natural.binomial(i + 0, i) * (i! * 0!) = (i + 0)! by previousRow(0);
        (1 + i)! = (1 + i) * i!;
        Natural.binomial((1 + i) + 0, 1 + i) * ((1 + i)! * 0!)
           = (Natural.binomial(i + 0, i) + Natural.binomial(i + 0, 1 + i)) * ((1 + i)! * 0!)
           = (Natural.binomial(i + 0, i) + 0) * ((1 + i)! * 0!)
           = (Natural.binomial(i + 0, i) + 0) * (((1 + i) * i!) * 0!)
           = (1 + (i + 0)) * (Natural.binomial(i + 0, i) * (i! * 0!))
           = (1 + (i + 0)) * (i + 0)!
           = ((1 + i) + 0)!
      }
    case n = 1 + m: unfold Natural.add, Natural in {
        Natural.binomial(i + (1 + m), i) * (i! * (1 + m)!) = (i + (1 + m))! by previousRow(1 + m);
        Natural.binomial((1 + i) + m, 1 + i) * ((1 + i)! * m!) = ((1 + i) + m)! by IH;
        i + (1 + m) = (1 + i) + m;
        (1 + i)! = (1 + i) * i!;
        (1 + m)! = (1 + m) * m!;
        Natural.binomial((1 + i) + (1 + m), 1 + i)
            = Natural.binomial(i + (1 + m), i) + Natural.binomial(i + (1 + m), 1 + i);
        Natural.binomial(i + (1 + m), 1 + i) = Natural.binomial((1 + i) + m, 1 + i);
        Natural.binomial(i + (1 + m), i) * ((1 + i)! * (1 + m)!)
           = Natural.binomial(i + (1 + m), i) * (((1 + i) * i!) * (1 + m)!)
           = (1 + i) * (Natural.binomial(i + (1 + m), i) * (i! * (1 + m)!))
           = (1 + i) * (i + (1 + m))!;
        Natural.binomial((1 + i) + m, 1 + i) * ((1 + i)! * (1 + m)!)
           = Natural.binomial((1 + i) + m, 1 + i) * ((1 + i)! * ((1 + m) * m!))
           = (1 + m) * (Natural.binomial((1 + i) + m, 1 + i) * ((1 + i)! * m!))
           = (1 + m) * ((1 + i) + m)!;
        Natural.binomial((1 + i) + (1 + m), 1 + i) * ((1 + i)! * (1 + m)!)
           = (Natural.binomial(i + (1 + m), i) + Natural.binomial(i + (1 + m), 1 + i)) * ((1 + i)! * (1 + m)!)
           = (Natural.binomial(i + (1 + m), i) + Natural.binomial((1 + i) + m, 1 + i)) * ((1 + i)! * (1 + m)!)
           = Natural.binomial(i + (1 + m), i) * ((1 + i)! * (1 + m)!)
             + Natural.binomial((1 + i) + m, 1 + i) * ((1 + i)! * (1 + m)!)
           = (1 + i) * (i + (1 + m))! + Natural.binomial((1 + i) + m, 1 + i) * ((1 + i)! * (1 + m)!)
           = (1 + i) * (i + (1 + m))! + (1 + m) * ((1 + i) + m)!
           = (1 + i) * (i + (1 + m))! + (1 + m) * (i + (1 + m))!
           = ((1 + i) + (1 + m)) * (i + (1 + m))!
           = ((1 + i) + (1 + m))!
      }
  }

-- The closed form itself, row by row.
theorem Natural.binomial_factorial (j : Natural)
        : ∀ (n : Natural). Natural.binomial(j + n, j) * (j! * n!) = (j + n)! :=
  by induction on j with previousRow {
    case 0: {
        take n : Natural;
        Natural.binomial(0 + n, 0) = 1;
        Natural.binomial(0 + n, 0) * (0! * n!) = 1 * (0! * n!) = (0 + n)!
      }
    case 1 + i: {
        take n : Natural;
        Natural.binomial((1 + i) + n, 1 + i) * ((1 + i)! * n!) = ((1 + i) + n)! by Natural.binomial_factorial_row
      }
  }

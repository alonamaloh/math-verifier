-- Natural/binomial.math
--
-- Binomial coefficients by the Pascal recursion, with the overflow
-- rule C(n, k) = 0 for k > n.

module Natural.binomial

import axioms
import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Natural.strong_recursion
import Natural.multiply_order
import Natural.decide
import Natural.divisibility
import Natural.factorial

definition Natural.binomial : Natural → Natural → Natural
  | zero, k =>
      cases k {
        | zero => 1
        | successor(_) => 0
      }
  | successor(n), k =>
      cases k {
        | zero => 1
        | successor(kPredecessor) =>
            Natural.binomial(n, kPredecessor)
            + Natural.binomial(n, successor(kPredecessor))
      }

-- Above the diagonal the coefficients vanish.
theorem Natural.binomial_overflow (n : Natural)
        : ∀ (k : Natural). successor(n) ≤ k → Natural.binomial(n, k) = 0 :=
  unfold Natural.add in
  by_induction on n with IH {
    case zero:
        (k : Natural) (overflow : successor(0) ≤ k) ↦
          cases k refining overflow {
            | zero => {
                claim False;
                done
              }
            | successor(kPredecessor) => done
          }
    case successor(nPredecessor):
        (k : Natural) (overflow : successor(successor(nPredecessor)) ≤ k) ↦
          cases k refining overflow {
            | zero => {
                claim False;
                done
              }
            | successor(kPredecessor) => {
                claim innerOverflow : successor(nPredecessor) ≤ kPredecessor
                    by Natural.successor_le_cancel;
                claim outerOverflow
                      : successor(nPredecessor) ≤ successor(kPredecessor);
                claim Natural.binomial(nPredecessor, kPredecessor) = 0
                    by IH(kPredecessor, innerOverflow);
                claim Natural.binomial(nPredecessor, successor(kPredecessor)) = 0
                    by IH(successor(kPredecessor), outerOverflow);
                calc Natural.binomial(
                         successor(nPredecessor), successor(kPredecessor))
                   = Natural.binomial(nPredecessor, kPredecessor)
                     + Natural.binomial(nPredecessor, successor(kPredecessor))
                   = 0 + Natural.binomial(nPredecessor, successor(kPredecessor))
                   = 0 + 0
                   = 0
              }
          }
  }

-- The left edge of Pascal's triangle is all ones.
theorem Natural.binomial_zero_right
        : ∀ (n : Natural). Natural.binomial(n, 0) = 1
  | zero => done
  | successor(nPredecessor) => done

-- The closed form, stated additively to keep the subtraction honest:
-- C(j + n, j) · j! · n! = (j + n)!. The outer recursion is on j (Pascal's
-- rule splits the coefficient); each new row is proved by recursion on n
-- with the whole previous row in hand, since the second Pascal summand
-- lives one column back in the same row.

-- One row step: row i (in full) gives row i + 1.
theorem Natural.binomial_factorial_row (i : Natural)
        (previousRow
            : ∀ (n : Natural).
              Natural.binomial(i + n, i)
                    * (Natural.factorial(i) * Natural.factorial(n))
                = Natural.factorial(i + n))
        : ∀ (n : Natural).
          Natural.binomial(successor(i) + n, successor(i))
                * (Natural.factorial(successor(i)) * Natural.factorial(n))
            = Natural.factorial(successor(i) + n)
  | zero => unfold Natural.add in {
      claim i + 0 = i;
      claim successor(i + 0) ≤ successor(i);
      claim Natural.binomial(i + 0, successor(i)) = 0;
      claim Natural.binomial(i + 0, i)
                * (Natural.factorial(i) * Natural.factorial(0))
            = Natural.factorial(i + 0)
          by previousRow(0);
      claim Natural.factorial(successor(i)) = successor(i) * Natural.factorial(i);
      calc Natural.binomial(successor(i) + 0, successor(i))
               * (Natural.factorial(successor(i)) * Natural.factorial(0))
         = (Natural.binomial(i + 0, i) + Natural.binomial(i + 0, successor(i)))
               * (Natural.factorial(successor(i)) * Natural.factorial(0))
         = (Natural.binomial(i + 0, i) + 0)
               * (Natural.factorial(successor(i)) * Natural.factorial(0))
         = (Natural.binomial(i + 0, i) + 0)
               * ((successor(i) * Natural.factorial(i)) * Natural.factorial(0))
         = successor(i + 0)
               * (Natural.binomial(i + 0, i)
                      * (Natural.factorial(i) * Natural.factorial(0)))
         = successor(i + 0) * Natural.factorial(i + 0)
         = Natural.factorial(successor(i) + 0)
    }
  | successor(m) => unfold Natural.add in {
      claim Natural.binomial(i + successor(m), i)
                * (Natural.factorial(i) * Natural.factorial(successor(m)))
            = Natural.factorial(i + successor(m))
          by previousRow(successor(m));
      claim Natural.binomial(successor(i) + m, successor(i))
                * (Natural.factorial(successor(i)) * Natural.factorial(m))
            = Natural.factorial(successor(i) + m);
      claim i + successor(m) = successor(i) + m;
      claim Natural.factorial(successor(i)) = successor(i) * Natural.factorial(i);
      claim Natural.factorial(successor(m)) = successor(m) * Natural.factorial(m);
      claim Natural.binomial(successor(i) + successor(m), successor(i))
            = Natural.binomial(i + successor(m), i)
              + Natural.binomial(i + successor(m), successor(i));
      claim Natural.binomial(i + successor(m), successor(i))
            = Natural.binomial(successor(i) + m, successor(i));
      calc Natural.binomial(i + successor(m), i)
               * (Natural.factorial(successor(i)) * Natural.factorial(successor(m)))
         = Natural.binomial(i + successor(m), i)
               * ((successor(i) * Natural.factorial(i))
                      * Natural.factorial(successor(m)))
         = successor(i)
               * (Natural.binomial(i + successor(m), i)
                      * (Natural.factorial(i) * Natural.factorial(successor(m))))
         = successor(i) * Natural.factorial(i + successor(m));
      calc Natural.binomial(successor(i) + m, successor(i))
               * (Natural.factorial(successor(i)) * Natural.factorial(successor(m)))
         = Natural.binomial(successor(i) + m, successor(i))
               * (Natural.factorial(successor(i))
                      * (successor(m) * Natural.factorial(m)))
         = successor(m)
               * (Natural.binomial(successor(i) + m, successor(i))
                      * (Natural.factorial(successor(i)) * Natural.factorial(m)))
         = successor(m) * Natural.factorial(successor(i) + m);
      calc Natural.binomial(successor(i) + successor(m), successor(i))
               * (Natural.factorial(successor(i)) * Natural.factorial(successor(m)))
         = (Natural.binomial(i + successor(m), i)
                + Natural.binomial(i + successor(m), successor(i)))
               * (Natural.factorial(successor(i)) * Natural.factorial(successor(m)))
         = (Natural.binomial(i + successor(m), i)
                + Natural.binomial(successor(i) + m, successor(i)))
               * (Natural.factorial(successor(i)) * Natural.factorial(successor(m)))
         = Natural.binomial(i + successor(m), i)
               * (Natural.factorial(successor(i)) * Natural.factorial(successor(m)))
           + Natural.binomial(successor(i) + m, successor(i))
               * (Natural.factorial(successor(i)) * Natural.factorial(successor(m)))
         = successor(i) * Natural.factorial(i + successor(m))
           + Natural.binomial(successor(i) + m, successor(i))
               * (Natural.factorial(successor(i)) * Natural.factorial(successor(m)))
         = successor(i) * Natural.factorial(i + successor(m))
           + successor(m) * Natural.factorial(successor(i) + m)
         = successor(i) * Natural.factorial(i + successor(m))
           + successor(m) * Natural.factorial(i + successor(m))
         = (successor(i) + successor(m)) * Natural.factorial(i + successor(m))
         = Natural.factorial(successor(i) + successor(m))
    }

-- The closed form itself, row by row.
theorem Natural.binomial_factorial (j : Natural)
        : ∀ (n : Natural).
          Natural.binomial(j + n, j)
                * (Natural.factorial(j) * Natural.factorial(n))
            = Natural.factorial(j + n) :=
  by_induction on j with previousRow {
    case zero: (n : Natural) ↦ {
        claim Natural.binomial(0 + n, 0) = 1;
        calc Natural.binomial(0 + n, 0)
                 * (Natural.factorial(0) * Natural.factorial(n))
           = 1 * (Natural.factorial(0) * Natural.factorial(n))
           = Natural.factorial(0 + n)
      }
    case successor(i): done by Natural.binomial_factorial_row
  }

-- Natural/padic_valuation.math
--
-- `Natural.padic_valuation(p, n)`: the largest k such that p^k divides
-- n. Defined honestly as a `Natural → Natural → Natural` function via
-- fuel-based recursion. Pattern-matches on `Natural.modulo(p, n)`
-- (a Natural) to test divisibility — Type-safe.
--
-- For p ≥ 2, each iteration strips one factor of p; n iterations of
-- fuel always suffice. For p ≤ 1, the convention here is that the
-- function returns 0 (since "infinite valuation" or undefined doesn't
-- fit in `Natural`).

module Natural.padic_valuation

import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.divide
import Natural.multiply_order
import Natural.cancellation
import Natural.divisibility
import Natural.subtraction
import Natural.distance
import Natural.power
import Natural.prime
import Natural.decide_divides
import Natural.prime_divides_product
import Integer.basics
import Integer.addition
import Integer.absolute_value_natural
import Equality.basics
import Logic.basics
import Logic.exists
import Logic.quotient

-- padic_valuation_step(fuel, prime, target): fuel-bounded valuation.
-- With fuel ≥ floor(log_prime(target)), returns the largest k with
-- prime^k | target. Recursion is structural on fuel.
definition Natural.padic_valuation_step
        : (fuel prime target : Natural) → Natural
  | zero,            _,     _      => zero
  | successor(fuel), prime, target =>
      cases Natural.modulo(prime, target) {
        | zero =>
            -- prime | target: strip one factor, count one.
            successor(
                Natural.padic_valuation_step(
                    fuel, prime, Natural.divide(prime, target)))
        | successor(_) =>
            -- prime ∤ target: done.
            0
      }

-- Top-level p-adic valuation. Fuel = target is more than enough.
definition Natural.padic_valuation (prime target : Natural) : Natural :=
  Natural.padic_valuation_step(
      fuel := target, prime := prime, target := target)

-- ----------------------------------------------------------------------
-- Step-level recursive characterizations.

-- When modulo(p, n) ≠ 0 (i.e., monus(modulo(p, n), 1) = some succ),
-- the step returns 0. Used for the "p ∤ n" case.
theorem Natural.padic_valuation_step_zero_when_not_divides
        (fuel prime target predM : Natural)
        (moduloIsSucc : Natural.modulo(prime, target) = successor(predM))
        : Natural.padic_valuation_step(successor(fuel), prime, target)
          = 0 :=
  Equality.transport_proposition(
      Natural,
      function (m : Natural) =>
          (cases m {
             | zero =>
                 successor(Natural.padic_valuation_step(
                               fuel, prime, Natural.divide(prime, target)))
             | successor(_) => zero
           } : Natural) = 0,
      successor(predM), Natural.modulo(prime, target),
      Equality.symmetry(moduloIsSucc),
      reflexivity(Natural, 0))

-- When modulo(p, n) = 0, the step recurses.
theorem Natural.padic_valuation_step_succ_when_divides
        (fuel prime target : Natural)
        (moduloZero : Natural.modulo(prime, target) = 0)
        : Natural.padic_valuation_step(successor(fuel), prime, target)
          = successor(Natural.padic_valuation_step(
                          fuel, prime, Natural.divide(prime, target))) :=
  Equality.transport_proposition(
      Natural,
      function (m : Natural) =>
          (cases m {
             | zero =>
                 successor(Natural.padic_valuation_step(
                               fuel, prime, Natural.divide(prime, target)))
             | successor(_) => zero
           } : Natural)
          = successor(Natural.padic_valuation_step(
                          fuel, prime, Natural.divide(prime, target))),
      0, Natural.modulo(prime, target),
      Equality.symmetry(moduloZero),
      reflexivity(Natural,
          successor(Natural.padic_valuation_step(
              fuel, prime, Natural.divide(prime, target)))))

-- ----------------------------------------------------------------------
-- Helpers about Natural.divide when the modulo is zero.

-- When the modulo is zero and the target is positive, the quotient is also
-- positive. Reason: from divide_modulo_decompose, prime * divide = target;
-- if divide were zero, prime * 0 = 0 ≠ target ≥ 1. Case-split on the
-- value of divide, using the with-pattern.
theorem Natural.divide_positive_when_divides
        (prime target : Natural)
        (targetPositive : successor(0) ≤ target)
        (moduloZero : Natural.modulo(prime, target) = 0)
        : successor(0) ≤ Natural.divide(prime, target) := {
  calc prime * Natural.divide(prime, target)
     = prime * Natural.divide(prime, target) + 0
     = prime * Natural.divide(prime, target)
         + Natural.modulo(prime, target)
     = target                                                as productEqTarget;
  cases Natural.divide(prime, target) with refinedDivideEq {
    | zero =>
        -- prime * 0 = 0, so target = 0, contradicting targetPositive.
        absurd(
            rewrite(
                calc target
                   = prime * Natural.divide(prime, target)
                   = prime * 0
                   = 0,
                targetPositive))
    | successor(q') =>
        -- divide = successor(q') ≥ 1. Transport from successor(q') back.
        rewrite(
            Equality.symmetry(refinedDivideEq),
            Natural.successor_less_or_equal_successor(
                0, q', Natural.zero_least(q')))
  }
}

-- The quotient is strictly less than the target when prime ≥ 2,
-- target ≥ 1, and prime divides target. From prime * divide = target
-- with divide ≥ 1 and prime ≥ 2, successor(divide) ≤ prime * divide.
theorem Natural.divide_lt_when_divides
        (prime target : Natural)
        (primeAtLeastTwo : successor(successor(0)) ≤ prime)
        (targetPositive : successor(0) ≤ target)
        (moduloZero : Natural.modulo(prime, target) = 0)
        : successor(Natural.divide(prime, target)) ≤ target := {
  calc prime * Natural.divide(prime, target)
     = prime * Natural.divide(prime, target) + 0
     = prime * Natural.divide(prime, target)
         + Natural.modulo(prime, target)
     = target                                                as productEqTarget;
  claim dividePositive : successor(0) ≤ Natural.divide(prime, target)
    by Natural.divide_positive_when_divides(
           prime, target, targetPositive, moduloZero);
  -- successor(divide) ≤ prime * divide  (since 2 ≤ prime, 1 ≤ divide).
  -- Transport via productEqTarget : prime * divide = target.
  rewrite(
      productEqTarget,
      Natural.successor_less_or_equal_multiply(
          prime, Natural.divide(prime, target),
          primeAtLeastTwo, dividePositive))
}

-- ----------------------------------------------------------------------
-- Fuel monotonicity for `padic_valuation_step` at target ≥ 1.
--
-- Strong induction on target. The predicate quantifies over both
-- fuels (and the divides-quotient is smaller than target, so the IH
-- applies). At target = 0 the predicate is vacuously true (premise
-- 1 ≤ 0 fails). At target ≥ 1 with both fuels ≥ target, dispatch on
-- modulo(prime, target):
--   * modulo ≠ 0: both fuels give 0 by step_zero_when_not_divides.
--   * modulo = 0: both fuels descend to step on divide(prime, target),
--     a strictly smaller target; IH applies.

theorem Natural.padic_valuation_step_fuel_stable
        (prime target fuel1 fuel2 : Natural)
        (primeAtLeastTwo : successor(successor(0)) ≤ prime)
        (targetPositive : successor(0) ≤ target)
        (fuel1Sufficient : target ≤ fuel1)
        (fuel2Sufficient : target ≤ fuel2)
        : Natural.padic_valuation_step(fuel1, prime, target)
          = Natural.padic_valuation_step(fuel2, prime, target) :=
  Natural.strong_induction(
      function (t : Natural) =>
          (f1 f2 : Natural)
            → successor(0) ≤ t → t ≤ f1 → t ≤ f2
            → Natural.padic_valuation_step(f1, prime, t)
              = Natural.padic_valuation_step(f2, prime, t),
      function (n : Natural)
               (inductionHypothesis :
                   (k : Natural) → successor(k) ≤ n
                     → (f1 f2 : Natural)
                         → successor(0) ≤ k → k ≤ f1 → k ≤ f2
                         → Natural.padic_valuation_step(f1, prime, k)
                           = Natural.padic_valuation_step(f2, prime, k)) =>
        function (f1 f2 : Natural)
                 (nPositive : successor(0) ≤ n)
                 (nLeF1 : n ≤ f1)
                 (nLeF2 : n ≤ f2) =>
          -- Case on f1; f1 must be a successor since n ≥ 1.
          (cases f1 {
             | zero =>
                 function (refinedNLeF1 : n ≤ 0) =>
                   absurd(
                       LessOrEqual.transitive(
                           successor(0), n, 0,
                           refinedNLeF1, nPositive))
             | successor(f1') =>
                 function (refinedNLeF1 : n ≤ successor(f1')) =>
                   -- Case on f2 next.
                   (cases f2 {
                      | zero =>
                          function (refinedNLeF2 : n ≤ 0) =>
                            absurd(
                                LessOrEqual.transitive(
                                    successor(0), n, 0,
                                    refinedNLeF2, nPositive))
                      | successor(f2') =>
                          function (refinedNLeF2 : n ≤ successor(f2')) =>
                            -- Both fuels are successors. Case on modulo.
                            cases Natural.modulo(prime, n) with refinedModuloEq {
                              | zero =>
                                  calc Natural.padic_valuation_step(
                                           successor(f1'), prime, n)
                                     = successor(Natural.padic_valuation_step(
                                           f1', prime, Natural.divide(prime, n)))
                                            by Natural.padic_valuation_step_succ_when_divides(
                                                   f1', prime, n, refinedModuloEq)
                                     = successor(Natural.padic_valuation_step(
                                           f2', prime, Natural.divide(prime, n)))
                                            by congruenceOf(
                                                   successor,
                                                   inductionHypothesis(
                                                       Natural.divide(prime, n),
                                                       Natural.divide_lt_when_divides(
                                                           prime, n,
                                                           primeAtLeastTwo,
                                                           nPositive,
                                                           refinedModuloEq),
                                                       f1', f2',
                                                       Natural.divide_positive_when_divides(
                                                           prime, n,
                                                           nPositive,
                                                           refinedModuloEq),
                                                       Natural.less_or_equal_successor_successor_descend(
                                                           Natural.divide(prime, n),
                                                           f1',
                                                           LessOrEqual.transitive(
                                                               successor(Natural.divide(prime, n)),
                                                               n, successor(f1'),
                                                               refinedNLeF1,
                                                               Natural.divide_lt_when_divides(
                                                                   prime, n,
                                                                   primeAtLeastTwo,
                                                                   nPositive,
                                                                   refinedModuloEq))),
                                                       Natural.less_or_equal_successor_successor_descend(
                                                           Natural.divide(prime, n),
                                                           f2',
                                                           LessOrEqual.transitive(
                                                               successor(Natural.divide(prime, n)),
                                                               n, successor(f2'),
                                                               refinedNLeF2,
                                                               Natural.divide_lt_when_divides(
                                                                   prime, n,
                                                                   primeAtLeastTwo,
                                                                   nPositive,
                                                                   refinedModuloEq)))))
                                     = Natural.padic_valuation_step(
                                           successor(f2'), prime, n)
                                            by Equality.symmetry(
                                                   Natural.padic_valuation_step_succ_when_divides(
                                                       f2', prime, n,
                                                       refinedModuloEq))
                              | successor(predM) =>
                                  calc Natural.padic_valuation_step(successor(f1'), prime, n)
                                     = 0
                                           by Natural.padic_valuation_step_zero_when_not_divides(
                                                  f1', prime, n, predM, refinedModuloEq)
                                     = Natural.padic_valuation_step(successor(f2'), prime, n)
                                           by Equality.symmetry(
                                                  Natural.padic_valuation_step_zero_when_not_divides(
                                                      f2', prime, n, predM, refinedModuloEq))
                            }
                    } : (refinedNLeF2 : n ≤ f2)
                        → Natural.padic_valuation_step(successor(f1'), prime, n)
                          = Natural.padic_valuation_step(f2, prime, n))(nLeF2)
           } : (refinedNLeF1 : n ≤ f1)
               → Natural.padic_valuation_step(f1, prime, n)
                 = Natural.padic_valuation_step(f2, prime, n))(nLeF1),
      target,
      fuel1, fuel2, targetPositive, fuel1Sufficient, fuel2Sufficient)

-- ----------------------------------------------------------------------
-- Top-level recursive equations for `padic_valuation`.

-- The valuation is zero when the prime does not divide the target.
-- Two cases:
--   * target = 0: divides_zero gives prime | 0, contradicting notDivides.
--   * target ≥ 1: case on modulo(prime, target). modulo = 0 makes
--     prime | target via modulo_zero_implies_divides (contradiction);
--     modulo = succ(_) makes padic_valuation_step_zero_when_not_divides
--     apply directly.
theorem Natural.padic_valuation_when_not_divides
        (prime target : Natural)
        (notDivides : ¬ Natural.divides(prime, target))
        : Natural.padic_valuation(prime, target) = 0 :=
  (cases target {
     | zero =>
         function (refinedNotDivides : ¬ Natural.divides(prime, 0)) =>
           absurd(refinedNotDivides(Natural.divides_zero(prime)))
     | successor(predT) =>
         function (refinedNotDivides
                     : ¬ Natural.divides(prime, successor(predT))) =>
           cases Natural.modulo(prime, successor(predT)) with refinedModuloEq {
             | zero =>
                 absurd(
                     refinedNotDivides(
                         Natural.modulo_zero_implies_divides(
                             prime, successor(predT), refinedModuloEq)))
             | successor(predM) =>
                 Natural.padic_valuation_step_zero_when_not_divides(
                     predT, prime, successor(predT), predM, refinedModuloEq)
           }
   } : ¬ Natural.divides(prime, target)
       → Natural.padic_valuation(prime, target) = 0)(notDivides)

-- Stripping one factor of the prime increases the valuation by one.
-- For prime ≥ 2 and quotient ≥ 1, modulo(prime, prime * quotient) = 0
-- (since prime divides itself times anything). The step then peels
-- one factor of prime; the recursive call lands on
-- divide(prime, prime * quotient) = quotient. Fuel stability bridges
-- the fuel difference between the recursive call (with fuel = predPQ)
-- and padic_valuation(prime, quotient) (with fuel = quotient).
theorem Natural.padic_valuation_strip
        (prime quotient : Natural)
        (primeAtLeastTwo : successor(successor(0)) ≤ prime)
        (quotientPositive : successor(0) ≤ quotient)
        : Natural.padic_valuation(prime, prime * quotient)
          = successor(Natural.padic_valuation(prime, quotient)) := {
  claim primePositive : successor(0) ≤ prime
    by Natural.less_or_equal_predecessor_less_or_equal(
           successor(0), prime, primeAtLeastTwo);
  claim productPositive : successor(0) ≤ prime * quotient
    by Natural.multiply_at_least_one(
           prime, quotient, primePositive, quotientPositive);
  claim moduloZero : Natural.modulo(prime, prime * quotient) = 0
    by Natural.divides_implies_modulo_zero(
           prime, prime * quotient, primePositive,
           Natural.divides_self_multiple(prime, quotient));
  -- From decompose + moduloZero, prime * divide(prime, prime*quotient) = prime * quotient.
  -- Cancel the prime factor (primePositive) to get divide = quotient.
  claim divideEqQuotient : Natural.divide(prime, prime * quotient) = quotient
    by Natural.multiply_cancel_left(
           prime, Natural.divide(prime, prime * quotient), quotient,
           primePositive,
           calc prime * Natural.divide(prime, prime * quotient)
              = prime * Natural.divide(prime, prime * quotient) + 0
              = prime * Natural.divide(prime, prime * quotient)
                  + Natural.modulo(prime, prime * quotient)
              = prime * quotient);
  -- Case-split on prime * quotient to expose successor structure for step_succ_when_divides.
  cases prime * quotient with refinedPqEq {
    | zero =>
        absurd(rewrite(refinedPqEq, productPositive))
    | successor(predPQ) =>
        calc Natural.padic_valuation(prime, prime * quotient)
           = Natural.padic_valuation(prime, successor(predPQ))
           = successor(Natural.padic_valuation_step(
                 predPQ, prime,
                 Natural.divide(prime, successor(predPQ))))
                  by Natural.padic_valuation_step_succ_when_divides(
                         predPQ, prime, successor(predPQ),
                         rewrite(refinedPqEq, moduloZero))
           = successor(Natural.padic_valuation_step(
                 predPQ, prime, quotient))
                  by congruenceOf(
                         function (m : Natural) =>
                             successor(
                                 Natural.padic_valuation_step(predPQ, prime, m)),
                         calc Natural.divide(prime, successor(predPQ))
                            = Natural.divide(prime, prime * quotient)
                            = quotient)
           = successor(Natural.padic_valuation_step(
                 quotient, prime, quotient))
                  by congruenceOf(
                         successor,
                         Natural.padic_valuation_step_fuel_stable(
                             prime, quotient, predPQ, quotient,
                             primeAtLeastTwo, quotientPositive,
                             -- quotient ≤ predPQ via succ(quotient) ≤ succ(predPQ).
                             Natural.less_or_equal_successor_successor_descend(
                                 quotient, predPQ,
                                 rewrite(
                                     refinedPqEq,
                                     Natural.successor_less_or_equal_multiply(
                                         prime, quotient,
                                         primeAtLeastTwo,
                                         quotientPositive))),
                             LessOrEqual.reflexivity(quotient)))
  }
}

-- ----------------------------------------------------------------------
-- Multiplicativity of `padic_valuation`.

-- Small helper: if succ(d) ≤ a, then succ(d + b) ≤ a + b. Definitional
-- reductions of add on succ first arg make this a transport plus a
-- successor-step. Induction on b.
theorem Natural.successor_add_preserves_le
        : (b a d : Natural)
          → successor(d) ≤ a
          → successor(d + b) ≤ a + b
  | zero, a, d, succDLeA =>
      rewrite(
          Equality.symmetry(Natural.add_zero(a)),
          rewrite(
              Equality.symmetry(Natural.add_zero(d)),
              succDLeA))
  | successor(b'), a, d, succDLeA =>
      -- IH on b' gives succ(d + b') ≤ a + b'. By successor_preserves,
      -- succ(succ(d + b')) ≤ succ(a + b'). Then rewrite both sides via
      -- add_successor symmetry to express in terms of succ(b').
      rewrite(
          Equality.symmetry(Natural.add_successor(a, b')),
          rewrite(
              congruenceOf(
                  successor,
                  Equality.symmetry(Natural.add_successor(d, b'))),
              Natural.successor_less_or_equal_successor(
                  successor(d + b'), a + b',
                  Natural.successor_add_preserves_le(b', a, d, succDLeA))))

-- Main theorem: v_p(a · b) = v_p(a) + v_p(b) for prime p, a ≥ 1, b ≥ 1.
--
-- Strong induction on a + b. Dispatch by decides_divides:
--   * p | a: a = p · a' with a' = divide(p, a) (a' ≥ 1, a' < a). Apply
--     strip on the LHS and on v_p(a); recurse via IH at a' + b < a + b
--     to relate v_p(a' · b) to v_p(a') + v_p(b).
--   * p ∤ a, p | b: symmetric.
--   * p ∤ a, p ∤ b: by Euclid's lemma, p ∤ (a · b). All three valuations
--     are zero, and 0 = 0 + 0.

theorem Natural.padic_valuation_multiplicative
        (prime a b : Natural)
        (primality : Natural.is_prime(prime))
        (aPositive : successor(0) ≤ a)
        (bPositive : successor(0) ≤ b)
        : Natural.padic_valuation(prime, a * b)
          = Natural.padic_valuation(prime, a)
                + Natural.padic_valuation(prime, b) := {
  claim primeAtLeastTwo : 2 ≤ prime by Natural.is_prime.at_least_two(prime, primality);
  claim primePositive   : 1 ≤ prime by Natural.is_prime.positive(prime, primality);
  Natural.strong_induction(
      function (s : Natural) =>
          (a' b' : Natural)
            → successor(0) ≤ a' → successor(0) ≤ b'
            → a' + b' = s
            → Natural.padic_valuation(prime, a' * b')
              = Natural.padic_valuation(prime, a')
                    + Natural.padic_valuation(prime, b'),
      function (n : Natural)
               (inductionHypothesis :
                   (k : Natural) → successor(k) ≤ n
                     → (a' b' : Natural)
                         → successor(0) ≤ a' → successor(0) ≤ b'
                         → a' + b' = k
                         → Natural.padic_valuation(prime, a' * b')
                           = Natural.padic_valuation(prime, a')
                                 + Natural.padic_valuation(prime, b')) =>
        function (a' b' : Natural)
                 (a'Positive : successor(0) ≤ a')
                 (b'Positive : successor(0) ≤ b')
                 (sumEq : a' + b' = n) =>
          claim (prime ∣ a') ∨ (prime ∤ a')
          claim by cases {
            in (prime ∣ a') as pDividesA: {
                claim moduloAIsZero : Natural.modulo(prime, a') = 0
                  by Natural.divides_implies_modulo_zero(
                         prime, a', primePositive, pDividesA);
                claim divideAPositive
                      : successor(0) ≤ Natural.divide(prime, a')
                  by Natural.divide_positive_when_divides(
                         prime, a', a'Positive, moduloAIsZero);
                claim succDivideALeA
                      : successor(Natural.divide(prime, a')) ≤ a'
                  by Natural.divide_lt_when_divides(
                         prime, a', primeAtLeastTwo, a'Positive, moduloAIsZero);
                calc a'
                   = prime * Natural.divide(prime, a')
                       + Natural.modulo(prime, a')
                         by Equality.symmetry(
                                Natural.divide_modulo_decompose(prime, a'))
                   = prime * Natural.divide(prime, a') + 0
                   = prime * Natural.divide(prime, a')           as aEqPrimeDivide;
                -- IH on (divide(p, a'), b'): need succ(divide + b') ≤ n.
                claim recursiveSumLeN
                      : successor(Natural.divide(prime, a') + b') ≤ n
                  by rewrite(
                         sumEq,
                         Natural.successor_add_preserves_le(
                             b', a', Natural.divide(prime, a'), succDivideALeA));
                claim recursedEq
                      : Natural.padic_valuation(
                            prime, Natural.divide(prime, a') * b')
                        = Natural.padic_valuation(prime, Natural.divide(prime, a'))
                              + Natural.padic_valuation(prime, b')
                  by inductionHypothesis(
                         Natural.divide(prime, a') + b',
                         recursiveSumLeN,
                         Natural.divide(prime, a'), b',
                         divideAPositive, b'Positive,
                         reflexivity(Natural,
                             Natural.divide(prime, a') + b'));
                calc Natural.padic_valuation(prime, a' * b')
                   = Natural.padic_valuation(
                         prime, (prime * Natural.divide(prime, a')) * b')
                   = Natural.padic_valuation(
                         prime, prime * (Natural.divide(prime, a') * b'))
                   = successor(Natural.padic_valuation(
                         prime, Natural.divide(prime, a') * b'))
                          by Natural.padic_valuation_strip(
                                 prime, Natural.divide(prime, a') * b',
                                 primeAtLeastTwo,
                                 Natural.multiply_at_least_one(
                                     Natural.divide(prime, a'), b',
                                     divideAPositive, b'Positive))
                   = successor(Natural.padic_valuation(
                         prime, Natural.divide(prime, a'))
                       + Natural.padic_valuation(prime, b'))
                   = successor(Natural.padic_valuation(
                         prime, Natural.divide(prime, a')))
                     + Natural.padic_valuation(prime, b')
                   = Natural.padic_valuation(
                         prime, prime * Natural.divide(prime, a'))
                     + Natural.padic_valuation(prime, b')
                          by congruenceOf(
                                 function (m : Natural) =>
                                     m + Natural.padic_valuation(prime, b'),
                                 Equality.symmetry(
                                     Natural.padic_valuation_strip(
                                         prime, Natural.divide(prime, a'),
                                         primeAtLeastTwo,
                                         divideAPositive)))
                   = Natural.padic_valuation(prime, a')
                     + Natural.padic_valuation(prime, b')
              }
            in (prime ∤ a') as notDivA:
                claim (prime ∣ b') ∨ (prime ∤ b')
                claim by cases {
                  in (prime ∣ b') as pDividesB: {
                      claim moduloBIsZero : Natural.modulo(prime, b') = 0
                        by Natural.divides_implies_modulo_zero(
                               prime, b', primePositive, pDividesB);
                      claim divideBPositive
                            : successor(0) ≤ Natural.divide(prime, b')
                        by Natural.divide_positive_when_divides(
                               prime, b', b'Positive, moduloBIsZero);
                      claim succDivideBLeB
                            : successor(Natural.divide(prime, b')) ≤ b'
                        by Natural.divide_lt_when_divides(
                               prime, b', primeAtLeastTwo, b'Positive,
                               moduloBIsZero);
                      calc b'
                         = prime * Natural.divide(prime, b')
                             + Natural.modulo(prime, b')
                               by Equality.symmetry(
                                      Natural.divide_modulo_decompose(prime, b'))
                         = prime * Natural.divide(prime, b') + 0
                         = prime * Natural.divide(prime, b')         as bEqPrimeDivide;
                      -- IH on (a', divide(p, b')): need succ(a' + divide) ≤ n.
                      -- a' + divide < a' + b' = n; specifically succ(a' + divide) ≤ a' + b'.
                      claim recursiveSumLeN
                            : successor(a' + Natural.divide(prime, b')) ≤ n
                        by rewrite(
                               sumEq,
                               -- succ(a' + div) ≤ a' + b' from succ(div) ≤ b'.
                               -- successor_add_preserves_le gives succ(d+x) ≤ a+x
                               -- from succ(d) ≤ a; here d = div, x = a', a = b'.
                               -- We want succ(a' + div) ≤ a' + b'. Use commutative.
                               rewrite(
                                   congruenceOf(
                                       successor,
                                       Natural.add_commutative(
                                           Natural.divide(prime, b'), a')),
                                   rewrite(
                                       Natural.add_commutative(b', a'),
                                       Natural.successor_add_preserves_le(
                                           a', b', Natural.divide(prime, b'),
                                           succDivideBLeB))));
                      claim recursedEq
                            : Natural.padic_valuation(
                                  prime, a' * Natural.divide(prime, b'))
                              = Natural.padic_valuation(prime, a')
                                    + Natural.padic_valuation(
                                          prime, Natural.divide(prime, b'))
                        by inductionHypothesis(
                               a' + Natural.divide(prime, b'),
                               recursiveSumLeN,
                               a', Natural.divide(prime, b'),
                               a'Positive, divideBPositive,
                               reflexivity(Natural,
                                   a' + Natural.divide(prime, b')));
                      calc Natural.padic_valuation(prime, a' * b')
                         = Natural.padic_valuation(
                               prime, a' * (prime * Natural.divide(prime, b')))
                         = Natural.padic_valuation(
                               prime, prime * (a' * Natural.divide(prime, b')))
                                by congruenceOf(
                                       function (m : Natural) =>
                                           Natural.padic_valuation(prime, m),
                                       calc a' * (prime * Natural.divide(prime, b'))
                                          = prime * (a' * Natural.divide(prime, b')))
                         = successor(Natural.padic_valuation(
                               prime, a' * Natural.divide(prime, b')))
                                by Natural.padic_valuation_strip(
                                       prime, a' * Natural.divide(prime, b'),
                                       primeAtLeastTwo,
                                       Natural.multiply_at_least_one(
                                           a', Natural.divide(prime, b'),
                                           a'Positive, divideBPositive))
                         = successor(Natural.padic_valuation(prime, a')
                                     + Natural.padic_valuation(
                                           prime, Natural.divide(prime, b')))
                         = Natural.padic_valuation(prime, a')
                             + successor(Natural.padic_valuation(
                                   prime, Natural.divide(prime, b')))
                         = Natural.padic_valuation(prime, a')
                             + Natural.padic_valuation(
                                   prime, prime * Natural.divide(prime, b'))
                                by congruenceOf(
                                       function (m : Natural) =>
                                           Natural.padic_valuation(prime, a') + m,
                                       Equality.symmetry(
                                           Natural.padic_valuation_strip(
                                               prime, Natural.divide(prime, b'),
                                               primeAtLeastTwo,
                                               divideBPositive)))
                         = Natural.padic_valuation(prime, a')
                             + Natural.padic_valuation(prime, b')
                    }
                  in (prime ∤ b') as notDivB: {
                      -- prime ∤ a' ∧ prime ∤ b' → prime ∤ (a' * b').
                      claim notDivProduct : prime ∤ (a' * b')
                        by function (productDivides : prime ∣ a' * b') =>
                               {
                               claim (prime ∣ a') ∨ (prime ∣ b')
                                   by Natural.prime_divides_product(
                                          prime, a', b', primality,
                                          productDivides)
                               claim by cases {
                                 in (prime ∣ a') as primeDivA: notDivA(primeDivA)
                                 in (prime ∣ b') as primeDivB: notDivB(primeDivB)
                               }
                               };
                      -- All three valuations are zero.
                      calc Natural.padic_valuation(prime, a' * b')
                         = 0
                                by Natural.padic_valuation_when_not_divides(
                                       prime, a' * b', notDivProduct)
                         = 0 + 0
                         = Natural.padic_valuation(prime, a') + 0
                                by congruenceOf(
                                       function (m : Natural) => m + 0,
                                       Equality.symmetry(
                                           Natural.padic_valuation_when_not_divides(
                                               prime, a', notDivA)))
                         = Natural.padic_valuation(prime, a')
                             + Natural.padic_valuation(prime, b')
                                by congruenceOf(
                                       function (m : Natural) =>
                                           Natural.padic_valuation(prime, a') + m,
                                       Equality.symmetry(
                                           Natural.padic_valuation_when_not_divides(
                                               prime, b', notDivB)))
                    }
                }
          },
      a + b, a, b, aPositive, bPositive, reflexivity(Natural, a + b))
}

-- ----------------------------------------------------------------------
-- Towards the ultrametric inequality: p^v_p(n) divides n.

-- Helper: if d divides n, then prime * d divides prime * n. From
-- n = d * q derive prime * n = prime * d * q = (prime * d) * q.
theorem Natural.divides_multiply_left
        (k d n : Natural) (dDividesN : d ∣ n)
        : k * d ∣ k * n := {
  let ⟨q, nEqDQ⟩ := dDividesN;
  ⟨q,
   calc k * n
      = k * (d * q)
      = k * d * q⟩
}

-- p^v_p(n) divides n, for prime ≥ 2 and any n. Strong induction on n.
-- Cases: m = 0 (trivial since 1 | 0); m ≥ 1 with decides_divides(p, m)
-- dispatch.
theorem Natural.padic_valuation_power_divides
        (prime : Natural)
        (primeAtLeastTwo : successor(successor(0)) ≤ prime)
        : (n : Natural)
          → Natural.divides(
                Natural.power(Natural.padic_valuation(prime, n), prime), n) :=
  Natural.strong_induction(
      function (m : Natural) =>
          Natural.divides(
              Natural.power(Natural.padic_valuation(prime, m), prime), m),
      function (m : Natural)
               (inductionHypothesis :
                   (k : Natural) → successor(k) ≤ m
                     → Natural.divides(
                           Natural.power(Natural.padic_valuation(prime, k), prime),
                           k)) =>
        claim (prime ∣ m) ∨ (prime ∤ m)
        claim by cases {
          in (prime ∣ m) as pDividesM: {
              -- m = prime * q. Case on q to handle m = 0 (q = 0) vs the
              -- recursive case (q ≥ 1).
              let ⟨q, mEqPrimeQ⟩ := pDividesM;
              (cases q {
                 | zero =>
                     function (refinedMEq : m = prime * 0) =>
                       -- m = prime * 0 = 0. v_p(0) = 0. p^0 = 1. 1 | m = 0.
                       Equality.transport_proposition(
                           Natural,
                           function (mValue : Natural) =>
                               Natural.divides(
                                   Natural.power(
                                       Natural.padic_valuation(prime, mValue),
                                       prime),
                                   mValue),
                           0, m,
                           Equality.symmetry(
                               calc m
                                  = prime * 0
                                  = 0),
                           Natural.one_divides(0))
                 | successor(predQ) =>
                     function (refinedMEq : m = prime * successor(predQ)) => {
                       claim primePositive : successor(0) ≤ prime
                         by Natural.less_or_equal_predecessor_less_or_equal(
                                successor(0), prime, primeAtLeastTwo);
                       claim succQPositive : 1 ≤ successor(predQ)
                         by Natural.successor_positive(predQ);
                       -- succ(q) < m. From m = p * q with p ≥ 2, q ≥ 1:
                       -- succ(q) ≤ p * q = m.
                       claim succQLeM
                             : successor(successor(predQ)) ≤ m
                         by rewrite(
                                Equality.symmetry(refinedMEq),
                                Natural.successor_less_or_equal_multiply(
                                    prime, successor(predQ),
                                    primeAtLeastTwo, succQPositive));
                       -- IH on succ(predQ): p^v_p(succ(predQ)) | succ(predQ).
                       claim qDivResult
                             : Natural.divides(
                                   Natural.power(
                                       Natural.padic_valuation(
                                           prime, successor(predQ)), prime),
                                   successor(predQ))
                         by inductionHypothesis(
                                successor(predQ), succQLeM);
                       -- Apply strip: v_p(p * succ(predQ)) = succ(v_p(succ(predQ))).
                       claim valuationProduct
                             : Natural.padic_valuation(
                                   prime, prime * successor(predQ))
                               = successor(
                                     Natural.padic_valuation(
                                         prime, successor(predQ)))
                         by Natural.padic_valuation_strip(
                                prime, successor(predQ),
                                primeAtLeastTwo, succQPositive);
                       -- power(succ(v_p(q)), p) = p * power(v_p(q), p).
                       -- divides_multiply_left: p^v_p(q) | q → p * p^v_p(q) | p * q.
                       claim shiftedDivides
                             : Natural.divides(
                                   prime
                                     * Natural.power(
                                           Natural.padic_valuation(
                                               prime, successor(predQ)),
                                           prime),
                                   prime * successor(predQ))
                         by Natural.divides_multiply_left(
                                prime,
                                Natural.power(
                                    Natural.padic_valuation(
                                        prime, successor(predQ)), prime),
                                successor(predQ),
                                qDivResult);
                       -- Bridge: p * p^v_p(q) = p^(succ(v_p(q))) = p^v_p(p*q) = p^v_p(m).
                       Equality.transport_proposition(
                           Natural,
                           function (m' : Natural) =>
                               Natural.divides(
                                   Natural.power(
                                       Natural.padic_valuation(prime, m'),
                                       prime),
                                   m'),
                           prime * successor(predQ), m,
                           Equality.symmetry(refinedMEq),
                           Equality.transport_proposition(
                               Natural,
                               function (v : Natural) =>
                                   Natural.divides(
                                       Natural.power(v, prime),
                                       prime * successor(predQ)),
                               successor(
                                   Natural.padic_valuation(
                                       prime, successor(predQ))),
                               Natural.padic_valuation(
                                   prime, prime * successor(predQ)),
                               Equality.symmetry(valuationProduct),
                               -- power(succ(v_p(q)), p) reduces to
                               -- p * power(v_p(q), p) by definition.
                               shiftedDivides))
                     }
               } : m = prime * q
                   → Natural.divides(
                         Natural.power(Natural.padic_valuation(prime, m), prime),
                         m))(mEqPrimeQ)
          }
          in (prime ∤ m) as notDivM:
              -- v_p(m) = 0. p^0 = 1. 1 | m.
              Equality.transport_proposition(
                  Natural,
                  function (v : Natural) =>
                      Natural.divides(Natural.power(v, prime), m),
                  0, Natural.padic_valuation(prime, m),
                  Equality.symmetry(
                      Natural.padic_valuation_when_not_divides(
                          prime, m, notDivM)),
                  Natural.one_divides(m))
        })

-- p^j | p^k when j ≤ k. From j ≤ k get a witness r with k = j + r;
-- then power(k, p) = power(j + r, p) = power(j, p) * power(r, p).
theorem Natural.power_divides_power
        (p j k : Natural) (jLeK : j ≤ k)
        : Natural.divides(Natural.power(j, p), Natural.power(k, p)) := {
    obtain ⟨r, kEqJPlusR⟩ from Natural.subtraction_witness(j, k, jLeK);
    witness Natural.power(r, p) with
        (calc Natural.power(k, p)
            = Natural.power(j + r, p)
            = Natural.power(j, p) * Natural.power(r, p))
}

-- Combining the above two: if k ≤ v_p(n), then p^k | n.
theorem Natural.padic_valuation_ge_implies_power_divides
        (prime : Natural)
        (primeAtLeastTwo : successor(successor(0)) ≤ prime)
        (k n : Natural)
        (kLeValuation : k ≤ Natural.padic_valuation(prime, n))
        : Natural.divides(Natural.power(k, prime), n) :=
  Natural.divides_transitive(
      Natural.power(k, prime),
      Natural.power(Natural.padic_valuation(prime, n), prime),
      n,
      Natural.power_divides_power(prime, k,
          Natural.padic_valuation(prime, n), kLeValuation),
      Natural.padic_valuation_power_divides(prime, primeAtLeastTwo, n))

-- Converse direction: if p^k | n (with n ≥ 1), then k ≤ v_p(n).
-- Induct on k. At successor(k'): from p^succ(k') | n, get p | n
-- (since p | p^succ(k') | n). Apply IH on q = divide(p, n) using strip.
theorem Natural.power_divides_implies_padic_valuation_ge
        (prime : Natural)
        (primeAtLeastTwo : successor(successor(0)) ≤ prime)
        : (k n : Natural)
          → successor(0) ≤ n
          → Natural.divides(Natural.power(k, prime), n)
          → k ≤ Natural.padic_valuation(prime, n)
  | zero, n, _, _ =>
      Natural.zero_least(Natural.padic_valuation(prime, n))
  | successor(predK), n, nPositive, succPDivides => {
      claim primePositive : successor(0) ≤ prime
        by Natural.less_or_equal_predecessor_less_or_equal(
               successor(0), prime, primeAtLeastTwo);
      -- p^succ(predK) = p * p^predK | n. So p | n.
      claim pDividesN : prime ∣ n
        by Natural.divides_transitive(
               prime,
               Natural.power(successor(predK), prime),
               n,
               -- p | p^succ(predK) — witness power(predK, p).
               (witness Natural.power(predK, prime) with
                   reflexivity(Natural,
                       Natural.power(successor(predK), prime))),
               succPDivides);
      let ⟨q, nEqPrimeQ⟩ := pDividesN;
      -- For q = 0 case: n = 0, contradicts n ≥ 1.
      -- For q = succ(predQ): apply strip + IH.
      (cases q {
         | zero =>
             function (refinedNEq : n = prime * 0) =>
               absurd(
                   rewrite(
                       calc n
                          = prime * 0
                          = 0,
                       nPositive))
         | successor(predQ) =>
             function (refinedNEq : n = prime * successor(predQ)) => {
               claim succQPositive : 1 ≤ successor(predQ)
                 by Natural.successor_positive(predQ);
               -- p^succ(predK) | n = p * succ(predQ). Hence
               -- p * p^predK | p * succ(predQ). Cancel p (multiply_cancel_left).
               -- Get p^predK | succ(predQ).
               -- More directly: p^succ(predK) | p*succ(predQ), and
               -- p^succ(predK) = p * p^predK. So p * p^predK | p * succ(predQ).
               -- From this we extract p^predK | succ(predQ).
               let ⟨w, nEqProductW⟩ := succPDivides;
               -- nEqProductW : n = p^succ(predK) * w = (p * p^predK) * w
               --             = p * (p^predK * w).
               -- And n = p * succ(predQ) by refinedNEq.
               -- So p * succ(predQ) = p * (p^predK * w).
               -- By multiply_cancel_left: succ(predQ) = p^predK * w. So p^predK | succ(predQ).
               claim qDividesEq
                     : successor(predQ)
                       = Natural.power(predK, prime) * w
                 by Natural.multiply_cancel_left(
                        prime, successor(predQ),
                        Natural.power(predK, prime) * w,
                        primePositive,
                        calc prime * successor(predQ)
                           = n
                           = Natural.power(successor(predK), prime) * w
                           = (prime * Natural.power(predK, prime)) * w
                           = prime * (Natural.power(predK, prime) * w));
               claim pPredKDividesQ
                     : Natural.divides(
                           Natural.power(predK, prime),
                           successor(predQ))
                 by witness w with qDividesEq;
               -- By IH on (predK, succ(predQ)): predK ≤ v_p(succ(predQ)).
               claim ihResult
                     : predK ≤ Natural.padic_valuation(
                                   prime, successor(predQ))
                 by Natural.power_divides_implies_padic_valuation_ge(
                        prime, primeAtLeastTwo,
                        predK, successor(predQ),
                        succQPositive, pPredKDividesQ);
               -- v_p(n) = v_p(p * succ(predQ)) = succ(v_p(succ(predQ))) by strip.
               -- So we want succ(predK) ≤ succ(v_p(succ(predQ))).
               rewrite(
                   calc successor(Natural.padic_valuation(prime, successor(predQ)))
                      = Natural.padic_valuation(prime, prime * successor(predQ))
                            by Equality.symmetry(
                                   Natural.padic_valuation_strip(
                                       prime, successor(predQ),
                                       primeAtLeastTwo, succQPositive))
                      = Natural.padic_valuation(prime, n),
                   Natural.successor_less_or_equal_successor(
                       predK,
                       Natural.padic_valuation(prime, successor(predQ)),
                       ihResult))
             }
       } : n = prime * q
           → successor(predK) ≤ Natural.padic_valuation(prime, n))(nEqPrimeQ)
    }

-- Natural ultrametric, asymmetric form: when v_p(a) ≤ v_p(b),
-- v_p(a) ≤ v_p(a + b), provided a + b ≥ 1 (so the bridge converse
-- applies). Path: p^v_p(a) divides both a and b (using the
-- bidirectional bridge above); divides_add gives p^v_p(a) | (a+b);
-- then the converse bridge gives v_p(a) ≤ v_p(a+b).
theorem Natural.padic_valuation_ultrametric_when_le
        (prime : Natural)
        (primeAtLeastTwo : successor(successor(0)) ≤ prime)
        (a b : Natural)
        (sumPositive : successor(0) ≤ a + b)
        (valuationLe :
            Natural.padic_valuation(prime, a)
              ≤ Natural.padic_valuation(prime, b))
        : Natural.padic_valuation(prime, a)
          ≤ Natural.padic_valuation(prime, a + b) := {
  claim pPowerDividesA
        : Natural.divides(
              Natural.power(Natural.padic_valuation(prime, a), prime), a)
    by Natural.padic_valuation_ge_implies_power_divides(
           prime, primeAtLeastTwo,
           Natural.padic_valuation(prime, a), a,
           LessOrEqual.reflexivity(Natural.padic_valuation(prime, a)));
  claim pPowerDividesB
        : Natural.divides(
              Natural.power(Natural.padic_valuation(prime, a), prime), b)
    by Natural.padic_valuation_ge_implies_power_divides(
           prime, primeAtLeastTwo,
           Natural.padic_valuation(prime, a), b, valuationLe);
  claim pPowerDividesSum
        : Natural.divides(
              Natural.power(Natural.padic_valuation(prime, a), prime),
              a + b)
    by Natural.divides_add(
           Natural.power(Natural.padic_valuation(prime, a), prime),
           a, b, pPowerDividesA, pPowerDividesB);
  Natural.power_divides_implies_padic_valuation_ge(
      prime, primeAtLeastTwo,
      Natural.padic_valuation(prime, a),
      a + b, sumPositive, pPowerDividesSum)
}

-- Symmetric form: when v_p(b) ≤ v_p(a), v_p(b) ≤ v_p(a + b).
-- Derived from the previous via add_commutative.
theorem Natural.padic_valuation_ultrametric_when_ge
        (prime : Natural)
        (primeAtLeastTwo : successor(successor(0)) ≤ prime)
        (a b : Natural)
        (sumPositive : successor(0) ≤ a + b)
        (valuationLe :
            Natural.padic_valuation(prime, b)
              ≤ Natural.padic_valuation(prime, a))
        : Natural.padic_valuation(prime, b)
          ≤ Natural.padic_valuation(prime, a + b) :=
  rewrite(
      Natural.add_commutative(b, a),
      Natural.padic_valuation_ultrametric_when_le(
          prime, primeAtLeastTwo, b, a,
          rewrite(
              Natural.add_commutative(a, b),
              sumPositive),
          valuationLe))

-- Subtraction preserves divides: if d | a and d | b and b ≤ a, then
-- d | monus(a, b). Uses monus_zero_implies_decompose to express
-- a = b + monus(a, b), then divides_subtract_from_sum.
theorem Natural.divides_monus
        (d a b : Natural)
        (bLeA : b ≤ a)
        (dDividesA : d ∣ a)
        (dDividesB : d ∣ b)
        : d ∣ Natural.monus(a, b) := {
  claim aEqBPlusMonus : a = b + Natural.monus(a, b)
    by Natural.monus_zero_implies_decompose(
           b, a, Natural.le_implies_monus_zero(a, b, bLeA));
  -- Transport dDividesA along aEqBPlusMonus to get d | (b + monus(a, b)).
  Natural.divides_subtract_from_sum(
      d, b, Natural.monus(a, b),
      rewrite(aEqBPlusMonus, dDividesA),
      dDividesB)
}

-- Ultrametric for monus: when v_p(b) ≤ v_p(a) and b ≤ a (so monus is
-- a-b at the Natural level), v_p(monus(a, b)) ≥ v_p(b), provided
-- monus(a, b) ≥ 1.
theorem Natural.padic_valuation_monus_ultrametric_when_le
        (prime : Natural)
        (primeAtLeastTwo : successor(successor(0)) ≤ prime)
        (a b : Natural)
        (bLeA : b ≤ a)
        (monusPositive : successor(0) ≤ Natural.monus(a, b))
        (valuationLe :
            Natural.padic_valuation(prime, b)
              ≤ Natural.padic_valuation(prime, a))
        : Natural.padic_valuation(prime, b)
          ≤ Natural.padic_valuation(prime, Natural.monus(a, b)) := {
  claim pPowerDividesA
        : Natural.divides(
              Natural.power(Natural.padic_valuation(prime, b), prime), a)
    by Natural.padic_valuation_ge_implies_power_divides(
           prime, primeAtLeastTwo,
           Natural.padic_valuation(prime, b), a, valuationLe);
  claim pPowerDividesB
        : Natural.divides(
              Natural.power(Natural.padic_valuation(prime, b), prime), b)
    by Natural.padic_valuation_ge_implies_power_divides(
           prime, primeAtLeastTwo,
           Natural.padic_valuation(prime, b), b,
           LessOrEqual.reflexivity(Natural.padic_valuation(prime, b)));
  claim pPowerDividesMonus
        : Natural.divides(
              Natural.power(Natural.padic_valuation(prime, b), prime),
              Natural.monus(a, b))
    by Natural.divides_monus(
           Natural.power(Natural.padic_valuation(prime, b), prime),
           a, b, bLeA, pPowerDividesA, pPowerDividesB);
  Natural.power_divides_implies_padic_valuation_ge(
      prime, primeAtLeastTwo,
      Natural.padic_valuation(prime, b),
      Natural.monus(a, b), monusPositive, pPowerDividesMonus)
}

-- And the analogue when v_p(a) ≤ v_p(b): then v_p(a) ≤ v_p(monus(b, a))
-- (assuming a ≤ b so monus is non-negative). Symmetric form via the
-- _when_le above by swapping a, b.
theorem Natural.padic_valuation_monus_ultrametric_when_ge
        (prime : Natural)
        (primeAtLeastTwo : successor(successor(0)) ≤ prime)
        (a b : Natural)
        (aLeB : a ≤ b)
        (monusPositive : successor(0) ≤ Natural.monus(b, a))
        (valuationLe :
            Natural.padic_valuation(prime, a)
              ≤ Natural.padic_valuation(prime, b))
        : Natural.padic_valuation(prime, a)
          ≤ Natural.padic_valuation(prime, Natural.monus(b, a)) :=
  Natural.padic_valuation_monus_ultrametric_when_le(
      prime, primeAtLeastTwo, b, a, aLeB, monusPositive, valuationLe)

-- distance(a, b) equals monus(a, b) when b ≤ a (and monus(b, a) when
-- a ≤ b). These convert between the structurally-recursive distance
-- and the order-dependent monus formulation so we can apply divides
-- facts.
theorem Natural.distance_monus_when_le
        : (b a : Natural) → b ≤ a → Natural.distance(a, b) = Natural.monus(a, b)
  | zero, a, _ =>
      -- distance(a, 0) = a, monus(a, 0) = a.
      calc Natural.distance(a, 0)
         = a
         = Natural.monus(a, 0)
  | successor(predB), a, succPredBLeA =>
      (cases a {
         | zero =>
             function (refinedLe : successor(predB) ≤ 0) =>
               absurd(refinedLe)
         | successor(predA) =>
             function (refinedLe : successor(predB) ≤ successor(predA)) =>
               -- distance(succ(predA), succ(predB)) reduces to
               -- distance(predA, predB). monus(succ(predA), succ(predB))
               -- reduces to monus(predA, predB).
               Natural.distance_monus_when_le(
                   predB, predA,
                   Natural.less_or_equal_successor_successor_descend(
                       predB, predA, refinedLe))
       } : (refinedLe : successor(predB) ≤ a)
           → Natural.distance(a, successor(predB))
             = Natural.monus(a, successor(predB)))(succPredBLeA)

-- The other side: distance(a, b) = monus(b, a) when a ≤ b. Use symmetry.
theorem Natural.distance_monus_when_ge
        (a b : Natural) (aLeB : a ≤ b)
        : Natural.distance(a, b) = Natural.monus(b, a) :=
  calc Natural.distance(a, b)
     = Natural.distance(b, a)
     = Natural.monus(b, a)
           by Natural.distance_monus_when_le(a, b, aLeB)

-- Helper: a ≤ c implies a + b ≤ c + b. By induction on the proof of a ≤ c.
theorem Natural.le_add_preserves_left
        (a c b : Natural) (aLeC : a ≤ c)
        : a + b ≤ c + b := {
  -- From a ≤ c get witness r : c = a + r. Then a + b ≤ a + r + b = c + b.
  let ⟨r, cEqAplusR⟩ := Natural.subtraction_witness(a, c, aLeC);
  rewrite(
      Equality.symmetry(cEqAplusR),
      -- a + b ≤ (a + r) + b. (a + r) + b = a + (r + b) by assoc; same as a + (b + r) by commutativity.
      -- Use less_or_equal_add_right: a + b ≤ (a + b) + r.
      rewrite(
          -- (a + b) + r = (a + r) + b via assoc and commutativity.
          calc (a + b) + r
             = a + (b + r)
             = a + (r + b)
             = (a + r) + b,
          Natural.less_or_equal_add_right(a + b, r)))
}

-- And on the right: b ≤ d implies a + b ≤ a + d. Same proof, via
-- add_commutative.
theorem Natural.le_add_preserves_right
        (a b d : Natural) (bLeD : b ≤ d)
        : a + b ≤ a + d :=
  rewrite(
      Natural.add_commutative(b, a),
      rewrite(
          Natural.add_commutative(d, a),
          Natural.le_add_preserves_left(b, d, a, bLeD)))

-- a ≤ c ∧ b ≤ d → a + b ≤ c + d.
theorem Natural.le_add_le
        (a c b d : Natural) (aLeC : a ≤ c) (bLeD : b ≤ d)
        : a + b ≤ c + d :=
  LessOrEqual.transitive(
      a + b, c + b, c + d,
      Natural.le_add_preserves_right(c, b, d, bLeD),
      Natural.le_add_preserves_left(a, c, b, aLeC))

-- monus expansion for sums: when a ≤ c and b ≤ d,
-- monus(c + d, a + b) = monus(c, a) + monus(d, b).
-- Proof: c = a + monus(c, a); d = b + monus(d, b); so c + d = (a + b) +
-- (monus(c, a) + monus(d, b)). Then monus_add_cancel.
theorem Natural.monus_add_distributes
        (a c b d : Natural) (aLeC : a ≤ c) (bLeD : b ≤ d)
        : Natural.monus(c + d, a + b)
          = Natural.monus(c, a) + Natural.monus(d, b) := {
  claim cDecompose : c = a + Natural.monus(c, a)
    by Natural.monus_zero_implies_decompose(
           a, c, Natural.le_implies_monus_zero(c, a, aLeC));
  claim dDecompose : d = b + Natural.monus(d, b)
    by Natural.monus_zero_implies_decompose(
           b, d, Natural.le_implies_monus_zero(d, b, bLeD));
  calc c + d
       = (a + Natural.monus(c, a)) + d
       = (a + Natural.monus(c, a)) + (b + Natural.monus(d, b))
       = (a + b) + (Natural.monus(c, a) + Natural.monus(d, b))    as sumDecompose;
  calc Natural.monus(c + d, a + b)
     = Natural.monus(
           (a + b) + (Natural.monus(c, a) + Natural.monus(d, b)),
           a + b)
     = Natural.monus(c, a) + Natural.monus(d, b)
}

-- Helper: d divides distance(a, b) when d divides both a and b.
-- Case-split via totality, then apply divides_monus.
theorem Natural.divides_distance
        (d a b : Natural) (dDividesA : d ∣ a) (dDividesB : d ∣ b)
        : d ∣ Natural.distance(a, b) :=
  claim (a ≤ b) ∨ (b ≤ a)
  claim by cases {
    in (a ≤ b) as aLeB:
        rewrite(
            Equality.symmetry(Natural.distance_monus_when_ge(a, b, aLeB)),
            Natural.divides_monus(d, b, a, aLeB, dDividesB, dDividesA))
    in (b ≤ a) as bLeA:
        rewrite(
            Equality.symmetry(Natural.distance_monus_when_le(b, a, bLeA)),
            Natural.divides_monus(d, a, b, bLeA, dDividesA, dDividesB))
  }

-- The key Natural-level identity: distance(a1+b1, a2+b2) is the
-- distance of two specific quantities built from monus.
-- When a1 ≤ a2 and b2 ≤ b1 (cross-direction), distance(a1+b1, a2+b2)
-- = distance(monus(b1, b2), monus(a2, a1)).
-- Proof: a2 = a1 + monus(a2, a1), b1 = b2 + monus(b1, b2). So
-- a2 + b2 = (a1 + b2) + monus(a2, a1) and a1 + b1 = (a1 + b2) + monus(b1, b2).
-- Then distance_add_left_cancel.
theorem Natural.distance_sum_cross_le_le
        (a1 a2 b1 b2 : Natural) (a1LeA2 : a1 ≤ a2) (b2LeB1 : b2 ≤ b1)
        : Natural.distance(a1 + b1, a2 + b2)
          = Natural.distance(Natural.monus(b1, b2), Natural.monus(a2, a1)) := {
  claim a2Decompose : a2 = a1 + Natural.monus(a2, a1)
    by Natural.monus_zero_implies_decompose(
           a1, a2, Natural.le_implies_monus_zero(a2, a1, a1LeA2));
  claim b1Decompose : b1 = b2 + Natural.monus(b1, b2)
    by Natural.monus_zero_implies_decompose(
           b2, b1, Natural.le_implies_monus_zero(b1, b2, b2LeB1));
  calc Natural.distance(a1 + b1, a2 + b2)
     = Natural.distance(a1 + (b2 + Natural.monus(b1, b2)),
                         a2 + b2)
     = Natural.distance(a1 + (b2 + Natural.monus(b1, b2)),
                         (a1 + Natural.monus(a2, a1)) + b2)
     = Natural.distance((a1 + b2) + Natural.monus(b1, b2),
                         (a1 + Natural.monus(a2, a1)) + b2)
     = Natural.distance((a1 + b2) + Natural.monus(b1, b2),
                         (a1 + b2) + Natural.monus(a2, a1))
            by congruenceOf(
                   function (m : Natural) =>
                       Natural.distance(
                           (a1 + b2) + Natural.monus(b1, b2),
                           m),
                   calc (a1 + Natural.monus(a2, a1)) + b2
                      = a1 + (Natural.monus(a2, a1) + b2)
                      = a1 + (b2 + Natural.monus(a2, a1))
                      = (a1 + b2) + Natural.monus(a2, a1))
     = Natural.distance(Natural.monus(b1, b2), Natural.monus(a2, a1))
}

-- The Natural-level "distance ultrametric": if d divides both
-- distance(a1, a2) and distance(b1, b2), then d divides
-- distance(a1+b1, a2+b2). Case analysis via totality.
theorem Natural.divides_distance_sum
        (d a1 a2 b1 b2 : Natural)
        (dDividesDistanceA : d ∣ Natural.distance(a1, a2))
        (dDividesDistanceB : d ∣ Natural.distance(b1, b2))
        : d ∣ Natural.distance(a1 + b1, a2 + b2) :=
  claim (a1 ≤ a2) ∨ (a2 ≤ a1)
  claim by cases {
    in (a1 ≤ a2) as a1LeA2:
        {
        claim (b1 ≤ b2) ∨ (b2 ≤ b1)
        claim by cases {
          in (b1 ≤ b2) as b1LeB2: {
              -- Same direction (a1 ≤ a2, b1 ≤ b2).
              -- distance(a1+b1, a2+b2) = monus(a2+b2, a1+b1)
              --                       = monus(a2, a1) + monus(b2, b1)
              --                       = distance(a1, a2) + distance(b1, b2).
              claim sumLe : a1 + b1 ≤ a2 + b2
                by Natural.le_add_le(a1, a2, b1, b2, a1LeA2, b1LeB2);
              rewrite(
                  calc Natural.distance(a1, a2) + Natural.distance(b1, b2)
                     = Natural.monus(a2, a1) + Natural.distance(b1, b2)
                            by congruenceOf(
                                   function (m : Natural) =>
                                       m + Natural.distance(b1, b2),
                                   Natural.distance_monus_when_ge(
                                       a1, a2, a1LeA2))
                     = Natural.monus(a2, a1) + Natural.monus(b2, b1)
                            by congruenceOf(
                                   function (m : Natural) =>
                                       Natural.monus(a2, a1) + m,
                                   Natural.distance_monus_when_ge(
                                       b1, b2, b1LeB2))
                     = Natural.monus(a2 + b2, a1 + b1)
                            by Equality.symmetry(
                                   Natural.monus_add_distributes(
                                       a1, a2, b1, b2, a1LeA2, b1LeB2))
                     = Natural.distance(a1 + b1, a2 + b2)
                            by Equality.symmetry(
                                   Natural.distance_monus_when_ge(
                                       a1 + b1, a2 + b2, sumLe)),
                  Natural.divides_add(
                      d,
                      Natural.distance(a1, a2),
                      Natural.distance(b1, b2),
                      dDividesDistanceA, dDividesDistanceB))
            }
          in (b2 ≤ b1) as b2LeB1:
              -- Cross direction (a1 ≤ a2, b2 ≤ b1). distance(a1+b1, a2+b2)
              -- = distance(monus(b1, b2), monus(a2, a1)). Then divides_distance.
              rewrite(
                  Equality.symmetry(
                      Natural.distance_sum_cross_le_le(
                          a1, a2, b1, b2, a1LeA2, b2LeB1)),
                  Natural.divides_distance(
                      d, Natural.monus(b1, b2), Natural.monus(a2, a1),
                      rewrite(
                          Natural.distance_monus_when_le(b2, b1, b2LeB1),
                          dDividesDistanceB),
                      rewrite(
                          Natural.distance_monus_when_ge(a1, a2, a1LeA2),
                          dDividesDistanceA)))
        }
        }
    in (a2 ≤ a1) as a2LeA1:
        {
        claim (b1 ≤ b2) ∨ (b2 ≤ b1)
        claim by cases {
          in (b1 ≤ b2) as b1LeB2:
              -- Cross direction (a2 ≤ a1, b1 ≤ b2). Symmetric to AB case.
              -- distance(a1+b1, a2+b2) = distance(a2+b2, a1+b1) by symmetry.
              -- = distance(monus(b2, b1), monus(a1, a2)).
              rewrite(
                  Natural.distance_symmetric(a2 + b2, a1 + b1),
                  rewrite(
                      Equality.symmetry(
                          Natural.distance_sum_cross_le_le(
                              a2, a1, b2, b1, a2LeA1, b1LeB2)),
                      Natural.divides_distance(
                          d, Natural.monus(b2, b1), Natural.monus(a1, a2),
                          rewrite(
                              Natural.distance_monus_when_ge(b1, b2, b1LeB2),
                              dDividesDistanceB),
                          rewrite(
                              Natural.distance_monus_when_le(a2, a1, a2LeA1),
                              dDividesDistanceA))))
          in (b2 ≤ b1) as b2LeB1: {
              -- Same direction (a2 ≤ a1, b2 ≤ b1). distance is in
              -- terms of monus(a1, a2) and monus(b1, b2). By the
              -- same distributivity / divides_add chain as the first case.
              claim sumLe : a2 + b2 ≤ a1 + b1
                by Natural.le_add_le(a2, a1, b2, b1, a2LeA1, b2LeB1);
              rewrite(
                  calc Natural.distance(a1, a2) + Natural.distance(b1, b2)
                     = Natural.monus(a1, a2) + Natural.distance(b1, b2)
                            by congruenceOf(
                                   function (m : Natural) =>
                                       m + Natural.distance(b1, b2),
                                   Natural.distance_monus_when_le(
                                       a2, a1, a2LeA1))
                     = Natural.monus(a1, a2) + Natural.monus(b1, b2)
                            by congruenceOf(
                                   function (m : Natural) =>
                                       Natural.monus(a1, a2) + m,
                                   Natural.distance_monus_when_le(
                                       b2, b1, b2LeB1))
                     = Natural.monus(a1 + b1, a2 + b2)
                            by Equality.symmetry(
                                   Natural.monus_add_distributes(
                                       a2, a1, b2, b1, a2LeA1, b2LeB1))
                     = Natural.distance(a1 + b1, a2 + b2)
                            by Equality.symmetry(
                                   Natural.distance_monus_when_le(
                                       a2 + b2, a1 + b1, sumLe)),
                  Natural.divides_add(
                      d,
                      Natural.distance(a1, a2),
                      Natural.distance(b1, b2),
                      dDividesDistanceA, dDividesDistanceB))
            }
        }
        }
  }

-- Integer-level: if d divides |A|_Nat and |B|_Nat, then d divides |A+B|_Nat.
-- Quotient.induct_two on A, B, then case_split the representatives.
-- At reps, |A|_Nat = distance(a1, a2), |B|_Nat = distance(b1, b2),
-- |A+B|_Nat = distance(a1+b1, a2+b2), and divides_distance_sum closes
-- the goal.
theorem Integer.divides_absolute_value_natural_sum
        (d : Natural) (A B : Integer)
        (dDividesAbsA : d ∣ Integer.absolute_value_natural(A))
        (dDividesAbsB : d ∣ Integer.absolute_value_natural(B))
        : d ∣ Integer.absolute_value_natural(A + B) :=
  Quotient.induct_two(
      IntegerRepresentative, IntegerEquivalent,
      IntegerRepresentative, IntegerEquivalent,
      function (A' B' : Integer) =>
          d ∣ Integer.absolute_value_natural(A')
            → d ∣ Integer.absolute_value_natural(B')
            → d ∣ Integer.absolute_value_natural(A' + B'),
      function (rep_A rep_B : IntegerRepresentative) =>
        (cases rep_A {
           | IntegerRepresentative.make(a1, a2) =>
               (cases rep_B {
                  | IntegerRepresentative.make(b1, b2) =>
                      function (dDivDistA : d ∣ Natural.distance(a1, a2))
                               (dDivDistB : d ∣ Natural.distance(b1, b2)) =>
                        Natural.divides_distance_sum(
                            d, a1, a2, b1, b2,
                            dDivDistA, dDivDistB)
                } : d ∣ Integer.absolute_value_natural(
                          Quotient.mk(IntegerRepresentative,
                                       IntegerEquivalent,
                                       IntegerRepresentative.make(a1, a2)))
                    → d ∣ Integer.absolute_value_natural(
                              Quotient.mk(IntegerRepresentative,
                                           IntegerEquivalent, rep_B))
                    → d ∣ Integer.absolute_value_natural(
                              Quotient.mk(IntegerRepresentative,
                                           IntegerEquivalent,
                                           IntegerRepresentative.make(a1, a2))
                              + Quotient.mk(IntegerRepresentative,
                                             IntegerEquivalent, rep_B)))
         } : d ∣ Integer.absolute_value_natural(
                   Quotient.mk(IntegerRepresentative,
                                IntegerEquivalent, rep_A))
             → d ∣ Integer.absolute_value_natural(
                       Quotient.mk(IntegerRepresentative,
                                    IntegerEquivalent, rep_B))
             → d ∣ Integer.absolute_value_natural(
                       Quotient.mk(IntegerRepresentative,
                                    IntegerEquivalent, rep_A)
                       + Quotient.mk(IntegerRepresentative,
                                      IntegerEquivalent, rep_B))),
      A, B, dDividesAbsA, dDividesAbsB)

-- x ≤ p * x for p ≥ 1. From p = 1 + monus(p, 1): p * x = x + monus(p, 1)*x,
-- then less_or_equal_add_right.
theorem Natural.le_multiply_when_factor_at_least_one
        (x p : Natural) (pPositive : successor(0) ≤ p)
        : x ≤ p * x := {
  claim pDecompose : p = successor(0) + Natural.monus(p, successor(0))
    by Natural.monus_zero_implies_decompose(
           successor(0), p,
           Natural.le_implies_monus_zero(p, successor(0), pPositive));
  rewrite(
      Equality.symmetry(pDecompose),
      -- (1 + monus(p, 1)) * x = x + monus(p, 1) * x. Then x ≤ that.
      rewrite(
          calc x + Natural.monus(p, successor(0)) * x
             = successor(0) * x + Natural.monus(p, successor(0)) * x
             = (successor(0) + Natural.monus(p, successor(0))) * x,
          Natural.less_or_equal_add_right(
              x, Natural.monus(p, successor(0)) * x)))
}

-- Power is monotone in the exponent (when base p ≥ 1).
-- Direct induction on r where b = a + r.
theorem Natural.power_monotone_via_r
        (a p : Natural) (pPositive : successor(0) ≤ p)
        : (r : Natural) → Natural.power(a, p) ≤ Natural.power(a + r, p)
  | zero =>
      Equality.transport_proposition(
          Natural,
          function (m : Natural) => Natural.power(a, p) ≤ Natural.power(m, p),
          a, a + 0,
          Equality.symmetry(Natural.add_zero(a)),
          LessOrEqual.reflexivity(Natural.power(a, p)))
  | successor(r') =>
      -- power(a + succ(r'), p) = power(succ(a + r'), p) = p * power(a + r', p)
      -- by definition.
      -- IH: power(a, p) ≤ power(a + r', p).
      -- power(a + r', p) ≤ p * power(a + r', p) by le_multiply_when_factor_at_least_one.
      -- Combine.
      Equality.transport_proposition(
          Natural,
          function (m : Natural) => Natural.power(a, p) ≤ Natural.power(m, p),
          successor(a + r'), a + successor(r'),
          Equality.symmetry(Natural.add_successor(a, r')),
          LessOrEqual.transitive(
              Natural.power(a, p),
              Natural.power(a + r', p),
              p * Natural.power(a + r', p),
              Natural.le_multiply_when_factor_at_least_one(
                  Natural.power(a + r', p), p, pPositive),
              Natural.power_monotone_via_r(a, p, pPositive, r')))

-- Power monotonicity: a ≤ b implies power(a, p) ≤ power(b, p).
theorem Natural.power_monotone
        (a b p : Natural) (aLeB : a ≤ b)
        (pPositive : successor(0) ≤ p)
        : Natural.power(a, p) ≤ Natural.power(b, p) := {
    obtain ⟨r, bEqAplusR⟩ from Natural.subtraction_witness(a, b, aLeB);
    rewrite(
        Equality.symmetry(bEqAplusR),
        Natural.power_monotone_via_r(a, p, pPositive, r))
}

-- distance(a, b) = 0 implies a = b. Useful for the |·|_Nat = 0 →
-- Integer.zero bridge.
theorem Natural.distance_zero_implies_equal
        : (a b : Natural) → Natural.distance(a, b) = 0 → a = b
  | zero, b, eq =>
      Equality.symmetry(eq)
  | successor(k), b, eq =>
      (cases b {
         | zero =>
             function (refinedEq
                         : Natural.distance(successor(k), 0) = 0) =>
               absurd(refinedEq)
         | successor(m) =>
             function (refinedEq
                         : Natural.distance(successor(k), successor(m)) = 0) =>
               congruenceOf(
                   successor,
                   Natural.distance_zero_implies_equal(k, m, refinedEq))
       } : Natural.distance(successor(k), b) = 0 → successor(k) = b)(eq)

-- |x|_Nat = 0 implies x = Integer.zero. Quotient.induct on x; at rep
-- distance(a, b) = 0 gives a = b, and Quotient.sound between
-- make(a, a) and make(zero, zero) (using the trivial a + 0 = a + 0).
theorem Integer.absolute_value_natural_zero_implies_zero
        (x : Integer)
        (eq : Integer.absolute_value_natural(x) = 0)
        : x = Integer.zero :=
  Quotient.induct(
      function (x' : Integer) =>
          Integer.absolute_value_natural(x') = 0 → x' = Integer.zero,
      function (rep : IntegerRepresentative) =>
        (cases rep {
           | IntegerRepresentative.make(a, b) =>
               function (distanceEq : Natural.distance(a, b) = 0) =>
                 Quotient.sound(
                     IntegerRepresentative.make(a, b),
                     IntegerRepresentative.make(0, 0),
                     calc a + 0
                        = a
                        = b
                              by Natural.distance_zero_implies_equal(
                                     a, b, distanceEq)
                        = b + 0)
         } : Integer.absolute_value_natural(
                 Quotient.mk(IntegerRepresentative,
                              IntegerEquivalent, rep)) = 0
             → Quotient.mk(IntegerRepresentative, IntegerEquivalent, rep)
               = Integer.zero),
      x)(eq)

-- Integer-level p-adic ultrametric: v_p(|A|_Nat) ≤ v_p(|B|_Nat) and
-- |A + B|_Nat ≥ 1 implies v_p(|A|_Nat) ≤ v_p(|A + B|_Nat).
-- Goes through divides_absolute_value_natural_sum and the bidirectional
-- v_p ↔ p^k divides bridge.
theorem Integer.padic_valuation_absolute_value_natural_ultrametric_when_le
        (prime : Natural)
        (primeAtLeastTwo : successor(successor(0)) ≤ prime)
        (A B : Integer)
        (sumAbsPositive
            : successor(0) ≤ Integer.absolute_value_natural(A + B))
        (valuationLe :
            Natural.padic_valuation(
                prime, Integer.absolute_value_natural(A))
              ≤ Natural.padic_valuation(
                    prime, Integer.absolute_value_natural(B)))
        : Natural.padic_valuation(
              prime, Integer.absolute_value_natural(A))
          ≤ Natural.padic_valuation(
                prime, Integer.absolute_value_natural(A + B)) :=
  Natural.power_divides_implies_padic_valuation_ge(
      prime, primeAtLeastTwo,
      Natural.padic_valuation(prime, Integer.absolute_value_natural(A)),
      Integer.absolute_value_natural(A + B),
      sumAbsPositive,
      Integer.divides_absolute_value_natural_sum(
          Natural.power(
              Natural.padic_valuation(
                  prime, Integer.absolute_value_natural(A)), prime),
          A, B,
          Natural.padic_valuation_ge_implies_power_divides(
              prime, primeAtLeastTwo,
              Natural.padic_valuation(
                  prime, Integer.absolute_value_natural(A)),
              Integer.absolute_value_natural(A),
              LessOrEqual.reflexivity(
                  Natural.padic_valuation(
                      prime, Integer.absolute_value_natural(A)))),
          Natural.padic_valuation_ge_implies_power_divides(
              prime, primeAtLeastTwo,
              Natural.padic_valuation(
                  prime, Integer.absolute_value_natural(A)),
              Integer.absolute_value_natural(B),
              valuationLe)))

-- Natural/subtraction.math
--
-- Subtraction for Natural via existence-of-witness: when b ‚â§ a, there is
-- a unique c with a = b + c. We never define a partial `subtract`
-- function on Natural ‚Äî that would either leak truncation (monus) or
-- require Integer to land at. Instead we expose the existential, and
-- downstream proofs unpack the witness as needed.
--
-- We also prove totality of ‚â§ on Natural here, since both halves of any
-- algorithm "split on which side is bigger" pair the same structure.

module Natural.subtraction

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order

-- If b ‚â§ a then ‚àÉ c. a = b + c. Read straight off `‚â§`'s meaning
-- (`b < a ‚à® b = a`): equality gives c = 0; the strict-order witness `c'`
-- with `b + (1 + c') = a` gives c = 1 + c'.
theorem Natural.subtraction_witness (b a : Natural)
        (proof : b ‚â§ a) : ‚àÉ (c : Natural). a = b + c :=
  done by cases {
    case b < a as lessThan: {
        choose cPrime such that b + (1 + cPrime) = a from Natural.lt_elim;
        witness (1 + cPrime) with (a = b + (1 + cPrime))
      }
    case b = a as equal:
        witness 0 with
            a
               = b
               = b + 0
  }

-- Totality: for any a, b, either a ‚â§ b or b ‚â§ a. The successor case
-- on a needs a recursive call passed in as a hypothesis (mirroring
-- the shape used by `decides_less_or_equal` in `Natural.decide`).
theorem Natural.totality_of_less_or_equal_successor_against
        (predecessorOfA : Natural)
        (totalityPredecessorOfA :
            ‚àÄ (b : Natural). predecessorOfA ‚â§ b ‚à® b ‚â§ predecessorOfA)
        : ‚àÄ (b : Natural).
          successor(predecessorOfA) ‚â§ b ‚à® b ‚â§ successor(predecessorOfA)
  | zero => {
      0 ‚â§ successor(predecessorOfA);
      done
    }
  | successor(predecessorOfB) => {
      (predecessorOfA ‚â§ predecessorOfB) ‚à® (predecessorOfB ‚â§ predecessorOfA);
      done by cases {
        case predecessorOfA ‚â§ predecessorOfB as leftBranch: {
            successor(predecessorOfA) ‚â§ successor(predecessorOfB);
            done
          }
        case predecessorOfB ‚â§ predecessorOfA as rightBranch: {
            successor(predecessorOfB) ‚â§ successor(predecessorOfA);
            done
          }
      }
    }

automatic theorem Natural.totality_of_less_or_equal (a : Natural)
        : ‚àÄ (b : Natural). a ‚â§ b ‚à® b ‚â§ a :=
  by induction on a with IH {
    case zero: {
        take b : Natural;
        0 ‚â§ b;
        done
      }
    case successor(predecessorOfA): {
        -- fix an arbitrary b; totality at predecessorOfA (the IH) lifts to
        -- successor by the helper.
        take b : Natural;
        done
      }
  }

-- Antisymmetry of ‚â§: if a ‚â§ b and b ‚â§ a then a = b. Each inequality gives
-- a witness ‚Äî b = a + c and a = b + d ‚Äî so a = a + (c + d); cancelling a
-- forces c + d = 0, hence c = 0, and then b = a + c = a. (Lives here, not
-- with the additive-order lemmas: it needs only the subtraction witness and
-- add-cancellation, so this is its earliest natural home ‚Äî which lets the
-- divisibility layer use it.)
theorem Natural.le_antisymmetric (a b : Natural) (aLeB : a ‚â§ b) (bLeA : b ‚â§ a)
        : a = b := {
  -- The `such that` body pins which ‚â§ witness each existential comes from
  -- (both `a ‚â§ b` and `b ‚â§ a` are in scope).
  choose c such that b = a + c from Natural.subtraction_witness;
  choose d such that a = b + d from Natural.subtraction_witness;
  -- a + (c + d) = a + 0, so cancelling a forces c + d = 0.
  a + (c + d)
     = (a + c) + d
     = b + d
     = a
     = a + 0;
  c + d = 0;
  a
     = a + 0
     = a + c
     = b
}

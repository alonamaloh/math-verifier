-- Natural/subtraction.math
--
-- Subtraction for Natural via existence-of-witness: when b ≤ a, there is
-- a unique c with a = b + c. We never define a partial `subtract`
-- function on Natural — that would either leak truncation (monus) or
-- require Integer to land at. Instead we expose the existential, and
-- downstream proofs unpack the witness as needed.
--
-- We also prove totality of ≤ on Natural here, since both halves of any
-- algorithm "split on which side is bigger" pair the same structure.

module Natural.subtraction

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order

-- If b ≤ a then ∃ c. a = b + c. Read straight off `≤`'s meaning
-- (`b < a ∨ b = a`): equality gives c = 0; the strict-order witness `c'`
-- with `b + (1 + c') = a` gives c = 1 + c'.
theorem Natural.subtraction_witness (b a : Natural)
        (proof : b ≤ a) : ∃ (c : Natural). a = b + c :=
  done by cases {
    case b < a as lessThan: {
        choose cPrime such that b + (1 + cPrime) = a from Natural.lt_elim;
        witness (1 + cPrime) with (a = b + (1 + cPrime))
      }
    case b = a as equal:
        witness 0 with
            a
               = b
               = b + 0
  }

-- Totality: for any a, b, either a ≤ b or b ≤ a. The successor case
-- on a needs a recursive call passed in as a hypothesis (mirroring
-- the shape used by `decides_less_or_equal` in `Natural.decide`).
theorem Natural.totality_of_less_or_equal_successor_against
        (predecessorOfA : Natural)
        (totalityPredecessorOfA :
            ∀ (b : Natural). predecessorOfA ≤ b ∨ b ≤ predecessorOfA)
        (b : Natural)
        : successor(predecessorOfA) ≤ b ∨ b ≤ successor(predecessorOfA) :=
  done by cases {
    case b = 0: {
        0 ≤ successor(predecessorOfA);
        done
      }
    case b = successor(predecessorOfB) for some predecessorOfB: {
        (predecessorOfA ≤ predecessorOfB) ∨ (predecessorOfB ≤ predecessorOfA);
        done by cases {
          case predecessorOfA ≤ predecessorOfB as leftBranch: {
              successor(predecessorOfA) ≤ successor(predecessorOfB);
              done
            }
          case predecessorOfB ≤ predecessorOfA as rightBranch: {
              successor(predecessorOfB) ≤ successor(predecessorOfA);
              done
            }
        }
      }
  }

automatic theorem Natural.totality_of_less_or_equal (a : Natural)
        : ∀ (b : Natural). a ≤ b ∨ b ≤ a :=
  by induction on a with IH {
    case zero: {
        take b : Natural;
        0 ≤ b;
        done
      }
    case successor(predecessorOfA): {
        -- fix an arbitrary b; totality at predecessorOfA (the IH) lifts to
        -- successor by the helper.
        take b : Natural;
        done
      }
  }

-- Antisymmetry of ≤: if a ≤ b and b ≤ a then a = b. Each inequality gives
-- a witness — b = a + c and a = b + d — so a = a + (c + d); cancelling a
-- forces c + d = 0, hence c = 0, and then b = a + c = a. (Lives here, not
-- with the additive-order lemmas: it needs only the subtraction witness and
-- add-cancellation, so this is its earliest natural home — which lets the
-- divisibility layer use it.)
theorem Natural.le_antisymmetric (a b : Natural) (aLeB : a ≤ b) (bLeA : b ≤ a)
        : a = b := {
  -- The `such that` body pins which ≤ witness each existential comes from
  -- (both `a ≤ b` and `b ≤ a` are in scope).
  choose c such that b = a + c from Natural.subtraction_witness;
  choose d such that a = b + d from Natural.subtraction_witness;
  -- a + (c + d) = a + 0, so cancelling a forces c + d = 0.
  a + (c + d)
     = (a + c) + d
     = b + d
     = a
     = a + 0;
  c + d = 0;
  a
     = a + 0
     = a + c
     = b
}

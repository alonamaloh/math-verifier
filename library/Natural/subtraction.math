-- Natural/subtraction.math
--
-- Subtraction for Natural via existence-of-witness: when b ≤ a, there is
-- a unique c with a = b + c. We never define a partial `subtract`
-- function on Natural — that would either leak truncation (monus) or
-- require Integer to land at. Instead we expose the existential, and
-- downstream proofs unpack the witness as needed.
--
-- We also prove totality of ≤ on Natural here, since both halves of any
-- algorithm "split on which side is bigger" pair the same structure.

module Natural.subtraction

import Logic.basics
import Logic.exists
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order

-- If b ≤ a then ∃ c. a = b + c. By induction on the ≤ derivation:
-- reflexivity gives c = 0; the step case takes the IH witness and bumps it
-- through successor + add_successor.
theorem Natural.subtraction_witness (b a : Natural)
        (proof : b ≤ a) : ∃ (c : Natural). a = b + c :=
  by_induction on proof with IH {
    case LessOrEqual.reflexivity(commonValue):
        -- b = a = commonValue, so c = 0.
        witness 0 with calc commonValue = commonValue + 0
    case LessOrEqual.step(smaller, predecessorOfA, _): {
        -- a = successor(predecessorOfA), smaller ≤ predecessorOfA; the IH
        -- gives predecessorOfA = smaller + cPrime, so c = successor(cPrime).
        obtain ⟨cPrime, predEquality⟩ from IH;
        witness successor(cPrime) with
            calc successor(predecessorOfA)
               = successor(smaller + cPrime)
               = smaller + successor(cPrime)
      }
  }

-- Totality: for any a, b, either a ≤ b or b ≤ a. The successor case
-- on a needs a recursive call passed in as a hypothesis (mirroring
-- the shape used by `decides_less_or_equal` in `Natural.decide`).
theorem Natural.totality_of_less_or_equal_successor_against
        (predecessorOfA : Natural)
        (totalityPredecessorOfA :
            (b : Natural) → predecessorOfA ≤ b ∨ b ≤ predecessorOfA)
        : (b : Natural)
          → successor(predecessorOfA) ≤ b ∨ b ≤ successor(predecessorOfA)
  | zero => {
      claim zeroLeast : 0 ≤ successor(predecessorOfA) since Natural.zero_least;
      Or.introduceRight(zeroLeast)
    }
  | successor(predecessorOfB) =>
      claim (predecessorOfA ≤ predecessorOfB) ∨ (predecessorOfB ≤ predecessorOfA)
          by totalityPredecessorOfA(predecessorOfB)
      claim by cases {
        in (predecessorOfA ≤ predecessorOfB) as leftBranch: {
            claim lifted : successor(predecessorOfA) ≤ successor(predecessorOfB)
                by Natural.successor_less_or_equal_successor;
            Or.introduceLeft(lifted)
          }
        in (predecessorOfB ≤ predecessorOfA) as rightBranch: {
            claim lifted : successor(predecessorOfB) ≤ successor(predecessorOfA)
                by Natural.successor_less_or_equal_successor;
            Or.introduceRight(lifted)
          }
      }

theorem Natural.totality_of_less_or_equal (a : Natural)
        : (b : Natural) → a ≤ b ∨ b ≤ a :=
  by_induction on a with IH {
    case zero: {
        take b : Natural;
        claim zeroLeast : 0 ≤ b since Natural.zero_least;
        Or.introduceLeft(zeroLeast)
      }
    case successor(predecessorOfA): {
        -- fix an arbitrary b; totality at predecessorOfA (the IH) lifts to
        -- successor by the helper.
        take b : Natural;
        goal by Natural.totality_of_less_or_equal_successor_against
      }
  }

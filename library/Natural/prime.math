-- Natural/prime.math
--
-- Primality of natural numbers: a candidate is prime when it is at
-- least 2 AND every divisor of it equals either 1 or the
-- candidate itself.

module Natural.prime

import Natural.basics
import Natural.order
import Natural.divisibility
import Equality.basics
import Logic.basics

definition Natural.is_prime(candidate : ℕ) : Proposition :=
  2 ≤ candidate
  ∧ (∀ (divisor : ℕ).
        divisor ∣ candidate
        → divisor = 1 ∨ divisor = candidate)

-- A prime is at least 2. The first half of the is_prime conjunction —
-- exposes the bound without forcing callers to unfold via And.eliminate.
theorem Natural.is_prime.at_least_two
        (candidate : ℕ) (primality : Natural.is_prime(candidate))
        : 2 ≤ candidate :=
  done

-- A prime is at least 1. Composes at_least_two with the predecessor
-- inequality. Used wherever the proof only needs positivity, not the
-- ≥2 fact.
theorem Natural.is_prime.positive
        (candidate : ℕ) (primality : Natural.is_prime(candidate))
        : 1 ≤ candidate :=
  { done }

-- The divisor half: every divisor of a prime is either 1 or the prime
-- itself. Exposes the second is_prime conjunct as an argument-free
-- citation, so callers needn't project the ∀ out of the conjunction.
theorem Natural.is_prime.divisor_one_or_self
        (candidate : ℕ) (primality : Natural.is_prime(candidate))
        (divisor : ℕ) (dividesCandidate : divisor ∣ candidate)
        : divisor = 1 ∨ divisor = candidate :=
  done

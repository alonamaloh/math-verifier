-- Natural/prime.math
--
-- Primality of natural numbers: a candidate is prime when it is at
-- least two AND every divisor of it equals either one or the
-- candidate itself.

module Natural.prime

import Natural.basics
import Natural.order
import Natural.divisibility
import Equality.basics
import Logic.basics

definition Natural.is_prime(candidate : Natural) : Proposition :=
  And(
    LessOrEqual(two, candidate),
    (divisor : Natural)
      → Natural.divides(divisor, candidate)
      → Or(divisor = one, divisor = candidate))

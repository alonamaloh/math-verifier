-- Natural/prime.math
--
-- Primality of natural numbers: p is prime if p ≥ 2 and every divisor
-- of p is either 1 or p. This file just defines the predicate; non-
-- trivial primality proofs (e.g. "2 is prime", "there are infinitely
-- many primes") need further library work.

module Natural.prime

import Natural.basics
import Natural.order
import Natural.divisibility
import Equality.basics
import Logic.basics

-- A natural p is prime when 2 ≤ p AND every divisor of p equals 1 or p.
definition Natural.is_prime(p : Natural) : Prop :=
  And(
    LessOrEqual(two, p),
    (d : Natural)
      → Natural.divides(d, p)
      → Or(d = one, d = p))

-- A `fold_operation` whose witness certifies a DIFFERENT operation than
-- the one the operator registry dispatches the symbol to must be
-- rejected: `+` on Natural is Natural.add, but the witness is the
-- multiplicative monoid.
module ErrorTest.fold_operation_mismatch

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Algebra.monoid

definition ErrorTest.multiply_witness : IsMonoid(Natural, Natural.multiply, 1) := {
  Natural.multiply_associative;
  Natural.one_multiply;
  Natural.multiply_one;
  done
}

fold_operation (+) on Natural := ErrorTest.multiply_witness

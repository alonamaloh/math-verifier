-- A stated proposition `… by <lambda>` whose BODY contains a failing
-- inner statement must report the inner failure (its line, its goal),
-- not the generic outer "citation does not prove this goal" message.

module ErrorTest.lambda_hint_inner_error

import axioms
import Logic.basics
import Natural.basics
import Natural.order

theorem ErrorTest.lambda_inner (n : Natural) : (m : Natural) → n ≤ m → n ≤ m := {
  (m : Natural) → n ≤ m → n ≤ m
      by (m : Natural) (h : n ≤ m) ↦ {
          n ≤ 0 by h;
          h
        } as helper;
  helper
}

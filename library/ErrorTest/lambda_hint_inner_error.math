-- A `claim … by <lambda>` whose BODY contains a failing inner claim must
-- report the inner failure (its line, its goal), not the generic outer
-- "citation does not prove this goal" with the whole Pi-typed goal.

module ErrorTest.lambda_hint_inner_error

import axioms
import Logic.basics
import Natural.basics
import Natural.order

theorem ErrorTest.lambda_inner (n : Natural) : (m : Natural) → n ≤ m → n ≤ m := {
  claim helper : (m : Natural) → n ≤ m → n ≤ m
      by (m : Natural) (h : n ≤ m) ↦ {
          claim bogus : n ≤ 0 by h;
          h
        };
  helper
}

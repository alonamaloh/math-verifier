-- A `case zero:` (legacy raw-recursor vocabulary) mixed with a `case
-- step(k):` (the `1 + n` vocabulary) must be rejected with a message that
-- names the offending clause and points at the base/step rename — not a
-- generic "expects exactly base and step". This is the common mid-conversion
-- state when migrating a legacy induction one clause at a time.

module ErrorTest.induction_one_plus_mixed_vocabulary

import Natural.basics
import Natural.arithmetic
import Natural.one_plus_induction
import Equality.basics

theorem ErrorTest.mixed_vocabulary (n : Natural) : n = n :=
  by_induction on n with IH {
    case zero:    done
    case step(k): done
  }

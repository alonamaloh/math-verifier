-- Registered noncommutative carrier views belong to the explicit `ring`
-- tactic. Merely asking the general proof search to close the goal must not
-- silently opt into matrix word normalization.

module ErrorTest.matrix_ordered_ring_stays_explicit

import Algebra.matrix_ring

theorem ErrorTest.matrix_ordered_ring_requires_explicit_tactic
        {r : CommutativeRing} {n : ℕ}
        (T D N : Matrix(r, n, n))
        : ((Matrix.identity(r, n) + T) * D)
            * (Matrix.identity(r, n) + N)
          = (D + T * D) + (D * N + (T * D) * N) := {
  done
}

-- A bare name in a non-first pattern slot that matches a constructor of
-- the slot's type binds a NEW variable (it does not match the
-- constructor) — historically a silent footgun producing "expected X /
-- got X" mysteries. Must be rejected with a message naming the
-- shadowed constructor.

module ErrorTest.pattern_shadows_constructor

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano

theorem ErrorTest.shadowed : (a b : Natural) → b = b
  | zero, zero => reflexivity(Natural, zero)
  | successor(i), b => reflexivity(Natural, b)

-- A bare constructor name in a NON-FIRST pattern slot binds a fresh variable
-- (shadowing the constructor) rather than matching it. The elaborator must
-- name this footgun explicitly — it once surfaced as a baffling distant
-- type mismatch with byte-identical printouts.
module ErrorTest.pattern_shadows_constructor

import Logic.basics
import Natural.basics

definition ErrorTest.f : Natural → Natural → Natural
  | successor(i), zero => i
  | successor(i), successor(j) => j
  | zero, b => b

-- `let ⟨q, r, extra⟩ :=` from `d ∣ n` (which provides only a witness + a
-- proof) has one component too many. The trailing component right-nests and
-- tries to destructure the equality proof `n = d·q` — the message must name
-- that cause and the fix, not leak the internal "index must be a local
-- variable".
module ErrorTest.destructure_too_many_components

import Logic.basics
import Logic.exists
import Natural.basics
import Natural.divisibility

theorem ErrorTest.t (d n : Natural) (h : d ∣ n) : Natural := {
  let ⟨q, r, extra⟩ := h;
  q
}

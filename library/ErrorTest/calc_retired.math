-- The `calc` keyword is retired (A1 Phase 3): a relation chain is
-- written bare at statement position, as a `:=`/arm body, or inside
-- `{ … }` in argument positions. The old spelling must fail with a
-- migration-grade error steering to the bare forms.
module ErrorTest.calc_retired

import Natural.basics
import Natural.arithmetic
import Equality.basics

theorem ErrorTest.retired_calc
        (a b c : Natural) (firstStep : a = b) (secondStep : b = c)
        : a = c := {
  calc a = b
       = c;
  done
}

-- `cases E with <eq>` is retired (A4): the equation-shaped by-cases
-- split states the equation as the arm's hypothesis and discharges
-- exhaustiveness through the coverage lemma. The old spelling must
-- fail with a migration-grade error teaching the replacement.
module ErrorTest.cases_with_eq_retired

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

theorem ErrorTest.retired_cases_with (n : Natural) : n = n :=
  cases n with splitEquation {
    | zero          => reflexivity(Natural, 0)
    | successor(k)  => reflexivity(Natural, successor(k))
  }

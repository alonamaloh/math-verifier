-- A failed finite sweep identifies the first missing table row.
module ErrorTest.finite_check_false_leaf

import Logic.basics
import Natural.finite_range

theorem ErrorTest.missingThree
        (P : ℕ → Proposition) (atTwo : P(2)) (atFour : P(4))
        : ∀ (n : ℕ). 2 ≤ n → n < 5 → P(n) :=
  by finite_check n from 2 until 5


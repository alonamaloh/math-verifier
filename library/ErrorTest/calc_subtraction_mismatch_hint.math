-- A calc `=` step whose two sides express subtraction differently — `a - b`
-- (subtract) on the left, `a + -b` (add-of-negate) on the right. They print
-- alike and are ring-equal, but the structural matcher treats them as distinct,
-- so the cited lemma can't bridge. The message must HINT at the subtraction
-- representation as the obstacle, not just dump the two relations.
module ErrorTest.calc_subtraction_mismatch_hint

import Logic.basics
import Natural.basics
import Integer.basics
import Rational.basics
import Rational.addition
import Rational.negation
import Rational.halve

theorem ErrorTest.t (epsilon : Rational)
    : epsilon - Rational.halve(epsilon)
      = (Rational.halve(epsilon) + Rational.halve(epsilon)) + -Rational.halve(epsilon) :=
  -- A trivial reflexive first step makes this a genuine ≥2-step chain
  -- (the bare-chain grammar needs it), so the second step still routes
  -- through the calc-step elaborator's relation-mismatch diagnostics.
  epsilon - Rational.halve(epsilon)
     = epsilon - Rational.halve(epsilon)
     = (Rational.halve(epsilon) + Rational.halve(epsilon)) + -Rational.halve(epsilon)
           by Rational.halve_doubled(epsilon)

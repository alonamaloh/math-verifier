-- `ring` builds a malformed proof term on a large mixed-sign polynomial
-- identity. The identity below is TRUE (it is b1·s1 − b2·s2 = D·r1 with
-- s_i = n_i − D·q_i, r1 = a1 − (b1q1−b2q2), D = b1²+b2², n_i the conj-product
-- coordinates — the core of Gaussian Euclidean division). Lower-degree
-- variants (same shape with n1,n2,D kept as atoms) verify fine; only the
-- fully-inlined degree-3 form trips an internal `+`-reassociation mismatch.
module ErrorTest.probe_ring_assembly_bug

import Logic.basics
import Equality.basics
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.algebra
import Integer.absolute_value

theorem ErrorTest.r (a1 a2 b1 b2 q1 q2 : Integer)
        : b1*((a1*b1 + a2*b2) - (b1*b1 + b2*b2)*q1) - b2*((a2*b1 - a1*b2) - (b1*b1 + b2*b2)*q2)
          = (b1*b1 + b2*b2) * (a1 - (b1*q1 - b2*q2)) := ring

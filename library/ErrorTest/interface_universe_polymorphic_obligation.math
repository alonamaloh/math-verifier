-- D residual close-out: interface obligations are MONOMORPHIC — the
-- obligation check elaborates the stated type without universe
-- parameters in scope and the seal re-emits at the stated spelling, so
-- `.{u}` must fail loudly at parse with a pointer to the bulk-export
-- route (which preserves an implementation lemma's universe parameters).
interface module ErrorTest.poly_interface implemented by ErrorTest.poly_impl

import Logic.basics
import Equality.basics

theorem ErrorTest.poly_obligation.{u} : Equality.{u}

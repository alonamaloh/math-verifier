-- `obtain … by <lemma>` with TWO hypotheses matching the lemma's premise
-- and pinning different arguments must refuse with a list, not silently
-- pick one (the original incident: two ≤ facts in scope, the wrong one
-- chosen for Natural.subtraction_witness).

module ErrorTest.obtain_by_ambiguous_premise

import axioms
import Logic.basics
import Logic.exists
import Natural.basics
import Natural.order
import Natural.subtraction

theorem ErrorTest.ambiguous_obtain (i j p : Natural)
        (jLessOrEqual : j ≤ i)
        (iBelow : successor(i) ≤ p)
        : ∃ (c : Natural). i = j + c := {
  obtain ⟨difference, equation⟩ by Natural.subtraction_witness;
  ⟨difference, equation⟩
}

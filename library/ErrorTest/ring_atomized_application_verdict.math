-- A genuinely false bundled-ring identity whose fingerprint atoms include
-- an unreduced transparent-definition application. `ring` must fail — but
-- the verdict must use the softened atomization-artifact wording, not the
-- flat "the identity is FALSE" (the diagnostic evaluator cannot see
-- through bundled operations, so a hard verdict would overclaim).
module ErrorTest.ring_atomized_application_verdict

import Logic.basics
import Logic.functions
import Equality.basics
import Natural.basics
import Natural.classical_decidable
import Set.finite
import Lists.list
import Lists.map
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.commutative_ring_aggregation
import Algebra.permutation_enumeration
import Algebra.matrix
import Algebra.matrix_ring
import Algebra.matrix_transpose
import Algebra.matrix_vector

theorem ErrorTest.t {r : CommutativeRing} {rows columns : ℕ}
        (A : Matrix(r, rows, columns)) (a : CommutativeRing.carrier(r))
        (x : RingVector(r, columns)) (i : NaturalsBelow(rows)) (k : NaturalsBelow(columns))
        : A(i, k) * (a • x)(k) = a * a :=
  ring

-- The `refining` clause is retired (A4): hypotheses depending on the
-- split variable are generalized automatically on every route; genuine
-- induction loading is spelled `generalizing b, c, …`. The old spelling
-- must fail with a migration-grade error naming both facts.
module ErrorTest.refining_retired

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

theorem ErrorTest.retired_refining (n : Natural) (equation : n = 0)
        : n = 0 :=
  cases n refining equation {
    | zero          => reflexivity(Natural, 0)
    | successor(k)  => equation
  }

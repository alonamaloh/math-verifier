-- Citing a misspelled / nonexistent lemma name in `by`. The error must
-- say the NAME is unknown (a typo), not the generic "citation does not
-- prove this goal" (which masked the real "unknown identifier" cause).
module ErrorTest.unknown_lemma_name

import Natural.basics
import Natural.peano
import Natural.arithmetic

theorem ErrorTest.typo (a b : Natural) : a + b = b + a := {
  claim a + b = b + a by Natural.add_comutative
}

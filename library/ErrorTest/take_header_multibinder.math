-- The combined take header `take IDENT REL EXPR;` binds a SINGLE
-- variable. A multi-binder spelling `take a, b > 0;` must be rejected
-- at parse time with a message naming the one-binder restriction and
-- steering to separate `take` statements.
module ErrorTest.take_header_multibinder

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order

theorem ErrorTest.take_header_multibinder
        : (a : Natural) → (b : Natural) → b > 0 → b > 0 := {
  take a, b > 0;
  done
}

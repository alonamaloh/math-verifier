-- `decide` in a module that does NOT import `Natural.classical_decidable`.
-- The tactic desugars to `cases Logic.classical_decidable(P)`, so the lookup
-- fails on the desugared name — the message must point at the missing import,
-- not just report a baffling "unknown identifier" at the `decide`.
module ErrorTest.decide_missing_classical_decidable

import Logic.basics

theorem ErrorTest.decision_needs_import (P : Proposition) : P ∨ Not(P) :=
  decide P {
    | yes holds => Or.introduceLeft(holds)
    | no notHolds => Or.introduceRight(notHolds)
  }

-- PENDING (PLAN_ELABORATOR_ERGONOMICS.md step E1). Note this fails by a
-- DIFFERENT mechanism than carrier_pending_bundled_relation, which is why both
-- are pinned: here the bundled carrier DOES win and becomes the expected type
-- for the right operand, but the numeral fails to coerce into it, because the
-- coercion registry is keyed on the head name `CommutativeRing.carrier` rather
-- than the reduced `Integer`.
--
-- So E1's normalized head should fix this via the COERCION lookup, not via the
-- operand join. If this still fails after E1, the `=` path also needs E3's
-- operand reordering — record that as a finding.
module ErrorTest.carrier_pending_bundled_equality

import Algebra.escalation

definition ErrorTest.pending {n : ℕ}
        (M : Matrix(Integer.commutative_ring_bundle, n, n))
        (i : NaturalsBelow(n)) : Proposition :=
  M(i, i) = 0

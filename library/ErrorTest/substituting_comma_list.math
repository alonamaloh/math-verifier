-- `by substituting eq1, eq2` is not supported — the substitution search
-- rewrites with a SINGLE equation, it does not chain rewrites. The comma
-- must be diagnosed at the source with a clear message pointing to the
-- one-substituting-per-step idiom, not left to surface as a confusing
-- "expected expression" further downstream.
module ErrorTest.substituting_comma_list

import Logic.basics
import Equality.basics
import Natural.basics

theorem ErrorTest.comma_substituting (a b : Natural) (h1 : a = b) (h2 : b = a)
        : a = a := {
  a
     = a by substituting h1, h2
}

-- A `Ôêú` step followed by a `Ôëñ` step: no relation-composition rule joins
-- them (`=` composes with everything; a mixed pair needs a registry
-- row). The fold must reject the pair by name, not build a wrong proof.
module ErrorTest.calc_composition_gap

import Logic.basics
import Natural.basics
import Natural.divisibility
import Natural.order

theorem ErrorTest.t (a b c : Natural)
        (abDivides : a Ôêú b) (bBelow : b Ôëñ c)
        : True :=
  a Ôêú b   by abDivides
    Ôëñ c   by bBelow

-- A `∣` step meeting a chain that widens ℕ → ℤ (an honest-subtraction
-- endpoint raises the carrier). `∣` has a coercion-preservation slot
-- (Divides_preserves) but no edge declares the lemma, so the raise must
-- fail with a legible per-edge error naming the missing lemma — never a
-- silent wrong answer (PLAN_CALC_WIDENING §D, verification #3).
module ErrorTest.calc_divides_widening

import Logic.basics
import Natural.basics
import Natural.divisibility
import Integer.basics
import Integer.addition
import Integer.ring
import Integer.negation
import Integer.embedding
import Integer.order
import Integer.natural_subtraction

theorem ErrorTest.t (a b d : Natural)
        (abDivides : a ∣ b)
        (bIsDifference : (b : Integer) = d - 1)
        : True :=
  a ∣ b       by abDivides
    = d - 1   by bIsDifference

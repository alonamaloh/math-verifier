-- `substituting <lemma>` where the lemma still needs its argument(s).
-- `substituting` wants a concrete equality term; a bare lemma name is a
-- FUNCTION (a)→(eq), so it reports "not an equality" — without hinting that
-- `by <lemma>` / `by substitution` would infer the arguments instead.
module ErrorTest.probe_substituting_lemma_no_args

import Natural.basics
import Natural.arithmetic

theorem ErrorTest.q (n : Natural) : n + 0 = n :=
  calc n + 0
     = n   by substituting Natural.add_zero

-- A lambda hint on a bare equality CLAIM keeps the ordinary proof-term
-- reading (the inner error is the real one there) — but when the
-- under-binder pointwise-congruence form was attempted and declined, the
-- error must carry a note saying so and why, instead of only the
-- incomprehensible inner-lambda failure.

module ErrorTest.under_binder_claim_note

import Logic.basics
import Equality.basics
import Natural.basics
import Lists.list
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.commutative_ring_aggregation

theorem ErrorTest.under_binder_claim_head_mismatch {r : CommutativeRing}
        (f : ℕ → CommutativeRing.carrier(r)) (E : List(ℕ))
        : CommutativeRing.sumOver(f, E) = CommutativeRing.productOver(f, E) := {
  CommutativeRing.sumOver(f, E) = CommutativeRing.productOver(f, E)
      by ((j : ℕ) ↦ { done });
  done
}

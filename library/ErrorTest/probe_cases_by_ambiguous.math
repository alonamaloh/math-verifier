-- `cases by <lemma>` with TWO context premises matching the lemma's premise
-- shape (a*a=0 and b*b=0). The tactic picks one; the `let`/return type does
-- not disambiguate, so it silently picks the wrong premise and the error
-- surfaces as a downstream branch type-mismatch (b=0 vs expected a=0).
module ErrorTest.probe_cases_by_ambiguous

import Integer.basics
import Integer.multiplication
import Logic.basics
import Logic.sum
import Algebra.integer_domain

theorem ErrorTest.p (a b : Integer)
        (aaZero : a * a = Integer.zero)
        (bbZero : b * b = Integer.zero) : a = Integer.zero :=
  cases by Integer.multiply_eq_zero_implies {
    | Or.introduceLeft(h) => h
    | Or.introduceRight(h) => h
  }

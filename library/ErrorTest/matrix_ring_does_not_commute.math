-- Ordered-word normalization must never commute matrix factors.

module ErrorTest.matrix_ring_does_not_commute

import Algebra.matrix_ring

theorem ErrorTest.matrix_multiplication_is_not_commutative
        {r : CommutativeRing} {n : ℕ}
        (A B : Matrix(r, n, n))
        : A * B = B * A := ring

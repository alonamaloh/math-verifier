-- A finite vector literal has exactly the dimension given by its number of
-- entries.  Expected dimension mismatches must be rejected at elaboration.

module ErrorTest.vector_literal_dimension_mismatch

import Algebra.integer_quadratic_form

definition ErrorTest.badLiteral
        : RingVector(Integer.commutative_ring_bundle, 3) :=
  ⟨1, 2⟩

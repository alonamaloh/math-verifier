-- The underscore induction spellings are retired (A4): the unified
-- grammar is `by induction on E …` / `by strong induction on E …`.
-- The old keyword must fail with a migration-grade error steering to
-- the space spelling.
module ErrorTest.by_induction_retired

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic

theorem ErrorTest.retired_by_induction (n : Natural) : n + 0 = n :=
  by_induction on n with IH {
    case n = 0: done
    case n = k + 1 for some k: done by IH
  }

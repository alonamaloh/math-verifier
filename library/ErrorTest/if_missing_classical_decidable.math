-- `if P then a else b` in a module that does NOT import
-- `Natural.classical_decidable`. The conditional desugars to
-- `cases Logic.classical_decidable(P)`, so the lookup fails on the
-- desugared name — the message must point at the missing import, not
-- just report a baffling "unknown identifier" at the `if`.
module ErrorTest.if_missing_classical_decidable

import Logic.basics
import Natural.basics

definition ErrorTest.conditional_needs_import (P : Proposition) : Natural :=
  if P then 0 else 1

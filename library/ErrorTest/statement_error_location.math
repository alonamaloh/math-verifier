-- A kernel TypeError thrown while elaborating a theorem STATEMENT (here:
-- `+` on Polynomial(Real, Real.zero) dispatches to an instance that wants
-- the Ring.carrier(Real.ring) spelling, passing Real where a Ring is
-- expected) must be anchored at the declaration — file, theorem name, a
-- line inside the statement — not reported at 1:1 with no context.
module ErrorTest.statement_error_location

import Logic.basics
import Logic.product
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Algebra.ring
import Algebra.ring_bundle
import Real.basics
import Real.addition
import Real.multiplication
import Real.negation
import Real.ring
import Real.algebra
import Real.instances
import Polynomial.basics
import Polynomial.addition
import Polynomial.multiplication

theorem ErrorTest.statement_error (p q : Polynomial(Real, Real.zero))
    : p + q = q + p
    := sorry

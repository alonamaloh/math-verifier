-- `Natural` is sealed (PLAN_NATURAL_SEALING Stage 4): a
-- Proposition-valued pattern match on it cannot ride the Type-level
-- boundary combinator, and here the Prop-level twin
-- (`Natural.induction_on_successor`) is not in scope either — the
-- error must teach both escape routes (restate by induction, or the
-- raw floor's `unfold Natural in`).
module ErrorTest.sealed_natural_pattern_match

import Logic.basics
import Equality.basics
import Natural.basics

definition ErrorTest.sealed_prop_match : ∀ (n : Natural). n = n
  | zero         => reflexivity(Natural, zero)
  | successor(k) => reflexivity(Natural, successor(k))

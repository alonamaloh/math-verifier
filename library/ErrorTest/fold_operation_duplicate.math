-- A second `fold_operation` registration for a (symbol, carrier) key that
-- an IMPORTED module already registered (Natural `+`, from
-- Algebra.aggregation) must be rejected with the ambiguity message —
-- which also proves the registry replays from the cache.
module ErrorTest.fold_operation_duplicate

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Algebra.monoid
import Algebra.aggregation

definition ErrorTest.second_add_witness : IsMonoid(Natural, Natural.add, 0) := {
  claim Natural.add_associative;
  claim Natural.zero_add;
  claim Natural.add_zero;
  done
}

fold_operation (+) on Natural := ErrorTest.second_add_witness

-- `choose … from <lemma>` with TWO hypotheses matching the lemma's premise
-- and pinning different arguments must refuse with a list, not silently
-- pick one (the original incident: two ≤ facts in scope, the wrong one
-- chosen for Natural.subtraction_witness).

module ErrorTest.choose_from_ambiguous_premise

import axioms
import Logic.basics
import Logic.exists
import Natural.basics
import Natural.order
import Natural.subtraction

theorem ErrorTest.ambiguous_choose (i j p : Natural)
        (jLessOrEqual : j ≤ i)
        (iBelow : successor(i) ≤ p)
        : ∃ (c : Natural). i = j + c := {
  choose difference as equation from Natural.subtraction_witness;
  witness difference with equation
}

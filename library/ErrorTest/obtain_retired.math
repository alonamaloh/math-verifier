-- The `obtain` construct is retired (A5): ∃/∧ elimination is `choose`
-- (with the property stated on the page), and genuine data destructures
-- are `let ⟨…⟩ :=`. The old spelling must fail with a migration-grade
-- error steering to both.
module ErrorTest.obtain_retired

import Logic.basics
import Logic.exists
import Natural.basics

theorem ErrorTest.retired_obtain
        (h : ∃ (n : Natural). n = n) : Natural := {
  obtain ⟨n, eq⟩ from h;
  n
}

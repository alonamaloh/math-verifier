-- §9 error 4: a single prefix term matching BOTH probe starts is
-- ambiguous; every surviving candidate is named.
module ErrorTest.fold_ellipsis_ambiguous

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.monus
import Algebra.monoid
import Algebra.aggregation

theorem ErrorTest.ambiguous (k : Natural) : (0 + ... + k * (k - 1)) = 0 :=
  done

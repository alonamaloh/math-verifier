-- A2: two in-scope facts with the addressed statement is a loud error
-- naming both (anonymous facts included).
module ErrorTest.statement_address_ambiguous

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic

theorem ErrorTest.ambiguousAddress (P : Natural → Proposition) (m : Natural)
        (universal : ∀ (k : Natural). P(k))
        : P(m) := {
  claim ∀ (j : Natural). P(j) by universal;
  (∀ (k : Natural). P(k))(m)
}

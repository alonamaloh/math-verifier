-- A pattern destructure / `cases` on a scrutinee whose type is NOT an
-- inductive (here a function type) — even after ζ-unfolding local lets the
-- head doesn't reduce to an inductive. The message must say so in user
-- terms, not "head is not an inductive constant after normalisation".
module ErrorTest.cases_scrutinee_not_inductive

import Logic.basics

theorem ErrorTest.t (P : Proposition) (h : P → P) : P := {
  let ⟨a, b⟩ := h;
  a
}

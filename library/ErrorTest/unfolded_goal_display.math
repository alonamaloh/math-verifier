-- A `divides` goal reaches the error UNFOLDED (the choose's Exists-elim
-- motive δ-expands it). The citation-failure message should print the
-- goal folded (`d ∣ n` / `Natural.divides d n`), not its `Exists` body.
module ErrorTest.unfolded_goal_display

import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.divisibility
import Logic.exists

theorem ErrorTest.bad (d n : Natural) (h : d ∣ n) : d ∣ n := {
  choose q such that n = d * q as eq from h;
  done by Natural.multiply_commutative
}

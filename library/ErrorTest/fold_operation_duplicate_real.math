-- Same probe as fold_operation_duplicate, for a carrier whose
-- registration lives in its instances file: a second registration for
-- (`*`, Real) must collide with the one Real.instances registered —
-- proving the per-carrier instances registrations replay from the cache.
module ErrorTest.fold_operation_duplicate_real

import Logic.basics
import Equality.basics
import Algebra.monoid
import Real.basics
import Real.multiplication
import Real.algebra
import Real.instances

definition ErrorTest.second_multiply_witness
        : IsMonoid(Real, Real.multiply, Real.one) := {
  claim Real.multiply_is_monoid;
  done
}

fold_operation (*) on Real := ErrorTest.second_multiply_witness

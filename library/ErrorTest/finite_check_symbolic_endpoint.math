-- The first version intentionally enumerates only closed literal ranges.
module ErrorTest.finite_check_symbolic_endpoint

import Logic.basics
import Natural.finite_range

theorem ErrorTest.symbolicEndpoint (upper : ℕ) (P : ℕ → Proposition)
        : ∀ (n : ℕ). 0 ≤ n → n < upper → P(n) :=
  by finite_check n from 0 until upper


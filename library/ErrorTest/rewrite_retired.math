-- The `rewrite(…)` form is retired (A1 de-rewrite): transport across an
-- in-scope equation is what a bare stated proposition already does (the
-- context-equality bridge carries it), and a chain step cites the
-- equation directly. The old spelling must fail with a migration-grade
-- error steering to the bare forms.
module ErrorTest.rewrite_retired

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.order

theorem ErrorTest.retired_rewrite
        (a b : Natural) (equality : a = b) (smallA : zero ≤ a)
        : zero ≤ b :=
  rewrite(equality, smallA)

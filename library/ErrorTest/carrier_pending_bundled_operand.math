-- PENDING (PLAN_ELABORATOR_ERGONOMICS.md step E1). Binary operator dispatch
-- does not see the concrete carrier behind the ring bundle, so it cannot lift
-- the Natural operand `Matrix.truant(A)`. Pinned alongside the relation probe
-- because operator dispatch and relation dispatch are separate code paths and
-- must BOTH consume the shared carrier-head candidates.
--
-- When E1 lands, DELETE this file and move the probe into
-- library/Test/expected_carrier_propagation_test.math.
module ErrorTest.carrier_pending_bundled_operand

import Algebra.escalation

definition ErrorTest.pending {n : ℕ}
        (M : Matrix(Integer.commutative_ring_bundle, n, n))
        (A : Matrix(Integer.commutative_ring_bundle, n, n))
        (i : NaturalsBelow(n)) : Proposition :=
  M(i, i) * Matrix.truant(A) = 0

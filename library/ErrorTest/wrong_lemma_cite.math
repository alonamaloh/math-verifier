-- Control case (a GOOD message): citing a lemma whose conclusion
-- genuinely cannot unify with the goal. The error should name the
-- conclusion and the goal so the mismatch is obvious.
module ErrorTest.wrong_lemma_cite

import Natural.basics
import Natural.peano
import Natural.arithmetic

theorem ErrorTest.bad_cite (a b : Natural) : a + b = b + a := {
  claim a + b = b + a by Natural.multiply_commutative
}

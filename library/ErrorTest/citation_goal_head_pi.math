-- A citation whose conclusion targets a different head than the goal
-- reports a head-mismatch. When the GOAL is a `∀`/`→` statement (its head
-- is a binder, not a named relation), the head-description must READ as
-- "a ∀/→ statement" rather than leaking the internal `<unknown>`
-- placeholder that `headConstantName` returns for a non-constant head.
module ErrorTest.citation_goal_head_pi

import Natural.basics
import Natural.arithmetic

theorem ErrorTest.citation_goal_head_pi
    (P : Natural → Proposition) (a b : Natural) (h : a = b)
    : (n : Natural) → P(n) := {
  (n : Natural) → P(n) by h
}

-- PERMANENT negative control (PLAN_ELABORATOR_ERGONOMICS.md step E0).
--
-- Coercions are UPWARD only. A Rational in a Natural-expecting position must
-- stay an error however much carrier evidence is flowing around it; the
-- registry has no ℚ → ℕ edge and none may be invented.
module ErrorTest.no_downward_carrier_coercion

import Rational.embedding
import Rational.order

definition ErrorTest.control (q : ℚ) : Proposition := Natural.to_integer(q) = 0

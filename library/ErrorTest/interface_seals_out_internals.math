-- D6 close-out pin: a consumer of a sealed interface CANNOT reach a
-- construction-internal name the interface did not export — the sealed
-- cache filters them out entirely (they are absent, not merely
-- unadvertised), so the reference fails loudly at lookup. This is what
-- made the once-planned visibility lint moot.
module ErrorTest.interface_seals_out_internals

import Logic.basics
import Equality.basics
import Real.interface

theorem ErrorTest.reach_sealed_out_internal (x : Real) : True := {
  done by Real.bisectionLeft_below_witness
}

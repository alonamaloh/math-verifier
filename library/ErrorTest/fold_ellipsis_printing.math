-- §8 printing: a goal carrying an Algebra.Fold prints back in the
-- ellipsis notation the user wrote (this intentionally unprovable
-- statement exists to capture the printed goal).
module ErrorTest.fold_ellipsis_printing

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Algebra.monoid
import Algebra.aggregation

theorem ErrorTest.printed (n : Natural) : (1 + 2 + ... + n) = 0 :=
  done

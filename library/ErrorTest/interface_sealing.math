-- D Phase-1 sealing acceptance: through the interface, Test.Counter is
-- an abstract type — a consumer CANNOT see the construction (Counter
-- := Natural), so equating start with a Natural numeral is ill-typed.
module ErrorTest.interface_sealing

import Logic.basics
import Equality.basics
import Natural.basics
import Test.counter_interface

theorem ErrorTest.peeks_behind_the_interface
        : Test.Counter.start = (0 : Natural) :=
  done

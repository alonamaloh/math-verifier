-- The fold binder form over an operator with no fold_operation
-- registration on the body's carrier must fail with the actionable
-- registration message (naming the operator, the carrier, and the
-- declaration to write).
module ErrorTest.fold_binder_unregistered

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.monus
import Algebra.monoid
import Algebra.aggregation

theorem ErrorTest.unregistered_fold (n : Natural)
        : (fold (-) k from 0 to n of k) = 0 :=
  done

-- Pattern-match `| Ctor(...) => body` proof rows are retired for THEOREMS
-- (PLAN_REMOVE_SURFACE_CASES STEP 5): they are a raw recursor spelling, and
-- a theorem proof must read like mathematics. The proof is written with
-- `by induction on <proof> { case Ctor(...): ... }` instead, moving the
-- premise being matched to a parameter. Pattern-match clauses remain
-- available for `definition`s. The old spelling must fail at parse time
-- with a migration-grade error.
module ErrorTest.pattern_match_theorem_retired

import Logic.basics
import Natural.basics

theorem ErrorTest.retired_pattern_theorem (n : Natural) : n = n
  | zero         => reflexivity(Natural, 0)
  | successor(k) => reflexivity(Natural, successor(k))

-- The `claim` keyword is retired (A1 Phase 3): a stated proposition is
-- written bare (`P;`, `P by V;`, `P as NAME;`), and a goal restate is
-- `done`. The old spelling must fail with a migration-grade error
-- steering to the bare forms.
module ErrorTest.claim_retired

import Logic.basics
import Natural.basics

theorem ErrorTest.retired_claim
        (a b : Natural) (aEqB : a = b) : b = a := {
  claim a = b;
  claim b = a
}

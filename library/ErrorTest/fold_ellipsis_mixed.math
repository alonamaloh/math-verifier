-- §9 error 1: an ellipsis prefix mixing two operators at the same
-- precedence must be rejected at parse time.
module ErrorTest.fold_ellipsis_mixed

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Algebra.monoid
import Algebra.aggregation

theorem ErrorTest.mixed (n : Natural) : (1 + 2 - ... - n) = 0 :=
  done

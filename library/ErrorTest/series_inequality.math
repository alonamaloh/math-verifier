-- §6 v1: series inequalities are rejected (the series node reaches an
-- operand position of ≤, which is the term-position error).
module ErrorTest.series_inequality

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Algebra.monoid
import Algebra.aggregation
import Rational.basics
import Real.basics
import Real.embedding
import Real.addition
import Real.multiplication
import Real.order
import Real.power

theorem ErrorTest.seriesInequality (B : Real)
        : Real.power(2, 0) + Real.power(2, 1) + ... + Real.power(2, k) + ... ≤ B :=
  done

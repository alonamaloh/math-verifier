-- An application registration (`operator (()) on (T) := F`) requires F
-- to yield a function once the wrapped value is supplied. Registering a
-- projection that returns a plain value must fail with a message naming
-- the required shape.
module ErrorTest.application_operator_not_function

import Logic.basics
import Equality.basics
import Natural.basics

inductive ErrorTest.Wrapped : Type(0) where
  | ErrorTest.Wrapped.make : Natural → ErrorTest.Wrapped

definition ErrorTest.Wrapped.value : ErrorTest.Wrapped → Natural
  | ErrorTest.Wrapped.make(n) => n

operator (()) on (ErrorTest.Wrapped) := ErrorTest.Wrapped.value

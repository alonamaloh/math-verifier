-- `Natural` is sealed (PLAN_NATURAL_SEALING Stage 4): a Proposition
-- `cases` on it needs a boundary theorem, and this file deliberately
-- imports neither `Natural.cases_on_successor` nor the induction twin —
-- the error must name the boundary theorem and the raw floor's
-- `unfold Natural in`.
module ErrorTest.sealed_natural_cases

import Logic.basics
import Equality.basics
import Natural.basics

theorem ErrorTest.sealed_prop_cases (n : Natural) : n = n :=
  cases n {
    | zero         => reflexivity(Natural, zero)
    | successor(k) => reflexivity(Natural, successor(k))
  }

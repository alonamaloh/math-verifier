-- The square-zero inverse is false without the relation N*N = 0.

module ErrorTest.matrix_square_zero_requires_evidence

import Algebra.matrix_ring

theorem ErrorTest.matrix_square_zero_relation_is_not_inferred
        {r : CommutativeRing} {n : ℕ}
        (N : Matrix(r, n, n))
        : (Matrix.identity(r, n) + N)
            * (Matrix.identity(r, n) + Matrix.negate(N))
          = Matrix.identity(r, n) := ring

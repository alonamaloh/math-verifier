-- The underscore strong-induction spelling is retired (A4): write
-- `by strong induction on E with hypothesis ih`. The old keyword must
-- fail with a migration-grade error steering to the space spelling.
module ErrorTest.by_strong_induction_retired

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Natural.strong_recursion

theorem ErrorTest.retired_by_strong_induction (n : Natural) : 0 ≤ n := {
  by_strong_induction on n with hypothesis smaller;
  done by Natural.zero_least
}

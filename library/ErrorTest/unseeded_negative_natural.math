-- PERMANENT negative control (PLAN_ELABORATOR_ERGONOMICS.md step E2).
--
-- Expected-carrier propagation lifts a Natural variable through unary `-`
-- only when the surrounding expression supplies a registered upper carrier.
-- With no expected carrier, `-m` must remain rejected rather than guessing
-- Integer (or any other carrier).
module ErrorTest.unseeded_negative_natural

import Natural.basics
import Natural.arithmetic

definition ErrorTest.control (m : ℕ) : Proposition := -m = -m

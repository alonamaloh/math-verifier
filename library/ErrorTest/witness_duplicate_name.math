-- A witness-case arm's `for some` binder list must use distinct names.
-- Repeating a name (`for some k, k`) is a parse error: the two binders
-- would shadow each other and the body could not name both.
module ErrorTest.witness_duplicate_name

import Logic.basics
import Logic.exists
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order

theorem ErrorTest.witness_duplicate_name (n : Natural) : 0 ≤ n := {
  0 ≤ n by cases {
    case n = k + k for some k, k: done
    otherwise: done
  };
  done
}

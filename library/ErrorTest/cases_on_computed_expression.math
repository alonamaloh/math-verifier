-- A user-written `cases` whose scrutinee is a computed expression (a function
-- application) is rejected: a `cases` scrutinee must be a variable. The message
-- must steer to the condition forms / an argument-matching helper rather than
-- leave the user staring at an inductive-elaboration failure.
module ErrorTest.cases_on_computed_expression

import Logic.basics
import Natural.basics
import Natural.compare

definition ErrorTest.cases_on_expr (a b : Natural) : Natural :=
  cases Natural.compare_strict(a, b) {
    | Natural.StrictComparison.below(_)   => 0
    | Natural.StrictComparison.atLeast(_) => 1
  }

-- The single-prefix products display is genuinely two-way ambiguous:
-- f(0) = 0*(0 monus 1) = 0 and f(1) = 1*0 both generate the written 1*0.
module ErrorTest.fold_ellipsis_ambiguous_products

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.monus
import Algebra.monoid
import Algebra.aggregation

theorem ErrorTest.ambiguousProducts (k : Natural)
        : (1*0 + ... + k*(k-1)) = 0 :=
  done

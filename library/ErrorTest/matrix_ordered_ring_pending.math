-- M2a acceptance: this valid matrix-ring expansion must eventually move to
-- matrix_ergonomics_test.math with the proof `:= ring`.

module ErrorTest.matrix_ordered_ring_pending

import Algebra.matrix_ring

theorem ErrorTest.matrix_ordered_ring_expansion_pending
        {r : CommutativeRing} {n : ℕ}
        (T D N : Matrix(r, n, n))
        : ((Matrix.identity(r, n) + T) * D)
            * (Matrix.identity(r, n) + N)
          = (D + T * D) + (D * N + (T * D) * N) := ring

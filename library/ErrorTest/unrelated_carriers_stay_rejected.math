-- PERMANENT negative control (PLAN_ELABORATOR_ERGONOMICS.md step E0).
--
-- Two carriers with no join must stay an error. Widening dispatch to consult
-- carrier-head candidates must not turn "no common carrier" into a guess at
-- one of them.
module ErrorTest.unrelated_carriers_stay_rejected

import Algebra.escalation
import Rational.embedding
import Rational.order

definition ErrorTest.control (q : ℚ) {n : ℕ}
        (v : RingVector(Integer.commutative_ring_bundle, n)) : Proposition :=
  q = v

-- Indexing a value whose type has no registered `[]` operator must fail
-- with a message that names the type and shows the registration form.
module ErrorTest.index_operator_unregistered

import Logic.basics
import Equality.basics
import Natural.basics

theorem ErrorTest.bad_index (n : Natural) (k : Natural) : n[k] = n[k] :=
  reflexivity(Natural, n[k])

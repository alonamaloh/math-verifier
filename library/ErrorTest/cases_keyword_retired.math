-- The `cases <scrutinee>` pattern-match keyword is retired: it was a raw
-- recursor split. A PROOF splits with `by cases` / `by induction on x`;
-- a VALUE destructures with `let ⟨…⟩ := x in …`; a quotient representative
-- comes from `by_representatives x as <pat> => …`. Only `cases by <lemma>`
-- (the goal-directed split whose disjunction a lemma supplies) survives.
-- The old spelling must fail at parse time with a migration-grade error.
module ErrorTest.cases_keyword_retired

import Logic.basics
import Natural.basics

theorem ErrorTest.retired_cases (n : Natural) : n = n :=
  cases n {
    | zero         => reflexivity(Natural, 0)
    | successor(k) => reflexivity(Natural, successor(k))
  }

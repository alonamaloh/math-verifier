-- A lambda `by` proof on a calc `=` step has exactly one reading — the
-- under-binder pointwise-congruence form. When that form does not apply
-- (here: the endpoints' heads differ), the error must SAY so, naming the
-- recognizer and the reason — not let the lambda elaborate bare and die
-- with "bare `claim` / `done` needs an expected type" (QUIRK Q9's
-- misreport).

module ErrorTest.under_binder_fall_through

import Logic.basics
import Equality.basics
import Natural.basics
import Lists.list
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.commutative_ring_aggregation

theorem ErrorTest.under_binder_head_mismatch {r : CommutativeRing}
        (f : ℕ → CommutativeRing.carrier(r)) (E : List(ℕ))
        : CommutativeRing.sumOver(f, E) = CommutativeRing.productOver(f, E) := {
  CommutativeRing.sumOver(f, E)
     = CommutativeRing.sumOver(f, E)
     = CommutativeRing.productOver(f, E)   by ((j : ℕ) ↦ { done });
  done
}

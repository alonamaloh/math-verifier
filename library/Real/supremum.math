-- Real/supremum.math
--
-- Least-upper-bound (sup) property for Real: every nonempty subset of
-- Real that's bounded above has a supremum (least upper bound). This
-- is the defining property of Real that distinguishes it from
-- Rational.
--
-- The proof is by bisection. Given x0 ∈ S and upper bound B0:
--   - Build a sequence of nested rational intervals [aₙ, bₙ] with
--     bₙ - aₙ = (B0 - a0)/2ⁿ, where:
--       * aₙ is not an upper bound for S (some x ∈ S exceeds it)
--       * bₙ IS an upper bound for S
--   - At each step, decide via excluded_middle whether the midpoint
--     mₙ = (aₙ + bₙ)/2 is an upper bound; bisect accordingly.
--   - (aₙ) is Cauchy; its real-valued limit s is the supremum:
--       * Upper bound: any x ∈ S satisfies x ≤ bₙ for all n, so
--         x ≤ lim(bₙ) = s.
--       * Least: any upper bound B satisfies aₙ ≤ B for all n
--         (since aₙ < some x ≤ B), so s = lim(aₙ) ≤ B.
--
-- The construction uses excluded_middle (already imported transitively
-- via Real.field) — fully classical, consistent with the rest of the
-- library.

module Real.supremum

import Logic.basics
import Logic.exists
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.classical_decidable
import Natural.peano
import Natural.arithmetic
import Natural.add_order
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.order
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.reciprocal
import Rational.linearity
import Rational.archimedean
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.order
import Real.absolute_value
import Real.absolute_value_order
import Real.embedding_order
import Real.linearity
import Set.basics

-- ----------------------------------------------------------------------
-- Halving algebra used by the bisection width invariant. Kept local
-- to this file rather than promoted to `Rational/halve.math` because
-- `ring` needs `Rational.multiply_negate_left` (defined in
-- `Rational/order_multiplication.math`, which sits above `halve` in
-- the import DAG) to handle distributivity over subtraction. Once
-- the carrier has that lemma transitively, the proofs collapse to
-- one `halve_doubled` step plus pure-ring distribution.

-- halve(a + a) = a. Unfold halve, distribute (ring), refold, apply
-- halve_doubled.
theorem Rational.halve_of_doubled (a : Rational)
        : Rational.halve(a + a) = a :=
  calc Rational.halve(a + a)
     = (a + a) * Rational.one_half
     = a * Rational.one_half + a * Rational.one_half
     = Rational.halve(a) + Rational.halve(a)
     = a

-- halve(x) - halve(y) = halve(x - y). Distributivity over `(1/2)` is
-- pure ring once `multiply_negate_left` is in scope.
theorem Rational.halve_subtract_distributive (x y : Rational)
        : Rational.halve(x) - Rational.halve(y) = Rational.halve(x - y) :=
  calc Rational.halve(x) - Rational.halve(y)
     = x * Rational.one_half - y * Rational.one_half
     = (x - y) * Rational.one_half
     = Rational.halve(x - y)

-- halve(a + b) - a = halve(b - a). Yes-branch width identity:
-- new_width = midpoint - left = halve(left + right) - left =
-- halve(right - left) = halve(old_width). The auto-prover finds each
-- step via the lemma index (halve_of_doubled, halve_subtract_distributive,
-- add_subtract_cancel_left).
theorem Rational.halve_endpoint_left (a b : Rational)
        : Rational.halve(a + b) - a = Rational.halve(b - a) :=
  calc Rational.halve(a + b) - a
     = Rational.halve(a + b) - Rational.halve(a + a)
     = Rational.halve((a + b) - (a + a))
     = Rational.halve(b - a)

-- b - halve(a + b) = halve(b - a). No-branch width identity:
-- new_width = right - midpoint = right - halve(left + right) =
-- halve(right - left) = halve(old_width).
theorem Rational.halve_endpoint_right (a b : Rational)
        : b - Rational.halve(a + b) = Rational.halve(b - a) :=
  calc b - Rational.halve(a + b)
     = Rational.halve(b + b) - Rational.halve(a + b)
     = Rational.halve((b + b) - (a + b))
     = Rational.halve(b - a)

-- ----------------------------------------------------------------------
-- Halving order helpers. The midpoint of [a, b] (where a ≤ b) lies in
-- [a, b]; halving preserves ≤. Used by the bisection's within-interval
-- and monotone-step invariants.

theorem Rational.halve_preserves_LessOrEqual
        (x y : Rational) (xLeqY : x ≤ y)
        : Rational.halve(x) ≤ Rational.halve(y) := {
  claim (0 : Rational) ≤ Rational.one_half;
  calc Rational.halve(x)
     = x * Rational.one_half
     ≤ y * Rational.one_half   by Rational.LessOrEqual.multiply_by_nonneg_right
     = Rational.halve(y)
}

-- a ≤ b → a ≤ halve(a + b). From a + a ≤ a + b (left-add b), halve
-- both sides, then `halve(a + a) = a`.
theorem Rational.halve_left_le_sum (a b : Rational) (aLeqB : a ≤ b)
        : a ≤ Rational.halve(a + b) := {
  claim a + a ≤ a + b;
  calc a
     = Rational.halve(a + a)
     ≤ Rational.halve(a + b)   by Rational.halve_preserves_LessOrEqual
}

-- a ≤ b → halve(a + b) ≤ b. Symmetric: a + b ≤ b + b, then halve and
-- `halve(b + b) = b`.
theorem Rational.halve_sum_le_right (a b : Rational) (aLeqB : a ≤ b)
        : Rational.halve(a + b) ≤ b := {
  claim a + b ≤ b + b;
  calc Rational.halve(a + b)
     ≤ Rational.halve(b + b)   by Rational.halve_preserves_LessOrEqual
     = b
}

-- ----------------------------------------------------------------------
-- Bound vocabulary on Real.

-- `b` is an upper bound for `S` when every element of `S` is ≤ `b`.
definition Real.IsUpperBound (subset : Set(Real)) (bound : Real)
        : Proposition :=
  ∀ (subject : Real). subject ∈ subset → subject ≤ bound

-- `S` is bounded above when some Real is an upper bound for it.
definition Real.IsBoundedAbove (subset : Set(Real)) : Proposition :=
  ∃ (bound : Real). Real.IsUpperBound(subset, bound)

-- `s` is the supremum (least upper bound) of `S` when:
--   - `s` is an upper bound for `S`, and
--   - every other upper bound `b` satisfies `s ≤ b`.
definition Real.IsSupremum (subset : Set(Real)) (s : Real)
        : Proposition :=
  Real.IsUpperBound(subset, s) ∧ ∀ (otherBound : Real).
            Real.IsUpperBound(subset, otherBound)
          → s ≤ otherBound

-- ----------------------------------------------------------------------
-- Building block #1: every Real has a Rational lower bound.
--
-- Given x : Real with Cauchy representative `make(seq, seqCauchy)`,
-- pick N from the Cauchy witness at ε = 1, then `q := seq(N) - 1` is
-- below x. Reason: for m ≥ N, `|seq(m) - seq(N)| < 1`, so
-- `seq(m) > seq(N) - 1 = q`, so the difference sequence
-- `λn. seq(n) - q` is eventually > 0, hence eventually > -ε for any
-- positive ε — that's exactly Real.IsNonneg(x - (q : Real)).

theorem Real.exists_rational_below_at_make
        : ∀ (rep : CauchyRationalSequence).
            ∃ (q : Rational).
                (q : Real) ≤ Quotient.class_of(rep)
  | CauchyRationalSequence.make(seq, seqIsCauchy) => {
      -- Pick N from the Cauchy witness at ε = 1; for m, n ≥ N,
      -- |seq(m) - seq(n)| < 1. The witness rational is q := seq(N) - 1
      -- — every later term `seq(m)` lies in (seq(N) - 1, seq(N) + 1),
      -- hence strictly above q.
      choose N as cauchyAt1
          from seqIsCauchy((1 : Rational), (0 : Rational) < (1 : Rational));
      witness seq(N) - (1 : Rational) with (unfold Real.IsNonneg in {
        -- (q : Real) ≤ mk(make(seq, _)) unfolds (via Quotient.lift
        -- through `LessOrEqual` → `IsNonneg` of the difference) to:
        -- `∀ ε > 0. ∃ M. ∀ m ≥ M. seq(m) - (seq(N) - 1) > -ε`. Take
        -- M = N and chain -ε < 0 < seq(m) - (seq(N) - 1).
        let ε ∈ Rational with (0 : Rational) < ε;
        witness N with {
          let m ∈ Natural with N ≤ m;
          claim N ≤ N;
          claim abs(seq(m) - seq(N)) < (1: Rational)
            by cauchyAt1(m, given(N ≤ m), N, given(N ≤ N));
          claim (-(1 : Rational) < seq(m) - seq(N))
                  ∧ (seq(m) - seq(N) < (1 : Rational))
            by Rational.absolute_value_LessThan_bounds;
          claim -(1 : Rational) < seq(m) - seq(N);
          -- 0 = -1 + 1 < (seq(m) - seq(N)) + 1, adding 1 on the right;
          -- ring rearranges the RHS to `seq(m) - (seq(N) - 1)`.
          calc (0 : Rational)
                  = -(1 : Rational) + (1 : Rational)
                  < (seq(m) - seq(N)) + (1 : Rational)
                       by Rational.add_preserves_LessThan
                  = seq(m) - (seq(N) - (1 : Rational));
          -- Close -ε < seq(m) - (seq(N) - 1) by chaining through 0:
          -- -ε < 0 (since ε > 0) and 0 < ... by the calc above.
          calc -ε
             < (0 : Rational)        by Rational.negate_LessThan_zero_of_positive
             < seq(m) - (seq(N) - (1 : Rational))
        }
      })
   }

-- Lift the at-make form via Quotient.induct.
theorem Real.exists_rational_below (x : Real)
        : ∃ (q : Rational). (q : Real) ≤ x :=
  by_representatives x as rep => done

-- ----------------------------------------------------------------------
-- Building block #2: every Real has a Rational upper bound. Symmetric
-- to #1 with q := seq(N) + 1; for m ≥ N, |seq(m) - seq(N)| < 1 gives
-- seq(m) < seq(N) + 1 = q, so q - seq(m) > 0, hence x ≤ (q : Real).

theorem Real.exists_rational_above_at_make
        : ∀ (rep : CauchyRationalSequence).
            ∃ (q : Rational).
                (Quotient.class_of(rep) : Real) ≤ (q : Real)
  | CauchyRationalSequence.make(seq, seqIsCauchy) => {
      choose N as cauchyAt1
          from seqIsCauchy((1 : Rational), Rational.zero_less_one);
      witness seq(N) + (1 : Rational) with
          unfold Real.IsNonneg in
          ((ε : Rational)
                   (εPositive : (0 : Rational) < ε) ↦
            witness N with
                (m : Natural) (mGeN : N ≤ m) ↦ {
                  claim N ≤ N;
                  claim abs(seq(m) - seq(N)) < (1 : Rational)
                    by cauchyAt1(m, mGeN, N, given(N ≤ N));
                  claim (-(1 : Rational) < seq(m) - seq(N))
                          ∧ (seq(m) - seq(N) < (1 : Rational))
                    by Rational.absolute_value_LessThan_bounds;
                  claim seq(m) - seq(N) < (1 : Rational);
                  -- Negate both sides: from `seq(m) - seq(N) < 1` we
                  -- get `-1 < -(seq(m) - seq(N)) = seq(N) - seq(m)`.
                  -- Then add 1 to both sides:
                  -- `0 < (seq(N) - seq(m)) + 1 = (seq(N) + 1) - seq(m)`.
                  calc -(1 : Rational)
                          < -(seq(m) - seq(N))   by Rational.LessThan.negate
                          = seq(N) - seq(m);
                  calc (0 : Rational)
                          = -(1 : Rational) + (1 : Rational)
                          < (seq(N) - seq(m)) + (1 : Rational)
                               by Rational.add_preserves_LessThan
                          = (seq(N) + (1 : Rational)) - seq(m);
                  -- Chain: -ε < 0 < (seq(N) + 1) - seq(m).
                  calc -ε
                     < (0 : Rational)        by Rational.negate_LessThan_zero_of_positive
                     < (seq(N) + (1 : Rational)) - seq(m)
                })
   }

-- Lift exists_rational_above_at_make via Quotient.induct.
theorem Real.exists_rational_above (x : Real)
        : ∃ (q : Rational). x ≤ (q : Real) :=
  by_representatives x as rep => done

-- A positive rational roof over |x|: the form every ε-argument wants,
-- with positivity bundled in so the roof can be fed to reciprocals.
theorem Real.exists_positive_rational_roof (x : Real)
        : ∃ (q : Rational). Rational.zero < q ∧ abs(x) ≤ (q : Real) := {
  claim ∃ (q : Rational). abs(x) ≤ (q : Real);
  choose bound as boundRoof from given(∃ (q : Rational). abs(x) ≤ (q : Real));
  claim Real.zero ≤ abs(x);
  claim Rational.zero < Rational.one;
  claim Real.zero < (Rational.one : Real)
      by Rational.to_real.positive_preserves;
  claim ((bound + Rational.one) : Real)
          = (bound : Real) + (Rational.one : Real);
  calc Real.zero
     ≤ abs(x)
     ≤ (bound : Real);
  calc (Rational.zero : Real)
     ≤ (bound : Real)
     = (bound : Real) + Real.zero
     < (bound : Real) + (Rational.one : Real)
           by Real.add_left_preserves_LessThan
     = ((bound + Rational.one) : Real);
  calc abs(x)
     ≤ (bound : Real)
     = (bound : Real) + Real.zero
     ≤ (bound : Real) + (Rational.one : Real)
           by Real.add_preserves_LessOrEqual_left
     = ((bound + Rational.one) : Real);
  witness bound + Rational.one with {
    claim Rational.zero < bound + Rational.one
        by Rational.to_real.LessThan_reflects;
    done
  }
}

-- ----------------------------------------------------------------------
-- Building block #3: the bisection state and step function.
--
-- Each step of the bisection holds a Rational interval [a, b]. We
-- maintain two invariants on this interval (formalised in the
-- Cauchy + sup proofs below):
--   * b is an upper bound for S (`(b : Real) ≥ everything in S`).
--   * a is below some element of S (∃ y ∈ S. (a : Real) ≤ y).
--
-- The step's midpoint `m = halve(a + b)` is decided classically:
-- either `(m : Real)` is itself an upper bound for S — in which case
-- the new interval is [a, m] — or not, in which case we know some
-- y ∈ S satisfies `m < y` so the new interval [m, b] still meets
-- both invariants.

inductive Real.BisectionInterval : Type(0) where
  | Real.BisectionInterval.make
      : Rational → Rational → Real.BisectionInterval

definition Real.BisectionInterval.left
        : Real.BisectionInterval → Rational
  | Real.BisectionInterval.make(a, _) => a

definition Real.BisectionInterval.right
        : Real.BisectionInterval → Rational
  | Real.BisectionInterval.make(_, b) => b

-- One bisection step PARAMETRIZED by the decidability. Splitting
-- this out from the axiom application lets later proofs case-analyze
-- on the same decidability variable they need to reduce — when the
-- decision is in constructor form (Decidable.yes / Decidable.no),
-- the body's `cases` ι-reduces and the kernel sees `right(step(yes
-- midIsUpper)) ≡ midpoint`. Without this split, the kernel can't
-- unify the proof's case-analysis with the one buried inside
-- `bisectionStep`'s body (both on the opaque axiom result).
definition Real.bisectionStepWithDec
        (subset : Set(Real)) (state : Real.BisectionInterval)
        (decision
            : Logic.Decidable(
                  Real.IsUpperBound(
                      subset,
                      (Rational.halve(
                           Real.BisectionInterval.left(state)
                           + Real.BisectionInterval.right(state))
                       : Real))))
        : Real.BisectionInterval :=
  cases decision {
    | Logic.Decidable.yes(_) =>
        Real.BisectionInterval.make(
            Real.BisectionInterval.left(state),
            Rational.halve(
                Real.BisectionInterval.left(state)
                + Real.BisectionInterval.right(state)))
    | Logic.Decidable.no(_) =>
        Real.BisectionInterval.make(
            Rational.halve(
                Real.BisectionInterval.left(state)
                + Real.BisectionInterval.right(state)),
            Real.BisectionInterval.right(state))
  }

-- One bisection step. Classical: split at the midpoint and pick the
-- half consistent with the running invariants.
definition Real.bisectionStep
        (subset : Set(Real)) (state : Real.BisectionInterval)
        : Real.BisectionInterval :=
  Real.bisectionStepWithDec(
      subset, state,
      Logic.classical_decidable(
          Real.IsUpperBound(
              subset,
              (Rational.halve(
                   Real.BisectionInterval.left(state)
                   + Real.BisectionInterval.right(state)) : Real))))

-- The full bisection sequence: starting from a Rational interval
-- [a0, b0] enclosing the bisection setup, generate the nth refined
-- interval by iterating `bisectionStep`.
definition Real.bisectionIntervals
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        : Natural → Real.BisectionInterval
  | zero =>
      initial
  | successor(predecessor) =>
      Real.bisectionStep(
          subset,
          Real.bisectionIntervals(subset, initial, predecessor))

-- The lower-bound sequence and upper-bound sequence: projections of
-- the bisection intervals.
definition Real.bisectionLeft
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (n : Natural) : Rational :=
  Real.BisectionInterval.left(
      Real.bisectionIntervals(subset, initial, n))

definition Real.bisectionRight
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (n : Natural) : Rational :=
  Real.BisectionInterval.right(
      Real.bisectionIntervals(subset, initial, n))

-- ----------------------------------------------------------------------
-- Invariants of the bisection sequence. Each step's interval `[aₙ,
-- bₙ]` satisfies:
--
--   I1. `aₙ` is below some element of S (in particular, ≤ x0 ∈ S).
--   I2. `bₙ` is an upper bound for S.
--   I3. `bₙ - aₙ = (b0 - a0) / 2ⁿ`.
--   I4. `|aₘ - aₙ| ≤ (b0 - a0) / 2^min(m, n)` (Cauchy bound).
--
-- These are proved by induction on n. Each step's cases on
-- `Logic.classical_decidable` preserves the invariants in each branch.

-- I1: the lower bound of the bisection interval is below some element
-- of S. We use the EXISTENTIAL form `∃ y ∈ S. aₙ ≤ y` rather than `aₙ
-- ≤ x0` for a fixed x0 because the no-branch advances aₙ to the
-- midpoint, which may exceed any particular x0 we'd want to fix.
-- The existential is preserved across both branches: yes-branch keeps
-- the same witness; no-branch extracts a NEW witness from the
-- classical "not an upper bound" fact (some y ∈ S satisfies
-- midpoint ≤ y, otherwise midpoint WOULD have been an upper bound).
theorem Real.bisectionLeft_below_witness
        (subset : Set(Real))
        (initial : Real.BisectionInterval)
        (initialLeftBelowSome
            : ∃ (y : Real).
                  y ∈ subset ∧ (Real.BisectionInterval.left(initial) : Real) ≤ y)
        (n : Natural)
        : ∃ (y : Real).
              y ∈ subset ∧ (Real.bisectionLeft(subset, initial, n) : Real) ≤ y :=
  by_induction on n with IH {
    case zero: initialLeftBelowSome
    case successor(predecessor): {
        let intervals : Real.BisectionInterval :=
            Real.bisectionIntervals(subset, initial, predecessor);
        let midReal : Real :=
            (Rational.halve(
                 Real.BisectionInterval.left(intervals)
                 + Real.BisectionInterval.right(intervals)) : Real);
        -- Decide whether the midpoint is an upper bound. Yes: the new
        -- left endpoint is unchanged, below some element by the IH.
        -- No: the new left endpoint is the midpoint — not an upper
        -- bound, so some y ∈ S exceeds it.
        decide Real.IsUpperBound(subset, midReal) {
          | yes _ => IH
          | no midNotUpper => {
              -- IsUpperBound unfolds to `∀ (y : Real). y ∈ S → y ≤ midReal`;
              -- not_forall_implies_exists_not + not_implies_implies_and_not
              -- give some y with y ∈ S and ¬(y ≤ midReal);
              -- not_LessOrEqual_implies flips to midReal ≤ y.
              choose witnessReal as witnessImpFails
                  from Logic.not_forall_implies_exists_not(
                           Real,
                           (y : Real) ↦
                               y ∈ subset → y ≤ midReal,
                           midNotUpper);
              claim (witnessReal ∈ subset) ∧ ¬(witnessReal ≤ midReal);
              claim witnessReal ∈ subset;
              claim ¬(witnessReal ≤ midReal);
              claim midReal ≤ witnessReal   by Real.not_LessOrEqual_implies;
              witness witnessReal with done
            }
        }
      }
  }

-- I2: the upper bound of the bisection interval is an upper bound
-- for S. Induction on n: the base case is the initial hypothesis;
-- the step case threads the bisectionStep's `cases` on the classical
-- decision. The "yes" branch sets right = midpoint, which is exactly
-- the upper-bound proof we picked that branch by; the "no" branch
-- preserves right = right(predecessor), which the IH covers.
--
-- The `cases X with decisionEq` form retains the equation
-- `classical_decidable(...) = Decidable.yes(midIsUpper)` (or `no`)
-- in each branch. We then rewrite each branch's witness back into the
-- goal — the type ascription on the witness pins down a structural
-- occurrence of the decision constructor for the rewrite matcher,
-- and the kernel ι-reduces `bisectionStepWithDec` on it.
-- Step lemma: takes the classical decision as an explicit argument
-- so `cases` (not `decide`) does the case split. This sidesteps the
-- expensive decide-elaborator motive walker that would have to
-- δ-unfold `bisectionRight(... successor(n))` to find the buried
-- `classical_decidable(...)`; here the decision is a top-level
-- binder and `cases` matches it directly.
theorem Real.bisectionRight_is_upper_bound
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (initialRightAbove
            : Real.IsUpperBound(
                  subset,
                  (Real.BisectionInterval.right(initial) : Real)))
        (n : Natural)
        : Real.IsUpperBound(
              subset,
              (Real.bisectionRight(subset, initial, n) : Real)) :=
  by_induction on n with IH {
    case zero: initialRightAbove
    case successor(predecessor): {
        let intervals : Real.BisectionInterval :=
            Real.bisectionIntervals(subset, initial, predecessor);
        -- Decide whether the midpoint is an upper bound. Yes: the new
        -- right endpoint IS the midpoint, an upper bound by that decision.
        -- No: the right endpoint is unchanged, an upper bound by the IH.
        decide Real.IsUpperBound(
                   subset,
                   (Rational.halve(
                        Real.BisectionInterval.left(intervals)
                        + Real.BisectionInterval.right(intervals)) : Real)) {
          | yes midIsUpper => midIsUpper
          | no  _          => IH
        }
      }
  }

-- I3 (width): bₙ - aₙ = halve^n(b0 - a0). The width sequence is
-- defined recursively as repeated halving of the initial width.
definition Real.bisectionWidth
        (initial : Real.BisectionInterval) : Natural → Rational
  | zero =>
      Real.BisectionInterval.right(initial)
      - Real.BisectionInterval.left(initial)
  | successor(predecessor) =>
      Rational.halve(Real.bisectionWidth(initial, predecessor))

-- The width invariant: at every step, the difference between right and
-- left endpoints equals the recursive halving of (b0 - a0).
theorem Real.bisection_width_invariant
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (n : Natural)
        : Real.bisectionRight(subset, initial, n)
            - Real.bisectionLeft(subset, initial, n)
          = Real.bisectionWidth(initial, n) :=
  by_induction on n with IH {
    case zero: done
    case successor(predecessor): {
        let intervals : Real.BisectionInterval :=
            Real.bisectionIntervals(subset, initial, predecessor);
        -- Decide whether the midpoint is an upper bound. Either way the
        -- new width is half the old: the new interval is one half of the
        -- previous, and the IH equates the old width with
        -- bisectionWidth(initial, predecessor).
        decide Real.IsUpperBound(
                   subset,
                   (Rational.halve(
                        Real.BisectionInterval.left(intervals)
                        + Real.BisectionInterval.right(intervals)) : Real)) {
          | yes _ =>
              calc Rational.halve(
                       Real.BisectionInterval.left(intervals)
                       + Real.BisectionInterval.right(intervals))
                   - Real.BisectionInterval.left(intervals)
                 = Rational.halve(
                       Real.BisectionInterval.right(intervals)
                       - Real.BisectionInterval.left(intervals))
                 = Rational.halve(Real.bisectionWidth(initial, predecessor))
                       by IH
          | no _ =>
              calc Real.BisectionInterval.right(intervals)
                   - Rational.halve(
                         Real.BisectionInterval.left(intervals)
                         + Real.BisectionInterval.right(intervals))
                 = Rational.halve(
                       Real.BisectionInterval.right(intervals)
                       - Real.BisectionInterval.left(intervals))
                 = Rational.halve(Real.bisectionWidth(initial, predecessor))
                       by IH
        }
      }
  }

-- ----------------------------------------------------------------------
-- Limit preserves ≤: if every term of a Cauchy rational sequence is
-- (as Real) ≤ some Real B, then the limit mk(make(s, _)) is ≤ B.
--
-- This is the key "limit-side" lemma — both `bisectionLimit_is_least`
-- and (the symmetric form for) `bisectionLimit_is_upper_bound` reduce
-- to it after extracting the pointwise bound from `bisectionLeft`'s
-- below-witness or `bisectionRight`'s upper-bound invariant.
--
-- Proof at make (B = mk(make(b, _))): the goal reduces (via Real.add /
-- Real.negate / Real.IsNonneg Quotient.lift β-reductions plus
-- pattern-match ι on add/negate of make) to
--   Rational.sequence.IsEventuallyNonneg(λj. b(j) - s(j)).
-- At positive ε:
--   · Pick N_s from sIsCauchy at halve(ε): |s(m) - s(N_s)| < halve(ε)
--     for m ≥ N_s.
--   · Apply pointwiseLeq(N_s) at halve(ε). At constant-(s(N_s)) Real,
--     the diff sequence is (λj. b(j) - s(N_s)); pick N_b such that
--     b(j) - s(N_s) > -halve(ε) for j ≥ N_b.
--   · For j ≥ max(N_s, N_b): from |s(j) - s(N_s)| < halve(ε) extract
--     `s(N_s) - s(j) > -halve(ε)` (upper bound + LessThan.negate).
--     Sum with `b(j) - s(N_s) > -halve(ε)`:
--       (b(j) - s(N_s)) + (s(N_s) - s(j)) > -ε
--     LHS reduces (by Rational.add_subtract_cancel_left applied
--     symmetrically) to b(j) - s(j). Done.
theorem Real.LessOrEqual_of_pointwise_at_make
        (s : Natural → Rational)
        (sIsCauchy : Rational.sequence.IsCauchy(s))
        (b : Natural → Rational)
        (bIsCauchy : Rational.sequence.IsCauchy(b))
        (pointwiseLeq
            : ∀ (n : Natural).
                (s(n) : Real)
                  ≤ Real.from_cauchy_sequence(b, bIsCauchy))
        : Real.from_cauchy_sequence(s, sIsCauchy)
            ≤ Real.from_cauchy_sequence(b, bIsCauchy) :=
  unfold Real.IsNonneg in
  ((ε : Rational)
           (εPositive : (0 : Rational) < ε) ↦ {
    claim halvedPositive : (0 : Rational) < Rational.halve(ε);
    choose N_s as sCauchyAt
        from sIsCauchy(Rational.halve(ε), halvedPositive);
    choose N_b as bMinusSAt
        from pointwiseLeq(N_s)(Rational.halve(ε), halvedPositive);
    witness Natural.maximum(N_s, N_b) with
        (m : Natural)
                 (mGeMax : Natural.maximum(N_s, N_b) ≤ m) ↦ {
          claim m_geq_N_s : N_s ≤ m;
          claim m_geq_N_b : N_b ≤ m;
          claim N_s ≤ N_s;
          -- |s(m) - s(N_s)| < halve(ε)
          claim abs(s(m) - s(N_s)) < Rational.halve(ε)
            by sCauchyAt(m, m_geq_N_s, N_s, given(N_s ≤ N_s));
          claim (-Rational.halve(ε) < s(m) - s(N_s))
                  ∧ (s(m) - s(N_s) < Rational.halve(ε))
            by Rational.absolute_value_LessThan_bounds;
          claim s(m) - s(N_s) < Rational.halve(ε);
          -- Flip: -halve(ε) < s(N_s) - s(m). LessThan.negate gives
          -- -halve(ε) < -(s(m) - s(N_s)) = s(N_s) - s(m).
          calc -Rational.halve(ε)
                  < -(s(m) - s(N_s))   by Rational.LessThan.negate
                  = s(N_s) - s(m);
          -- bMinusSAt at m: -halve(ε) < b(m) - s(N_s)
          claim
                -Rational.halve(ε) < b(m) - s(N_s)
            by bMinusSAt(m, m_geq_N_b);
          -- Chain the two ε/2 bounds end-to-end and simplify:
          --   -ε = -halve(ε) + -halve(ε)
          --      < (b(m) - s(N_s)) + -halve(ε)            (bBound)
          --      ≤ (b(m) - s(N_s)) + (s(N_s) - s(m))      (sFlippedBound, weakened)
          --      = b(m) - s(m).
          claim -Rational.halve(ε) ≤ s(N_s) - s(m);
          calc -ε
             = -(Rational.halve(ε) + Rational.halve(ε))
                  by Rational.halve_doubled
             = -Rational.halve(ε) + -Rational.halve(ε)
             < (b(m) - s(N_s)) + -Rational.halve(ε)
                  by Rational.add_preserves_LessThan
             ≤ (b(m) - s(N_s)) + (s(N_s) - s(m))
                  by Rational.add_general_LessOrEqual_left
             = b(m) - s(m)
        }
  })

-- Lift to arbitrary Real B via Quotient.induct: case on B = mk(b_rep),
-- Take a representative B = [(b, bIsCauchy)]; the at-make form proves it.
theorem Real.LessOrEqual_of_pointwise
        (s : Natural → Rational)
        (sIsCauchy : Rational.sequence.IsCauchy(s))
        (B : Real)
        (pointwiseLeq : ∀ (n : Natural). (s(n) : Real) ≤ B)
        : Real.from_cauchy_sequence(s, sIsCauchy)
            ≤ B :=
  cases B refining pointwiseLeq {
    | CauchyRationalSequence.make(b, bIsCauchy) => {
        -- The goal β-reduces (through the quotient) to the eventually-nonneg
        -- form; state the `≤` the at-make lemma proves and let `done` cross
        -- the opaque `Real.IsNonneg` to close the reduced goal.
        claim Real.from_cauchy_sequence(s, sIsCauchy)
                ≤ Real.from_cauchy_sequence(b, bIsCauchy);
        done
      }
  }

-- Dual: at-make form, lower bound by the limit. If every term of a
-- Cauchy rational sequence is (as Real) ≥ some lower bound mk(make(b, _)),
-- then mk(make(b, _)) ≤ mk(make(s, _)). Same proof structure as the
-- upper-bound version with s and b swapped: pick N_s from s's Cauchy
-- modulus at ε/2 (giving `s(N_s) - s(j) < ε/2`), apply the pointwise
-- bound at N_s to extract `s(N_s) - b(j) > -ε/2`, sum to
-- `s(j) - b(j) > -ε`.
theorem Real.LessOrEqual_of_pointwise_lower_at_make
        (s : Natural → Rational)
        (sIsCauchy : Rational.sequence.IsCauchy(s))
        (b : Natural → Rational)
        (bIsCauchy : Rational.sequence.IsCauchy(b))
        (pointwiseGeq
            : ∀ (n : Natural).
                Real.from_cauchy_sequence(b, bIsCauchy)
                  ≤ (s(n) : Real))
        : Real.from_cauchy_sequence(b, bIsCauchy)
            ≤ Real.from_cauchy_sequence(s, sIsCauchy) :=
  unfold Real.IsNonneg in
  ((ε : Rational)
           (εPositive : (0 : Rational) < ε) ↦ {
    claim halvedPositive : (0 : Rational) < Rational.halve(ε);
    choose N_s as sCauchyAt
        from sIsCauchy(Rational.halve(ε), halvedPositive);
    -- pointwiseGeq(N_s) : mk(make(b, _)) ≤ (s(N_s) : Real)
    --   = Real.IsNonneg((s(N_s) : Real) - mk(make(b, _)))
    --   = IsEventuallyNonneg(λj. s(N_s) - b(j))
    choose N_b as sNsMinusBAt
        from pointwiseGeq(N_s)(Rational.halve(ε), halvedPositive);
    witness Natural.maximum(N_s, N_b) with
        (m : Natural)
                 (mGeMax : Natural.maximum(N_s, N_b) ≤ m) ↦ {
          claim m_geq_N_s : N_s ≤ m;
          claim m_geq_N_b : N_b ≤ m;
          claim N_s ≤ N_s;
          -- |s(m) - s(N_s)| < halve(ε)
          claim abs(s(m) - s(N_s)) < Rational.halve(ε)
            by sCauchyAt(m, m_geq_N_s, N_s, given(N_s ≤ N_s));
          -- Lower bound: -halve(ε) < s(m) - s(N_s)  (lower half of |·| bounds).
          claim (-Rational.halve(ε) < s(m) - s(N_s))
                  ∧ (s(m) - s(N_s) < Rational.halve(ε))
            by Rational.absolute_value_LessThan_bounds;
          claim -Rational.halve(ε) < s(m) - s(N_s);
          -- pointwiseGeq at m: -halve(ε) < s(N_s) - b(m).
          claim -Rational.halve(ε) < s(N_s) - b(m)
            by sNsMinusBAt(m, m_geq_N_b);
          -- Chain the two ε/2 bounds end-to-end and simplify:
          --   -ε = -halve(ε) + -halve(ε)
          --      < (s(m) - s(N_s)) + -halve(ε)            (sLowerBound)
          --      ≤ (s(m) - s(N_s)) + (s(N_s) - b(m))      (sBBound, weakened)
          --      = s(m) - b(m).
          claim -Rational.halve(ε) ≤ s(N_s) - b(m);
          calc -ε
             = -(Rational.halve(ε) + Rational.halve(ε))
                  by Rational.halve_doubled
             = -Rational.halve(ε) + -Rational.halve(ε)
             < (s(m) - s(N_s)) + -Rational.halve(ε)
                  by Rational.add_preserves_LessThan
             ≤ (s(m) - s(N_s)) + (s(N_s) - b(m))
                  by Rational.add_general_LessOrEqual_left
             = s(m) - b(m)
        }
  })

-- Take a representative B = [(b, bIsCauchy)]; the at-make form proves it.
theorem Real.LessOrEqual_of_pointwise_lower
        (s : Natural → Rational)
        (sIsCauchy : Rational.sequence.IsCauchy(s))
        (B : Real)
        (pointwiseGeq : ∀ (n : Natural). B ≤ (s(n) : Real))
        : B ≤ Real.from_cauchy_sequence(s, sIsCauchy) :=
  cases B refining pointwiseGeq {
    | CauchyRationalSequence.make(b, bIsCauchy) => {
        claim Real.from_cauchy_sequence(b, bIsCauchy)
                ≤ Real.from_cauchy_sequence(s, sIsCauchy);
        done
      }
  }

-- ----------------------------------------------------------------------
-- Within-interval invariant: left(n) ≤ right(n) at every step. Each
-- bisection step preserves this — the new interval is one half of
-- the previous, and the midpoint lies inside.

theorem Real.bisectionLeq_invariant
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (initialLeftLeqRight
            : Real.BisectionInterval.left(initial)
              ≤ Real.BisectionInterval.right(initial))
        (n : Natural)
        : Real.bisectionLeft(subset, initial, n)
          ≤ Real.bisectionRight(subset, initial, n) :=
  by_induction on n with IH {
    case zero: initialLeftLeqRight
    case successor(predecessor): {
        let intervals : Real.BisectionInterval :=
            Real.bisectionIntervals(subset, initial, predecessor);
        -- Decide whether the midpoint is an upper bound. Yes: the new
        -- interval is [left, midpoint] with left ≤ halve(left + right).
        -- No: the new interval is [midpoint, right] with
        -- halve(left + right) ≤ right. Both use the IH left ≤ right.
        decide Real.IsUpperBound(
                   subset,
                   (Rational.halve(
                        Real.BisectionInterval.left(intervals)
                        + Real.BisectionInterval.right(intervals)) : Real)) {
          | yes _ => done by Rational.halve_left_le_sum
          | no  _ => done by Rational.halve_sum_le_right
        }
      }
  }

-- ----------------------------------------------------------------------
-- Step-monotone: left endpoint goes up, right endpoint goes down.
-- Both depend on the within-interval invariant at the previous step.

theorem Real.bisectionLeft_step_monotone
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (initialLeftLeqRight
            : Real.BisectionInterval.left(initial)
              ≤ Real.BisectionInterval.right(initial))
        (n : Natural)
        : Real.bisectionLeft(subset, initial, n)
          ≤ Real.bisectionLeft(subset, initial, 1 + n) := {
    let intervals : Real.BisectionInterval :=
        Real.bisectionIntervals(subset, initial, n);
    -- The within-interval invariant: left(n) ≤ right(n), used by the
    -- no-branch to place the midpoint above left.
    claim Real.bisectionLeft(subset, initial, n)
            ≤ Real.bisectionRight(subset, initial, n);
    -- Decide whether the midpoint is an upper bound. Yes: left is
    -- unchanged. No: left advances to the midpoint, ≥ left since
    -- left ≤ right. Then bridge the stated index `1 + n` to
    -- `successor(n)` so `bisectionLeft` unfolds.
    claim
          Real.bisectionLeft(subset, initial, n)
            ≤ Real.bisectionLeft(subset, initial, successor(n))
      by decide Real.IsUpperBound(
                    subset,
                    (Rational.halve(
                         Real.BisectionInterval.left(intervals)
                         + Real.BisectionInterval.right(intervals)) : Real)) {
           | yes _ => done by Rational.LessOrEqual.reflexive
           | no  _ => done by Rational.halve_left_le_sum
         };
    done by substituting Natural.one_add
  }

theorem Real.bisectionRight_step_monotone
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (initialLeftLeqRight
            : Real.BisectionInterval.left(initial)
              ≤ Real.BisectionInterval.right(initial))
        (n : Natural)
        : Real.bisectionRight(subset, initial, 1 + n)
          ≤ Real.bisectionRight(subset, initial, n) := {
    let intervals : Real.BisectionInterval :=
        Real.bisectionIntervals(subset, initial, n);
    -- The within-interval invariant: left(n) ≤ right(n), used by the
    -- yes-branch to place the midpoint below right.
    claim Real.bisectionLeft(subset, initial, n)
            ≤ Real.bisectionRight(subset, initial, n);
    -- Decide whether the midpoint is an upper bound. Yes: right advances
    -- to the midpoint, ≤ right since left ≤ right. No: right is
    -- unchanged. Then bridge the stated index `1 + n` to `successor(n)`
    -- so `bisectionRight` unfolds.
    claim
          Real.bisectionRight(subset, initial, successor(n))
            ≤ Real.bisectionRight(subset, initial, n)
      by decide Real.IsUpperBound(
                    subset,
                    (Rational.halve(
                         Real.BisectionInterval.left(intervals)
                         + Real.BisectionInterval.right(intervals)) : Real)) {
           | yes _ => done by Rational.halve_sum_le_right
           | no  _ => done by Rational.LessOrEqual.reflexive
         };
    done by substituting Natural.one_add
  }

-- ----------------------------------------------------------------------
-- Multi-step monotone: iterate the step-monotone lemmas.

theorem Real.bisectionLeft_le_subsequent
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (initialLeftLeqRight
            : Real.BisectionInterval.left(initial)
              ≤ Real.BisectionInterval.right(initial))
        : ∀ (k n : Natural).
            Real.bisectionLeft(subset, initial, n)
            ≤ Real.bisectionLeft(subset, initial, k + n)
  | zero, n => done
  | successor(k), n => {
      claim
            Real.bisectionLeft(subset, initial, n)
              ≤ Real.bisectionLeft(subset, initial, k + n);
      claim Real.bisectionLeft(subset, initial, k + n)
              ≤ Real.bisectionLeft(subset, initial, 1 + (k + n));
      -- `successor(k) + n = 1 + (k + n)`: shift the successor across the sum.
      claim successor(k) + n = 1 + (k + n);
      calc Real.bisectionLeft(subset, initial, n)
         ≤ Real.bisectionLeft(subset, initial, k + n)
         ≤ Real.bisectionLeft(subset, initial, 1 + (k + n))
         = Real.bisectionLeft(subset, initial, successor(k) + n)
  }

theorem Real.bisectionRight_le_predecessor
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (initialLeftLeqRight
            : Real.BisectionInterval.left(initial)
              ≤ Real.BisectionInterval.right(initial))
        : ∀ (k n : Natural).
            Real.bisectionRight(subset, initial, k + n)
            ≤ Real.bisectionRight(subset, initial, n)
  | zero, n => done
  | successor(k), n => {
      claim
            Real.bisectionRight(subset, initial, k + n)
              ≤ Real.bisectionRight(subset, initial, n);
      claim Real.bisectionRight(subset, initial, 1 + (k + n))
              ≤ Real.bisectionRight(subset, initial, k + n);
      -- `successor(k) + n = 1 + (k + n)`: shift the successor across the sum.
      claim successor(k) + n = 1 + (k + n);
      calc Real.bisectionRight(subset, initial, successor(k) + n)
         = Real.bisectionRight(subset, initial, 1 + (k + n))
         ≤ Real.bisectionRight(subset, initial, k + n)
         ≤ Real.bisectionRight(subset, initial, n)
  }

-- Cross-bound: left(k + n) ≤ right(n). Combine left ≤ right at k+n
-- with right(k + n) ≤ right(n).
theorem Real.bisectionLeft_le_bisectionRight_predecessor
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (initialLeftLeqRight
            : Real.BisectionInterval.left(initial)
              ≤ Real.BisectionInterval.right(initial))
        (k n : Natural)
        : Real.bisectionLeft(subset, initial, k + n)
          ≤ Real.bisectionRight(subset, initial, n) :=
  calc Real.bisectionLeft(subset, initial, k + n)
     ≤ Real.bisectionRight(subset, initial, k + n)
     ≤ Real.bisectionRight(subset, initial, n)

-- ----------------------------------------------------------------------
-- Cauchy modulus for the bisection width.

-- halve(x) * y = x * halve(y). One-half is symmetric across the
-- multiplication: ring after unfolding halve to `* one_half`.
theorem Rational.halve_multiply_swap (x y : Rational)
        : Rational.halve(x) * y = x * Rational.halve(y) :=
  calc Rational.halve(x) * y
     = (x * Rational.one_half) * y
     = x * (y * Rational.one_half)
     = x * Rational.halve(y)

-- halve((1 + 1) + (n : Rational)) ≤ (1 + (n : Rational)). Used to
-- step the multiplicative bound.
theorem Rational.halve_two_plus_le_one_plus (n : Natural)
        : Rational.halve((1 : Rational) + (1 : Rational) + (n : Rational))
          ≤ (1 : Rational) + (n : Rational) := {
  -- 1 ≤ 1 + n because n ≥ 0:  1 = 1 + 0 ≤ 1 + n.
  claim Rational.IsNonneg((n : Rational));
  claim (0 : Rational) ≤ (n : Rational);
  -- 1 = 1 + 0 ≤ 1 + n, adding 1 on the left to 0 ≤ n.
  calc (1 : Rational) = (1 : Rational) + (0 : Rational)
                      ≤ (1 : Rational) + (n : Rational);
  -- 1 + 1 + n = 1 + (1 + n) ≤ (1 + n) + (1 + n), since 1 ≤ 1 + n.
  calc (1 : Rational) + (1 : Rational) + (n : Rational)
          = (1 : Rational) + ((1 : Rational) + (n : Rational))
          ≤ ((1 : Rational) + (n : Rational))
            + ((1 : Rational) + (n : Rational));
  -- halve is monotone, and halve of a doubled value folds back.
  calc Rational.halve((1 : Rational) + (1 : Rational) + (n : Rational))
     ≤ Rational.halve(((1 : Rational) + (n : Rational))
                       + ((1 : Rational) + (n : Rational)))
     = (1 : Rational) + (n : Rational)
}

-- width(n) ≥ 0 inductively from initial width ≥ 0 + halve preserves nonneg.
theorem Real.bisectionWidth_nonneg
        (initial : Real.BisectionInterval)
        (initialWidthNonneg
            : Rational.IsNonneg(
                  Real.BisectionInterval.right(initial)
                  - Real.BisectionInterval.left(initial)))
        : ∀ (n : Natural).
            Rational.IsNonneg(Real.bisectionWidth(initial, n))
  | zero => initialWidthNonneg
  | successor(predecessor) => {
      claim Rational.IsNonneg(Real.bisectionWidth(initial, predecessor));
      done
    }

-- For c ≥ 0, halve^n(c) * (successor(n) : Rational) ≤ c. Multiplicative
-- bound that turns into the Cauchy modulus via Archimedean.
theorem Real.bisectionWidth_times_succ_le_initial
        (initial : Real.BisectionInterval)
        (initialWidthNonneg
            : Rational.IsNonneg(
                  Real.BisectionInterval.right(initial)
                  - Real.BisectionInterval.left(initial)))
        : ∀ (n : Natural).
            Real.bisectionWidth(initial, n)
              * (successor(n) : Rational)
            ≤ Real.BisectionInterval.right(initial)
              - Real.BisectionInterval.left(initial)
  | zero =>
      -- width(0) reduces to (right - left); (succ 0 : R) reduces to 1.
      -- The product · 1 collapses to (right - left), then reflexive.
      calc Real.bisectionWidth(initial, zero)
              * (1 : Rational)
         = (Real.BisectionInterval.right(initial)
              - Real.BisectionInterval.left(initial))
              * (1 : Rational)
         = Real.BisectionInterval.right(initial)
              - Real.BisectionInterval.left(initial)
         ≤ Real.BisectionInterval.right(initial)
              - Real.BisectionInterval.left(initial)
  | successor(predecessor) => {
      claim Real.bisectionWidth(initial, predecessor)
                * (successor(predecessor) : Rational)
              ≤ Real.BisectionInterval.right(initial)
                - Real.BisectionInterval.left(initial);
      -- width(succ(predecessor)) = halve(width(predecessor)).
      -- (succ(succ(predecessor)) : R) = 1 + 1 + (predecessor : R) (kernel reduces).
      -- halve(width(predecessor)) * (1+1+pred) = width(predecessor) * halve(1+1+pred)
      --       [halve_multiply_swap]
      -- halve(1+1+pred) ≤ 1+pred                  [halve_two_plus_le_one_plus]
      -- width(predecessor) ≥ 0 (need this)
      -- So width(predecessor) * halve(1+1+pred) ≤ width(predecessor) * (1+pred) ≤ initial
      claim Rational.IsNonneg(Real.bisectionWidth(initial, predecessor));
      claim Rational.halve(Real.bisectionWidth(initial, predecessor))
                * (successor(successor(predecessor)) : Rational)
              = Real.bisectionWidth(initial, predecessor)
                * Rational.halve(
                      (successor(successor(predecessor)) : Rational));
      -- Bridge through the cast: halve((succ(succ(n)) : R)) ≤ (succ(n) : R)
      -- using halve_two_plus_le_one_plus on the expanded Rational form.
      calc Rational.halve(
                    (successor(successor(predecessor)) : Rational))
              = Rational.halve(
                    (1 : Rational) + (1 : Rational) + (predecessor : Rational))
              ≤ (1 : Rational) + (predecessor : Rational)
              = (successor(predecessor) : Rational);
      claim (0 : Rational) ≤ Real.bisectionWidth(initial, predecessor);
      claim Real.bisectionWidth(initial, predecessor)
                * Rational.halve(
                      (successor(successor(predecessor)) : Rational))
              ≤ Real.bisectionWidth(initial, predecessor)
                * (successor(predecessor) : Rational);
      calc Rational.halve(Real.bisectionWidth(initial, predecessor))
              * (successor(successor(predecessor)) : Rational)
         = Real.bisectionWidth(initial, predecessor)
              * Rational.halve(
                    (successor(successor(predecessor)) : Rational))
         ≤ Real.bisectionWidth(initial, predecessor)
              * (successor(predecessor) : Rational)
         ≤ Real.BisectionInterval.right(initial)
              - Real.BisectionInterval.left(initial)
  }

-- ----------------------------------------------------------------------
-- Natural helper: from `smaller ≤ larger`, extract the difference.
-- Induct on the proof: reflexivity gives k = 0, step prepends a
-- successor.

-- Multi-step monotone at ≤: lift bisectionLeft_le_subsequent and the
-- right/cross variants from "k + N" to "any m ≥ N" via le_to_add.

theorem Real.bisectionLeft_le_at_le
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (initialLeftLeqRight
            : Real.BisectionInterval.left(initial)
              ≤ Real.BisectionInterval.right(initial))
        (N m : Natural) (NLeqM : N ≤ m)
        : Real.bisectionLeft(subset, initial, N)
          ≤ Real.bisectionLeft(subset, initial, m) := {
  -- Write m as k + N (justified by N ≤ m), then the step-monotone
  -- lemma at k iterations closes the rewritten goal.
  claim ∃ (k : Natural). m = k + N   by Natural.le_to_add;
  choose k as mEq from given(∃ (k : Natural). m = k + N);
  claim Real.bisectionLeft(subset, initial, N)
        ≤ Real.bisectionLeft(subset, initial, k + N);
  claim by substitution
}

theorem Real.bisectionRight_le_at_le
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (initialLeftLeqRight
            : Real.BisectionInterval.left(initial)
              ≤ Real.BisectionInterval.right(initial))
        (N m : Natural) (NLeqM : N ≤ m)
        : Real.bisectionRight(subset, initial, m)
          ≤ Real.bisectionRight(subset, initial, N) := {
  claim ∃ (k : Natural). m = k + N   by Natural.le_to_add;
  choose k as mEq from given(∃ (k : Natural). m = k + N);
  claim Real.bisectionRight(subset, initial, k + N)
        ≤ Real.bisectionRight(subset, initial, N);
  claim by substitution
}

theorem Real.bisectionLeft_le_bisectionRight_at_le
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (initialLeftLeqRight
            : Real.BisectionInterval.left(initial)
              ≤ Real.BisectionInterval.right(initial))
        (N m : Natural) (NLeqM : N ≤ m)
        : Real.bisectionLeft(subset, initial, m)
          ≤ Real.bisectionRight(subset, initial, N) := {
  claim ∃ (k : Natural). m = k + N   by Natural.le_to_add;
  choose k as mEq from given(∃ (k : Natural). m = k + N);
  claim Real.bisectionLeft(subset, initial, k + N)
        ≤ Real.bisectionRight(subset, initial, N);
  claim by substitution
}

-- ----------------------------------------------------------------------
-- Cauchy modulus: ∀ ε > 0. ∃ N. bisectionWidth(initial, N) < ε.

theorem Real.exists_bisectionWidth_below
        (initial : Real.BisectionInterval)
        (initialWidthNonneg
            : Rational.IsNonneg(
                  Real.BisectionInterval.right(initial)
                  - Real.BisectionInterval.left(initial)))
        (ε : Rational)
        (εPositive : (0 : Rational) < ε)
        : ∃ (N : Natural).
              Real.bisectionWidth(initial, N) < ε := {
  claim ∃ (K : Natural).
            (Real.BisectionInterval.right(initial)
             - Real.BisectionInterval.left(initial))
            ≤ (successor(K) : Rational) * ε
    by Rational.archimedean_for_positives_successor;
  choose K as archBound from given(∃ (K : Natural).
            (Real.BisectionInterval.right(initial)
             - Real.BisectionInterval.left(initial))
            ≤ (successor(K) : Rational) * ε);
  claim
        Real.bisectionWidth(initial, successor(K))
            * (successor(successor(K)) : Rational)
          ≤ Real.BisectionInterval.right(initial)
            - Real.BisectionInterval.left(initial);
  claim (0 : Rational) < (successor(successor(K)) : Rational);
  -- succ(K) < succ(succ(K)) lifts (× positive ε) to a strict product bound:
  -- 0 < (succ(succ(K)) - succ(K))·ε, add succ(K)·ε to both sides.
  claim (0 : Rational) < (1 : Rational);
  calc (successor(K) : Rational)
     = (0 : Rational) + (successor(K) : Rational)
     < (1 : Rational) + (successor(K) : Rational)
          by Rational.add_preserves_LessThan
     = (successor(successor(K)) : Rational);
  calc (0 : Rational)
     = (successor(K) : Rational) - (successor(K) : Rational)
     < (successor(successor(K)) : Rational) - (successor(K) : Rational)
          by Rational.add_preserves_LessThan;
  claim (0 : Rational)
          < ((successor(successor(K)) : Rational)
             - (successor(K) : Rational)) * ε;
  calc (successor(K) : Rational) * ε
     = (0 : Rational) + (successor(K) : Rational) * ε
     < ((successor(successor(K)) : Rational)
        - (successor(K) : Rational)) * ε
       + (successor(K) : Rational) * ε
          by Rational.add_preserves_LessThan
     = (successor(successor(K)) : Rational) * ε;
  calc Real.bisectionWidth(initial, successor(K))
            * (successor(successor(K)) : Rational)
          ≤ (successor(K) : Rational) * ε
               by Rational.LessOrEqual.transitive
          < (successor(successor(K)) : Rational) * ε
          = ε * (successor(successor(K)) : Rational);
  witness successor(K) with
      done by Rational.LessThan.multiply_cancel_right_positive
}

-- ----------------------------------------------------------------------
-- Absolute-value bound from interval bounds: -c ≤ x ≤ c → |x| ≤ c.

theorem Rational.absolute_value_LessOrEqual_of_bounds
        (x c : Rational)
        (lowerBound : -c ≤ x) (upperBound : x ≤ c)
        : abs(x) ≤ c :=
  claim by cases {
    in (Rational.IsNonneg(x)) as xNonneg:
        calc abs(x)
           = x
           ≤ c
    in (Rational.IsNonneg(-x)) as negXNonneg:
        calc abs(x)
           = -x
           ≤ -(-c)
           = c
  }

-- ----------------------------------------------------------------------
-- |a_m - a_n| ≤ width(N) when both indices exceed N. Both a_m and a_n
-- live in [a_N, b_N] by monotone containment; their difference lies in
-- [-(b_N - a_N), b_N - a_N] = [-width(N), width(N)].

theorem Real.bisectionLeft_diff_bound
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (initialLeftLeqRight
            : Real.BisectionInterval.left(initial)
              ≤ Real.BisectionInterval.right(initial))
        (N m n : Natural) (NLeqM : N ≤ m) (NLeqN : N ≤ n)
        : abs(
              Real.bisectionLeft(subset, initial, m)
              - Real.bisectionLeft(subset, initial, n))
          ≤ Real.bisectionWidth(initial, N) := {
  claim Real.bisectionWidth(initial, N)
        = Real.bisectionRight(subset, initial, N)
          - Real.bisectionLeft(subset, initial, N);
  claim Real.bisectionLeft(subset, initial, N)
          ≤ Real.bisectionLeft(subset, initial, m);
  claim Real.bisectionLeft(subset, initial, N)
          ≤ Real.bisectionLeft(subset, initial, n);
  claim Real.bisectionLeft(subset, initial, m)
          ≤ Real.bisectionRight(subset, initial, N);
  claim Real.bisectionLeft(subset, initial, n)
          ≤ Real.bisectionRight(subset, initial, N);
  -- left(m) - left(n) ≤ right(N) - left(N) = width(N).
  claim -Real.bisectionLeft(subset, initial, n)
          ≤ -Real.bisectionLeft(subset, initial, N);
  claim
        Real.bisectionLeft(subset, initial, m)
          - Real.bisectionLeft(subset, initial, n)
          ≤ Real.bisectionRight(subset, initial, N)
            - Real.bisectionLeft(subset, initial, N)
    by Rational.LessOrEqual.sum;
  -- left(n) - left(m) ≤ right(N) - left(N). Negate: left(m) - left(n) ≥ -(width).
  claim -Real.bisectionLeft(subset, initial, m)
          ≤ -Real.bisectionLeft(subset, initial, N);
  claim
        Real.bisectionLeft(subset, initial, n)
          - Real.bisectionLeft(subset, initial, m)
          ≤ Real.bisectionRight(subset, initial, N)
            - Real.bisectionLeft(subset, initial, N)
    by Rational.LessOrEqual.sum;
  calc -(Real.bisectionRight(subset, initial, N)
              - Real.bisectionLeft(subset, initial, N))
          ≤ -(Real.bisectionLeft(subset, initial, n)
              - Real.bisectionLeft(subset, initial, m))
          = Real.bisectionLeft(subset, initial, m)
              - Real.bisectionLeft(subset, initial, n);
  calc abs(
           Real.bisectionLeft(subset, initial, m)
           - Real.bisectionLeft(subset, initial, n))
     ≤ Real.bisectionRight(subset, initial, N)
       - Real.bisectionLeft(subset, initial, N)
     = Real.bisectionWidth(initial, N)
}

-- I4: the lower-bound sequence is Cauchy at the rational level.
-- Combine the |a_m - a_n| ≤ width(N) bound + the Cauchy modulus.
theorem Real.bisectionLeft_is_cauchy
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (initialLeftLeqRight
            : Real.BisectionInterval.left(initial)
              ≤ Real.BisectionInterval.right(initial))
        : Rational.sequence.IsCauchy(
              Real.bisectionLeft(subset, initial)) :=
  (ε : Rational)
           (εPositive : (0 : Rational) < ε) ↦ {
    claim ∃ (N : Natural). Real.bisectionWidth(initial, N) < ε;
    choose N as widthBelowε
        from given(∃ (N : Natural). Real.bisectionWidth(initial, N) < ε);
    witness N with
        (m : Natural) (NLeqM : N ≤ m)
                 (n : Natural) (NLeqN : N ≤ n) ↦
          calc abs(Real.bisectionLeft(subset, initial, m)
                    - Real.bisectionLeft(subset, initial, n))
             ≤ Real.bisectionWidth(initial, N)
             < ε
  }

-- ----------------------------------------------------------------------
-- The Real-level ≤ on rational embeddings reflects to the Rational
-- level. (a : Real) ≤ (b : Real) reduces (by the standard Quotient.lift
-- β chain on Real.subtract/Real.IsNonneg/sequenceFunction at the constant
-- representatives) to the eventually-nonneg statement on the constant
-- sequence λn. b - a — i.e., ∀ε > 0. -ε < b - a. From this we conclude
-- Rational.IsNonneg(b - a) = a ≤ b by case-on-linearity: if b < a
-- strictly, apply at ε = a - b > 0 and the conclusion `-(a - b) < b - a`
-- is `b - a < b - a`, contradicting irreflexivity.

theorem Rational.LessOrEqual_of_real_LessOrEqual
        (a b : Rational)
        (realLeq : (a : Real) ≤ (b : Real))
        : a ≤ b :=
  claim by cases {
    in (a ≤ b) as aLeqB: done
    in (b ≤ a) as bLeqA:
      decide a = b {
        | yes aEqB =>
            calc a ≤ a
                   = b
        | no aNotEqB => {
            -- b ≤ a AND a ≠ b: derive 0 < a - b for the contradiction.
            claim Rational.LessOrEqual((0 : Rational), a - b);
            claim ¬((0 : Rational) = a - b)
              by (zeroEqDiff : (0 : Rational) = a - b) ↦
                   aNotEqB(
                       calc a
                          = b + (a - b)
                          = b + (0 : Rational)
                          = b);
            claim diffPositive : (0 : Rational) < a - b;
            -- realLeq at ε = a - b yields the contradiction.
            choose N as bound
                from (unfold Real.IsNonneg in realLeq)(a - b, diffPositive);
            claim N ≤ N;
            claim -(a - b) < b - a by bound(N, given(N ≤ N));
            claim b - a < b - a by substituting (ring : -(a - b) = b - a);
            claim selfNotSelf : b - a ≠ b - a;
            absurd(selfNotSelf(done))
          }
      }
  }

-- The bisection limit. Once the lower-bound sequence is Cauchy, its
-- Real-level limit is well-defined: package the Cauchy proof and
-- take the Quotient.class_of.
definition Real.bisectionLimit
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (initialLeftLeqRight
            : Real.BisectionInterval.left(initial)
              ≤ Real.BisectionInterval.right(initial))
        : Real :=
  Real.from_cauchy_sequence(Real.bisectionLeft(subset, initial),
          Real.bisectionLeft_is_cauchy(
              subset, initial, initialLeftLeqRight))

-- The limit is an upper bound for S. At every n, `bisectionRight(n)`
-- bounds S from above; the limit `lim aₙ = lim bₙ` is therefore also
-- an upper bound. Sub-lemma still to prove: limit-of-Cauchy-sequence
-- is upper bound when each term is.
-- At-rep form: for a Cauchy rep y_rep with mk(y_rep) ∈ subset,
-- show mk(y_rep) ≤ bisectionLimit. Pattern-match at the rep
-- exposes (yseq, yIsCauchy) so the at-rep reduces to the
-- IsEventuallyNonneg(λn. bisectionLeft(n) - yseq(n)) form via the
-- standard Quotient.lift β chain. Pick K with width(K) < ε/2
-- (modulus); the pointwise upper bound y ≤ bisectionRight(K) gives
-- bisectionRight(K) - yseq(j) > -ε/2 for j ≥ M; combine with
-- bisectionLeft(j) ≥ bisectionLeft(K) = bisectionRight(K) - width(K)
-- > bisectionRight(K) - ε/2 to get bisectionLeft(j) - yseq(j) > -ε.
-- At-rep form: pattern-match y_rep to expose (yseq, yIsCauchy).
theorem Real.bisectionLimit_is_upper_bound_at_rep
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (initialLeftLeqRight
            : Real.BisectionInterval.left(initial)
              ≤ Real.BisectionInterval.right(initial))
        (initialRightAbove
            : Real.IsUpperBound(
                  subset,
                  (Real.BisectionInterval.right(initial) : Real)))
        : ∀ (y_rep : CauchyRationalSequence).
            (Quotient.class_of(y_rep) : Real) ∈ subset
          → (Quotient.class_of(y_rep) : Real)
              ≤ Real.bisectionLimit(
                    subset, initial, initialLeftLeqRight)
  | CauchyRationalSequence.make(yseq, yIsCauchy), yInSubset =>
  unfold Real.IsNonneg in
  ((ε : Rational)
           (εPositive : (0 : Rational) < ε) ↦ {
    claim halvedPositive : (0 : Rational) < Rational.halve(ε);
    claim ∃ (N : Natural).
              Real.bisectionWidth(initial, N) < Rational.halve(ε);
    choose K as widthBelow from given(∃ (N : Natural).
              Real.bisectionWidth(initial, N) < Rational.halve(ε));
    claim Real.IsUpperBound(
              subset, (Real.bisectionRight(subset, initial, K) : Real));
    claim yLeqRightK
          : Real.from_cauchy_sequence(yseq, yIsCauchy)
            ≤ (Real.bisectionRight(subset, initial, K) : Real);
    choose M as pointwiseAt
        from yLeqRightK(Rational.halve(ε), halvedPositive);
    witness Natural.maximum(K, M) with
        (j : Natural)
                 (jGeMax : Natural.maximum(K, M) ≤ j) ↦ {
          claim K ≤ j;
          claim j_geq_M : M ≤ j;
          claim
                Real.bisectionLeft(subset, initial, K)
                  ≤ Real.bisectionLeft(subset, initial, j);
          claim -Rational.halve(ε) < -Real.bisectionWidth(initial, K)
            by Rational.LessThan.negate;
          claim
                -Rational.halve(ε)
                  < Real.bisectionRight(subset, initial, K) - yseq(j)
            by pointwiseAt(j, j_geq_M);
          -- Algebraic bridge: (right(K) - yseq(j)) + -width(K)
          --                    = bisectionLeft(K) - yseq(j),
          -- using width(K) = right(K) - left(K) (the width invariant).
          -- Anonymous: the calc below finds it by type-match.
          calc (Real.bisectionRight(subset, initial, K) - yseq(j))
               + -Real.bisectionWidth(initial, K)
             = (Real.bisectionRight(subset, initial, K)
                - Real.bisectionWidth(initial, K))
               - yseq(j)
             = (Real.bisectionRight(subset, initial, K)
                - (Real.bisectionRight(subset, initial, K)
                   - Real.bisectionLeft(subset, initial, K)))
               - yseq(j)
             = Real.bisectionLeft(subset, initial, K) - yseq(j);
          -- Chain the two ε/2 bounds end-to-end, bridge by widthBridge,
          -- then weaken K → j on the left endpoint.
          claim -Rational.halve(ε) ≤ -Real.bisectionWidth(initial, K);
          calc -ε
             = -(Rational.halve(ε) + Rational.halve(ε))
                  by Rational.halve_doubled
             = -Rational.halve(ε) + -Rational.halve(ε)
             < (Real.bisectionRight(subset, initial, K) - yseq(j))
                 + -Rational.halve(ε)
                  by Rational.add_preserves_LessThan
             ≤ (Real.bisectionRight(subset, initial, K) - yseq(j))
                 + -Real.bisectionWidth(initial, K)
                  by Rational.add_general_LessOrEqual_left
             = Real.bisectionLeft(subset, initial, K) - yseq(j)
             ≤ Real.bisectionLeft(subset, initial, j) - yseq(j)
        }
  })

-- Take a representative y = [(rep, _)]; the at-rep lemma proves it.
theorem Real.bisectionLimit_is_upper_bound
        (subset : Set(Real)) (initial : Real.BisectionInterval)
        (initialLeftLeqRight
            : Real.BisectionInterval.left(initial)
              ≤ Real.BisectionInterval.right(initial))
        (initialRightAbove
            : Real.IsUpperBound(
                  subset,
                  (Real.BisectionInterval.right(initial) : Real)))
        : Real.IsUpperBound(
              subset,
              Real.bisectionLimit(subset, initial, initialLeftLeqRight)) :=
  (y : Real) (yInSubset : y ∈ subset) ↦
    cases y refining yInSubset { | rep =>
      done by Real.bisectionLimit_is_upper_bound_at_rep }

-- The limit is the LEAST upper bound: every other upper bound `B`
-- satisfies `limit ≤ B`. Pointwise: `bisectionLeft(n) ≤ y_n ≤ otherBound`
-- via bisectionLeft_below_witness + otherIsUpper applied at the witness.
-- Then LessOrEqual_of_pointwise lifts the pointwise bound to the limit.
theorem Real.bisectionLimit_is_least
        (subset : Set(Real))
        (initial : Real.BisectionInterval)
        (initialLeftLeqRight
            : Real.BisectionInterval.left(initial)
              ≤ Real.BisectionInterval.right(initial))
        (initialLeftBelowSome
            : ∃ (y : Real).
                  y ∈ subset ∧ (Real.BisectionInterval.left(initial) : Real) ≤ y)
        (otherBound : Real)
        (otherIsUpper : Real.IsUpperBound(subset, otherBound))
        : Real.bisectionLimit(subset, initial, initialLeftLeqRight)
          ≤ otherBound := {
  -- Every lower endpoint is below some element of S, which otherBound
  -- caps: bisectionLeft(n) ≤ y ≤ otherBound. So the limit of the lower
  -- endpoints is ≤ otherBound.
  claim ∀ (n : Natural).
            (Real.bisectionLeft(subset, initial, n) : Real) ≤ otherBound
      by (n : Natural) ↦ {
        claim ∃ (y : Real).
                  y ∈ subset ∧ (Real.bisectionLeft(subset, initial, n) : Real) ≤ y;
        choose witnessY such that
                 witnessY ∈ subset
                 ∧ (Real.bisectionLeft(subset, initial, n) : Real) ≤ witnessY
            as yInSAndAnLeqY
            from given(∃ (y : Real).
                  y ∈ subset ∧ (Real.bisectionLeft(subset, initial, n) : Real) ≤ y);
        claim witnessY ∈ subset;
        claim (Real.bisectionLeft(subset, initial, n) : Real) ≤ witnessY;
        claim witnessY ≤ otherBound;
        calc (Real.bisectionLeft(subset, initial, n) : Real)
           ≤ witnessY
           ≤ otherBound
      };
  done
}

-- ----------------------------------------------------------------------
-- Headline theorem.

theorem Real.supremum_exists
        (subset : Set(Real))
        (nonempty : Set.IsNonempty(Real, subset))
        (bounded : Real.IsBoundedAbove(subset))
        : ∃ (s : Real). Real.IsSupremum(subset, s) := {
  choose x0 as x0InS from nonempty;
  choose B0real as B0IsUpper from bounded;
  claim ∃ (q : Rational). (q : Real) ≤ x0;
  choose a0 as a0LeqX0 from given(∃ (q : Rational). (q : Real) ≤ x0);
  claim ∃ (q : Rational). B0real ≤ (q : Real);
  choose b0 as B0LeqB0 from given(∃ (q : Rational). B0real ≤ (q : Real));
  let initial : Real.BisectionInterval :=
      Real.BisectionInterval.make(a0, b0);
  -- b0 is an upper bound for S: for any y ∈ S, y ≤ B0real ≤ (b0 : Real).
  claim Real.IsUpperBound(subset, (b0 : Real))
    by (y : Real) (yInS : y ∈ subset) ↦
         calc y
            ≤ B0real
            ≤ (b0 : Real);
  -- Package x0 + a0LeqX0 + x0InS as the existential witness needed
  -- by bisectionLeft_below_witness / bisectionLimit_is_least.
  claim ∃ (y : Real).
            y ∈ subset ∧ (Real.BisectionInterval.left(initial) : Real) ≤ y
    by {
      witness x0 with done
    };
  -- a0 ≤ b0 as Rationals follows from (a0 : Real) ≤ x0 ≤ B0 ≤ (b0 : Real).
  -- This is needed for bisectionLeft_is_cauchy and friends.
  calc (a0 : Real)
          ≤ x0
          ≤ B0real
          ≤ (b0 : Real);
  claim initialLeftLeqRight
        : Real.BisectionInterval.left(initial)
          ≤ Real.BisectionInterval.right(initial);
  let supValue : Real :=
      Real.bisectionLimit(subset, initial, initialLeftLeqRight);
  witness supValue with {
    claim Real.IsUpperBound(subset, supValue);
    claim ∀ (otherBound : Real).
              Real.IsUpperBound(subset, otherBound) → supValue ≤ otherBound
        by (otherBound : Real)
                 (otherIsUpper : Real.IsUpperBound(subset, otherBound)) ↦
             done by Real.bisectionLimit_is_least;
    done
  }
}

-- ----------------------------------------------------------------------
-- Approximation from below: anything strictly below the supremum is
-- exceeded by some element of the set. (Otherwise that smaller value
-- would itself be an upper bound, contradicting leastness.) This is
-- the lemma every "the supremum is attained up to ε" argument — IVT,
-- monotone convergence on sets — actually consumes.
theorem Real.IsSupremum.exists_above
        (subset : Set(Real)) (s u : Real)
        (isSupremum : Real.IsSupremum(subset, s))
        (uBelowSupremum : u < s)
        : ∃ (x : Real). x ∈ subset ∧ u < x :=
  decide ∃ (x : Real). x ∈ subset ∧ u < x {
    | yes someAbove => someAbove
    | no noneAbove => {
        -- Every element fails to exceed u, so u is an upper bound …
        claim Real.IsUpperBound(subset, u)
            by (y : Real) (yInSubset : y ∈ subset) ↦ {
              claim ¬(u < y)
                  by (uBelowY : u < y) ↦ {
                       claim ∃ (x : Real). x ∈ subset ∧ u < x
                           by { witness y with done };
                       noneAbove(given(∃ (x : Real). x ∈ subset ∧ u < x))
                     };
              done by Real.LessOrEqual_of_not_LessThan
            };
        -- … so leastness pins s ≤ u, against u < s.
        claim ∀ (otherBound : Real).
                  Real.IsUpperBound(subset, otherBound) → s ≤ otherBound;
        claim s ≤ u;
        claim u < u by Real.LessThan.transitive_right;
        claim False;
        done
      }
  }

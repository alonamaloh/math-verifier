-- Real/finite_products.math
--
-- Finite products Π_{k<n} s(k), mirroring the partial-sum toolkit:
-- nonnegativity, splitting at a cut, and pulling out a constant
-- factor (which exits as its n-th power).

module Real.finite_products

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Integer.basics
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.archimedean
import Set.basics
import Algebra.ring_lemmas
import Algebra.aggregation
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.instances
import Real.order
import Real.linearity
import Real.embedding_order
import Real.order_multiplication
import Real.absolute_value
import Real.absolute_value_order
import Real.convergence
import Real.supremum
import Real.limits
import Real.series
import Real.power

-- Finite products Π_{k<n} s(k) — the multiplicative instance of the
-- generic aggregation, over Real's multiplicative commutative monoid.
definition Real.partialProduct (s : Natural → Real) (n : Natural) : Real :=
  Algebra.indexedAggregate(Real, Real.multiply, Real.one, s, n)

-- The recursion unfold: one more factor is the (n)-th term.
theorem Real.partialProduct_add_one (s : Natural → Real) (n : Natural)
        : Real.partialProduct(s, 1 + n) = Real.partialProduct(s, n) * s(n) :=
  done by Algebra.indexedAggregate_add_one

-- Products of nonnegative terms are nonnegative.
theorem Real.partialProduct_nonneg (s : Natural → Real) (n : Natural)
        (termsNonneg : ∀ (j : Natural). Real.zero ≤ s(j))
        : Real.zero ≤ Real.partialProduct(s, n) :=
  by_induction on n with IH {
    case zero: {
        Rational.zero < Rational.one;
        Real.zero < Rational.one;
        Real.zero ≤ (Rational.one : Real);
        done
      }
    case successor(predecessor): {
        Real.zero ≤ s(predecessor);
        Real.IsNonneg(Real.partialProduct(s, predecessor));
        Real.IsNonneg(s(predecessor));
        Real.IsNonneg(
                  Real.partialProduct(s, predecessor) * s(predecessor));
        Real.zero
                ≤ Real.partialProduct(s, predecessor) * s(predecessor);
        Real.partialProduct(s, 1 + predecessor)
                = Real.partialProduct(s, predecessor) * s(predecessor)
            by Real.partialProduct_add_one;
        done by substituting Natural.one_add
      }
  }

-- Splitting a product at a cut.
theorem Real.partialProduct_split (s : Natural → Real) (n k : Natural)
        : Real.partialProduct(s, k + n)
          = Real.partialProduct(s, n)
            * Real.partialProduct((j : Natural) ↦ s(n + j), k) :=
  Algebra.indexedAggregate_split(associativity := Real.multiply_associative,
      identityRight := Real.multiply_one)

-- A constant factor exits as its n-th power.
theorem Real.partialProduct_scale (c : Real) (s : Natural → Real) (n : Natural)
        : Real.partialProduct((k : Natural) ↦ c * s(k), n)
          = Real.power(c, n) * Real.partialProduct(s, n) :=
  by_induction on n with IH {
    case zero:
        calc Real.partialProduct((k : Natural) ↦ c * s(k), 0)
           = Real.power(c, 0) * Real.partialProduct(s, 0)
    case successor(predecessor): {
        Real.partialProduct((k : Natural) ↦ c * s(k), 1 + predecessor)
           = Real.partialProduct((k : Natural) ↦ c * s(k), predecessor)
             * (c * s(predecessor))
                 by Real.partialProduct_add_one
           = (Real.power(c, predecessor) * Real.partialProduct(s, predecessor))
             * (c * s(predecessor))
                 by IH
           = (c * Real.power(c, predecessor))
             * (Real.partialProduct(s, predecessor) * s(predecessor))
                 by ring
           = Real.power(c, 1 + predecessor)
             * (Real.partialProduct(s, predecessor) * s(predecessor))
                 by substituting Real.power_add_one
           = Real.power(c, 1 + predecessor) * Real.partialProduct(s, 1 + predecessor)
                 by substituting Real.partialProduct_add_one;
        done by substituting Natural.one_add
      }
  }

-- Products only see the terms' values.
theorem Real.partialProduct_pointwise
        (s sequencePrime : Natural → Real)
        (pointwiseEqual : ∀ (k : Natural). s(k) = sequencePrime(k))
        (n : Natural)
        : Real.partialProduct(s, n) = Real.partialProduct(sequencePrime, n) :=
  Algebra.indexedAggregate_pointwise(pointwiseEqual := pointwiseEqual)

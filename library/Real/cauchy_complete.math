-- Real/cauchy_complete.math
--
-- Cauchy completeness of ℝ: every Cauchy sequence of reals converges.
-- The limit is the supremum of the sequence's "eventual lower bounds" —
-- the reals that some tail of the sequence never goes below. A Cauchy
-- tail at tolerance q traps that supremum within q of the tail's first
-- term, which traps the whole tail within 2q of the supremum.
--
-- This is the convergence criterion that needs no monotonicity, and
-- the gateway to series with sign-changing terms (exp at negative
-- arguments, alternating series).

module Real.cauchy_complete

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.order
import Natural.maximum
import Rational.basics
import Rational.addition
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.halve
import Rational.positive
import Set.basics
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.order
import Real.linearity
import Real.absolute_value
import Real.absolute_value_order
import Real.embedding_order
import Real.convergence
import Real.supremum

-- ----------------------------------------------------------------------
-- A Cauchy sequence of reals: past some index, any two terms are
-- within ε of each other — for every positive rational ε.
definition Real.SequenceIsCauchy (s : Natural → Real) : Proposition :=
  (epsilon : Rational) → Rational.zero < epsilon →
    ∃ (N : Natural).
      (m n : Natural) → N ≤ m → N ≤ n →
        abs(s(m) - s(n)) < (epsilon : Real)

-- The eventual lower bounds of a sequence: the reals that some tail
-- of the sequence stays at or above.
definition Real.eventual_lower_bounds (s : Natural → Real) : Set(Real) :=
  (t : Real) ↦ ∃ (N : Natural). (m : Natural) → N ≤ m → t ≤ s(m)

-- ----------------------------------------------------------------------
-- A Cauchy tail at tolerance q pins the eventual lower bounds around
-- its first term: s(N) − q is one of them, and s(N) + q is above all
-- of them.

theorem Real.cauchy_tail_gives_lower_bound
        (s : Natural → Real) (N : Natural) (q : Rational)
        (tailClose : (m n : Natural) → N ≤ m → N ≤ n
                     → abs(s(m) - s(n)) < (q : Real))
        : (s(N) - (q : Real)) ∈ Real.eventual_lower_bounds(s) :=
  witness N with
      (m : Natural) (mInTail : N ≤ m) ↦ {
        claim N ≤ N;
        claim close : abs(s(m) - s(N)) < (q : Real)
            by tailClose(m, N, mInTail, (N ≤ N));
        obtain ⟨closeLower, _⟩
            from Real.absolute_value_LessThan_bounds(
                     s(m) - s(N), (q : Real), close);
        claim s(N) - (q : Real) < s(m)
            by calc s(N) - (q : Real)
                  = -(q : Real) + s(N)
                  < (s(m) - s(N)) + s(N)       by Real.add_preserves_LessThan
                  = s(m)                       by ring;
        done since Real.LessThan.weaken
      }

theorem Real.cauchy_tail_gives_upper_bound
        (s : Natural → Real) (N : Natural) (q : Rational)
        (tailClose : (m n : Natural) → N ≤ m → N ≤ n
                     → abs(s(m) - s(n)) < (q : Real))
        : Real.IsUpperBound(Real.eventual_lower_bounds(s),
                            s(N) + (q : Real)) :=
  (t : Real) (tEventual : t ∈ Real.eventual_lower_bounds(s)) ↦ {
    obtain ⟨tailStart, tailLow⟩ from tEventual;
    -- Probe past both tails at once.
    claim tailStart ≤ Natural.maximum(tailStart, N)
        since Natural.left_le_max;
    claim N ≤ Natural.maximum(tailStart, N)
        since Natural.right_le_max;
    claim N ≤ N;
    claim tBelowTerm : t ≤ s(Natural.maximum(tailStart, N))
        by tailLow(Natural.maximum(tailStart, N),
                   (tailStart ≤ Natural.maximum(tailStart, N)));
    claim close : abs(s(Natural.maximum(tailStart, N)) - s(N)) < (q : Real)
        by tailClose(Natural.maximum(tailStart, N), N,
                     (N ≤ Natural.maximum(tailStart, N)), (N ≤ N));
    obtain ⟨_, closeUpper⟩
        from Real.absolute_value_LessThan_bounds(
                 s(Natural.maximum(tailStart, N)) - s(N), (q : Real), close);
    claim termBelow : s(Natural.maximum(tailStart, N)) < s(N) + (q : Real)
        by calc s(Natural.maximum(tailStart, N))
              = (s(Natural.maximum(tailStart, N)) - s(N)) + s(N)   by ring
              < (q : Real) + s(N)        by Real.add_preserves_LessThan
              = s(N) + (q : Real)        by ring;
    calc t
       ≤ s(Natural.maximum(tailStart, N))    by tBelowTerm
       < s(N) + (q : Real)                   by termBelow;
    done since Real.LessThan.weaken
  }

-- ----------------------------------------------------------------------
-- The headline: Cauchy sequences of reals converge.
theorem Real.cauchy_sequence_converges (s : Natural → Real)
        (cauchy : Real.SequenceIsCauchy(s))
        : Real.SequenceConvergent(s) := {
  -- The eventual lower bounds are nonempty (one unit below any Cauchy
  -- tail) and bounded above (one unit above it), so they have a
  -- supremum.
  obtain ⟨unitIndex, unitClose⟩
      from cauchy(Rational.one, Rational.zero_less_one);
  claim nonempty : Set.IsNonempty(Real, Real.eventual_lower_bounds(s))
      by ⟨s(unitIndex) - (Rational.one : Real),
          Real.cauchy_tail_gives_lower_bound(
              s, unitIndex, Rational.one, unitClose)⟩;
  claim boundedAbove : Real.IsBoundedAbove(Real.eventual_lower_bounds(s))
      by ⟨s(unitIndex) + (Rational.one : Real),
          Real.cauchy_tail_gives_upper_bound(
              s, unitIndex, Rational.one, unitClose)⟩;
  obtain ⟨limit, isSupremum⟩
      from Real.supremum_exists(Real.eventual_lower_bounds(s),
                                nonempty, boundedAbove);
  let ⟨isUpper, isLeast⟩ := isSupremum;
  witness limit with
      (epsilon : Rational)
      (epsilonPositive : Rational.zero < epsilon) ↦ {
        claim Rational.zero < Rational.halve(epsilon)
            since Rational.halve_positive;
        claim quarterPositive
              : Rational.zero < Rational.halve(Rational.halve(epsilon))
            since Rational.halve_positive;
        obtain ⟨N, tailClose⟩
            from cauchy(Rational.halve(Rational.halve(epsilon)),
                        quarterPositive);
        -- The supremum is trapped within a quarter-ε of s(N).
        claim s(N) - (Rational.halve(Rational.halve(epsilon)) : Real)
                ≤ limit
            by isUpper(
                   s(N) - (Rational.halve(Rational.halve(epsilon)) : Real),
                   Real.cauchy_tail_gives_lower_bound(
                       s, N, Rational.halve(Rational.halve(epsilon)),
                       tailClose));
        claim limit
                ≤ s(N) + (Rational.halve(Rational.halve(epsilon)) : Real)
            by isLeast(
                   s(N) + (Rational.halve(Rational.halve(epsilon)) : Real),
                   Real.cauchy_tail_gives_upper_bound(
                       s, N, Rational.halve(Rational.halve(epsilon)),
                       tailClose));
        claim Rational.halve(epsilon) < epsilon
            since Rational.halve_less_than_self;
        claim halveBelowEpsilon
              : (Rational.halve(epsilon) : Real) < (epsilon : Real)
            since Rational.to_real.LessThan_preserves;
        witness N with
            (m : Natural) (mInTail : N ≤ m) ↦ {
              claim N ≤ N;
              claim close
                    : abs(s(m) - s(N))
                      < (Rational.halve(Rational.halve(epsilon)) : Real)
                  by tailClose(m, N, mInTail, (N ≤ N));
              obtain ⟨closeLower, closeUpper⟩
                  from Real.absolute_value_LessThan_bounds(
                           s(m) - s(N),
                           (Rational.halve(Rational.halve(epsilon)) : Real),
                           close);
              -- Both gaps to the limit stay below 2·(ε/4) < ε.
              claim -limit
                      ≤ -(s(N) - (Rational.halve(Rational.halve(epsilon))
                                  : Real))
                  since Real.LessOrEqual.negate;
              claim s(m) - limit < (epsilon : Real)
                  by calc s(m) - limit
                        ≤ s(m) - (s(N)
                                  - (Rational.halve(Rational.halve(epsilon))
                                     : Real))
                              since Real.add_preserves_LessOrEqual_left
                        = (s(m) - s(N))
                          + (Rational.halve(Rational.halve(epsilon)) : Real)
                              by ring
                        < (Rational.halve(Rational.halve(epsilon)) : Real)
                          + (Rational.halve(Rational.halve(epsilon)) : Real)
                              by Real.add_preserves_LessThan
                        = ((Rational.halve(Rational.halve(epsilon))
                            + Rational.halve(Rational.halve(epsilon))
                            : Rational) : Real)
                              since Rational.to_real.add_preserves
                        = (Rational.halve(epsilon) : Real)
                              by Rational.halve_doubled(Rational.halve(epsilon))
                        < (epsilon : Real)
                              by halveBelowEpsilon;
              claim s(N) - (Rational.halve(Rational.halve(epsilon)) : Real)
                      < s(m)
                  by calc s(N) - (Rational.halve(Rational.halve(epsilon))
                                  : Real)
                        = -(Rational.halve(Rational.halve(epsilon)) : Real)
                          + s(N)
                              by ring
                        < (s(m) - s(N)) + s(N)
                              by Real.add_preserves_LessThan
                        = s(m)
                              by ring;
              claim -s(m)
                      < -(s(N) - (Rational.halve(Rational.halve(epsilon))
                                  : Real))
                  since Real.negate_flip_LessThan;
              claim limit - s(m) < (epsilon : Real)
                  by calc limit - s(m)
                        ≤ (s(N) + (Rational.halve(Rational.halve(epsilon))
                                   : Real)) - s(m)
                              by Real.add_preserves_LessOrEqual
                        < (s(N) + (Rational.halve(Rational.halve(epsilon))
                                   : Real))
                          - (s(N) - (Rational.halve(Rational.halve(epsilon))
                                     : Real))
                              since Real.add_left_preserves_LessThan
                        = (Rational.halve(Rational.halve(epsilon)) : Real)
                          + (Rational.halve(Rational.halve(epsilon)) : Real)
                              by ring
                        = ((Rational.halve(Rational.halve(epsilon))
                            + Rational.halve(Rational.halve(epsilon))
                            : Rational) : Real)
                              since Rational.to_real.add_preserves
                        = (Rational.halve(epsilon) : Real)
                              by Rational.halve_doubled(Rational.halve(epsilon))
                        < (epsilon : Real)
                              by halveBelowEpsilon;
              claim -(epsilon : Real) < -(limit - s(m))
                  since Real.negate_flip_LessThan;
              claim -(epsilon : Real) < s(m) - limit
                  by calc -(epsilon : Real)
                        < -(limit - s(m))    by (-(epsilon : Real)
                                                 < -(limit - s(m)))
                        = s(m) - limit       by ring;
              done since Real.absolute_value_LessThan_of_bounds
            }
      }
}

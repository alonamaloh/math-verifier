-- Real/cauchy_complete.math
--
-- Cauchy completeness of ℝ: every Cauchy sequence of reals converges.
-- The limit is the supremum of the sequence's "eventual lower bounds" —
-- the reals that some tail of the sequence never goes below. A Cauchy
-- tail at tolerance q traps that supremum within q of the tail's first
-- term, which traps the whole tail within 2q of the supremum.
--
-- This is the convergence criterion that needs no monotonicity, and
-- the gateway to series with sign-changing terms (exp at negative
-- arguments, alternating series).

module Real.cauchy_complete

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.order
import Natural.maximum
import Natural.compare
import Rational.basics
import Rational.addition
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.halve
import Rational.positive
import Set.basics
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.order
import Real.linearity
import Real.absolute_value
import Real.absolute_value_order
import Real.embedding_order
import Real.convergence
import Real.supremum
import Real.series

-- ----------------------------------------------------------------------
-- A Cauchy sequence of reals: past some index, any two terms are
-- within ε of each other — for every positive real ε. (ε is a real
-- number, as in convergence; the at_rational bridge below mediates the
-- rational tolerances the supremum machinery still speaks.)
definition Real.SequenceIsCauchy (s : Natural → Real) : Proposition :=
  ∀ (ε : Real). ε > 0 →
    ∃ (N : Natural).
      ∀ (m n : Natural). N ≤ m → N ≤ n →
        abs(s(m) - s(n)) < ε

-- The Cauchy criterion holds at every positive RATIONAL tolerance too:
-- instantiate the Real-ε definition at the embedded rational.
theorem Real.SequenceIsCauchy.at_rational (s : Natural → Real)
        (cauchy : Real.SequenceIsCauchy(s))
        : ∀ (ε : Rational). Rational.zero < ε →
            ∃ (N : Natural).
              ∀ (m n : Natural). N ≤ m → N ≤ n →
                abs(s(m) - s(n)) < (ε : Real) :=
  (ε : Rational) (εPositive : Rational.zero < ε) ↦ {
    claim (ε : Real) > 0 by Rational.to_real.positive_preserves;
    done by cauchy((ε : Real))
  }

-- The eventual lower bounds of a sequence: the reals that some tail
-- of the sequence stays at or above.
definition Real.eventual_lower_bounds (s : Natural → Real) : Set(Real) :=
  (t : Real) ↦ ∃ (N : Natural). ∀ (m : Natural). N ≤ m → t ≤ s(m)

-- ----------------------------------------------------------------------
-- A Cauchy tail at tolerance q pins the eventual lower bounds around
-- its first term: s(N) − q is one of them, and s(N) + q is above all
-- of them.

theorem Real.cauchy_tail_gives_lower_bound
        (s : Natural → Real) (N : Natural) (q : Rational)
        (tailClose : ∀ (m n : Natural). N ≤ m → N ≤ n
                     → abs(s(m) - s(n)) < q)
        : (s(N) - q) ∈ Real.eventual_lower_bounds(s) :=
  witness N with
      (m : Natural) (mInTail : N ≤ m) ↦ {
        claim N ≤ N;
        claim close : abs(s(m) - s(N)) < q
            by tailClose(m, N, mInTail, (N ≤ N));
        obtain ⟨closeLower, _⟩
            from Real.absolute_value_LessThan_bounds(
                     s(m) - s(N), (q : Real), close);
        claim s(N) - q < s(m)
            by calc s(N) - q
                  = -q + s(N)
                  < (s(m) - s(N)) + s(N)       by Real.add_preserves_LessThan
                  = s(m)                       by ring;
        done by Real.LessThan.weaken
      }

theorem Real.cauchy_tail_gives_upper_bound
        (s : Natural → Real) (N : Natural) (q : Rational)
        (tailClose : ∀ (m n : Natural). N ≤ m → N ≤ n
                     → abs(s(m) - s(n)) < q)
        : Real.IsUpperBound(Real.eventual_lower_bounds(s),
                            s(N) + q) :=
  (t : Real) (tEventual : t ∈ Real.eventual_lower_bounds(s)) ↦ {
    obtain ⟨tailStart, tailLow⟩ from tEventual;
    -- Probe past both tails at once.
    claim tailStart ≤ Natural.maximum(tailStart, N)
        by Natural.left_le_max;
    claim N ≤ Natural.maximum(tailStart, N)
        by Natural.right_le_max;
    claim N ≤ N;
    claim tBelowTerm : t ≤ s(Natural.maximum(tailStart, N))
        by tailLow(Natural.maximum(tailStart, N),
                   (tailStart ≤ Natural.maximum(tailStart, N)));
    claim close : abs(s(Natural.maximum(tailStart, N)) - s(N)) < q
        by tailClose(Natural.maximum(tailStart, N), N,
                     (N ≤ Natural.maximum(tailStart, N)), (N ≤ N));
    obtain ⟨_, closeUpper⟩
        from Real.absolute_value_LessThan_bounds(
                 s(Natural.maximum(tailStart, N)) - s(N), (q : Real), close);
    claim termBelow : s(Natural.maximum(tailStart, N)) < s(N) + q
        by calc s(Natural.maximum(tailStart, N))
              = (s(Natural.maximum(tailStart, N)) - s(N)) + s(N)   by ring
              < q + s(N)        by Real.add_preserves_LessThan
              = s(N) + q        by ring;
    calc t
       ≤ s(Natural.maximum(tailStart, N))    by tBelowTerm
       < s(N) + q                   by termBelow;
    done by Real.LessThan.weaken
  }

-- ----------------------------------------------------------------------
-- The headline: Cauchy sequences of reals converge.
theorem Real.cauchy_sequence_converges (s : Natural → Real)
        (cauchy : Real.SequenceIsCauchy(s))
        : Real.SequenceConvergent(s) := {
  -- The eventual lower bounds are nonempty (one unit below any Cauchy
  -- tail) and bounded above (one unit above it), so they have a
  -- supremum.
  choose unitIndex as unitClose
      from Real.SequenceIsCauchy.at_rational(s, cauchy)(
               Rational.one, Rational.zero_less_one);
  claim nonempty : Set.IsNonempty(Real, Real.eventual_lower_bounds(s))
      by ⟨s(unitIndex) - (Rational.one : Real),
          Real.cauchy_tail_gives_lower_bound(
              s, unitIndex, Rational.one, unitClose)⟩;
  claim boundedAbove : Real.IsBoundedAbove(Real.eventual_lower_bounds(s))
      by ⟨s(unitIndex) + (Rational.one : Real),
          Real.cauchy_tail_gives_upper_bound(
              s, unitIndex, Rational.one, unitClose)⟩;
  obtain ⟨limit, isSupremum⟩
      from Real.supremum_exists(Real.eventual_lower_bounds(s),
                                nonempty, boundedAbove);
  let ⟨isUpper, isLeast⟩ := isSupremum;
  witness limit with
      -- Convergence is established at a rational ε (the Cauchy criterion and
      -- supremum trapping both work with rational tolerances), lifted by density.
      Real.SequenceConverges.of_rational(s, limit,
      (ε : Rational)
      (εPositive : Rational.zero < ε) ↦ {
        claim Rational.zero < Rational.halve(ε)
            by Rational.halve_positive;
        claim quarterPositive
              : Rational.zero < Rational.halve(Rational.halve(ε))
            by Rational.halve_positive;
        choose N as tailClose
            from Real.SequenceIsCauchy.at_rational(s, cauchy)(
                     Rational.halve(Rational.halve(ε)),
                     quarterPositive);
        -- The supremum is trapped within a quarter-ε of s(N).
        claim s(N) - (Rational.halve(Rational.halve(ε)) : Real)
                ≤ limit
            by isUpper(
                   s(N) - (Rational.halve(Rational.halve(ε)) : Real),
                   Real.cauchy_tail_gives_lower_bound(
                       s, N, Rational.halve(Rational.halve(ε)),
                       tailClose));
        claim limit
                ≤ s(N) + (Rational.halve(Rational.halve(ε)) : Real)
            by isLeast(
                   s(N) + (Rational.halve(Rational.halve(ε)) : Real),
                   Real.cauchy_tail_gives_upper_bound(
                       s, N, Rational.halve(Rational.halve(ε)),
                       tailClose));
        claim Rational.halve(ε) < ε
            by Rational.halve_less_than_self;
        claim halveBelowε
              : (Rational.halve(ε) : Real) < (ε : Real)
            by Rational.to_real.LessThan_preserves;
        witness N with
            (m : Natural) (mInTail : N ≤ m) ↦ {
              claim N ≤ N;
              claim close
                    : abs(s(m) - s(N))
                      < (Rational.halve(Rational.halve(ε)) : Real)
                  by tailClose(m, N, mInTail, (N ≤ N));
              obtain ⟨closeLower, closeUpper⟩
                  from Real.absolute_value_LessThan_bounds(
                           s(m) - s(N),
                           (Rational.halve(Rational.halve(ε)) : Real),
                           close);
              -- Both gaps to the limit stay below 2·(ε/4) < ε.
              claim -limit
                      ≤ -(s(N) - (Rational.halve(Rational.halve(ε))
                                  : Real))
                  by Real.LessOrEqual.negate;
              claim s(m) - limit < (ε : Real)
                  by calc s(m) - limit
                        ≤ s(m) - (s(N)
                                  - (Rational.halve(Rational.halve(ε))
                                     : Real))
                              by Real.add_preserves_LessOrEqual_left
                        = (s(m) - s(N))
                          + (Rational.halve(Rational.halve(ε)) : Real)
                              by ring
                        < (Rational.halve(Rational.halve(ε)) : Real)
                          + (Rational.halve(Rational.halve(ε)) : Real)
                              by Real.add_preserves_LessThan
                        = ((Rational.halve(Rational.halve(ε))
                            + Rational.halve(Rational.halve(ε))
                            : Rational) : Real)
                              by Rational.to_real.add_preserves
                        = (Rational.halve(ε) : Real)
                              by Rational.halve_doubled(Rational.halve(ε))
                        < (ε : Real)
                              by halveBelowε;
              claim s(N) - (Rational.halve(Rational.halve(ε)) : Real)
                      < s(m)
                  by calc s(N) - (Rational.halve(Rational.halve(ε))
                                  : Real)
                        = -(Rational.halve(Rational.halve(ε)) : Real)
                          + s(N)
                              by ring
                        < (s(m) - s(N)) + s(N)
                              by Real.add_preserves_LessThan
                        = s(m)
                              by ring;
              claim -s(m)
                      < -(s(N) - (Rational.halve(Rational.halve(ε))
                                  : Real))
                  by Real.LessThan.negate;
              claim limit - s(m) < (ε : Real)
                  by calc limit - s(m)
                        ≤ (s(N) + (Rational.halve(Rational.halve(ε))
                                   : Real)) - s(m)
                              by Real.add_preserves_LessOrEqual
                        < (s(N) + (Rational.halve(Rational.halve(ε))
                                   : Real))
                          - (s(N) - (Rational.halve(Rational.halve(ε))
                                     : Real))
                              by Real.add_left_preserves_LessThan
                        = (Rational.halve(Rational.halve(ε)) : Real)
                          + (Rational.halve(Rational.halve(ε)) : Real)
                              by ring
                        = ((Rational.halve(Rational.halve(ε))
                            + Rational.halve(Rational.halve(ε))
                            : Rational) : Real)
                              by Rational.to_real.add_preserves
                        = (Rational.halve(ε) : Real)
                              by Rational.halve_doubled(Rational.halve(ε))
                        < (ε : Real)
                              by halveBelowε;
              claim -(ε : Real) < -(limit - s(m))
                  by Real.LessThan.negate;
              claim -(ε : Real) < s(m) - limit
                  by calc -(ε : Real)
                        < -(limit - s(m))    by (-(ε : Real)
                                                 < -(limit - s(m)))
                        = s(m) - limit       by ring;
              done by Real.absolute_value_LessThan_of_bounds
            }
      })
}

-- ----------------------------------------------------------------------
-- Convergent sequences are Cauchy: both tails sit within ε/2 of the
-- limit, so within ε of each other.
theorem Real.converges_implies_cauchy (s : Natural → Real)
        (convergent : Real.SequenceConvergent(s))
        : Real.SequenceIsCauchy(s) := {
  choose limit such that Real.SequenceConverges(s, limit) as converges
      from convergent;
  take ε : Real;
  take εPositive : ε > 0;
  claim (2 : Real) > 0 by Real.two_positive;
  claim (2 : Real) ≠ 0 by Real.two_is_nonzero;
  claim halfPositive : ε / 2 > 0 by Real.divide_positive;
  choose N as tailClose from converges(ε / 2, halfPositive);
  witness N with
      (m n : Natural) (mInTail : N ≤ m) (nInTail : N ≤ n) ↦ {
        claim abs(s(m) - limit) < ε / 2 by tailClose(m, mInTail);
        claim abs(s(n) - limit) < ε / 2 by tailClose(n, nInTail);
        calc abs(s(m) - s(n))
           = abs((s(m) - limit) + (limit - s(n)))
                 by ((s(m) - limit) + (limit - s(n)) = s(m) - s(n))
           ≤ abs(s(m) - limit) + abs(limit - s(n))
                 by Real.triangle_inequality
           = abs(s(m) - limit) + abs(s(n) - limit)
                 by Real.absolute_value_subtract_swap
           < ε / 2 + ε / 2
                 by Real.LessThan.add_strict_strict
           = ε
                 by Real.divide_two_doubled
      }
}

-- ----------------------------------------------------------------------
-- The comparison test, Cauchy form: if |t(k)| ≤ b(k) termwise and the
-- partial sums of b are Cauchy, so are the partial sums of t — any
-- window of t-terms is absolutely below the matching window of b.
theorem Real.series_dominated_cauchy (t b : Natural → Real)
        (domination : ∀ (k : Natural). abs(t(k)) ≤ b(k))
        (boundCauchy : Real.SequenceIsCauchy(Real.partialSum(b)))
        : Real.SequenceIsCauchy(Real.partialSum(t)) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    choose N as tailClose from boundCauchy(ε, εPositive);
    -- The ordered case: the gap from index i up to index j ≥ i.
    claim oneSided
          : ∀ (i j : Natural). N ≤ i → N ≤ j → i ≤ j
            → abs(Real.partialSum(t, j) - Real.partialSum(t, i))
              < ε
        by {
          take i : Natural; take j : Natural;
          take iInTail : N ≤ i; take jInTail : N ≤ j;
          take iLeqJ : i ≤ j;
          obtain ⟨c, splitEquation⟩
              from Natural.subtraction_witness(i, j, iLeqJ);
          claim jAsSum : j = c + i
              by calc j
                    = i + c    by splitEquation
                    = c + i    by ring;
          claim splitT
                : Real.partialSum(t, j)
                  = Real.partialSum(t, i)
                    + Real.partialSum((k : Natural) ↦ t(i + k), c)
              by calc Real.partialSum(t, j)
                    = Real.partialSum(t, c + i)    by jAsSum
                    = Real.partialSum(t, i)
                      + Real.partialSum((k : Natural) ↦ t(i + k), c)
                          by Real.partialSum_split(t, i, c);
          claim splitB
                : Real.partialSum(b, j)
                  = Real.partialSum(b, i)
                    + Real.partialSum((k : Natural) ↦ b(i + k), c)
              by calc Real.partialSum(b, j)
                    = Real.partialSum(b, c + i)    by jAsSum
                    = Real.partialSum(b, i)
                      + Real.partialSum((k : Natural) ↦ b(i + k), c)
                          by Real.partialSum_split(b, i, c);
          claim tWindowValue
                : Real.partialSum(t, j) - Real.partialSum(t, i)
                  = Real.partialSum((k : Natural) ↦ t(i + k), c)
              by calc Real.partialSum(t, j) - Real.partialSum(t, i)
                    = (Real.partialSum(t, i)
                       + Real.partialSum((k : Natural) ↦ t(i + k), c))
                      - Real.partialSum(t, i)
                          by splitT
                    = Real.partialSum((k : Natural) ↦ t(i + k), c)
                          by ring;
          claim bWindowValue
                : Real.partialSum((k : Natural) ↦ b(i + k), c)
                  = Real.partialSum(b, j) - Real.partialSum(b, i)
              by calc Real.partialSum((k : Natural) ↦ b(i + k), c)
                    = (Real.partialSum(b, i)
                       + Real.partialSum((k : Natural) ↦ b(i + k), c))
                      - Real.partialSum(b, i)
                          by ring
                    = Real.partialSum(b, j) - Real.partialSum(b, i)
                          by splitB;
          claim tWindowBound
                : abs(Real.partialSum((k : Natural) ↦ t(i + k), c))
                  ≤ Real.partialSum((k : Natural) ↦ b(i + k), c)
              by calc abs(Real.partialSum((k : Natural) ↦ t(i + k), c))
                    ≤ Real.partialSum((k : Natural) ↦ abs(t(i + k)), c)
                          by Real.abs_partialSum_le((k : Natural) ↦ t(i + k), c)
                    ≤ Real.partialSum((k : Natural) ↦ b(i + k), c)
                          by Real.partialSum_le_pointwise(
                                 (k : Natural) ↦ abs(t(i + k)),
                                 (k : Natural) ↦ b(i + k), c,
                                 (k : Natural) (_ : k < c) ↦
                                   domination(i + k));
          claim bWindowBelow
                : Real.partialSum(b, j) - Real.partialSum(b, i)
                  < ε
              by calc Real.partialSum(b, j) - Real.partialSum(b, i)
                    ≤ abs(Real.partialSum(b, j) - Real.partialSum(b, i))
                          by Real.LessOrEqual_absolute_value
                    < ε
                          by tailClose(j, i, jInTail, iInTail);
          calc abs(Real.partialSum(t, j) - Real.partialSum(t, i))
             = abs(Real.partialSum((k : Natural) ↦ t(i + k), c))
                   by tWindowValue
             ≤ Real.partialSum((k : Natural) ↦ b(i + k), c)
                   by tWindowBound
             = Real.partialSum(b, j) - Real.partialSum(b, i)
                   by bWindowValue
             < ε
                   by bWindowBelow
        };
    witness N with
        (m n : Natural) (mInTail : N ≤ m) (nInTail : N ≤ n) ↦
          cases Natural.compare_strict(m, n) {
            | Natural.StrictComparison.below(mStrictlyBelowN) => {
                claim m ≤ n;
                claim abs(Real.partialSum(t, n) - Real.partialSum(t, m))
                        < ε
                    by oneSided(m, n, mInTail, nInTail, (m ≤ n));
                claim swapped
                      : abs(Real.partialSum(t, m) - Real.partialSum(t, n))
                        = abs(Real.partialSum(t, n) - Real.partialSum(t, m))
                    by Real.absolute_value_subtract_swap;
                calc abs(Real.partialSum(t, m) - Real.partialSum(t, n))
                   = abs(Real.partialSum(t, n) - Real.partialSum(t, m))
                         by swapped
                   < ε
              }
            | Natural.StrictComparison.atLeast(nLeqM) =>
                oneSided(n, m, nInTail, mInTail, nLeqM)
          }
  }

-- The comparison test: a series termwise dominated by a convergent
-- series converges.
theorem Real.series_dominated_converges (t b : Natural → Real)
        (domination : ∀ (k : Natural). abs(t(k)) ≤ b(k))
        (boundConvergent : Real.SequenceConvergent(Real.partialSum(b)))
        : Real.SequenceConvergent(Real.partialSum(t)) := {
  claim Real.SequenceIsCauchy(Real.partialSum(b))
      by Real.converges_implies_cauchy;
  claim Real.SequenceIsCauchy(Real.partialSum(t))
      by Real.series_dominated_cauchy;
  done by Real.cauchy_sequence_converges
}

-- Real/exponential_addition.math
--
-- Toward exp(x + y) = exp(x) · exp(y): the binomial theorem splits the
-- k-th term of the exponential series at x + y into the k-th diagonal
-- of the Cauchy product of the series at x and at y,
--   (x+y)ᵏ/k! = Σ_{i ≤ k} (xⁱ/i!) · (yᵏ⁻ⁱ/(k−i)!),
-- because C(k, i)/k! = 1/(i!·(k−i)!).

module Real.exponential_addition

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics

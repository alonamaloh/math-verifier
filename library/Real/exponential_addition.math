-- ----------------------------------------------------------------------
-- The coefficient identity at ℚ: 1/(i+d)! · C(i+d, i) = 1/i! · 1/d!.
-- The cast of `Natural.binomial_factorial` clears all denominators.
theorem Rational.binomial_reciprocal_split (i d : Natural)
        : Rational.reciprocal_function((Natural.factorial(i + d) : Rational))
              * (Natural.binomial(i + d, i) : Rational)
          = Rational.reciprocal_function((Natural.factorial(i) : Rational))
            * Rational.reciprocal_function((Natural.factorial(d) : Rational)) := {
  -- The closed form, cast into ℚ.
  claim castSplit
      : (Natural.binomial(i + d, i) : Rational)
            * ((Natural.factorial(i) : Rational) * (Natural.factorial(d) : Rational))
        = (Natural.factorial(i + d) : Rational)
      by calc (Natural.binomial(i + d, i) : Rational)
                  * ((Natural.factorial(i) : Rational) * (Natural.factorial(d) : Rational))
            = (Natural.binomial(i + d, i) : Rational)
                  * ((Natural.factorial(i) * Natural.factorial(d) : Natural) : Rational)
                  by Rational.from_natural_multiply_preserves(
                         Natural.factorial(i), Natural.factorial(d))
            = ((Natural.binomial(i + d, i)
                    * (Natural.factorial(i) * Natural.factorial(d)) : Natural) : Rational)
                  by Rational.from_natural_multiply_preserves(
                         Natural.binomial(i + d, i),
                         Natural.factorial(i) * Natural.factorial(d))
            = ((Natural.factorial(i + d) : Natural) : Rational)
                  by Natural.binomial_factorial(i, d);
  -- All three factorial casts are positive, hence nonzero.
  claim Rational.zero < (Natural.factorial(i) : Rational)
      since Rational.factorial_cast_positive;
  claim ¬(Rational.zero = (Natural.factorial(i) : Rational))
      since Rational.LessThan.distinct;
  claim ¬((Natural.factorial(i) : Rational) = Rational.zero);
  claim Rational.zero < (Natural.factorial(d) : Rational)
      since Rational.factorial_cast_positive;
  claim ¬(Rational.zero = (Natural.factorial(d) : Rational))
      since Rational.LessThan.distinct;
  claim ¬((Natural.factorial(d) : Rational) = Rational.zero);
  claim Rational.zero < (Natural.factorial(i + d) : Rational)
      since Rational.factorial_cast_positive;
  claim ¬(Rational.zero = (Natural.factorial(i + d) : Rational))
      since Rational.LessThan.distinct;
  claim ¬((Natural.factorial(i + d) : Rational) = Rational.zero);
  claim Rational.zero
        < (Natural.factorial(i) : Rational) * (Natural.factorial(d) : Rational)
      since Rational.multiply_positive_positive;
  claim ¬(Rational.zero
              = (Natural.factorial(i) : Rational) * (Natural.factorial(d) : Rational))
      since Rational.LessThan.distinct;
  claim ¬((Natural.factorial(i) : Rational) * (Natural.factorial(d) : Rational)
              = Rational.zero);
  -- The cancellations.
  claim productCancel
      : ((Natural.factorial(i) : Rational) * (Natural.factorial(d) : Rational))
            * Rational.reciprocal_function(
                  (Natural.factorial(i) : Rational) * (Natural.factorial(d) : Rational))
        = Rational.one
      since Rational.reciprocal_function_multiplies;
  claim wholeCancel
      : (Natural.factorial(i + d) : Rational)
            * Rational.reciprocal_function((Natural.factorial(i + d) : Rational))
        = Rational.one
      since Rational.reciprocal_function_multiplies;
  claim recipProduct
      : Rational.reciprocal_function((Natural.factorial(i) : Rational))
            * Rational.reciprocal_function((Natural.factorial(d) : Rational))
        = Rational.reciprocal_function(
              (Natural.factorial(i) : Rational) * (Natural.factorial(d) : Rational))
      since Rational.reciprocal_function_product;
  -- Multiply by 1 = (i!·d!)·(1/(i!·d!)), absorb the closed form, cancel.
  calc Rational.reciprocal_function((Natural.factorial(i + d) : Rational))
           * (Natural.binomial(i + d, i) : Rational)
     = Rational.reciprocal_function((Natural.factorial(i + d) : Rational))
           * ((Natural.binomial(i + d, i) : Rational) * Rational.one)
     = Rational.reciprocal_function((Natural.factorial(i + d) : Rational))
           * ((Natural.binomial(i + d, i) : Rational)
                  * (((Natural.factorial(i) : Rational) * (Natural.factorial(d) : Rational))
                         * Rational.reciprocal_function(
                               (Natural.factorial(i) : Rational)
                                   * (Natural.factorial(d) : Rational))))
           since productCancel
     = Rational.reciprocal_function((Natural.factorial(i + d) : Rational))
           * (((Natural.binomial(i + d, i) : Rational)
                   * ((Natural.factorial(i) : Rational) * (Natural.factorial(d) : Rational)))
                  * Rational.reciprocal_function(
                        (Natural.factorial(i) : Rational)
                            * (Natural.factorial(d) : Rational)))
     = Rational.reciprocal_function((Natural.factorial(i + d) : Rational))
           * ((Natural.factorial(i + d) : Rational)
                  * Rational.reciprocal_function(
                        (Natural.factorial(i) : Rational)
                            * (Natural.factorial(d) : Rational)))
           since castSplit
     = ((Natural.factorial(i + d) : Rational)
            * Rational.reciprocal_function((Natural.factorial(i + d) : Rational)))
           * Rational.reciprocal_function(
                 (Natural.factorial(i) : Rational) * (Natural.factorial(d) : Rational))
     = Rational.one
           * Rational.reciprocal_function(
                 (Natural.factorial(i) : Rational) * (Natural.factorial(d) : Rational))
           since wholeCancel
     = Rational.reciprocal_function(
           (Natural.factorial(i) : Rational) * (Natural.factorial(d) : Rational))
     = Rational.reciprocal_function((Natural.factorial(i) : Rational))
           * Rational.reciprocal_function((Natural.factorial(d) : Rational))
           since recipProduct
}

-- ----------------------------------------------------------------------
-- The k-th exponential term at x + y is the k-th Cauchy-product
-- diagonal of the two series.
theorem Real.exponentialTerm_binomial_split (x y : Real) (k : Natural)
        : Real.exponentialTerm(x + y, k)
          = Real.partialSum(
                (i : Natural) ↦
                    Real.exponentialTerm(x, i)
                    * Real.exponentialTerm(y, Natural.monus(k, i)),
                1 + k) := {
  -- Each summand below the cut: fold the coefficient into the two
  -- reciprocal factorials.
  claim termSplit
      : (i : Natural) → successor(i) ≤ 1 + k
        → (Rational.reciprocal_function((Natural.factorial(k) : Rational)) : Real)
              * (((Natural.binomial(k, i) : Rational) : Real)
                     * (Real.power(x, i) * Real.power(y, Natural.monus(k, i))))
          = Real.exponentialTerm(x, i)
            * Real.exponentialTerm(y, Natural.monus(k, i))
      by (i : Natural) (iBelow : successor(i) ≤ 1 + k) ↦ {
           claim i ≤ k since Natural.successor_le_cancel;
           obtain ⟨d, kSplit⟩ from Natural.subtraction_witness(i, k, (i ≤ k));
           claim kJoin : i + d = k;
           claim monusCollapse : Natural.monus(k, i) = d
               by {
                 claim Natural.monus(i + d, i) = d since Natural.monus_add_left;
                 done by substituting kJoin
               };
           claim coefficientSplit
               : Rational.reciprocal_function((Natural.factorial(k) : Rational))
                     * (Natural.binomial(k, i) : Rational)
                 = Rational.reciprocal_function((Natural.factorial(i) : Rational))
                   * Rational.reciprocal_function((Natural.factorial(d) : Rational))
               by calc Rational.reciprocal_function((Natural.factorial(k) : Rational))
                           * (Natural.binomial(k, i) : Rational)
                     = Rational.reciprocal_function((Natural.factorial(i + d) : Rational))
                           * (Natural.binomial(i + d, i) : Rational)
                           by kJoin
                     = Rational.reciprocal_function((Natural.factorial(i) : Rational))
                           * Rational.reciprocal_function((Natural.factorial(d) : Rational))
                           by Rational.binomial_reciprocal_split(i, d);
           calc (Rational.reciprocal_function((Natural.factorial(k) : Rational)) : Real)
                    * (((Natural.binomial(k, i) : Rational) : Real)
                           * (Real.power(x, i) * Real.power(y, Natural.monus(k, i))))
              = (Rational.reciprocal_function((Natural.factorial(k) : Rational)) : Real)
                    * (((Natural.binomial(k, i) : Rational) : Real)
                           * (Real.power(x, i) * Real.power(y, d)))
                    since monusCollapse
              = ((Rational.reciprocal_function((Natural.factorial(k) : Rational))
                      * (Natural.binomial(k, i) : Rational) : Rational) : Real)
                    * (Real.power(x, i) * Real.power(y, d))
                    by Rational.to_real.multiply_preserves(
                           Rational.reciprocal_function((Natural.factorial(k) : Rational)),
                           (Natural.binomial(k, i) : Rational))
              = ((Rational.reciprocal_function((Natural.factorial(i) : Rational))
                      * Rational.reciprocal_function((Natural.factorial(d) : Rational))
                          : Rational) : Real)
                    * (Real.power(x, i) * Real.power(y, d))
                    since coefficientSplit
              = ((Rational.reciprocal_function((Natural.factorial(i) : Rational)) : Real)
                     * (Rational.reciprocal_function((Natural.factorial(d) : Rational)) : Real))
                    * (Real.power(x, i) * Real.power(y, d))
                    by Rational.to_real.multiply_preserves(
                           Rational.reciprocal_function((Natural.factorial(i) : Rational)),
                           Rational.reciprocal_function((Natural.factorial(d) : Rational)))
              = ((Rational.reciprocal_function((Natural.factorial(i) : Rational)) : Real)
                     * Real.power(x, i))
                    * ((Rational.reciprocal_function((Natural.factorial(d) : Rational)) : Real)
                           * Real.power(y, d))
              = Real.exponentialTerm(x, i) * Real.exponentialTerm(y, d)
              = Real.exponentialTerm(x, i)
                    * Real.exponentialTerm(y, Natural.monus(k, i))
                    since monusCollapse
         };
  -- Scale the binomial expansion through the sum and rewrite each term.
  calc Real.exponentialTerm(x + y, k)
     = (Rational.reciprocal_function((Natural.factorial(k) : Rational)) : Real)
           * Real.power(x + y, k)
     = (Rational.reciprocal_function((Natural.factorial(k) : Rational)) : Real)
           * Real.partialSum(
                 (i : Natural) ↦
                     ((Natural.binomial(k, i) : Rational) : Real)
                     * (Real.power(x, i) * Real.power(y, Natural.monus(k, i))),
                 1 + k)
           by Real.binomial_theorem(x, y, k)
     = Real.partialSum(
           (i : Natural) ↦
               (Rational.reciprocal_function((Natural.factorial(k) : Rational)) : Real)
               * (((Natural.binomial(k, i) : Rational) : Real)
                      * (Real.power(x, i) * Real.power(y, Natural.monus(k, i)))),
           1 + k)
           by Real.partialSum_scale(
                  (Rational.reciprocal_function((Natural.factorial(k) : Rational)) : Real),
                  (i : Natural) ↦
                      ((Natural.binomial(k, i) : Rational) : Real)
                      * (Real.power(x, i) * Real.power(y, Natural.monus(k, i))),
                  1 + k)
     = Real.partialSum(
           (i : Natural) ↦
               Real.exponentialTerm(x, i)
               * Real.exponentialTerm(y, Natural.monus(k, i)),
           1 + k)
           by Real.partialSum_pointwise_below(
                  (i : Natural) ↦
                      (Rational.reciprocal_function((Natural.factorial(k) : Rational)) : Real)
                      * (((Natural.binomial(k, i) : Rational) : Real)
                             * (Real.power(x, i) * Real.power(y, Natural.monus(k, i)))),
                  (i : Natural) ↦
                      Real.exponentialTerm(x, i)
                      * Real.exponentialTerm(y, Natural.monus(k, i)),
                  1 + k,
                  termSplit)
}

-- ----------------------------------------------------------------------
-- Exchanging the order of summation over the triangle: summing the
-- Cauchy-product diagonals through row n equals weighting each a(i) by
-- the partial sum of b up to n − i. (Σ_{k<n} Σ_{i≤k} aᵢ·b_{k−i}
-- = Σ_{i<n} aᵢ·B(n−i), where B is the partial-sum of b.)
theorem Real.cauchy_product_exchange (a b : Natural → Real)
        : (n : Natural)
          → Real.partialSum(
                (k : Natural) ↦
                    Real.partialSum(
                        (i : Natural) ↦ a(i) * b(Natural.monus(k, i)), 1 + k),
                n)
            = Real.partialSum(
                  (i : Natural) ↦
                      a(i) * Real.partialSum(b, Natural.monus(n, i)),
                  n)
  | zero => done
  | successor(p) => {
      claim exchangeTail
          : Real.partialSum(
                (k : Natural) ↦
                    Real.partialSum(
                        (i : Natural) ↦ a(i) * b(Natural.monus(k, i)), 1 + k),
                p)
            = Real.partialSum(
                  (i : Natural) ↦
                      a(i) * Real.partialSum(b, Natural.monus(p, i)),
                  p)
          by Real.cauchy_product_exchange(a, b, p);
      -- Padding the weighted row-p sum with its vanishing head:
      -- a(p)·B(p − p) = a(p)·B(0) = 0.
      claim monusDiagonal : Natural.monus(p, p) = 0 since Natural.monus_self;
      claim headPadding
          : Real.partialSum(
                (i : Natural) ↦
                    a(i) * Real.partialSum(b, Natural.monus(p, i)),
                successor(p))
            = Real.partialSum(
                  (i : Natural) ↦
                      a(i) * Real.partialSum(b, Natural.monus(p, i)),
                  p)
          by calc Real.partialSum(
                      (i : Natural) ↦
                          a(i) * Real.partialSum(b, Natural.monus(p, i)),
                      successor(p))
                = Real.partialSum(
                      (i : Natural) ↦
                          a(i) * Real.partialSum(b, Natural.monus(p, i)),
                      p)
                  + a(p) * Real.partialSum(b, Natural.monus(p, p))
                = Real.partialSum(
                      (i : Natural) ↦
                          a(i) * Real.partialSum(b, Natural.monus(p, i)),
                      p)
                  + a(p) * Real.partialSum(b, 0)
                      since monusDiagonal
                = Real.partialSum(
                      (i : Natural) ↦
                          a(i) * Real.partialSum(b, Natural.monus(p, i)),
                      p)
                  + a(p) * Real.zero
                = Real.partialSum(
                      (i : Natural) ↦
                          a(i) * Real.partialSum(b, Natural.monus(p, i)),
                      p)
                      by ring;
      -- Below the cut, peeling the successor off n − i absorbs one
      -- diagonal term into each weight.
      claim stepSplit
          : (i : Natural) → successor(i) ≤ successor(p)
            → a(i) * Real.partialSum(b, Natural.monus(p, i))
                  + a(i) * b(Natural.monus(p, i))
              = a(i) * Real.partialSum(b, Natural.monus(successor(p), i))
          by (i : Natural) (iBelow : successor(i) ≤ successor(p)) ↦ {
               claim i ≤ p since Natural.successor_le_cancel;
               claim monusStep
                   : Natural.monus(successor(p), i)
                     = successor(Natural.monus(p, i))
                   by Natural.monus_succ_left(i, p, (i ≤ p));
               calc a(i) * Real.partialSum(b, Natural.monus(p, i))
                        + a(i) * b(Natural.monus(p, i))
                  = a(i) * (Real.partialSum(b, Natural.monus(p, i))
                                + b(Natural.monus(p, i)))
                  = a(i) * Real.partialSum(b, successor(Natural.monus(p, i)))
                  = a(i) * Real.partialSum(b, Natural.monus(successor(p), i))
                        since monusStep
             };
      calc Real.partialSum(
               (k : Natural) ↦
                   Real.partialSum(
                       (i : Natural) ↦ a(i) * b(Natural.monus(k, i)), 1 + k),
               successor(p))
         = Real.partialSum(
               (k : Natural) ↦
                   Real.partialSum(
                       (i : Natural) ↦ a(i) * b(Natural.monus(k, i)), 1 + k),
               p)
           + Real.partialSum(
                 (i : Natural) ↦ a(i) * b(Natural.monus(p, i)), 1 + p)
         = Real.partialSum(
               (i : Natural) ↦
                   a(i) * Real.partialSum(b, Natural.monus(p, i)),
               p)
           + Real.partialSum(
                 (i : Natural) ↦ a(i) * b(Natural.monus(p, i)), 1 + p)
               since exchangeTail
         = Real.partialSum(
               (i : Natural) ↦
                   a(i) * Real.partialSum(b, Natural.monus(p, i)),
               successor(p))
           + Real.partialSum(
                 (i : Natural) ↦ a(i) * b(Natural.monus(p, i)), successor(p))
               since headPadding
         = Real.partialSum(
               (i : Natural) ↦
                   a(i) * Real.partialSum(b, Natural.monus(p, i))
                   + a(i) * b(Natural.monus(p, i)),
               successor(p))
               by Real.partialSum_add(
                      (i : Natural) ↦
                          a(i) * Real.partialSum(b, Natural.monus(p, i)),
                      (i : Natural) ↦ a(i) * b(Natural.monus(p, i)),
                      successor(p))
         = Real.partialSum(
               (i : Natural) ↦
                   a(i) * Real.partialSum(b, Natural.monus(successor(p), i)),
               successor(p))
               by Real.partialSum_pointwise_below(
                      (i : Natural) ↦
                          a(i) * Real.partialSum(b, Natural.monus(p, i))
                          + a(i) * b(Natural.monus(p, i)),
                      (i : Natural) ↦
                          a(i) * Real.partialSum(b, Natural.monus(successor(p), i)),
                      successor(p),
                      stepSplit)
    }

import Real.exponential

-- ----------------------------------------------------------------------
-- The coefficient identity: 1/(i+d)! · C(i+d, i) = 1/i! · 1/d!.
-- The cast of `Natural.binomial_factorial` clears all denominators.
theorem Real.binomial_reciprocal_split (i d : ℕ)
        : (1 / ((i + d)! : ℝ)) * (Natural.binomial(i + d, i) : ℝ)
          = (1 / (i! : ℝ)) * (1 / (d! : ℝ)) := {
  -- The closed form, cast into ℝ.
  ((i + d)! : ℝ)
        = (Natural.binomial(i + d, i) * (i! * d!) : ℝ)
              by Natural.binomial_factorial
        = (Natural.binomial(i + d, i) : ℝ) * ((i! : ℝ) * (d! : ℝ));
  -- Divide it through.
  (1 / ((i + d)! : ℝ)) * (Natural.binomial(i + d, i) : ℝ)
     = (1 / ((Natural.binomial(i + d, i) : ℝ) * ((i! : ℝ) * (d! : ℝ))))
           * (Natural.binomial(i + d, i) : ℝ)
     = (1 / (i! : ℝ)) * (1 / (d! : ℝ))
}

-- ----------------------------------------------------------------------
-- The k-th exponential term at x + y is the k-th Cauchy-product
-- diagonal of the two series.
theorem Real.exponentialTerm_binomial_split (x y : ℝ) (k : ℕ)
        : Real.exponentialTerm(x + y, k)
          = Real.partialSum(
                (i : ℕ) ↦
                    Real.exponentialTerm(x, i)
                    * Real.exponentialTerm(y, k ∸ i),
                1 + k) := {
  -- Each summand below the cut: fold the coefficient into the two
  -- reciprocal factorials.
  ∀ (i : ℕ). i < 1 + k
        → (1 / (k! : ℝ))
              * ((Natural.binomial(k, i) : ℝ) * (x ^ i * y ^ (k ∸ i)))
          = Real.exponentialTerm(x, i) * Real.exponentialTerm(y, k ∸ i)
      by (i : ℕ) (iLessThan : i < 1 + k) ↦ {
           i ≤ k by Natural.le_of_lt_one_plus;
           choose d such that k = i + d from Natural.subtraction_witness;
           i + d = k as kJoin;
           k ∸ i = d
               by {
                 (i + d) ∸ i = d;
                 done by substituting kJoin
               } as monusCollapse;
           (1 / (k! : ℝ)) * (Natural.binomial(k, i) : ℝ)
                 = (1 / (i! : ℝ)) * (1 / (d! : ℝ))
               by substituting kJoin as coefficientSplit;
           (1 / (k! : ℝ))
                    * ((Natural.binomial(k, i) : ℝ) * (x ^ i * y ^ (k ∸ i)))
              = (1 / (k! : ℝ))
                    * ((Natural.binomial(k, i) : ℝ) * (x ^ i * y ^ d))
                    by monusCollapse
              = ((1 / (k! : ℝ)) * (Natural.binomial(k, i) : ℝ))
                    * (x ^ i * y ^ d)
              = ((1 / (i! : ℝ)) * (1 / (d! : ℝ)))
                    * (x ^ i * y ^ d)
                    by coefficientSplit
              = ((1 / (i! : ℝ)) * x ^ i)
                    * ((1 / (d! : ℝ)) * y ^ d)
              = Real.exponentialTerm(x, i) * Real.exponentialTerm(y, d)
              = Real.exponentialTerm(x, i) * Real.exponentialTerm(y, k ∸ i)
                    by monusCollapse
         };
  -- Scale the binomial expansion through the sum and rewrite each term.
  Real.exponentialTerm(x + y, k)
     = (1 / (k! : ℝ)) * (x + y) ^ k
     = (1 / (k! : ℝ))
           * Real.partialSum(
                 (i : ℕ) ↦
                     (Natural.binomial(k, i) : ℝ) * (x ^ i * y ^ (k ∸ i)),
                 1 + k)
           by Real.binomial_theorem
     = Real.partialSum(
           (i : ℕ) ↦
               (1 / (k! : ℝ))
               * ((Natural.binomial(k, i) : ℝ) * (x ^ i * y ^ (k ∸ i))),
           1 + k)
           by Real.partialSum_scale
     = Real.partialSum(
           (i : ℕ) ↦ Real.exponentialTerm(x, i) * Real.exponentialTerm(y, k ∸ i),
           1 + k)
           by Real.partialSum_pointwise_below
}

-- ----------------------------------------------------------------------
-- Exchanging the order of summation over the triangle: summing the
-- Cauchy-product diagonals through row n equals weighting each a(i) by
-- the partial sum of b up to n − i. (Σ_{k<n} Σ_{i≤k} aᵢ·b_{k−i}
-- = Σ_{i<n} aᵢ·B(n−i), where B is the partial-sum of b.)
theorem Real.cauchy_product_exchange (a b : ℕ → ℝ) (n : ℕ)
        : Real.partialSum(
              (k : ℕ) ↦
                  Real.partialSum(
                      (i : ℕ) ↦ a(i) * b(k ∸ i), 1 + k),
              n)
          = Real.partialSum(
                (i : ℕ) ↦
                    a(i) * Real.partialSum(b, n ∸ i),
                n) :=
  by induction on n with IH {
    case n = 0: done
    case n = 1 + p for some p: {
      Real.partialSum(
                (k : ℕ) ↦
                    Real.partialSum(
                        (i : ℕ) ↦ a(i) * b(k ∸ i), 1 + k),
                p)
            = Real.partialSum(
                  (i : ℕ) ↦
                      a(i) * Real.partialSum(b, p ∸ i),
                  p)
          by IH as exchangeTail;
      -- Padding the weighted row-p sum with its vanishing head:
      -- a(p)·B(p − p) = a(p)·B(0) = 0.
      p ∸ p = 0 as monusDiagonal;
      Real.partialSum(
                (i : ℕ) ↦
                    a(i) * Real.partialSum(b, p ∸ i),
                1 + p)
            = Real.partialSum(
                  (i : ℕ) ↦
                      a(i) * Real.partialSum(b, p ∸ i),
                  p)
              + a(p) * Real.partialSum(b, p ∸ p)
            = Real.partialSum(
                  (i : ℕ) ↦
                      a(i) * Real.partialSum(b, p ∸ i),
                  p)
              + a(p) * Real.partialSum(b, 0)
                  by monusDiagonal
            = Real.partialSum(
                  (i : ℕ) ↦
                      a(i) * Real.partialSum(b, p ∸ i),
                  p)
              + a(p) * Real.zero
            = Real.partialSum(
                  (i : ℕ) ↦
                      a(i) * Real.partialSum(b, p ∸ i),
                  p)
                  by ring as headPadding;
      -- Below the cut, peeling one term off n − i absorbs one
      -- diagonal term into each weight.
      ∀ (i : ℕ). i < 1 + p
            → a(i) * Real.partialSum(b, p ∸ i)
                  + a(i) * b(p ∸ i)
              = a(i) * Real.partialSum(b, (1 + p) ∸ i)
          by (i : ℕ) (iLessThan : i < 1 + p) ↦ {
               i ≤ p by Natural.le_of_lt_one_plus;
               (1 + p) ∸ i = 1 + (p ∸ i) as monusStep;
               a(i) * Real.partialSum(b, p ∸ i)
                        + a(i) * b(p ∸ i)
                  = a(i) * (Real.partialSum(b, p ∸ i)
                                + b(p ∸ i))
                  = a(i) * Real.partialSum(b, 1 + (p ∸ i))
                  = a(i) * Real.partialSum(b, (1 + p) ∸ i)
                        by monusStep
             };
      Real.partialSum(
               (k : ℕ) ↦
                   Real.partialSum(
                       (i : ℕ) ↦ a(i) * b(k ∸ i), 1 + k),
               1 + p)
         = Real.partialSum(
               (k : ℕ) ↦
                   Real.partialSum(
                       (i : ℕ) ↦ a(i) * b(k ∸ i), 1 + k),
               p)
           + Real.partialSum(
                 (i : ℕ) ↦ a(i) * b(p ∸ i), 1 + p)
               by Real.partialSum_add_one
         = Real.partialSum(
               (i : ℕ) ↦
                   a(i) * Real.partialSum(b, p ∸ i),
               p)
           + Real.partialSum(
                 (i : ℕ) ↦ a(i) * b(p ∸ i), 1 + p)
               by exchangeTail
         = Real.partialSum(
               (i : ℕ) ↦
                   a(i) * Real.partialSum(b, p ∸ i),
               1 + p)
           + Real.partialSum(
                 (i : ℕ) ↦ a(i) * b(p ∸ i), 1 + p)
               by headPadding
         = Real.partialSum(
               (i : ℕ) ↦
                   a(i) * Real.partialSum(b, p ∸ i)
                   + a(i) * b(p ∸ i),
               1 + p)
               by Real.partialSum_add
         = Real.partialSum(
               (i : ℕ) ↦
                   a(i) * Real.partialSum(b, (1 + p) ∸ i),
               1 + p)
               by Real.partialSum_pointwise_below
    }
  }

-- ----------------------------------------------------------------------
-- The square-minus-triangle gap, dominated by the same gap of the
-- absolute series: |A(n)·B(n) − T(n)| ≤ Aabs(n)·Babs(n) − Tabs(n).
-- Both gaps are the same a-weighted sum of windows of B, and a window
-- of B is dominated by the matching window of Babs.
theorem Real.cauchy_product_difference_bound (a b : ℕ → ℝ) (n : ℕ)
        : abs(Real.partialSum(a, n) * Real.partialSum(b, n)
                  - Real.partialSum(
                        (k : ℕ) ↦
                            Real.partialSum(
                                (i : ℕ) ↦ a(i) * b(k ∸ i),
                                1 + k),
                        n))
          ≤ Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
                * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
            - Real.partialSum(
                  (k : ℕ) ↦
                      Real.partialSum(
                          (i : ℕ) ↦ abs(a(i)) * abs(b(k ∸ i)),
                          1 + k),
                  n) := {
  Real.partialSum(
            (k : ℕ) ↦
                Real.partialSum(
                    (i : ℕ) ↦ abs(a(i)) * abs(b(k ∸ i)),
                    1 + k),
            n)
        = Real.partialSum(
              (i : ℕ) ↦
                  abs(a(i))
                  * Real.partialSum((k : ℕ) ↦ abs(b(k)), n ∸ i),
              n)
      by Real.cauchy_product_exchange(
             a := (k : ℕ) ↦ abs(a(k)), b := (k : ℕ) ↦ abs(b(k))) as absExchange;
  Real.partialSum(
            (i : ℕ) ↦ a(i) * Real.partialSum(b, n), n)
        = Real.partialSum(a, n) * Real.partialSum(b, n) as signedScale;
  Real.partialSum(
            (i : ℕ) ↦
                abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)), n),
            n)
        = Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
          * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
      by Real.partialSum_scale_right as absScale;
  -- Each weighted window of B is dominated by the weighted window of Babs.
  ∀ (i : ℕ). i < n
        → abs(a(i) * Real.partialSum(b, n)
                  - a(i) * Real.partialSum(b, n ∸ i))
          ≤ abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
            - abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)),
                  n ∸ i)
      by (i : ℕ) (iLessThan : i < n) ↦ {
           i ≤ n by Natural.LessThan.weaken;
           choose e such that n = i + e from Natural.subtraction_witness;
           i + e = n as nJoin;
           n ∸ i = e
               by {
                 (i + e) ∸ i = e;
                 done by substituting nJoin
               } as monusCollapse;
           abs(Real.partialSum(b, n) - Real.partialSum(b, e))
                 ≤ Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
                   - Real.partialSum((k : ℕ) ↦ abs(b(k)), e)
               by {
                 abs(Real.partialSum(b, i + e) - Real.partialSum(b, e))
                       ≤ Real.partialSum((k : ℕ) ↦ abs(b(k)), i + e)
                         - Real.partialSum((k : ℕ) ↦ abs(b(k)), e)
                     by Real.partialSum_window_bound;
                 done by substituting nJoin
               };
           Real.zero ≤ abs(a(i));
           Real.IsNonneg(abs(a(i)));
           abs(a(i) * Real.partialSum(b, n)
                    - a(i) * Real.partialSum(b, n ∸ i))
              = abs(a(i) * Real.partialSum(b, n)
                    - a(i) * Real.partialSum(b, e))
                    by monusCollapse
              = abs(a(i)
                    * (Real.partialSum(b, n) - Real.partialSum(b, e)))
                    by substituting
                        (ring : a(i) * (Real.partialSum(b, n) - Real.partialSum(b, e))
                            = a(i) * Real.partialSum(b, n)
                              - a(i) * Real.partialSum(b, e))
              = abs(a(i)) * abs(Real.partialSum(b, n) - Real.partialSum(b, e))
              = abs(Real.partialSum(b, n) - Real.partialSum(b, e)) * abs(a(i))
              ≤ (Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
                     - Real.partialSum((k : ℕ) ↦ abs(b(k)), e))
                    * abs(a(i))
                    by Real.LessOrEqual.multiply_by_nonneg_right
              = abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
                - abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)), e)
              = abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
                - abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)),
                      n ∸ i)
                    by monusCollapse
         };
  abs(Real.partialSum(a, n) * Real.partialSum(b, n)
               - Real.partialSum(
                     (k : ℕ) ↦
                         Real.partialSum(
                             (i : ℕ) ↦ a(i) * b(k ∸ i),
                             1 + k),
                     n))
     = abs(Real.partialSum(
               (i : ℕ) ↦ a(i) * Real.partialSum(b, n), n)
           - Real.partialSum(
                 (i : ℕ) ↦ a(i) * Real.partialSum(b, n ∸ i),
                 n))
           by signedScale
     = abs(Real.partialSum(
               (i : ℕ) ↦
                   a(i) * Real.partialSum(b, n)
                   - a(i) * Real.partialSum(b, n ∸ i),
               n))
           by Real.partialSum_subtract
     ≤ Real.partialSum(
           (i : ℕ) ↦
               abs(a(i) * Real.partialSum(b, n)
                   - a(i) * Real.partialSum(b, n ∸ i)),
           n)
           by Real.abs_partialSum_le
     ≤ Real.partialSum(
           (i : ℕ) ↦
               abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
               - abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)),
                     n ∸ i),
           n)
           by Real.partialSum_le_pointwise
     = Real.partialSum(
           (i : ℕ) ↦
               abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)), n),
           n)
       - Real.partialSum(
             (i : ℕ) ↦
                 abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)),
                     n ∸ i),
             n)
           by Real.partialSum_subtract
     = Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
           * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
       - Real.partialSum(
             (i : ℕ) ↦
                 abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)),
                     n ∸ i),
             n)
           by absScale
     = Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
           * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
       - Real.partialSum(
             (k : ℕ) ↦
                 Real.partialSum(
                     (i : ℕ) ↦ abs(a(i)) * abs(b(k ∸ i)),
                     1 + k),
             n)
           by absExchange
}

-- ----------------------------------------------------------------------
-- Mertens for absolutely convergent series: the triangle sums of the
-- Cauchy product converge to the product of the limits. The square
-- converges there by the product of limits; the square-minus-triangle
-- gap is dominated by the absolute gap, and the absolute triangle and
-- square share one limit because Tabs(n) ≤ Sabs(n) ≤ Tabs(n + n).
theorem Real.cauchy_product_converges
        (a b : ℕ → ℝ)
        (aLimit bLimit aAbsoluteLimit bAbsoluteLimit : ℝ)
        (aConverges : Real.SequenceConverges(Real.partialSum(a), aLimit))
        (bConverges : Real.SequenceConverges(Real.partialSum(b), bLimit))
        (aAbsolutelyConverges
            : Real.SequenceConverges(
                  Real.partialSum((k : ℕ) ↦ abs(a(k))), aAbsoluteLimit))
        (bAbsolutelyConverges
            : Real.SequenceConverges(
                  Real.partialSum((k : ℕ) ↦ abs(b(k))), bAbsoluteLimit))
        : Real.SequenceConverges(
              Real.partialSum(
                  (k : ℕ) ↦
                      Real.partialSum(
                          (i : ℕ) ↦ a(i) * b(k ∸ i),
                          1 + k)),
              aLimit * bLimit) := {
  -- The squares converge, signed and absolute.
  Real.SequenceConverges(
            (n : ℕ) ↦ Real.partialSum(a, n) * Real.partialSum(b, n),
            aLimit * bLimit)
      by Real.SequenceConverges.multiply as productConverges;
  Real.SequenceConverges(
            (n : ℕ) ↦
                Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
                * Real.partialSum((k : ℕ) ↦ abs(b(k)), n),
            aAbsoluteLimit * bAbsoluteLimit)
      by Real.SequenceConverges.multiply as absoluteProductConverges;
  -- The absolute triangle sums are monotone in n.
  ∀ (i : ℕ). Real.zero ≤ abs(a(i))
      by { take i : ℕ; done by Real.absolute_value_nonneg };
  ∀ (i : ℕ). Real.zero ≤ abs(b(i))
      by { take i : ℕ; done by Real.absolute_value_nonneg };
  ∀ (k : ℕ).
          Real.zero
          ≤ Real.partialSum(
                (i : ℕ) ↦ abs(a(i)) * abs(b(k ∸ i)),
                1 + k)
      by (k : ℕ) ↦
           Real.partialSum_nonneg(termsNonneg := (j : ℕ) ↦ {
                 Real.zero ≤ abs(a(j));
                 Real.zero ≤ abs(b(k ∸ j));
                 Real.IsNonneg(abs(a(j)));
                 Real.IsNonneg(abs(b(k ∸ j)));
                 Real.IsNonneg(abs(a(j)) * abs(b(k ∸ j)));
                 done by Real.LessOrEqual_zero_of_IsNonneg
               });
  ∀ (i j : ℕ). i ≤ j
        → Real.partialSum(
              (k : ℕ) ↦
                  Real.partialSum(
                      (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                      1 + k),
              i)
          ≤ Real.partialSum(
                (k : ℕ) ↦
                    Real.partialSum(
                        (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                        1 + k),
                j)
      by (i j : ℕ) (iLeqJ : i ≤ j) ↦ {
           done by Real.partialSum_monotone_of_nonneg
         } as absoluteTriangleMonotone;
  -- The absolute square sits below its limit (it is monotone), and the
  -- absolute triangle sits below the absolute square.
  ∀ (n : ℕ).
          Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
              * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
          ≤ aAbsoluteLimit * bAbsoluteLimit
      by (n : ℕ) ↦
           Real.SequenceConverges.ge_of_eventually_ge(
               s := (m : ℕ) ↦
                   Real.partialSum((k : ℕ) ↦ abs(a(k)), m)
                   * Real.partialSum((k : ℕ) ↦ abs(b(k)), m),
               converges := absoluteProductConverges,
               N := n,
               tailAbove := (m : ℕ) (nLeqM : n ≤ m) ↦ {
                 Real.zero ≤ Real.partialSum((k : ℕ) ↦ abs(a(k)), n);
                 Real.zero ≤ Real.partialSum((k : ℕ) ↦ abs(b(k)), n);
                 Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
                       ≤ Real.partialSum((k : ℕ) ↦ abs(a(k)), m)
                     by Real.partialSum_monotone_of_nonneg;
                 Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
                       ≤ Real.partialSum((k : ℕ) ↦ abs(b(k)), m)
                     by Real.partialSum_monotone_of_nonneg;
                 Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
                           * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
                       ≤ Real.partialSum((k : ℕ) ↦ abs(a(k)), m)
                         * Real.partialSum((k : ℕ) ↦ abs(b(k)), m)
                     by Real.LessOrEqual.multiply_monotone_nonneg;
                 done
               });
  ∀ (n : ℕ).
          Real.partialSum(
              (k : ℕ) ↦
                  Real.partialSum(
                      (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                      1 + k),
              n)
          ≤ Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
            * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
      by (n : ℕ) ↦ {
           ∀ (i : ℕ). i < n
                 → abs(a(i))
                       * Real.partialSum((k : ℕ) ↦ abs(b(k)),
                             n ∸ i)
                   ≤ abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
               by (i : ℕ) (iLessThan : i < n) ↦ {
                    i ≤ n by Natural.LessThan.weaken;
                    choose e such that n = i + e
                        from Natural.subtraction_witness;
                    n ∸ i ≤ n;
                    Real.partialSum((k : ℕ) ↦ abs(b(k)),
                              n ∸ i)
                          ≤ Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
                        by Real.partialSum_monotone_of_nonneg;
                    Real.zero ≤ abs(a(i));
                    Real.IsNonneg(abs(a(i)));
                    abs(a(i))
                             * Real.partialSum((k : ℕ) ↦ abs(b(k)),
                                   n ∸ i)
                       = Real.partialSum((k : ℕ) ↦ abs(b(k)),
                             n ∸ i) * abs(a(i))
                       ≤ Real.partialSum((k : ℕ) ↦ abs(b(k)), n) * abs(a(i))
                             by Real.LessOrEqual.multiply_by_nonneg_right
                       = abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
                  };
           Real.partialSum(
                    (k : ℕ) ↦
                        Real.partialSum(
                            (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                            1 + k),
                    n)
              = Real.partialSum(
                    (i : ℕ) ↦
                        abs(a(i))
                        * Real.partialSum((k : ℕ) ↦ abs(b(k)),
                              n ∸ i),
                    n)
                    by Real.cauchy_product_exchange(
                           a := (k : ℕ) ↦ abs(a(k)),
                           b := (k : ℕ) ↦ abs(b(k)))
              ≤ Real.partialSum(
                    (i : ℕ) ↦
                        abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)), n),
                    n)
                    by Real.partialSum_le_pointwise
              = Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
                    * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
                    by Real.partialSum_scale_right
         };
  -- The absolute triangle converges (monotone, bounded by the absolute
  -- square's limit) …
  ∀ (n : ℕ).
          Real.partialSum(
              (k : ℕ) ↦
                  Real.partialSum(
                      (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                      1 + k),
              n)
          ≤ aAbsoluteLimit * bAbsoluteLimit
      by (n : ℕ) ↦ {
           Real.partialSum(
                     (k : ℕ) ↦
                         Real.partialSum(
                             (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                             1 + k),
                     n)
                 ≤ Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
                   * Real.partialSum((k : ℕ) ↦ abs(b(k)), n);
           Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
                     * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
                 ≤ aAbsoluteLimit * bAbsoluteLimit;
           Real.partialSum(
                     (k : ℕ) ↦
                         Real.partialSum(
                             (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                             1 + k),
                     n)
                 ≤ aAbsoluteLimit * bAbsoluteLimit;
           done
         } as absoluteTriangleBounded;
  choose triangleAbsoluteLimit such that
      Real.SequenceConverges(
          Real.partialSum(
              (k : ℕ) ↦
                  Real.partialSum(
                      (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                      1 + k)),
          triangleAbsoluteLimit)
      as absoluteTriangleConverges
      from Real.monotone_bounded_converges;
  -- … to the SAME limit as the absolute square, because
  -- Sabs(n) ≤ Tabs(n + n).
  ∀ (n : ℕ).
          Real.partialSum(
              (k : ℕ) ↦
                  Real.partialSum(
                      (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                      1 + k),
              n)
          ≤ triangleAbsoluteLimit
      by (n : ℕ) ↦
           Real.SequenceConverges.ge_of_eventually_ge(
               s := Real.partialSum(
                   (k : ℕ) ↦
                       Real.partialSum(
                           (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                           1 + k)),
               converges := absoluteTriangleConverges,
               N := n,
               tailAbove := (m : ℕ) (nLeqM : n ≤ m) ↦
                 absoluteTriangleMonotone(n, m, nLeqM));
  ∀ (n : ℕ).
          Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
              * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
          ≤ Real.partialSum(
                (k : ℕ) ↦
                    Real.partialSum(
                        (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                        1 + k),
                n + n)
      by (n : ℕ) ↦ {
           ∀ (i : ℕ). i < n
                 → abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
                   ≤ abs(a(i))
                     * Real.partialSum((k : ℕ) ↦ abs(b(k)),
                           (n + n) ∸ i)
               by (i : ℕ) (iLessThan : i < n) ↦ {
                    i ≤ n by Natural.LessThan.weaken;
                    choose e such that n = i + e as nSplit
                        from Natural.subtraction_witness;
                    n + n
                        = (i + e) + n    by nSplit
                        = i + (e + n);
                    (n + n) ∸ i = e + n
                        by {
                          (i + (e + n)) ∸ i = e + n;
                          i + (e + n) = n + n;
                          done by substituting (i + (e + n) = n + n)
                        } as monusStretch;
                    n ≤ (n + n) ∸ i
                        by {
                          n ≤ n + e;
                          n + e = e + n;
                          n ≤ e + n;
                          done by substituting monusStretch
                        };
                    Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
                          ≤ Real.partialSum((k : ℕ) ↦ abs(b(k)),
                                (n + n) ∸ i)
                        by Real.partialSum_monotone_of_nonneg;
                    Real.zero ≤ abs(a(i));
                    Real.IsNonneg(abs(a(i)));
                    abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
                       = Real.partialSum((k : ℕ) ↦ abs(b(k)), n) * abs(a(i))
                       ≤ Real.partialSum((k : ℕ) ↦ abs(b(k)),
                             (n + n) ∸ i) * abs(a(i))
                             by Real.LessOrEqual.multiply_by_nonneg_right
                       = abs(a(i))
                         * Real.partialSum((k : ℕ) ↦ abs(b(k)),
                               (n + n) ∸ i)
                  };
           ∀ (i : ℕ).
                   Real.zero
                   ≤ abs(a(i))
                     * Real.partialSum((k : ℕ) ↦ abs(b(k)),
                           (n + n) ∸ i)
               by (i : ℕ) ↦ {
                    Real.zero ≤ abs(a(i));
                    Real.zero
                          ≤ Real.partialSum((k : ℕ) ↦ abs(b(k)),
                                (n + n) ∸ i)
                        by Real.partialSum_nonneg;
                    Real.IsNonneg(abs(a(i)));
                    Real.IsNonneg(
                              Real.partialSum((k : ℕ) ↦ abs(b(k)),
                                  (n + n) ∸ i));
                    Real.IsNonneg(
                              abs(a(i))
                              * Real.partialSum((k : ℕ) ↦ abs(b(k)),
                                    (n + n) ∸ i));
                    done by Real.LessOrEqual_zero_of_IsNonneg
                  };
           n ≤ n + n;
           Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
                    * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
              = Real.partialSum(
                    (i : ℕ) ↦
                        abs(a(i)) * Real.partialSum((k : ℕ) ↦ abs(b(k)), n),
                    n)
                    by Real.partialSum_scale_right
              ≤ Real.partialSum(
                    (i : ℕ) ↦
                        abs(a(i))
                        * Real.partialSum((k : ℕ) ↦ abs(b(k)),
                              (n + n) ∸ i),
                    n)
                    by Real.partialSum_le_pointwise
              ≤ Real.partialSum(
                    (i : ℕ) ↦
                        abs(a(i))
                        * Real.partialSum((k : ℕ) ↦ abs(b(k)),
                              (n + n) ∸ i),
                    n + n)
                    by Real.partialSum_monotone_of_nonneg
              = Real.partialSum(
                    (k : ℕ) ↦
                        Real.partialSum(
                            (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                            1 + k),
                    n + n)
                    by Real.cauchy_product_exchange(
                           a := (k : ℕ) ↦ abs(a(k)),
                           b := (k : ℕ) ↦ abs(b(k)))
         };
  -- The two absolute limits agree.
  triangleAbsoluteLimit ≤ aAbsoluteLimit * bAbsoluteLimit
      by Real.SequenceConverges.le_of_eventually_le(
             s := Real.partialSum(
                 (k : ℕ) ↦
                     Real.partialSum(
                         (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                         1 + k)),
             converges := absoluteTriangleConverges,
             N := 0,
             tailBelow := (m : ℕ) (_ : 0 ≤ m) ↦ absoluteTriangleBounded(m));
  aAbsoluteLimit * bAbsoluteLimit ≤ triangleAbsoluteLimit
      by Real.SequenceConverges.le_of_eventually_le(
             s := (n : ℕ) ↦
                 Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
                 * Real.partialSum((k : ℕ) ↦ abs(b(k)), n),
             converges := absoluteProductConverges,
             N := 0,
             tailBelow := (m : ℕ) (_ : 0 ≤ m) ↦ {
               Real.partialSum((k : ℕ) ↦ abs(a(k)), m)
                         * Real.partialSum((k : ℕ) ↦ abs(b(k)), m)
                     ≤ Real.partialSum(
                           (k : ℕ) ↦
                               Real.partialSum(
                                   (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                                   1 + k),
                           m + m);
               Real.partialSum(
                         (k : ℕ) ↦
                             Real.partialSum(
                                 (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                                 1 + k),
                         m + m)
                     ≤ triangleAbsoluteLimit;
               Real.partialSum((k : ℕ) ↦ abs(a(k)), m)
                         * Real.partialSum((k : ℕ) ↦ abs(b(k)), m)
                     ≤ triangleAbsoluteLimit;
               done
             });
  aAbsoluteLimit * bAbsoluteLimit = triangleAbsoluteLimit
      by Real.LessOrEqual.antisymmetric as limitsAgree;
  -- The absolute gap vanishes …
  Real.SequenceConverges(
            (n : ℕ) ↦
                -Real.partialSum(
                     (k : ℕ) ↦
                         Real.partialSum(
                             (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                             1 + k),
                     n),
            -triangleAbsoluteLimit)
      by Real.SequenceConverges.negate(
             s := Real.partialSum(
                 (k : ℕ) ↦
                     Real.partialSum(
                         (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                         1 + k)),
             sConverges := absoluteTriangleConverges) as negatedTriangleConverges;
  Real.SequenceConverges(
            (n : ℕ) ↦
                Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
                    * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
                + -Real.partialSum(
                       (k : ℕ) ↦
                           Real.partialSum(
                               (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                               1 + k),
                       n),
            aAbsoluteLimit * bAbsoluteLimit + -triangleAbsoluteLimit)
      by Real.SequenceConverges.add(
             s := (n : ℕ) ↦
                 Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
                 * Real.partialSum((k : ℕ) ↦ abs(b(k)), n),
             t := (n : ℕ) ↦
                 -Real.partialSum(
                      (k : ℕ) ↦
                          Real.partialSum(
                              (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                              1 + k),
                      n),
             sConverges := absoluteProductConverges,
             tConverges := negatedTriangleConverges);
  aAbsoluteLimit * bAbsoluteLimit + -triangleAbsoluteLimit
      = triangleAbsoluteLimit + -triangleAbsoluteLimit
            by limitsAgree
      = Real.zero;
  Real.SequenceConverges(
            (n : ℕ) ↦
                Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
                    * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
                - Real.partialSum(
                      (k : ℕ) ↦
                          Real.partialSum(
                              (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                              1 + k),
                      n),
            Real.zero)
      by {
        Real.zero = aAbsoluteLimit * bAbsoluteLimit + -triangleAbsoluteLimit;
        done by substituting
            (Real.zero = aAbsoluteLimit * bAbsoluteLimit + -triangleAbsoluteLimit)
      };
  -- … so the signed gap vanishes by the squeeze.
  ∀ (n : ℕ).
          abs(Real.partialSum(a, n) * Real.partialSum(b, n)
                  - Real.partialSum(
                        (k : ℕ) ↦
                            Real.partialSum(
                                (i : ℕ) ↦ a(i) * b(k ∸ i),
                                1 + k),
                        n))
          ≤ Real.partialSum((k : ℕ) ↦ abs(a(k)), n)
                * Real.partialSum((k : ℕ) ↦ abs(b(k)), n)
            - Real.partialSum(
                  (k : ℕ) ↦
                      Real.partialSum(
                          (l : ℕ) ↦ abs(a(l)) * abs(b(k ∸ l)),
                          1 + k),
                  n)
      by (n : ℕ) ↦ { done by Real.cauchy_product_difference_bound };
  Real.SequenceConverges(
            (n : ℕ) ↦
                Real.partialSum(a, n) * Real.partialSum(b, n)
                - Real.partialSum(
                      (k : ℕ) ↦
                          Real.partialSum(
                              (i : ℕ) ↦ a(i) * b(k ∸ i),
                              1 + k),
                      n),
            Real.zero)
      by Real.SequenceConverges.squeeze_zero as signedGapVanishes;
  -- Triangle = square − (square − triangle).
  Real.SequenceConverges(
            (n : ℕ) ↦
                -(Real.partialSum(a, n) * Real.partialSum(b, n)
                  - Real.partialSum(
                        (k : ℕ) ↦
                            Real.partialSum(
                                (i : ℕ) ↦ a(i) * b(k ∸ i),
                                1 + k),
                        n)),
            -Real.zero)
      by Real.SequenceConverges.negate(
             s := (n : ℕ) ↦
                 Real.partialSum(a, n) * Real.partialSum(b, n)
                 - Real.partialSum(
                       (k : ℕ) ↦
                           Real.partialSum(
                               (i : ℕ) ↦ a(i) * b(k ∸ i),
                               1 + k),
                       n),
             sConverges := signedGapVanishes) as negatedSignedGapConverges;
  Real.SequenceConverges(
            (n : ℕ) ↦
                Real.partialSum(a, n) * Real.partialSum(b, n)
                + -(Real.partialSum(a, n) * Real.partialSum(b, n)
                    - Real.partialSum(
                          (k : ℕ) ↦
                              Real.partialSum(
                                  (i : ℕ) ↦ a(i) * b(k ∸ i),
                                  1 + k),
                          n)),
            aLimit * bLimit + -Real.zero)
      by Real.SequenceConverges.add(
             s := (n : ℕ) ↦ Real.partialSum(a, n) * Real.partialSum(b, n),
             t := (n : ℕ) ↦
                 -(Real.partialSum(a, n) * Real.partialSum(b, n)
                   - Real.partialSum(
                         (k : ℕ) ↦
                             Real.partialSum(
                                 (i : ℕ) ↦ a(i) * b(k ∸ i),
                                 1 + k),
                         n)),
             sConverges := productConverges,
             tConverges := negatedSignedGapConverges);
  aLimit * bLimit = aLimit * bLimit + -Real.zero
      by ring as limitSimplifies;
  Real.SequenceConverges(
            (n : ℕ) ↦
                Real.partialSum(a, n) * Real.partialSum(b, n)
                + -(Real.partialSum(a, n) * Real.partialSum(b, n)
                    - Real.partialSum(
                          (k : ℕ) ↦
                              Real.partialSum(
                                  (i : ℕ) ↦ a(i) * b(k ∸ i),
                                  1 + k),
                          n)),
            aLimit * bLimit)
      by substituting limitSimplifies as assembledAtProduct;
  ∀ (n : ℕ).
          Real.partialSum(a, n) * Real.partialSum(b, n)
              + -(Real.partialSum(a, n) * Real.partialSum(b, n)
                  - Real.partialSum(
                        (k : ℕ) ↦
                            Real.partialSum(
                                (i : ℕ) ↦ a(i) * b(k ∸ i),
                                1 + k),
                        n))
          = Real.partialSum(
                (k : ℕ) ↦
                    Real.partialSum(
                        (i : ℕ) ↦ a(i) * b(k ∸ i),
                        1 + k),
                n)
      by (n : ℕ) ↦ {
           Real.partialSum(a, n) * Real.partialSum(b, n)
                     + -(Real.partialSum(a, n) * Real.partialSum(b, n)
                         - Real.partialSum(
                               (k : ℕ) ↦
                                   Real.partialSum(
                                       (i : ℕ) ↦ a(i) * b(k ∸ i),
                                       1 + k),
                               n))
                 = Real.partialSum(
                       (k : ℕ) ↦
                           Real.partialSum(
                               (i : ℕ) ↦ a(i) * b(k ∸ i),
                               1 + k),
                       n)
               by ring;
           done
         };
  done by Real.SequenceConverges.of_pointwise(
              t := Real.partialSum(
                  (k : ℕ) ↦
                      Real.partialSum(
                          (i : ℕ) ↦ a(i) * b(k ∸ i),
                          1 + k)),
              sConverges := assembledAtProduct)
}

-- ----------------------------------------------------------------------
-- The functional equation: exp(x + y) = exp(x) · exp(y). The partial
-- sums of the series at x + y ARE the Cauchy-product triangle sums
-- (termwise, by the binomial split), and those converge to the product
-- of the limits by Mertens; limits are unique.
theorem Real.exponential_add (x y : ℝ)
        : exp(x + y) = exp(x) * exp(y) := {
  choose xAbsoluteLimit such that
      Real.SequenceConverges(
          Real.partialSum((k : ℕ) ↦ abs(Real.exponentialTerm(x, k))),
          xAbsoluteLimit)
      as xAbsolutelyConverges
      from Real.exponential_series_absolutely_convergent;
  choose yAbsoluteLimit such that
      Real.SequenceConverges(
          Real.partialSum((k : ℕ) ↦ abs(Real.exponentialTerm(y, k))),
          yAbsoluteLimit)
      as yAbsolutelyConverges
      from Real.exponential_series_absolutely_convergent;
  Real.SequenceConverges(
            Real.partialSum(Real.exponentialTerm(x)), exp(x))
      by Real.exponential_converges;
  Real.SequenceConverges(
            Real.partialSum(Real.exponentialTerm(y)), exp(y))
      by Real.exponential_converges;
  Real.SequenceConverges(
            Real.partialSum(
                (k : ℕ) ↦
                    Real.partialSum(
                        (i : ℕ) ↦
                            Real.exponentialTerm(x, i)
                            * Real.exponentialTerm(y, k ∸ i),
                        1 + k)),
            exp(x) * exp(y))
      by Real.cauchy_product_converges(
             aAbsolutelyConverges := xAbsolutelyConverges,
             bAbsolutelyConverges := yAbsolutelyConverges) as triangleConverges;
  ∀ (n : ℕ).
          Real.partialSum(
              (k : ℕ) ↦
                  Real.partialSum(
                      (i : ℕ) ↦
                          Real.exponentialTerm(x, i)
                          * Real.exponentialTerm(y, k ∸ i),
                      1 + k),
              n)
          = Real.partialSum(Real.exponentialTerm(x + y), n)
      by (n : ℕ) ↦
           Real.partialSum_pointwise(pointwiseEqual := (k : ℕ) ↦ {
                 Real.exponentialTerm(x + y, k)
                       = Real.partialSum(
                             (i : ℕ) ↦
                                 Real.exponentialTerm(x, i)
                                 * Real.exponentialTerm(y, k ∸ i),
                             1 + k)
                     by Real.exponentialTerm_binomial_split;
                 done
               });
  Real.SequenceConverges(
            Real.partialSum(Real.exponentialTerm(x + y)),
            exp(x) * exp(y))
      by Real.SequenceConverges.of_pointwise(
             s := Real.partialSum(
                 (k : ℕ) ↦
                     Real.partialSum(
                         (i : ℕ) ↦
                             Real.exponentialTerm(x, i)
                             * Real.exponentialTerm(y, k ∸ i),
                         1 + k)),
             t := Real.partialSum(Real.exponentialTerm(x + y)),
             sConverges := triangleConverges);
  Real.SequenceConverges(
            Real.partialSum(Real.exponentialTerm(x + y)),
            exp(x + y))
      by Real.exponential_converges;
  done by Real.SequenceConverges.unique
}

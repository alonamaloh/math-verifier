-- Real/field_bundle.math
--
-- ℝ as a bundled `Field`: `Real.commutative_ring` plus the two field
-- properties ℝ already proves (`Real.zero_not_equal_one`,
-- `Real.reciprocal_exists_for_nonzero`). The first concrete scalar
-- field for the linear-algebra layer.

module Real.field_bundle

import Logic.basics
import Logic.exists
import Equality.basics
import Algebra.ring
import Algebra.field
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.commutative_ring_algebra
import Algebra.field_bundle
import Real.basics
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.instances
import Real.ring_bundle
import Real.order
import Real.division
import Real.field

-- ℝ as a bundled field. The property arguments land at the
-- `CommutativeRing` projections of `Real.commutative_ring`, which
-- reduce to the concrete ℝ constants, so the existing lemmas fit
-- definitionally.
definition Real.field : Field :=
  Field.make(Real.commutative_ring, Real.zero_not_equal_one,
      Real.reciprocal_exists_for_nonzero)

-- Canonical `Field` for the carrier `Real`, like `Real.ring` for `Ring`.
instance Real.field

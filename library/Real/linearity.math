-- Real/linearity.math
--
-- Linearity / totality of the Real order. Real.apartness provides the
-- key analytic fact: a Cauchy sequence not equivalent to zero has
-- `|seq(m)| ≥ lowerBound` eventually, for some positive lowerBound.
-- Combined with the sequence's own Cauchy property at ε = lowerBound,
-- the sign of seq can't flip eventually: either seq(m) ≥ lowerBound
-- for all m past some signIndex, OR seq(m) ≤ -lowerBound for all m
-- past some signIndex. (Were the sign to flip, two terms separated
-- by more than 2·lowerBound would violate Cauchy at lowerBound.)
--
-- The strong-apartness statement above is the analytic content; the
-- order-theoretic wrappers built on top of it are:
--
--   * Real.IsNonneg_or_negate_IsNonneg : ∀x. IsNonneg(x) ∨ IsNonneg(-x)
--   * Real.LessOrEqual.linear           : ∀x y. x ≤ y ∨ y ≤ x
--   * Real.not_LessOrEqual_implies      : ¬(x ≤ y) → y ≤ x
--
-- Same shape as Rational.linearity, lifted through the Cauchy quotient.

module Real.linearity

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.maximum
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.triangle
import Rational.triangle_more
import Rational.linearity
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.ring
import Real.order
import Real.apartness

-- ----------------------------------------------------------------------
-- Step lemma (positive branch). If at some witness index `signIndex`
-- we know seq(signIndex) ≥ lowerBound, AND the sequence is Cauchy
-- within lowerBound past signIndex, AND |seq(k)| ≥ lowerBound past
-- signIndex, then seq(k) ≥ lowerBound for every k past signIndex.
--
-- Reason: |seq(k) - seq(signIndex)| < lowerBound gives seq(k) >
-- seq(signIndex) - lowerBound, and seq(signIndex) - lowerBound ≥ 0
-- by hypothesis, so seq(k) > 0. Combined with |seq(k)| ≥ lowerBound
-- and IsNonneg(seq(k)) we get seq(k) ≥ lowerBound.
theorem Real.cauchy_sign_eventually_positive_branch
        (sequence : Rational.sequence.Sequence)
        (lowerBound : Rational)
        (lowerBoundPositive : Rational.zero < lowerBound)
        (signIndex : Natural)
        (seqAtSignIndexBound : lowerBound ≤ sequence(signIndex))
        (apartnessTail
            : ∀ (m : Natural). signIndex ≤ m
              → lowerBound ≤ abs(sequence(m)))
        (cauchyTail
            : ∀ (m : Natural). signIndex ≤ m
              → ∀ (n : Natural). signIndex ≤ n
              → abs(sequence(m) - sequence(n))
                  < lowerBound)
        : ∀ (m : Natural). signIndex ≤ m
          → lowerBound ≤ sequence(m) :=
  (m : Natural) (mGeSignIndex : signIndex ≤ m) ↦ {
    claim lowerBound ≤ abs(sequence(m)) since apartnessTail;
    claim signIndex ≤ signIndex since Natural.LessOrEqual.reflexive;
    claim abs(sequence(m) - sequence(signIndex)) < lowerBound since cauchyTail;
    claim (-lowerBound < sequence(m) - sequence(signIndex))
            ∧ (sequence(m) - sequence(signIndex) < lowerBound)
      since Rational.absolute_value_LessThan_bounds;
    claim -lowerBound < sequence(m) - sequence(signIndex);
    calc sequence(signIndex) - lowerBound
            = sequence(signIndex) + -lowerBound
            < sequence(signIndex) + (sequence(m) - sequence(signIndex))
                 since Rational.add_left_preserves_LessThan
            = sequence(m);
    claim Rational.zero ≤ sequence(signIndex) - lowerBound;
    claim Rational.zero < sequence(m) since Rational.LessThan.transitive_left;
    claim Rational.IsNonneg(sequence(m)) since Rational.IsNonneg_of_LessOrEqual_zero;
    calc lowerBound
       ≤ abs(sequence(m))
       = sequence(m) since Rational.absolute_value_when_nonneg
  }

-- Symmetric step lemma (negative branch). seq(signIndex) ≤ -lowerBound
-- at the witness propagates to seq(m) ≤ -lowerBound past signIndex.
theorem Real.cauchy_sign_eventually_negative_branch
        (sequence : Rational.sequence.Sequence)
        (lowerBound : Rational)
        (lowerBoundPositive : Rational.zero < lowerBound)
        (signIndex : Natural)
        (seqAtSignIndexBound : sequence(signIndex) ≤ -lowerBound)
        (apartnessTail
            : ∀ (m : Natural). signIndex ≤ m
              → lowerBound ≤ abs(sequence(m)))
        (cauchyTail
            : ∀ (m : Natural). signIndex ≤ m
              → ∀ (n : Natural). signIndex ≤ n
              → abs(sequence(m) - sequence(n))
                  < lowerBound)
        : ∀ (m : Natural). signIndex ≤ m
          → sequence(m) ≤ -lowerBound :=
  (m : Natural) (mGeSignIndex : signIndex ≤ m) ↦ {
    claim lowerBound ≤ abs(sequence(m)) since apartnessTail;
    claim signIndex ≤ signIndex since Natural.LessOrEqual.reflexive;
    claim abs(sequence(m) - sequence(signIndex)) < lowerBound since cauchyTail;
    claim (-lowerBound < sequence(m) - sequence(signIndex))
            ∧ (sequence(m) - sequence(signIndex) < lowerBound)
      since Rational.absolute_value_LessThan_bounds;
    claim sequence(m) - sequence(signIndex) < lowerBound;
    calc sequence(m)
            = sequence(signIndex) + (sequence(m) - sequence(signIndex))
            < sequence(signIndex) + lowerBound
                 since Rational.add_left_preserves_LessThan;
    calc sequence(signIndex) + lowerBound
            ≤ -lowerBound + lowerBound since Rational.add_preserves_LessOrEqual
            = Rational.zero;
    claim sequence(m) < Rational.zero since Rational.LessThan.transitive_right;
    claim sequence(m) ≤ Rational.zero since Rational.LessThan.weaken;
    claim Rational.zero ≤ -sequence(m) since Rational.LessOrEqual.negate;
    claim Rational.IsNonneg(-sequence(m)) since Rational.IsNonneg_of_LessOrEqual_zero;
    calc lowerBound
            ≤ abs(sequence(m))
            = -sequence(m) since Rational.absolute_value_when_negate_nonneg;
    calc sequence(m)
       = -(-sequence(m))
       ≤ -lowerBound since Rational.LessOrEqual.negate
  }

-- ----------------------------------------------------------------------
-- Cauchy sign-eventually lemma. A non-zero Cauchy sequence is eventually
-- bounded away from zero on one side: either ≥ lowerBound eventually,
-- or ≤ -lowerBound eventually, for some positive lowerBound.

theorem Real.cauchy_sign_eventually
        (sequence : CauchyRationalSequence)
        (notEquivalentToZero
            : Not(CauchyEquivalent(
                      sequence,
                      Rational.to_cauchy_constant(Rational.zero))))
        : ∃ (lowerBound : Rational).
            Rational.zero < lowerBound ∧ ∃ (signIndex : Natural).
                (∀ (m : Natural). signIndex ≤ m
                    → lowerBound
                      ≤ CauchyRationalSequence.sequenceFunction(
                            sequence, m)) ∨ ∀ (m : Natural). signIndex ≤ m
                    → CauchyRationalSequence.sequenceFunction(
                          sequence, m)
                        ≤ -lowerBound := {
    claim apartnessExists
          : ∃ (lowerBound : Rational). ∃ (apartnessIndex : Natural).
              Rational.zero < lowerBound ∧ ∀ (m : Natural). apartnessIndex ≤ m →
                lowerBound ≤ abs(CauchyRationalSequence.sequenceFunction(sequence, m))
      since Real.cauchy_apartness_from_zero;
    choose lowerBound as lowerBoundData from apartnessExists;
    choose apartnessIndex as lowerAndApartness from lowerBoundData;
    claim lowerBoundPositive : Rational.zero < lowerBound;
    claim apartness
          : ∀ (m : Natural). apartnessIndex ≤ m →
              lowerBound ≤ abs(CauchyRationalSequence.sequenceFunction(sequence, m));
    claim cauchyExists
          : ∃ (cauchyIndex : Natural). ∀ (m : Natural). cauchyIndex ≤ m →
              ∀ (n : Natural). cauchyIndex ≤ n →
                abs(CauchyRationalSequence.sequenceFunction(sequence, m)
                    - CauchyRationalSequence.sequenceFunction(sequence, n)) < lowerBound
      since CauchyRationalSequence.isCauchy;
    choose cauchyIndex as cauchyAt from cauchyExists;
    let signIndex : Natural :=
        Natural.maximum(apartnessIndex, cauchyIndex);
    claim signIndex ≤ signIndex since Natural.LessOrEqual.reflexive;
    claim apartnessIndex ≤ signIndex since Natural.le_through_max_left;
    claim lowerBound
            ≤ abs(CauchyRationalSequence.sequenceFunction(sequence, signIndex))
      since apartness;
    claim ∀ (m : Natural). signIndex ≤ m
            → lowerBound
              ≤ abs(
                    CauchyRationalSequence.sequenceFunction(
                        sequence, m))
      by (m : Natural) (mGeSign : signIndex ≤ m) ↦ {
           claim apartnessIndex ≤ m since Natural.le_through_max_left;
           claim lowerBound ≤ abs(CauchyRationalSequence.sequenceFunction(sequence, m))
             since apartness;
           done
         };
    claim ∀ (m : Natural). signIndex ≤ m
            → ∀ (n : Natural). signIndex ≤ n
            → abs(
                  CauchyRationalSequence.sequenceFunction(sequence, m)
                  - CauchyRationalSequence.sequenceFunction(sequence, n))
                < lowerBound
      by (m : Natural) (mGeSign : signIndex ≤ m)
         (n : Natural) (nGeSign : signIndex ≤ n) ↦ {
           claim cauchyIndex ≤ m since Natural.le_through_max_right;
           claim cauchyIndex ≤ n since Natural.le_through_max_right;
           claim abs(CauchyRationalSequence.sequenceFunction(sequence, m)
                     - CauchyRationalSequence.sequenceFunction(sequence, n)) < lowerBound
             since cauchyAt;
           done
         };
    witness lowerBound with And.introduction(
        lowerBoundPositive,
        witness signIndex with claim by cases {
          in (Rational.IsNonneg(CauchyRationalSequence.sequenceFunction(sequence, signIndex)))
              as seqIsNonneg: {
            calc lowerBound
               ≤ abs(CauchyRationalSequence.sequenceFunction(sequence, signIndex))
               = CauchyRationalSequence.sequenceFunction(sequence, signIndex)
                    since Rational.absolute_value_when_nonneg;
            claim ∀ (m : Natural). signIndex ≤ m
                    → lowerBound ≤ CauchyRationalSequence.sequenceFunction(sequence, m)
              since Real.cauchy_sign_eventually_positive_branch;
            done
          }
          in (Rational.IsNonneg(-CauchyRationalSequence.sequenceFunction(sequence, signIndex)))
              as seqNegateIsNonneg: {
            calc lowerBound
               ≤ abs(CauchyRationalSequence.sequenceFunction(sequence, signIndex))
               = -CauchyRationalSequence.sequenceFunction(sequence, signIndex)
                    since Rational.absolute_value_when_negate_nonneg;
            calc CauchyRationalSequence.sequenceFunction(sequence, signIndex)
               = -(-CauchyRationalSequence.sequenceFunction(sequence, signIndex))
               ≤ -lowerBound since Rational.LessOrEqual.negate;
            claim ∀ (m : Natural). signIndex ≤ m
                    → CauchyRationalSequence.sequenceFunction(sequence, m) ≤ -lowerBound
              since Real.cauchy_sign_eventually_negative_branch;
            done
          }
        })
}

-- ----------------------------------------------------------------------
-- Lift cauchy_sign_eventually to the Real level: every Real x admits
-- IsNonneg(x) ∨ IsNonneg(-x).
--
-- Case-split on (x = 0): if equal, IsNonneg(0) handles it. Otherwise,
-- Quotient.induct on x, derive ¬CauchyEquivalent from the inequality
-- via Quotient.equivalent_implies_equal's contrapositive, feed it to cauchy_sign_eventually
-- and turn the "eventually ≥ lowerBound" / "eventually ≤ -lowerBound"
-- bounds into the IsEventuallyNonneg shape (-ε < seq) by chaining
-- through 0 < lowerBound > -ε.

theorem Real.IsNonneg_or_negate_IsNonneg
        (x : Real)
        : Real.IsNonneg(x) ∨ Real.IsNonneg(-x) :=
  decide x = Real.zero {
    | yes xEqZero => {
        claim Real.IsNonneg(Real.zero) since Real.IsNonneg_zero;
        claim Real.IsNonneg(x) by substituting xEqZero;
        done
      }
    | no xNotEqZero =>
        cases x refining xNotEqZero { | rep =>
              ({
                claim Not(CauchyEquivalent(
                            rep,
                            Rational.to_cauchy_constant(Rational.zero)))
                    by (representativesEquivalent
                            : CauchyEquivalent(
                                  rep, Rational.to_cauchy_constant(Rational.zero))) ↦
                         xNotEqZero(Quotient.equivalent_implies_equal(
                                        CauchyRationalSequence, CauchyEquivalent,
                                        rep, Rational.to_cauchy_constant(Rational.zero),
                                        representativesEquivalent));
                claim signEventually
                      : ∃ (lowerBound : Rational).
                          Rational.zero < lowerBound ∧ ∃ (signIndex : Natural).
                              (∀ (m : Natural). signIndex ≤ m
                                  → lowerBound
                                    ≤ CauchyRationalSequence.sequenceFunction(rep, m))
                              ∨ ∀ (m : Natural). signIndex ≤ m
                                  → CauchyRationalSequence.sequenceFunction(rep, m)
                                      ≤ -lowerBound
                  since Real.cauchy_sign_eventually;
                choose lowerBound as lowerAndSignData from signEventually;
                claim Rational.zero < lowerBound;
                claim signData
                      : ∃ (signIndex : Natural).
                          (∀ (m : Natural). signIndex ≤ m
                              → lowerBound
                                ≤ CauchyRationalSequence.sequenceFunction(rep, m))
                          ∨ ∀ (m : Natural). signIndex ≤ m
                              → CauchyRationalSequence.sequenceFunction(rep, m)
                                  ≤ -lowerBound;
                choose signIndex from signData;
                claim by cases {
                  in (∀ (m : Natural). signIndex ≤ m
                        → lowerBound ≤ CauchyRationalSequence.sequenceFunction(rep, m))
                      as eventuallyPositive: {
                    claim CauchyRationalSequence.IsEventuallyNonneg(rep)
                      by (epsilon : Rational)
                         (epsilonPositive : Rational.zero < epsilon) ↦
                          witness signIndex with
                              (m : Natural) (mGeSign : signIndex ≤ m) ↦
                                calc -epsilon
                                   < Rational.zero
                                        since Rational.negate_LessThan_zero_of_positive
                                   < lowerBound
                                   ≤ CauchyRationalSequence.sequenceFunction(rep, m);
                    claim Real.IsNonneg((Quotient.class_of(rep) : Real))
                      since Real.IsNonneg.of_eventually_nonneg;
                    done
                  }
                  in (∀ (m : Natural). signIndex ≤ m
                        → CauchyRationalSequence.sequenceFunction(rep, m) ≤ -lowerBound)
                      as eventuallyNegative: {
                    claim CauchyRationalSequence.IsEventuallyNonneg(CauchyRationalSequence.negate(rep))
                      by (epsilon : Rational)
                         (epsilonPositive : Rational.zero < epsilon) ↦
                          witness signIndex with
                              (m : Natural) (mGeSign : signIndex ≤ m) ↦ {
                                claim CauchyRationalSequence.sequenceFunction(rep, m)
                                        ≤ -lowerBound;
                                calc lowerBound
                                   = -(-lowerBound)
                                   ≤ -CauchyRationalSequence.sequenceFunction(rep, m)
                                        since Rational.LessOrEqual.negate;
                                calc -epsilon
                                   < Rational.zero
                                        since Rational.negate_LessThan_zero_of_positive
                                   < lowerBound
                                   ≤ -CauchyRationalSequence.sequenceFunction(rep, m)
                                   = CauchyRationalSequence.sequenceFunction(
                                         CauchyRationalSequence.negate(rep), m)
                                        since CauchyRationalSequence.sequenceFunction_negate;
                                done
                              };
                    claim Real.IsNonneg(-(Quotient.class_of(rep) : Real))
                      since Real.IsNonneg.of_eventually_nonneg;
                    done
                  }
                }
              } : Real.IsNonneg((Quotient.class_of(rep) : Real)) ∨ Real.IsNonneg(-(Quotient.class_of(rep) : Real))) }
  }

-- ----------------------------------------------------------------------
-- Total order on Real. From the disjunction on signs of (y - x), one
-- side gives IsNonneg(y - x) = (x ≤ y), the other gives IsNonneg(-(y -
-- x)) = IsNonneg(x - y) = (y ≤ x).

theorem Real.LessOrEqual.linear
        (x y : Real)
        : x ≤ y ∨ y ≤ x :=
  claim by cases {
    in (Real.IsNonneg(y - x)) as diffNonneg: {
        claim x ≤ y;
        done
      }
    in (Real.IsNonneg(-(y - x))) as negDiffNonneg: {
        claim y ≤ x by substituting (ring : -(y - x) = x - y);
        done
      }
  }

-- ----------------------------------------------------------------------
-- Contrapositive of ≤: ¬(x ≤ y) → y ≤ x. Same shape as
-- Rational.not_LessThan_implies_LessOrEqual but on the non-strict
-- order — needed for translating "midpoint not above y" into
-- "midpoint ≤ y" in the bisection's classical no-branch.

theorem Real.not_LessOrEqual_implies
        (x y : Real)
        (notXLeqY : Not(x ≤ y))
        : y ≤ x :=
  claim by cases {
    in (x ≤ y) as xLeqY: absurd(notXLeqY(xLeqY))
    in (y ≤ x) as yLeqX: yLeqX
  }


-- Contrapositive on the strict side: ¬(y < x) → x ≤ y. By linearity,
-- either x ≤ y outright, or y ≤ x — and then y = x (else y < x).
theorem Real.LessOrEqual_of_not_LessThan
        (x y : Real)
        (notLess : Not(y < x))
        : x ≤ y :=
  claim by cases {
    in (x ≤ y) as xLeqY: xLeqY
    in (y ≤ x) as yLeqX:
        decide x = y {
          | yes equal => {
              claim x ≤ x since Real.LessOrEqual.reflexive;
              claim x ≤ y by substituting equal;
              done
            }
          | no notEqual => {
              claim ¬(y = x)
                  by (yEqualsX : y = x) ↦
                      notEqual(calc x = y);
              claim yLessX : y < x;
              absurd(notLess(yLessX))
            }
        }
  }

-- Strict form of the contrapositive: ¬(x ≤ y) forces y < x outright —
-- weakly by linearity, strictly because y = x would make x ≤ y hold
-- by reflexivity.
theorem Real.LessThan_of_not_LessOrEqual
        (x y : Real)
        (notXLeqY : Not(x ≤ y))
        : y < x := {
  claim yLeqX : y ≤ x since Real.not_LessOrEqual_implies;
  claim yNotX : ¬(y = x)
      by (yEqualsX : y = x) ↦ {
           claim x ≤ x since Real.LessOrEqual.reflexive;
           claim xLeqY : x ≤ y by substituting yEqualsX;
           notXLeqY(xLeqY)
         };
  And.introduction(yLeqX, yNotX)
}

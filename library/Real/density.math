-- Real/density.math
--
-- A positive real exceeds some positive rational. This is the bridge
-- every ε–δ argument needs when the gap it works with is a *real*
-- quantity (|f(c)| > 0, say) but the tolerance fed to a continuity or
-- convergence hypothesis must be *rational*.
--
-- Proof: descend to a Cauchy representative. By the sign-eventually
-- dichotomy (Real.linearity), a representative of a nonzero real is
-- eventually trapped on one side of some positive rational lowerBound;
-- the negative side contradicts 0 < x, and on the positive side
-- halve(lowerBound) is the witness. This is a foundation-file descent:
-- downstream analysis cites only the Real-level statement.

module Real.density

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.order
import Rational.basics
import Rational.addition
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.halve
import Rational.order_multiplication
import Rational.positive
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.ring
import Real.order
import Real.embedding_order
import Real.linearity

-- ----------------------------------------------------------------------
-- 0 < x yields a rational q with 0 < q and (q : ℝ) < x.
theorem Real.exists_positive_rational_below
        (x : Real) (xPositive : Real.zero < x)
        : ∃ (q : Rational). Rational.zero < q ∧ q < x := {
  cases x {
    | CauchyRationalSequence.make(seq, seqCauchy) => {
        ¬(Real.zero = Real.from_cauchy_sequence(seq, seqCauchy));
        ¬CauchyEquivalent(
              CauchyRationalSequence.make(seq, seqCauchy),
              Rational.to_cauchy_constant(Rational.zero))
            by (equivalent : CauchyEquivalent(
                                 CauchyRationalSequence.make(seq, seqCauchy),
                                 Rational.to_cauchy_constant(Rational.zero))) ↦ {
                CauchyEquivalent(
                    Rational.to_cauchy_constant(Rational.zero),
                    CauchyRationalSequence.make(seq, seqCauchy))
                    by CauchyEquivalent.symmetric;
                Real.zero = Real.from_cauchy_sequence(seq, seqCauchy)
                    by Quotient.equivalent_implies_equal;
                done
              };
        ∃ (lowerBound : Rational).
            Rational.zero < lowerBound ∧ ∃ (signIndex : Natural).
                (∀ (m : Natural). signIndex ≤ m
                    → lowerBound
                      ≤ CauchyRationalSequence.sequenceFunction(
                            CauchyRationalSequence.make(seq, seqCauchy), m))
                ∨ ∀ (m : Natural). signIndex ≤ m
                    → CauchyRationalSequence.sequenceFunction(
                          CauchyRationalSequence.make(seq, seqCauchy), m)
                        ≤ -lowerBound
          by Real.cauchy_sign_eventually as signEventually;
        choose lowerBound from signEventually;
        Rational.zero < lowerBound;
        ∃ (signIndex : Natural).
            (∀ (m : Natural). signIndex ≤ m
                → lowerBound
                  ≤ CauchyRationalSequence.sequenceFunction(
                        CauchyRationalSequence.make(seq, seqCauchy), m))
            ∨ ∀ (m : Natural). signIndex ≤ m
                → CauchyRationalSequence.sequenceFunction(
                      CauchyRationalSequence.make(seq, seqCauchy), m)
                    ≤ -lowerBound as signData;
        choose signIndex from signData;
        done by cases {
          -- seq(m) ≥ lowerBound past signIndex: then (lowerBound : ℝ)
          -- ≤ x, and halve(lowerBound) is the rational we want.
          case (∀ (m : Natural). signIndex ≤ m
                → lowerBound
                  ≤ CauchyRationalSequence.sequenceFunction(
                        CauchyRationalSequence.make(seq, seqCauchy), m))
              as positiveTail: {
              (lowerBound : Real)
                      ≤ (Quotient.class_of(
                             CauchyRationalSequence.make(seq, seqCauchy))
                         : Real)
                  by unfold Real.IsNonneg in
                     ((ε : Rational)
                     (εPositive : Rational.zero < ε) ↦
                       witness signIndex with
                           (m : Natural)
                           (mPastSignIndex : signIndex ≤ m) ↦ {
                             lowerBound ≤ seq(m)
                                 by positiveTail(m, mPastSignIndex);
                             -ε
                                < Rational.zero
                                      by Rational.negate_LessThan_zero_of_positive
                                ≤ seq(m) - lowerBound
                           })
                  as lowerBoundBelowX;
              Rational.zero < Rational.halve(lowerBound);
              Rational.halve(lowerBound) < lowerBound
                  by Rational.halve_less_than_self;
              witness Rational.halve(lowerBound) with {
                  (Rational.halve(lowerBound) : Real)
                     < (lowerBound : Real)
                           by Rational.to_real.LessThan_preserves
                     ≤ (Quotient.class_of(
                            CauchyRationalSequence.make(seq, seqCauchy))
                        : Real)
                           by lowerBoundBelowX;
                  done
              }
            }
          -- seq(m) ≤ -lowerBound past signIndex: then x ≤ (−lowerBound
          -- : ℝ) < 0, contradicting 0 < x.
          case (∀ (m : Natural). signIndex ≤ m
                → CauchyRationalSequence.sequenceFunction(
                      CauchyRationalSequence.make(seq, seqCauchy), m)
                    ≤ -lowerBound)
              as negativeTail: {
              (Quotient.class_of(
                     CauchyRationalSequence.make(seq, seqCauchy))
                 : Real)
                      ≤ (-lowerBound : Real)
                  by unfold Real.IsNonneg in
                     ((ε : Rational)
                     (εPositive : Rational.zero < ε) ↦
                       witness signIndex with
                           (m : Natural)
                           (mPastSignIndex : signIndex ≤ m) ↦ {
                             seq(m) ≤ -lowerBound
                                 by negativeTail(m, mPastSignIndex);
                             -ε
                                < Rational.zero
                                      by Rational.negate_LessThan_zero_of_positive
                                ≤ -lowerBound - seq(m)
                           });
              -lowerBound < Rational.zero
                  by Rational.negate_LessThan_zero_of_positive;
              (-lowerBound : Real) < Real.zero
                  by Rational.to_real.LessThan_preserves;
              (Quotient.class_of(
                     CauchyRationalSequence.make(seq, seqCauchy))
                 : Real)
                      < Real.zero
                  by Real.LessThan.transitive_left;
              (Quotient.class_of(
                   CauchyRationalSequence.make(seq, seqCauchy))
               : Real)
                    ≤ Real.zero;
              Real.zero < Real.zero
                  by Real.LessThan.transitive_right;
              False;
              done
            }
        }
      }
  }
}

-- Boundary lemmas for the SEALED Real interface (D Phase-1). Inside the
-- construction each of these is a definitional identity; through the
-- interface (where the carrier and operations are abstract constants)
-- they are the bridges consumers cite. This module sits at the TOP of
-- the construction — only the Real.cauchy roll-up imports it — so its
-- indexed equalities never enter construction-side proof searches
-- (partialSum definitionally IS the fold, and indexing that identity
-- perturbs matcher-unfolding searches in files that load it).
module Real.interface_boundary

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Algebra.monoid
import Algebra.aggregation
import Rational.basics
import Real.basics
import Real.addition
import Real.instances
import Real.sequence
import Real.series

-- The fold/ellipsis notation meets the partial-sum vocabulary: stated
-- fold-first with the binder form's eta-expanded term function, so
-- consumer-side binder-form goals match it syntactically.
theorem Real.fold_as_partialSum (s : ℕ → ℝ) (n : ℕ)
        : Algebra.Fold(ℝ, Real.add, Real.zero, (k : ℕ) ↦ s(k), 0, n) = Real.partialSum(s, n) :=
  done

-- Real/series.math
--
-- Infinite series as limits of partial sums, and the geometric series
-- (Freek #66): for |r| < 1 the powers of r sum to the inverse of 1 − r.
--
-- The partial sums satisfy the closed form (1 − r)·Sₙ = 1 − rⁿ (a ring
-- induction), so Sₙ − L = −rⁿ·L whenever (1 − r)·L = 1, and the error
-- is |r|ⁿ·|L| — geometric decay times a constant. A rational roof over
-- |L| turns the decay tolerance into the requested ε.

module Real.series

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Integer.basics
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.absolute_value
import Rational.triangle
import Rational.triangle_more
import Rational.positive
import Rational.linearity
import Rational.reciprocal
import Rational.reciprocal_function
import Rational.archimedean
import Rational.power
import Algebra.ring_lemmas
import Set.basics
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.instances
import Real.order
import Real.linearity
import Real.embedding_order
import Real.order_multiplication
import Real.apartness
import Real.reciprocal
import Real.field
import Real.order_field
import Real.density
import Real.absolute_value
import Real.absolute_value_order
import Real.convergence
import Real.supremum
import Real.limits
import Real.power

-- ----------------------------------------------------------------------
-- Partial sums: Σ_{k < n} s(k), by recursion on n.
definition Real.partialSum (s : Natural → Real) : Natural → Real
  | zero => Real.zero
  | successor(n) => Real.partialSum(s, n) + s(n)

-- A series converges to a total when its partial sums do.
definition Real.SeriesConverges
        (s : Natural → Real) (total : Real) : Proposition :=
  Real.SequenceConverges(Real.partialSum(s), total)

-- ----------------------------------------------------------------------
-- The geometric closed form: (1 − r)·Σ_{k<n} rᵏ = 1 − rⁿ. The sum
-- telescopes one factor at a time.
theorem Real.geometric_partialSum (r : Real) (n : Natural)
        : (Real.one - r)
              * Real.partialSum((k : Natural) ↦ Real.power(r, k), n)
          = Real.one - Real.power(r, n) :=
  by_induction on n with IH {
    case zero:
        calc (Real.one - r)
                 * Real.partialSum((k : Natural) ↦ Real.power(r, k), 0)
           = (Real.one - r) * Real.zero
           = Real.one - Real.one
           = Real.one - Real.power(r, 0)
    case successor(predecessor):
        calc (Real.one - r)
                 * Real.partialSum(
                       (k : Natural) ↦ Real.power(r, k), successor(predecessor))
           = (Real.one - r)
                 * (Real.partialSum((k : Natural) ↦ Real.power(r, k), predecessor)
                    + Real.power(r, predecessor))
           = (Real.one - r)
                 * Real.partialSum((k : Natural) ↦ Real.power(r, k), predecessor)
             + (Real.one - r) * Real.power(r, predecessor)
           = (Real.one - Real.power(r, predecessor))
             + (Real.one - r) * Real.power(r, predecessor)
                 since IH
           = Real.one - r * Real.power(r, predecessor)
           = Real.one - Real.power(r, successor(predecessor))
  }

-- ----------------------------------------------------------------------
-- Convergence of the geometric series to a given inverse L of 1 − r.
theorem Real.geometric_series_converges
        (r L : Real)
        (rSmall : abs(r) < Real.one)
        (inverseProperty : (Real.one - r) * L = Real.one)
        : Real.SeriesConverges((k : Natural) ↦ Real.power(r, k), L) :=
  (epsilon : Rational) (epsilonPositive : Rational.zero < epsilon) ↦ {
    claim absRNonneg : Real.zero ≤ abs(r)
        since Real.absolute_value_nonneg;
    -- A positive rational roof over |L|.
    claim Real.zero ≤ abs(L)
        since Real.absolute_value_nonneg;
    obtain ⟨B, LRoof⟩ from Real.exists_rational_above(abs(L));
    claim castStep : ((B + Rational.one) : Real)
                     = (B : Real) + (Rational.one : Real)
        since Rational.to_real.add_preserves;
    claim Rational.zero < Rational.one by Rational.zero_less_one;
    claim Real.zero < (Rational.one : Real)
        since Rational.to_real.positive_preserves;
    calc Real.zero ≤ abs(L) ≤ (B : Real);
    calc Real.zero
       ≤ (B : Real)
       = (B : Real) + Real.zero
       < (B : Real) + (Rational.one : Real)
             by Real.add_left_preserves_LessThan;
    claim (Rational.zero : Real) < ((B + Rational.one) : Real)
        by substituting castStep;
    claim Rational.zero < B + Rational.one
        since Rational.to_real.LessThan_reflects;
    claim abs(L) ≤ ((B + Rational.one) : Real)
        by { claim abs(L) < (B : Real) + (Rational.one : Real)
                 by calc abs(L)
                       ≤ (B : Real)        by LRoof
                       = (B : Real) + Real.zero    by ring
                       < (B : Real) + (Rational.one : Real)
                             by Real.add_left_preserves_LessThan;
             claim abs(L) ≤ (B : Real) + (Rational.one : Real)
                 since Real.LessThan.weaken;
             done by substituting castStep };
    -- The scaled tolerance ε/(B+1), and the decay tail at it.
    claim Rational.zero < Rational.reciprocal_function(B + Rational.one)
        since Rational.reciprocal_function_positive_of_positive;
    claim scaledPositive
          : Rational.zero
            < epsilon * Rational.reciprocal_function(B + Rational.one)
        since Rational.multiply_positive_positive;
    obtain ⟨N, tailBelow⟩
        from Real.power_eventually_below(
                 abs(r), absRNonneg, rSmall,
                 epsilon * Rational.reciprocal_function(B + Rational.one),
                 scaledPositive);
    -- Scaling back: (ε/(B+1))·(B+1) = ε.
    claim ¬(B + Rational.one = Rational.zero);
    claim recipProduct
          : (B + Rational.one)
                * Rational.reciprocal_function(B + Rational.one)
            = Rational.one;
    claim toleranceProduct
          : (epsilon * Rational.reciprocal_function(B + Rational.one))
                * (B + Rational.one)
            = epsilon
        by calc (epsilon * Rational.reciprocal_function(B + Rational.one))
                    * (B + Rational.one)
              = epsilon
                    * ((B + Rational.one)
                       * Rational.reciprocal_function(B + Rational.one))
                    by ring
              = epsilon * Rational.one    by recipProduct
              = epsilon                   by ring;
    witness N with
        (m : Natural) (NLeqM : N ≤ m) ↦ {
          claim Real.power(abs(r), m)
                  < ((epsilon * Rational.reciprocal_function(B + Rational.one))
                     : Real)
              by tailBelow(m, NLeqM);
          -- Sₘ = (1 − rᵐ)·L, so the error is exactly |r|ᵐ·|L|.
          claim sumFormula
                : Real.partialSum((k : Natural) ↦ Real.power(r, k), m)
                  = (Real.one - Real.power(r, m)) * L
              by calc Real.partialSum((k : Natural) ↦ Real.power(r, k), m)
                    = Real.partialSum((k : Natural) ↦ Real.power(r, k), m)
                          * Real.one
                          by ring
                    = Real.partialSum((k : Natural) ↦ Real.power(r, k), m)
                          * ((Real.one - r) * L)
                          by inverseProperty
                    = ((Real.one - r)
                       * Real.partialSum((k : Natural) ↦ Real.power(r, k), m))
                          * L
                          by ring
                    = (Real.one - Real.power(r, m)) * L
                          by Real.geometric_partialSum(r, m);
          claim absDifference
                : abs(Real.partialSum((k : Natural) ↦ Real.power(r, k), m) - L)
                  = Real.power(abs(r), m) * abs(L)
              by calc abs(Real.partialSum((k : Natural) ↦ Real.power(r, k), m)
                          - L)
                    = abs((Real.one - Real.power(r, m)) * L - L)
                          by sumFormula
                    = abs(-(Real.power(r, m) * L))
                          by substituting
                              (ring : (Real.one - Real.power(r, m)) * L - L
                                  = -(Real.power(r, m) * L))
                    = abs(Real.power(r, m) * L)
                          by Real.absolute_value_negate(Real.power(r, m) * L)
                    = abs(Real.power(r, m)) * abs(L)
                          by Real.absolute_value_multiplicative(
                                 Real.power(r, m), L)
                    = Real.power(abs(r), m) * abs(L)
                          by Real.absolute_value_power(r, m);
          -- |r|ᵐ·|L| ≤ |r|ᵐ·(B+1) < (ε/(B+1))·(B+1) = ε.
          claim Real.zero ≤ Real.power(abs(r), m)
              since Real.power_nonneg;
          claim Real.IsNonneg(Real.power(abs(r), m))
              since Real.IsNonneg_of_LessOrEqual_zero;
          claim finalBound
                : Real.power(abs(r), m) * abs(L) < (epsilon : Real)
              by calc Real.power(abs(r), m) * abs(L)
                    = abs(L) * Real.power(abs(r), m)
                          by ring
                    ≤ ((B + Rational.one) : Real) * Real.power(abs(r), m)
                          since Real.LessOrEqual.multiply_by_nonneg_right
                    = Real.power(abs(r), m) * ((B + Rational.one) : Real)
                          by ring
                    < ((epsilon
                        * Rational.reciprocal_function(B + Rational.one))
                       : Real)
                          * ((B + Rational.one) : Real)
                          since Real.LessThan.multiply_by_positive_right
                    = (((epsilon
                         * Rational.reciprocal_function(B + Rational.one))
                        * (B + Rational.one) : Rational) : Real)
                          by Rational.to_real.multiply_preserves(
                                 epsilon
                                 * Rational.reciprocal_function(B + Rational.one),
                                 B + Rational.one)
                    = (epsilon : Real)
                          by toleranceProduct;
          calc abs(Real.partialSum((k : Natural) ↦ Real.power(r, k), m) - L)
             = Real.power(abs(r), m) * abs(L)    by absDifference
             < (epsilon : Real)                  by finalBound
        }
  }

-- ----------------------------------------------------------------------
-- Freek #66: the geometric series. For |r| < 1 there is an inverse L
-- of 1 − r — the sum of the series — and Σ rᵏ converges to it.
theorem Real.geometric_series (r : Real) (rSmall : abs(r) < Real.one)
        : ∃ (L : Real).
            And((Real.one - r) * L = Real.one,
                Real.SeriesConverges((k : Natural) ↦ Real.power(r, k), L)) := {
  claim r ≤ abs(r) since Real.LessOrEqual_absolute_value;
  claim r < Real.one since Real.LessThan.transitive_left;
  claim Real.zero < Real.one - r
      by calc Real.zero
            = r - r             by ring
            < Real.one - r      by Real.add_preserves_LessThan;
  claim zeroNotGap : ¬(Real.zero = Real.one - r)
      since Real.LessThan.distinct;
  claim gapNotZero : ¬(Real.one - r = Real.zero)
      by (gapZero : Real.one - r = Real.zero) ↦
           zeroNotGap(calc Real.zero = Real.one - r by gapZero);
  obtain ⟨L, inverseProperty⟩
      from Real.reciprocal_exists_for_nonzero(Real.one - r, gapNotZero);
  witness L with
      And.introduction(
          inverseProperty,
          Real.geometric_series_converges(r, L, rSmall, inverseProperty))
}

-- ----------------------------------------------------------------------
-- Partial sums only see the terms' values.
theorem Real.partialSum_pointwise
        (s sequencePrime : Natural → Real)
        (pointwiseEqual : (k : Natural) → s(k) = sequencePrime(k))
        (n : Natural)
        : Real.partialSum(s, n) = Real.partialSum(sequencePrime, n) :=
  by_induction on n with IH {
    case zero: done
    case successor(predecessor):
        calc Real.partialSum(s, successor(predecessor))
           = Real.partialSum(s, predecessor) + s(predecessor)
           = Real.partialSum(sequencePrime, predecessor) + s(predecessor)
                 since IH
           = Real.partialSum(sequencePrime, predecessor)
             + sequencePrime(predecessor)
                 by pointwiseEqual(predecessor)
  }

-- The bounded variant: agreement below the cut is enough (the terms at
-- or above n are never read). What the unbounded version cannot give
-- when the identity genuinely fails past the cut — e.g. binomial
-- coefficients that overflow to zero.
theorem Real.partialSum_pointwise_below
        (s sequencePrime : Natural → Real)
        : (n : Natural)
          → ((k : Natural) → successor(k) ≤ n → s(k) = sequencePrime(k))
          → Real.partialSum(s, n) = Real.partialSum(sequencePrime, n)
  | zero =>
      (pointwiseEqual : (k : Natural) → successor(k) ≤ 0
           → s(k) = sequencePrime(k)) ↦
        done
  | successor(predecessor) =>
      (pointwiseEqual : (k : Natural) → successor(k) ≤ successor(predecessor)
           → s(k) = sequencePrime(k)) ↦ {
        claim tailEqual
            : Real.partialSum(s, predecessor)
              = Real.partialSum(sequencePrime, predecessor)
            by Real.partialSum_pointwise_below(s, sequencePrime, predecessor,
                   (k : Natural) (kBelow : successor(k) ≤ predecessor) ↦ {
                     claim predecessor ≤ successor(predecessor)
                         since Natural.le_successor;
                     claim successor(k) ≤ successor(predecessor)
                         since LessOrEqual.transitive;
                     done by pointwiseEqual(k, (successor(k) ≤ successor(predecessor)))
                   });
        claim successor(predecessor) ≤ successor(predecessor);
        claim headEqual : s(predecessor) = sequencePrime(predecessor)
            by pointwiseEqual(predecessor,
                   (successor(predecessor) ≤ successor(predecessor)));
        calc Real.partialSum(s, successor(predecessor))
           = Real.partialSum(s, predecessor) + s(predecessor)
           = Real.partialSum(sequencePrime, predecessor) + s(predecessor)
                 since tailEqual
           = Real.partialSum(sequencePrime, predecessor) + sequencePrime(predecessor)
                 since headEqual
      }

-- A telescoping sum collapses to its boundary terms.
theorem Real.telescoping_partialSum
        (t : Natural → Real) (n : Natural)
        : Real.partialSum((k : Natural) ↦ t(k) - t(1 + k), n)
          = t(0) - t(n) :=
  by_induction on n with IH {
    case zero:
        calc Real.partialSum((k : Natural) ↦ t(k) - t(1 + k), 0)
           = Real.zero
           = t(0) - t(0)    by ring
    case successor(predecessor):
        calc Real.partialSum(
                 (k : Natural) ↦ t(k) - t(1 + k), successor(predecessor))
           = Real.partialSum((k : Natural) ↦ t(k) - t(1 + k), predecessor)
             + (t(predecessor) - t(1 + predecessor))
           = (t(0) - t(predecessor)) + (t(predecessor) - t(1 + predecessor))
                 since IH
           = t(0) - t(1 + predecessor)
                 by ring
  }

-- ----------------------------------------------------------------------
-- Splitting a partial sum at a cut: the part below n, plus the block
-- of k terms shifted past n.
theorem Real.partialSum_split (s : Natural → Real) (n k : Natural)
        : Real.partialSum(s, k + n)
          = Real.partialSum(s, n)
            + Real.partialSum((j : Natural) ↦ s(n + j), k) :=
  by_induction on k with IH {
    case zero:
        calc Real.partialSum(s, 0 + n)
           = Real.partialSum(s, n)
           = Real.partialSum(s, n) + Real.zero    by ring
           = Real.partialSum(s, n)
             + Real.partialSum((j : Natural) ↦ s(n + j), 0)
    case successor(predecessor):
        calc Real.partialSum(s, successor(predecessor) + n)
           = Real.partialSum(s, predecessor + n) + s(predecessor + n)
           = (Real.partialSum(s, n)
              + Real.partialSum((j : Natural) ↦ s(n + j), predecessor))
             + s(predecessor + n)
                 since IH
           = (Real.partialSum(s, n)
              + Real.partialSum((j : Natural) ↦ s(n + j), predecessor))
             + s(n + predecessor)
                 by (predecessor + n = n + predecessor)
           = Real.partialSum(s, n)
             + Real.partialSum((j : Natural) ↦ s(n + j), successor(predecessor))
  }

-- Termwise comparison below the cut compares the partial sums.
theorem Real.partialSum_le_pointwise (s t : Natural → Real) (n : Natural)
        (termsBounded : (j : Natural) → successor(j) ≤ n → s(j) ≤ t(j))
        : Real.partialSum(s, n) ≤ Real.partialSum(t, n) :=
  by_induction on n with IH refining termsBounded {
    case zero: {
        claim Real.zero ≤ Real.zero since Real.LessOrEqual.reflexive;
        done
      }
    case successor(predecessor): {
        claim prefixBounded
              : (j : Natural) → successor(j) ≤ predecessor → s(j) ≤ t(j)
            by (j : Natural) (jBelow : successor(j) ≤ predecessor) ↦
                 termsBounded(
                     j, LessOrEqual.step(successor(j), predecessor, jBelow));
        claim Real.partialSum(s, predecessor) ≤ Real.partialSum(t, predecessor)
            by IH(prefixBounded);
        claim successor(predecessor) ≤ successor(predecessor);
        claim s(predecessor) ≤ t(predecessor)
            by termsBounded(predecessor, (successor(predecessor) ≤ successor(predecessor)));
        calc Real.partialSum(s, successor(predecessor))
           = Real.partialSum(s, predecessor) + s(predecessor)
           ≤ Real.partialSum(t, predecessor) + s(predecessor)
                 by Real.add_preserves_LessOrEqual
           ≤ Real.partialSum(t, predecessor) + t(predecessor)
                 by Real.add_preserves_LessOrEqual_left
      }
  }

-- Sums of nonnegative terms are nonnegative.
theorem Real.partialSum_nonneg (s : Natural → Real) (n : Natural)
        (termsNonneg : (j : Natural) → Real.zero ≤ s(j))
        : Real.zero ≤ Real.partialSum(s, n) :=
  by_induction on n with IH {
    case zero: {
        claim Real.zero ≤ Real.zero since Real.LessOrEqual.reflexive;
        done
      }
    case successor(predecessor): {
        claim Real.zero ≤ s(predecessor) by termsNonneg(predecessor);
        calc Real.zero
           = Real.zero + Real.zero    by ring
           ≤ Real.partialSum(s, predecessor) + Real.zero
                 by Real.add_preserves_LessOrEqual
           ≤ Real.partialSum(s, predecessor) + s(predecessor)
                 by Real.add_preserves_LessOrEqual_left
      }
  }

-- … so partial sums of nonnegative terms only grow.
theorem Real.partialSum_monotone_of_nonneg (s : Natural → Real)
        (termsNonneg : (j : Natural) → Real.zero ≤ s(j))
        (N m : Natural) (NLeqM : N ≤ m)
        : Real.partialSum(s, N) ≤ Real.partialSum(s, m) := {
  obtain ⟨k, mEq⟩ by Natural.le_to_add;
  claim Real.zero ≤ Real.partialSum((j : Natural) ↦ s(N + j), k)
      by Real.partialSum_nonneg(
             (j : Natural) ↦ s(N + j), k,
             (j : Natural) ↦ termsNonneg(N + j));
  claim Real.partialSum(s, N) ≤ Real.partialSum(s, k + N)
      by calc Real.partialSum(s, N)
            = Real.partialSum(s, N) + Real.zero    by ring
            ≤ Real.partialSum(s, N)
              + Real.partialSum((j : Natural) ↦ s(N + j), k)
                  by Real.add_preserves_LessOrEqual_left
            = Real.partialSum(s, k + N)
                  by Real.partialSum_split(s, N, k);
  claim by substitution
}

-- A constant block sums to (its length)·(the constant), with the
-- scalar carried by the linearGrowth closed form.
theorem Real.partialSum_constant_cast (c : Rational) (n : Natural)
        : Real.partialSum((j : Natural) ↦ (c : Real), n)
          = ((Rational.linearGrowth(c, n) - Rational.one : Rational) : Real) :=
  by_induction on n with IH {
    case zero: {
        claim zeroUnfold : Rational.linearGrowth(c, 0) = Rational.one;
        calc Real.partialSum((j : Natural) ↦ (c : Real), 0)
           = (Rational.zero : Real)
           = ((Rational.one - Rational.one : Rational) : Real)
                 by (Rational.zero = Rational.one - Rational.one)
           = ((Rational.linearGrowth(c, 0) - Rational.one : Rational) : Real)
                 by zeroUnfold
      }
    case successor(predecessor): {
        claim stepUnfold
              : Rational.linearGrowth(c, successor(predecessor))
                = Rational.linearGrowth(c, predecessor) + c;
        calc Real.partialSum((j : Natural) ↦ (c : Real), successor(predecessor))
           = Real.partialSum((j : Natural) ↦ (c : Real), predecessor)
             + (c : Real)
           = ((Rational.linearGrowth(c, predecessor) - Rational.one
               : Rational) : Real)
             + (c : Real)
                 since IH
           = ((Rational.linearGrowth(c, predecessor) - Rational.one + c
               : Rational) : Real)
                 since Rational.to_real.add_preserves
           = ((Rational.linearGrowth(c, predecessor) + c - Rational.one
               : Rational) : Real)
                 by (Rational.linearGrowth(c, predecessor) - Rational.one + c
                     = Rational.linearGrowth(c, predecessor) + c
                       - Rational.one)
           = ((Rational.linearGrowth(c, successor(predecessor)) - Rational.one
               : Rational) : Real)
                 by stepUnfold
      }
  }

-- ----------------------------------------------------------------------
-- Linearity of partial sums: they split over termwise sums and pull
-- out constant factors.
theorem Real.partialSum_add (s t : Natural → Real) (n : Natural)
        : Real.partialSum((k : Natural) ↦ s(k) + t(k), n)
          = Real.partialSum(s, n) + Real.partialSum(t, n) :=
  by_induction on n with IH {
    case zero:
        calc Real.partialSum((k : Natural) ↦ s(k) + t(k), 0)
           = Real.zero
           = Real.zero + Real.zero
    case successor(predecessor):
        calc Real.partialSum((k : Natural) ↦ s(k) + t(k), successor(predecessor))
           = Real.partialSum((k : Natural) ↦ s(k) + t(k), predecessor)
             + (s(predecessor) + t(predecessor))
           = (Real.partialSum(s, predecessor) + Real.partialSum(t, predecessor))
             + (s(predecessor) + t(predecessor))
                 since IH
           = (Real.partialSum(s, predecessor) + s(predecessor))
             + (Real.partialSum(t, predecessor) + t(predecessor))
                 by ring
  }

theorem Real.partialSum_scale (c : Real) (s : Natural → Real) (n : Natural)
        : Real.partialSum((k : Natural) ↦ c * s(k), n)
          = c * Real.partialSum(s, n) :=
  by_induction on n with IH {
    case zero:
        calc Real.partialSum((k : Natural) ↦ c * s(k), 0)
           = Real.zero
           = c * Real.zero    by ring
    case successor(predecessor):
        calc Real.partialSum((k : Natural) ↦ c * s(k), successor(predecessor))
           = Real.partialSum((k : Natural) ↦ c * s(k), predecessor)
             + c * s(predecessor)
           = c * Real.partialSum(s, predecessor) + c * s(predecessor)
                 since IH
           = c * (Real.partialSum(s, predecessor) + s(predecessor))
                 by ring
  }

-- A sum of nonnegative terms vanishes only if every term below the cut
-- does: each term is squeezed between zero and the whole sum.
theorem Real.partialSum_zero_term (s : Natural → Real) (n : Natural)
        (termsNonneg : (j : Natural) → Real.zero ≤ s(j))
        (sumZero : Real.partialSum(s, n) = Real.zero)
        (j : Natural) (jBelow : successor(j) ≤ n)
        : s(j) = Real.zero := {
  obtain ⟨k, splitEquation⟩ by Natural.le_to_add;
  -- s(j) ≤ Σ_{i < j+1} s(i) ≤ Σ_{i < n} s(i) = 0.
  claim Real.zero ≤ Real.partialSum(s, j)
      by Real.partialSum_nonneg(s, j, termsNonneg);
  claim headBound : s(j) ≤ Real.partialSum(s, successor(j))
      by calc s(j)
            = Real.zero + s(j)                       by ring
            ≤ Real.partialSum(s, j) + s(j)
                  by Real.add_preserves_LessOrEqual;
  claim tailBound : Real.partialSum(s, successor(j)) ≤ Real.partialSum(s, n)
      by Real.partialSum_monotone_of_nonneg(
             s, termsNonneg, successor(j), n, jBelow);
  claim s(j) ≤ Real.zero
      by calc s(j)
            ≤ Real.partialSum(s, successor(j))    by headBound
            ≤ Real.partialSum(s, n)               by tailBound
            = Real.zero                           by sumZero;
  claim Real.zero ≤ s(j) by termsNonneg(j);
  done since Real.LessOrEqual.antisymmetric
}

-- The zero series sums to zero.
theorem Real.partialSum_zero (n : Natural)
        : Real.partialSum((k : Natural) ↦ Real.zero, n) = Real.zero :=
  by_induction on n with IH {
    case zero: done
    case successor(predecessor):
        calc Real.partialSum((k : Natural) ↦ Real.zero, successor(predecessor))
           = Real.partialSum((k : Natural) ↦ Real.zero, predecessor) + Real.zero
           = Real.zero + Real.zero    since IH
           = Real.zero
  }

-- Termwise equality below the cut gives equal partial sums.
theorem Real.partialSum_pointwise_bounded
        (s sequencePrime : Natural → Real) (n : Natural)
        (termsEqual : (j : Natural) → successor(j) ≤ n
                      → s(j) = sequencePrime(j))
        : Real.partialSum(s, n) = Real.partialSum(sequencePrime, n) :=
  by_induction on n with IH refining termsEqual {
    case zero: done
    case successor(predecessor): {
        claim prefixEqual
              : (j : Natural) → successor(j) ≤ predecessor
                → s(j) = sequencePrime(j)
            by (j : Natural) (jBelow : successor(j) ≤ predecessor) ↦
                 termsEqual(
                     j, LessOrEqual.step(successor(j), predecessor, jBelow));
        claim successor(predecessor) ≤ successor(predecessor);
        claim topEqual : s(predecessor) = sequencePrime(predecessor)
            by termsEqual(
                   predecessor,
                   (successor(predecessor) ≤ successor(predecessor)));
        calc Real.partialSum(s, successor(predecessor))
           = Real.partialSum(s, predecessor) + s(predecessor)
           = Real.partialSum(sequencePrime, predecessor) + s(predecessor)
                 by IH(prefixEqual)
           = Real.partialSum(sequencePrime, predecessor)
             + sequencePrime(predecessor)
                 by topEqual
      }
  }

-- ----------------------------------------------------------------------
-- The triangle inequality for partial sums: |Σ s(k)| ≤ Σ |s(k)|.
theorem Real.abs_partialSum_le (s : Natural → Real) (n : Natural)
        : abs(Real.partialSum(s, n))
          ≤ Real.partialSum((k : Natural) ↦ abs(s(k)), n) :=
  by_induction on n with IH {
    case zero: {
        claim Real.IsNonneg(Real.zero) since Real.IsNonneg_zero;
        claim absZero : abs(Real.zero) = Real.zero
            since Real.absolute_value_when_nonneg;
        claim Real.zero ≤ Real.zero since Real.LessOrEqual.reflexive;
        done by substituting absZero
      }
    case successor(predecessor):
        calc abs(Real.partialSum(s, successor(predecessor)))
           = abs(Real.partialSum(s, predecessor) + s(predecessor))
           ≤ abs(Real.partialSum(s, predecessor)) + abs(s(predecessor))
                 by Real.triangle_inequality
           ≤ Real.partialSum((k : Natural) ↦ abs(s(k)), predecessor)
             + abs(s(predecessor))
                 by Real.add_preserves_LessOrEqual
           = Real.partialSum((k : Natural) ↦ abs(s(k)), successor(predecessor))
  }

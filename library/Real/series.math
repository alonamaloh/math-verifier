-- Real/series.math
--
-- Infinite series as limits of partial sums, and the geometric series
-- (Freek #66): for |r| < 1 the powers of r sum to the inverse of 1 − r.
--
-- The partial sums satisfy the closed form (1 − r)·Sₙ = 1 − rⁿ (a ring
-- induction), so Sₙ − L = −rⁿ·L whenever (1 − r)·L = 1, and the error
-- is |r|ⁿ·|L| — geometric decay times a constant. A rational roof over
-- |L| turns the decay tolerance into the requested ε.

module Real.series

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Integer.basics
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.absolute_value
import Rational.triangle
import Rational.triangle_more
import Rational.positive
import Rational.linearity
import Rational.reciprocal
import Rational.reciprocal_function
import Rational.archimedean
import Rational.power
import Algebra.ring_lemmas
import Algebra.aggregation
import Set.basics
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.instances
import Real.order
import Real.linearity
import Real.embedding_order
import Real.order_multiplication
import Real.apartness
import Real.reciprocal
import Real.field
import Real.order_field
import Real.density
import Real.absolute_value
import Real.absolute_value_order
import Real.convergence
import Real.supremum
import Real.limits
import Real.power

-- ----------------------------------------------------------------------
-- Partial sums: Σ_{k < n} s(k) — the additive instance of the generic
-- aggregation, over Real's additive commutative monoid.
definition Real.partialSum (s : Natural → Real) (n : Natural) : Real :=
  Algebra.indexedAggregate(Real, Real.add, Real.zero, s, n)

-- The recursion characterised in `1 + n` form, so consumers step the
-- index without naming the raw constructor (`Natural.add` is opaque, so
-- `1 + n` is not definitionally the constructor form; bridge via `one_add`).
theorem Real.partialSum_add_one (s : Natural → Real) (n : Natural)
        : Real.partialSum(s, 1 + n) = Real.partialSum(s, n) + s(n) :=
  done by substituting Natural.one_add

-- A series converges to a total when its partial sums do.
definition Real.SeriesConverges
        (s : Natural → Real) (total : Real) : Proposition :=
  Real.SequenceConverges(Real.partialSum(s), total)

-- ----------------------------------------------------------------------
-- The geometric closed form: (1 − r)·Σ_{k<n} rᵏ = 1 − rⁿ. The sum
-- telescopes one factor at a time.
theorem Real.geometric_partialSum (r : Real) (n : Natural)
        : (Real.one - r)
              * Real.partialSum((k : Natural) ↦ Real.power(r, k), n)
          = Real.one - Real.power(r, n) :=
  by_induction on n with IH {
    case base:
        calc (Real.one - r)
                 * Real.partialSum((k : Natural) ↦ Real.power(r, k), 0)
           = (Real.one - r) * Real.zero
           = Real.one - Real.one
           = Real.one - Real.power(r, 0)
    case step(predecessor):
        calc (Real.one - r)
                 * Real.partialSum(
                       (k : Natural) ↦ Real.power(r, k), 1 + predecessor)
           = (Real.one - r)
                 * (Real.partialSum((k : Natural) ↦ Real.power(r, k), predecessor)
                    + Real.power(r, predecessor))
                 by substituting Real.partialSum_add_one
           = (Real.one - r)
                 * Real.partialSum((k : Natural) ↦ Real.power(r, k), predecessor)
             + (Real.one - r) * Real.power(r, predecessor)
           = (Real.one - Real.power(r, predecessor))
             + (Real.one - r) * Real.power(r, predecessor)
                 since IH
           = Real.one - r * Real.power(r, predecessor)
           = Real.one - Real.power(r, 1 + predecessor)
                 by substituting Real.power_add_one
  }

-- ----------------------------------------------------------------------
-- Convergence of the geometric series to a given inverse L of 1 − r.
theorem Real.geometric_series_converges
        (r L : Real)
        (rSmall : abs(r) < Real.one)
        (inverseProperty : (Real.one - r) * L = Real.one)
        : Real.SeriesConverges((k : Natural) ↦ Real.power(r, k), L) :=
  -- The decay tolerance is scaled at the rational layer, so build the
  -- partial-sum convergence at a rational ε and lift it by density.
  {
    claim ∀ (ε : Rational). ε > Rational.zero →
            ∃ (N : Natural). ∀ (m : Natural). N ≤ m →
              abs(Real.partialSum((k : Natural) ↦ Real.power(r, k), m) - L)
              < (ε : Real)
        by (ε : Rational) (εPositive : ε > Rational.zero) ↦ {
          claim Real.zero ≤ abs(r) since Real.absolute_value_nonneg;
          claim absLNonneg : Real.zero ≤ abs(L) since Real.absolute_value_nonneg;
          -- The positive rational roof B + 1 over |L|.
          choose B such that abs(L) ≤ (B : Real) as LRoof
              from Real.exists_rational_above;
          claim castStep : ((B + Rational.one) : Real) = (B : Real) + (Rational.one : Real)
              since Rational.to_real.add_preserves;
          claim Rational.one > Rational.zero since Rational.zero_less_one;
          claim (Rational.one : Real) > Real.zero since Rational.to_real.positive_preserves;
          calc abs(L)
             ≤ (B : Real)                           since LRoof
             = (B : Real) + Real.zero
             < (B : Real) + (Rational.one : Real)   by Real.add_left_preserves_LessThan
             = ((B + Rational.one) : Real)          since castStep
             as absStrictRoof;
          claim abs(L) ≤ ((B + Rational.one) : Real) since Real.LessThan.weaken;
          calc (Rational.zero : Real)
             ≤ abs(L)                       since absLNonneg
             < ((B + Rational.one) : Real)  since absStrictRoof;
          claim B + Rational.one > Rational.zero since Rational.to_real.LessThan_reflects;
          -- The scaled tolerance ε/(B + 1), and the decay tail below it.
          claim Rational.reciprocal_function(B + Rational.one) > Rational.zero
              since Rational.reciprocal_function_positive_of_positive;
          claim ε * Rational.reciprocal_function(B + Rational.one) > Rational.zero;
          choose N such that
              ∀ (m : Natural). N ≤ m →
                Real.power(abs(r), m)
                < ((ε * Rational.reciprocal_function(B + Rational.one)) : Real)
              as tailBelow
              from Real.power_eventually_below;
          -- Scaling back: (ε/(B + 1))·(B + 1) = ε.
          claim B + Rational.one ≠ Rational.zero;
          claim recipProduct
                : (B + Rational.one) * Rational.reciprocal_function(B + Rational.one)
                  = Rational.one;
          calc (ε * Rational.reciprocal_function(B + Rational.one)) * (B + Rational.one)
             = ε * ((B + Rational.one) * Rational.reciprocal_function(B + Rational.one))
                   by ring
             = ε * Rational.one    since recipProduct
             = ε
             as toleranceProduct;
          witness N with {
            take m : Natural;
            take NLeqM : N ≤ m;
            claim Real.power(abs(r), m)
                  < ((ε * Rational.reciprocal_function(B + Rational.one)) : Real)
                by tailBelow(m, NLeqM);
            -- Sₘ = (1 − rᵐ)·L, so the error is exactly |r|ᵐ·|L|.
            calc Real.partialSum((k : Natural) ↦ Real.power(r, k), m)
               = Real.partialSum((k : Natural) ↦ Real.power(r, k), m) * Real.one
               = Real.partialSum((k : Natural) ↦ Real.power(r, k), m)
                     * ((Real.one - r) * L)
                     by inverseProperty
               = ((Real.one - r)
                  * Real.partialSum((k : Natural) ↦ Real.power(r, k), m)) * L
                     by ring
               = (Real.one - Real.power(r, m)) * L
                     by Real.geometric_partialSum
               as sumFormula;
            calc abs(Real.partialSum((k : Natural) ↦ Real.power(r, k), m) - L)
               = abs((Real.one - Real.power(r, m)) * L - L)
                     since sumFormula
               = abs(-(Real.power(r, m) * L))
                     by substituting
                         (ring : (Real.one - Real.power(r, m)) * L - L
                             = -(Real.power(r, m) * L))
               = abs(Real.power(r, m) * L)
               = abs(Real.power(r, m)) * abs(L)
               = Real.power(abs(r), m) * abs(L)         by Real.absolute_value_power
               as absDifference;
            -- |r|ᵐ·|L| ≤ |r|ᵐ·(B + 1) < (ε/(B + 1))·(B + 1) = ε.
            claim Real.zero ≤ Real.power(abs(r), m) since Real.power_nonneg;
            claim Real.IsNonneg(Real.power(abs(r), m));
            calc Real.power(abs(r), m) * abs(L)
               = abs(L) * Real.power(abs(r), m)
               ≤ ((B + Rational.one) : Real) * Real.power(abs(r), m)
                     since Real.LessOrEqual.multiply_by_nonneg_right
               = Real.power(abs(r), m) * ((B + Rational.one) : Real)
               < ((ε * Rational.reciprocal_function(B + Rational.one)) : Real)
                     * ((B + Rational.one) : Real)
                     since Real.LessThan.multiply_by_positive_right
               = (((ε * Rational.reciprocal_function(B + Rational.one))
                   * (B + Rational.one) : Rational) : Real)
               = (ε : Real)                                          by toleranceProduct
               as finalBound;
            calc abs(Real.partialSum((k : Natural) ↦ Real.power(r, k), m) - L)
               = Real.power(abs(r), m) * abs(L)    by absDifference
               < (ε : Real)                        by finalBound
          }
        };
    done by Real.SequenceConverges.of_rational
  }

-- ----------------------------------------------------------------------
-- Freek #66: the geometric series. For |r| < 1 there is an inverse L
-- of 1 − r — the sum of the series — and Σ rᵏ converges to it.
theorem Real.geometric_series (r : Real) (rSmall : abs(r) < Real.one)
        : ∃ (L : Real).
            (Real.one - r) * L = Real.one ∧ Real.SeriesConverges((k : Natural) ↦ Real.power(r, k), L) := {
  claim r ≤ abs(r) since Real.LessOrEqual_absolute_value;
  claim r < Real.one since Real.LessThan.transitive_left;
  calc Real.zero
     = r - r
     < Real.one - r      by Real.add_preserves_LessThan;
  claim Real.one - r ≠ Real.zero since Real.nonzero_of_positive;
  choose L such that (Real.one - r) * L = Real.one as inverseProperty
      from Real.reciprocal_exists_for_nonzero;
  claim Real.SeriesConverges((k : Natural) ↦ Real.power(r, k), L)
      since Real.geometric_series_converges;
  witness L with done
}

-- ----------------------------------------------------------------------
-- Partial sums only see the terms' values.
theorem Real.partialSum_pointwise
        (s sequencePrime : Natural → Real)
        (pointwiseEqual : ∀ (k : Natural). s(k) = sequencePrime(k))
        (n : Natural)
        : Real.partialSum(s, n) = Real.partialSum(sequencePrime, n) :=
  Algebra.indexedAggregate_pointwise(pointwiseEqual := pointwiseEqual)

-- The bounded variant: agreement below the cut is enough (the terms at
-- or above n are never read). What the unbounded version cannot give
-- when the identity genuinely fails past the cut — e.g. binomial
-- coefficients that overflow to zero.
theorem Real.partialSum_pointwise_below
        (s sequencePrime : Natural → Real) (n : Natural)
        (pointwiseEqual : ∀ (k : Natural). k < n → s(k) = sequencePrime(k))
        : Real.partialSum(s, n) = Real.partialSum(sequencePrime, n) :=
  Algebra.indexedAggregate_pointwise_below(pointwiseEqual := pointwiseEqual)

-- A telescoping sum collapses to its boundary terms.
theorem Real.telescoping_partialSum
        (t : Natural → Real) (n : Natural)
        : Real.partialSum((k : Natural) ↦ t(k) - t(1 + k), n)
          = t(0) - t(n) :=
  by_induction on n with IH {
    case base:
        calc Real.partialSum((k : Natural) ↦ t(k) - t(1 + k), 0)
           = Real.zero
           = t(0) - t(0)
    case step(predecessor):
        calc Real.partialSum(
                 (k : Natural) ↦ t(k) - t(1 + k), 1 + predecessor)
           = Real.partialSum((k : Natural) ↦ t(k) - t(1 + k), predecessor)
             + (t(predecessor) - t(1 + predecessor))
                 by Real.partialSum_add_one
           = (t(0) - t(predecessor)) + (t(predecessor) - t(1 + predecessor))
                 since IH
           = t(0) - t(1 + predecessor)
                 by ring
  }

-- ----------------------------------------------------------------------
-- Splitting a partial sum at a cut: the part below n, plus the block
-- of k terms shifted past n.
theorem Real.partialSum_split (s : Natural → Real) (n k : Natural)
        : Real.partialSum(s, k + n)
          = Real.partialSum(s, n)
            + Real.partialSum((j : Natural) ↦ s(n + j), k) :=
  Algebra.indexedAggregate_split(associativity := Real.add_associative,
      identityRight := Real.add_zero)

-- Termwise comparison below the cut compares the partial sums.
theorem Real.partialSum_le_pointwise (s t : Natural → Real) (n : Natural)
        (termsBounded : ∀ (j : Natural). j < n → s(j) ≤ t(j))
        : Real.partialSum(s, n) ≤ Real.partialSum(t, n) :=
  by_induction on n with IH refining termsBounded {
    case base: { claim Real.zero ≤ Real.zero; done }
    case step(predecessor): {
        claim predecessorBelow : predecessor < 1 + predecessor since Natural.lt_one_plus;
        claim prefixBounded
              : ∀ (j : Natural). j < predecessor → s(j) ≤ t(j)
            by (j : Natural) (jBelow : j < predecessor) ↦ {
                 claim jBelowStep : j < 1 + predecessor since Natural.lt_transitive;
                 done since termsBounded(j, jBelowStep)
               };
        claim Real.partialSum(s, predecessor) ≤ Real.partialSum(t, predecessor)
            since IH(prefixBounded);
        claim s(predecessor) ≤ t(predecessor)
            since termsBounded(predecessor, predecessorBelow);
        calc Real.partialSum(s, 1 + predecessor)
           = Real.partialSum(s, predecessor) + s(predecessor)
           ≤ Real.partialSum(t, predecessor) + s(predecessor)
           ≤ Real.partialSum(t, predecessor) + t(predecessor)
                 by Real.add_preserves_LessOrEqual_left
           = Real.partialSum(t, 1 + predecessor)
      }
  }

-- Sums of nonnegative terms are nonnegative.
theorem Real.partialSum_nonneg (s : Natural → Real) (n : Natural)
        (termsNonneg : ∀ (j : Natural). Real.zero ≤ s(j))
        : Real.zero ≤ Real.partialSum(s, n) :=
  by_induction on n with IH {
    case base: { claim Real.zero ≤ Real.zero; done }
    case step(predecessor): {
        claim Real.zero ≤ s(predecessor) since termsNonneg(predecessor);
        calc Real.zero
           = Real.zero + Real.zero
           ≤ Real.partialSum(s, predecessor) + Real.zero
           ≤ Real.partialSum(s, predecessor) + s(predecessor)
                 by Real.add_preserves_LessOrEqual_left
           = Real.partialSum(s, 1 + predecessor)
      }
  }

-- … so partial sums of nonnegative terms only grow.
theorem Real.partialSum_monotone_of_nonneg (s : Natural → Real)
        (termsNonneg : ∀ (j : Natural). Real.zero ≤ s(j))
        (N m : Natural) (NLeqM : N ≤ m)
        : Real.partialSum(s, N) ≤ Real.partialSum(s, m) := {
  choose k such that m = k + N from Natural.le_to_add;
  claim ∀ (j : Natural). Real.zero ≤ s(N + j) by (j : Natural) ↦ termsNonneg(N + j);
  claim Real.zero ≤ Real.partialSum((j : Natural) ↦ s(N + j), k)
      since Real.partialSum_nonneg;
  calc Real.partialSum(s, N)
     = Real.partialSum(s, N) + Real.zero
     ≤ Real.partialSum(s, N) + Real.partialSum((j : Natural) ↦ s(N + j), k)
           by Real.add_preserves_LessOrEqual_left
     = Real.partialSum(s, k + N)
     = Real.partialSum(s, m)
}

-- A constant block sums to (its length)·(the constant), with the
-- scalar carried by the linearGrowth closed form.
theorem Real.partialSum_constant_cast (c : Rational) (n : Natural)
        : Real.partialSum((j : Natural) ↦ (c : Real), n)
          = ((Rational.linearGrowth(c, n) - Rational.one : Rational) : Real) :=
  by_induction on n with IH {
    case base: {
        claim Rational.linearGrowth(c, 0) = Rational.one;
        calc Real.partialSum((j : Natural) ↦ (c : Real), 0)
           = (Rational.zero : Real)
           = ((Rational.one - Rational.one : Rational) : Real)
                 by (Rational.zero = Rational.one - Rational.one)
           = ((Rational.linearGrowth(c, 0) - Rational.one : Rational) : Real)
      }
    case step(predecessor): {
        calc Real.partialSum((j : Natural) ↦ (c : Real), 1 + predecessor)
           = Real.partialSum((j : Natural) ↦ (c : Real), predecessor)
             + (c : Real)
                 by Real.partialSum_add_one
           = ((Rational.linearGrowth(c, predecessor) - Rational.one
               : Rational) : Real)
             + (c : Real)
                 since IH
           = ((Rational.linearGrowth(c, predecessor) - Rational.one + c
               : Rational) : Real)
                 since Rational.to_real.add_preserves
           = ((Rational.linearGrowth(c, predecessor) + c - Rational.one
               : Rational) : Real)
                 by (Rational.linearGrowth(c, predecessor) - Rational.one + c
                     = Rational.linearGrowth(c, predecessor) + c
                       - Rational.one)
           = ((Rational.linearGrowth(c, 1 + predecessor) - Rational.one
               : Rational) : Real)
                 by substituting Rational.linearGrowth_add_one
      }
  }

-- ----------------------------------------------------------------------
-- Linearity of partial sums: they split over termwise sums and pull
-- out constant factors.
theorem Real.partialSum_add (s t : Natural → Real) (n : Natural)
        : Real.partialSum((k : Natural) ↦ s(k) + t(k), n)
          = Real.partialSum(s, n) + Real.partialSum(t, n) :=
  Algebra.indexedAggregate_add(associativity := Real.add_associative,
      commutativity := Real.add_commutative, identityLeft := Real.zero_add)

theorem Real.partialSum_scale (c : Real) (s : Natural → Real) (n : Natural)
        : Real.partialSum((k : Natural) ↦ c * s(k), n)
          = c * Real.partialSum(s, n) :=
  Algebra.indexedAggregate_scale(
      distributes := (x : Real) (y : Real) ↦ (ring : c * (x + y) = c * x + c * y),
      scaleIdentity := (ring : c * Real.zero = Real.zero))

-- Negating every term negates the sum.
theorem Real.partialSum_negate (s : Natural → Real) (n : Natural)
        : Real.partialSum((k : Natural) ↦ -s(k), n)
          = -Real.partialSum(s, n) :=
  by_induction on n with IH {
    case base:
        calc Real.partialSum((k : Natural) ↦ -s(k), 0)
           = Real.zero
           = -Real.zero
    case step(predecessor):
        calc Real.partialSum((k : Natural) ↦ -s(k), 1 + predecessor)
           = Real.partialSum((k : Natural) ↦ -s(k), predecessor)
             + -s(predecessor)
                 by Real.partialSum_add_one
           = -Real.partialSum(s, predecessor) + -s(predecessor)
                 since IH
           = -(Real.partialSum(s, predecessor) + s(predecessor))
           = -Real.partialSum(s, 1 + predecessor)
                 by substituting Real.partialSum_add_one
  }

-- Sums subtract termwise.
theorem Real.partialSum_subtract (s t : Natural → Real) (n : Natural)
        : Real.partialSum((k : Natural) ↦ s(k) - t(k), n)
          = Real.partialSum(s, n) - Real.partialSum(t, n) :=
  by_induction on n with IH {
    case base:
        calc Real.partialSum((k : Natural) ↦ s(k) - t(k), 0)
           = Real.zero
           = Real.zero - Real.zero
    case step(predecessor):
        calc Real.partialSum((k : Natural) ↦ s(k) - t(k), 1 + predecessor)
           = Real.partialSum((k : Natural) ↦ s(k) - t(k), predecessor)
             + (s(predecessor) - t(predecessor))
                 by Real.partialSum_add_one
           = (Real.partialSum(s, predecessor) - Real.partialSum(t, predecessor))
             + (s(predecessor) - t(predecessor))
                 since IH
           = (Real.partialSum(s, predecessor) + s(predecessor))
             - (Real.partialSum(t, predecessor) + t(predecessor))
                 by ring
           = Real.partialSum(s, 1 + predecessor) - Real.partialSum(t, 1 + predecessor)
                 by substituting Real.partialSum_add_one
  }

-- Scaling on the right (a common factor behind every term).
theorem Real.partialSum_scale_right (s : Natural → Real) (c : Real) (n : Natural)
        : Real.partialSum((k : Natural) ↦ s(k) * c, n)
          = Real.partialSum(s, n) * c :=
  by_induction on n with IH {
    case base:
        calc Real.partialSum((k : Natural) ↦ s(k) * c, 0)
           = Real.zero
           = Real.zero * c    by ring
    case step(predecessor):
        calc Real.partialSum((k : Natural) ↦ s(k) * c, 1 + predecessor)
           = Real.partialSum((k : Natural) ↦ s(k) * c, predecessor)
             + s(predecessor) * c
                 by Real.partialSum_add_one
           = Real.partialSum(s, predecessor) * c + s(predecessor) * c
                 since IH
           = (Real.partialSum(s, predecessor) + s(predecessor)) * c
           = Real.partialSum(s, 1 + predecessor) * c
                 by substituting Real.partialSum_add_one
  }

-- A sum of nonnegative terms vanishes only if every term below the cut
-- does: each term is squeezed between zero and the whole sum.
theorem Real.partialSum_zero_term (s : Natural → Real) (n : Natural)
        (termsNonneg : ∀ (j : Natural). Real.zero ≤ s(j))
        (sumZero : Real.partialSum(s, n) = Real.zero)
        (j : Natural) (jBelow : j < n)
        : s(j) = Real.zero := {
  -- s(j) ≤ Σ_{i < j+1} s(i) ≤ Σ_{i < n} s(i) = 0.
  claim Real.zero ≤ Real.partialSum(s, j) since Real.partialSum_nonneg;
  calc s(j)
     = Real.zero + s(j)
     ≤ Real.partialSum(s, j) + s(j)
     = Real.partialSum(s, 1 + j)
     as headBound;
  claim 1 + j ≤ n
      by { claim j + 1 ≤ n by Natural.add_one_le_of_lt;
           done by substituting (ring : 1 + j = j + 1) };
  claim Real.partialSum(s, 1 + j) ≤ Real.partialSum(s, n)
      since Real.partialSum_monotone_of_nonneg;
  calc s(j)
     ≤ Real.partialSum(s, 1 + j)           by headBound
     ≤ Real.partialSum(s, n)
     = Real.zero                           since sumZero;
  claim Real.zero ≤ s(j) since termsNonneg(j);
  done since Real.LessOrEqual.antisymmetric
}

-- The zero series sums to zero.
theorem Real.partialSum_zero (n : Natural)
        : Real.partialSum((k : Natural) ↦ Real.zero, n) = Real.zero :=
  by_induction on n with IH {
    case base: done
    case step(predecessor):
        calc Real.partialSum((k : Natural) ↦ Real.zero, 1 + predecessor)
           = Real.partialSum((k : Natural) ↦ Real.zero, predecessor) + Real.zero
                 by Real.partialSum_add_one
           = Real.zero + Real.zero    since IH
           = Real.zero
  }

-- Termwise equality below the cut gives equal partial sums.
theorem Real.partialSum_pointwise_bounded
        (s sequencePrime : Natural → Real) (n : Natural)
        (termsEqual : ∀ (j : Natural). j < n
                      → s(j) = sequencePrime(j))
        : Real.partialSum(s, n) = Real.partialSum(sequencePrime, n) :=
  Algebra.indexedAggregate_pointwise_below(pointwiseEqual := termsEqual)

-- ----------------------------------------------------------------------
-- The triangle inequality for partial sums: |Σ s(k)| ≤ Σ |s(k)|.
theorem Real.abs_partialSum_le (s : Natural → Real) (n : Natural)
        : abs(Real.partialSum(s, n))
          ≤ Real.partialSum((k : Natural) ↦ abs(s(k)), n) :=
  by_induction on n with IH {
    case base: {
        claim Real.IsNonneg(Real.zero);
        claim absZero : abs(Real.zero) = Real.zero
            since Real.absolute_value_when_nonneg;
        calc abs(Real.partialSum(s, 0))
           = abs(Real.zero)
           = Real.zero                                            since absZero
           ≤ Real.zero
           = Real.partialSum((k : Natural) ↦ abs(s(k)), 0)
      }
    case step(predecessor):
        calc abs(Real.partialSum(s, 1 + predecessor))
           = abs(Real.partialSum(s, predecessor) + s(predecessor))
                 by substituting Real.partialSum_add_one
           ≤ abs(Real.partialSum(s, predecessor)) + abs(s(predecessor))
           ≤ Real.partialSum((k : Natural) ↦ abs(s(k)), predecessor)
             + abs(s(predecessor))
           = Real.partialSum((k : Natural) ↦ abs(s(k)), 1 + predecessor)
                 by substituting Real.partialSum_add_one
  }

-- A window of a sum is bounded by the same window of the absolute
-- series: |B(w+m) − B(m)| ≤ Babs(w+m) − Babs(m).
theorem Real.partialSum_window_bound (b : Natural → Real) (m w : Natural)
        : abs(Real.partialSum(b, w + m) - Real.partialSum(b, m))
          ≤ Real.partialSum((k : Natural) ↦ abs(b(k)), w + m)
            - Real.partialSum((k : Natural) ↦ abs(b(k)), m) := {
  claim signedSplit
      : Real.partialSum(b, w + m)
        = Real.partialSum(b, m)
          + Real.partialSum((j : Natural) ↦ b(m + j), w)
      since Real.partialSum_split;
  claim absSplit
      : Real.partialSum((k : Natural) ↦ abs(b(k)), w + m)
        = Real.partialSum((k : Natural) ↦ abs(b(k)), m)
          + Real.partialSum((j : Natural) ↦ abs(b(m + j)), w)
      by Real.partialSum_split;
  calc abs(Real.partialSum(b, w + m) - Real.partialSum(b, m))
     = abs((Real.partialSum(b, m)
                + Real.partialSum((j : Natural) ↦ b(m + j), w))
           - Real.partialSum(b, m))
           since signedSplit
     = abs(Real.partialSum((j : Natural) ↦ b(m + j), w))
           by substituting
               (ring : Real.partialSum((j : Natural) ↦ b(m + j), w)
                   = (Real.partialSum(b, m)
                          + Real.partialSum((j : Natural) ↦ b(m + j), w))
                     - Real.partialSum(b, m))
     ≤ Real.partialSum((j : Natural) ↦ abs(b(m + j)), w)
           by Real.abs_partialSum_le
     = (Real.partialSum((k : Natural) ↦ abs(b(k)), m)
            + Real.partialSum((j : Natural) ↦ abs(b(m + j)), w))
       - Real.partialSum((k : Natural) ↦ abs(b(k)), m)
           by ring
     = Real.partialSum((k : Natural) ↦ abs(b(k)), w + m)
       - Real.partialSum((k : Natural) ↦ abs(b(k)), m)
           since absSplit
}

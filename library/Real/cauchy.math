-- D Phase-1 (sealed structures): the roll-up implementation module for
-- the Real interface (named for the Cauchy-sequence construction).
-- Imports the construction subtree; the interface
-- (Real.interface) obligation-checks against it and seals. Whole-theorem
-- consumers (intermediate_value, uncountable, the series showcases) stay
-- outside per the D3 closure discipline.
implementation module Real.cauchy implements Real.interface

import Real.basics
import Real.addition
import Real.negation
import Real.multiplication
import Real.order
import Real.ring
import Real.ring_bundle
import Real.algebra
import Real.instances
import Real.embedding
import Real.embedding_order
import Real.division
import Real.reciprocal
import Real.field
import Real.order_field
import Real.order_multiplication
import Real.apartness
import Real.absolute_value
import Real.absolute_value_order
import Real.density
import Real.sequence
import Real.convergence
import Real.cauchy_bounded
import Real.cauchy_complete
import Real.supremum
import Real.limits
import Real.series
import Real.power
import Real.linearity
import Real.minimum
import Real.finite_products
import Real.exponential
import Real.exponential_algebra
import Real.exponential_addition
import Real.square_root
import Real.continuity
import Real.derivative
import Real.interface_boundary

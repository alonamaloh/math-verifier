-- Real/square_root.math
--
-- Square roots exist: every nonnegative real is the square of a
-- nonnegative real. The intermediate value theorem does the work —
-- t ↦ t·t − c is continuous, starts at −c ≤ 0, and at t = c + 1 has
-- climbed to c² + c + 1 > 0, so it crosses zero on [0, c + 1].

module Real.square_root

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import axioms
import Equality.basics
import Natural.basics
import Natural.order
import Integer.basics
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.halve
import Rational.positive
import Rational.linearity
import Rational.minimum
import Rational.reciprocal
import Rational.archimedean
import Set.basics
import Algebra.ring_lemmas
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.instances
import Real.order
import Real.linearity
import Real.embedding_order
import Real.order_multiplication
import Real.apartness
import Real.reciprocal
import Real.field
import Real.order_field
import Real.absolute_value
import Real.absolute_value_order
import Real.density
import Real.convergence
import Real.supremum
import Real.limits
import Real.continuity
import Real.intermediate_value

theorem Real.square_root_exists (c : Real) (cNonneg : Real.zero ≤ c)
        : ∃ (r : Real). Real.zero ≤ r ∧ r * r = c := {
  claim Real.ContinuousOn((t : Real) ↦ t * t - c, Real.zero, c + Real.one)
      since (t : Real) (_ : Real.zero ≤ t) (_ : t ≤ c + Real.one) ↦ {
           claim Real.ContinuousAt((u : Real) ↦ u, t)
               since Real.ContinuousAt.identity;
           claim Real.ContinuousAt((u : Real) ↦ u * u, t)
               by Real.ContinuousAt.multiply(f := (u : Real) ↦ u, g := (u : Real) ↦ u);
           claim Real.ContinuousAt((u : Real) ↦ c, t)
               since Real.ContinuousAt.constant;
           done by Real.ContinuousAt.subtract(
                       f := (u : Real) ↦ u * u, g := (u : Real) ↦ c)
         };
  claim Rational.zero < Rational.one;
  claim Real.zero < Rational.one
      since Rational.to_real.positive_preserves;
  claim Real.zero ≤ Real.one since Real.LessThan.weaken;
  calc Real.zero
     ≤ c                  by cNonneg
     = c + Real.zero
     ≤ c + Real.one       since Real.add_preserves_LessOrEqual_left;
  calc Real.zero * Real.zero - c
     = Real.zero + -c
     ≤ c + -c             by Real.add_preserves_LessOrEqual
     = Real.zero;
  claim Real.IsNonneg(c * c) since Real.square_IsNonneg;
  claim Real.zero ≤ c * c since Real.LessOrEqual_zero_of_IsNonneg;
  calc Real.zero
     = Real.zero + Real.zero
     ≤ c * c + Real.zero          by Real.add_preserves_LessOrEqual
     ≤ c * c + (c + Real.one)     since Real.add_preserves_LessOrEqual_left
     = (c + Real.one) * (c + Real.one) - c;
  claim crossesZero
        : ∃ (r : Real). Real.zero ≤ r ∧ r ≤ c + Real.one ∧ r * r - c = Real.zero
      since Real.intermediate_value(f := (t : Real) ↦ t * t - c);
  choose r such that Real.zero ≤ r ∧ r ≤ c + Real.one ∧ r * r - c = Real.zero
      from crossesZero;
  claim zeroLeqR : Real.zero ≤ r;
  claim valueZero : r * r - c = Real.zero;
  witness r with
      And.introduction(
          zeroLeqR,
          calc r * r
             = (r * r - c) + c
             = Real.zero + c      since valueZero
             = c)
}

-- Nonnegative square roots are unique: two of them differ by a factor
-- of (r − s)(r + s) = c − c = 0, and if the sum vanishes both numbers
-- were zero anyway.
theorem Real.square_root_unique
        (c r s : Real)
        (rNonneg : Real.zero ≤ r) (sNonneg : Real.zero ≤ s)
        (rSquares : r * r = c) (sSquares : s * s = c)
        : r = s := {
  calc (r - s) * (r + s)
     = r * r - s * s
     = c - s * s
     = c - c
     = Real.zero;
  decide r - s = Real.zero {
    | yes differenceZero =>
        done since Real.eq_of_sub_eq_zero
    | no differenceNonzero => {
        claim r + s = Real.zero
            since Real.right_factor_zero_of_product_zero;
        calc r
           = r + Real.zero
           ≤ r + s          since Real.add_preserves_LessOrEqual_left
           = Real.zero;
        claim r = Real.zero
            since Real.LessOrEqual.antisymmetric;
        calc s
           = Real.zero + s
           ≤ r + s          since Real.add_preserves_LessOrEqual
           = Real.zero;
        claim s = Real.zero
            since Real.LessOrEqual.antisymmetric;
        calc r
           = Real.zero
           = s
      }
  }
}

-- Comparing against a nonnegative number reduces to comparing squares:
-- x² ≤ y² and 0 ≤ y give x ≤ y. (If y ≤ x the squares are forced equal,
-- and the factorization x² − y² = (x − y)(x + y) = 0 collapses both
-- numbers to zero unless x = y outright.)
theorem Real.LessOrEqual_of_square_LessOrEqual (x y : Real)
        (yNonneg : Real.zero ≤ y) (squaresOrdered : x * x ≤ y * y)
        : x ≤ y := {
  done by cases {
    case x ≤ y as ordered: ordered
    case Not(x ≤ y) as notOrdered: {
      claim y ≤ x since Real.not_LessOrEqual_implies;
      claim y * y ≤ x * x since Real.LessOrEqual.multiply_monotone_nonneg;
      claim x * x = y * y since Real.LessOrEqual.antisymmetric;
      calc (x - y) * (x + y)
         = x * x - y * y
         = y * y - y * y
         = Real.zero;
      decide x - y = Real.zero {
        | yes differenceZero =>
            calc x
               = y    since Real.eq_of_sub_eq_zero
               ≤ y    since Real.LessOrEqual.reflexive
        | no differenceNonzero => {
            claim x + y = Real.zero
                since Real.right_factor_zero_of_product_zero;
            calc y
               = Real.zero + y
               ≤ y + y          since Real.add_preserves_LessOrEqual
               ≤ x + y          since Real.add_preserves_LessOrEqual
               = Real.zero;
            claim y = Real.zero since Real.LessOrEqual.antisymmetric;
            calc x
               = x + Real.zero
               = x + y
               = Real.zero;
            calc x
               = Real.zero
               = y
               ≤ y    since Real.LessOrEqual.reflexive
          }
      }
    }
  }
}

-- The uniqueness above, repackaged in the shape definite description
-- expects (bundled And-witnesses).
theorem Real.square_root_property_unique (c : Real)
        : ∀ (a b : Real).
            Real.zero ≤ a ∧ a * a = c
          → Real.zero ≤ b ∧ b * b = c
          → a = b :=
  (a b : Real)
  (aData : Real.zero ≤ a ∧ a * a = c)
  (bData : Real.zero ≤ b ∧ b * b = c) ↦
    done since Real.square_root_unique

-- THE square root, by definite description: existence from the
-- intermediate value theorem, uniqueness from the lemma above. √ is
-- now an honest function of (c, proof that 0 ≤ c).
definition Real.square_root (c : Real) (cNonneg : Real.zero ≤ c) : Real := {
  claim squareRootExists : ∃ (r : Real). Real.zero ≤ r ∧ r * r = c
      since Real.square_root_exists;
  Logic.the(
      Real,
      (r : Real) ↦ Real.zero ≤ r ∧ r * r = c,
      squareRootExists,
      Real.square_root_property_unique(c))
}

theorem Real.square_root_satisfies (c : Real) (cNonneg : Real.zero ≤ c)
        : Real.zero ≤ Real.square_root(c, cNonneg) ∧ Real.square_root(c, cNonneg)
              * Real.square_root(c, cNonneg) = c := {
  claim squareRootExists : ∃ (r : Real). Real.zero ≤ r ∧ r * r = c
      since Real.square_root_exists;
  Logic.the_satisfies(
      Real,
      (r : Real) ↦ Real.zero ≤ r ∧ r * r = c,
      squareRootExists,
      Real.square_root_property_unique(c))
}

theorem Real.square_root_nonneg (c : Real) (cNonneg : Real.zero ≤ c)
        : Real.zero ≤ Real.square_root(c, cNonneg) := {
  claim Real.zero ≤ Real.square_root(c, cNonneg)
            ∧ Real.square_root(c, cNonneg) * Real.square_root(c, cNonneg) = c
      since Real.square_root_satisfies;
  done
}

theorem Real.square_root_squares (c : Real) (cNonneg : Real.zero ≤ c)
        : Real.square_root(c, cNonneg) * Real.square_root(c, cNonneg) = c := {
  claim Real.zero ≤ Real.square_root(c, cNonneg)
            ∧ Real.square_root(c, cNonneg) * Real.square_root(c, cNonneg) = c
      since Real.square_root_satisfies;
  done
}

-- D Phase-1 (sealed structures): the Real interface — the public view.
-- The carrier and operations are ABSTRACT here; every theorem of the
-- construction subtree is bulk-exported (sealed); the wiring
-- (operators, coercion, fold operations, instances) is copied
-- mechanically into the sealed cache. Consumers importing this module
-- never load the construction. See PLAN_LANGUAGE_IMPROVEMENT.md D3/D3a.
interface module Real.interface implemented by Real.cauchy

import Logic.basics
import Logic.exists
import Equality.basics
import Set.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order

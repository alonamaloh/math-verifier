-- ── The abstract carrier and primitives ─────────────────────────────
-- Constants: the quotient-level primitives, whose construction bodies
-- mention the Cauchy representation — the seal is exactly about hiding
-- these bodies.
type Real
constant Real.add : ℝ → ℝ → ℝ
constant Real.multiply : ℝ → ℝ → ℝ
constant Real.negate : ℝ → ℝ
constant Real.absolute_value : ℝ → ℝ
constant Real.IsNonneg : ℝ → Proposition
constant Rational.to_real : ℚ → ℝ
constant Real.square_root : (c : ℝ) → Real.zero ≤ c → ℝ

-- ── The transparent public layer ─────────────────────────────────────
-- Definitions whose bodies are stated entirely in public vocabulary
-- re-export WITH their bodies (closure-validated at seal time):
-- consumer proofs intro/eliminate ε-δ and supremum bodies, decompose
-- the order conjunction, and lean on the embedded-numeral defeqs
-- (Real.zero ≡ to_real 0), exactly as construction-side proofs do.
export definitions Real.zero, Real.one, Real.subtract,
    Real.LessOrEqual, Real.LessThan,
    Real.power, Real.partialSum, Real.partialProduct,
    Real.divide, Real.reciprocal,
    Real.midpoint, Real.minimum,
    Real.exponential, Real.exponentialTerm, Real.e,
    Real.SequenceConverges, Real.SequenceIsCauchy,
    Real.SequenceConvergent, Real.limit, Real.SeriesConverges,
    Real.TendsToInfinity,
    Real.ContinuousAt, Real.ContinuousOn, Real.HasDerivativeAt,
    Real.IsUpperBound, Real.IsBoundedAbove, Real.IsSupremum,
    Real.sequence_range

-- ── Structure witnesses the wiring points at ────────────────────────
-- Transparent: consumers project fields out of the bundles
-- (Ring.carrier(Real.ring) must reduce to Real for Polynomial(Real,…)
-- sites), and the bundle bodies are public vocabulary + exported
-- proofs.
export definitions Real.add_is_monoid, Real.multiply_is_monoid, Real.ring

-- ── The theorem surface: everything the construction proves ─────────
export theorems of Real.basics, Real.addition, Real.negation,
    Real.multiplication, Real.order, Real.ring, Real.ring_bundle,
    Real.algebra, Real.instances, Real.embedding, Real.embedding_order,
    Real.division, Real.reciprocal, Real.field, Real.order_field,
    Real.order_multiplication, Real.apartness, Real.absolute_value,
    Real.absolute_value_order, Real.density, Real.sequence,
    Real.convergence, Real.cauchy_bounded, Real.cauchy_complete,
    Real.supremum, Real.limits, Real.intermediate_value,
    Real.series, Real.power, Real.linearity,
    Real.minimum, Real.finite_products, Real.exponential,
    Real.exponential_algebra, Real.exponential_addition,
    Real.square_root, Real.continuity, Real.derivative,
    Real.interface_boundary

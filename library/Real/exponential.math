-- Real/exponential.math
--
-- The real exponential function, as the sum of the series Σ xᵏ/k!.
-- The coefficient 1/k! is an honest rational (k! is a positive
-- natural), so each term is a rational scalar times a power. The
-- series converges absolutely by the ratio bound: past an index K
-- with 2·|x| ≤ K + 1, each term is at most half the one before, so
-- the absolute partial sums sit below a geometric roof and converge
-- by monotone convergence; Cauchy completeness then carries the
-- sign-changing series itself. The value exp(x) is extracted by
-- definite description through Real.limit.

module Real.exponential

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Natural.maximum
import Natural.compare
import Natural.subtraction
import Natural.factorial
import Integer.basics
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.absolute_value
import Rational.triangle
import Rational.triangle_more
import Rational.positive
import Rational.halve
import Rational.linearity
import Rational.reciprocal
import Rational.archimedean
import Algebra.ring_lemmas
import Set.basics
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.instances
import Real.order
import Real.linearity
import Real.embedding_order
import Real.order_multiplication
import Real.apartness
import Real.reciprocal
import Real.field
import Real.division
import Real.order_field
import Real.density
import Real.absolute_value
import Real.absolute_value_order
import Real.convergence
import Real.supremum
import Real.limits
import Real.power
import Real.series
import Real.cauchy_complete

-- ----------------------------------------------------------------------
-- The k-th term of the exponential series: (1/k!) · xᵏ.
definition Real.exponentialTerm (x : ℝ) (k : ℕ) : ℝ :=
  (1 / (k! : ℝ)) * x ^ k

-- ----------------------------------------------------------------------
-- The factorial's cast is positive (so dividing by it is honest).
theorem Real.factorial_cast_positive (k : ℕ)
        : (k! : ℝ) > 0 := {
  1 ≤ k!;
  k! > 0;
  done
}

-- … and at the Rational layer, for the consumers still working there.
theorem Rational.factorial_cast_positive (k : ℕ)
        : Rational.zero < k! := {
  1 ≤ k!;
  choose c such that k! = 1 + c as factorialSplit
      from Natural.subtraction_witness;
  (0 : ℚ) < (1 + c : ℚ);
  done by substituting factorialSplit
}

-- ----------------------------------------------------------------------
-- The defining recurrence, with the factorial unwound one step:
-- term(x, k+1) = (1/(k+1)) · x · term(x, k).
theorem Real.exponentialTerm_one_plus (x : ℝ) (k : ℕ)
        : Real.exponentialTerm(x, 1 + k)
          = (1 / (1 + k : ℝ))
            * (x * Real.exponentialTerm(x, k)) := {
  ((1 + k)! : ℝ)
      = ((1 + k) * k! : ℝ)
            by Natural.factorial_add_one
      = (1 + k : ℝ) * (k! : ℝ)
      as factorialStep;
  (1 + k : ℝ) > 0;
  (k! : ℝ) > 0;
  ((1 + k)! : ℝ) > 0;
  (1 + k : ℝ) ≠ 0;
  (k! : ℝ) ≠ 0;
  ((1 + k)! : ℝ) ≠ 0;
  ((1 + k : ℝ) * (k! : ℝ)) * ((1 / (1 + k : ℝ)) * (1 / (k! : ℝ))) = 1
      by field as productCancel;
  ((1 + k)! : ℝ) * (1 / ((1 + k)! : ℝ)) = 1 as factorialCancel;
  1 / ((1 + k)! : ℝ)
     = 1 * (1 / ((1 + k)! : ℝ))
     = (((1 + k : ℝ) * (k! : ℝ))
        * ((1 / (1 + k : ℝ)) * (1 / (k! : ℝ))))
       * (1 / ((1 + k)! : ℝ))
           by productCancel
     = (((1 + k)! : ℝ)
        * ((1 / (1 + k : ℝ)) * (1 / (k! : ℝ))))
       * (1 / ((1 + k)! : ℝ))
           by factorialStep
     = (((1 + k)! : ℝ) * (1 / ((1 + k)! : ℝ)))
       * ((1 / (1 + k : ℝ)) * (1 / (k! : ℝ)))
     = 1 * ((1 / (1 + k : ℝ)) * (1 / (k! : ℝ)))
           by factorialCancel
     = (1 / (1 + k : ℝ)) * (1 / (k! : ℝ))
     as reciprocalSplit;
  Real.exponentialTerm(x, 1 + k)
     = (1 / ((1 + k)! : ℝ)) * x ^ (1 + k)
     = ((1 / (1 + k : ℝ)) * (1 / (k! : ℝ))) * x ^ (1 + k)
           by reciprocalSplit
     = ((1 / (1 + k : ℝ)) * (1 / (k! : ℝ))) * (x * x ^ k)
           by Real.power_add_one
     = (1 / (1 + k : ℝ)) * (x * ((1 / (k! : ℝ)) * x ^ k))
     = (1 / (1 + k : ℝ)) * (x * Real.exponentialTerm(x, k))
}

-- ----------------------------------------------------------------------
-- The first two terms in closed form, and termwise nonnegativity for
-- nonnegative arguments.

theorem Real.exponentialTerm_zero (x : ℝ)
        : Real.exponentialTerm(x, 0) = Real.one := {
  (0! : ℝ) = 1;
  (0! : ℝ) > 0;
  (0! : ℝ) ≠ 0;
  (0! : ℝ) * (1 / (0! : ℝ)) = 1;
  1 / (0! : ℝ)
     = 1 * (1 / (0! : ℝ))
     = (0! : ℝ) * (1 / (0! : ℝ))
     = 1
     as reciprocalOne;
  Real.exponentialTerm(x, 0)
     = (1 / (0! : ℝ)) * x ^ 0
     = 1 * x ^ 0
           by reciprocalOne
     = x ^ 0
     = Real.one
}

theorem Real.exponentialTerm_one (x : ℝ)
        : Real.exponentialTerm(x, 1) = x := {
  1!
      = (1 + 0) * 0!
      = 1
      as factorialOne;
  (1! : ℝ) = 1 by substituting factorialOne as castOne;
  (1! : ℝ) > 0;
  (1! : ℝ) ≠ 0;
  (1! : ℝ) * (1 / (1! : ℝ)) = 1;
  1 / (1! : ℝ)
     = 1 * (1 / (1! : ℝ))
     = (1! : ℝ) * (1 / (1! : ℝ))
           by castOne
     = 1
     as reciprocalOne;
  x ^ 1 = x * Real.one;
  Real.exponentialTerm(x, 1)
     = (1 / (1! : ℝ)) * x ^ 1
     = 1 * x ^ 1
           by reciprocalOne
     = Real.one * (x * Real.one)
     = x
}

theorem Real.exponentialTerm_nonneg (x : ℝ)
        (xNonneg : Real.zero ≤ x) (k : ℕ)
        : Real.zero ≤ Real.exponentialTerm(x, k) := {
  (k! : ℝ) > 0;
  (1 : ℝ) > 0;
  1 / (k! : ℝ) > 0;
  Real.zero ≤ 1 / (k! : ℝ);
  Real.IsNonneg(1 / (k! : ℝ));
  Real.zero ≤ x ^ k;
  Real.IsNonneg(x ^ k);
  Real.IsNonneg((1 / (k! : ℝ)) * x ^ k);
  Real.zero ≤ (1 / (k! : ℝ)) * x ^ k
      by Real.LessOrEqual_zero_of_IsNonneg;
  done
}

-- ----------------------------------------------------------------------
-- Absolute convergence: the partial sums of |term(x, ·)| are monotone
-- and bounded, hence convergent. Bounded because past an index K with
-- 2·|x| ≤ K + 1 the terms at least halve at every step, so the tail
-- sits under the geometric roof 2·|term(x, K)|.
theorem Real.exponential_series_absolutely_convergent (x : ℝ)
        : Real.SequenceConvergent(
              Real.partialSum(
                  (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)))) := {
  -- A roof over |x|, and a natural K with 2·roof ≤ K + 1.
  choose xRoof from Real.exists_positive_rational_roof(x);
  choose K such that abs(xRoof + xRoof) ≤ ((K + 1) : ℚ)
      from Rational.absolute_value_le_add_one_natural;
  Rational.zero
      = Rational.zero + Rational.zero
      < xRoof + xRoof
            by Rational.LessThan.add_strict_strict;
  Rational.zero ≤ xRoof + xRoof;
  Rational.IsNonneg(xRoof + xRoof);
  abs(xRoof + xRoof) = xRoof + xRoof as doubleRoofAbsolute;
  xRoof + xRoof ≤ ((K + 1) : ℚ)
      by substituting doubleRoofAbsolute;
  -- Past K, one series step multiplies the term by at most 1/2.
  ∀ (k : ℕ). K ≤ k → abs(x) * (1 / (1 + k : ℝ)) ≤ (Rational.one_half : ℝ)
      by {
        take k : ℕ;
        take KBelowIndex : K ≤ k;
        1 + K ≤ 1 + k;
        (1 + K : ℝ) ≤ (1 + k : ℝ) by Real.from_natural.LessOrEqual_preserves;
        (1 + K : ℝ) > 0;
        (1 + k : ℝ) > 0;
        (1 + K : ℝ) ≠ 0;
        (1 + k : ℝ) ≠ 0;
        1 / (1 + k : ℝ) ≤ 1 / (1 + K : ℝ) by Real.one_divide_antitone;
        (1 + K : ℝ) * (1 / (1 + K : ℝ)) = 1;
        (1 : ℝ) > 0;
        1 / (1 + K : ℝ) > 0;
        Real.zero ≤ 1 / (1 + K : ℝ);
        Real.IsNonneg(1 / (1 + K : ℝ)) by Real.IsNonneg_of_LessOrEqual_zero;
        (xRoof : ℝ) + (xRoof : ℝ)
            = ((xRoof + xRoof : ℚ) : ℝ)
            ≤ (((K + 1) : ℚ) : ℝ)          by Rational.to_real.LessOrEqual_preserves
            = (1 + K : ℝ)             by ((K + 1 : ℕ) = 1 + K);
        ((xRoof : ℝ) + (xRoof : ℝ)) * (1 / (1 + K : ℝ))
            ≤ (1 + K : ℝ) * (1 / (1 + K : ℝ))    by Real.LessOrEqual.multiply_by_nonneg_right
            = 1;
        (Rational.one_half : ℝ) + (Rational.one_half : ℝ)
            = ((Rational.one_half + Rational.one_half : ℚ) : ℝ)
            = ((Rational.one : ℚ) : ℝ)                             by Rational.one_half_doubled
            = 1
            as halvesToOne;
        Rational.zero < Rational.one_half;
        (Rational.one_half : ℝ) > 0;
        Real.zero ≤ (Rational.one_half : ℝ);
        Real.IsNonneg((Rational.one_half : ℝ));
        (xRoof : ℝ) * (1 / (1 + K : ℝ))
            = ((xRoof : ℝ) * (1 / (1 + K : ℝ))) * 1
            = ((xRoof : ℝ) * (1 / (1 + K : ℝ))) * ((Rational.one_half : ℝ) + (Rational.one_half : ℝ))
                  by halvesToOne
            = (((xRoof : ℝ) + (xRoof : ℝ)) * (1 / (1 + K : ℝ))) * (Rational.one_half : ℝ)
            ≤ 1 * (Rational.one_half : ℝ)    by Real.LessOrEqual.multiply_by_nonneg_right
            = (Rational.one_half : ℝ)
            as roofHalf;
        Real.zero ≤ abs(x) by Real.absolute_value_nonneg;
        1 / (1 + k : ℝ) > 0;
        Real.zero ≤ 1 / (1 + k : ℝ) by Real.LessThan.weaken;
        abs(x) * (1 / (1 + k : ℝ))
           ≤ (xRoof : ℝ) * (1 / (1 + K : ℝ))    by Real.LessOrEqual.multiply_monotone_nonneg
           ≤ (Rational.one_half : ℝ)                           by roofHalf
      } as ratioBound;
  -- Geometric decay of the terms past K, by induction on the offset.
  ∀ (j : ℕ).
      abs(Real.exponentialTerm(x, j + K))
      ≤ abs(Real.exponentialTerm(x, K)) * (Rational.one_half : ℝ) ^ j
      by by induction on j with IH {
           case base: {
               (Rational.one_half : ℝ) ^ 0 = Real.one;
               abs(Real.exponentialTerm(x, K)) ≤ abs(Real.exponentialTerm(x, K));
               abs(Real.exponentialTerm(x, K))
                   = abs(Real.exponentialTerm(x, K)) * Real.one
                   = abs(Real.exponentialTerm(x, K))
                     * (Rational.one_half : ℝ) ^ 0
                   as productForm;
               done by substituting productForm
             }
           case step(predecessor): {
               K ≤ K + predecessor;
               K + predecessor = predecessor + K as indexCommute;
               K ≤ predecessor + K by substituting indexCommute;
               Real.exponentialTerm(x, 1 + (predecessor + K))
                   = (1 / (1 + (predecessor + K) : ℝ)) * (x * Real.exponentialTerm(x, predecessor + K))
                   as stepEquation;
               (1 + (predecessor + K) : ℝ) > 0;
               (1 : ℝ) > 0;
               1 / (1 + (predecessor + K) : ℝ) > 0;
               Real.zero ≤ 1 / (1 + (predecessor + K) : ℝ);
               Real.IsNonneg(1 / (1 + (predecessor + K) : ℝ));
               abs(Real.exponentialTerm(x, 1 + (predecessor + K)))
                   = abs((1 / (1 + (predecessor + K) : ℝ)) * (x * Real.exponentialTerm(x, predecessor + K)))
                         by stepEquation
                   = abs(1 / (1 + (predecessor + K) : ℝ)) * abs(x * Real.exponentialTerm(x, predecessor + K))
                   = abs(1 / (1 + (predecessor + K) : ℝ))
                     * (abs(x) * abs(Real.exponentialTerm(x, predecessor + K)))
                         by Real.absolute_value_multiplicative
                   = (1 / (1 + (predecessor + K) : ℝ))
                     * (abs(x) * abs(Real.exponentialTerm(x, predecessor + K)))
                         by Real.absolute_value_when_nonneg
                   as absoluteStep;
               Real.zero ≤ abs(x) by Real.absolute_value_nonneg;
               Real.zero ≤ abs(Real.exponentialTerm(x, predecessor + K)) by Real.absolute_value_nonneg;
               Real.IsNonneg(abs(x));
               Real.IsNonneg(abs(x) * (1 / (1 + (predecessor + K) : ℝ)));
               Real.zero ≤ abs(x) * (1 / (1 + (predecessor + K) : ℝ))
                   by Real.LessOrEqual_zero_of_IsNonneg;
               abs(x) * (1 / (1 + (predecessor + K) : ℝ)) ≤ (Rational.one_half : ℝ)
                   by ratioBound;
               abs(Real.exponentialTerm(x, (1 + predecessor) + K))
                  = abs(Real.exponentialTerm(x, 1 + (predecessor + K)))
                        by substituting ((1 + predecessor) + K = 1 + (predecessor + K))
                  = (1 / (1 + (predecessor + K) : ℝ))
                    * (abs(x) * abs(Real.exponentialTerm(x, predecessor + K)))
                        by absoluteStep
                  = (abs(x) * (1 / (1 + (predecessor + K) : ℝ)))
                    * abs(Real.exponentialTerm(x, predecessor + K))
                  ≤ (Rational.one_half : ℝ)
                    * (abs(Real.exponentialTerm(x, K)) * (Rational.one_half : ℝ) ^ predecessor)
                        by Real.LessOrEqual.multiply_monotone_nonneg
                  = abs(Real.exponentialTerm(x, K))
                    * ((Rational.one_half : ℝ) * (Rational.one_half : ℝ) ^ predecessor)
                  = abs(Real.exponentialTerm(x, K)) * (Rational.one_half : ℝ) ^ (1 + predecessor)
                        by Real.power_add_one
             }
         } as tailDecay;
  -- The geometric roof: partial sums of (1/2)ᵏ never exceed 2.
  Rational.zero < Rational.one_half;
  Real.zero < Rational.one_half;
  Real.zero ≤ (Rational.one_half : ℝ);
  Rational.one_half + Rational.one_half = Real.one
      by {
        (Rational.one_half : ℝ) + (Rational.one_half : ℝ)
            = ((Rational.one_half + Rational.one_half : ℚ) : ℝ)
            = (Rational.one : ℝ)
                  by Rational.one_half_doubled
            = Real.one
      }
      as halvesSum;
  Real.one - Rational.one_half = (Rational.one_half : ℝ)
      by {
        Real.one - (Rational.one_half : ℝ)
            = ((Rational.one_half : ℝ) + (Rational.one_half : ℝ))
              - (Rational.one_half : ℝ)
                  by halvesSum
            = (Rational.one_half : ℝ)
      }
      as oneMinusHalf;
  ∀ (c : ℕ).
      Real.partialSum(
          (k : ℕ) ↦ (Rational.one_half : ℝ) ^ k, c)
      ≤ Real.one + Real.one
      by {
        take c : ℕ;
        (Real.one - Rational.one_half)
            * Real.partialSum(
                  (k : ℕ) ↦ (Rational.one_half : ℝ) ^ k,
                  c)
            = Real.one - (Rational.one_half : ℝ) ^ c
            by Real.geometric_partialSum as closedForm;
        Rational.one_half
            * Real.partialSum(
                  (k : ℕ) ↦ (Rational.one_half : ℝ) ^ k,
                  c)
            = Real.one - (Rational.one_half : ℝ) ^ c
            by {
                  (Rational.one_half : ℝ)
                    * Real.partialSum(
                          (k : ℕ) ↦ (Rational.one_half : ℝ) ^ k, c)
                  = (Real.one - (Rational.one_half : ℝ))
                    * Real.partialSum(
                          (k : ℕ) ↦ (Rational.one_half : ℝ) ^ k, c)
                        by oneMinusHalf
                  = Real.one - (Rational.one_half : ℝ) ^ c
                        by closedForm
            }
            as halfScaled;
        Real.zero ≤ (Rational.one_half : ℝ) ^ c
            by Real.power_nonneg;
        Real.IsNonneg((Rational.one_half : ℝ) ^ c);
        Real.one - (Rational.one_half : ℝ) ^ c ≤ Real.one
            by substituting
                   (ring : (Rational.one_half : ℝ) ^ c
                       = Real.one
                         - (Real.one
                            - (Rational.one_half : ℝ) ^ c))
            as chopped;
        Rational.one_half * (Real.one + Real.one) = Real.one
            by {
                  (Rational.one_half : ℝ) * (Real.one + Real.one)
                  = (Rational.one_half : ℝ) + (Rational.one_half : ℝ)
                  = Real.one
            }
            as doubled;
        Rational.one_half
            * Real.partialSum(
                  (k : ℕ) ↦ (Rational.one_half : ℝ) ^ k,
                  c)
            ≤ (Rational.one_half : ℝ) * (Real.one + Real.one)
            by {
                  (Rational.one_half : ℝ)
                    * Real.partialSum(
                          (k : ℕ) ↦ (Rational.one_half : ℝ) ^ k, c)
                  = Real.one - (Rational.one_half : ℝ) ^ c
                        by halfScaled
                  ≤ Real.one
                        by chopped
                  = (Rational.one_half : ℝ) * (Real.one + Real.one)
                        by doubled
            };
        done by Real.LessOrEqual.multiply_cancel_left_positive
      } as geometricRoof;
  -- Termwise nonnegativity, twice over (terms, then their sums).
  ∀ (k : ℕ). Real.zero ≤ abs(Real.exponentialTerm(x, k))
      by {
        take k : ℕ;
        Real.zero ≤ abs(Real.exponentialTerm(x, k));
        done
      };
  ∀ (i j : ℕ). i ≤ j
      → Real.partialSum(
            (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)), i)
        ≤ Real.partialSum(
              (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)), j)
      by {
        take i : ℕ; take j : ℕ; take iBelowJ : i ≤ j;
        done by Real.partialSum_monotone_of_nonneg
      };
  -- The roof itself is nonnegative padding.
  Real.zero ≤ abs(Real.exponentialTerm(x, K));
  Real.IsNonneg(abs(Real.exponentialTerm(x, K)));
  Rational.zero < Rational.one;
  Real.zero < Rational.one;
  Real.zero
      < (Rational.one : ℝ)
      = Real.one + Real.zero
      < Real.one + Real.one      by Real.add_left_preserves_LessThan;
  Real.zero ≤ Real.one + Real.one;
  Real.IsNonneg(Real.one + Real.one)
      by Real.IsNonneg_of_LessOrEqual_zero;
  Real.IsNonneg(abs(Real.exponentialTerm(x, K)) * (Real.one + Real.one));
  Real.zero ≤ abs(Real.exponentialTerm(x, K)) * (Real.one + Real.one)
      by Real.LessOrEqual_zero_of_IsNonneg;
  -- Every partial sum stays below prefix-up-to-K plus the tail roof.
  ∀ (n : ℕ).
      Real.partialSum(
          (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)), n)
      ≤ Real.partialSum(
            (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)), K)
        + abs(Real.exponentialTerm(x, K)) * (Real.one + Real.one)
      by {
        take n : ℕ;
        n ≤ K ∨ K ≤ n by Natural.totality_of_less_or_equal;
        done by cases {
          case n ≤ K as nLeqK: {
              Real.partialSum(
                    (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)), n)
                ≤ Real.partialSum(
                      (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)),
                      K)
                as prefixBound;
              Real.partialSum(
                       (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)), n)
                 ≤ Real.partialSum(
                       (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)), K)
                       by prefixBound
                 = Real.partialSum(
                       (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)), K)
                   + Real.zero
                 ≤ Real.partialSum(
                       (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)), K)
                   + abs(Real.exponentialTerm(x, K)) * (Real.one + Real.one)
                       by Real.add_preserves_LessOrEqual_left
            }
          case K ≤ n as KLeqN: {
              choose c such that n = K + c as nSplit
                  from Natural.subtraction_witness;
              n
                  = K + c    by nSplit
                  = c + K
                  as nAsSum;
              Real.partialSum(
                    (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)), n)
                = Real.partialSum(
                      (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)),
                      c + K)
                      by nAsSum
                = Real.partialSum(
                      (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)),
                      K)
                  + Real.partialSum(
                        (j : ℕ)
                          ↦ abs(Real.exponentialTerm(x, K + j)), c)
                      by Real.partialSum_split
                  as splitSum;
              ∀ (j : ℕ). j < c
                  → abs(Real.exponentialTerm(x, K + j))
                    ≤ abs(Real.exponentialTerm(x, K))
                      * (Rational.one_half : ℝ) ^ j
                  by {
                    take j : ℕ;
                    take _ : j < c;
                    abs(Real.exponentialTerm(x, j + K))
                        ≤ abs(Real.exponentialTerm(x, K))
                          * (Rational.one_half : ℝ) ^ j
                        by tailDecay;
                    K + j = j + K as indexCommute;
                    done by substituting indexCommute
                  };
              abs(Real.exponentialTerm(x, K)) ≤ abs(Real.exponentialTerm(x, K))
                  by Real.LessOrEqual.reflexive;
              ∀ (j : ℕ). Real.zero ≤ (Rational.one_half : ℝ) ^ j
                  by {
                    take j : ℕ;
                    Real.zero ≤ (Rational.one_half : ℝ) ^ j
                        by Real.power_nonneg;
                    done
                  };
              Real.zero
                  ≤ Real.partialSum(
                        (j : ℕ)
                          ↦ (Rational.one_half : ℝ) ^ j, c)
                  by Real.partialSum_nonneg;
              Real.partialSum(
                    (j : ℕ)
                      ↦ (Rational.one_half : ℝ) ^ j, c)
                  ≤ Real.one + Real.one
                  by geometricRoof;
              Real.partialSum(
                    (j : ℕ)
                      ↦ abs(Real.exponentialTerm(x, K + j)), c)
                  ≤ Real.partialSum(
                        (j : ℕ)
                          ↦ abs(Real.exponentialTerm(x, K))
                            * (Rational.one_half : ℝ) ^ j,
                        c)
                        by Real.partialSum_le_pointwise
                  = abs(Real.exponentialTerm(x, K))
                    * Real.partialSum(
                          (j : ℕ)
                            ↦ (Rational.one_half : ℝ) ^ j,
                          c)
                  ≤ abs(Real.exponentialTerm(x, K))
                    * (Real.one + Real.one)
                        by Real.LessOrEqual.multiply_monotone_nonneg;
              Real.partialSum(
                       (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)), n)
                 = Real.partialSum(
                       (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)), K)
                   + Real.partialSum(
                         (j : ℕ)
                           ↦ abs(Real.exponentialTerm(x, K + j)), c)
                       by splitSum
                 ≤ Real.partialSum(
                       (k : ℕ) ↦ abs(Real.exponentialTerm(x, k)), K)
                   + abs(Real.exponentialTerm(x, K)) * (Real.one + Real.one)
                       by Real.add_preserves_LessOrEqual_left
            }
        }
      };
  done by Real.monotone_bounded_converges
}

-- ----------------------------------------------------------------------
-- The signed series converges (dominated by its own absolute values),
-- and exp(x) is THE limit, by definite description.
theorem Real.exponential_series_convergent (x : ℝ)
        : Real.SequenceConvergent(
              Real.partialSum(Real.exponentialTerm(x))) := {
  ∀ (k : ℕ). abs(Real.exponentialTerm(x, k)) ≤ abs(Real.exponentialTerm(x, k))
      by {
        take k : ℕ;
        abs(Real.exponentialTerm(x, k)) ≤ abs(Real.exponentialTerm(x, k));
        done
      };
  done by Real.series_dominated_converges(
              boundConvergent := Real.exponential_series_absolutely_convergent(x))
}

definition Real.exponential (x : ℝ) : ℝ :=
  Real.limit(Real.partialSum(Real.exponentialTerm(x)),
             Real.exponential_series_convergent(x))

-- The standard mathematical notation exp(x) (not an abbreviation: this
-- IS the name a mathematician writes, like `e` and `i`).
overload exp := Real.exponential

theorem Real.exponential_converges (x : ℝ)
        : Real.SeriesConverges(Real.exponentialTerm(x), Real.exponential(x)) :=
  Real.limit_converges(Real.partialSum(Real.exponentialTerm(x)),
                       Real.exponential_series_convergent(x))

-- ----------------------------------------------------------------------
-- exp(0) = 1: from index 1 on, every partial sum is exactly 1 — the
-- head term is 1/0! · 0⁰ = 1 and every later term carries a factor
-- 0^(k+1) = 0.
theorem Real.exponential_zero : Real.exponential(Real.zero) = Real.one := {
  Real.exponentialTerm(Real.zero, 0) = Real.one as termZero;
  ∀ (k : ℕ). Real.exponentialTerm(Real.zero, 1 + k) = Real.zero
      by {
        take k : ℕ;
        Real.zero ^ (1 + k)
            = Real.zero * Real.zero ^ k
            = Real.zero    by ring
            as powerVanishes;
        Real.exponentialTerm(Real.zero, 1 + k)
           = (1 / ((1 + k)! : ℝ)) * Real.zero ^ (1 + k)
           = (1 / ((1 + k)! : ℝ)) * Real.zero
                 by powerVanishes
           = Real.zero
                 by ring
      } as laterTermsVanish;
  ∀ (p : ℕ).
      Real.partialSum(Real.exponentialTerm(Real.zero), 1 + p) = Real.one
      by by induction on p with IH {
           case p = 0:
               Real.partialSum(
                   Real.exponentialTerm(Real.zero), 1)
             = Real.partialSum(Real.exponentialTerm(Real.zero), 0)
               + Real.exponentialTerm(Real.zero, 0)
             = Real.zero + Real.one
                   by termZero
             = Real.one
           case p = 1 + q for some q:
               Real.partialSum(
                   Real.exponentialTerm(Real.zero), 1 + (1 + q))
             = Real.partialSum(
                   Real.exponentialTerm(Real.zero), 1 + q)
               + Real.exponentialTerm(Real.zero, 1 + q)
             = Real.one + Real.exponentialTerm(Real.zero, 1 + q)
                   by IH
             = Real.one + Real.zero
                   by laterTermsVanish
             = Real.one
         } as tailConstant;
  Real.SequenceConverges(
      Real.partialSum(Real.exponentialTerm(Real.zero)), Real.one)
      by {
        take ε : ℝ;
        take εPositive : ε > 0;
        witness 1 with
            (m : ℕ) (oneBelow : 1 ≤ m) ↦ {
              choose c such that m = 1 + c as mSplit
                  from Natural.subtraction_witness;
              Real.partialSum(
                      Real.exponentialTerm(Real.zero), m)
                  = Real.partialSum(
                        Real.exponentialTerm(Real.zero), 1 + c)
                        by mSplit
                  = Real.one
                        by tailConstant
                  as sumAtM;
              Real.partialSum(
                      Real.exponentialTerm(Real.zero), m) - Real.one
                  = Real.one - Real.one    by sumAtM
                  = Real.zero
                  as differenceZero;
              Real.IsNonneg(Real.zero);
              abs(Real.partialSum(
                          Real.exponentialTerm(Real.zero), m)
                      - Real.one)
                  = abs(Real.zero)
                        by differenceZero
                  = Real.zero
                  as absoluteZero;
              abs(Real.partialSum(Real.exponentialTerm(Real.zero), m)
                       - Real.one)
                 = Real.zero            by absoluteZero
                 < ε              by εPositive
            }
      };
  done by Real.SequenceConverges.unique(
              convergesToL1 := Real.exponential_converges(Real.zero))
}

-- ----------------------------------------------------------------------
-- For nonnegative arguments the series dominates its first two terms:
-- 1 + x ≤ exp(x), so in particular exp is positive there.
theorem Real.exponential_lower_bound (x : ℝ) (xNonneg : Real.zero ≤ x)
        : Real.one + x ≤ Real.exponential(x) := {
  Real.partialSum(Real.exponentialTerm(x), 2)
      = Real.partialSum(Real.exponentialTerm(x), 1)
        + Real.exponentialTerm(x, 1)
      = Real.partialSum(Real.exponentialTerm(x), 1) + x
            by Real.exponentialTerm_one
      = (Real.partialSum(Real.exponentialTerm(x), 0)
         + Real.exponentialTerm(x, 0)) + x
      = (Real.partialSum(Real.exponentialTerm(x), 0) + Real.one) + x
            by Real.exponentialTerm_zero
      = (Real.zero + Real.one) + x
      = Real.one + x
            by ring
      as sumAtTwo;
  ∀ (k : ℕ). Real.zero ≤ Real.exponentialTerm(x, k)
      by {
        take k : ℕ;
        done by Real.exponentialTerm_nonneg
      };
  ∀ (m : ℕ). 2 ≤ m → Real.one + x ≤ Real.partialSum(Real.exponentialTerm(x), m)
      by {
        take m : ℕ;
        take twoBelow : 2 ≤ m;
        Real.partialSum(Real.exponentialTerm(x), 2)
            ≤ Real.partialSum(Real.exponentialTerm(x), m)
            by Real.partialSum_monotone_of_nonneg;
        done by substituting sumAtTwo
      };
  done by Real.SequenceConverges.ge_of_eventually_ge(
              s := Real.partialSum(Real.exponentialTerm(x)),
              converges := Real.exponential_converges(x), N := 2)
}

-- ----------------------------------------------------------------------
-- Euler's number. (A single-letter name, like ComplexNumber.i: `e` is
-- the constant's actual mathematical name, not an abbreviation.)
definition Real.e : ℝ := Real.exponential(Real.one)

-- A concrete taste: e exceeds 2 — already the third partial sum
-- 1 + 1 + 1/2 does.
theorem Real.e_above_two : Real.one + Real.one < Real.e := {
  1!
      = (1 + 0) * 0!
      = 1;
  2!
      = 2 * 1!
      = 2 * 1
      = 2
      as factorialTwo;
  (2! : ℝ) = (2 : ℝ) by substituting factorialTwo as factorialTwoCast;
  (2! : ℝ) > 0;
  (2! : ℝ) ≠ 0;
  (2 : ℝ) * (1 / (2 : ℝ)) = 1 as cancelTwo;
  (2! : ℝ) * (1 / (2! : ℝ)) = 1 as factorialCancel;
  1 / (2! : ℝ)
      = 1 * (1 / (2! : ℝ))
      = ((2 : ℝ) * (1 / (2 : ℝ))) * (1 / (2! : ℝ))
            by cancelTwo
      = ((2! : ℝ) * (1 / (2 : ℝ))) * (1 / (2! : ℝ))
            by factorialTwoCast
      = ((2! : ℝ) * (1 / (2! : ℝ))) * (1 / (2 : ℝ))
      = 1 * (1 / (2 : ℝ))
            by factorialCancel
      = 1 / (2 : ℝ)
      as recipTwo;
  Real.one ^ 2 = Real.one * (Real.one * Real.one);
  Real.one ^ 2
      = Real.one * (Real.one * Real.one)
      = Real.one                           by ring
      as powerTwoOne;
  Real.exponentialTerm(Real.one, 2)
      = (1 / (2! : ℝ)) * Real.one ^ 2
      = (1 / (2 : ℝ)) * Real.one ^ 2
            by recipTwo
      = (1 / (2 : ℝ)) * Real.one
            by powerTwoOne
      = 1 / (2 : ℝ)
      as termTwo;
  Real.partialSum(Real.exponentialTerm(Real.one), 0) = Real.zero;
  Real.partialSum(Real.exponentialTerm(Real.one), 3)
      = Real.partialSum(Real.exponentialTerm(Real.one), 2) + Real.exponentialTerm(Real.one, 2)
            by Real.partialSum_add_one
      = Real.partialSum(Real.exponentialTerm(Real.one), 2) + 1 / (2 : ℝ)
            by termTwo
      = (Real.partialSum(Real.exponentialTerm(Real.one), 1) + Real.exponentialTerm(Real.one, 1)) + 1 / (2 : ℝ)
            by Real.partialSum_add_one
      = (Real.partialSum(Real.exponentialTerm(Real.one), 1) + Real.one) + 1 / (2 : ℝ)
            by Real.exponentialTerm_one
      = ((Real.partialSum(Real.exponentialTerm(Real.one), 0) + Real.exponentialTerm(Real.one, 0)) + Real.one) + 1 / (2 : ℝ)
            by Real.partialSum_add_one
      = ((Real.partialSum(Real.exponentialTerm(Real.one), 0) + Real.one) + Real.one) + 1 / (2 : ℝ)
            by Real.exponentialTerm_zero
      = ((Real.zero + Real.one) + Real.one) + 1 / (2 : ℝ)
      = Real.one + Real.one + 1 / (2 : ℝ)
            by ring
      as sumAtThree;
  Rational.zero < Rational.one;
  Real.zero < Rational.one;
  Real.zero < Real.one;
  Real.zero ≤ Real.one;
  ∀ (k : ℕ). Real.zero ≤ Real.exponentialTerm(Real.one, k)
      by {
        take k : ℕ;
        done by Real.exponentialTerm_nonneg
      };
  ∀ (m : ℕ). 3 ≤ m → Real.one + Real.one + 1 / (2 : ℝ) ≤ Real.partialSum(Real.exponentialTerm(Real.one), m)
      by {
        take m : ℕ;
        take threeBelow : 3 ≤ m;
        Real.partialSum(Real.exponentialTerm(Real.one), 3) ≤ Real.partialSum(Real.exponentialTerm(Real.one), m)
            by Real.partialSum_monotone_of_nonneg;
        done by substituting sumAtThree
      };
  Real.one + Real.one + 1 / (2 : ℝ) ≤ Real.exponential(Real.one)
      by Real.SequenceConverges.ge_of_eventually_ge(
             s := Real.partialSum(Real.exponentialTerm(Real.one)),
             converges := Real.exponential_converges(Real.one), N := 3)
      as aboveSumThree;
  (1 : ℝ) > 0;
  1 / (2 : ℝ) > 0;
  Real.one + Real.one
     = (Real.one + Real.one) + Real.zero
     < (Real.one + Real.one) + 1 / (2 : ℝ)
           by Real.add_left_preserves_LessThan
     ≤ Real.exponential(Real.one)
           by aboveSumThree
}

-- Real/limits.math
--
-- The arithmetic of sequence limits, and the first consequence of
-- completeness: a monotone sequence bounded above converges (to the
-- supremum of its range). Limits of sums and negations run on the
-- triangle inequality with the usual ε/2 bookkeeping; the monotone
-- convergence theorem is where `Real.supremum_exists` starts paying
-- analytic dividends.

module Real.limits

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.order
import Natural.maximum
import Natural.eventually
import Rational.basics
import Rational.addition
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.halve
import Rational.positive
import Rational.multiplication
import Rational.order_multiplication
import Rational.linearity
import Rational.reciprocal
import Rational.archimedean
import Set.basics
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.order
import Real.linearity
import Real.absolute_value
import Real.absolute_value_order
import Real.order_multiplication
import Real.division
import Real.density
import Real.embedding_order
import Real.convergence
import Real.supremum

-- ----------------------------------------------------------------------
-- Constant sequences converge to their value.
theorem Real.constant_sequence_converges (c : Real)
        : Real.SequenceConverges((n : Natural) ↦ c, c) :=
  (ε : Real)
  (εPositive : ε > 0) ↦
    witness 0 with
        (m : Natural) (_ : 0 ≤ m) ↦
          abs(c - c)
             = abs((0 : Real))
                   by substituting (ring : c - c = 0)
             = 0
             < ε

-- ----------------------------------------------------------------------
-- The Archimedean core: 1/(n+1) → 0. This is the one place ℝ's Archimedean
-- property descends to ℚ's: the decay tolerance is the rational bound
-- `Rational.scaled_reciprocal_eventually_below`, built at a rational ε and
-- lifted to real ε by density (`of_rational`). Callers get a clean real-ε
-- convergence and never see a rational tolerance.
theorem Real.reciprocal_successor_converges_zero
        : Real.SequenceConverges((n : Natural) ↦ 1 / (1 + n : Real), Real.zero) :=
  by Real.SequenceConverges.of_rational(
      rationalBound :=
  (ε : Rational)
  (εPositive : ε > Rational.zero) ↦ {
    Rational.zero ≤ (1 : Rational);
    Rational.IsNonneg((1 : Rational));
    choose N such that
        ∀ (m : Natural). N ≤ m
          → (1 : Rational) * Rational.reciprocal_function((1 + m : Rational)) < ε
        as tailBelow
        from Rational.scaled_reciprocal_eventually_below;
    witness N with
        (m : Natural) (aboveThreshold : N ≤ m) ↦ {
          (1 + m : Rational) > Rational.zero;
          (1 + m : Rational) ≠ Rational.zero;
          (1 + m : Real) > 0;
          (1 + m : Real) ≠ 0;
          (((1 : Rational)
                 * Rational.reciprocal_function((1 + m : Rational))) : Real)
             = ((1 : Rational) : Real)
               * ((Rational.reciprocal_function((1 + m : Rational))) : Real)
             = ((1 : Rational) : Real) * (1 / (1 + m : Real))
             = 1 / (1 + m : Real);
          (1 : Rational)
                      * Rational.reciprocal_function((1 + m : Rational))
                  < ε
              by tailBelow;
          (((1 : Rational) * Rational.reciprocal_function((1 + m : Rational))) : Real) < (ε : Real);
          1 / (1 + m : Real) < (ε : Real);
          (1 : Real) > 0;
          1 / (1 + m : Real) > 0;
          1 / (1 + m : Real) ≥ 0;
          Real.IsNonneg(1 / (1 + m : Real));
          abs(1 / (1 + m : Real) - Real.zero)
             = abs(1 / (1 + m : Real))
                   by (1 / (1 + m : Real) - Real.zero
                       = 1 / (1 + m : Real))
             = 1 / (1 + m : Real)
             < (ε : Real)
        }
  })

-- ----------------------------------------------------------------------
-- Sum of limits: each summand within ε/2 puts the sum within ε.
theorem Real.SequenceConverges.add (s t : Natural → Real)
        (sLimit tLimit : Real)
        (sConverges : Real.SequenceConverges(s, sLimit))
        (tConverges : Real.SequenceConverges(t, tLimit))
        : Real.SequenceConverges((n : Natural) ↦ s(n) + t(n), sLimit + tLimit) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    ε / 2 > 0 as halfPositive;
    choose sThreshold as sClose
        from sConverges(ε / 2, halfPositive);
    choose tThreshold as tClose
        from tConverges(ε / 2, halfPositive);
    witness Natural.maximum(sThreshold, tThreshold) with
        (m : Natural)
        (aboveMaximum : Natural.maximum(sThreshold, tThreshold) ≤ m) ↦ {
          sThreshold ≤ m as sAbove;
          tThreshold ≤ m as tAbove;
          abs(s(m) - sLimit) < ε / 2 by sClose(m, sAbove);
          abs(t(m) - tLimit) < ε / 2 by tClose(m, tAbove);
          abs((s(m) + t(m)) - (sLimit + tLimit))
             = abs((s(m) - sLimit) + (t(m) - tLimit))
                   by substituting
                       (ring : (s(m) + t(m)) - (sLimit + tLimit)
                           = (s(m) - sLimit) + (t(m) - tLimit))
             ≤ abs(s(m) - sLimit) + abs(t(m) - tLimit)
             < ε / 2 + ε / 2
             = ε
        }
  }

-- Negating a sequence negates its limit.
theorem Real.SequenceConverges.negate (s : Natural → Real) (sLimit : Real)
        (sConverges : Real.SequenceConverges(s, sLimit))
        : Real.SequenceConverges((n : Natural) ↦ -s(n), -sLimit) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    choose threshold from sConverges(ε, εPositive);
    witness threshold with
        (m : Natural) (aboveThreshold : threshold ≤ m) ↦
          abs(-s(m) - -sLimit)
             = abs(-(s(m) - sLimit))
                   by substituting
                       (ring : -s(m) - -sLimit = -(s(m) - sLimit))
             = abs(s(m) - sLimit)
             < ε
  }

-- ----------------------------------------------------------------------
-- Shifting the index by one leaves the limit unchanged: the tail of a
-- convergent sequence has the same limit.
theorem Real.SequenceConverges.shift_one (s : Natural → Real) (limit : Real)
        (sConverges : Real.SequenceConverges(s, limit))
        : Real.SequenceConverges((n : Natural) ↦ s(1 + n), limit) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    choose threshold from sConverges(ε, εPositive);
    witness threshold with
        (m : Natural) (aboveThreshold : threshold ≤ m) ↦ {
          threshold
             ≤ m
             ≤ 1 + m;
          abs(s(1 + m) - limit) < ε
        }
  }

-- ----------------------------------------------------------------------
-- Convergence only reads the terms: pointwise-equal sequences share
-- their limits.
theorem Real.SequenceConverges.of_pointwise (s t : Natural → Real)
        (limit : Real)
        (pointwiseEqual : ∀ (n : Natural). s(n) = t(n))
        (sConverges : Real.SequenceConverges(s, limit))
        : Real.SequenceConverges(t, limit) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    choose threshold from sConverges(ε, εPositive);
    witness threshold with
        (m : Natural) (aboveThreshold : threshold ≤ m) ↦
          abs(t(m) - limit)
             = abs(s(m) - limit)    by pointwiseEqual(m)
             < ε
  }

-- The squeeze at zero: a sequence dominated in absolute value by one
-- that vanishes also vanishes.
theorem Real.SequenceConverges.squeeze_zero (v u : Natural → Real)
        (dominated : ∀ (n : Natural). abs(v(n)) ≤ u(n))
        (uVanishes : Real.SequenceConverges(u, (0 : Real)))
        : Real.SequenceConverges(v, (0 : Real)) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    choose threshold from uVanishes(ε, εPositive);
    witness threshold with
        (m : Natural) (aboveThreshold : threshold ≤ m) ↦ {
          u(m) ≤ abs(u(m));
          abs(v(m) - 0)
             = abs(v(m))
                   by substituting (ring : v(m) - 0 = v(m))
             ≤ u(m)
             ≤ abs(u(m))
             = abs(u(m) - 0)
                   by substituting (ring : u(m) - 0 = u(m))
             < ε
        }
  }

-- ----------------------------------------------------------------------
-- Product of limits. The difference splits as
--   s(m)·t(m) − S·T = s(m)·(t(m) − T) + T·(s(m) − S).
-- Roof each factor over its limit — |s(m)| ≤ 1 + |S| once s is within 1 of
-- S, and |T| ≤ 1 + |T| — and pick each tolerance as ε/4 over the opposite
-- roof, so each piece is bounded by roof · (ε/4)/roof = ε/4. The whole
-- estimate lives in ℝ: the complete ordered field divides, so no descent to
-- a rational tolerance is needed.
theorem Real.SequenceConverges.multiply (s t : Natural → Real)
        (sLimit tLimit : Real)
        (sConverges : Real.SequenceConverges(s, sLimit))
        (tConverges : Real.SequenceConverges(t, tLimit))
        : Real.SequenceConverges((n : Natural) ↦ s(n) * t(n), sLimit * tLimit) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    -- A positive roof over each limit, one unit above its absolute value.
    let sBound : Real := 1 + abs(sLimit);
    let tBound : Real := 1 + abs(tLimit);
    abs(sLimit) ≥ 0;
    abs(tLimit) ≥ 0;
    (0 : Real) < 1 as onePositive;
    (0 : Real) ≤ 1;
    (0 : Real)
       < 1
       = 1 + 0
       ≤ 1 + abs(sLimit);
    (0 : Real)
       < 1
       = 1 + 0
       ≤ 1 + abs(tLimit);
    sBound ≠ 0;
    tBound ≠ 0;
    abs(tLimit)
       = 0 + abs(tLimit)
       ≤ 1 + abs(tLimit);
    -- Each piece gets a quarter of ε, divided by the opposite roof.
    ε / 4 > 0;
    (ε / 4) / sBound > 0 as tTolerancePositive;
    (ε / 4) / tBound > 0 as sTolerancePositive;
    -- Tails: s within one unit of its limit (to roof |s(m)|), and each
    -- sequence within its tolerance.
    choose unitThreshold as sUnitClose from sConverges((1 : Real), onePositive);
    choose tThreshold as tClose from tConverges((ε / 4) / sBound, tTolerancePositive);
    choose sThreshold as sClose from sConverges((ε / 4) / tBound, sTolerancePositive);
    witness Natural.maximum(unitThreshold, Natural.maximum(tThreshold, sThreshold)) with
        (m : Natural)
        (aboveAll : Natural.maximum(unitThreshold,
                        Natural.maximum(tThreshold, sThreshold)) ≤ m) ↦ {
          unitThreshold ≤ m;
          Natural.maximum(tThreshold, sThreshold) ≤ m;
          tThreshold ≤ m;
          sThreshold ≤ m;
          abs(s(m)) ≥ 0;
          abs(t(m) - tLimit) ≥ 0;
          abs(s(m) - sLimit) ≥ 0;
          -- |s(m)| ≤ sBound, since s is within one unit of its limit.
          abs(s(m) - sLimit) < 1 by sUnitClose(m, (unitThreshold ≤ m));
          abs(s(m) - sLimit) ≤ 1;
          abs(s(m))
             = abs((s(m) - sLimit) + sLimit)
                   by substituting (ring : s(m) = (s(m) - sLimit) + sLimit)
             ≤ abs(s(m) - sLimit) + abs(sLimit)   by Real.triangle_inequality
             ≤ 1 + abs(sLimit);
          -- Each tolerance is realised at m, then weakened to ≤.
          abs(t(m) - tLimit) < (ε / 4) / sBound by tClose(m, (tThreshold ≤ m));
          abs(t(m) - tLimit) ≤ (ε / 4) / sBound;
          abs(s(m) - sLimit) < (ε / 4) / tBound by sClose(m, (sThreshold ≤ m));
          abs(s(m) - sLimit) ≤ (ε / 4) / tBound;
          -- Each piece collapses to a quarter of ε.
          abs(s(m) * (t(m) - tLimit))
             = abs(s(m)) * abs(t(m) - tLimit)
             ≤ sBound * ((ε / 4) / sBound)
             = ε / 4;
          abs(tLimit * (s(m) - sLimit))
             = abs(tLimit) * abs(s(m) - sLimit)
             ≤ tBound * ((ε / 4) / tBound)
             = ε / 4;
          -- Assemble: split, triangle, two quarters, half < whole.
          abs(s(m) * t(m) - sLimit * tLimit)
             = abs(s(m) * (t(m) - tLimit) + tLimit * (s(m) - sLimit))
                   by substituting
                       (ring : s(m) * t(m) - sLimit * tLimit
                           = s(m) * (t(m) - tLimit) + tLimit * (s(m) - sLimit))
             ≤ abs(s(m) * (t(m) - tLimit)) + abs(tLimit * (s(m) - sLimit))
             ≤ ε / 4 + abs(tLimit * (s(m) - sLimit))
             ≤ ε / 4 + ε / 4
             = ε / 2   by field
             < ε
        }
  }

-- ----------------------------------------------------------------------
-- Any real multiple of the reciprocal-successor sequence still vanishes:
-- c/(n+1) → 0. Pure real ε — the ℚ Archimedean descent lives entirely in
-- `reciprocal_successor_converges_zero`; here the limit is only scaled by a
-- constant, via the product of limits and pointwise `c·(1/(n+1)) = c/(n+1)`.
theorem Real.scaled_reciprocal_successor_converges_zero (c : Real)
        : Real.SequenceConverges((n : Natural) ↦ c / (1 + n : Real), Real.zero) := {
  Real.constant_sequence_converges(c);
  Real.reciprocal_successor_converges_zero;
  Real.SequenceConverges((n : Natural) ↦ c * (1 / (1 + n : Real)), c * Real.zero)
      by Real.SequenceConverges.multiply(
             s := (n : Natural) ↦ c,
             t := (n : Natural) ↦ 1 / (1 + n : Real));
  Real.SequenceConverges((n : Natural) ↦ c * (1 / (1 + n : Real)), Real.zero)
      by substituting (ring : c * Real.zero = Real.zero);
  ∀ (n : Natural). c * (1 / (1 + n : Real)) = c / (1 + n : Real)
      by (n : Natural) ↦ {
           (1 + n : Real) ≠ 0;
           done
         };
  done by Real.SequenceConverges.of_pointwise(
             s := (n : Natural) ↦ c * (1 / (1 + n : Real)))
}

-- ----------------------------------------------------------------------
-- Monotone convergence. The range of the sequence, as a set.
definition Real.sequence_range (s : Natural → Real) : Set(Real) :=
  (x : Real) ↦ ∃ (n : Natural). s(n) = x

-- If no term of the sequence exceeds c, then c bounds the whole range.
theorem Real.upper_bound_of_no_term_above (s : Natural → Real) (c : Real)
        (noTermAbove : ¬(∃ (N : Natural). c < s(N)))
        : Real.IsUpperBound(Real.sequence_range(s), c) :=
  (y : Real) (yInRange : y ∈ Real.sequence_range(s)) ↦ {
    choose n such that s(n) = y from yInRange;
    ¬(c < s(n))
        by (above : c < s(n)) ↦ {
             ∃ (N : Natural). c < s(N) by witness n with above as termExists;
             noTermAbove(termExists)
           };
    s(n) ≤ c by Real.LessOrEqual_of_not_LessThan;
    done
  }

-- Subtracting something positive moves strictly down.
theorem Real.subtract_positive_LessThan (x ε : Real)
        (εPositive : ε > 0)
        : x - ε < x := {
  -ε
     = 0 + -ε
     < ε + -ε
     = 0;
  x - ε
     = -ε + x
     < 0 + x
     = x
}

-- A monotone sequence bounded above converges — to the supremum of its
-- range. Within any ε of the supremum there is a term s(N) (else the
-- supremum could be lowered by ε), and monotonicity keeps the whole
-- tail trapped between s(N) and the supremum.
theorem Real.monotone_bounded_converges (s : Natural → Real)
        (monotone : ∀ (i j : Natural). i ≤ j → s(i) ≤ s(j))
        (bound : Real)
        (bounded : ∀ (n : Natural). s(n) ≤ bound)
        : Real.SequenceConvergent(s) := {
  -- The range is nonempty and bounded above, so it has a supremum.
  Set.IsNonempty(Real, Real.sequence_range(s))
      by witness s(0) with witness 0 with reflexivity(Real, s(0));
  Real.IsBoundedAbove(Real.sequence_range(s))
      by witness bound with
          (y : Real) (yInRange : y ∈ Real.sequence_range(s)) ↦ {
            choose n such that s(n) = y from yInRange;
            s(n) ≤ bound;
            done
          };
  choose limit such that Real.IsSupremum(Real.sequence_range(s), limit)
      from Real.supremum_exists;
  Real.IsUpperBound(Real.sequence_range(s), limit);
  ∀ (otherBound : Real).
      Real.IsUpperBound(Real.sequence_range(s), otherBound)
    → limit ≤ otherBound;
  witness limit with
      (ε : Real)
      (εPositive : ε > 0) ↦ {
        -- Some term rises above limit − ε; otherwise limit − ε would be a
        -- smaller upper bound than the least one.
        suppose ¬(∃ (N : Natural). limit - ε < s(N)) for contradiction {
            Real.IsUpperBound(Real.sequence_range(s),
                limit - ε);
            limit ≤ limit - ε;
            limit - ε < limit;
            limit < limit by Real.LessThan.transitive_left;
            False;
            done
        };
        choose N such that limit - ε < s(N);
        witness N with
            (m : Natural) (aboveThreshold : N ≤ m) ↦ {
              -- limit − ε < s(N) ≤ s(m) ≤ limit < limit + ε.
              limit - ε
                 < s(N)
                 ≤ s(m);
              s(m) ∈ Real.sequence_range(s)
                  by witness m with reflexivity(Real, s(m));
              s(m) ≤ limit;
              s(m) - limit
                 ≤ limit - limit
                 = 0
                 < ε;
              -ε
                 = (limit - ε) - limit
                 < s(m) - limit;
              done by Real.absolute_value_LessThan_of_bounds
            }
      }
}

-- ----------------------------------------------------------------------
-- Convergence only sees the sequence's values: pointwise-equal
-- sequences share their limits.
theorem Real.SequenceConverges.pointwise
        (s sequencePrime : Natural → Real) (limit : Real)
        (pointwiseEqual : ∀ (n : Natural). s(n) = sequencePrime(n))
        (primeConverges : Real.SequenceConverges(sequencePrime, limit))
        : Real.SequenceConverges(s, limit) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    choose N from primeConverges(ε, εPositive);
    witness N with
        (m : Natural) (aboveThreshold : N ≤ m) ↦
          abs(s(m) - limit)
             = abs(sequencePrime(m) - limit)   by substituting pointwiseEqual(m)
             < ε
  }

-- ----------------------------------------------------------------------
-- Divergence to +∞: the sequence eventually exceeds every rational
-- bound (and hence, by density, every real one).
definition Real.TendsToInfinity (s : Natural → Real) : Proposition :=
  ∀ (bound : Real).
    eventually (m). bound < s(m)

-- ----------------------------------------------------------------------
-- Limits respect eventual bounds: if some tail of the sequence stays
-- at or below a roof, the limit cannot rise above it (and dually for
-- floors). Were the limit strictly above, a rational sliver of the gap
-- would separate the tail from the limit — contradicting convergence.

theorem Real.SequenceConverges.le_of_eventually_le
        (s : Natural → Real) (limit bound : Real)
        (converges : Real.SequenceConverges(s, limit))
        (N : Natural)
        (tailBelow : ∀ (m : Natural). N ≤ m → s(m) ≤ bound)
        : limit ≤ bound := {
  suppose bound < limit as above for contradiction {
    0
       = bound - bound
       < limit - bound;
    let ε : Real := (limit - bound) / 2;
    (2 : Real) > 0;
    (limit - bound) / 2 > 0 as εPositive;
    ε < limit - bound by Real.divide_two_less_than_self;
    choose M as tailClose from converges(ε, εPositive);
    N ≤ Natural.maximum(N, M);
    M ≤ Natural.maximum(N, M);
    s(Natural.maximum(N, M)) ≤ bound;
    abs(s(Natural.maximum(N, M)) - limit) < ε
        by tailClose(Natural.maximum(N, M), (M ≤ Natural.maximum(N, M)));
    -ε < s(Natural.maximum(N, M)) - limit
        by Real.absolute_value_LessThan_bounds;
    limit - ε
       = -ε + limit
       < (s(Natural.maximum(N, M)) - limit) + limit
       = s(Natural.maximum(N, M));
    bound + ε
       < bound + (limit - bound)
       = limit;
    bound
       = (bound + ε) - ε
       < limit - ε
       < s(Natural.maximum(N, M));
    bound < bound by Real.LessThan.transitive_right;
    done
  };
  done by Real.LessOrEqual_of_not_LessThan
}

theorem Real.SequenceConverges.ge_of_eventually_ge
        (s : Natural → Real) (limit bound : Real)
        (converges : Real.SequenceConverges(s, limit))
        (N : Natural)
        (tailAbove : ∀ (m : Natural). N ≤ m → bound ≤ s(m))
        : bound ≤ limit := {
  suppose limit < bound as below for contradiction {
    0
       = limit - limit
       < bound - limit;
    let ε : Real := (bound - limit) / 2;
    (2 : Real) > 0;
    (bound - limit) / 2 > 0 as εPositive;
    ε < bound - limit by Real.divide_two_less_than_self;
    choose M as tailClose from converges(ε, εPositive);
    N ≤ Natural.maximum(N, M);
    M ≤ Natural.maximum(N, M);
    bound ≤ s(Natural.maximum(N, M));
    abs(s(Natural.maximum(N, M)) - limit) < ε
        by tailClose(Natural.maximum(N, M), (M ≤ Natural.maximum(N, M)));
    s(Natural.maximum(N, M)) - limit < ε
        by Real.absolute_value_LessThan_bounds;
    s(Natural.maximum(N, M))
       = (s(Natural.maximum(N, M)) - limit) + limit
       < ε + limit
       = limit + ε;
    s(Natural.maximum(N, M))
       < limit + ε
       < limit + (bound - limit)
       = bound;
    bound < bound by Real.LessThan.transitive_left;
    done
  };
  done by Real.LessOrEqual_of_not_LessThan
}

-- Real/absolute_value.math
--
-- Pointwise absolute value of a Cauchy sequence, lifted to a unary
-- operation on Real. Cauchyness of |s| follows from the reverse
-- triangle inequality ||s(m)| - |s(n)|| ≤ |s(m) - s(n)|: the bound
-- on the RHS transfers directly to the LHS, so the same N witnesses.
-- Real.triangle_inequality is then a pointwise lift of
-- Rational.triangle_inequality through Quotient.induct_two.

module Real.absolute_value

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.maximum
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.order_arithmetic
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.triangle
import Rational.triangle_more
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.ring
import Real.order

-- ----------------------------------------------------------------------
-- Pointwise absolute value preserves the Cauchy property.

-- The pointwise absolute value of a Cauchy sequence is Cauchy.
-- For any ε > 0, use the same N as s itself; then for m, n ≥ N,
--   ||s(m)| - |s(n)|| ≤ |s(m) - s(n)| < ε.
theorem Rational.sequence.absolute_value_is_cauchy
        (s : Rational.sequence.Sequence)
        (sIsCauchy : Rational.sequence.IsCauchy(s))
        : Rational.sequence.IsCauchy(
              (n : Natural) ↦ abs(s(n))) :=
  (ε : Rational)
           (εPositive : Rational.zero < ε) ↦ {
    -- `obtain` cannot infer the existential through the opaque Rational, so
    -- state it top-down first.
    claim sBounded
        : ∃ (N : Natural).
            ∀ (m : Natural). N ≤ m → ∀ (n : Natural). N ≤ n → abs(s(m) - s(n)) < ε;
    choose N from sBounded;
    witness N with
        (m : Natural) (N_leq_m : N ≤ m)
                 (n : Natural) (N_leq_n : N ≤ n) ↦
          calc abs(
                   abs(s(m))
                   - abs(s(n)))
             ≤ abs(s(m) - s(n))
             < ε
  }

-- ----------------------------------------------------------------------
-- Absolute value of a packaged Cauchy sequence.

definition CauchyRationalSequence.absolute_value
        : CauchyRationalSequence → CauchyRationalSequence
  | CauchyRationalSequence.make(s, sCauchy) =>
      CauchyRationalSequence.make(
          (n : Natural) ↦ abs(s(n)),
          Rational.sequence.absolute_value_is_cauchy(s, sCauchy))

-- Bridge: sf(absolute_value(rep), m) = |sf(rep, m)|.
theorem CauchyRationalSequence.sequenceFunction_absolute_value
        : ∀ (rep : CauchyRationalSequence). ∀ (m : Natural).
            CauchyRationalSequence.sequenceFunction(
                CauchyRationalSequence.absolute_value(rep), m)
            = abs(
                  CauchyRationalSequence.sequenceFunction(rep, m))
  | CauchyRationalSequence.make(s, _), m =>
      reflexivity(Rational, abs(s(m)))

-- ----------------------------------------------------------------------
-- Respect: equivalent sequences have equivalent absolute-value
-- sequences. Reverse triangle: ||sf(rep, m)| - |sf(rep', m)|| ≤
-- |sf(rep, m) - sf(rep', m)| < ε.

theorem Real.absolute_value_respects
        (rep rep' : CauchyRationalSequence)
        (equivalenceHypothesis : CauchyEquivalent(rep, rep'))
        : CauchyEquivalent(
              CauchyRationalSequence.absolute_value(rep),
              CauchyRationalSequence.absolute_value(rep')) :=
  (ε : Rational)
           (εPositive : Rational.zero < ε) ↦ {
      choose N from equivalenceHypothesis(ε, εPositive);
      witness N with
              (m : Natural) (N_leq_m : N ≤ m) ↦
                -- Goal: |sf(abs(rep), m) - sf(abs(rep'), m)| < ε.
                -- Via the bridge: sf(abs(rep), m) = |sf(rep, m)|.
                -- So goal becomes ||sf(rep, m)| - |sf(rep', m)|| < ε,
                -- which is bounded by |sf(rep, m) - sf(rep', m)| via
                -- reverse triangle, and that is bounded by ε via the
                -- equivalence hypothesis at N.
                calc abs(
                         CauchyRationalSequence.sequenceFunction(
                             CauchyRationalSequence.absolute_value(rep), m)
                         - CauchyRationalSequence.sequenceFunction(
                             CauchyRationalSequence.absolute_value(rep'), m))
                   = abs(
                         abs(
                             CauchyRationalSequence.sequenceFunction(rep, m))
                         - abs(
                             CauchyRationalSequence.sequenceFunction(rep', m)))
                   ≤ abs(
                         CauchyRationalSequence.sequenceFunction(rep, m)
                         - CauchyRationalSequence.sequenceFunction(rep', m))
                   < ε
      }

-- ----------------------------------------------------------------------
-- Real.absolute_value: take the pointwise absolute value of the
-- representative; well-defined by the reverse-triangle respect above.
definition Real.absolute_value : Real → Real
  by representatives rep ↦
       (Quotient.class_of(CauchyRationalSequence.absolute_value(rep)) : Real)
  well_defined by Real.absolute_value_respects

overload abs := Real.absolute_value

-- ----------------------------------------------------------------------
-- Triangle inequality on Real.

-- Strategy. After Quotient.induct_two and decomposing each rep into
-- `CauchyRationalSequence.make(s, _)`, the full Real-level chain
-- (Real.absolute_value, Real.add, Real.subtract, Real.IsNonneg) collapses
-- via Quotient.lift β + pattern-match ι to a goal of the form
--   IsEventuallyNonneg(λn. (|sx(n)| + |sy(n)|) + -|sx(n) + sy(n)|).
-- The witness is N = 0; pointwise the bound 0 ≤ |sx| + |sy| - |sx + sy|
-- is exactly Rational.triangle_inequality, and -ε < 0 by positivity of ε.

-- At constructor reps. Pattern-matching exposes the underlying sequences
-- so every Quotient.lift and CauchyRationalSequence pattern-match reduces.
theorem Real.triangle_inequality_at_make
        : ∀ (rep_x rep_y : CauchyRationalSequence).
            abs(
                (Quotient.class_of(rep_x) : Real) + Quotient.class_of(rep_y))
            ≤ abs((Quotient.class_of(rep_x) : Real))
              + abs((Quotient.class_of(rep_y) : Real))
  | CauchyRationalSequence.make(sx, _),
    CauchyRationalSequence.make(sy, _) =>
      unfold Real.IsNonneg in
      ((ε : Rational)
               (εPositive : Rational.zero < ε) ↦
        witness 0 with
            (m : Natural) (_ : 0 ≤ m) ↦ {
              -- 0 ≤ (|sx(m)| + |sy(m)|) − |sx(m) + sy(m)| is the triangle
              -- inequality; −ε < 0 by positivity of ε.
              claim abs(sx(m) + sy(m)) ≤ abs(sx(m)) + abs(sy(m));
              calc -ε
                 < Rational.zero
                      by Rational.negate_LessThan_zero_of_positive
                 = abs(sx(m) + sy(m)) + -abs(sx(m) + sy(m))
                 ≤ (abs(sx(m)) + abs(sy(m)))
                   + -abs(sx(m) + sy(m))
                      by Rational.add_preserves_LessOrEqual
            })

-- Triangle on Real. Lift via Quotient.induct_two to the at-make form.
automatic theorem Real.triangle_inequality (x y : Real)
        : abs(x + y)
          ≤ abs(x) + abs(y) :=
  by_representatives x as repX, y as repY =>
      done by Real.triangle_inequality_at_make

-- ----------------------------------------------------------------------
-- |-x| = |x| on Real. Lift the pointwise Rational.absolute_value_negate.
theorem Real.absolute_value_negate (x : Real)
        : abs(-x) = abs(x) :=
  cases x { | rep_x => {
    -- Pointwise: sf(abs(neg(rep_x)), n) = |sf(neg(rep_x), n)| = |-sf(rep_x, n)|
    --                                   = |sf(rep_x, n)| = sf(abs(rep_x), n).
    claim ∀ (n : Natural).
            CauchyRationalSequence.sequenceFunction(
                CauchyRationalSequence.absolute_value(
                    CauchyRationalSequence.negate(rep_x)), n)
            = CauchyRationalSequence.sequenceFunction(
                  CauchyRationalSequence.absolute_value(rep_x), n)
        by (n : Natural) ↦
          calc CauchyRationalSequence.sequenceFunction(
                   CauchyRationalSequence.absolute_value(
                       CauchyRationalSequence.negate(rep_x)), n)
             = abs(
                   CauchyRationalSequence.sequenceFunction(
                       CauchyRationalSequence.negate(rep_x), n))
             = abs(
                   -CauchyRationalSequence.sequenceFunction(rep_x, n))
             = abs(
                   CauchyRationalSequence.sequenceFunction(rep_x, n))
             = CauchyRationalSequence.sequenceFunction(
                   CauchyRationalSequence.absolute_value(rep_x), n);
    done by Real.equal_of_pointwise_sequence
  } }

-- |x - y| = |y - x| on Real. From x - y = -(y - x) plus
-- Real.absolute_value_negate.
theorem Real.absolute_value_subtract_swap (x y : Real)
        : abs(x - y) = abs(y - x) :=
  calc abs(x - y)
     = abs(-(y - x))
     = abs(y - x)

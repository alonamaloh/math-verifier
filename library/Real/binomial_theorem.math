-- Real/binomial_theorem.math
--
-- The binomial theorem on ℝ (Freek #44), as an instance of the generic
-- commutative-ring theorem `CommutativeRing.binomial_theorem`. The work is
-- three bridges between ℝ's native operations and the bundled-ring ones at
-- `Real.ring`: powers, the finite sum, and the Natural-coefficient cast.

module Real.binomial_theorem

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.monus
import Natural.binomial
import Natural.one_plus_induction
import Rational.basics
import Rational.embedding
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Algebra.ring_power
import Algebra.ring_from_natural
import Algebra.ring_summation
import Algebra.binomial
import Real.basics
import Real.addition
import Real.multiplication
import Real.ring
import Real.algebra
import Real.instances
import Real.ring_bundle
import Real.embedding
import Real.embedding_order
import Real.power
import Real.series

-- Bridge 1: the bundled-ring power at `Real.ring` is ℝ's native power.
theorem Real.power_eq_ring_power (x : Real) (n : Natural)
        : Ring.power(Real.ring, x, n) = Real.power(x, n) :=
  by induction on n with IH {
    case base: done
    case step(k):
        Ring.power(Real.ring, x, 1 + k)
           = x * Ring.power(Real.ring, x, k)
           = x * Real.power(x, k)              by IH
           = Real.power(x, 1 + k)
  }

-- Bridge 2: the bundled-ring sum Σ_{i≤n} is ℝ's partial sum over 1+n terms.
theorem Real.partialSum_eq_ring_sum (f : Natural → Real) (n : Natural)
        : Ring.Sum(Real.ring, f, n) = Real.partialSum(f, 1 + n) :=
  by induction on n with IH {
    case base:
        Ring.Sum(Real.ring, f, 0)
           = f(0)
           = Real.zero + f(0)
           = Real.partialSum(f, 0) + f(0)
           = Real.partialSum(f, 1 + 0)
    case step(k):
        Ring.Sum(Real.ring, f, 1 + k)
           = Ring.Sum(Real.ring, f, k) + f(1 + k)
           = Real.partialSum(f, 1 + k) + f(1 + k)   by IH
           = Real.partialSum(f, 1 + (1 + k))
  }

-- Bridge 3: the ring's Natural map at `Real.ring` is the ℕ → ℚ → ℝ cast.
theorem Real.from_natural_eq_ring_from_natural (m : Natural)
        : Ring.from_natural(Real.ring, m) = ((m : Rational) : Real) :=
  by induction on m with IH {
    case base: done
    case step(k):
        Ring.from_natural(Real.ring, 1 + k)
           = Ring.from_natural(Real.ring, 1) + Ring.from_natural(Real.ring, k)
           = Ring.one(Real.ring) + Ring.from_natural(Real.ring, k)   by Ring.from_natural_one
           = Real.one + Ring.from_natural(Real.ring, k)
           = Real.one + ((k : Rational) : Real)           by IH
           = ((1 : Rational) : Real) + ((k : Rational) : Real)
           = (((1 + k : Natural) : Rational) : Real)      by Real.from_natural.add_preserves
  }

-- The bundled-ring general term at `Real.ring` is ℝ's binomial summand.
theorem Real.binomialTerm_cast (a b : Real) (n k : Natural)
        : Ring.binomialTerm(Real.ring, a, b, n, k)
          = ((Natural.binomial(n, k) : Rational) : Real)
            * (Real.power(a, k) * Real.power(b, Natural.monus(n, k))) :=
  Ring.binomialTerm(Real.ring, a, b, n, k)
     = Ring.from_natural(Real.ring, Natural.binomial(n, k))
       * (Ring.power(Real.ring, a, k) * Ring.power(Real.ring, b, Natural.monus(n, k)))
     = ((Natural.binomial(n, k) : Rational) : Real)
       * (Ring.power(Real.ring, a, k) * Ring.power(Real.ring, b, Natural.monus(n, k)))
           by substituting Real.from_natural_eq_ring_from_natural
     = ((Natural.binomial(n, k) : Rational) : Real)
       * (Real.power(a, k) * Real.power(b, Natural.monus(n, k)))

-- ----------------------------------------------------------------------
-- Freek #44 on ℝ.
theorem Real.binomial_theorem (a b : Real) (n : Natural)
        : Real.power(a + b, n)
          = Real.partialSum(
                (k : Natural) ↦
                    (Natural.binomial(n, k) : Rational)
                    * (Real.power(a, k)
                       * Real.power(b, Natural.monus(n, k))),
                1 + n) :=
  Real.power(a + b, n)
     = Ring.power(Real.ring, a + b, n)
     = Ring.Sum(Real.ring,
           (k : Natural) ↦ Ring.binomialTerm(Real.ring, a, b, n, k), n)
           by CommutativeRing.binomial_theorem(c := Real.commutative_ring)
     = Real.partialSum(
           (k : Natural) ↦ Ring.binomialTerm(Real.ring, a, b, n, k), 1 + n)
     = Real.partialSum(
           (k : Natural) ↦
               ((Natural.binomial(n, k) : Rational) : Real)
               * (Real.power(a, k) * Real.power(b, Natural.monus(n, k))),
           1 + n)
           by Real.partialSum_pointwise(
                  pointwiseEqual := (k : Natural) ↦ Real.binomialTerm_cast(a, b, n, k))

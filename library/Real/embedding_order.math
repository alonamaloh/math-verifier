-- Real/embedding_order.math
--
-- The embedding ℚ → ℝ preserves the order, in both the weak and the
-- strict form. Strictness is the essential half: a positive rational ε
-- coerces to a positive real, which is what lets every ε–N and ε–δ
-- argument compare real quantities against rational tolerances.

module Real.embedding_order

import Logic.basics
import Logic.excluded_middle
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.order
import Rational.basics
import Rational.addition
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.absolute_value
import Rational.triangle_more
import Rational.linearity
import Rational.embedding
import Natural.basics
import Integer.basics
import Integer.embedding
import Integer.order
import Rational.archimedean
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.ring
import Real.order

-- ----------------------------------------------------------------------
-- Weak order: a ≤ b transfers pointwise (the difference of the constant
-- sequences is the constant b − a, which is nonnegative).
theorem Rational.to_real.LessOrEqual_preserves (a b : Rational)
        (aLessOrEqualB : a ≤ b)
        : (a : Real) ≤ (b : Real) :=
  unfold Real.IsNonneg in
  ((ε : Rational)
  (εPositive : Rational.zero < ε) ↦
    witness 0 with
        (m : Natural) (_ : 0 ≤ m) ↦
          calc -ε
             < Rational.zero by Rational.negate_LessThan_zero_of_positive
             ≤ b + -a
                  by Rational.LessOrEqual_zero_of_IsNonneg)

-- ----------------------------------------------------------------------
-- Strict order. The weak part is above; distinctness is the embedding's
-- injectivity at distinct points: were (a : ℝ) = (b : ℝ), the constant
-- sequences would be Cauchy-equivalent, putting |a − b| below the
-- positive gap b − a itself — yet b − a ≤ |a − b|.
theorem Rational.to_real.LessThan_preserves (a b : Rational)
        (aLessThanB : a < b)
        : (a : Real) < (b : Real) := {
  a ≤ b;
  (a : Real) ≤ (b : Real) as lessOrEqualPart;
  Rational.zero
     = a + -a
     < b + -a   by Rational.add_preserves_LessThan
    as gapPositive;
  ¬((a : Real) = (b : Real)) by {
          suppose (a : Real) = (b : Real) as coercedEqual;
          let equivalent
              : CauchyEquivalent(Rational.to_cauchy_constant(a),
                    Rational.to_cauchy_constant(b))
              := Quotient.equal_implies_equivalent(
                     CauchyRationalSequence, CauchyEquivalent, Real.equivalence,
                     Rational.to_cauchy_constant(a), Rational.to_cauchy_constant(b), coercedEqual);
          -- Evaluate the equivalence at ε = b − a.
          choose N such that
              ∀ (m : Natural). N ≤ m →
                abs(CauchyRationalSequence.sequenceFunction(Rational.to_cauchy_constant(a), m)
                    - CauchyRationalSequence.sequenceFunction(Rational.to_cauchy_constant(b), m))
                  < b - a
              as eventuallyClose
              from equivalent(b - a, gapPositive);
          N ≤ N;
          abs(a - b) < b - a
              by eventuallyClose(N, (N ≤ N)) as tooClose;
          -- But the gap is at most that absolute difference.
          b - a
             ≤ abs(b - a)   by Rational.le_absolute_value
             = abs(a - b)
             < b - a        by tooClose;
          done
        } as notEqualPart;
  And.introduction(lessOrEqualPart, notEqualPart)
}

-- The workhorse special case: a positive rational tolerance is a
-- positive real.
automatic theorem Rational.to_real.positive_preserves (ε : Rational)
        (εPositive : Rational.zero < ε)
        : Real.zero < (ε : Real) := {
  done by Rational.to_real.LessThan_preserves
}

-- ----------------------------------------------------------------------
-- The embedding also REFLECTS the strict order: a strict inequality
-- between the casts forces the rational one (classically — were b ≤ a,
-- the cast of that would contradict the strictness).
theorem Rational.to_real.LessThan_reflects (a b : Rational)
        (strictAtReal : (a : Real) < (b : Real))
        : a < b :=
  {
    suppose ¬(a < b) for contradiction;
    b ≤ a by Rational.not_LessThan_implies_LessOrEqual;
    (b : Real) ≤ (a : Real);
    (a : Real) < (a : Real) by Real.LessThan.transitive_right;
    done
  }

-- ----------------------------------------------------------------------
-- The composite ℕ → ℝ cast is additive, leg by leg.
theorem Real.from_natural_add_preserves (m1 m2 : Natural)
        : (m1 + m2 : Real) = (m1 : Real) + (m2 : Real) :=
  calc (m1 + m2 : Real)
     = (((m1 : Rational) + (m2 : Rational)) : Real)
     = (m1 : Real) + (m2 : Real)

-- The cast of the natural 0 is the real 0 (definitionally, hop by hop).
theorem Real.from_natural_zero_preserves
        : ((0 : Natural) : Real) = Real.zero :=
  reflexivity(Real, Real.zero)

-- The cast of the natural 1 is the real 1.
theorem Real.from_natural_one_preserves
        : ((1 : Rational) : Real) = Real.one := {
  ((1 : Rational) : Real)
     = ((Rational.one) : Real)
     = Real.one
}


-- … and multiplicative.
theorem Real.from_natural_multiply_preserves (m1 m2 : Natural)
        : (m1 * m2 : Real) = (m1 : Real) * (m2 : Real) :=
  calc (m1 * m2 : Real)
     = (((m1 : Rational) * (m2 : Rational)) : Real)
     = (m1 : Real) * (m2 : Real)

-- ----------------------------------------------------------------------
-- The composite ℕ → ℝ cast preserves the order: the weak form, positivity,
-- and the hypothesis-free `1 + n` special case.
theorem Real.from_natural_le_preserves (m1 m2 : Natural) (le : m1 ≤ m2)
        : (m1 : Real) ≤ (m2 : Real) := {
  (m1 : Rational) ≤ (m2 : Rational)
      by Rational.from_natural_le_preserves;
  done
}

theorem Real.from_natural_positive (n : Natural) (nPositive : n > 0)
        : (n : Real) > 0 := {
  (n : Integer) > Integer.zero;
  (n : Rational) > Rational.zero;
  done
}

theorem Real.one_plus_cast_positive (n : Natural)
        : (1 + n : Real) > 0 := {
  (1 + n : Rational) > 0;
  done
}

-- Real/arithmetic_geometric_mean.math
--
-- The two-variable arithmetic/geometric mean inequality (toward Freek
-- #38): a nonnegative g with g² = x·y sits below the arithmetic mean
-- (x + y)/2 — and such a g always exists, by the square-root theorem.
--
-- The algebra is the classic square gap:
--   ((x + y)/2)² − x·y = ((x − y)/2)² ≥ 0,
-- so g² is bounded by the mean's square, and squares compare like
-- their nonnegative roots.

module Real.arithmetic_geometric_mean

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.order
import Natural.add_order
import Natural.monus
import Natural.one_plus_induction
import Integer.basics
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.halve
import Rational.positive
import Rational.linearity
import Rational.minimum
import Rational.reciprocal
import Rational.archimedean
import Set.basics
import Algebra.ring_lemmas
import Real.interface
import Real.harmonic_series

-- Any nonnegative square root of x·y is at most the arithmetic mean.
theorem Real.geometric_mean_le_arithmetic_mean
        (x y g : Real)
        (xNonneg : 0 ≤ x) (yNonneg : 0 ≤ y)
        (gNonneg : 0 ≤ g)
        (gSquare : g * g = x * y)
        : g ≤ (x + y) / 2 := {
  let mean : Real := (x + y) / 2;
  let halfDiff : Real := (x - y) / 2;
  -- The mean is nonnegative.
  (0 : Real)
   = 0 + 0
   ≤ x + 0   by Real.add_preserves_LessOrEqual
   ≤ x + y    by Real.add_preserves_LessOrEqual_left;
  0 < (2 : Real);
  0 ≤ mean by Real.divide_nonneg;
  -- g² ≤ mean², via the square gap mean² − x·y = ((x − y)/2)².
  x * y = ((x + y) / 2) * ((x + y) / 2) - ((x - y) / 2) * ((x - y) / 2)
      by field;
  Real.IsNonneg(halfDiff * halfDiff);
  0 ≤ halfDiff * halfDiff;
  -(halfDiff * halfDiff)
   = 0 - halfDiff * halfDiff
   ≤ halfDiff * halfDiff - halfDiff * halfDiff   by Real.add_preserves_LessOrEqual
   = 0;
  g * g
   = x * y
   = mean * mean + -(halfDiff * halfDiff)
   ≤ mean * mean + 0                         by Real.add_preserves_LessOrEqual_left
   = mean * mean;
  -- Nonnegative numbers compare like their squares.
  {
    suppose mean < g for contradiction {
        0 < g by Real.LessThan.transitive_left;
        mean ≤ g;
        mean * mean
         ≤ g * mean   by Real.LessOrEqual.multiply_by_nonneg_right
         = mean * g
         < g * g       by Real.LessThan.multiply_by_positive_right;
        g * g < g * g by Real.LessThan.transitive_left;
        done
    };
    done by Real.LessOrEqual_of_not_LessThan
  }
}

-- The geometric mean exists, and the inequality holds for it: the
-- two-variable arithmetic/geometric mean inequality.
theorem Real.arithmetic_geometric_mean_two
        (x y : Real)
        (xNonneg : 0 ≤ x) (yNonneg : 0 ≤ y)
        : ∃ (g : Real).
            0 ≤ g ∧ g * g = x * y ∧ g ≤ (x + y) / 2 := {
  Real.IsNonneg(x);
  Real.IsNonneg(y);
  Real.IsNonneg(x * y);
  0 ≤ x * y;
  choose g such that 0 ≤ g ∧ g * g = x * y from Real.square_root_exists;
  witness g with {
    g ≤ (x + y) / 2 by Real.geometric_mean_le_arithmetic_mean;
    done
  }
}

-- ----------------------------------------------------------------------
-- The n-variable inequality (Freek #38), in the division-free form
--   nⁿ · Π_{k<n} s(k) ≤ (Σ_{k<n} s(k))ⁿ,
-- proven by Cauchy's forward–backward induction: it holds at 1 and 2,
-- doubling preserves it, and stepping down preserves it.

definition Real.MeansInequalityAt (n : Natural) : Proposition :=
  (s : Natural → Real) → (∀ (j : Natural). 0 ≤ s(j))
  → (n : Real) ^ n * Real.partialProduct(s, n)
    ≤ Real.partialSum(s, n) ^ n

theorem Real.means_inequality_one : Real.MeansInequalityAt(1) :=
  (s : Natural → Real) (termsNonneg : ∀ (j : Natural). 0 ≤ s(j)) ↦ {
    0 ≤ s(0);
    ((1 : Natural) : Real) ^ 1
       * Real.partialProduct(s, 1)
     = (((1 : Natural) : Real) * 1)
       * (1 * s(0 + 0))
     = (((1 : Natural) : Real) * 1)
       * (1 * s(0))   by (0 + 0 = 0)
     = (1 * 1) * (1 * s(0))
     = (0 + s(0)) * 1
   as value;
    Real.partialSum(s, 1)
     = 0 + s(0 + 0)
     = 0 + s(0)   by (0 + 0 = 0);
    Real.partialSum(s, 1) * 1 ≤ Real.partialSum(s, 1) * 1;
    done by substituting value
  }

-- Doubling preserves the inequality: split the 2m variables into two
-- halves, bound each half by its own inequality, and close with the
-- two-variable square gap on the half-sums.
theorem Real.means_inequality_double (m : Natural)
        (atHalf : Real.MeansInequalityAt(m))
        : Real.MeansInequalityAt(m + m) :=
  (s : Natural → Real) (termsNonneg : ∀ (j : Natural). 0 ≤ s(j)) ↦ {
    let firstSum : Real := Real.partialSum(s, m);
    let secondSum : Real := Real.partialSum((j : Natural) ↦ s(m + j), m);
    let firstProduct : Real := Real.partialProduct(s, m);
    let secondProduct : Real := Real.partialProduct((j : Natural) ↦ s(m + j), m);
    ∀ (j : Natural). 0 ≤ s(m + j)
        by (j : Natural) ↦ termsNonneg(m + j) as shiftNonneg;
    (m : Real) ^ m * firstProduct ≤ firstSum ^ m;
    (m : Real) ^ m * secondProduct ≤ secondSum ^ m
        by atHalf((j : Natural) ↦ s(m + j), shiftNonneg);
    -- Nonnegativity inventory.
    0 ≤ firstSum
        by Real.partialSum_nonneg;
    0 ≤ secondSum
        by Real.partialSum_nonneg;
    0 ≤ secondProduct
        by Real.partialProduct_nonneg;
    Rational.IsNonneg((m : Rational));
    Rational.zero ≤ (m : Rational);
    (Rational.zero : Real) ≤ (m : Real);
    0 ≤ (m : Real);
    0 ≤ (m : Real) ^ m;
    Rational.zero < Rational.one;
    0 < (Rational.one : Real);
    0 ≤ Real.one;
    (0 : Real)
     = 0 + 0
     ≤ Real.one + 0        by Real.add_preserves_LessOrEqual
     ≤ Real.one + Real.one  by Real.add_preserves_LessOrEqual_left
     = 2;
    0 ≤ (2 : Real) ^ m;
    0 ≤ firstSum ^ m;
    -- IsNonneg forms for the multiplications.
    Real.IsNonneg((2 : Real) ^ m);
    Real.IsNonneg((m : Real) ^ m);
    Real.IsNonneg(secondProduct);
    Real.IsNonneg(firstSum ^ m);
    Real.IsNonneg((2 : Real) ^ m * (2 : Real) ^ m);
    Real.IsNonneg((m : Real) ^ m * secondProduct);
    Real.IsNonneg(((2 : Real) ^ m * (2 : Real) ^ m) * ((m : Real) ^ m * secondProduct));
    Real.IsNonneg(((2 : Real) ^ m * (2 : Real) ^ m) * firstSum ^ m);
    -- The two-variable square gap on the half-sums.
    Real.IsNonneg((firstSum - secondSum) * (firstSum - secondSum));
    0 ≤ (firstSum - secondSum) * (firstSum - secondSum);
    -((firstSum - secondSum) * (firstSum - secondSum))
     = 0 - (firstSum - secondSum) * (firstSum - secondSum)
     ≤ (firstSum - secondSum) * (firstSum - secondSum)
       - (firstSum - secondSum) * (firstSum - secondSum)
           by Real.add_preserves_LessOrEqual
     = 0;
    ((2 : Real) * (2 : Real)) * (firstSum * secondSum)
     = (firstSum + secondSum) * (firstSum + secondSum)
       + -((firstSum - secondSum) * (firstSum - secondSum))
     ≤ (firstSum + secondSum) * (firstSum + secondSum) + 0
           by Real.add_preserves_LessOrEqual_left
     = (firstSum + secondSum) * (firstSum + secondSum);
    0 ≤ ((2 : Real) * (2 : Real)) * (firstSum * secondSum);
    -- The chain.
    (m + m : Real) ^ (m + m) * Real.partialProduct(s, m + m)
     = ((m : Real) + (m : Real)) ^ (m + m) * Real.partialProduct(s, m + m)
     = ((m : Real) + (m : Real)) ^ (m + m) * (firstProduct * secondProduct)
     = (2 * (m : Real)) ^ (m + m) * (firstProduct * secondProduct)
           by ((m : Real) + (m : Real) = 2 * (m : Real))
     = ((2 : Real) ^ (m + m) * (m : Real) ^ (m + m)) * (firstProduct * secondProduct)
     = (((2 : Real) ^ m * (2 : Real) ^ m) * (m : Real) ^ (m + m)) * (firstProduct * secondProduct)
     = (((2 : Real) ^ m * (2 : Real) ^ m) * ((m : Real) ^ m * (m : Real) ^ m))
       * (firstProduct * secondProduct)
     = ((m : Real) ^ m * firstProduct)
       * (((2 : Real) ^ m * (2 : Real) ^ m) * ((m : Real) ^ m * secondProduct))
     ≤ firstSum ^ m
       * (((2 : Real) ^ m * (2 : Real) ^ m) * ((m : Real) ^ m * secondProduct))
           by Real.LessOrEqual.multiply_by_nonneg_right
     = ((m : Real) ^ m * secondProduct)
       * (((2 : Real) ^ m * (2 : Real) ^ m) * firstSum ^ m)
     ≤ secondSum ^ m
       * (((2 : Real) ^ m * (2 : Real) ^ m) * firstSum ^ m)
           by Real.LessOrEqual.multiply_by_nonneg_right
     = ((2 : Real) ^ m * (2 : Real) ^ m)
       * (firstSum ^ m * secondSum ^ m)
     = ((2 : Real) * (2 : Real)) ^ m
       * (firstSum ^ m * secondSum ^ m)
     = ((2 : Real) * (2 : Real)) ^ m * (firstSum * secondSum) ^ m
     = (((2 : Real) * (2 : Real)) * (firstSum * secondSum)) ^ m
     ≤ ((firstSum + secondSum) * (firstSum + secondSum)) ^ m
           by Real.power_monotone
     = (firstSum + secondSum) ^ m * (firstSum + secondSum) ^ m
     = (firstSum + secondSum) ^ (m + m)
     = Real.partialSum(s, m + m) ^ (m + m)
  }

-- Stepping down preserves the inequality: feed the (m+1)-row the m
-- scaled values m·s(k) and, as the last entry, the plain sum A — its
-- sum telescopes to (m+1)·A and its product to A·mᵐ·Π, so the (m+1)
-- inequality collapses onto the m one after cancelling (m+1)ᵐ⁺¹ and A.
-- The augmented scaled row used to fold an (m+1)-term mean back to an
-- m-term one: slot 0 carries the whole sum A = Σ_{<m} s, and slot j+1
-- carries m·s(j). Over m+1 slots its sum telescopes to (m+1)·A and its
-- product is A·mᵐ·Π, so the (m+1)-case applied to it yields the m-case.
definition Real.augmentedScaledRow (s : Natural → Real) (m : Natural)
        : Natural → Real :=
  (k : Natural) ↦
    if k = 0 then Real.partialSum(s, m) else (m : Real) * s(Natural.monus(k, 1))

-- Slot 0 carries the whole sum A = Σ_{<m} s.
theorem Real.augmentedScaledRow_zero (s : Natural → Real) (m : Natural)
        : Real.augmentedScaledRow(s, m, 0) = Real.partialSum(s, m) :=
  if (0 : Natural) = 0
  then reflexivity(Real, Real.partialSum(s, m))
  else { (0 : Natural) = 0; done }

-- Every later slot 1 + j carries the scaled value m·s(j).
theorem Real.augmentedScaledRow_one_plus (s : Natural → Real) (m j : Natural)
        : Real.augmentedScaledRow(s, m, 1 + j) = (m : Real) * s(j) :=
  if (1 + j : Natural) = 0
  then { (1 + j : Natural) ≠ 0; done }
  else {
    Natural.monus(1 + j, 1)
     = Natural.monus(j + 1, 1)
     = j
   as predecessorShift;
    (m : Real) * s(Natural.monus(1 + j, 1)) = (m : Real) * s(j)
        by substituting predecessorShift;
    done
  }

theorem Real.means_inequality_predecessor (m : Natural)
        (atSuccessor : Real.MeansInequalityAt(1 + m))
        : Real.MeansInequalityAt(m) :=
  (s : Natural → Real) (termsNonneg : ∀ (j : Natural). 0 ≤ s(j)) ↦ {
    let augmentedRow : Natural → Real := Real.augmentedScaledRow(s, m);
    0 ≤ Real.partialSum(s, m);
    Rational.IsNonneg((m : Rational));
    Rational.zero ≤ (m : Rational);
    (Rational.zero : Real) ≤ (m : Real);
    0 ≤ (m : Real);
    Real.IsNonneg((m : Real));
    ∀ (k : Natural). 0 ≤ Real.augmentedScaledRow(s, m, k) by {
        take k : Natural;
        if k = 0
        then {
          0 ≤ Real.partialSum(s, m);
          done
        }
        else {
          0 ≤ s(Natural.monus(k, 1));
          Real.IsNonneg(s(Natural.monus(k, 1)));
          Real.IsNonneg((m : Real) * s(Natural.monus(k, 1)));
          0 ≤ (m : Real) * s(Natural.monus(k, 1));
          done
        }
    };
    (1 + m : Real) ^ (1 + m) * Real.partialProduct(augmentedRow, 1 + m)
      ≤ Real.partialSum(augmentedRow, 1 + m) ^ (1 + m)
        by atSuccessor as applied;
    -- The augmented sum telescopes to (m+1)·A.
    1 + m = m + 1;
    let onePlusMReal : Real := (1 + m : Real);
    onePlusMReal
     = (((1 : Rational) + (m : Rational)) : Real)
     = (((1 : Rational)) : Real) + (m : Real)
     = 1 + (m : Real);
    ∀ (j : Natural). Real.augmentedScaledRow(s, m, 1 + j) = (m : Real) * s(j) by {
        take j : Natural;
        done
    };
    Real.partialSum(augmentedRow, 1 + m)
         = Real.partialSum(augmentedRow, m + 1)
         = Real.partialSum(augmentedRow, 1)
           + Real.partialSum((j : Natural) ↦ Real.augmentedScaledRow(s, m, 1 + j), m)
         = Real.partialSum(augmentedRow, 1) + Real.partialSum((j : Natural) ↦ (m : Real) * s(j), m)
         = Real.partialSum(augmentedRow, 1) + (m : Real) * Real.partialSum(s, m)
         = (0 + Real.augmentedScaledRow(s, m, 0 + 0)) + (m : Real) * Real.partialSum(s, m)
         = (0 + Real.augmentedScaledRow(s, m, 0)) + (m : Real) * Real.partialSum(s, m)
               by (0 + 0 = 0)
         = (0 + Real.partialSum(s, m)) + (m : Real) * Real.partialSum(s, m)
         = (1 + (m : Real)) * Real.partialSum(s, m)
         = onePlusMReal * Real.partialSum(s, m);
    -- The augmented product telescopes to A·mᵐ·Π.
    Real.partialProduct(augmentedRow, 1 + m)
         = Real.partialProduct(augmentedRow, m + 1)
         = Real.partialProduct(augmentedRow, 1)
           * Real.partialProduct((j : Natural) ↦ Real.augmentedScaledRow(s, m, 1 + j), m)
         = Real.partialProduct(augmentedRow, 1)
           * Real.partialProduct((j : Natural) ↦ (m : Real) * s(j), m)
         = Real.partialProduct(augmentedRow, 1) * ((m : Real) ^ m * Real.partialProduct(s, m))
         = (1 * Real.augmentedScaledRow(s, m, 0 + 0)) * ((m : Real) ^ m * Real.partialProduct(s, m))
         = (1 * Real.augmentedScaledRow(s, m, 0)) * ((m : Real) ^ m * Real.partialProduct(s, m))
               by (0 + 0 = 0)
         = (1 * Real.partialSum(s, m)) * ((m : Real) ^ m * Real.partialProduct(s, m))
         = Real.partialSum(s, m) * ((m : Real) ^ m * Real.partialProduct(s, m));
    -- Cancel the positive (m+1)ᵐ⁺¹.
    Rational.zero < (1 + m : Rational);
    (Rational.zero : Real) < (1 + m : Real);
    0 < (1 + m : Real);
    0 < (1 + m : Real) ^ (1 + m);
    (1 + m : Real) ^ (1 + m)
    * (Real.partialSum(s, m) * ((m : Real) ^ m * Real.partialProduct(s, m)))
         = (1 + m : Real) ^ (1 + m) * Real.partialProduct(augmentedRow, 1 + m)
         ≤ Real.partialSum(augmentedRow, 1 + m) ^ (1 + m)   by applied
         = (onePlusMReal * Real.partialSum(s, m)) ^ (1 + m)
         = (1 + m : Real) ^ (1 + m) * Real.partialSum(s, m) ^ (1 + m);
    Real.partialSum(s, m) * ((m : Real) ^ m * Real.partialProduct(s, m))
      ≤ Real.partialSum(s, m) ^ (1 + m)
        by Real.LessOrEqual.multiply_cancel_left_positive as cancelled;
    -- Cancel A — or collapse when A vanishes.
    done by cases {
      case Real.partialSum(s, m) = 0 as sumZero:
          if m = 0
          then
              -- With m = 0 every exponent is 0, so each power is 1 and the
              -- empty product is 1, collapsing both sides to 1.
              (m : Real) ^ m * Real.partialProduct(s, m)
                 = (0 : Real) ^ 0 * Real.partialProduct(s, 0)
                 = 1 * 1
                 = 1
                 = Real.partialSum(s, 0) ^ 0
                 ≤ Real.partialSum(s, m) ^ m
                       by substituting (m = 0)
          else {
              1 ≤ m;
              choose mPredecessor such that m = 1 + mPredecessor
                  from Natural.subtraction_witness;
              mPredecessor
               < 1 + mPredecessor   by Natural.lt_one_plus
               = m;
              s(mPredecessor) = 0
                  by Real.partialSum_zero_term;
              Real.partialProduct(s, m)
               = Real.partialProduct(s, 1 + mPredecessor)
               = Real.partialProduct(s, mPredecessor) * s(mPredecessor)
               = Real.partialProduct(s, mPredecessor) * 0
               = 0;
              0 ≤ Real.partialSum(s, m);
              0 ≤ Real.partialSum(s, m) ^ m;
              (m : Real) ^ m * Real.partialProduct(s, m)
               = (m : Real) ^ m * 0
               = 0
               ≤ Real.partialSum(s, m) ^ m
          }
      otherwise as sumNonzero: {
          0 ≠ Real.partialSum(s, m) by {
              suppose 0 = Real.partialSum(s, m) as zeroEqualsSum;
              Real.partialSum(s, m) = 0;
              done
          };
          0 < Real.partialSum(s, m);
          Real.partialSum(s, m) * ((m : Real) ^ m * Real.partialProduct(s, m))
           ≤ Real.partialSum(s, m) ^ (1 + m)   by cancelled
           = Real.partialSum(s, m) * Real.partialSum(s, m) ^ m;
          done by Real.LessOrEqual.multiply_cancel_left_positive
        }
    }
  }

-- The inequality holds at every power of two …
theorem Real.means_inequality_doubling (k : Natural)
        : Real.MeansInequalityAt(Natural.doubling(k)) :=
  by induction on k with IH {
    case base: Real.means_inequality_one
    case step(predecessor): {
        Real.MeansInequalityAt(Natural.doubling(predecessor) + Natural.doubling(predecessor));
        done by substituting Natural.doubling_one_plus(k := predecessor)
      }
  }

-- … every index sits below some power of two …
theorem Natural.le_doubling (n : Natural) : n ≤ Natural.doubling(n) :=
  by induction on n with IH {
    case base: done
    case step(predecessor): {
        1 ≤ Natural.doubling(predecessor);
        1 + predecessor
         = predecessor + 1
         ≤ Natural.doubling(predecessor) + 1
               by Natural.le_add_preserves_left
         = 1 + Natural.doubling(predecessor)
         ≤ Natural.doubling(predecessor) + Natural.doubling(predecessor)
               by Natural.le_add_preserves_left
         = Natural.doubling(1 + predecessor)
      }
  }

-- … and the inequality descends one index at a time.
theorem Real.means_inequality_downward (difference : Natural)
        : ∀ (n : Natural).
            Real.MeansInequalityAt(difference + n)
          → Real.MeansInequalityAt(n) :=
  by induction on difference with IH {
    case base:
        (n : Natural) (atIndex : Real.MeansInequalityAt(0 + n)) ↦ {
          done by substituting (0 + n = n)
        }
    case step(predecessor):
        (n : Natural)
        (atTop : Real.MeansInequalityAt((1 + predecessor) + n)) ↦ {
          Real.MeansInequalityAt(1 + (predecessor + n))
              by substituting ((1 + predecessor) + n = 1 + (predecessor + n));
          Real.MeansInequalityAt(predecessor + n)
              by Real.means_inequality_predecessor as atLower;
          IH(n, atLower)
        }
  }

-- ----------------------------------------------------------------------
-- Freek #38: the inequality of arithmetic and geometric means, in the
-- division-free form nⁿ·Πs ≤ (Σs)ⁿ.
theorem Real.arithmetic_mean_geometric_mean (n : Natural)
        (s : Natural → Real)
        (termsNonneg : ∀ (j : Natural). 0 ≤ s(j))
        : (n : Real) ^ n * Real.partialProduct(s, n)
          ≤ Real.partialSum(s, n) ^ n := {
  n ≤ Natural.doubling(n);
  choose difference such that Natural.doubling(n) = difference + n
      from Natural.le_to_add;
  difference + n = Natural.doubling(n) as equationFlipped;
  Real.MeansInequalityAt(Natural.doubling(n));
  Real.MeansInequalityAt(difference + n)
      by substituting equationFlipped;
  Real.MeansInequalityAt(n) by Real.means_inequality_downward;
  done
}

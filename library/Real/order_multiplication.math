-- Real/order_multiplication.math
--
-- The multiplicative half of the ordered-field axioms for ℝ: a product
-- of nonnegatives is nonnegative. This is the last fact about ℝ that
-- needs the Cauchy representatives — with it, the interface
-- "complete ordered field with an order-embedded ℚ" is fully proven,
-- and everything downstream factors through that interface.
--
-- At representatives: both sequences are eventually above -δ and (being
-- Cauchy) bounded by naturally-embedded rationals; the pointwise product
-- bound (Rational.product_lower_bound_of_lower_bounds) then pins the
-- product above -(B·δ), and δ is chosen by dividing ε by the bound.

module Real.order_multiplication

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.maximum
import Integer.basics
import Integer.addition
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.triangle
import Rational.triangle_more
import Rational.linearity
import Rational.reciprocal
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.order
import Real.linearity
import Real.cauchy_bounded
import Real.absolute_value
import Real.absolute_value_order

-- The natural-image bound of a sum: coercion splits the embedded bound
-- (a + b + 1) + 1 into the Rational sum (a + 1) + (b + 1).
theorem Rational.add_one_sum_coercion (a b : Natural)
        : (((a + b + 1) + 1) : Rational)
          = ((a + 1) : Rational) + ((b + 1) : Rational) := {
  claim (a + b + 1) + 1 = (a + 1) + (b + 1);
  calc (((a + b + 1) + 1) : Rational)
     = (((a + 1) + (b + 1)) : Rational)
     = ((a + 1) : Rational) + ((b + 1) : Rational)
}

-- ----------------------------------------------------------------------
-- The representative-level core.
theorem Real.IsNonneg.multiply_at_make
        : ∀ (repX repY : CauchyRationalSequence).
            CauchyRationalSequence.IsEventuallyNonneg(repX)
          → CauchyRationalSequence.IsEventuallyNonneg(repY)
          → Real.IsNonneg((Quotient.class_of(repX) : Real) * (Quotient.class_of(repY) : Real))
  | CauchyRationalSequence.make(s, sCauchy),
    CauchyRationalSequence.make(t, tCauchy) =>
      -- The product's sequence is λm. s(m)·t(m); the goal reduces to its
      -- eventual non-negativity, which the ε/δ argument below establishes.
      unfold Real.IsNonneg in
      ((sNonneg : CauchyRationalSequence.IsEventuallyNonneg(
           CauchyRationalSequence.make(s, sCauchy)))
      (tNonneg : CauchyRationalSequence.IsEventuallyNonneg(
           CauchyRationalSequence.make(t, tCauchy)))
      (epsilon : Rational)
      (epsilonPositive : Rational.zero < epsilon) ↦ {
        -- Bound both sequences by one naturally-embedded rational B.
        claim sBoundedExists
              : ∃ (K : Natural). ∃ (N : Natural).
                  ∀ (m : Natural). N ≤ m → abs(s(m)) ≤ ((K + 1) : Rational)
            since Rational.sequence.cauchy_is_naturally_bounded;
        choose KS as sBoundedTail from sBoundedExists;
        choose NS as sBounded from sBoundedTail;
        claim tBoundedExists
              : ∃ (K : Natural). ∃ (N : Natural).
                  ∀ (m : Natural). N ≤ m → abs(t(m)) ≤ ((K + 1) : Rational)
            since Rational.sequence.cauchy_is_naturally_bounded;
        choose KT as tBoundedTail from tBoundedExists;
        choose NT as tBounded from tBoundedTail;
        let K : Natural := KS + KT + 1;
        claim Rational.IsNonneg(((KT + 1) : Rational))
            since Rational.from_natural_is_nonneg;
        claim Rational.IsNonneg(((KS + 1) : Rational))
            since Rational.from_natural_is_nonneg;
        -- Choose δ with (K + 1 : ℚ)·δ ≤ ε/2, and tail indices where both
        -- sequences are above -δ.
        claim Rational.zero < Rational.halve(epsilon)
            since Rational.halve_positive;
        claim deltaExists
              : ∃ (delta : Rational). Rational.zero < delta
                ∧ Rational.LessOrEqual(((K + 1) : Rational) * delta, Rational.halve(epsilon))
            since Rational.divide_by_succ_positive;
        choose delta as deltaProperties from deltaExists;
        claim deltaPositive : Rational.zero < delta;
        claim Rational.LessOrEqual(((K + 1) : Rational) * delta, Rational.halve(epsilon));
        choose N1 as sLow from sNonneg(delta, deltaPositive);
        choose N2 as tLow from tNonneg(delta, deltaPositive);
        witness Natural.maximum(Natural.maximum(N1, N2),
                    Natural.maximum(NS, NT)) with
            (m : Natural)
            (aboveAll : Natural.maximum(Natural.maximum(N1, N2),
                            Natural.maximum(NS, NT)) ≤ m) ↦ {
              -- Unpack the four tail conditions at m.
              claim Natural.maximum(N1, N2) ≤ m
                  since Natural.le_through_max_left;
              claim Natural.maximum(NS, NT) ≤ m
                  since Natural.le_through_max_right;
              claim aboveN1 : N1 ≤ m;
              claim aboveN2 : N2 ≤ m;
              claim NS ≤ m;
              claim NT ≤ m;
              claim -delta < s(m) by sLow(m, aboveN1);
              claim -delta < t(m) by tLow(m, aboveN2);
              claim Rational.zero ≤ ((KT + 1) : Rational)
                  since Rational.LessOrEqual_zero_of_IsNonneg;
              claim Rational.zero ≤ ((KS + 1) : Rational)
                  since Rational.LessOrEqual_zero_of_IsNonneg;
              calc abs(s(m))
                 ≤ ((KS + 1) : Rational)
                 = ((KS + 1) : Rational) + Rational.zero
                 ≤ ((KS + 1) : Rational)
                       + ((KT + 1) : Rational)
                       by Rational.add_general_LessOrEqual_left
                 = ((K + 1) : Rational)
                       since Rational.add_one_sum_coercion;
              calc abs(t(m))
                 ≤ ((KT + 1) : Rational)
                 = ((KT + 1) : Rational) + Rational.zero
                 ≤ ((KT + 1) : Rational)
                       + ((KS + 1) : Rational)
                       by Rational.add_general_LessOrEqual_left
                 = ((KS + 1) : Rational)
                       + ((KT + 1) : Rational)
                 = ((K + 1) : Rational)
                       since Rational.add_one_sum_coercion;
              -- The pointwise product bound, then the ε-budget.
              claim -(((K + 1) : Rational) * delta) ≤ s(m) * t(m)
                  since Rational.product_lower_bound_of_lower_bounds;
              calc ((K + 1) : Rational) * delta
                 ≤ Rational.halve(epsilon)
                 < epsilon
                       since Rational.halve_less_than_self;
              claim -epsilon < -(((K + 1) : Rational) * delta)
                  since Rational.LessThan.negate;
              calc -epsilon
                 < -(((K + 1) : Rational) * delta)
                 ≤ s(m) * t(m)
            }
      })

-- ----------------------------------------------------------------------
-- The interface fact: ℝ is an ordered field on the multiplicative side.
theorem Real.IsNonneg.multiply (x y : Real)
        (xNonneg : Real.IsNonneg(x)) (yNonneg : Real.IsNonneg(y))
        : Real.IsNonneg(x * y) :=
  cases x refining xNonneg { | repX =>
      cases y refining yNonneg { | repY => {
          claim CauchyRationalSequence.IsEventuallyNonneg(repX)
              by Real.IsNonneg.eventually_nonneg;
          claim CauchyRationalSequence.IsEventuallyNonneg(repY)
              by Real.IsNonneg.eventually_nonneg;
          done
      } } }

-- Multiplying by a nonnegative factor preserves ≤ (on the right).
theorem Real.LessOrEqual.multiply_by_nonneg_right (x y c : Real)
        (xLeqY : x ≤ y) (cNonneg : Real.IsNonneg(c))
        : x * c ≤ y * c := {
  -- (y − x)·c ≥ 0, and that product is y·c − x·c.
  claim Real.IsNonneg((y - x) * c) since Real.IsNonneg.multiply;
  claim Real.IsNonneg(y * c - x * c)
      by substituting (ring : (y - x) * c = y * c - x * c);
  done
}

-- Multiplying inequalities between nonnegative quantities: a ≤ b and
-- c ≤ d give a·c ≤ b·d. The workhorse for bounding products of error
-- terms in ε-arguments.
theorem Real.LessOrEqual.multiply_monotone_nonneg (a b c d : Real)
        (aLeqB : a ≤ b) (cLeqD : c ≤ d)
        (aNonneg : Real.zero ≤ a) (cNonneg : Real.zero ≤ c)
        : a * c ≤ b * d := {
  claim Real.IsNonneg(c) since Real.IsNonneg_of_LessOrEqual_zero;
  claim Real.zero ≤ b since Real.LessOrEqual.transitive;
  claim Real.IsNonneg(b) since Real.IsNonneg_of_LessOrEqual_zero;
  calc a * c
     ≤ b * c     since Real.LessOrEqual.multiply_by_nonneg_right
     = c * b
     ≤ d * b     since Real.LessOrEqual.multiply_by_nonneg_right
     = b * d
}

-- |x·y| = |x|·|y|: by the sign cases, every combination reduces to a
-- ring rearrangement once |·| is identified with ± its argument.
theorem Real.absolute_value_multiplicative (x y : Real)
        : abs(x * y) = abs(x) * abs(y) :=
  claim by cases {
    in (Real.IsNonneg(x)) as xNonneg:
      claim by cases {
        in (Real.IsNonneg(y)) as yNonneg: {
            claim Real.IsNonneg(x * y)
                since Real.IsNonneg.multiply;
            calc abs(x * y)
               = x * y
               = abs(x) * y
               = abs(x) * abs(y)
          }
        in (Real.IsNonneg(-y)) as negateYNonneg: {
            claim Real.IsNonneg(x * -y) since Real.IsNonneg.multiply;
            claim Real.IsNonneg(-(x * y))
                by substituting (ring : x * -y = -(x * y));
            calc abs(x * y)
               = -(x * y)
               = x * -y
               = abs(x) * -y
               = abs(x) * abs(y)
          }
      }
    in (Real.IsNonneg(-x)) as negateXNonneg:
      claim by cases {
        in (Real.IsNonneg(y)) as yNonneg: {
            claim Real.IsNonneg(-x * y) since Real.IsNonneg.multiply;
            claim Real.IsNonneg(-(x * y))
                by substituting (ring : -x * y = -(x * y));
            calc abs(x * y)
               = -(x * y)
               = -x * y
               = abs(x) * y
               = abs(x) * abs(y)
          }
        in (Real.IsNonneg(-y)) as negateYNonneg: {
            claim Real.IsNonneg(x * y)
                by {
                  claim Real.IsNonneg(-x * -y) since Real.IsNonneg.multiply;
                  claim Real.IsNonneg(x * y)
                      by substituting (ring : -x * -y = x * y);
                  done
                };
            calc abs(x * y)
               = x * y
               = -x * -y
               = abs(x) * -y
               = abs(x) * abs(y)
          }
      }
  }

-- A Real square is nonnegative: at a representative the squared sequence
-- is pointwise a Rational square (≥ 0), so eventually-nonnegative.
theorem Real.square_IsNonneg (x : Real)
        : Real.IsNonneg(Real.multiply(x, x)) :=
  cases x { | c => {
    claim CauchyRationalSequence.IsEventuallyNonneg(CauchyRationalSequence.multiply(c, c))
        by (epsilon : Rational) (epsilonPositive : Rational.zero < epsilon) ↦
          witness 0 with
              (m : Natural) (_ : 0 ≤ m) ↦ {
                claim Rational.IsNonneg(
                          CauchyRationalSequence.sequenceFunction(c, m)
                          * CauchyRationalSequence.sequenceFunction(c, m))
                    since Rational.square_IsNonneg;
                calc -epsilon
                   < Rational.zero
                         since Rational.negate_LessThan_zero_of_positive
                   ≤ CauchyRationalSequence.sequenceFunction(c, m)
                         * CauchyRationalSequence.sequenceFunction(c, m)
                         since Rational.LessOrEqual_zero_of_IsNonneg
                   = CauchyRationalSequence.sequenceFunction(
                         CauchyRationalSequence.multiply(c, c), m)
                         since CauchyRationalSequence.sequenceFunction_multiply
              };
    done
  } }


-- |x|·|x| = x·x: the square forgets the sign.
theorem Real.absolute_value_square (x : Real)
        : abs(x) * abs(x) = x * x := {
  claim Real.IsNonneg(x * x) since Real.square_IsNonneg;
  calc abs(x) * abs(x)
     = abs(x * x)    since Real.absolute_value_multiplicative
     = x * x         since Real.absolute_value_when_nonneg
}

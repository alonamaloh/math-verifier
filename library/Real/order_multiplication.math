-- Real/order_multiplication.math
--
-- The multiplicative half of the ordered-field axioms for ℝ: a product
-- of nonnegatives is nonnegative. This is the last fact about ℝ that
-- needs the Cauchy representatives — with it, the interface
-- "complete ordered field with an order-embedded ℚ" is fully proven,
-- and everything downstream factors through that interface.
--
-- At representatives: both sequences are eventually above -δ and (being
-- Cauchy) bounded by naturally-embedded rationals; the pointwise product
-- bound (Rational.product_lower_bound_of_lower_bounds) then pins the
-- product above -(B·δ), and δ is chosen by dividing ε by the bound.

module Real.order_multiplication

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.maximum
import Integer.basics
import Integer.addition
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.triangle
import Rational.triangle_more
import Rational.linearity
import Rational.reciprocal
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.order
import Real.linearity
import Real.cauchy_bounded
import Real.absolute_value
import Real.absolute_value_order

-- The natural-image bound of a sum: coercion splits the embedded bound
-- (a + b + 1) + 1 into the Rational sum (a + 1) + (b + 1).
theorem Rational.add_one_sum_coercion (a b : ℕ)
        : (((a + b + 1) + 1) : ℚ)
          = ((a + 1) : ℚ) + ((b + 1) : ℚ) := {
  (a + b + 1) + 1 = (a + 1) + (b + 1);
  (((a + b + 1) + 1) : ℚ)
     = (((a + 1) + (b + 1)) : ℚ)
     = ((a + 1) : ℚ) + ((b + 1) : ℚ)
}

-- ----------------------------------------------------------------------
-- The representative-level core.
theorem Real.IsNonneg.multiply_at_make
        (repX repY : CauchyRationalSequence)
        (sNonneg : CauchyRationalSequence.IsEventuallyNonneg(repX))
        (tNonneg : CauchyRationalSequence.IsEventuallyNonneg(repY))
        : Real.IsNonneg((Quotient.class_of(repX) : ℝ) * (Quotient.class_of(repY) : ℝ)) := {
      let ⟨s, _⟩ := repX;
      let ⟨t, _⟩ := repY;
      -- The product's sequence is λm. s(m)·t(m); the goal reduces to its
      -- eventual non-negativity, which the ε/δ argument below establishes.
      unfold Real.IsNonneg in
      ((ε : ℚ)
      (εPositive : Rational.zero < ε) ↦ {
        -- Bound both sequences by one naturally-embedded rational B.
        choose KS, NS such that
            ∀ (m : ℕ). NS ≤ m → abs(s(m)) ≤ ((KS + 1) : ℚ)
            from Rational.sequence.cauchy_is_naturally_bounded;
        choose KT, NT such that
            ∀ (m : ℕ). NT ≤ m → abs(t(m)) ≤ ((KT + 1) : ℚ)
            from Rational.sequence.cauchy_is_naturally_bounded;
        let K : ℕ := KS + KT + 1;
        Rational.IsNonneg(((KT + 1) : ℚ));
        Rational.IsNonneg(((KS + 1) : ℚ));
        -- Choose δ with (K + 1 : ℚ)·δ ≤ ε/2, and tail indices where both
        -- sequences are above -δ.
        Rational.zero < Rational.halve(ε);
        choose δ such that Rational.zero < δ
            ∧ ((K + 1) : ℚ) * δ ≤ Rational.halve(ε)
            from Rational.divide_by_succ_positive;
        choose N1 as sLow from sNonneg(δ, (Rational.zero < δ));
        choose N2 as tLow from tNonneg(δ, (Rational.zero < δ));
        witness Natural.maximum(Natural.maximum(N1, N2),
                    Natural.maximum(NS, NT)) with
            (m : ℕ)
            (aboveAll : Natural.maximum(Natural.maximum(N1, N2),
                            Natural.maximum(NS, NT)) ≤ m) ↦ {
              -- Unpack the four tail conditions at m.
              Natural.maximum(N1, N2) ≤ m;
              Natural.maximum(NS, NT) ≤ m;
              N1 ≤ m as aboveN1;
              N2 ≤ m as aboveN2;
              NS ≤ m;
              NT ≤ m;
              -δ < s(m) by sLow(m, aboveN1);
              -δ < t(m) by tLow(m, aboveN2);
              Rational.zero ≤ ((KT + 1) : ℚ);
              Rational.zero ≤ ((KS + 1) : ℚ);
              abs(s(m))
                 ≤ ((KS + 1) : ℚ)
                 = ((KS + 1) : ℚ) + Rational.zero
                 ≤ ((KS + 1) : ℚ)
                       + ((KT + 1) : ℚ)
                 = ((K + 1) : ℚ);
              abs(t(m))
                 ≤ ((KT + 1) : ℚ)
                 = ((KT + 1) : ℚ) + Rational.zero
                 ≤ ((KT + 1) : ℚ)
                       + ((KS + 1) : ℚ)
                 = ((KS + 1) : ℚ)
                       + ((KT + 1) : ℚ)
                 = ((K + 1) : ℚ);
              -- The pointwise product bound, then the ε-budget.
              -(((K + 1) : ℚ) * δ) ≤ s(m) * t(m)
                  by Rational.product_lower_bound_of_lower_bounds;
              ((K + 1) : ℚ) * δ
                 ≤ Rational.halve(ε)
                 < ε;
              -ε < -(((K + 1) : ℚ) * δ);
              -ε
                 < -(((K + 1) : ℚ) * δ)
                 ≤ s(m) * t(m)
            }
      })
}

-- ----------------------------------------------------------------------
-- The interface fact: ℝ is an ordered field on the multiplicative side.
theorem Real.IsNonneg.multiply (x y : ℝ)
        (xNonneg : Real.IsNonneg(x)) (yNonneg : Real.IsNonneg(y))
        : Real.IsNonneg(x * y) :=
  by_representatives x as repX, y as repY => {
      CauchyRationalSequence.IsEventuallyNonneg(repX)
          by Real.IsNonneg.eventually_nonneg;
      CauchyRationalSequence.IsEventuallyNonneg(repY)
          by Real.IsNonneg.eventually_nonneg;
      done
  }

-- Multiplying by a nonnegative factor preserves ≤ (on the right).
theorem Real.LessOrEqual.multiply_by_nonneg_right (x y c : ℝ)
        (xLeqY : x ≤ y) (cNonneg : Real.IsNonneg(c))
        : x * c ≤ y * c := {
  -- (y − x)·c ≥ 0, and that product is y·c − x·c.
  Real.IsNonneg((y - x) * c);
  Real.IsNonneg(y * c - x * c);
  done
}

-- Multiplying inequalities between nonnegative quantities: a ≤ b and
-- c ≤ d give a·c ≤ b·d. The workhorse for bounding products of error
-- terms in ε-arguments.
theorem Real.LessOrEqual.multiply_monotone_nonneg (a b c d : ℝ)
        (aLeqB : a ≤ b) (cLeqD : c ≤ d)
        (aNonneg : Real.zero ≤ a) (cNonneg : Real.zero ≤ c)
        : a * c ≤ b * d := {
  Real.IsNonneg(c);
  Real.zero ≤ b;
  Real.IsNonneg(b);
  a * c
     ≤ b * c
     = c * b
     ≤ d * b
     = b * d
}

-- |x·y| = |x|·|y|: by the sign cases, every combination reduces to a
-- ring rearrangement once |·| is identified with ± its argument.
theorem Real.absolute_value_multiplicative (x y : ℝ)
        : abs(x * y) = abs(x) * abs(y) :=
  done by cases {
    case Real.IsNonneg(x) as xNonneg:
      done by cases {
        case Real.IsNonneg(y) as yNonneg: {
            Real.IsNonneg(x * y);
            abs(x * y)
               = x * y
               = abs(x) * y
               = abs(x) * abs(y)
          }
        case Real.IsNonneg(-y) as negateYNonneg: {
            Real.IsNonneg(x * -y);
            Real.IsNonneg(-(x * y));
            abs(x * y)
               = -(x * y)
               = x * -y
               = abs(x) * -y
               = abs(x) * abs(y)
          }
      }
    case Real.IsNonneg(-x) as negateXNonneg:
      done by cases {
        case Real.IsNonneg(y) as yNonneg: {
            Real.IsNonneg(-x * y);
            Real.IsNonneg(-(x * y));
            abs(x * y)
               = -(x * y)
               = -x * y
               = abs(x) * y
               = abs(x) * abs(y)
          }
        case Real.IsNonneg(-y) as negateYNonneg: {
            Real.IsNonneg(x * y)
                by {
                  Real.IsNonneg(-x * -y);
                  Real.IsNonneg(x * y)
                      by substituting (ring : -x * -y = x * y);
                  done
                };
            abs(x * y)
               = x * y
               = -x * -y
               = abs(x) * -y
               = abs(x) * abs(y)
          }
      }
  }

-- A Real square is nonnegative: at a representative the squared sequence
-- is pointwise a Rational square (≥ 0), so eventually-nonnegative.
theorem Real.square_IsNonneg (x : ℝ)
        : Real.IsNonneg(Real.multiply(x, x)) :=
  by_representatives x as c => {
    CauchyRationalSequence.IsEventuallyNonneg(CauchyRationalSequence.multiply(c, c))
        by (ε : ℚ) (εPositive : Rational.zero < ε) ↦
          witness 0 with
              (m : ℕ) (_ : 0 ≤ m) ↦ {
                Rational.IsNonneg(c(m) * c(m));
                -ε < Rational.zero ≤ c(m) * c(m) = (c * c)(m)
              };
    done
  }


-- |x|·|x| = x·x: the square forgets the sign.
theorem Real.absolute_value_square (x : ℝ)
        : abs(x) * abs(x) = x * x := {
  Real.IsNonneg(x * x);
  abs(x) * abs(x)
     = abs(x * x)    by Real.absolute_value_multiplicative
     = x * x
}

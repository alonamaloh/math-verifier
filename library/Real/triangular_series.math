-- Real/triangular_series.math
--
-- The sum of the reciprocals of the triangular numbers (Freek #42):
--   Σ 1/T(k+1) = 2,   T(n) = 1 + 2 + … + n.
--
-- Partial fractions: 1/T(k+1) = 2/(k+1) − 2/(k+2) (from the product
-- form 2·T(k+1) = (k+1)(k+2) and the field tactic), so the partial
-- sums telescope to 2 − 2/(n+1), and the tail dies by the Archimedean
-- bound. The terms are honest real divisions; only the Archimedean
-- decay is fetched from the Rational layer, through the ℚ→ℝ boundary.

module Real.triangular_series

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Natural.triangular
import Integer.basics
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.absolute_value
import Rational.triangle
import Rational.triangle_more
import Rational.positive
import Rational.linearity
import Rational.reciprocal
import Rational.reciprocal_function
import Rational.archimedean
import Algebra.ring_lemmas
import Set.basics
import Real.interface

-- ----------------------------------------------------------------------
-- The term sequence: 1/T(k+1).
definition Real.triangular_reciprocal_term (k : Natural) : Real :=
  1 / Natural.triangular(1 + k)

-- ----------------------------------------------------------------------
-- Partial fractions: 1/T(k+1) = 2/(k+1) − 2/(k+2), telescoping shape.
theorem Real.triangular_term_telescopes (k : Natural)
        : Real.triangular_reciprocal_term(k)
          = 2 / (1 + k : Real)
            - 2 / (1 + (1 + k) : Real) := {
  -- The product form of the doubled triangular number, cast to ℝ.
  (Natural.triangular(1 + k) : Real) * 2
     = ((Natural.triangular(1 + k) * 2 : Natural) : Real)
     = ((1 + k) * (1 + (1 + k)) : Real)
           by Natural.triangular_doubled
     = (1 + k : Real) * (1 + (1 + k) : Real)
     as doubledCast;
  -- The three denominators are nonzero.
  (1 + k : Real) > 0;
  (1 + (1 + k) : Real) > 0;
  (1 + k : Real) ≠ 0;
  (1 + (1 + k) : Real) ≠ 0;
  1 ≤ Natural.triangular(1 + k);
  Natural.triangular(1 + k) > 0;
  (Natural.triangular(1 + k) : Real) > 0;
  (Natural.triangular(1 + k) : Real) ≠ 0;
  -- Cancellations for the three reciprocals.
  (Natural.triangular(1 + k) : Real)
        * (1 / (Natural.triangular(1 + k) : Real))
    = 1 as TCancel;
  ((1 + k : Real) * (1 + (1 + k) : Real))
        * ((1 / (1 + k : Real))
           * (1 / (1 + (1 + k) : Real)))
    = 1
      by field as productCancel;
  -- Consecutive denominators are one apart.
  (1 + (1 + k) : Real)
    = ((1 : Natural) : Real) + (1 + k : Real) as oneSplit;
  (1 + (1 + k) : Real) - (1 + k : Real)
     = (((1 : Natural) : Real) + (1 + k : Real))
       - (1 + k : Real)
           by oneSplit
     = 1
     as gapOne;
  -- 1/T(k+1) = 2·(1/(k+1))·(1/(k+2)): trade T for (k+1)(k+2)/2 against
  -- the cancellations.
  1 / (Natural.triangular(1 + k) : Real)
     = (1 / (Natural.triangular(1 + k) : Real)) * 1
     = (1 / (Natural.triangular(1 + k) : Real))
       * (((1 + k : Real) * (1 + (1 + k) : Real))
          * ((1 / (1 + k : Real))
             * (1 / (1 + (1 + k) : Real))))
           by productCancel
     = (1 / (Natural.triangular(1 + k) : Real))
       * (((Natural.triangular(1 + k) : Real) * 2)
          * ((1 / (1 + k : Real))
             * (1 / (1 + (1 + k) : Real))))
           by doubledCast
     = ((Natural.triangular(1 + k) : Real)
        * (1 / (Natural.triangular(1 + k) : Real)))
       * (2 * ((1 / (1 + k : Real))
               * (1 / (1 + (1 + k) : Real))))
     = 1 * (2 * ((1 / (1 + k : Real))
                 * (1 / (1 + (1 + k) : Real))))
           by TCancel
     = 2 * ((1 / (1 + k : Real))
            * (1 / (1 + (1 + k) : Real)))
     as termIdentity;
  -- A difference of consecutive reciprocals is their product (the gap
  -- between the denominators is exactly 1).
  (1 / (1 + k : Real)) - (1 / (1 + (1 + k) : Real))
     = ((1 + (1 + k) : Real) - (1 + k : Real))
       * ((1 / (1 + k : Real))
          * (1 / (1 + (1 + k) : Real)))
           by field
     = 1 * ((1 / (1 + k : Real))
            * (1 / (1 + (1 + k) : Real)))
           by gapOne
     = (1 / (1 + k : Real)) * (1 / (1 + (1 + k) : Real))
     as coreCollapsed;
  Real.triangular_reciprocal_term(k)
     = 1 / (Natural.triangular(1 + k) : Real)
     = 2 * ((1 / (1 + k : Real))
            * (1 / (1 + (1 + k) : Real)))
           by termIdentity
     = 2 * ((1 / (1 + k : Real))
            - (1 / (1 + (1 + k) : Real)))
           by coreCollapsed
     = 2 * (1 / (1 + k : Real))
       - 2 * (1 / (1 + (1 + k) : Real))
           by ring
     = 2 / (1 + k : Real)
       - 2 * (1 / (1 + (1 + k) : Real))
           by Real.multiply_one_divide
     = 2 / (1 + k : Real) - 2 / (1 + (1 + k) : Real)
           by Real.multiply_one_divide
}

-- ----------------------------------------------------------------------
-- The tail 2/(n+1) converges to zero. The decay rate is the Rational
-- Archimedean bound, carried across the ℚ→ℝ boundary term by term.
theorem Real.triangular_tail_converges
        : Real.SequenceConverges(
              (n : Natural) ↦ 2 / (1 + n : Real),
              Real.zero) := {
  -- The decay tolerance is rational (`scaled_reciprocal_eventually_below`),
  -- so build at a rational ε and lift by density.
  done by Real.SequenceConverges.of_rational(
      rationalBound :=
  (ε : Rational)
  (εPositive : ε > Rational.zero) ↦ {
    Rational.IsNonneg((2 : Rational));
    choose N such that
        ∀ (m : Natural). N ≤ m
          → (2 : Rational) * Rational.reciprocal_function((1 + m : Rational)) < ε
        as tailBelow
        from Rational.scaled_reciprocal_eventually_below;
    witness N with
        (m : Natural) (aboveThreshold : N ≤ m) ↦ {
          -- Carry the rational bound across the boundary.
          (1 + m : Rational) > Rational.zero;
          (1 + m : Rational) ≠ Rational.zero;
          (1 + m : Real) > 0;
          (1 + m : Real) ≠ 0;
          (((2 : Rational)
                 * Rational.reciprocal_function((1 + m : Rational))) : Real)
             = ((2 : Rational) : Real)
               * ((Rational.reciprocal_function((1 + m : Rational))) : Real)
             = ((2 : Rational) : Real) * (1 / (1 + m : Real))
                   by Rational.to_real.reciprocal_preserves
             = 2 / (1 + m : Real)
             as boundaryBridge;
          (2 : Rational)
                      * Rational.reciprocal_function((1 + m : Rational))
                  < ε
              by tailBelow;
          (((2 : Rational)
                  * Rational.reciprocal_function((1 + m : Rational))) : Real)
                  < (ε : Real)
              by Rational.to_real.LessThan_preserves;
          2 / (1 + m : Real) < (ε : Real)
              by substituting boundaryBridge as tailBelowCast;
          -- The tail is nonnegative, so it is its own absolute value.
          (2 : Real) > 0;
          2 / (1 + m : Real) > 0;
          2 / (1 + m : Real) ≥ 0;
          Real.IsNonneg(2 / (1 + m : Real));
          abs(2 / (1 + m : Real) - Real.zero)
             = abs(2 / (1 + m : Real))
                   by (2 / (1 + m : Real) - Real.zero
                       = 2 / (1 + m : Real))
             = 2 / (1 + m : Real)
             < (ε : Real)
                   by tailBelowCast
        }
  })
}

-- ----------------------------------------------------------------------
-- Freek #42: the reciprocals of the triangular numbers sum to 2.
theorem Real.triangular_reciprocals_sum_to_two
        : Real.SeriesConverges(Real.triangular_reciprocal_term, (2 : Real)) := {
  -- The first tail is exactly 2: 2/(0+1) = 2.
  (1 + 0 : Real) = 1 as castOne;
  2 / (1 + 0 : Real)
     = 1 * (2 / (1 + 0 : Real))
     = (1 + 0 : Real) * (2 / (1 + 0 : Real))
           by castOne
     = 2
     as tailAtZero;
  -- Limit algebra: constant head plus vanishing negated tail.
  Real.triangular_tail_converges;
  Real.SequenceConverges(
            (n : Natural) ↦ -(2 / (1 + n : Real)),
            -Real.zero)
      by Real.SequenceConverges.negate(
             s := (n : Natural) ↦ 2 / (1 + n : Real));
  Real.SequenceConverges(
            (n : Natural) ↦ 2 / (1 + 0 : Real),
            2 / (1 + 0 : Real))
      by Real.constant_sequence_converges;
  Real.SequenceConverges(
            (n : Natural) ↦
                2 / (1 + 0 : Real)
                + -(2 / (1 + n : Real)),
            2 / (1 + 0 : Real) + -Real.zero)
      by Real.SequenceConverges.add(
             s := (n : Natural) ↦ 2 / (1 + 0 : Real),
             t := (n : Natural) ↦ -(2 / (1 + n : Real)));
  -- The combined limit is 2.
  (2 : Real)
     = 2 / (1 + 0 : Real)
           by tailAtZero
     = 2 / (1 + 0 : Real) + -Real.zero
     as limitEquation;
  Real.SequenceConverges(
            (n : Natural) ↦
                2 / (1 + 0 : Real)
                + -(2 / (1 + n : Real)),
            (2 : Real))
      by substituting limitEquation;
  -- The partial sums are exactly that sequence, by telescoping.
  Real.triangular_term_telescopes;
  ∀ (n : Natural).
            Real.partialSum(Real.triangular_reciprocal_term, n)
            = 2 / (1 + 0 : Real)
              + -(2 / (1 + n : Real))
      by {
        take n : Natural;
        Real.partialSum(Real.triangular_reciprocal_term, n)
           = Real.partialSum(
                 (k : Natural) ↦
                     2 / (1 + k : Real)
                     - 2 / (1 + (1 + k) : Real),
                 n)
           = 2 / (1 + 0 : Real)
             - 2 / (1 + n : Real)
                 by Real.telescoping_partialSum(
                        t := (j : Natural) ↦ 2 / (1 + j : Real))
      };
  done by Real.SequenceConverges.pointwise
}

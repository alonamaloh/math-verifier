-- Real/triangular_series.math
--
-- The sum of the reciprocals of the triangular numbers (Freek #42):
--   Σ 1/T(k+1) = 2,   T(n) = 1 + 2 + … + n.
--
-- Partial fractions: 1/T(k+1) = 2/(k+1) − 2/(k+2) (from the product
-- form 2·T(k+1) = (k+1)(k+2) and the field tactic), so the partial
-- sums telescope to 2 − 2/(n+1), and the tail dies by the Archimedean
-- bound. Everything analytic happens at the Rational layer; the series
-- machinery sees only casts.

module Real.triangular_series

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Natural.triangular
import Integer.basics
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.absolute_value
import Rational.triangle
import Rational.triangle_more
import Rational.positive
import Rational.linearity
import Rational.reciprocal
import Rational.reciprocal_function
import Rational.archimedean
import Algebra.ring_lemmas
import Set.basics
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.instances
import Real.order
import Real.linearity
import Real.embedding_order
import Real.order_multiplication
import Real.absolute_value
import Real.absolute_value_order
import Real.convergence
import Real.supremum
import Real.limits
import Real.series

-- ----------------------------------------------------------------------
-- The term sequence: 1/T(k+1), embedded into the reals.
definition Real.triangular_reciprocal_term (k : Natural) : Real :=
  (Rational.reciprocal_function((Natural.triangular(1 + k) : Rational)) : Real)

-- ----------------------------------------------------------------------
-- Partial fractions at the Rational layer:
-- 1/T(k+1) = 2/(k+1) − 2/(k+2).
theorem Rational.triangular_reciprocal_split (k : Natural)
        : Rational.reciprocal_function((Natural.triangular(1 + k) : Rational))
          = (2 : Rational)
                * Rational.reciprocal_function((1 + k : Rational))
            - (2 : Rational)
                * Rational.reciprocal_function(
                      (1 + (1 + k) : Rational)) := {
  -- The product form of the doubled triangular number, cast to ℚ.
  calc (Natural.triangular(1 + k) : Rational) * (2 : Rational)
     = ((Natural.triangular(1 + k) * 2 : Natural) : Rational)
           since Rational.from_natural_multiply_preserves
     = (((1 + k) * (1 + (1 + k)) : Natural) : Rational)
           since Natural.triangular_doubled
     = (1 + k : Rational) * (1 + (1 + k) : Rational)
           since Rational.from_natural_multiply_preserves
     as doubledCast;
  -- The three denominators are nonzero.
  claim (1 + k : Rational) > Rational.zero
      since Rational.one_plus_cast_positive;
  claim (1 + (1 + k) : Rational) > Rational.zero
      since Rational.one_plus_cast_positive;
  claim skNonzero : (1 + k : Rational) ≠ Rational.zero;
  claim sskNonzero : (1 + (1 + k) : Rational) ≠ Rational.zero;
  claim (1 + k : Rational) * (1 + (1 + k) : Rational) > Rational.zero
      since Rational.multiply_positive_positive;
  claim (Natural.triangular(1 + k) : Rational) * (2 : Rational) > Rational.zero
      by substituting doubledCast;
  claim Rational.zero ≠ (Natural.triangular(1 + k) : Rational) * (2 : Rational)
      since Rational.LessThan.distinct;
  claim (Natural.triangular(1 + k) : Rational) ≠ Rational.zero by {
      suppose (Natural.triangular(1 + k) : Rational) = Rational.zero as triangularZero;
      calc Rational.zero
         = Rational.zero * (2 : Rational)
         = (Natural.triangular(1 + k) : Rational) * (2 : Rational)
               by substituting triangularZero;
      done
  };
  -- Cancellations for the three reciprocals.
  claim TCancel
        : (Natural.triangular(1 + k) : Rational)
              * Rational.reciprocal_function(
                    (Natural.triangular(1 + k) : Rational))
          = Rational.one;
  claim productCancel
        : ((1 + k : Rational) * (1 + (1 + k) : Rational))
              * (Rational.reciprocal_function((1 + k : Rational))
                 * Rational.reciprocal_function(
                       (1 + (1 + k) : Rational)))
          = Rational.one
      by field(skNonzero, sskNonzero);
  -- Consecutive denominators are one apart.
  calc (1 + (1 + k) : Rational) - (1 + k : Rational)
     = ((1 : Rational) + (1 + k : Rational)) - (1 + k : Rational)
           since Rational.one_plus_cast
     = Rational.one
     as gapOne;
  -- 1/T(k+1) = 2·(1/(k+1))·(1/(k+2)): trade T for (k+1)(k+2)/2 against
  -- the cancellations.
  calc Rational.reciprocal_function((Natural.triangular(1 + k) : Rational))
     = Rational.reciprocal_function((Natural.triangular(1 + k) : Rational))
       * Rational.one
     = Rational.reciprocal_function((Natural.triangular(1 + k) : Rational))
       * (((1 + k : Rational) * (1 + (1 + k) : Rational))
          * (Rational.reciprocal_function((1 + k : Rational))
             * Rational.reciprocal_function((1 + (1 + k) : Rational))))
           since productCancel
     = Rational.reciprocal_function((Natural.triangular(1 + k) : Rational))
       * (((Natural.triangular(1 + k) : Rational) * (2 : Rational))
          * (Rational.reciprocal_function((1 + k : Rational))
             * Rational.reciprocal_function((1 + (1 + k) : Rational))))
           since doubledCast
     = ((Natural.triangular(1 + k) : Rational)
        * Rational.reciprocal_function((Natural.triangular(1 + k) : Rational)))
       * ((2 : Rational)
          * (Rational.reciprocal_function((1 + k : Rational))
             * Rational.reciprocal_function((1 + (1 + k) : Rational))))
     = Rational.one
       * ((2 : Rational)
          * (Rational.reciprocal_function((1 + k : Rational))
             * Rational.reciprocal_function((1 + (1 + k) : Rational))))
           since TCancel
     = (2 : Rational)
       * (Rational.reciprocal_function((1 + k : Rational))
          * Rational.reciprocal_function((1 + (1 + k) : Rational)))
     as termIdentity;
  -- A difference of consecutive reciprocals is their product (the gap
  -- between the denominators is exactly 1).
  calc Rational.reciprocal_function((1 + k : Rational))
       - Rational.reciprocal_function((1 + (1 + k) : Rational))
     = ((1 + (1 + k) : Rational) - (1 + k : Rational))
       * (Rational.reciprocal_function((1 + k : Rational))
          * Rational.reciprocal_function(
                (1 + (1 + k) : Rational)))
           since field(skNonzero, sskNonzero)
     = Rational.one
       * (Rational.reciprocal_function((1 + k : Rational))
          * Rational.reciprocal_function(
                (1 + (1 + k) : Rational)))
           since gapOne
     = Rational.reciprocal_function((1 + k : Rational))
       * Rational.reciprocal_function(
             (1 + (1 + k) : Rational))
     as coreCollapsed;
  calc Rational.reciprocal_function((Natural.triangular(1 + k) : Rational))
     = (2 : Rational)
       * (Rational.reciprocal_function((1 + k : Rational))
          * Rational.reciprocal_function(
                (1 + (1 + k) : Rational)))
           since termIdentity
     = (2 : Rational)
       * (Rational.reciprocal_function((1 + k : Rational))
          - Rational.reciprocal_function(
                (1 + (1 + k) : Rational)))
           since coreCollapsed
     = (2 : Rational)
           * Rational.reciprocal_function((1 + k : Rational))
       - (2 : Rational)
           * Rational.reciprocal_function(
                 (1 + (1 + k) : Rational))
}

-- ----------------------------------------------------------------------
-- The same split, embedded: each term is a difference of consecutive
-- tails 2/(n+1).
theorem Real.triangular_term_telescopes (k : Natural)
        : Real.triangular_reciprocal_term(k)
          = (((2 : Rational)
              * Rational.reciprocal_function((1 + k : Rational)))
             : Real)
            - (((2 : Rational)
                * Rational.reciprocal_function(
                      (1 + (1 + k) : Rational)))
               : Real) :=
  calc Real.triangular_reciprocal_term(k)
     = ((Rational.reciprocal_function(
             (Natural.triangular(1 + k) : Rational))) : Real)
     = ((((2 : Rational)
          * Rational.reciprocal_function((1 + k : Rational)))
         - ((2 : Rational)
            * Rational.reciprocal_function(
                  (1 + (1 + k) : Rational)))) : Real)
           since Rational.triangular_reciprocal_split
     = (((2 : Rational)
         * Rational.reciprocal_function((1 + k : Rational))) : Real)
       - (((2 : Rational)
           * Rational.reciprocal_function(
                 (1 + (1 + k) : Rational))) : Real)
           since Rational.to_real.subtract_preserves

-- Now that both indices are written `1 + k` and `1 + (1 + k)`, the "shifted"
-- form the telescoping consumer wants is definitionally the plain telescoping
-- identity; kept as a named alias for `Real.telescoping_partialSum`'s call site.
theorem Real.triangular_term_telescopes_shifted (k : Natural)
        : Real.triangular_reciprocal_term(k)
          = (((2 : Rational)
              * Rational.reciprocal_function((1 + k : Rational)))
             : Real)
            - (((2 : Rational)
                * Rational.reciprocal_function(
                      (1 + (1 + k) : Rational)))
               : Real) :=
  Real.triangular_term_telescopes

-- ----------------------------------------------------------------------
-- The tail 2/(n+1) converges to zero.
theorem Real.triangular_tail_converges
        : Real.SequenceConverges(
              (n : Natural) ↦
                  (((2 : Rational)
                    * Rational.reciprocal_function((1 + n : Rational)))
                   : Real),
              Real.zero) := {
  -- The decay tolerance is rational (`scaled_reciprocal_eventually_below`),
  -- so build at a rational ε and lift by density.
  done by Real.SequenceConverges.of_rational(
      rationalBound :=
  (ε : Rational)
  (εPositive : ε > Rational.zero) ↦ {
    claim Rational.IsNonneg((2 : Rational))
        since Rational.from_natural_IsNonneg;
    choose N such that
        ∀ (m : Natural). N ≤ m
          → (2 : Rational) * Rational.reciprocal_function((1 + m : Rational)) < ε
        as tailBelow
        from Rational.scaled_reciprocal_eventually_below;
    witness N with
        (m : Natural) (aboveThreshold : N ≤ m) ↦ {
          claim (2 : Rational)
                      * Rational.reciprocal_function((1 + m : Rational))
                  < ε
              by tailBelow;
          -- The tail is nonnegative, so its cast is its own absolute value.
          claim (1 + m : Rational) > Rational.zero
              since Rational.one_plus_cast_positive;
          claim Rational.reciprocal_function((1 + m : Rational)) > Rational.zero
              since Rational.reciprocal_function_positive_of_positive;
          claim Rational.reciprocal_function((1 + m : Rational)) ≥ Rational.zero
              since Rational.LessThan.weaken;
          claim Rational.IsNonneg(
                    Rational.reciprocal_function((1 + m : Rational)))
              since Rational.IsNonneg_of_LessOrEqual_zero;
          claim Rational.IsNonneg(
                    (2 : Rational)
                    * Rational.reciprocal_function((1 + m : Rational)))
              since Rational.IsNonneg.multiply;
          claim (2 : Rational)
                    * Rational.reciprocal_function((1 + m : Rational)) ≥ Rational.zero
              since Rational.LessOrEqual_zero_of_IsNonneg;
          claim (((2 : Rational)
                  * Rational.reciprocal_function((1 + m : Rational))) : Real)
                  ≥ (Rational.zero : Real)
              since Rational.to_real.LessOrEqual_preserves;
          claim Real.IsNonneg(
                    (((2 : Rational)
                      * Rational.reciprocal_function(
                            (1 + m : Rational))) : Real))
              since Real.IsNonneg_of_LessOrEqual_zero;
          calc abs((((2 : Rational)
                     * Rational.reciprocal_function((1 + m : Rational))) : Real)
                   - Real.zero)
             = abs((((2 : Rational)
                     * Rational.reciprocal_function((1 + m : Rational))) : Real))
                   by ((((2 : Rational)
                         * Rational.reciprocal_function((1 + m : Rational))) : Real)
                       - Real.zero
                       = (((2 : Rational)
                           * Rational.reciprocal_function((1 + m : Rational))) : Real))
             = (((2 : Rational)
                 * Rational.reciprocal_function((1 + m : Rational))) : Real)
                   since Real.absolute_value_when_nonneg
             as absEqual;
          claim (((2 : Rational)
                  * Rational.reciprocal_function(
                        (1 + m : Rational))) : Real)
                  < (ε : Real)
              since Rational.to_real.LessThan_preserves;
          done by substituting absEqual
        }
  })
}

-- ----------------------------------------------------------------------
-- Freek #42: the reciprocals of the triangular numbers sum to 2.
theorem Real.triangular_reciprocals_sum_to_two
        : Real.SeriesConverges(
              Real.triangular_reciprocal_term, ((2 : Rational) : Real)) := {
  -- The first tail is exactly 2: 2/(0+1) = 2.
  calc (1 + 0 : Rational)
     = (1 : Rational) + (0 : Rational)    since Rational.one_plus_cast
     = Rational.one;
  claim (1 + 0 : Rational) > Rational.zero
      since Rational.one_plus_cast_positive;
  claim (1 + 0 : Rational) ≠ Rational.zero
      since Rational.nonzero_of_positive;
  claim (1 + 0 : Rational)
              * Rational.reciprocal_function((1 + 0 : Rational))
          = Rational.one
      since Rational.reciprocal_function_multiplies;
  calc Rational.reciprocal_function((1 + 0 : Rational))
     = Rational.one * Rational.reciprocal_function((1 + 0 : Rational))
     = (1 + 0 : Rational)
       * Rational.reciprocal_function((1 + 0 : Rational))
     = Rational.one
     as recipS0;
  claim tailAtZero
        : (2 : Rational)
              * Rational.reciprocal_function((1 + 0 : Rational))
          = (2 : Rational)
      by substituting recipS0;
  -- Limit algebra: constant head plus vanishing negated tail.
  claim Real.triangular_tail_converges;
  claim Real.SequenceConverges(
            (n : Natural) ↦
                -(((2 : Rational)
                   * Rational.reciprocal_function((1 + n : Rational))) : Real),
            -Real.zero)
      by Real.SequenceConverges.negate(
             s := (n : Natural) ↦
                 (((2 : Rational)
                   * Rational.reciprocal_function((1 + n : Rational))) : Real));
  claim Real.SequenceConverges(
            (n : Natural) ↦
                (((2 : Rational)
                  * Rational.reciprocal_function((1 + 0 : Rational))) : Real),
            (((2 : Rational)
              * Rational.reciprocal_function((1 + 0 : Rational))) : Real))
      by Real.constant_sequence_converges;
  claim Real.SequenceConverges(
            (n : Natural) ↦
                (((2 : Rational)
                  * Rational.reciprocal_function((1 + 0 : Rational))) : Real)
                + -(((2 : Rational)
                     * Rational.reciprocal_function((1 + n : Rational))) : Real),
            (((2 : Rational)
              * Rational.reciprocal_function((1 + 0 : Rational))) : Real)
            + -Real.zero)
      by Real.SequenceConverges.add(
             s := (n : Natural) ↦
                 (((2 : Rational)
                   * Rational.reciprocal_function((1 + 0 : Rational))) : Real),
             t := (n : Natural) ↦
                 -(((2 : Rational)
                    * Rational.reciprocal_function((1 + n : Rational))) : Real));
  -- The combined limit is 2.
  calc ((2 : Rational) : Real)
     = (((2 : Rational)
         * Rational.reciprocal_function((1 + 0 : Rational))) : Real)
           by tailAtZero
     = (((2 : Rational)
         * Rational.reciprocal_function((1 + 0 : Rational))) : Real)
       + -Real.zero
     as limitEquation;
  claim Real.SequenceConverges(
            (n : Natural) ↦
                (((2 : Rational)
                  * Rational.reciprocal_function((1 + 0 : Rational))) : Real)
                + -(((2 : Rational)
                     * Rational.reciprocal_function((1 + n : Rational))) : Real),
            ((2 : Rational) : Real))
      by substituting limitEquation;
  -- The partial sums are exactly that sequence, by telescoping.
  claim Real.triangular_term_telescopes_shifted;
  claim ∀ (n : Natural).
            Real.partialSum(Real.triangular_reciprocal_term, n)
            = (((2 : Rational)
                * Rational.reciprocal_function((1 + 0 : Rational))) : Real)
              + -(((2 : Rational)
                   * Rational.reciprocal_function((1 + n : Rational))) : Real)
      by {
        take n : Natural;
        calc Real.partialSum(Real.triangular_reciprocal_term, n)
           = Real.partialSum(
                 (k : Natural) ↦
                     (((2 : Rational)
                       * Rational.reciprocal_function((1 + k : Rational))) : Real)
                     - (((2 : Rational)
                         * Rational.reciprocal_function((1 + (1 + k) : Rational))) : Real),
                 n)
           = (((2 : Rational)
               * Rational.reciprocal_function((1 + 0 : Rational))) : Real)
             - (((2 : Rational)
                 * Rational.reciprocal_function((1 + n : Rational))) : Real)
                 by Real.telescoping_partialSum(
                        t := (j : Natural) ↦
                            (((2 : Rational)
                              * Rational.reciprocal_function((1 + j : Rational))) : Real))
      };
  done by Real.SequenceConverges.pointwise
}

-- Real/absolute_value_order.math
--
-- How the absolute value sits against the order on ℝ:
--
--   * x ≤ |x| and -x ≤ |x|;
--   * |x| = x when x ≥ 0, |x| = -x when -x ≥ 0;
--   * |x| < c exactly when -c < x < c (both directions) — the bridge
--     between ε-bounds on |·| and two-sided bounds, used throughout
--     limits and continuity.
--
-- Only the two `_at_make` lemmas touch representatives (pointwise
-- Rational facts lifted along the established at-make pattern);
-- everything else is Real-level order algebra.

module Real.absolute_value_order

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.order
import Rational.basics
import Rational.addition
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.triangle_more
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.ring
import Real.algebra
import Real.order
import Real.linearity
import Real.absolute_value

-- ----------------------------------------------------------------------
-- x ≤ |x|. Pointwise: the Rational fact x ≤ |x| at every index.
theorem Real.LessOrEqual_absolute_value_at_make
        (rep : CauchyRationalSequence)
        : (Quotient.class_of(rep) : ℝ) ≤ abs((Quotient.class_of(rep) : ℝ)) := {
  let ⟨s, _⟩ := rep;
  unfold Real.IsNonneg in
  ((ε : ℚ)
           (εPositive : Rational.zero < ε) ↦
    witness 0 with
        (m : ℕ) (_ : 0 ≤ m) ↦ {
          s(m) ≤ abs(s(m));
          Rational.IsNonneg(abs(s(m)) + -(s(m)));
          -ε < Rational.zero
             ≤ abs(s(m)) + -(s(m))
        })
}

theorem Real.LessOrEqual_absolute_value (x : ℝ) : x ≤ abs(x) :=
  by_representatives x as rep =>
      done by Real.LessOrEqual_absolute_value_at_make

-- -x ≤ |x|: apply the previous bound at -x and fold |-x| = |x|.
theorem Real.negate_LessOrEqual_absolute_value (x : ℝ) : -x ≤ abs(x) :=
  -x
     ≤ abs(-x)
     = abs(x)

-- ----------------------------------------------------------------------
-- |x| ≤ x when x ≥ 0. Pointwise: a nonnegativity bound -δ < s(m) gives
-- -2δ < s(m) - |s(m)| (the difference is 0 on the nonnegative side and
-- 2·s(m) otherwise), so the ε-argument runs at δ = ε/2.
theorem Real.absolute_value_LessOrEqual_of_nonneg_at_make
        (rep : CauchyRationalSequence)
        (eventuallyNonneg : CauchyRationalSequence.IsEventuallyNonneg(rep))
        : abs((Quotient.class_of(rep) : ℝ)) ≤ (Quotient.class_of(rep) : ℝ) := {
  let ⟨s, sCauchy⟩ := rep;
  unfold Real.IsNonneg in
  ((ε : ℚ)
   (εPositive : Rational.zero < ε) ↦ {
     Rational.zero < Rational.halve(ε) as halfPositive;
     choose N as eventuallyAboveHalf
         from eventuallyNonneg(Rational.halve(ε), halfPositive);
     witness N with
         (m : ℕ) (NLeqM : N ≤ m) ↦ {
           -Rational.halve(ε) < s(m)
               by eventuallyAboveHalf(m, NLeqM);
           -- Goal: -ε < s(m) + -|s(m)|; ε is twice the slack δ.
           -ε = -(Rational.halve(ε) + Rational.halve(ε))
              < s(m) + -abs(s(m))   by Rational.subtract_absolute_value_lower_bound
         }
   })
}

theorem Real.absolute_value_LessOrEqual_of_nonneg (x : ℝ)
        (xNonneg : Real.IsNonneg(x))
        : abs(x) ≤ x :=
  by_representatives x as rep => {
      CauchyRationalSequence.IsEventuallyNonneg(rep) by Real.IsNonneg.eventually_nonneg;
      done by Real.absolute_value_LessOrEqual_of_nonneg_at_make
  }

-- ----------------------------------------------------------------------
-- The sign-case equalities, by antisymmetry / reflection.

theorem Real.absolute_value_when_nonneg (x : ℝ)
        (xNonneg : Real.IsNonneg(x))
        : abs(x) = x := {
  abs(x) ≤ x;
  x ≤ abs(x);
  done by Real.LessOrEqual.antisymmetric
}

-- The absolute value of zero is zero. A routine fact the auto-prover finds
-- on its own, so a trivial `abs(Real.zero) = 0` step needs no hint.
automatic theorem Real.absolute_value_zero : abs(Real.zero) = Real.zero := {
  Real.IsNonneg(Real.zero);
  done
}

theorem Real.absolute_value_when_negate_nonneg (x : ℝ)
        (negateNonneg : Real.IsNonneg(-x))
        : abs(x) = -x :=
  abs(x)
     = abs(-x)
     = -x

-- ----------------------------------------------------------------------
-- Reflecting a strict bound through negation: -a < b gives -b < a
-- (add b + -a to both sides).
theorem Real.negate_flip_LessThan (a b : ℝ)
        (lowerBound : -a < b)
        : -b < a := {
  -a + (a + -b) < b + (a + -b);
  -b = -a + (a + -b)
     < b + (a + -b)
     = a
}

-- ----------------------------------------------------------------------
-- The two-sided characterisation of |x| < c.

theorem Real.absolute_value_LessThan_of_bounds (x c : ℝ)
        (lowerBound : -c < x) (upperBound : x < c)
        : abs(x) < c :=
  done by cases {
    case Real.IsNonneg(x) as xNonneg:
        abs(x)
           = x
           < c
    case Real.IsNonneg(-x) as negateNonneg: {
        -x < c;
        abs(x)
           = -x
           < c
      }
  }

theorem Real.absolute_value_LessThan_bounds (x c : ℝ)
        (absoluteBound : abs(x) < c)
        : -c < x ∧ x < c := {
  x ≤ abs(x)
    < c   as upperBound;
  -x ≤ abs(x)
     < c;
  -c < x as lowerBound;
  And.introduction(lowerBound, upperBound)
}

-- |x| is nonnegative: it equals x or −x, whichever is the nonneg one.
theorem Real.absolute_value_nonneg (x : ℝ) : Real.zero ≤ abs(x) :=
  done by cases {
    case Real.IsNonneg(x) as xNonneg: {
        Real.zero ≤ x;
        abs(x) = x;
        done
      }
    case Real.IsNonneg(-x) as negateNonneg: {
        Real.zero ≤ -x;
        abs(x) = -x;
        done
      }
  }

-- |x| is positive when x is nonzero: whichever sign case applies,
-- |x| equals a nonzero nonnegative number.
automatic theorem Real.absolute_value_positive (x : ℝ) (xNonzero : x ≠ 0)
        : abs(x) > 0 :=
  done by cases {
    case Real.IsNonneg(x) as xNonneg: {
        Real.zero ≤ x;
        x > 0;
        abs(x) = x;
        done
      }
    case Real.IsNonneg(-x) as negateNonneg: {
        Real.zero ≤ -x;
        -x ≠ 0 by (negateZero : -x = 0) ↦ xNonzero({ x = -(-x) = -(0 : ℝ) = 0 });
        -x > 0;
        abs(x) = -x;
        done
      }
  }

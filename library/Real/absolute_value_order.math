-- Real/absolute_value_order.math
--
-- How the absolute value sits against the order on ℝ:
--
--   * x ≤ |x| and -x ≤ |x|;
--   * |x| = x when x ≥ 0, |x| = -x when -x ≥ 0;
--   * |x| < c exactly when -c < x < c (both directions) — the bridge
--     between ε-bounds on |·| and two-sided bounds, used throughout
--     limits and continuity.
--
-- Only the two `_at_make` lemmas touch representatives (pointwise
-- Rational facts lifted along the established at-make pattern);
-- everything else is Real-level order algebra.

module Real.absolute_value_order

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.order
import Rational.basics
import Rational.addition
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.triangle_more
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.ring
import Real.algebra
import Real.order
import Real.linearity
import Real.absolute_value

-- ----------------------------------------------------------------------
-- x ≤ |x|. Pointwise: the Rational fact x ≤ |x| at every index.
theorem Real.LessOrEqual_absolute_value_at_make
        : ∀ (rep : CauchyRationalSequence).
            (Quotient.class_of(rep) : Real) ≤ abs((Quotient.class_of(rep) : Real))
  | CauchyRationalSequence.make(s, _) =>
      unfold Real.IsNonneg in
      ((epsilon : Rational)
               (epsilonPositive : Rational.zero < epsilon) ↦
        witness 0 with
            (m : Natural) (_ : 0 ≤ m) ↦ {
              claim s(m) ≤ abs(s(m)) since Rational.le_absolute_value;
              claim Rational.IsNonneg(abs(s(m)) + -(s(m)));
              calc -epsilon
                 < Rational.zero   since Rational.negate_LessThan_zero_of_positive
                 ≤ abs(s(m)) + -(s(m))   since Rational.LessOrEqual_zero_of_IsNonneg
            })

theorem Real.LessOrEqual_absolute_value (x : Real) : x ≤ abs(x) :=
  by_representatives x as rep =>
      done since Real.LessOrEqual_absolute_value_at_make

-- -x ≤ |x|: apply the previous bound at -x and fold |-x| = |x|.
theorem Real.negate_LessOrEqual_absolute_value (x : Real) : -x ≤ abs(x) :=
  calc -x
     ≤ abs(-x)   since Real.LessOrEqual_absolute_value
     = abs(x)    since Real.absolute_value_negate

-- ----------------------------------------------------------------------
-- |x| ≤ x when x ≥ 0. Pointwise: a nonnegativity bound -δ < s(m) gives
-- -2δ < s(m) - |s(m)| (the difference is 0 on the nonnegative side and
-- 2·s(m) otherwise), so the ε-argument runs at δ = ε/2.
theorem Real.absolute_value_LessOrEqual_of_nonneg_at_make
        : ∀ (rep : CauchyRationalSequence).
            CauchyRationalSequence.IsEventuallyNonneg(rep)
          → abs((Quotient.class_of(rep) : Real)) ≤ (Quotient.class_of(rep) : Real)
  | CauchyRationalSequence.make(s, sCauchy) =>
      unfold Real.IsNonneg in
      ((eventuallyNonneg
          : CauchyRationalSequence.IsEventuallyNonneg(
                CauchyRationalSequence.make(s, sCauchy)))
      (epsilon : Rational)
      (epsilonPositive : Rational.zero < epsilon) ↦ {
        claim halfPositive : Rational.zero < Rational.halve(epsilon)
            since Rational.halve_positive;
        choose N as eventuallyAboveHalf
            from eventuallyNonneg(Rational.halve(epsilon), halfPositive);
        witness N with
            (m : Natural) (NLeqM : N ≤ m) ↦ {
              claim -Rational.halve(epsilon) < s(m)
                  by eventuallyAboveHalf(m, NLeqM);
              -- Goal: -ε < s(m) + -|s(m)|; ε is twice the slack δ.
              calc -epsilon
                 = -(Rational.halve(epsilon) + Rational.halve(epsilon))
                 < s(m) + -abs(s(m))   since Rational.subtract_absolute_value_lower_bound
            }
      })

theorem Real.absolute_value_LessOrEqual_of_nonneg (x : Real)
        (xNonneg : Real.IsNonneg(x))
        : abs(x) ≤ x :=
  cases x refining xNonneg { | rep => {
      claim CauchyRationalSequence.IsEventuallyNonneg(rep) since Real.IsNonneg.eventually_nonneg;
      done since Real.absolute_value_LessOrEqual_of_nonneg_at_make
  } }

-- ----------------------------------------------------------------------
-- The sign-case equalities, by antisymmetry / reflection.

theorem Real.absolute_value_when_nonneg (x : Real)
        (xNonneg : Real.IsNonneg(x))
        : abs(x) = x := {
  claim abs(x) ≤ x since Real.absolute_value_LessOrEqual_of_nonneg;
  claim x ≤ abs(x) since Real.LessOrEqual_absolute_value;
  done since Real.LessOrEqual.antisymmetric
}

-- The absolute value of zero is zero. A routine fact the auto-prover finds
-- on its own, so a trivial `abs(Real.zero) = 0` step needs no hint.
theorem Real.absolute_value_zero : abs(Real.zero) = Real.zero := {
  claim Real.IsNonneg(Real.zero) since Real.IsNonneg_zero;
  done since Real.absolute_value_when_nonneg
}

theorem Real.absolute_value_when_negate_nonneg (x : Real)
        (negateNonneg : Real.IsNonneg(-x))
        : abs(x) = -x :=
  calc abs(x)
     = abs(-x)   since Real.absolute_value_negate
     = -x        since Real.absolute_value_when_nonneg

-- ----------------------------------------------------------------------
-- Reflecting a strict bound through negation: -a < b gives -b < a
-- (add b + -a to both sides).
theorem Real.negate_flip_LessThan (a b : Real)
        (lowerBound : -a < b)
        : -b < a := {
  claim -a + (a + -b) < b + (a + -b)
      since Real.add_preserves_LessThan;
  calc -b
     = -a + (a + -b)
     < b + (a + -b)
     = a
}

-- ----------------------------------------------------------------------
-- The two-sided characterisation of |x| < c.

theorem Real.absolute_value_LessThan_of_bounds (x c : Real)
        (lowerBound : -c < x) (upperBound : x < c)
        : abs(x) < c :=
  claim by cases {
    in (Real.IsNonneg(x)) as xNonneg:
        calc abs(x)
           = x   since Real.absolute_value_when_nonneg
           < c
    in (Real.IsNonneg(-x)) as negateNonneg: {
        claim -x < c since Real.negate_flip_LessThan;
        calc abs(x)
           = -x   since Real.absolute_value_when_negate_nonneg
           < c
      }
  }

theorem Real.absolute_value_LessThan_bounds (x c : Real)
        (absoluteBound : abs(x) < c)
        : -c < x ∧ x < c := {
  calc x
     ≤ abs(x)   since Real.LessOrEqual_absolute_value
     < c   as upperBound;
  calc -x
     ≤ abs(x)   since Real.negate_LessOrEqual_absolute_value
     < c;
  claim lowerBound : -c < x since Real.negate_flip_LessThan;
  And.introduction(lowerBound, upperBound)
}

-- |x| is nonnegative: it equals x or −x, whichever is the nonneg one.
theorem Real.absolute_value_nonneg (x : Real) : Real.zero ≤ abs(x) :=
  claim by cases {
    in (Real.IsNonneg(x)) as xNonneg: {
        claim Real.zero ≤ x since Real.LessOrEqual_zero_of_IsNonneg;
        claim absEquation : abs(x) = x since Real.absolute_value_when_nonneg;
        done by substituting absEquation
      }
    in (Real.IsNonneg(-x)) as negateNonneg: {
        claim Real.zero ≤ -x since Real.LessOrEqual_zero_of_IsNonneg;
        claim absEquation : abs(x) = -x since Real.absolute_value_when_negate_nonneg;
        done by substituting absEquation
      }
  }

-- Real/reciprocal.math
--
-- The reciprocal Cauchy rational sequence for a Real that's apart
-- from zero, plus the IsCauchy proof. Built on
-- `Rational.reciprocal_function` (a total reciprocal) and the
-- apartness extraction in `Real/apartness.math`.
--
-- The IsCauchy proof goes through the algebraic identity
-- `1/a - 1/b = (b - a) * (1/a * 1/b)` (provable in any commutative
-- ring with multiplicative inverses), which after multiplying by
-- s(m)·s(n) becomes `|ra - rb| · |s(m)| · |s(n)| = |s(n) - s(m)|`.
-- With `K ≤ |s(m)|, |s(n)|`, the LHS factor is `≥ K · K`, and a
-- Cauchy bound on the original sequence at `ε · (K · K)` cancels
-- the K² to give the reciprocal sequence Cauchy at ε.
--
-- The cancellation step needs a strict-cancellation lemma
-- `Rational.LessThan.multiply_cancel_right`, which is proved
-- locally in this file via `Rational.LessOrEqual.linear` +
-- antisymmetry on the `y ≤ x` branch.

module Real.reciprocal

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.maximum
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.absolute_value
import Rational.triangle
import Rational.positive
import Rational.linearity
import Rational.reciprocal_function
import Real.sequence
import Real.basics
import Real.apartness

-- ----------------------------------------------------------------------
-- The reciprocal sequence: pointwise total reciprocal.
definition Real.reciprocal_sequence
        (underlyingSequence : Rational.sequence.Sequence)
        : Rational.sequence.Sequence :=
  (index : ℕ) ↦
    Rational.reciprocal_function(underlyingSequence(index))

-- ----------------------------------------------------------------------
-- Algebraic helper: the reciprocal-subtraction identity. For nonzero
-- `a, b`, the difference `1/a - 1/b` factors as `(b - a) * (1/a · 1/b)`.
-- Pure ring manipulation using `reciprocal_function_multiplies`.
theorem Rational.reciprocal_function_subtract_identity
        (a b : ℚ)
        (aNonzero : ¬(a = Rational.zero))
        (bNonzero : ¬(b = Rational.zero))
        : Rational.reciprocal_function(a) - Rational.reciprocal_function(b)
          = (b - a) * (Rational.reciprocal_function(a)
                           * Rational.reciprocal_function(b)) :=
  field(aNonzero, bNonzero)

-- ----------------------------------------------------------------------
-- Strict-multiplication right cancellation: if `x * c < y * c` and
-- `0 < c`, then `x < y`. Linearity supplies the case-split:
-- the `y ≤ x` branch combined with `multiply_by_nonneg_right` gives
-- `y * c ≤ x * c`, antisymmetric with `x * c ≤ y * c` from the
-- hypothesis — but `x * c ≠ y * c` from the strict hypothesis, so
-- this branch is absurd. The `x ≤ y` branch needs `x ≠ y`, which
-- follows from `x = y → x * c = y * c` contradicting the strict
-- hypothesis.
theorem Rational.LessThan.multiply_cancel_right
        (x y c : ℚ)
        (cPositive : Rational.zero < c)
        (xCLessThanYC : x * c < y * c)
        : x < y :=
  done by cases {
    case x ≤ y as xLeqY: {
        -- x ≤ y; and x ≠ y, since x = y would give x·c = y·c, contradicting x·c < y·c.
        x * c ≠ y * c as productDistinct;
        x ≠ y by (xEqY : x = y) ↦ {
            x * c = y * c as productEqual;
            productDistinct(productEqual)
          };
        done
      }
    case y ≤ x as yLeqX: {
        -- y·c ≤ x·c (multiply by c ≥ 0); antisymmetric with x·c ≤ y·c forces
        -- x·c = y·c, contradicting x·c < y·c.
        Rational.zero ≤ c;
        y * c ≤ x * c;
        x * c ≤ y * c;
        x * c = y * c by Rational.LessOrEqual.antisymmetric as productEqual;
        x * c ≠ y * c as productDistinct;
        absurd(productDistinct(productEqual))
      }
  }

-- ----------------------------------------------------------------------
-- The Cauchy proof. For `m, n ≥ max(apartnessIndex, cauchyIndex(ε · K²))`,
-- the identity |1/a − 1/b| = |b − a| / (|a| · |b|) plus |a|, |b| ≥ K
-- gives the bound |1/a − 1/b| ≤ |b − a| / K² < ε.
theorem Real.reciprocal_sequence_is_cauchy
        (underlyingSequence : Rational.sequence.Sequence)
        (underlyingIsCauchy
            : Rational.sequence.IsCauchy(underlyingSequence))
        (lowerBound : ℚ)
        (lowerBoundPositive : Rational.zero < lowerBound)
        (apartnessIndex : ℕ)
        (apartness
            : ∀ (m : ℕ). apartnessIndex ≤ m →
                lowerBound ≤ abs(
                                 underlyingSequence(m)))
        : Rational.sequence.IsCauchy(
              Real.reciprocal_sequence(underlyingSequence)) :=
  (ε : ℚ)
           (εPositive : Rational.zero < ε) ↦ {
    -- The scaled threshold ε · (K · K) is positive.
    Rational.zero < lowerBound * lowerBound;
    -- Apply Cauchy at ε · (K · K).
    choose cauchyIndex as cauchyAtScaledε
        from underlyingIsCauchy(
                 ε * (lowerBound * lowerBound),
                 (Rational.zero < ε * (lowerBound * lowerBound)));
    -- N := max(apartnessIndex, cauchyIndex). Both apartness and Cauchy
    -- apply beyond N.
    witness Natural.maximum(apartnessIndex, cauchyIndex) with
        (m : ℕ)
                 (NLeqM : Natural.maximum(apartnessIndex, cauchyIndex) ≤ m)
                 (n : ℕ)
                 (NLeqN : Natural.maximum(apartnessIndex, cauchyIndex) ≤ n) ↦
          {
            -- Index bookkeeping: apartnessIndex ≤ m, apartnessIndex ≤ n,
            -- cauchyIndex ≤ m, cauchyIndex ≤ n.
            apartnessIndex ≤ m;
            apartnessIndex ≤ n;
            cauchyIndex ≤ m as cauchyIndexLeqM;
            cauchyIndex ≤ n as cauchyIndexLeqN;
            -- Apartness applied at m, n.
            lowerBound
                ≤ abs(underlyingSequence(m));
            lowerBound
                ≤ abs(underlyingSequence(n));
            -- s(m), s(n) are nonzero (0 < lowerBound ≤ |s(·)|).
            Rational.zero < abs(underlyingSequence(m))
                by Rational.LessThan.transitive_right;
            Rational.zero < abs(underlyingSequence(n))
                by Rational.LessThan.transitive_right;
            underlyingSequence(m) ≠ Rational.zero
                by Rational.nonzero_of_absolute_value_positive as smNonzero;
            underlyingSequence(n) ≠ Rational.zero
                by Rational.nonzero_of_absolute_value_positive as snNonzero;
            -- The Cauchy bound: |s(n) - s(m)| < ε · (K · K).
            abs(
                  underlyingSequence(n) - underlyingSequence(m))
                < ε * (lowerBound * lowerBound)
              by cauchyAtScaledε(
                     n, cauchyIndexLeqN, m, cauchyIndexLeqM);
            -- (ra - rb) * (s(m) * s(n)) = s(n) - s(m) — a pure field identity
            -- in s(m), s(n) given nonzero. Anonymous: next calc consumes it
            -- by type-match.
            (Rational.reciprocal_function(underlyingSequence(m))
                 - Rational.reciprocal_function(underlyingSequence(n)))
                    * (underlyingSequence(m) * underlyingSequence(n))
                  = underlyingSequence(n) - underlyingSequence(m)
              by field(smNonzero, snNonzero);
            -- Take absolute value to get
            --   |ra - rb| * (|s(m)| * |s(n)|) = |s(n) - s(m)|.
            abs(
                  Rational.reciprocal_function(underlyingSequence(m))
                    - Rational.reciprocal_function(
                          underlyingSequence(n)))
                  * (abs(underlyingSequence(m))
                         * abs(
                               underlyingSequence(n)))
               = abs(
                     Rational.reciprocal_function(underlyingSequence(m))
                       - Rational.reciprocal_function(
                             underlyingSequence(n)))
                     * abs(
                           underlyingSequence(m)
                               * underlyingSequence(n))
               = abs(
                     (Rational.reciprocal_function(underlyingSequence(m))
                        - Rational.reciprocal_function(
                              underlyingSequence(n)))
                         * (underlyingSequence(m)
                                * underlyingSequence(n)))
               = abs(
                     underlyingSequence(n) - underlyingSequence(m));
            -- |ra - rb| ≥ 0 (absolute value).
            Rational.zero
                ≤ abs(
                      Rational.reciprocal_function(
                          underlyingSequence(m))
                        - Rational.reciprocal_function(
                              underlyingSequence(n)));
            -- K * K ≤ |s(m)| * |s(n)|. We have K ≤ |s(m)| and K ≤ |s(n)|.
            -- K * K ≤ |s(m)| * K  [multiply_by_nonneg_right with cNonneg = K ≥ 0]
            -- |s(m)| * K ≤ |s(m)| * |s(n)|  [multiply_by_nonneg_left with cNonneg = |s(m)| ≥ 0]
            Rational.LessOrEqual(Rational.zero, lowerBound);
            Rational.LessOrEqual(
                Rational.zero,
                abs(underlyingSequence(m)));
            lowerBound * lowerBound
                    ≤ abs(underlyingSequence(m)) * lowerBound
                    ≤ abs(underlyingSequence(m)) * abs(underlyingSequence(n));
            -- Combine the three steps in one chain:
            --   |ra - rb| · K² ≤ |ra - rb| · (|s(m)| · |s(n)|)   (mul by nonneg)
            --                  = |s(n) - s(m)|                    (absRecipScaledEquation)
            --                  < ε · K²                           (cauchyBound).
            abs(
                  Rational.reciprocal_function(underlyingSequence(m))
                    - Rational.reciprocal_function(
                          underlyingSequence(n)))
                  * (lowerBound * lowerBound)
                    ≤ abs(
                          Rational.reciprocal_function(underlyingSequence(m))
                            - Rational.reciprocal_function(
                                  underlyingSequence(n)))
                          * (abs(underlyingSequence(m))
                                 * abs(underlyingSequence(n)))
                    = abs(underlyingSequence(n) - underlyingSequence(m))
                    < ε * (lowerBound * lowerBound);
            -- Cancel (K · K) on both sides.
            -- The reciprocal sequence value at m equals
            -- reciprocal_function(s(m)), by Real.reciprocal_sequence's
            -- definition.
            done by Rational.LessThan.multiply_cancel_right
          }
  }

-- ----------------------------------------------------------------------
-- Package the reciprocal sequence with its Cauchy proof.
definition Real.reciprocal_cauchy_sequence
        (underlyingSequence : Rational.sequence.Sequence)
        (underlyingIsCauchy
            : Rational.sequence.IsCauchy(underlyingSequence))
        (lowerBound : ℚ)
        (lowerBoundPositive : Rational.zero < lowerBound)
        (apartnessIndex : ℕ)
        (apartness
            : (m : ℕ) → apartnessIndex ≤ m →
                lowerBound ≤ abs(
                                 underlyingSequence(m)))
        : CauchyRationalSequence :=
  CauchyRationalSequence.make(
      Real.reciprocal_sequence(underlyingSequence),
      Real.reciprocal_sequence_is_cauchy(
          underlyingSequence, underlyingIsCauchy,
          lowerBound, lowerBoundPositive,
          apartnessIndex, apartness))

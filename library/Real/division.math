-- Real/division.math
--
-- Division on the reals: `a / b := a · reciprocal(b)`. Unlike the
-- Rational `/` (built on the *total* reciprocal_function), `Real.reciprocal`
-- is partial — it takes the proof that the denominator is nonzero — so the
-- side condition is genuine. The `/` operator leaves it for the auto-prover
-- to discharge at the use site (a hypothesis in scope), mirroring
-- `Integer.divide` / `Rational.divide`, so `a / b` reads plainly while
-- staying honest. The lemmas keep `bNonzero` as a hypothesis so the `/`
-- hole resolves to that bound variable — a unifiable slot the citation
-- matcher binds to whatever proof a use site carries (this kernel has no
-- definitional proof irrelevance, and `Real.reciprocal` genuinely depends
-- on its proof argument via `Logic.the`, so a compound proof baked in
-- would not match across sites).

module Real.division

import Logic.basics
import Equality.basics
import Rational.basics
import Rational.order
import Rational.halve
import Rational.reciprocal_function
import Real.basics
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.order
import Real.linearity
import Real.order_multiplication
import Real.order_field
import Real.embedding
import Real.embedding_order
import Real.apartness
import Real.reciprocal
import Real.field

definition Real.divide (a b : ℝ) (denominatorNonzero : b ≠ 0) : ℝ :=
  a * Real.reciprocal(b, denominatorNonzero)

operator (/) on (Real, Real) := Real.divide

-- A product of nonzero reals is nonzero (no zero divisors): if a·b = 0 with
-- a ≠ 0, then b = reciprocal(a)·(a·b) = reciprocal(a)·0 = 0.
theorem Real.multiply_nonzero (a b : ℝ)
        (aNonzero : a ≠ 0) (bNonzero : b ≠ 0)
        : a * b ≠ 0 := {
  suppose a * b = 0 as abZero for contradiction {
    b
       = a⁻¹ * (a * b)
       = a⁻¹ * 0
       = 0                  as bZero;
    absurd(bNonzero(bZero))
  };
  done
}

-- Negation preserves nonzeroness: if -x were zero, x = -(-x) would be too.
automatic theorem Real.negate_nonzero (x : ℝ) (xNonzero : x ≠ 0)
        : -x ≠ 0 := {
  suppose -x = 0 as negateZero for contradiction {
    x
       = -(-x)
       = -(0 : ℝ)
       = 0                 as xZero;
    absurd(xNonzero(xZero))
  };
  done
}

-- Left cancellation: c ≠ 0 and c·a = c·b give a = b (multiply by c⁻¹).
theorem Real.equal_of_multiply_left (a b c : ℝ) (cNonzero : c ≠ 0)
        (cancellable : c * a = c * b) : a = b := {
  a
     = c⁻¹ * (c * a)
     = c⁻¹ * (c * b)
     = b
}

-- b · (a / b) = a — the cancellation everything else leans on.
theorem Real.divide_cancel (a b : ℝ) (bNonzero : b ≠ 0)
        : b * (a / b) = a :=
  field

-- a / a = 1.
theorem Real.divide_self (a : ℝ) (aNonzero : a ≠ 0)
        : a / a = 1 :=
  field

-- 0 < 1 in ℝ (the embedded Rational one, which is Real.one definitionally).
theorem Real.zero_less_one : (0 : ℝ) < 1 :=
  (0 : ℝ)
     < (Rational.one : ℝ)
     = 1

-- 0 < 2 = 1 + 1.
automatic theorem Real.two_positive : 0 < (2 : ℝ) := {
  (0 : ℝ) < 1;
  (0 : ℝ)
     = 0 + 0
     < 1 + 1
     = 2
}

-- 2 ≠ 0 — the side condition every `/2` use site discharges.
automatic theorem Real.two_is_nonzero : (2 : ℝ) ≠ 0 := {
  suppose (2 : ℝ) = Real.zero as twoZero;
  0 < (2 : ℝ);
  Real.zero < Real.zero;
  done
}

-- 0 < 4 = 2 + 2.
automatic theorem Real.four_positive : 0 < (4 : ℝ) := {
  0 < (2 : ℝ);
  (0 : ℝ)
     = 0 + 0
     < 2 + 2
     = 4
}

-- 4 ≠ 0 — the side condition every `/4` use site discharges.
automatic theorem Real.four_is_nonzero : (4 : ℝ) ≠ 0 := {
  suppose (4 : ℝ) = Real.zero as fourZero;
  0 < (4 : ℝ);
  Real.zero < Real.zero;
  done
}

-- A positive real is nonzero — the flip of LessThan.distinct the `/`
-- side conditions want.
automatic theorem Real.nonzero_of_positive (x : ℝ) (xPositive : 0 < x)
        : x ≠ 0 := {
  suppose x = 0 as xZero;
  Real.zero < Real.zero;
  done
}

-- x / 2 + x / 2 = x — the ε/2 split.
theorem Real.divide_two_doubled (x : ℝ) : x / 2 + x / 2 = x :=
  field

-- The reciprocal of a positive real is positive: if it were not, then
-- recip·x ≤ 0·x = 0, contradicting x·recip = 1 > 0.
theorem Real.reciprocal_positive (x : ℝ) (xNonzero : x ≠ 0)
        (xPositive : 0 < x)
        : 0 < Real.reciprocal(x, xNonzero) :=
  {
    suppose Real.reciprocal(x, xNonzero) ≤ 0 for contradiction {
        x * Real.reciprocal(x, xNonzero) = 1;
        0 ≤ x;
        Real.reciprocal(x, xNonzero) * x ≤ 0 * x;
        (1 : ℝ)
           = Real.reciprocal(x, xNonzero) * x
           ≤ 0 * x
           = 0;
        (0 : ℝ)
           < (Rational.one : ℝ)
           = 1;
        Real.zero < Real.zero by Real.LessThan.transitive_right;
        done
    };
    done by Real.LessThan_of_not_LessOrEqual
  }

-- a / b is positive when both a and b are.
theorem Real.divide_positive (a b : ℝ) (bNonzero : b ≠ 0)
        (aPositive : 0 < a) (bPositive : 0 < b)
        : 0 < a / b := {
  0 < Real.reciprocal(b, bNonzero);
  done by Real.multiply_positive
}

-- a / b is nonnegative when a is nonnegative and b is positive.
theorem Real.divide_nonneg (a b : ℝ) (bNonzero : b ≠ 0)
        (aNonneg : 0 ≤ a) (bPositive : 0 < b)
        : 0 ≤ a / b := {
  0 < Real.reciprocal(b, bNonzero);
  0 ≤ Real.reciprocal(b, bNonzero);
  Real.IsNonneg(a);
  Real.IsNonneg(Real.reciprocal(b, bNonzero));
  Real.IsNonneg(a * Real.reciprocal(b, bNonzero));
  done
}

-- The reciprocal of a nonzero real is nonzero: x·x⁻¹ = 1 would
-- otherwise be zero.
automatic theorem Real.reciprocal_nonzero (x : ℝ) (xNonzero : x ≠ 0)
        : Real.reciprocal(x, xNonzero) ≠ 0 := {
  suppose Real.reciprocal(x, xNonzero) = 0 as reciprocalZero for contradiction {
    Real.zero
       = x * Real.reciprocal(x, xNonzero)
       = Real.one           as zeroEqualsOne;
    absurd(Real.zero_not_equal_one(zeroEqualsOne))
  };
  done
}

-- a / b is nonzero when both a and b are.
automatic theorem Real.divide_nonzero (a b : ℝ) (bNonzero : b ≠ 0)
        (aNonzero : a ≠ 0)
        : a / b ≠ 0 := {
  Real.reciprocal(b, bNonzero) ≠ 0;
  done by Real.multiply_nonzero
}

-- Taking reciprocals reverses the order among positives: a ≤ b gives
-- 1/b ≤ 1/a. Multiply a ≤ b by the nonnegative (1/a)·(1/b) and cancel
-- each factor against its reciprocal.
theorem Real.one_divide_antitone (a b : ℝ)
        (aNonzero : a ≠ 0) (bNonzero : b ≠ 0)
        (aPositive : a > 0) (aLessOrEqualB : a ≤ b)
        : 1 / b ≤ 1 / a := {
  b > 0 by Real.LessThan.transitive_right;
  (1 : ℝ) > 0;
  1 / a > 0;
  1 / b > 0;
  (1 / a) * (1 / b) > 0;
  (1 / a) * (1 / b) ≥ 0;
  Real.IsNonneg((1 / a) * (1 / b));
  a * ((1 / a) * (1 / b)) ≤ b * ((1 / a) * (1 / b));
  1 / b
     = a * ((1 / a) * (1 / b))
     ≤ b * ((1 / a) * (1 / b))
     = 1 / a
}

-- The ℚ→ℝ boundary: a rational reciprocal casts to the honest real
-- division 1/x. Both multiply the cast of x to 1, and multiplication by
-- a nonzero real cancels. (Kept here, at the boundary, so analysis
-- modules upstream can speak honest `/` throughout.)
theorem Rational.to_real.reciprocal_preserves (x : ℚ)
        (xNonzero : x ≠ Rational.zero) (castNonzero : (x : ℝ) ≠ Real.zero)
        : ((Rational.reciprocal_function(x)) : ℝ) = 1 / (x : ℝ) := {
  x * Rational.reciprocal_function(x) = Rational.one;
  (x : ℝ) * ((Rational.reciprocal_function(x)) : ℝ)
     = ((x * Rational.reciprocal_function(x) : ℚ) : ℝ)
     = ((Rational.one : ℚ) : ℝ)
     = 1
     = (x : ℝ) * (1 / (x : ℝ));
  done
}

-- The embedded rational one-half is 1/2: both double to 1.
theorem Real.one_half_cast : (Rational.one_half : ℝ) = 1 / (2 : ℝ) := {
  (2 : ℝ) * (Rational.one_half : ℝ)
     = (1 + 1) * (Rational.one_half : ℝ)
     = (Rational.one_half : ℝ) + (Rational.one_half : ℝ)
     = ((Rational.one_half + Rational.one_half : ℚ) : ℝ)
     = ((Rational.one : ℚ) : ℝ)
           by Rational.one_half_doubled
     = 1;
  (2 : ℝ) * (1 / (2 : ℝ)) = 1;
  (2 : ℝ) * (Rational.one_half : ℝ)
     = 1
     = (2 : ℝ) * (1 / (2 : ℝ));
  done
}

-- x / 2 < x for positive x (the gap is the other half).
theorem Real.divide_two_less_than_self (x : ℝ) (xPositive : 0 < x)
        : x / 2 < x := {
  0 < (2 : ℝ);
  0 < x / 2;
  x / 2
     = x / 2 + 0
     < x / 2 + x / 2
     = x
}

-- (a · b) / b = a.
theorem Real.multiply_divide_cancel (a b : ℝ) (bNonzero : b ≠ 0)
        : (a * b) / b = a :=
  field

-- Scaling a reciprocal is division by the same denominator.
theorem Real.multiply_one_divide (a b : ℝ) (bNonzero : b ≠ 0)
        : a * (1 / b) = a / b :=
  a * (1 / b)
     = a * (1 * Real.reciprocal(b, bNonzero))
     = a * Real.reciprocal(b, bNonzero)
     = a / b

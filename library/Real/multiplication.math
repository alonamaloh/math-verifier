-- Real/multiplication.math
--
-- Real multiplication. The mathematically correct definition uses the
-- pointwise product of representative Cauchy sequences; the respect
-- proofs require `cauchy_is_bounded`, `Rational.absolute_value_multiplicative`,
-- and multiplicative order arithmetic — a substantial analytic stack.
--
-- As a placeholder (matching the p-adic convention in this codebase)
-- we use a degenerate `CauchyRationalSequence.multiply` that returns
-- its first argument unchanged. This makes the respect proofs
-- reflexive (or a direct application of x ≡ x'), and Real.multiply
-- collapses to projection onto its first argument. This is
-- mathematically wrong but typed-correct; replace with the real
-- definition when the analytic infrastructure (`cauchy_is_bounded`
-- etc.) lands.

module Real.multiplication

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.order
import Rational.absolute_value
import Real.sequence
import Real.basics
import Real.embedding

-- Placeholder: returns the first input unchanged. Replace with the
-- pointwise-product definition `make(λn. s(n)·t(n), product_is_cauchy)`
-- when `Rational.sequence.product_is_cauchy` is proved.
definition CauchyRationalSequence.multiply
        : CauchyRationalSequence → CauchyRationalSequence
          → CauchyRationalSequence
  | CauchyRationalSequence.make(s, sCauchy), _ =>
      CauchyRationalSequence.make(s, sCauchy)

-- mk(multiply(rep_x, rep_y)) = mk(rep_x) = mk(multiply(rep_x, rep_yPrime))
-- by reflexivity (after pattern-matching rep_x to expose the
-- CauchyRationalSequence.make constructor that triggers kernel
-- reduction of multiply).
theorem Real.multiply_after_first_respects
        : (rep_x rep_y rep_yPrime : CauchyRationalSequence)
          → CauchyEquivalent(rep_y, rep_yPrime)
          → Quotient.mk(CauchyRationalSequence, CauchyEquivalent,
                         CauchyRationalSequence.multiply(rep_x, rep_y))
            = Quotient.mk(CauchyRationalSequence, CauchyEquivalent,
                           CauchyRationalSequence.multiply(rep_x, rep_yPrime))
  | CauchyRationalSequence.make(s, sCauchy), rep_y, rep_yPrime, _ =>
      reflexivity(Real,
          Quotient.mk(CauchyRationalSequence, CauchyEquivalent,
                      CauchyRationalSequence.make(s, sCauchy)))

-- mk(rep_x) = mk(rep_xPrime) via Quotient.sound applied to xEquiv. The
-- lift β-reduces both sides through the constant function (since
-- multiply ignores its second argument). Pattern-match rep_x and
-- rep_xPrime to expose CauchyRationalSequence.make and trigger kernel
-- reduction.
theorem Real.multiply_respects
        : (rep_x rep_xPrime : CauchyRationalSequence)
          → CauchyEquivalent(rep_x, rep_xPrime)
          → (yReal : Real)
          → Quotient.lift(
                function (rep_y : CauchyRationalSequence) =>
                    Quotient.mk(CauchyRationalSequence, CauchyEquivalent,
                                 CauchyRationalSequence.multiply(rep_x, rep_y)),
                Real.multiply_after_first_respects(rep_x),
                yReal)
            = Quotient.lift(
                function (rep_y : CauchyRationalSequence) =>
                    Quotient.mk(CauchyRationalSequence, CauchyEquivalent,
                                 CauchyRationalSequence.multiply(rep_xPrime, rep_y)),
                Real.multiply_after_first_respects(rep_xPrime),
                yReal)
  | CauchyRationalSequence.make(s_x, sCauchy_x), rep_xPrime, xEquiv, yReal =>
      (cases rep_xPrime {
         | CauchyRationalSequence.make(s_xPrime, sCauchy_xPrime) =>
             function (refinedXEquiv
                          : CauchyEquivalent(
                                CauchyRationalSequence.make(s_x, sCauchy_x),
                                CauchyRationalSequence.make(s_xPrime, sCauchy_xPrime))) =>
               Quotient.induct(
                   function (y : Real) =>
                       Quotient.lift(
                           function (rep_y : CauchyRationalSequence) =>
                               Quotient.mk(CauchyRationalSequence, CauchyEquivalent,
                                            CauchyRationalSequence.multiply(
                                                CauchyRationalSequence.make(
                                                    s_x, sCauchy_x), rep_y)),
                           Real.multiply_after_first_respects(
                               CauchyRationalSequence.make(s_x, sCauchy_x)),
                           y)
                       = Quotient.lift(
                           function (rep_y : CauchyRationalSequence) =>
                               Quotient.mk(CauchyRationalSequence, CauchyEquivalent,
                                            CauchyRationalSequence.multiply(
                                                CauchyRationalSequence.make(
                                                    s_xPrime, sCauchy_xPrime), rep_y)),
                           Real.multiply_after_first_respects(
                               CauchyRationalSequence.make(s_xPrime, sCauchy_xPrime)),
                           y),
                   function (rep_y : CauchyRationalSequence) =>
                       Quotient.sound(
                           CauchyRationalSequence, CauchyEquivalent,
                           CauchyRationalSequence.make(s_x, sCauchy_x),
                           CauchyRationalSequence.make(s_xPrime, sCauchy_xPrime),
                           refinedXEquiv),
                   yReal)
       } : (refinedXEquiv : CauchyEquivalent(
                                CauchyRationalSequence.make(s_x, sCauchy_x),
                                rep_xPrime))
             → Quotient.lift(
                   function (rep_y : CauchyRationalSequence) =>
                       Quotient.mk(CauchyRationalSequence, CauchyEquivalent,
                                    CauchyRationalSequence.multiply(
                                        CauchyRationalSequence.make(
                                            s_x, sCauchy_x), rep_y)),
                   Real.multiply_after_first_respects(
                       CauchyRationalSequence.make(s_x, sCauchy_x)),
                   yReal)
               = Quotient.lift(
                   function (rep_y : CauchyRationalSequence) =>
                       Quotient.mk(CauchyRationalSequence, CauchyEquivalent,
                                    CauchyRationalSequence.multiply(
                                        rep_xPrime, rep_y)),
                   Real.multiply_after_first_respects(rep_xPrime),
                   yReal))(xEquiv)

definition Real.multiply_after_first
        (rep_x : CauchyRationalSequence) (yReal : Real) : Real :=
  Quotient.lift(
      function (rep_y : CauchyRationalSequence) =>
          Quotient.mk(CauchyRationalSequence, CauchyEquivalent,
                       CauchyRationalSequence.multiply(rep_x, rep_y)),
      Real.multiply_after_first_respects(rep_x),
      yReal)

definition Real.multiply (x y : Real) : Real :=
  Quotient.lift(
      function (rep_x : CauchyRationalSequence) =>
          Real.multiply_after_first(rep_x, y),
      function (rep_x rep_xPrime : CauchyRationalSequence)
               (xEquiv : CauchyEquivalent(rep_x, rep_xPrime)) =>
          Real.multiply_respects(rep_x, rep_xPrime, xEquiv, y),
      x)

operator (*) on (Real, Real) := Real.multiply

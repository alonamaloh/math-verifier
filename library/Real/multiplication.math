-- Real/multiplication.math
--
-- Real multiplication via the pointwise product of representative
-- Cauchy sequences. `product_is_cauchy` is the load-bearing analytic
-- proof: it uses `cauchy_is_naturally_bounded`,
-- `Rational.absolute_value_multiplicative`, the multiplicative order
-- arithmetic in `order_multiplication.math`, and the
-- `divide_by_succ_positive` construction. The respect proofs follow
-- the same pattern as Real.add_respects, with a single absolute-value
-- bound on the fixed side.

module Real.multiplication

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.maximum
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.triangle
import Rational.order_arithmetic
import Rational.order_multiplication
import Real.sequence
import Real.basics
import Real.embedding
import Real.cauchy_bounded

-- ----------------------------------------------------------------------
-- Algebraic helper: ab - cd = a(b-d) + d(a-c).

-- a * -b = -(a * b).
theorem Rational.multiply_negate_right (a b : Rational)
        : a * -b = -(a * b) :=
  calc a * -b
     = -b * a
     = -(a * b)

theorem Rational.product_difference_decomposition (a b c d : Rational)
        : a * b - c * d = a * (b - d) + d * (a - c) :=
  ring

-- ----------------------------------------------------------------------
-- The bound chain extracted as a separate theorem to keep the
-- existential-elimination chain in product_is_cauchy readable. Given
-- all bounds and Cauchy witnesses, conclude the product is bounded by
-- ε at indices m, n ≥ max of all the witness indices.
theorem Rational.sequence.product_is_cauchy_bound
        (s t : Rational.sequence.Sequence) (ε : Rational)
        (K_s K_t : Natural)
        (δ_s δ_t : Rational)
        (N_s_bound N_t_bound N_s N_t m n : Natural)
        (m_ge : max(max(N_s_bound, N_t_bound), max(N_s, N_t)) ≤ m)
        (n_ge : max(max(N_s_bound, N_t_bound), max(N_s, N_t)) ≤ n)
        (sBound : ∀ (m_arg : Natural). N_s_bound ≤ m_arg →
                    abs(s(m_arg))
                      ≤ ((K_s + 1) : Rational))
        (tBound : ∀ (n_arg : Natural). N_t_bound ≤ n_arg →
                    abs(t(n_arg))
                      ≤ ((K_t + 1) : Rational))
        (sCauchyAt : ∀ (m_arg : Natural). N_s ≤ m_arg →
                       ∀ (n_arg : Natural). N_s ≤ n_arg →
                         abs(s(m_arg) - s(n_arg))
                           < δ_s)
        (tCauchyAt : ∀ (m_arg : Natural). N_t ≤ m_arg →
                       ∀ (n_arg : Natural). N_t ≤ n_arg →
                         abs(t(m_arg) - t(n_arg))
                           < δ_t)
        (δ_s_props : Rational.zero < δ_s ∧ Rational.LessOrEqual(
                                 ((K_t + 1) : Rational) * δ_s,
                                 Rational.halve(Rational.halve(ε))))
        (δ_t_props : Rational.zero < δ_t ∧ Rational.LessOrEqual(
                                 ((K_s + 1) : Rational) * δ_t,
                                 Rational.halve(Rational.halve(ε))))
        (εPositive : Rational.zero < ε)
        : abs(s(m) * t(m) - s(n) * t(n)) < ε := {
  -- m, n ≥ N_s_bound, N_t_bound, N_s, N_t. Each projects m_ge / n_ge through
  -- the nested max; the prover backward-chains `le_through_max` to the bound.
  claim m_ge_N_s_bound : N_s_bound ≤ m by Natural.le_through_max_left;
  claim n_ge_N_t_bound : N_t_bound ≤ n by Natural.le_through_max_right;
  claim m_ge_N_s : N_s ≤ m by Natural.le_through_max_left;
  claim n_ge_N_s : N_s ≤ n by Natural.le_through_max_left;
  claim m_ge_N_t : N_t ≤ m by Natural.le_through_max_right;
  claim n_ge_N_t : N_t ≤ n by Natural.le_through_max_right;
  -- Specific bounds at m, n.
  claim abs(s(m)) ≤ ((K_s + 1) : Rational)
    by sBound(m, m_ge_N_s_bound);
  claim abs(t(n)) ≤ ((K_t + 1) : Rational)
    by tBound(n, n_ge_N_t_bound);
  claim abs(s(m) - s(n)) < δ_s
    by sCauchyAt(m, m_ge_N_s, n, n_ge_N_s);
  claim abs(t(m) - t(n)) < δ_t
    by tCauchyAt(m, m_ge_N_t, n, n_ge_N_t);
  claim abs(s(m) - s(n)) ≤ δ_s
    by Rational.LessThan.weaken;
  claim abs(t(m) - t(n)) ≤ δ_t
    by Rational.LessThan.weaken;
  claim ((K_t + 1) : Rational) * δ_s
          ≤ Rational.halve(Rational.halve(ε));
  claim ((K_s + 1) : Rational) * δ_t
          ≤ Rational.halve(Rational.halve(ε));
  claim abs(s(m) * (t(m) - t(n)) + t(n) * (s(m) - s(n))) ≤ abs(s(m) * (t(m) - t(n))) + abs(t(n) * (s(m) - s(n)))
    by Rational.triangle_inequality;
  claim abs(s(m)) * abs(t(m) - t(n)) ≤ ((K_s + 1) : Rational) * abs(t(m) - t(n))
    by Rational.LessOrEqual.multiply_by_nonneg_right;
  claim ((K_s + 1) : Rational) * abs(t(m) - t(n)) ≤ ((K_s + 1) : Rational) * δ_t
    by Rational.LessOrEqual.multiply_by_nonneg_left;
  claim abs(t(n)) * abs(s(m) - s(n)) ≤ ((K_t + 1) : Rational) * abs(s(m) - s(n))
    by Rational.LessOrEqual.multiply_by_nonneg_right;
  claim ((K_t + 1) : Rational) * abs(s(m) - s(n)) ≤ ((K_t + 1) : Rational) * δ_s
    by Rational.LessOrEqual.multiply_by_nonneg_left;
  calc abs(s(m) * (t(m) - t(n)))
     = abs(s(m)) * abs(t(m) - t(n))
     ≤ ((K_s + 1) : Rational) * abs(t(m) - t(n))
     ≤ ((K_s + 1) : Rational) * δ_t
     ≤ Rational.halve(Rational.halve(ε));
  calc abs(t(n) * (s(m) - s(n)))
     = abs(t(n)) * abs(s(m) - s(n))
     ≤ ((K_t + 1) : Rational) * abs(s(m) - s(n))
     ≤ ((K_t + 1) : Rational) * δ_s
     ≤ Rational.halve(Rational.halve(ε));
  calc abs(s(m) * (t(m) - t(n))) + abs(t(n) * (s(m) - s(n)))
     ≤ Rational.halve(Rational.halve(ε)) + Rational.halve(Rational.halve(ε))
     = Rational.halve(ε);
  -- Triangle on the regrouped form; then ≤ ε/2 by the two halves; then
  -- < ε by halve_less_than_self. All in one calc chain.
  calc abs(s(m) * t(m) - s(n) * t(n))
     = abs(s(m) * (t(m) - t(n)) + t(n) * (s(m) - s(n)))
     ≤ abs(s(m) * (t(m) - t(n))) + abs(t(n) * (s(m) - s(n)))
     ≤ Rational.halve(ε)
     < ε
}

-- ----------------------------------------------------------------------
-- product_is_cauchy: the load-bearing analytic proof.

theorem Rational.sequence.product_is_cauchy
        (s t : Rational.sequence.Sequence)
        (sIsCauchy : Rational.sequence.IsCauchy(s))
        (tIsCauchy : Rational.sequence.IsCauchy(t))
        : Rational.sequence.IsCauchy(
              (n : Natural) ↦ s(n) * t(n)) :=
  (ε : Rational)
           (εPositive : Rational.zero < ε) ↦ {
    -- `obtain` cannot infer these existentials through the opaque Rational,
    -- so each is stated top-down before destructuring.
    -- Step 1: bound |s| eventually by (succ K_s : R) starting from N_s_bound.
    claim sNaturallyBounded
        : ∃ (K : Natural). ∃ (N : Natural).
            ∀ (m : Natural). N ≤ m → abs(s(m)) ≤ ((K + 1) : Rational)
        by Rational.sequence.cauchy_is_naturally_bounded;
    choose K_s as sBoundedAtN_s from sNaturallyBounded;
    choose N_s_bound as sBound from sBoundedAtN_s;
    -- Step 2: similar for t.
    claim tNaturallyBounded
        : ∃ (K : Natural). ∃ (N : Natural).
            ∀ (m : Natural). N ≤ m → abs(t(m)) ≤ ((K + 1) : Rational)
        by Rational.sequence.cauchy_is_naturally_bounded;
    choose K_t as tBoundedAtN_t from tNaturallyBounded;
    choose N_t_bound as tBound from tBoundedAtN_t;
    -- Step 3: get δ_s and δ_t with (succ K_·) · δ ≤ ε/4. Both need ε/4 > 0.
    claim Rational.zero < Rational.halve(ε) by Rational.halve_positive;
    claim Rational.zero < Rational.halve(Rational.halve(ε)) by Rational.halve_positive;
    claim δSExists
        : ∃ (δ : Rational).
            Rational.zero < δ ∧ Rational.LessOrEqual(
                    ((K_t + 1) : Rational) * δ,
                    Rational.halve(Rational.halve(ε)))
        by Rational.divide_by_succ_positive;
    choose δ_s from δSExists;
    claim δ_s_pos : Rational.zero < δ_s;
    claim Rational.LessOrEqual(
              ((K_t + 1) : Rational) * δ_s,
              Rational.halve(Rational.halve(ε)));
    -- Step 4: get δ_t.
    claim δTExists
        : ∃ (δ : Rational).
            Rational.zero < δ ∧ Rational.LessOrEqual(
                    ((K_s + 1) : Rational) * δ,
                    Rational.halve(Rational.halve(ε)))
        by Rational.divide_by_succ_positive;
    choose δ_t from δTExists;
    claim δ_t_pos : Rational.zero < δ_t;
    claim Rational.LessOrEqual(
              ((K_s + 1) : Rational) * δ_t,
              Rational.halve(Rational.halve(ε)));
    -- Step 5: apply sCauchy(δ_s) and tCauchy(δ_t). State the existentials
    -- top-down: `choose` can't infer them through the opaque Rational.
    claim sCauchyBound
        : ∃ (N : Natural).
            ∀ (m : Natural). N ≤ m → ∀ (n : Natural). N ≤ n → abs(s(m) - s(n)) < δ_s
        by sIsCauchy(δ_s, δ_s_pos);
    choose N_s as sCauchyAt from sCauchyBound;
    claim tCauchyBound
        : ∃ (N : Natural).
            ∀ (m : Natural). N ≤ m → ∀ (n : Natural). N ≤ n → abs(t(m) - t(n)) < δ_t
        by tIsCauchy(δ_t, δ_t_pos);
    choose N_t as tCauchyAt from tCauchyBound;
    -- Final N := max(N_s_bound, N_t_bound, N_s, N_t).
    witness max(max(N_s_bound, N_t_bound), max(N_s, N_t)) with
        (m : Natural) (m_ge : max(max(N_s_bound, N_t_bound), max(N_s, N_t)) ≤ m)
        (n : Natural) (n_ge : max(max(N_s_bound, N_t_bound), max(N_s, N_t)) ≤ n) ↦
          Rational.sequence.product_is_cauchy_bound(
              K_s := K_s, K_t := K_t,
              δ_s := δ_s, δ_t := δ_t,
              N_s_bound := N_s_bound, N_t_bound := N_t_bound,
              N_s := N_s, N_t := N_t)
  }

-- The bound chain extracted as a separate theorem to keep the
-- existential-elimination chain above readable. Given all bounds and
-- Cauchy witnesses, conclude the product is bounded by ε at indices
-- m, n ≥ max of all the witness indices.


-- ----------------------------------------------------------------------
-- Restore CauchyRationalSequence.multiply and the Real-level lifts.

definition CauchyRationalSequence.multiply
        : CauchyRationalSequence → CauchyRationalSequence
          → CauchyRationalSequence
  | CauchyRationalSequence.make(s, sCauchy),
    CauchyRationalSequence.make(t, tCauchy) =>
      CauchyRationalSequence.make(
          (n : Natural) ↦ s(n) * t(n),
          Rational.sequence.product_is_cauchy(s, t, sCauchy, tCauchy))

-- Pointwise product of representatives, so rep-level proofs read `a * b`
-- instead of naming `.multiply`.
operator (*) on (CauchyRationalSequence, CauchyRationalSequence) := CauchyRationalSequence.multiply

-- sf(multiply(rep_x, rep_y), m) = sf(rep_x, m) * sf(rep_y, m).
automatic theorem CauchyRationalSequence.sequenceFunction_multiply
        : ∀ (rep_x rep_y : CauchyRationalSequence). ∀ (m : Natural).
            CauchyRationalSequence.sequenceFunction(
                rep_x * rep_y, m)
            = CauchyRationalSequence.sequenceFunction(rep_x, m)
              * CauchyRationalSequence.sequenceFunction(rep_y, m)
  | CauchyRationalSequence.make(sa, _),
    CauchyRationalSequence.make(sb, _),
    m =>
      reflexivity(Rational, sa(m) * sb(m))

-- Helper: a*b - a*c = a*(b - c) via distributivity_left + multiply_negate_right.
theorem Rational.factor_subtract_distribute (a b c : Rational)
        : a * b - a * c = a * (b - c) :=
  ring

-- The respect-proof inner chain: given the bound |s_x(m)| ≤ (succ K : R)
-- and the difference bound |s_y(m) - s_y'(m)| < δ, conclude
-- |s_x(m)*s_y(m) - s_x(m)*s_y'(m)| < ε via the (succ K)*δ ≤ halve(ε)
-- + halve_less_than_self chain.
theorem Real.multiply_respect_bound_chain
        (s_x s_y s_yPrime : Rational.sequence.Sequence)
        (ε : Rational) (K : Natural) (δ : Rational)
        (m : Natural)
        (s_x_at_m_bound : abs(s_x(m))
                            ≤ ((K + 1) : Rational))
        (s_y_diff_bound : abs(s_y(m) - s_yPrime(m))
                            < δ)
        (δ_bound : Rational.LessOrEqual(
                           ((K + 1) : Rational) * δ,
                           Rational.halve(ε)))
        (εPositive : Rational.zero < ε)
        : abs(s_x(m) * s_y(m) - s_x(m) * s_yPrime(m))
            < ε := {
  claim abs(s_y(m) - s_yPrime(m)) ≤ δ;
  claim abs(s_x(m))
            * abs(s_y(m) - s_yPrime(m))
          ≤ ((K + 1) : Rational)
            * abs(s_y(m) - s_yPrime(m))
    by Rational.LessOrEqual.multiply_by_nonneg_right;
  claim ((K + 1) : Rational)
            * abs(s_y(m) - s_yPrime(m))
          ≤ ((K + 1) : Rational) * δ
    by Rational.LessOrEqual.multiply_by_nonneg_left;
  -- Factor s_x(m) out; |·| splits multiplicatively; bound |s_x| by
  -- (K+1), then |s_y - s_yPrime| by δ; finally δ·(K+1) ≤ ε/2 < ε.
  calc abs(s_x(m) * s_y(m) - s_x(m) * s_yPrime(m))
     = abs(s_x(m) * (s_y(m) - s_yPrime(m)))
     = abs(s_x(m))
           * abs(s_y(m) - s_yPrime(m))
     ≤ ((K + 1) : Rational)
           * abs(s_y(m) - s_yPrime(m))
     ≤ ((K + 1) : Rational) * δ
     ≤ Rational.halve(ε)
     < ε
}

-- Helper: produce the CauchyEquivalent proof body for the at-rep
-- multiply respect. Given fixed s_x with a Natural bound, and yEquiv,
-- show the product sequences are CauchyEquivalent.
theorem Real.multiply_after_first_respects_at_rep_inner
        (s_x : Rational.sequence.Sequence)
        (sCauchy_x : Rational.sequence.IsCauchy(s_x))
        (s_y s_yPrime : Rational.sequence.Sequence)
        (sCauchy_y : Rational.sequence.IsCauchy(s_y))
        (sCauchy_yPrime : Rational.sequence.IsCauchy(s_yPrime))
        (refinedYEquiv : CauchyEquivalent(
                             CauchyRationalSequence.make(s_y, sCauchy_y),
                             CauchyRationalSequence.make(s_yPrime, sCauchy_yPrime)))
        (ε : Rational) (εPositive : Rational.zero < ε)
        : ∃ (N : Natural).
            ∀ (m : Natural). N ≤ m →
              abs(s_x(m) * s_y(m) - s_x(m) * s_yPrime(m))
                < ε := {
    claim xNaturallyBounded
        : ∃ (K : Natural). ∃ (N : Natural).
            ∀ (m : Natural). N ≤ m → abs(s_x(m)) ≤ ((K + 1) : Rational)
        by Rational.sequence.cauchy_is_naturally_bounded;
    choose K as xBoundedAtN from xNaturallyBounded;
    choose N_x_bound as xBound from xBoundedAtN;
    claim Rational.zero < Rational.halve(ε) by Rational.halve_positive;
    claim δExists
        : ∃ (δ : Rational).
            Rational.zero < δ ∧ Rational.LessOrEqual(
                    ((K + 1) : Rational) * δ, Rational.halve(ε))
        by Rational.divide_by_succ_positive;
    choose δ from δExists;
    claim δ_pos : Rational.zero < δ;
    claim Rational.LessOrEqual(((K + 1) : Rational) * δ, Rational.halve(ε));
    choose N_y as yEquivAt from refinedYEquiv(δ, δ_pos);
    witness max(N_x_bound, N_y) with
        (m : Natural) (m_ge_max : max(N_x_bound, N_y) ≤ m) ↦ {
          claim mGeNxBound : N_x_bound ≤ m by Natural.le_through_max_left;
          claim mGeNy : N_y ≤ m by Natural.le_through_max_right;
          claim abs(s_x(m)) ≤ ((K + 1) : Rational) by xBound(m, mGeNxBound);
          claim abs(s_y(m) - s_yPrime(m)) < δ by yEquivAt(m, mGeNy);
          claim abs(s_x(m) * s_y(m) - s_x(m) * s_yPrime(m)) < ε
              by Real.multiply_respect_bound_chain;
          done
        }
}

-- Respect of multiplication in the second argument: rep_x fixed, y
-- varies. Multi-pattern destructure on all three reps so the bound on
-- s_x is accessible (cauchy_is_naturally_bounded needs the underlying
-- sequence); the inner ε-N bound is supplied by _at_rep_inner.
theorem Real.multiply_respects_second
        : ∀ (rep_x rep_y rep_yPrime : CauchyRationalSequence).
            CauchyEquivalent(rep_y, rep_yPrime)
          → CauchyEquivalent(rep_x * rep_y, rep_x * rep_yPrime)
  | CauchyRationalSequence.make(s_x, sCauchy_x),
    CauchyRationalSequence.make(s_y, sCauchy_y),
    CauchyRationalSequence.make(s_yPrime, sCauchy_yPrime),
    refinedYEquiv =>
      (ε : Rational)
               (εPositive : Rational.zero < ε) ↦ {
        change ∃ (N : Natural). ∀ (m : Natural). N ≤ m →
                 abs(s_x(m) * s_y(m) - s_x(m) * s_yPrime(m)) < ε;
        done by Real.multiply_after_first_respects_at_rep_inner
      }

-- Symmetric inner-chain helper for multiply_respects_first: y is
-- bounded, x varies via xEquiv.
theorem Real.multiply_respects_at_rep_y_inner
        (s_x : Rational.sequence.Sequence)
        (sCauchy_x : Rational.sequence.IsCauchy(s_x))
        (s_xPrime : Rational.sequence.Sequence)
        (sCauchy_xPrime : Rational.sequence.IsCauchy(s_xPrime))
        (s_y : Rational.sequence.Sequence)
        (sCauchy_y : Rational.sequence.IsCauchy(s_y))
        (refinedXEquiv : CauchyEquivalent(
                             CauchyRationalSequence.make(s_x, sCauchy_x),
                             CauchyRationalSequence.make(s_xPrime, sCauchy_xPrime)))
        (ε : Rational) (εPositive : Rational.zero < ε)
        : ∃ (N : Natural).
            ∀ (m : Natural). N ≤ m →
              abs(s_x(m) * s_y(m) - s_xPrime(m) * s_y(m))
                < ε :=
  -- Reduce to multiply_after_first_respects_at_rep_inner with s_y as
  -- the "fixed" sequence (bounded) and x varying.
  {
    claim boundedYExists
        : ∃ (N : Natural).
            ∀ (m : Natural). N ≤ m →
              abs(s_y(m) * s_x(m) - s_y(m) * s_xPrime(m)) < ε
        by Real.multiply_after_first_respects_at_rep_inner;
    choose N as boundedY from boundedYExists;
    witness N with
        (m : Natural) (N_leq_m : N ≤ m) ↦
          calc abs(s_x(m) * s_y(m) - s_xPrime(m) * s_y(m))
             = abs(s_y(m) * s_x(m) - s_y(m) * s_xPrime(m))
             < ε
                  by boundedY(m, N_leq_m)
  }

-- Respect of multiplication in the first argument: symmetric to
-- _second but with the bound on the y-side. Multi-pattern destructure
-- on all three reps; inner ε-N bound supplied by _at_rep_y_inner.
theorem Real.multiply_respects_first
        : ∀ (rep_x rep_xPrime rep_y : CauchyRationalSequence).
            CauchyEquivalent(rep_x, rep_xPrime)
          → CauchyEquivalent(rep_x * rep_y, rep_xPrime * rep_y)
  | CauchyRationalSequence.make(s_x, sCauchy_x),
    CauchyRationalSequence.make(s_xPrime, sCauchy_xPrime),
    CauchyRationalSequence.make(s_y, sCauchy_y),
    refinedXEquiv =>
      (ε : Rational)
               (εPositive : Rational.zero < ε) ↦ {
        change ∃ (N : Natural). ∀ (m : Natural). N ≤ m →
                 abs(s_x(m) * s_y(m) - s_xPrime(m) * s_y(m)) < ε;
        done by Real.multiply_respects_at_rep_y_inner
      }

-- Real.multiply: multiply the representative sequences pointwise;
-- well-defined in each argument by the respect lemmas above.
definition Real.multiply : Real → Real → Real
  by representatives a, c ↦ (Quotient.class_of(a * c) : Real)
  well_defined by Real.multiply_respects_first, Real.multiply_respects_second

operator (*) on (Real, Real) := Real.multiply

-- ----------------------------------------------------------------------
-- The embedding preserves multiplication (mirror of
-- Rational.to_real.add_preserves): both sides are the constant
-- sequence λn. a·b, so the pointwise difference vanishes.
theorem Rational.to_real.multiply_preserves_equiv (a b : Rational)
        : CauchyEquivalent(
              Rational.to_cauchy_constant(a * b),
              CauchyRationalSequence.multiply(
                  Rational.to_cauchy_constant(a),
                  Rational.to_cauchy_constant(b))) :=
  (ε : Rational)
           (εPositive : Rational.zero < ε) ↦
    witness 0 with
        (m : Natural) (_ : 0 ≤ m) ↦
          calc abs(
                   CauchyRationalSequence.sequenceFunction(
                       Rational.to_cauchy_constant(a * b), m)
                   - CauchyRationalSequence.sequenceFunction(
                         CauchyRationalSequence.multiply(
                             Rational.to_cauchy_constant(a),
                             Rational.to_cauchy_constant(b)),
                         m))
             = abs((a * b) - (a * b))
             = Rational.zero
             < ε

theorem Rational.to_real.multiply_preserves (a b : Rational)
        : Rational.to_real(a * b)
          = Rational.to_real(a) * Rational.to_real(b) := {
  claim CauchyEquivalent(
            Rational.to_cauchy_constant(a * b),
            CauchyRationalSequence.multiply(
                Rational.to_cauchy_constant(a),
                Rational.to_cauchy_constant(b)))
      by Rational.to_real.multiply_preserves_equiv;
  done
}

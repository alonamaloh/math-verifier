-- Real/basics.math
--
-- Real numbers as equivalence classes of Cauchy sequences of
-- Rationals. The equivalence relation: two Cauchy sequences are
-- equivalent iff their pointwise difference converges to zero.

module Real.basics

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.maximum
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.triangle
import Rational.order_arithmetic
import Real.sequence

-- A Cauchy sequence packaged with its Cauchy-witness proof.
inductive CauchyRationalSequence : Type(0) where
  | CauchyRationalSequence.make
      : (sequenceFunction : Rational.sequence.Sequence)
          → Rational.sequence.IsCauchy(sequenceFunction)
        → CauchyRationalSequence

-- Extract the underlying sequence from a packaged CauchyRationalSequence.
definition CauchyRationalSequence.sequenceFunction
        : CauchyRationalSequence → Rational.sequence.Sequence
  | CauchyRationalSequence.make(s, _) => s

-- Two Cauchy sequences are equivalent when their pointwise difference
-- converges to zero: for every positive ε there exists N such that
-- beyond N, |s(m) - t(m)| < ε.
definition CauchyEquivalent
        (a b : CauchyRationalSequence) : Proposition :=
  ∀ (ε : Rational). Rational.zero < ε →
    ∃ (N : Natural).
      ∀ (m : Natural). N ≤ m →
        abs(
            CauchyRationalSequence.sequenceFunction(a, m)
            - CauchyRationalSequence.sequenceFunction(b, m))
          < ε

-- The Real numbers: equivalence classes of Cauchy rational sequences.
definition Real : Type(0) :=
  Quotient(CauchyRationalSequence, CauchyEquivalent)

-- The canonical introduction form: the real number represented by a
-- Cauchy rational sequence. A transparent `construction` (δ-reduces to
-- the underlying Quotient.class_of), so proofs read
-- `Real.from_cauchy_sequence(s, sCauchy)` instead of
-- `Quotient.class_of(CauchyRationalSequence.make(s, sCauchy))`.
construction Real.from_cauchy_sequence
        (sequenceFunction : Rational.sequence.Sequence)
        (cauchyProof : Rational.sequence.IsCauchy(sequenceFunction))
        : Real :=
  Quotient.class_of(CauchyRationalSequence.make(sequenceFunction, cauchyProof))

-- CauchyEquivalent is reflexive: |s(m) - s(m)| = 0 < ε.
theorem CauchyEquivalent.reflexive
        : ∀ (a : CauchyRationalSequence). CauchyEquivalent(a, a)
  | CauchyRationalSequence.make(s, sCauchy) =>
      (ε : Rational)
               (εPositive : Rational.zero < ε) ↦
        witness zero with
            (m : Natural) (_ : zero ≤ m) ↦
              abs(s(m) - s(m))
                 = Rational.zero
                 < ε

-- CauchyEquivalent is symmetric. Use the abstract
-- `sequenceFunction(...)` projector everywhere rather than
-- destructuring (multi-arg constructor pattern doesn't refine
-- through nested cases). Transport via |x - y| = |y - x|.
theorem CauchyEquivalent.symmetric
        (a b : CauchyRationalSequence)
        (aEquivb : CauchyEquivalent(a, b))
        : CauchyEquivalent(b, a) :=
  (ε : Rational)
           (εPositive : Rational.zero < ε) ↦ {
    choose N as aEquivb_at_N from aEquivb(ε, εPositive);
    witness N with
        (m : Natural) (N_leq_m : N ≤ m) ↦
          abs(
                   CauchyRationalSequence.sequenceFunction(b, m)
                   - CauchyRationalSequence.sequenceFunction(a, m))
             = abs(
                   CauchyRationalSequence.sequenceFunction(a, m)
                   - CauchyRationalSequence.sequenceFunction(b, m))
             < ε
                 by aEquivb_at_N(m, N_leq_m)
  }

-- Algebra helper: (a - b) + (b - c) = a - c.
theorem Rational.subtract_chain (a b c : Rational)
        : (a - b) + (b - c) = a - c := ring

-- CauchyEquivalent is transitive. Triangle inequality on the pointwise
-- differences, with ε/2 + ε/2 = ε threshold split.
theorem CauchyEquivalent.transitive
        (a b c : CauchyRationalSequence)
        (aEquivb : CauchyEquivalent(a, b))
        (bEquivc : CauchyEquivalent(b, c))
        : CauchyEquivalent(a, c) :=
  (ε : Rational)
           (εPositive : Rational.zero < ε) ↦ {
    choose N_ab as abBound
        from aEquivb(Rational.halve(ε),
                     Rational.halve_positive(ε, εPositive));
    choose N_bc as bcBound
        from bEquivc(Rational.halve(ε),
                     Rational.halve_positive(ε, εPositive));
    witness Natural.maximum(N_ab, N_bc) with
        (m : Natural)
                 (m_ge_max : Natural.maximum(N_ab, N_bc) ≤ m) ↦ {
          let sa : Rational := CauchyRationalSequence.sequenceFunction(a, m);
          let sb : Rational := CauchyRationalSequence.sequenceFunction(b, m);
          let sc : Rational := CauchyRationalSequence.sequenceFunction(c, m);
          N_ab ≤ m as mGeNab;
          N_bc ≤ m as mGeNbc;
          abs(sa - sb) < Rational.halve(ε) by abBound(m, mGeNab);
          abs(sb - sc) < Rational.halve(ε) by bcBound(m, mGeNbc);
          -- |a-c| = |(a-b)+(b-c)| ≤ |a-b|+|b-c| < ε/2 + ε/2 = ε.
          abs(sa - sc)
             = abs((sa - sb) + (sb - sc))
             ≤ abs(sa - sb) + abs(sb - sc)
             < Rational.halve(ε) + Rational.halve(ε)
             = ε
        }
  }

-- The Cauchy equivalence bundled as an `IsEquivalenceRelation`,
-- registered as the canonical instance for Real's quotient — so
-- `Quotient.equal_implies_equivalent(x, y, mkEquality)` recovers the three laws.
definition Real.equivalence
        : IsEquivalenceRelation(CauchyRationalSequence, CauchyEquivalent) := {
  CauchyEquivalent.reflexive;
  CauchyEquivalent.symmetric;
  CauchyEquivalent.transitive;
  done
}

instance Real.equivalence

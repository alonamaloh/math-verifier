-- Real/basics.math
--
-- Real numbers as equivalence classes of Cauchy sequences of
-- Rationals. The equivalence relation: two Cauchy sequences are
-- equivalent iff their pointwise difference converges to zero.

module Real.basics

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.maximum
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.triangle
import Rational.order_arithmetic
import Real.sequence

-- A Cauchy sequence packaged with its Cauchy-witness proof.
inductive CauchyRationalSequence : Type(0) where
  | CauchyRationalSequence.make
      : (sequenceFunction : Rational.sequence.Sequence)
        → Rational.sequence.IsCauchy(sequenceFunction)
        → CauchyRationalSequence

-- Extract the underlying sequence from a packaged CauchyRationalSequence.
definition CauchyRationalSequence.sequenceFunction
        : CauchyRationalSequence → Rational.sequence.Sequence
  | CauchyRationalSequence.make(s, _) => s

-- Two Cauchy sequences are equivalent when their pointwise difference
-- converges to zero: for every positive ε there exists N such that
-- beyond N, |s(m) - t(m)| < ε.
definition CauchyEquivalent
        (a b : CauchyRationalSequence) : Proposition :=
  (epsilon : Rational) → Rational.zero < epsilon →
    ∃ (N : Natural).
      (m : Natural) → N ≤ m →
        Rational.absolute_value(
            CauchyRationalSequence.sequenceFunction(a, m)
            - CauchyRationalSequence.sequenceFunction(b, m))
          < epsilon

-- The Real numbers: equivalence classes of Cauchy rational sequences.
definition Real : Type(0) :=
  Quotient(CauchyRationalSequence, CauchyEquivalent)

-- CauchyEquivalent is reflexive: |s(m) - s(m)| = 0 < ε.
theorem CauchyEquivalent.reflexive
        : (a : CauchyRationalSequence) → CauchyEquivalent(a, a)
  | CauchyRationalSequence.make(s, sCauchy) =>
      function (epsilon : Rational)
               (epsilonPositive : Rational.zero < epsilon) =>
        Exists.introduce(
            Natural,
            function (N : Natural) =>
              (m : Natural) → N ≤ m →
                Rational.absolute_value(s(m) - s(m)) < epsilon,
            zero,
            function (m : Natural) (_ : zero ≤ m) =>
              Equality.transport_proposition(
                  Rational,
                  function (x : Rational) =>
                      Rational.LessThan(x, epsilon),
                  Rational.zero,
                  Rational.absolute_value(s(m) - s(m)),
                  Equality.symmetry(
                      Rational.absolute_value_subtract_self(s(m))),
                  epsilonPositive))

-- CauchyEquivalent is symmetric. Use the abstract
-- `sequenceFunction(...)` projector everywhere rather than
-- destructuring (multi-arg constructor pattern doesn't refine
-- through nested cases). Transport via |x - y| = |y - x|.
theorem CauchyEquivalent.symmetric
        (a b : CauchyRationalSequence)
        (aEquivb : CauchyEquivalent(a, b))
        : CauchyEquivalent(b, a) :=
  function (epsilon : Rational)
           (epsilonPositive : Rational.zero < epsilon) =>
    Exists.eliminate(
        Natural,
        function (N : Natural) =>
          (m : Natural) → N ≤ m →
            Rational.absolute_value(
                CauchyRationalSequence.sequenceFunction(a, m)
                - CauchyRationalSequence.sequenceFunction(b, m))
              < epsilon,
        ∃ (N : Natural).
          (m : Natural) → N ≤ m →
            Rational.absolute_value(
                CauchyRationalSequence.sequenceFunction(b, m)
                - CauchyRationalSequence.sequenceFunction(a, m))
              < epsilon,
        function (N : Natural)
                 (aEquivb_at_N
                     : (m : Natural) → N ≤ m →
                       Rational.absolute_value(
                           CauchyRationalSequence.sequenceFunction(a, m)
                           - CauchyRationalSequence.sequenceFunction(b, m))
                         < epsilon) =>
          Exists.introduce(
              Natural,
              function (N' : Natural) =>
                (m : Natural) → N' ≤ m →
                  Rational.absolute_value(
                      CauchyRationalSequence.sequenceFunction(b, m)
                      - CauchyRationalSequence.sequenceFunction(a, m))
                    < epsilon,
              N,
              function (m : Natural) (N_leq_m : N ≤ m) =>
                Equality.transport_proposition(
                    Rational,
                    function (x : Rational) =>
                        Rational.LessThan(x, epsilon),
                    Rational.absolute_value(
                        CauchyRationalSequence.sequenceFunction(a, m)
                        - CauchyRationalSequence.sequenceFunction(b, m)),
                    Rational.absolute_value(
                        CauchyRationalSequence.sequenceFunction(b, m)
                        - CauchyRationalSequence.sequenceFunction(a, m)),
                    Rational.absolute_value_subtract_swap(
                        CauchyRationalSequence.sequenceFunction(a, m),
                        CauchyRationalSequence.sequenceFunction(b, m)),
                    aEquivb_at_N(m, N_leq_m))),
        aEquivb(epsilon, epsilonPositive))

-- Algebra helper: (a - b) + (b - c) = a - c.
theorem Rational.subtract_chain (a b c : Rational)
        : (a - b) + (b - c) = a - c :=
  calc (a - b) + (b - c)
     = (a + -b) + (b + -c)
     = a + (-b + (b + -c))
     = a + ((-b + b) + -c)
     = a + (Rational.zero + -c)
            by congruenceOf(
                   function (w : Rational) => a + (w + -c),
                   Rational.add_negate_left(b))
     = a + -c
            by congruenceOf(
                   function (w : Rational) => a + w,
                   Rational.zero_add(-c))
     = a - c

-- CauchyEquivalent is transitive. Triangle inequality on the pointwise
-- differences, with ε/2 + ε/2 = ε threshold split.
theorem CauchyEquivalent.transitive
        (a b c : CauchyRationalSequence)
        (aEquivb : CauchyEquivalent(a, b))
        (bEquivc : CauchyEquivalent(b, c))
        : CauchyEquivalent(a, c) :=
  function (epsilon : Rational)
           (epsilonPositive : Rational.zero < epsilon) =>
    Exists.eliminate(
        Natural,
        function (N_ab : Natural) =>
          (m : Natural) → N_ab ≤ m →
            Rational.absolute_value(
                CauchyRationalSequence.sequenceFunction(a, m)
                - CauchyRationalSequence.sequenceFunction(b, m))
              < Rational.halve(epsilon),
        ∃ (N : Natural).
          (m : Natural) → N ≤ m →
            Rational.absolute_value(
                CauchyRationalSequence.sequenceFunction(a, m)
                - CauchyRationalSequence.sequenceFunction(c, m))
              < epsilon,
        function (N_ab : Natural)
                 (abBound
                    : (m : Natural) → N_ab ≤ m →
                      Rational.absolute_value(
                          CauchyRationalSequence.sequenceFunction(a, m)
                          - CauchyRationalSequence.sequenceFunction(b, m))
                        < Rational.halve(epsilon)) =>
          Exists.eliminate(
              Natural,
              function (N_bc : Natural) =>
                (m : Natural) → N_bc ≤ m →
                  Rational.absolute_value(
                      CauchyRationalSequence.sequenceFunction(b, m)
                      - CauchyRationalSequence.sequenceFunction(c, m))
                    < Rational.halve(epsilon),
              ∃ (N : Natural).
                (m : Natural) → N ≤ m →
                  Rational.absolute_value(
                      CauchyRationalSequence.sequenceFunction(a, m)
                      - CauchyRationalSequence.sequenceFunction(c, m))
                    < epsilon,
              function (N_bc : Natural)
                       (bcBound
                          : (m : Natural) → N_bc ≤ m →
                            Rational.absolute_value(
                                CauchyRationalSequence.sequenceFunction(b, m)
                                - CauchyRationalSequence.sequenceFunction(c, m))
                              < Rational.halve(epsilon)) =>
                Exists.introduce(
                    Natural,
                    function (N : Natural) =>
                      (m : Natural) → N ≤ m →
                        Rational.absolute_value(
                            CauchyRationalSequence.sequenceFunction(a, m)
                            - CauchyRationalSequence.sequenceFunction(c, m))
                          < epsilon,
                    Natural.maximum(N_ab, N_bc),
                    function (m : Natural)
                             (m_ge_max : Natural.maximum(N_ab, N_bc) ≤ m) =>
                      Rational.LessThan.transitive_left(
                          Rational.absolute_value(
                              CauchyRationalSequence.sequenceFunction(a, m)
                              - CauchyRationalSequence.sequenceFunction(c, m)),
                          Rational.absolute_value(
                              CauchyRationalSequence.sequenceFunction(a, m)
                              - CauchyRationalSequence.sequenceFunction(b, m))
                              + Rational.absolute_value(
                                    CauchyRationalSequence.sequenceFunction(b, m)
                                    - CauchyRationalSequence.sequenceFunction(c, m)),
                          epsilon,
                          -- Step 1: ≤ via triangle + subtract_chain.
                          Equality.transport_proposition(
                              Rational,
                              function (w : Rational) =>
                                  Rational.LessOrEqual(
                                      w,
                                      Rational.absolute_value(
                                          CauchyRationalSequence.sequenceFunction(a, m)
                                          - CauchyRationalSequence.sequenceFunction(b, m))
                                          + Rational.absolute_value(
                                                CauchyRationalSequence.sequenceFunction(b, m)
                                                - CauchyRationalSequence.sequenceFunction(c, m))),
                              Rational.absolute_value(
                                  (CauchyRationalSequence.sequenceFunction(a, m)
                                   - CauchyRationalSequence.sequenceFunction(b, m))
                                  + (CauchyRationalSequence.sequenceFunction(b, m)
                                     - CauchyRationalSequence.sequenceFunction(c, m))),
                              Rational.absolute_value(
                                  CauchyRationalSequence.sequenceFunction(a, m)
                                  - CauchyRationalSequence.sequenceFunction(c, m)),
                              congruenceOf(
                                  Rational.absolute_value,
                                  Rational.subtract_chain(
                                      CauchyRationalSequence.sequenceFunction(a, m),
                                      CauchyRationalSequence.sequenceFunction(b, m),
                                      CauchyRationalSequence.sequenceFunction(c, m))),
                              Rational.triangle_inequality(
                                  CauchyRationalSequence.sequenceFunction(a, m)
                                  - CauchyRationalSequence.sequenceFunction(b, m),
                                  CauchyRationalSequence.sequenceFunction(b, m)
                                  - CauchyRationalSequence.sequenceFunction(c, m))),
                          -- Step 2: < via add_strict_strict + halve_doubled.
                          Equality.transport_proposition(
                              Rational,
                              function (w : Rational) =>
                                  Rational.LessThan(
                                      Rational.absolute_value(
                                          CauchyRationalSequence.sequenceFunction(a, m)
                                          - CauchyRationalSequence.sequenceFunction(b, m))
                                          + Rational.absolute_value(
                                                CauchyRationalSequence.sequenceFunction(b, m)
                                                - CauchyRationalSequence.sequenceFunction(c, m)),
                                      w),
                              Rational.halve(epsilon) + Rational.halve(epsilon),
                              epsilon,
                              Rational.halve_doubled(epsilon),
                              Rational.LessThan.add_strict_strict(
                                  Rational.absolute_value(
                                      CauchyRationalSequence.sequenceFunction(a, m)
                                      - CauchyRationalSequence.sequenceFunction(b, m)),
                                  Rational.absolute_value(
                                      CauchyRationalSequence.sequenceFunction(b, m)
                                      - CauchyRationalSequence.sequenceFunction(c, m)),
                                  Rational.halve(epsilon),
                                  abBound(m,
                                      LessOrEqual.transitive(
                                          N_ab, Natural.maximum(N_ab, N_bc), m,
                                          m_ge_max,
                                          Natural.left_le_max(N_ab, N_bc))),
                                  bcBound(m,
                                      LessOrEqual.transitive(
                                          N_bc, Natural.maximum(N_ab, N_bc), m,
                                          m_ge_max,
                                          Natural.right_le_max(N_ab, N_bc))))))),
              bEquivc(Rational.halve(epsilon),
                  Rational.halve_positive(epsilon, epsilonPositive))),
        aEquivb(Rational.halve(epsilon),
            Rational.halve_positive(epsilon, epsilonPositive)))

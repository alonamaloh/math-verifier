-- Real/ring.math
--
-- Ring laws for Real addition and negation: commutativity,
-- associativity, identity, additive inverse. Each reads as "pick
-- representatives with `by_representatives`, then prove the underlying
-- sequences agree at every index". Two helpers carry all the quotient
-- machinery so the laws never name it:
--   • `equivalent_when_sequenceFunction_equal` — pointwise-equal Cauchy
--     sequences are equivalent in the quotient;
--   • `Real.equal_of_pointwise_sequence` — therefore the two classes are
--     equal (the one place `Quotient.equivalent_implies_equal` appears).

module Real.ring

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation

-- ----------------------------------------------------------------------
-- Pointwise-equal Cauchy sequences are equivalent. With f(n) = g(n)
-- at every n, the difference f(n) - g(n) is identically Rational.zero,
-- whose absolute value is Rational.zero < ε. So N = 0 witnesses.
theorem CauchyRationalSequence.equivalent_when_sequenceFunction_equal
        (rep1 rep2 : CauchyRationalSequence)
        (pointwiseEq
            : ∀ (n : Natural).
                CauchyRationalSequence.sequenceFunction(rep1, n)
                = CauchyRationalSequence.sequenceFunction(rep2, n))
        : CauchyEquivalent(rep1, rep2) :=
  (epsilon : Rational)
           (epsilonPositive : Rational.zero < epsilon) ↦
    witness 0 with
        (m : Natural) (_ : 0 ≤ m) ↦
          -- |sf(rep1, m) - sf(rep2, m)| = |sf(rep2, m) - sf(rep2, m)|
          --   = Rational.zero < epsilon.
          calc abs(
                   CauchyRationalSequence.sequenceFunction(rep1, m)
                   - CauchyRationalSequence.sequenceFunction(rep2, m))
             = abs(
                   CauchyRationalSequence.sequenceFunction(rep2, m)
                   - CauchyRationalSequence.sequenceFunction(rep2, m))
                  by pointwiseEq(m)
             = Rational.zero
             < epsilon

-- ----------------------------------------------------------------------
-- Two Reals built from Cauchy sequences are equal when the sequences
-- agree pointwise. Packages the quotient soundness together with the
-- pointwise-difference bridge, so every ring law below reads as "pick
-- representatives, prove the sequences agree at each n" and never names
-- the quotient machinery directly.
theorem Real.equal_of_pointwise_sequence
        (rep1 rep2 : CauchyRationalSequence)
        (pointwiseEqual
            : ∀ (n : Natural).
                CauchyRationalSequence.sequenceFunction(rep1, n)
                = CauchyRationalSequence.sequenceFunction(rep2, n))
        : (Quotient.class_of(rep1) : Real) = Quotient.class_of(rep2) :=
  -- A proof of the equivalence where the class-equality is expected
  -- auto-wraps Quotient.equivalent_implies_equal (WS3 equality-of-classes
  -- coercion) — the one designated quotient-boundary point for the ring laws.
  CauchyRationalSequence.equivalent_when_sequenceFunction_equal(
      rep1, rep2, pointwiseEqual)

-- ----------------------------------------------------------------------
-- Add is commutative on Real. Pick representatives; the pointwise
-- equality is exactly Rational.add_commutative.
automatic theorem Real.add_commutative (x y : Real) : Real.add(x, y) = Real.add(y, x) :=
  by_representatives x as ⟨sx, sxCauchy⟩, y as ⟨sy, syCauchy⟩ => {
    claim ∀ (n : Natural). sx(n) + sy(n) = sy(n) + sx(n) by Rational.add_commutative;
    done since Real.equal_of_pointwise_sequence
  }

-- Add is associative on Real. Pick representatives; the pointwise
-- equality is Rational.add_associative.
theorem Real.add_associative (x y z : Real)
        : Real.add(Real.add(x, y), z) = Real.add(x, Real.add(y, z)) :=
  by_representatives x as ⟨sx, sxCauchy⟩, y as ⟨sy, syCauchy⟩,
                     z as ⟨sz, szCauchy⟩ => {
    claim ∀ (n : Natural).
        (sx(n) + sy(n)) + sz(n) = sx(n) + (sy(n) + sz(n)) by Rational.add_associative;
    done since Real.equal_of_pointwise_sequence
  }

-- 0 + x = x on Real. Use the constant-zero sequence for the zero.
theorem Real.zero_add
        (x : Real)
        : Real.add(Real.zero, x) = x :=
  cases x { | rep_x =>
    Real.equal_of_pointwise_sequence(
        CauchyRationalSequence.add(
            Rational.to_cauchy_constant(Rational.zero), rep_x),
        rep_x,
        (n : Natural) ↦
          calc CauchyRationalSequence.sequenceFunction(
                   CauchyRationalSequence.add(
                       Rational.to_cauchy_constant(Rational.zero),
                       rep_x), n)
             = Rational.zero + CauchyRationalSequence.sequenceFunction(rep_x, n)
             = CauchyRationalSequence.sequenceFunction(rep_x, n)) }

-- x + 0 = x via add_commutative + zero_add.
theorem Real.add_zero
        (x : Real)
        : Real.add(x, Real.zero) = x :=
  calc Real.add(x, Real.zero)
     = Real.add(Real.zero, x)
     = x

-- x + (-x) = 0 on Real.
theorem Real.add_negate_right
        (x : Real)
        : Real.add(x, Real.negate(x)) = Real.zero :=
  cases x { | rep_x =>
    Real.equal_of_pointwise_sequence(
        CauchyRationalSequence.add(
            rep_x, CauchyRationalSequence.negate(rep_x)),
        Rational.to_cauchy_constant(Rational.zero),
        (n : Natural) ↦
          calc CauchyRationalSequence.sequenceFunction(
                   CauchyRationalSequence.add(
                       rep_x, CauchyRationalSequence.negate(rep_x)), n)
             = CauchyRationalSequence.sequenceFunction(rep_x, n)
               + -CauchyRationalSequence.sequenceFunction(rep_x, n)
             = Rational.zero) }

-- (-x) + x = 0 via add_commutative + add_negate_right.
automatic theorem Real.add_negate_left
        (x : Real)
        : Real.add(Real.negate(x), x) = Real.zero :=
  calc Real.add(Real.negate(x), x)
     = Real.add(x, Real.negate(x))
     = Real.zero


-- -(-x) = x on Real. Lift the pointwise Rational.negate_negate.
theorem Real.negate_negate (x : Real) : Real.negate(Real.negate(x)) = x :=
  cases x { | rep_x =>
    Real.equal_of_pointwise_sequence(
        CauchyRationalSequence.negate(CauchyRationalSequence.negate(rep_x)),
        rep_x,
        (n : Natural) ↦
          calc CauchyRationalSequence.sequenceFunction(
                   CauchyRationalSequence.negate(
                       CauchyRationalSequence.negate(rep_x)), n)
             = -(-CauchyRationalSequence.sequenceFunction(rep_x, n))
             = CauchyRationalSequence.sequenceFunction(rep_x, n)) }

-- -(x + y) = -x + -y on Real. Pick representatives; pointwise it is
-- Rational.negate_add.
theorem Real.negate_add (x y : Real) : -(x + y) = -x + -y :=
  by_representatives x as ⟨sx, sxCauchy⟩, y as ⟨sy, syCauchy⟩ => {
    claim ∀ (n : Natural). -(sx(n) + sy(n)) = -sx(n) + -sy(n) by Rational.negate_add;
    done since Real.equal_of_pointwise_sequence
  }

-- The Rational → Real embedding is a homomorphism of addition:
-- (a + b : Real) = (a : Real) + (b : Real). At rep level the LHS is
-- mk(const_(a+b)) and the RHS is mk(add(const_a, const_b));
-- pointwise both sides give a + b at every index.
theorem Rational.to_real_add (a b : Rational)
        : ((a + b) : Real) = a + b := {
  claim ∀ (n : Natural).
      CauchyRationalSequence.sequenceFunction(Rational.to_cauchy_constant(a + b), n)
      = CauchyRationalSequence.sequenceFunction(
            Rational.to_cauchy_constant(a) + Rational.to_cauchy_constant(b), n)
    by (n : Natural) ↦
      -- sf(const_(a+b), n) = a+b = sf(const_a,n) + sf(const_b,n)
      --                         = sf(const_a + const_b, n).
      calc CauchyRationalSequence.sequenceFunction(
               Rational.to_cauchy_constant(a + b), n)
         = a + b
         = CauchyRationalSequence.sequenceFunction(Rational.to_cauchy_constant(a), n)
           + CauchyRationalSequence.sequenceFunction(Rational.to_cauchy_constant(b), n)
         = CauchyRationalSequence.sequenceFunction(
               Rational.to_cauchy_constant(a) + Rational.to_cauchy_constant(b), n)
               since CauchyRationalSequence.sequenceFunction_add;
  done
}

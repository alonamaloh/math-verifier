-- Real/ring.math
--
-- Ring laws for Real addition and negation: commutativity,
-- associativity, identity, additive inverse. Each lifts from the
-- corresponding pointwise Rational law via Quotient.induct (or
-- Quotient.induct_two) plus a single helper:
-- `CauchyRationalSequence.equivalent_when_sequenceFunction_equal`,
-- which says that if two Cauchy rational sequences have pointwise-
-- equal sequenceFunctions, they're equivalent in the quotient.

module Real.ring

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation

-- ----------------------------------------------------------------------
-- Pointwise-equal Cauchy sequences are equivalent. With f(n) = g(n)
-- at every n, the difference f(n) - g(n) is identically Rational.zero,
-- whose absolute value is Rational.zero < ε. So N = 0 witnesses.
theorem CauchyRationalSequence.equivalent_when_sequenceFunction_equal
        (rep1 rep2 : CauchyRationalSequence)
        (pointwiseEq
            : (n : Natural)
              → CauchyRationalSequence.sequenceFunction(rep1, n)
                = CauchyRationalSequence.sequenceFunction(rep2, n))
        : CauchyEquivalent(rep1, rep2) :=
  function (epsilon : Rational)
           (epsilonPositive : Rational.zero < epsilon) =>
    witness 0 with
        function (m : Natural) (_ : 0 ≤ m) =>
          -- |sf(rep1, m) - sf(rep2, m)|
          --   = |sf(rep2, m) - sf(rep2, m)|     [pointwiseEq congruence]
          --   = Rational.zero                    [absolute_value_subtract_self]
          rewrite(
              Equality.symmetry(
                  calc abs(
                           CauchyRationalSequence.sequenceFunction(rep1, m)
                           - CauchyRationalSequence.sequenceFunction(rep2, m))
                     = abs(
                           CauchyRationalSequence.sequenceFunction(rep2, m)
                           - CauchyRationalSequence.sequenceFunction(rep2, m))
                            by pointwiseEq(m)
                     = Rational.zero),
              epsilonPositive)

-- ----------------------------------------------------------------------
-- Add is commutative on Real.

-- At constructor reps: pattern-matching exposes the underlying sequences
-- so add and sequenceFunction reduce, and the pointwise equality is
-- exactly Rational.add_commutative.
theorem Real.add_commutative_at_make
        : (rep_x rep_y : CauchyRationalSequence)
          → Real.add((Quotient.mk(rep_x) : Real), (Quotient.mk(rep_y) : Real))
            = Real.add((Quotient.mk(rep_y) : Real), (Quotient.mk(rep_x) : Real))
  | CauchyRationalSequence.make(sx, sx_cauchy),
    CauchyRationalSequence.make(sy, sy_cauchy) =>
      Quotient.sound(
          CauchyRationalSequence.add(
              CauchyRationalSequence.make(sx, sx_cauchy),
              CauchyRationalSequence.make(sy, sy_cauchy)),
          CauchyRationalSequence.add(
              CauchyRationalSequence.make(sy, sy_cauchy),
              CauchyRationalSequence.make(sx, sx_cauchy)),
          CauchyRationalSequence.equivalent_when_sequenceFunction_equal(
              CauchyRationalSequence.add(
                  CauchyRationalSequence.make(sx, sx_cauchy),
                  CauchyRationalSequence.make(sy, sy_cauchy)),
              CauchyRationalSequence.add(
                  CauchyRationalSequence.make(sy, sy_cauchy),
                  CauchyRationalSequence.make(sx, sx_cauchy)),
              function (n : Natural) =>
                Rational.add_commutative(sx(n), sy(n))))

theorem Real.add_commutative
        (x y : Real)
        : Real.add(x, y) = Real.add(y, x) :=
  Quotient.induct_two(
      function (xArg yArg : Real) =>
          Real.add(xArg, yArg) = Real.add(yArg, xArg),
      Real.add_commutative_at_make,
      x, y)

-- Add is associative on Real. At constructor reps, all the bridge
-- proofs reduce away and the pointwise equality is Rational.add_associative.
theorem Real.add_associative_at_make
        : (rep_x rep_y rep_z : CauchyRationalSequence)
          → Real.add(
                Real.add((Quotient.mk(rep_x) : Real), (Quotient.mk(rep_y) : Real)),
                (Quotient.mk(rep_z) : Real))
            = Real.add(
                  (Quotient.mk(rep_x) : Real),
                  Real.add((Quotient.mk(rep_y) : Real), (Quotient.mk(rep_z) : Real)))
  | CauchyRationalSequence.make(sx, sx_cauchy),
    CauchyRationalSequence.make(sy, sy_cauchy),
    CauchyRationalSequence.make(sz, sz_cauchy) =>
      Quotient.sound(
          CauchyRationalSequence.add(
              CauchyRationalSequence.add(
                  CauchyRationalSequence.make(sx, sx_cauchy),
                  CauchyRationalSequence.make(sy, sy_cauchy)),
              CauchyRationalSequence.make(sz, sz_cauchy)),
          CauchyRationalSequence.add(
              CauchyRationalSequence.make(sx, sx_cauchy),
              CauchyRationalSequence.add(
                  CauchyRationalSequence.make(sy, sy_cauchy),
                  CauchyRationalSequence.make(sz, sz_cauchy))),
          CauchyRationalSequence.equivalent_when_sequenceFunction_equal(
              CauchyRationalSequence.add(
                  CauchyRationalSequence.add(
                      CauchyRationalSequence.make(sx, sx_cauchy),
                      CauchyRationalSequence.make(sy, sy_cauchy)),
                  CauchyRationalSequence.make(sz, sz_cauchy)),
              CauchyRationalSequence.add(
                  CauchyRationalSequence.make(sx, sx_cauchy),
                  CauchyRationalSequence.add(
                      CauchyRationalSequence.make(sy, sy_cauchy),
                      CauchyRationalSequence.make(sz, sz_cauchy))),
              function (n : Natural) =>
                Rational.add_associative(sx(n), sy(n), sz(n))))

theorem Real.add_associative
        (x y z : Real)
        : Real.add(Real.add(x, y), z) = Real.add(x, Real.add(y, z)) :=
  Quotient.induct_three(
      function (xArg yArg zArg : Real) =>
          Real.add(Real.add(xArg, yArg), zArg) = Real.add(xArg, Real.add(yArg, zArg)),
      Real.add_associative_at_make,
      x, y, z)

-- 0 + x = x on Real. Use the constant-zero sequence for the zero.
theorem Real.zero_add
        (x : Real)
        : Real.add(Real.zero, x) = x :=
  Quotient.induct(
      function (xArg : Real) =>
          Real.add(Real.zero, xArg) = xArg,
      function (rep_x : CauchyRationalSequence) =>
        Quotient.sound(
            CauchyRationalSequence, CauchyEquivalent,
            CauchyRationalSequence.add(
                Rational.to_cauchy_constant(Rational.zero), rep_x),
            rep_x,
            CauchyRationalSequence.equivalent_when_sequenceFunction_equal(
                CauchyRationalSequence.add(
                    Rational.to_cauchy_constant(Rational.zero), rep_x),
                rep_x,
                function (n : Natural) =>
                  calc CauchyRationalSequence.sequenceFunction(
                           CauchyRationalSequence.add(
                               Rational.to_cauchy_constant(Rational.zero),
                               rep_x), n)
                     = CauchyRationalSequence.sequenceFunction(
                           Rational.to_cauchy_constant(Rational.zero), n)
                       + CauchyRationalSequence.sequenceFunction(rep_x, n)
                     = Rational.zero
                       + CauchyRationalSequence.sequenceFunction(rep_x, n)
                     = CauchyRationalSequence.sequenceFunction(rep_x, n))),
      x)

-- x + 0 = x via add_commutative + zero_add.
theorem Real.add_zero
        (x : Real)
        : Real.add(x, Real.zero) = x :=
  calc Real.add(x, Real.zero)
     = Real.add(Real.zero, x)
     = x

-- x + (-x) = 0 on Real.
theorem Real.add_negate_right
        (x : Real)
        : Real.add(x, Real.negate(x)) = Real.zero :=
  Quotient.induct(
      function (xArg : Real) =>
          Real.add(xArg, Real.negate(xArg)) = Real.zero,
      function (rep_x : CauchyRationalSequence) =>
        Quotient.sound(
            CauchyRationalSequence, CauchyEquivalent,
            CauchyRationalSequence.add(
                rep_x, CauchyRationalSequence.negate(rep_x)),
            Rational.to_cauchy_constant(Rational.zero),
            CauchyRationalSequence.equivalent_when_sequenceFunction_equal(
                CauchyRationalSequence.add(
                    rep_x, CauchyRationalSequence.negate(rep_x)),
                Rational.to_cauchy_constant(Rational.zero),
                function (n : Natural) =>
                  calc CauchyRationalSequence.sequenceFunction(
                           CauchyRationalSequence.add(
                               rep_x,
                               CauchyRationalSequence.negate(rep_x)), n)
                     = CauchyRationalSequence.sequenceFunction(rep_x, n)
                       + CauchyRationalSequence.sequenceFunction(
                             CauchyRationalSequence.negate(rep_x), n)
                     = CauchyRationalSequence.sequenceFunction(rep_x, n)
                       + -CauchyRationalSequence.sequenceFunction(rep_x, n)
                     = Rational.zero)),
      x)

-- (-x) + x = 0 via add_commutative + add_negate_right.
theorem Real.add_negate_left
        (x : Real)
        : Real.add(Real.negate(x), x) = Real.zero :=
  calc Real.add(Real.negate(x), x)
     = Real.add(x, Real.negate(x))
     = Real.zero


-- -(-x) = x on Real. Lift the pointwise Rational.negate_negate.
theorem Real.negate_negate (x : Real) : Real.negate(Real.negate(x)) = x :=
  Quotient.induct(
      function (xArg : Real) => Real.negate(Real.negate(xArg)) = xArg,
      function (rep_x : CauchyRationalSequence) =>
        Quotient.sound(
            CauchyRationalSequence, CauchyEquivalent,
            CauchyRationalSequence.negate(
                CauchyRationalSequence.negate(rep_x)),
            rep_x,
            CauchyRationalSequence.equivalent_when_sequenceFunction_equal(
                CauchyRationalSequence.negate(
                    CauchyRationalSequence.negate(rep_x)),
                rep_x,
                function (n : Natural) =>
                  -- sf(neg(neg(rep_x)), n) = -sf(neg(rep_x), n) = -(-sf(rep_x, n))
                  --                        = sf(rep_x, n) by Rational.negate_negate.
                  calc CauchyRationalSequence.sequenceFunction(
                           CauchyRationalSequence.negate(
                               CauchyRationalSequence.negate(rep_x)), n)
                     = -CauchyRationalSequence.sequenceFunction(
                            CauchyRationalSequence.negate(rep_x), n)
                     = -(-CauchyRationalSequence.sequenceFunction(rep_x, n))
                     = CauchyRationalSequence.sequenceFunction(rep_x, n))),
      x)

-- -(x + y) = -x + -y on Real. Lift the pointwise Rational.negate_add via
-- Quotient.induct_two; the at-make form pattern-matches both reps so
-- every sequenceFunction reduces.
theorem Real.negate_add_at_make
        : (rep_x rep_y : CauchyRationalSequence)
          → Real.negate(
                Real.add((Quotient.mk(rep_x) : Real),
                         (Quotient.mk(rep_y) : Real)))
            = Real.add(Real.negate((Quotient.mk(rep_x) : Real)),
                       Real.negate((Quotient.mk(rep_y) : Real)))
  | CauchyRationalSequence.make(sx, sx_cauchy),
    CauchyRationalSequence.make(sy, sy_cauchy) =>
      Quotient.sound(
          CauchyRationalSequence.negate(
              CauchyRationalSequence.add(
                  CauchyRationalSequence.make(sx, sx_cauchy),
                  CauchyRationalSequence.make(sy, sy_cauchy))),
          CauchyRationalSequence.add(
              CauchyRationalSequence.negate(
                  CauchyRationalSequence.make(sx, sx_cauchy)),
              CauchyRationalSequence.negate(
                  CauchyRationalSequence.make(sy, sy_cauchy))),
          CauchyRationalSequence.equivalent_when_sequenceFunction_equal(
              CauchyRationalSequence.negate(
                  CauchyRationalSequence.add(
                      CauchyRationalSequence.make(sx, sx_cauchy),
                      CauchyRationalSequence.make(sy, sy_cauchy))),
              CauchyRationalSequence.add(
                  CauchyRationalSequence.negate(
                      CauchyRationalSequence.make(sx, sx_cauchy)),
                  CauchyRationalSequence.negate(
                      CauchyRationalSequence.make(sy, sy_cauchy))),
              function (n : Natural) =>
                Rational.negate_add(sx(n), sy(n))))

theorem Real.negate_add (x y : Real) : -(x + y) = -x + -y :=
  Quotient.induct_two(
      function (xArg yArg : Real) => -(xArg + yArg) = -xArg + -yArg,
      Real.negate_add_at_make,
      x, y)

-- The Rational → Real embedding is a homomorphism of addition:
-- (a + b : Real) = (a : Real) + (b : Real). At rep level the LHS is
-- mk(const_(a+b)) and the RHS is mk(add(const_a, const_b));
-- pointwise both sides give a + b at every index.
theorem Rational.to_real_add (a b : Rational)
        : ((a + b) : Real) = (a : Real) + (b : Real) :=
  Quotient.sound(
      CauchyRationalSequence, CauchyEquivalent,
      Rational.to_cauchy_constant(a + b),
      CauchyRationalSequence.add(
          Rational.to_cauchy_constant(a),
          Rational.to_cauchy_constant(b)),
      CauchyRationalSequence.equivalent_when_sequenceFunction_equal(
          Rational.to_cauchy_constant(a + b),
          CauchyRationalSequence.add(
              Rational.to_cauchy_constant(a),
              Rational.to_cauchy_constant(b)),
          function (n : Natural) =>
            -- sf(const_(a+b), n) = a + b
            -- sf(add(const_a, const_b), n) = sf(const_a, n) + sf(const_b, n)
            --                              = a + b
            Equality.symmetry(
                CauchyRationalSequence.sequenceFunction_add(
                    Rational.to_cauchy_constant(a),
                    Rational.to_cauchy_constant(b),
                    n))))

-- Real/ring_bundle.math
--
-- ℝ as a bundled `Ring` and `CommutativeRing`. Bundling ℝ here (rather
-- than up in `ComplexNumber/`) lets the generic ring development —
-- `Ring.Sum`, `Ring.power`, the commutative-ring binomial theorem — apply
-- to ℝ, so `Real.binomial_theorem` is an instance of the generic one.

module Real.ring_bundle

import Logic.basics
import Equality.basics
import Algebra.ring
import Algebra.ring_bundle
import Algebra.commutative_ring_bundle
import Real.basics
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.instances

-- ℝ as a bundled ring.
definition Real.ring : Ring :=
  Ring.make(ℝ, Real.add, Real.zero, Real.negate, Real.multiply, Real.one,
      Real.is_ring)

-- Canonical `Ring` for the carrier `Real`: lets `{r : Ring}` resolve from a
-- concrete `Real` / `Polynomial(Real, …)` operand so the ring/polynomial
-- operators dispatch at the concrete spelling.
instance Real.ring

-- ℝ as a bundled commutative ring (the commutativity witness is exactly
-- `Real.multiply_commutative`, defeq through the `Ring.make` projections).
definition Real.commutative_ring : CommutativeRing :=
  CommutativeRing.make(Real.ring, Real.multiply_commutative)

-- Real/cauchy_bounded.math
--
-- Cauchy sequences are eventually bounded by a Natural-image Rational.
-- Apply the Cauchy condition with ε = 1 to get N; beyond N, |s(m)| is
-- within 1 of |s(N)|, and |s(N)| has a Natural bound (Archimedean).

module Real.cauchy_bounded

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.order_arithmetic
import Rational.triangle
import Rational.order_multiplication
import Real.sequence

-- ----------------------------------------------------------------------
-- Algebraic helper.

-- (succ K : I) + 1 = (succ (succ K) : I).
theorem Integer.succ_natural_plus_one (K : Natural)
        : (successor(K) : Integer) + Integer.one
          = (successor(successor(K)) : Integer) :=
  calc (successor(K) : Integer) + Integer.one
     = (successor(K) : Integer) + (successor(zero) : Integer)
     = ((successor(K) + successor(zero)) : Integer)
     = (successor(successor(K)) : Integer)
            by congruenceOf(Natural.to_integer,
                   calc successor(K) + successor(zero)
                      = successor(successor(K) + zero)
                      = successor(successor(K)))

-- (succ K : R) + 1 = (succ (succ K) : R) at Rational. Quotient.sound
-- bridges the small denominator discrepancy (0 + 0 vs 0).
theorem Rational.succ_natural_plus_one (K : Natural)
        : (successor(K) : Rational) + Rational.one
          = (successor(successor(K)) : Rational) :=
  Quotient.sound(
      RationalRepresentative.make(
          (successor(K) : Integer) * (successor(zero) : Integer)
              + Integer.one * (successor(zero) : Integer),
          zero + zero * successor(zero)),
      RationalRepresentative.make(
          (successor(successor(K)) : Integer), zero),
      -- Cross: LHS_num · succ(0) = (succ (succ K) : I) · succ(0 + 0·s(0)).
      -- Both reduce to (succ (succ K) : I) after Integer arithmetic.
      calc ((successor(K) : Integer) * (successor(zero) : Integer)
            + Integer.one * (successor(zero) : Integer))
              * (successor(zero) : Integer)
         = ((successor(K) : Integer) + Integer.one)
              * (successor(zero) : Integer)
                by congruenceOf(
                       function (z : Integer) =>
                           z * (successor(zero) : Integer),
                       calc (successor(K) : Integer)
                                * (successor(zero) : Integer)
                            + Integer.one * (successor(zero) : Integer)
                          = (successor(K) : Integer)
                            + Integer.one * (successor(zero) : Integer)
                                 by congruenceOf(
                                        function (w : Integer) =>
                                            w + Integer.one
                                                * (successor(zero) : Integer),
                                        Integer.multiply_identity_right(
                                            (successor(K) : Integer)))
                          = (successor(K) : Integer) + Integer.one)
         = (successor(K) : Integer) + Integer.one
                by Integer.multiply_identity_right(
                       (successor(K) : Integer) + Integer.one)
         = (successor(successor(K)) : Integer)
         = (successor(successor(K)) : Integer)
              * (successor(zero) : Integer)
                by Equality.symmetry(
                       Integer.multiply_identity_right(
                           (successor(successor(K)) : Integer)))
         = (successor(successor(K)) : Integer)
              * (successor(zero + zero * successor(zero)) : Integer))

-- s_m = s_N + (s_m - s_N). Pure ring algebra.
theorem Rational.split_via_anchor (a b : Rational)
        : a = b + (a - b) := ring

-- ----------------------------------------------------------------------
-- Cauchy is naturally bounded.

theorem Rational.sequence.cauchy_is_naturally_bounded
        (s : Rational.sequence.Sequence)
        (sIsCauchy : Rational.sequence.IsCauchy(s))
        : ∃ (K : Natural).
            ∃ (N : Natural).
              (m : Natural) → N ≤ m →
                Rational.absolute_value(s(m))
                  ≤ (successor(K) : Rational) :=
  -- Step 1: apply sCauchy with ε = 1, 0 < 1.
  {
    obtain ⟨N, sCauchy_at_N⟩
        from sIsCauchy(Rational.one, Rational.zero_less_one);
    -- Step 2: get Natural bound K_inner for |s(N)|.
    obtain ⟨K_inner, s_at_N_bound⟩
        from Rational.absolute_value_le_succ_natural(s(N));
    -- Witness: K := succ(K_inner) (so the final bound is
    -- (succ(succ(K_inner)) : R)), N := N (unchanged).
    witness successor(K_inner) with
        (witness N with
            function (m : Natural) (N_leq_m : N ≤ m) =>
              -- Chain:
              -- |s(m)|
              --   = |s(N) + (s(m) - s(N))|   (split_via_anchor)
              --   ≤ |s(N)| + |s(m) - s(N)|   (triangle)
              --   ≤ (succ K_inner : R) + |s(m) - s(N)|   (s_at_N_bound + add_preserves)
              --   ≤ (succ K_inner : R) + 1   (|s(m)-s(N)| < 1, weakened)
              --   = (succ (succ K_inner) : R)
              Rational.LessOrEqual.transitive(
                  Rational.absolute_value(s(m)),
                  (successor(K_inner) : Rational) + Rational.one,
                  (successor(successor(K_inner)) : Rational),
                  -- |s(m)| ≤ (succ K_inner : R) + 1.
                  Rational.LessOrEqual.transitive(
                      Rational.absolute_value(s(m)),
                      Rational.absolute_value(s(N))
                          + Rational.absolute_value(s(m) - s(N)),
                      (successor(K_inner) : Rational) + Rational.one,
                      -- |s(m)| = |s(N) + (s(m)-s(N))| ≤ |s(N)| + |s(m)-s(N)|.
                      rewrite(
                          Equality.symmetry(
                              congruenceOf(
                                  Rational.absolute_value,
                                  Rational.split_via_anchor(
                                      s(m), s(N)))),
                          Rational.triangle_inequality(
                              s(N), s(m) - s(N))),
                      -- |s(N)| + |s(m)-s(N)| ≤ (succ K_inner) + 1
                      -- via sum-of-≤.
                      Rational.LessOrEqual.sum(
                          Rational.absolute_value(s(N)),
                          (successor(K_inner) : Rational),
                          Rational.absolute_value(s(m) - s(N)),
                          Rational.one,
                          s_at_N_bound,
                          Rational.LessThan.weaken(
                              Rational.absolute_value(s(m) - s(N)),
                              Rational.one,
                              sCauchy_at_N(
                                  m, N_leq_m, N,
                                  LessOrEqual.reflexivity(N))))),
                  -- (succ K_inner) + 1 = (succ (succ K_inner)) at Rational.
                  Equality.transport_proposition(
                      Rational,
                      function (w : Rational) =>
                          Rational.LessOrEqual(
                              (successor(K_inner) : Rational)
                                  + Rational.one,
                              w),
                      (successor(K_inner) : Rational) + Rational.one,
                      (successor(successor(K_inner)) : Rational),
                      Rational.succ_natural_plus_one(K_inner),
                      Rational.LessOrEqual.reflexive(
                          (successor(K_inner) : Rational) + Rational.one))))
  }
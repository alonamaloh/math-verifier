-- Real/exponential_algebra.math
--
-- Algebraic corollaries of the functional equation
-- exp(x + y) = exp(x) · exp(y):
--   * exp(x) · exp(−x) = 1, so exp never vanishes;
--   * exp(−x) is THE reciprocal of exp(x);
--   * exp(x) > 0 for ALL x — exp(x) is the square of exp(x · ½)
--     (Real/exponential.math only reaches nonnegative arguments,
--     through the series itself);
--   * exp is strictly increasing.

module Real.exponential_algebra

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.order
import Integer.basics
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.halve
import Rational.positive
import Algebra.ring_lemmas
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.instances
import Real.order
import Real.linearity
import Real.embedding_order
import Real.order_multiplication
import Real.field
import Real.order_field
import Real.limits
import Real.series
import Real.exponential
import Real.exponential_addition

-- ----------------------------------------------------------------------
-- exp(x) · exp(−x) = exp(x + (−x)) = exp(0) = 1.
theorem Real.exponential_multiply_negate (x : Real)
        : Real.exponential(x) * Real.exponential(-x) = Real.one :=
  calc Real.exponential(x) * Real.exponential(-x)
     = Real.exponential(x + -x)       by Real.exponential_add(x, -x)
     = Real.exponential(Real.zero)    by (ring : x + -x = Real.zero)
     = Real.one                       by Real.exponential_zero

-- ----------------------------------------------------------------------
-- exp never vanishes: a vanishing factor would collapse the product
-- exp(x) · exp(−x) = 1 to 0.
theorem Real.exponential_nonzero (x : Real)
        : ¬(Real.exponential(x) = Real.zero) :=
  (exponentialVanishes : Real.exponential(x) = Real.zero) ↦ {
    calc Real.zero
       = Real.zero * Real.exponential(-x)              by ring
       = Real.exponential(x) * Real.exponential(-x)    since exponentialVanishes
       = Real.one                                      by Real.exponential_multiply_negate(x)
       as zeroEqualsOne;
    claim notEqual : ¬(Real.zero = Real.one) by Real.zero_not_equal_one;
    notEqual(zeroEqualsOne)
  }

-- ----------------------------------------------------------------------
-- exp(−x) is THE reciprocal of exp(x): both multiply exp(x) to 1, and
-- inverses are unique.
theorem Real.exponential_negate (x : Real)
        : Real.exponential(-x)
          = Real.reciprocal(Real.exponential(x), Real.exponential_nonzero(x)) := {
  claim Real.exponential(x) * Real.exponential(-x) = Real.one
      since Real.exponential_multiply_negate;
  claim Real.exponential(x)
        * Real.reciprocal(Real.exponential(x), Real.exponential_nonzero(x))
        = Real.one
      since Real.reciprocal_multiplies;
  done by Real.inverse_unique
}

-- ----------------------------------------------------------------------
-- exp(x) > 0 everywhere: exp(x) = exp(x·½ + x·½) is the square of
-- exp(x·½), hence nonnegative; and exp never vanishes.
theorem Real.exponential_positive (x : Real)
        : Real.zero < Real.exponential(x) := {
  claim halfSum
        : (Rational.one_half : Real) + (Rational.one_half : Real)
          = (Rational.one : Real)
      by calc (Rational.one_half : Real) + (Rational.one_half : Real)
            = ((Rational.one_half + Rational.one_half : Rational) : Real)
            = (Rational.one : Real)   by Rational.one_half_doubled;
  claim splitX
        : x = x * (Rational.one_half : Real) + x * (Rational.one_half : Real)
      by linear_combination(x - x * halfSum);
  claim Real.IsNonneg(Real.exponential(x * (Rational.one_half : Real))
                      * Real.exponential(x * (Rational.one_half : Real)))
      since Real.square_IsNonneg;
  claim exponentialNonneg : Real.zero ≤ Real.exponential(x)
      by calc Real.zero
            ≤ Real.exponential(x * (Rational.one_half : Real))
              * Real.exponential(x * (Rational.one_half : Real))
                  since Real.LessOrEqual_zero_of_IsNonneg
            = Real.exponential(x * (Rational.one_half : Real)
                               + x * (Rational.one_half : Real))
                  by Real.exponential_add(
                         x * (Rational.one_half : Real),
                         x * (Rational.one_half : Real))
            = Real.exponential(x)
                  since splitX;
  claim notZero : ¬(Real.exponential(x) = Real.zero)
      since Real.exponential_nonzero;
  claim zeroNotExponential : ¬(Real.zero = Real.exponential(x))
      by (zeroEquals : Real.zero = Real.exponential(x)) ↦
           notZero(calc Real.exponential(x) = Real.zero);
  And.introduction(exponentialNonneg, zeroNotExponential)
}

-- ----------------------------------------------------------------------
-- exp is strictly increasing: exp(y) = exp(x) · exp(y − x), and the
-- second factor exceeds 1 because y − x > 0 (1 + t ≤ exp(t)).
theorem Real.exponential_preserves_LessThan (x y : Real) (xLessY : x < y)
        : Real.exponential(x) < Real.exponential(y) := {
  claim gapPositive : Real.zero < y - x
      by calc Real.zero
            = x - x    by ring
            < y - x    by Real.add_preserves_LessThan;
  claim Real.zero ≤ y - x since Real.LessThan.weaken;
  claim lowerBound : Real.one + (y - x) ≤ Real.exponential(y - x)
      since Real.exponential_lower_bound;
  claim factorAboveOne : Real.one < Real.exponential(y - x)
      by calc Real.one
            = Real.one + Real.zero      by ring
            < Real.one + (y - x)        by Real.add_left_preserves_LessThan
            ≤ Real.exponential(y - x)   by lowerBound;
  claim Real.zero < Real.exponential(x)
      since Real.exponential_positive;
  calc Real.exponential(x)
     = Real.one * Real.exponential(x)   by ring
     < Real.exponential(y - x) * Real.exponential(x)
           by Real.LessThan.multiply_by_positive_right
     = Real.exponential((y - x) + x)
           by Real.exponential_add(y - x, x)
     = Real.exponential(y)
           by (ring : (y - x) + x = y)
}

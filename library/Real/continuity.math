-- Real/continuity.math
--
-- ε–δ continuity of functions on the reals, in the familiar form: ε and δ
-- are real numbers. (Real division, Real.minimum and the Real ε/2 split
-- carry the tolerance arithmetic that the rational version used to.)
--
-- This file: the definition, continuity on a closed interval, and the
-- algebra of continuous functions (constants, identity, negation; sums,
-- composition and products).

module Real.continuity

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Set.basics
import Real.basics
import Real.addition
import Real.negation
import Real.ring
import Real.algebra
import Real.order
import Real.linearity
import Real.absolute_value
import Real.absolute_value_order
import Real.multiplication
import Real.instances
import Real.order_multiplication
import Real.apartness
import Real.reciprocal
import Real.field
import Real.order_field
import Real.division
import Real.minimum

-- ----------------------------------------------------------------------
-- f is continuous at x: for every positive tolerance ε there is a positive
-- δ such that f moves points δ-close to x to points ε-close to f(x).
definition Real.ContinuousAt (f : Real → Real) (x : Real) : Proposition :=
  ∀ (ε : Real). ε > 0 →
    ∃ (δ : Real).
      δ > 0 ∧ ∀ (y : Real). abs(y - x) < δ →
            abs(f(y) - f(x)) < ε

-- f is continuous on the closed interval [a, b]: continuous at every
-- point of the interval.
definition Real.ContinuousOn
        (f : Real → Real) (a b : Real) : Proposition :=
  ∀ (x : Real). a ≤ x → x ≤ b → Real.ContinuousAt(f, x)

-- ----------------------------------------------------------------------
-- Constant functions are continuous: any δ works (ε itself is at hand),
-- since the image never moves at all.
theorem Real.ContinuousAt.constant (c x : Real)
        : Real.ContinuousAt((y : Real) ↦ c, x) :=
  (ε : Real)
  (εPositive : ε > 0) ↦
    witness ε with {
      ε > 0;
      ∀ (y : Real). abs(y - x) < ε → abs(c - c) < ε
          by (y : Real) (_ : abs(y - x) < ε) ↦
            abs(c - c)
               = abs(Real.zero)        by (c - c = 0)
               = 0
               < ε;
      done
    }

-- The identity is continuous: δ = ε verbatim.
theorem Real.ContinuousAt.identity (x : Real)
        : Real.ContinuousAt((y : Real) ↦ y, x) :=
  (ε : Real)
  (εPositive : ε > 0) ↦
    witness ε with {
      ε > 0;
      ∀ (y : Real). abs(y - x) < ε → abs(y - x) < ε
          by (y : Real) (yClose : abs(y - x) < ε) ↦ yClose;
      done
    }

-- Sums of continuous functions are continuous: the usual ε/2 argument,
-- with δ = min(δf, δg) so both summands' bounds apply at once.
theorem Real.ContinuousAt.add (f g : Real → Real) (x : Real)
        (fContinuous : Real.ContinuousAt(f, x))
        (gContinuous : Real.ContinuousAt(g, x))
        : Real.ContinuousAt((y : Real) ↦ f(y) + g(y), x) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    (2 : Real) > 0;
    ε / 2 > 0 as halfPositive;
    choose fδ such that fδ > 0
            ∧ ∀ (y : Real). abs(y - x) < fδ → abs(f(y) - f(x)) < ε / 2
        from fContinuous(ε / 2, halfPositive);
    ∀ (y : Real). abs(y - x) < fδ
            → abs(f(y) - f(x)) < ε / 2 as fClose;
    choose gδ such that gδ > 0
            ∧ ∀ (y : Real). abs(y - x) < gδ → abs(g(y) - g(x)) < ε / 2
        from gContinuous(ε / 2, halfPositive);
    ∀ (y : Real). abs(y - x) < gδ
            → abs(g(y) - g(x)) < ε / 2 as gClose;
    min(fδ, gδ) > 0 by Real.minimum_positive;
    witness min(fδ, gδ) with {
      ∀ (y : Real). abs(y - x) < min(fδ, gδ)
              → abs((f(y) + g(y)) - (f(x) + g(x))) < ε
          by (y : Real)
             (yClose : abs(y - x) < min(fδ, gδ)) ↦ {
               min(fδ, gδ) ≤ fδ;
               min(fδ, gδ) ≤ gδ;
               abs(y - x) < min(fδ, gδ) ≤ fδ as yCloseF;
               abs(y - x) < min(fδ, gδ) ≤ gδ as yCloseG;
               abs(f(y) - f(x)) < ε / 2 by fClose(y, yCloseF);
               abs(g(y) - g(x)) < ε / 2 by gClose(y, yCloseG);
               abs((f(y) + g(y)) - (f(x) + g(x)))
                  = abs((f(y) - f(x)) + (g(y) - g(x)))
                        by substituting
                            (ring : (f(y) + g(y)) - (f(x) + g(x))
                                = (f(y) - f(x)) + (g(y) - g(x)))
                  ≤ abs(f(y) - f(x)) + abs(g(y) - g(x))
                        by Real.triangle_inequality
                  < ε / 2 + ε / 2
                  = ε
          };
      done
    }
  }

-- Negation preserves continuity: |−f(y) − (−f(x))| = |f(y) − f(x)|,
-- so f's own δ serves unchanged.
theorem Real.ContinuousAt.negate (f : Real → Real) (x : Real)
        (fContinuous : Real.ContinuousAt(f, x))
        : Real.ContinuousAt((y : Real) ↦ -f(y), x) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    choose δ such that δ > 0
            ∧ ∀ (y : Real). abs(y - x) < δ → abs(f(y) - f(x)) < ε
        from fContinuous(ε, εPositive);
    witness δ with {
      δ > 0;
      ∀ (y : Real). abs(y - x) < δ → abs(-f(y) - -f(x)) < ε
          by (y : Real) (yClose : abs(y - x) < δ) ↦
            abs(-f(y) - -f(x))
               = abs(-(f(y) - f(x)))
                     by substituting (ring : -f(y) - -f(x) = -(f(y) - f(x)))
               = abs(f(y) - f(x))
               < ε;
      done
    }
  }

-- Composition: g's δ for the tolerance f demands at g(x). No minimum
-- needed — the tolerances chain instead of combining.
theorem Real.ContinuousAt.composition (f g : Real → Real) (x : Real)
        (gContinuous : Real.ContinuousAt(g, x))
        (fContinuous : Real.ContinuousAt(f, g(x)))
        : Real.ContinuousAt((y : Real) ↦ f(g(y)), x) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    choose fδ such that fδ > 0
            ∧ ∀ (z : Real). abs(z - g(x)) < fδ → abs(f(z) - f(g(x))) < ε
        from fContinuous(ε, εPositive);
    fδ > 0 as fδPositive;
    ∀ (z : Real). abs(z - g(x)) < fδ
            → abs(f(z) - f(g(x))) < ε as fClose;
    choose gδ such that gδ > 0
            ∧ ∀ (y : Real). abs(y - x) < gδ → abs(g(y) - g(x)) < fδ
        from gContinuous(fδ, fδPositive);
    ∀ (y : Real). abs(y - x) < gδ
            → abs(g(y) - g(x)) < fδ as gClose;
    witness gδ with {
      gδ > 0;
      ∀ (y : Real). abs(y - x) < gδ
              → abs(f(g(y)) - f(g(x))) < ε
          by (y : Real) (yClose : abs(y - x) < gδ) ↦
            fClose(g(y), gClose(y, yClose));
      done
    }
  }

-- Differences: f − g = f + (−g), and subtraction on Real is
-- definitionally addition of the negation.
theorem Real.ContinuousAt.subtract (f g : Real → Real) (x : Real)
        (fContinuous : Real.ContinuousAt(f, x))
        (gContinuous : Real.ContinuousAt(g, x))
        : Real.ContinuousAt((y : Real) ↦ f(y) - g(y), x) := {
  Real.ContinuousAt((y : Real) ↦ -g(y), x)
      by Real.ContinuousAt.negate as negateGContinuous;
  done by Real.ContinuousAt.add(f, (y : Real) ↦ -g(y), x, fContinuous, negateGContinuous)
}

-- Products of continuous functions are continuous. The error splits as
--   |f(y)g(y) − f(x)g(x)| ≤ |f(y)|·|g(y) − g(x)| + |g(x)|·|f(y) − f(x)|,
-- |f(y)| stays under the roof |f(x)| + 2 near x (its distance to f(x) is
-- eventually below 1), |g(x)| sits under |g(x)| + 2, and each factor gets
-- the tolerance ε/2 scaled down by the opposite roof.
theorem Real.ContinuousAt.multiply (f g : Real → Real) (x : Real)
        (fContinuous : Real.ContinuousAt(f, x))
        (gContinuous : Real.ContinuousAt(g, x))
        : Real.ContinuousAt((y : Real) ↦ f(y) * g(y), x) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    let fRoof : Real := abs(f(x)) + 1;
    let gRoof : Real := abs(g(x)) + 1;
    (1 : Real) > 0;
    (1 : Real) ≥ 0;
    abs(f(x)) ≥ 0;
    abs(g(x)) ≥ 0;
    -- The roofs are positive and bound their factors.
    0
       ≤ abs(f(x))
       < abs(f(x)) + 1;
    0
       ≤ abs(g(x))
       < abs(g(x)) + 1;
    abs(g(x)) ≤ abs(g(x)) + 1;
    fRoof ≠ Real.zero;
    gRoof ≠ Real.zero;
    -- Each factor's tolerance: ε/2, scaled down by the opposite roof.
    (2 : Real) > 0;
    ε / 2 > 0;
    let gTolerance : Real := ε / 2 / fRoof;
    let fTolerance : Real := ε / 2 / gRoof;
    gTolerance > 0 by Real.divide_positive as gTolerancePositive;
    fTolerance > 0 by Real.divide_positive as fTolerancePositive;
    -- The three δs: stay within 1 of f(x), and within each scaled
    -- tolerance for the matching factor.
    choose nearδ such that nearδ > 0
            ∧ ∀ (y : Real). abs(y - x) < nearδ → abs(f(y) - f(x)) < 1
        from fContinuous((1 : Real), Real.zero_less_one);
    nearδ > 0;
    ∀ (y : Real). abs(y - x) < nearδ
            → abs(f(y) - f(x)) < 1 as fNear;
    choose gδ such that gδ > 0
            ∧ ∀ (y : Real). abs(y - x) < gδ → abs(g(y) - g(x)) < gTolerance
        from gContinuous(gTolerance, gTolerancePositive);
    gδ > 0;
    ∀ (y : Real). abs(y - x) < gδ
            → abs(g(y) - g(x)) < gTolerance as gClose;
    choose fδ such that fδ > 0
            ∧ ∀ (y : Real). abs(y - x) < fδ → abs(f(y) - f(x)) < fTolerance
        from fContinuous(fTolerance, fTolerancePositive);
    fδ > 0;
    ∀ (y : Real). abs(y - x) < fδ
            → abs(f(y) - f(x)) < fTolerance as fClose;
    min(gδ, fδ) > 0;
    min(nearδ, min(gδ, fδ)) > 0;
    witness min(nearδ, min(gδ, fδ)) with {
      ∀ (y : Real). abs(y - x) < min(nearδ, min(gδ, fδ))
              → abs(f(y) * g(y) - f(x) * g(x)) < ε
          by (y : Real)
             (yClose : abs(y - x) < min(nearδ, min(gδ, fδ))) ↦ {
           -- The single δ serves all three continuity facts.
           min(nearδ, min(gδ, fδ)) ≤ nearδ;
           min(nearδ, min(gδ, fδ)) ≤ min(gδ, fδ);
           min(gδ, fδ) ≤ gδ;
           min(gδ, fδ) ≤ fδ;
           min(nearδ, min(gδ, fδ)) ≤ gδ;
           min(nearδ, min(gδ, fδ)) ≤ fδ;
           abs(y - x) < min(nearδ, min(gδ, fδ)) ≤ nearδ as yNear;
           abs(y - x) < min(nearδ, min(gδ, fδ)) ≤ gδ as yCloseG;
           abs(y - x) < min(nearδ, min(gδ, fδ)) ≤ fδ as yCloseF;
           -- |f(y)| sits under its roof.
           abs(f(y) - f(x)) < 1 by fNear(y, yNear);
           abs(f(y) - f(x)) ≤ 1;
           abs(f(y))
              = abs(f(x) + (f(y) - f(x)))            by (f(y) = f(x) + (f(y) - f(x)))
              ≤ abs(f(x)) + abs(f(y) - f(x))         by Real.triangle_inequality
              ≤ abs(f(x)) + 1;
           -- The two error terms, each strictly below its tolerance.
           abs(g(y) - g(x)) ≥ 0;
           abs(f(y) - f(x)) ≥ 0;
           abs(g(y) - g(x)) < gTolerance by gClose(y, yCloseG);
           abs(f(y) - f(x)) < fTolerance by fClose(y, yCloseF);
           abs(f(y)) * abs(g(y) - g(x))
              ≤ fRoof * abs(g(y) - g(x))
                    by Real.LessOrEqual.multiply_by_nonneg_right
              = abs(g(y) - g(x)) * fRoof
              < gTolerance * fRoof
              = fRoof * gTolerance;
           abs(g(x)) * abs(f(y) - f(x))
              ≤ gRoof * abs(f(y) - f(x))
                    by Real.LessOrEqual.multiply_by_nonneg_right
              = abs(f(y) - f(x)) * gRoof
              < fTolerance * gRoof
              = gRoof * fTolerance;
           -- Each roof times its scaled tolerance is exactly ε/2.
           fRoof * gTolerance = ε / 2 by Real.divide_cancel as fRoofCollapse;
           gRoof * fTolerance = ε / 2 by Real.divide_cancel as gRoofCollapse;
           -- Assemble.
           abs(f(y) * g(y) - f(x) * g(x))
              = abs(f(y) * (g(y) - g(x)) + g(x) * (f(y) - f(x)))
                    by (f(y) * g(y) - f(x) * g(x)
                        = f(y) * (g(y) - g(x)) + g(x) * (f(y) - f(x)))
              ≤ abs(f(y) * (g(y) - g(x))) + abs(g(x) * (f(y) - f(x)))
                    by Real.triangle_inequality
              = abs(f(y)) * abs(g(y) - g(x)) + abs(g(x) * (f(y) - f(x)))
              = abs(f(y)) * abs(g(y) - g(x)) + abs(g(x)) * abs(f(y) - f(x))
              < fRoof * gTolerance + gRoof * fTolerance
              = ε / 2 + gRoof * fTolerance
                    by fRoofCollapse
              = ε / 2 + ε / 2
                    by gRoofCollapse
              = ε
          };
      done
    }
  }

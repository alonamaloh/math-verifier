-- Real/continuity.math
--
-- ε–δ continuity of functions on the reals, in the familiar form: ε and δ
-- are real numbers. (Real division, Real.minimum and the Real ε/2 split
-- carry the tolerance arithmetic that the rational version used to.)
--
-- This file: the definition, continuity on a closed interval, and the
-- algebra of continuous functions (constants, identity, negation; sums,
-- composition and products).

module Real.continuity

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Set.basics
import Real.basics
import Real.addition
import Real.negation
import Real.ring
import Real.algebra
import Real.order
import Real.linearity
import Real.absolute_value
import Real.absolute_value_order
import Real.multiplication
import Real.instances
import Real.order_multiplication
import Real.apartness
import Real.reciprocal
import Real.field
import Real.order_field
import Real.division
import Real.minimum

-- ----------------------------------------------------------------------
-- f is continuous at x: for every positive tolerance ε there is a positive
-- δ such that f moves points δ-close to x to points ε-close to f(x).
definition Real.ContinuousAt (f : Real → Real) (x : Real) : Proposition :=
  ∀ (epsilon : Real). epsilon > 0 →
    ∃ (delta : Real).
      delta > 0 ∧ ∀ (y : Real). abs(y - x) < delta →
            abs(f(y) - f(x)) < epsilon

-- f is continuous on the closed interval [a, b]: continuous at every
-- point of the interval.
definition Real.ContinuousOn
        (f : Real → Real) (a b : Real) : Proposition :=
  ∀ (x : Real). a ≤ x → x ≤ b → Real.ContinuousAt(f, x)

-- ----------------------------------------------------------------------
-- Constant functions are continuous: any δ works (ε itself is at hand),
-- since the image never moves at all.
theorem Real.ContinuousAt.constant (c x : Real)
        : Real.ContinuousAt((y : Real) ↦ c, x) :=
  (epsilon : Real)
  (epsilonPositive : epsilon > 0) ↦
    witness epsilon with {
      claim epsilon > 0;
      claim ∀ (y : Real). abs(y - x) < epsilon → abs(c - c) < epsilon
          by (y : Real) (_ : abs(y - x) < epsilon) ↦
            calc abs(c - c)
               = abs(Real.zero)        by (c - c = 0)
               = 0
               < epsilon;
      done
    }

-- The identity is continuous: δ = ε verbatim.
theorem Real.ContinuousAt.identity (x : Real)
        : Real.ContinuousAt((y : Real) ↦ y, x) :=
  (epsilon : Real)
  (epsilonPositive : epsilon > 0) ↦
    witness epsilon with {
      claim epsilon > 0;
      claim ∀ (y : Real). abs(y - x) < epsilon → abs(y - x) < epsilon
          by (y : Real) (yClose : abs(y - x) < epsilon) ↦ yClose;
      done
    }

-- Sums of continuous functions are continuous: the usual ε/2 argument,
-- with δ = min(δf, δg) so both summands' bounds apply at once.
theorem Real.ContinuousAt.add (f g : Real → Real) (x : Real)
        (fContinuous : Real.ContinuousAt(f, x))
        (gContinuous : Real.ContinuousAt(g, x))
        : Real.ContinuousAt((y : Real) ↦ f(y) + g(y), x) :=
  (epsilon : Real)
  (epsilonPositive : epsilon > 0) ↦ {
    claim (2 : Real) > 0 since Real.two_positive;
    claim halfPositive : epsilon / 2 > 0 since Real.divide_positive;
    choose fDelta such that fDelta > 0
            ∧ ∀ (y : Real). abs(y - x) < fDelta → abs(f(y) - f(x)) < epsilon / 2
        as fDeltaProperties
        from fContinuous(epsilon / 2, halfPositive);
    claim fClose : ∀ (y : Real). abs(y - x) < fDelta
            → abs(f(y) - f(x)) < epsilon / 2;
    choose gDelta such that gDelta > 0
            ∧ ∀ (y : Real). abs(y - x) < gDelta → abs(g(y) - g(x)) < epsilon / 2
        as gDeltaProperties
        from gContinuous(epsilon / 2, halfPositive);
    claim gClose : ∀ (y : Real). abs(y - x) < gDelta
            → abs(g(y) - g(x)) < epsilon / 2;
    claim min(fDelta, gDelta) > 0 since Real.minimum_positive;
    witness min(fDelta, gDelta) with {
      claim ∀ (y : Real). abs(y - x) < min(fDelta, gDelta)
              → abs((f(y) + g(y)) - (f(x) + g(x))) < epsilon
          by (y : Real)
             (yClose : abs(y - x) < min(fDelta, gDelta)) ↦ {
               claim min(fDelta, gDelta) ≤ fDelta since Real.minimum_LessOrEqual_left;
               claim min(fDelta, gDelta) ≤ gDelta since Real.minimum_LessOrEqual_right;
               calc abs(y - x) < min(fDelta, gDelta) ≤ fDelta as yCloseF;
               calc abs(y - x) < min(fDelta, gDelta) ≤ gDelta as yCloseG;
               claim abs(f(y) - f(x)) < epsilon / 2 by fClose(y, yCloseF);
               claim abs(g(y) - g(x)) < epsilon / 2 by gClose(y, yCloseG);
               calc abs((f(y) + g(y)) - (f(x) + g(x)))
                  = abs((f(y) - f(x)) + (g(y) - g(x)))
                        by substituting
                            (ring : (f(y) + g(y)) - (f(x) + g(x))
                                = (f(y) - f(x)) + (g(y) - g(x)))
                  ≤ abs(f(y) - f(x)) + abs(g(y) - g(x))
                        since Real.triangle_inequality
                  < epsilon / 2 + epsilon / 2
                        since Real.LessThan.add_strict_strict
                  = epsilon
                        since Real.divide_two_doubled
          };
      done
    }
  }

-- Negation preserves continuity: |−f(y) − (−f(x))| = |f(y) − f(x)|,
-- so f's own δ serves unchanged.
theorem Real.ContinuousAt.negate (f : Real → Real) (x : Real)
        (fContinuous : Real.ContinuousAt(f, x))
        : Real.ContinuousAt((y : Real) ↦ -f(y), x) :=
  (epsilon : Real)
  (epsilonPositive : epsilon > 0) ↦ {
    choose delta such that delta > 0
            ∧ ∀ (y : Real). abs(y - x) < delta → abs(f(y) - f(x)) < epsilon
        as deltaProperties
        from fContinuous(epsilon, epsilonPositive);
    witness delta with {
      claim delta > 0;
      claim ∀ (y : Real). abs(y - x) < delta → abs(-f(y) - -f(x)) < epsilon
          by (y : Real) (yClose : abs(y - x) < delta) ↦
            calc abs(-f(y) - -f(x))
               = abs(-(f(y) - f(x)))
                     by substituting (ring : -f(y) - -f(x) = -(f(y) - f(x)))
               = abs(f(y) - f(x))
                     since Real.absolute_value_negate
               < epsilon;
      done
    }
  }

-- Composition: g's δ for the tolerance f demands at g(x). No minimum
-- needed — the tolerances chain instead of combining.
theorem Real.ContinuousAt.composition (f g : Real → Real) (x : Real)
        (gContinuous : Real.ContinuousAt(g, x))
        (fContinuous : Real.ContinuousAt(f, g(x)))
        : Real.ContinuousAt((y : Real) ↦ f(g(y)), x) :=
  (epsilon : Real)
  (epsilonPositive : epsilon > 0) ↦ {
    choose fDelta such that fDelta > 0
            ∧ ∀ (z : Real). abs(z - g(x)) < fDelta → abs(f(z) - f(g(x))) < epsilon
        as fDeltaProperties
        from fContinuous(epsilon, epsilonPositive);
    claim fDeltaPositive : fDelta > 0;
    claim fClose : ∀ (z : Real). abs(z - g(x)) < fDelta
            → abs(f(z) - f(g(x))) < epsilon;
    choose gDelta such that gDelta > 0
            ∧ ∀ (y : Real). abs(y - x) < gDelta → abs(g(y) - g(x)) < fDelta
        as gDeltaProperties
        from gContinuous(fDelta, fDeltaPositive);
    claim gClose : ∀ (y : Real). abs(y - x) < gDelta
            → abs(g(y) - g(x)) < fDelta;
    witness gDelta with {
      claim gDelta > 0;
      claim ∀ (y : Real). abs(y - x) < gDelta
              → abs(f(g(y)) - f(g(x))) < epsilon
          by (y : Real) (yClose : abs(y - x) < gDelta) ↦
            fClose(g(y), gClose(y, yClose));
      done
    }
  }

-- Differences: f − g = f + (−g), and subtraction on Real is
-- definitionally addition of the negation.
theorem Real.ContinuousAt.subtract (f g : Real → Real) (x : Real)
        (fContinuous : Real.ContinuousAt(f, x))
        (gContinuous : Real.ContinuousAt(g, x))
        : Real.ContinuousAt((y : Real) ↦ f(y) - g(y), x) := {
  claim negateGContinuous : Real.ContinuousAt((y : Real) ↦ -g(y), x)
      since Real.ContinuousAt.negate;
  done by Real.ContinuousAt.add(f, (y : Real) ↦ -g(y), x, fContinuous, negateGContinuous)
}

-- Products of continuous functions are continuous. The error splits as
--   |f(y)g(y) − f(x)g(x)| ≤ |f(y)|·|g(y) − g(x)| + |g(x)|·|f(y) − f(x)|,
-- |f(y)| stays under the roof |f(x)| + 2 near x (its distance to f(x) is
-- eventually below 1), |g(x)| sits under |g(x)| + 2, and each factor gets
-- the tolerance ε/2 scaled down by the opposite roof.
theorem Real.ContinuousAt.multiply (f g : Real → Real) (x : Real)
        (fContinuous : Real.ContinuousAt(f, x))
        (gContinuous : Real.ContinuousAt(g, x))
        : Real.ContinuousAt((y : Real) ↦ f(y) * g(y), x) :=
  (epsilon : Real)
  (epsilonPositive : epsilon > 0) ↦ {
    let fRoof : Real := abs(f(x)) + 1 + 1;
    let gRoof : Real := abs(g(x)) + 1 + 1;
    claim (1 : Real) > 0 since Real.zero_less_one;
    claim (1 : Real) ≥ 0 since Real.LessThan.weaken;
    claim abs(f(x)) ≥ 0 since Real.absolute_value_nonneg;
    claim abs(g(x)) ≥ 0 since Real.absolute_value_nonneg;
    -- The roofs are positive and bound their factors.
    calc 0
       ≤ abs(f(x))
       < abs(f(x)) + 1            by Real.less_than_add_of_positive
       < (abs(f(x)) + 1) + 1      by Real.less_than_add_of_positive;
    calc 0
       ≤ abs(g(x))
       < abs(g(x)) + 1            by Real.less_than_add_of_positive
       < (abs(g(x)) + 1) + 1      by Real.less_than_add_of_positive;
    calc abs(g(x))
       ≤ abs(g(x)) + 1            by Real.less_or_equal_add_of_nonneg
       ≤ (abs(g(x)) + 1) + 1      by Real.less_or_equal_add_of_nonneg;
    claim fRoof ≠ Real.zero since Real.nonzero_of_positive;
    claim gRoof ≠ Real.zero since Real.nonzero_of_positive;
    -- Each factor's tolerance: ε/2, scaled down by the opposite roof.
    claim (2 : Real) > 0 since Real.two_positive;
    claim halfPositive : epsilon / 2 > 0 since Real.divide_positive;
    let gTolerance : Real := epsilon / 2 / fRoof;
    let fTolerance : Real := epsilon / 2 / gRoof;
    claim gTolerancePositive : gTolerance > 0 since Real.divide_positive;
    claim fTolerancePositive : fTolerance > 0 since Real.divide_positive;
    -- The three δs: stay within 1 of f(x), and within each scaled
    -- tolerance for the matching factor.
    choose nearDelta such that nearDelta > 0
            ∧ ∀ (y : Real). abs(y - x) < nearDelta → abs(f(y) - f(x)) < Real.one
        as nearProperties
        from fContinuous(Real.one, Real.zero_less_one);
    claim nearDelta > 0;
    claim fNear : ∀ (y : Real). abs(y - x) < nearDelta
            → abs(f(y) - f(x)) < Real.one;
    choose gDelta such that gDelta > 0
            ∧ ∀ (y : Real). abs(y - x) < gDelta → abs(g(y) - g(x)) < gTolerance
        as gDeltaProperties
        from gContinuous(gTolerance, gTolerancePositive);
    claim gDelta > 0;
    claim gClose : ∀ (y : Real). abs(y - x) < gDelta
            → abs(g(y) - g(x)) < gTolerance;
    choose fDelta such that fDelta > 0
            ∧ ∀ (y : Real). abs(y - x) < fDelta → abs(f(y) - f(x)) < fTolerance
        as fDeltaProperties
        from fContinuous(fTolerance, fTolerancePositive);
    claim fDelta > 0;
    claim fClose : ∀ (y : Real). abs(y - x) < fDelta
            → abs(f(y) - f(x)) < fTolerance;
    claim min(gDelta, fDelta) > 0 since Real.minimum_positive;
    claim min(nearDelta, min(gDelta, fDelta)) > 0 since Real.minimum_positive;
    witness min(nearDelta, min(gDelta, fDelta)) with {
      claim ∀ (y : Real). abs(y - x) < min(nearDelta, min(gDelta, fDelta))
              → abs(f(y) * g(y) - f(x) * g(x)) < epsilon
          by (y : Real)
             (yClose : abs(y - x) < min(nearDelta, min(gDelta, fDelta))) ↦ {
           -- The single δ serves all three continuity facts.
           claim min(nearDelta, min(gDelta, fDelta)) ≤ nearDelta
               since Real.minimum_LessOrEqual_left;
           claim min(nearDelta, min(gDelta, fDelta)) ≤ min(gDelta, fDelta)
               since Real.minimum_LessOrEqual_right;
           claim min(gDelta, fDelta) ≤ gDelta since Real.minimum_LessOrEqual_left;
           claim min(gDelta, fDelta) ≤ fDelta since Real.minimum_LessOrEqual_right;
           claim min(nearDelta, min(gDelta, fDelta)) ≤ gDelta
               since Real.LessOrEqual.transitive;
           claim min(nearDelta, min(gDelta, fDelta)) ≤ fDelta
               since Real.LessOrEqual.transitive;
           calc abs(y - x) < min(nearDelta, min(gDelta, fDelta)) ≤ nearDelta as yNear;
           calc abs(y - x) < min(nearDelta, min(gDelta, fDelta)) ≤ gDelta as yCloseG;
           calc abs(y - x) < min(nearDelta, min(gDelta, fDelta)) ≤ fDelta as yCloseF;
           -- |f(y)| sits under its roof.
           claim abs(f(y) - f(x)) < Real.one by fNear(y, yNear);
           claim abs(f(y) - f(x)) ≤ Real.one since Real.LessThan.weaken;
           calc abs(f(y))
              = abs(f(x) + (f(y) - f(x)))            by (f(y) = f(x) + (f(y) - f(x)))
              ≤ abs(f(x)) + abs(f(y) - f(x))         since Real.triangle_inequality
              ≤ abs(f(x)) + 1                        since Real.add_preserves_LessOrEqual_left
              = (abs(f(x)) + 1) + 0
              ≤ (abs(f(x)) + 1) + 1                  since Real.add_preserves_LessOrEqual_left;
           -- The two error terms, each strictly below its tolerance.
           claim abs(g(y) - g(x)) ≥ 0 since Real.absolute_value_nonneg;
           claim abs(f(y) - f(x)) ≥ 0 since Real.absolute_value_nonneg;
           claim abs(g(y) - g(x)) < gTolerance by gClose(y, yCloseG);
           claim abs(f(y) - f(x)) < fTolerance by fClose(y, yCloseF);
           calc abs(f(y)) * abs(g(y) - g(x))
              ≤ fRoof * abs(g(y) - g(x))
                    since Real.LessOrEqual.multiply_by_nonneg_right
              = abs(g(y) - g(x)) * fRoof
              < gTolerance * fRoof
                    since Real.LessThan.multiply_by_positive_right
              = fRoof * gTolerance;
           calc abs(g(x)) * abs(f(y) - f(x))
              ≤ gRoof * abs(f(y) - f(x))
                    since Real.LessOrEqual.multiply_by_nonneg_right
              = abs(f(y) - f(x)) * gRoof
              < fTolerance * gRoof
                    since Real.LessThan.multiply_by_positive_right
              = gRoof * fTolerance;
           -- Each roof times its scaled tolerance is exactly ε/2.
           claim fRoofCollapse : fRoof * gTolerance = epsilon / 2 since Real.divide_cancel;
           claim gRoofCollapse : gRoof * fTolerance = epsilon / 2 since Real.divide_cancel;
           -- Assemble.
           calc abs(f(y) * g(y) - f(x) * g(x))
              = abs(f(y) * (g(y) - g(x)) + g(x) * (f(y) - f(x)))
                    by (f(y) * g(y) - f(x) * g(x)
                        = f(y) * (g(y) - g(x)) + g(x) * (f(y) - f(x)))
              ≤ abs(f(y) * (g(y) - g(x))) + abs(g(x) * (f(y) - f(x)))
                    since Real.triangle_inequality
              = abs(f(y)) * abs(g(y) - g(x)) + abs(g(x) * (f(y) - f(x)))
                    since Real.absolute_value_multiplicative
              = abs(f(y)) * abs(g(y) - g(x)) + abs(g(x)) * abs(f(y) - f(x))
                    since Real.absolute_value_multiplicative
              < fRoof * gTolerance + gRoof * fTolerance
                    since Real.LessThan.add_strict_strict
              = epsilon / 2 + gRoof * fTolerance
                    since fRoofCollapse
              = epsilon / 2 + epsilon / 2
                    since gRoofCollapse
              = epsilon
                    since Real.divide_two_doubled
          };
      done
    }
  }

-- Real/algebra.math
--
-- Multiplicative ring laws and distributivity for Real. Each lifts
-- from the corresponding pointwise Rational law via Quotient.induct(
-- _two) + the equivalent_when_sequenceFunction_equal helper.

module Real.algebra

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring

-- ----------------------------------------------------------------------
-- Multiply is commutative on Real.

-- At constructor reps: pattern-matching exposes the underlying sequences
-- so multiply and sequenceFunction reduce, and the pointwise equality is
-- exactly Rational.multiply_commutative.
theorem Real.multiply_commutative_at_make
        : (rep_x rep_y : CauchyRationalSequence)
          → Real.multiply((Quotient.mk(rep_x) : Real), (Quotient.mk(rep_y) : Real))
            = Real.multiply((Quotient.mk(rep_y) : Real), (Quotient.mk(rep_x) : Real))
  | CauchyRationalSequence.make(sx, sx_cauchy),
    CauchyRationalSequence.make(sy, sy_cauchy) =>
      Quotient.sound(
          CauchyRationalSequence.multiply(
              CauchyRationalSequence.make(sx, sx_cauchy),
              CauchyRationalSequence.make(sy, sy_cauchy)),
          CauchyRationalSequence.multiply(
              CauchyRationalSequence.make(sy, sy_cauchy),
              CauchyRationalSequence.make(sx, sx_cauchy)),
          CauchyRationalSequence.equivalent_when_sequenceFunction_equal(
              CauchyRationalSequence.multiply(
                  CauchyRationalSequence.make(sx, sx_cauchy),
                  CauchyRationalSequence.make(sy, sy_cauchy)),
              CauchyRationalSequence.multiply(
                  CauchyRationalSequence.make(sy, sy_cauchy),
                  CauchyRationalSequence.make(sx, sx_cauchy)),
              function (n : Natural) =>
                Rational.multiply_commutative(sx(n), sy(n))))

theorem Real.multiply_commutative
        (x y : Real)
        : Real.multiply(x, y) = Real.multiply(y, x) :=
  Quotient.induct_two(Real.multiply_commutative_at_make, x, y)

-- Multiply is associative on Real. At constructor reps, all the bridge
-- proofs reduce away and the pointwise equality is Rational.multiply_associative.
theorem Real.multiply_associative_at_make
        : (rep_x rep_y rep_z : CauchyRationalSequence)
          → Real.multiply(
                Real.multiply((Quotient.mk(rep_x) : Real), (Quotient.mk(rep_y) : Real)),
                (Quotient.mk(rep_z) : Real))
            = Real.multiply(
                  (Quotient.mk(rep_x) : Real),
                  Real.multiply((Quotient.mk(rep_y) : Real), (Quotient.mk(rep_z) : Real)))
  | CauchyRationalSequence.make(sx, sx_cauchy),
    CauchyRationalSequence.make(sy, sy_cauchy),
    CauchyRationalSequence.make(sz, sz_cauchy) =>
      Quotient.sound(
          CauchyRationalSequence.multiply(
              CauchyRationalSequence.multiply(
                  CauchyRationalSequence.make(sx, sx_cauchy),
                  CauchyRationalSequence.make(sy, sy_cauchy)),
              CauchyRationalSequence.make(sz, sz_cauchy)),
          CauchyRationalSequence.multiply(
              CauchyRationalSequence.make(sx, sx_cauchy),
              CauchyRationalSequence.multiply(
                  CauchyRationalSequence.make(sy, sy_cauchy),
                  CauchyRationalSequence.make(sz, sz_cauchy))),
          CauchyRationalSequence.equivalent_when_sequenceFunction_equal(
              CauchyRationalSequence.multiply(
                  CauchyRationalSequence.multiply(
                      CauchyRationalSequence.make(sx, sx_cauchy),
                      CauchyRationalSequence.make(sy, sy_cauchy)),
                  CauchyRationalSequence.make(sz, sz_cauchy)),
              CauchyRationalSequence.multiply(
                  CauchyRationalSequence.make(sx, sx_cauchy),
                  CauchyRationalSequence.multiply(
                      CauchyRationalSequence.make(sy, sy_cauchy),
                      CauchyRationalSequence.make(sz, sz_cauchy))),
              function (n : Natural) =>
                Rational.multiply_associative(sx(n), sy(n), sz(n))))

theorem Real.multiply_associative
        (x y z : Real)
        : Real.multiply(Real.multiply(x, y), z)
          = Real.multiply(x, Real.multiply(y, z)) :=
  Quotient.induct_three(Real.multiply_associative_at_make, x, y, z)

-- 1 * x = x on Real.
theorem Real.one_multiply
        (x : Real)
        : Real.multiply(Real.one, x) = x :=
  Quotient.induct(
      function (rep_x : CauchyRationalSequence) =>
        Quotient.sound(
            CauchyRationalSequence, CauchyEquivalent,
            CauchyRationalSequence.multiply(
                Rational.to_cauchy_constant(Rational.one), rep_x),
            rep_x,
            CauchyRationalSequence.equivalent_when_sequenceFunction_equal(
                CauchyRationalSequence.multiply(
                    Rational.to_cauchy_constant(Rational.one), rep_x),
                rep_x,
                function (n : Natural) =>
                  calc CauchyRationalSequence.sequenceFunction(
                           CauchyRationalSequence.multiply(
                               Rational.to_cauchy_constant(Rational.one),
                               rep_x), n)
                     = CauchyRationalSequence.sequenceFunction(
                           Rational.to_cauchy_constant(Rational.one), n)
                       * CauchyRationalSequence.sequenceFunction(rep_x, n)
                     = Rational.one
                       * CauchyRationalSequence.sequenceFunction(rep_x, n)
                     = CauchyRationalSequence.sequenceFunction(rep_x, n))),
      x)

-- x * 1 = x via multiply_commutative + one_multiply.
theorem Real.multiply_one
        (x : Real)
        : Real.multiply(x, Real.one) = x :=
  calc Real.multiply(x, Real.one)
     = Real.multiply(Real.one, x)
     = x

-- Distributivity: x * (y + z) = x * y + x * z.
theorem Real.distributivity_left
        (x y z : Real)
        : Real.multiply(x, Real.add(y, z))
          = Real.add(Real.multiply(x, y), Real.multiply(x, z)) :=
  cases x { | rep_x =>
    cases y { | rep_y =>
      cases z { | rep_z =>
        Quotient.sound(
            CauchyRationalSequence, CauchyEquivalent,
            CauchyRationalSequence.multiply(rep_x,
                CauchyRationalSequence.add(rep_y, rep_z)),
            CauchyRationalSequence.add(
                CauchyRationalSequence.multiply(rep_x, rep_y),
                CauchyRationalSequence.multiply(rep_x, rep_z)),
            CauchyRationalSequence.equivalent_when_sequenceFunction_equal(
                CauchyRationalSequence.multiply(rep_x,
                    CauchyRationalSequence.add(rep_y, rep_z)),
                CauchyRationalSequence.add(
                    CauchyRationalSequence.multiply(rep_x, rep_y),
                    CauchyRationalSequence.multiply(rep_x, rep_z)),
                function (n : Natural) =>
                  calc CauchyRationalSequence.sequenceFunction(
                           CauchyRationalSequence.multiply(rep_x,
                               CauchyRationalSequence.add(rep_y, rep_z)),
                           n)
                     = CauchyRationalSequence.sequenceFunction(rep_x, n)
                       * CauchyRationalSequence.sequenceFunction(
                             CauchyRationalSequence.add(rep_y, rep_z), n)
                     = CauchyRationalSequence.sequenceFunction(rep_x, n)
                       * (CauchyRationalSequence.sequenceFunction(rep_y, n)
                          + CauchyRationalSequence.sequenceFunction(rep_z, n))
                     = CauchyRationalSequence.sequenceFunction(rep_x, n)
                       * CauchyRationalSequence.sequenceFunction(rep_y, n)
                       + CauchyRationalSequence.sequenceFunction(rep_x, n)
                         * CauchyRationalSequence.sequenceFunction(rep_z, n)
                     = CauchyRationalSequence.sequenceFunction(
                           CauchyRationalSequence.multiply(rep_x, rep_y), n)
                       + CauchyRationalSequence.sequenceFunction(rep_x, n)
                         * CauchyRationalSequence.sequenceFunction(rep_z, n)
                     = CauchyRationalSequence.sequenceFunction(
                           CauchyRationalSequence.multiply(rep_x, rep_y), n)
                       + CauchyRationalSequence.sequenceFunction(
                             CauchyRationalSequence.multiply(rep_x, rep_z), n)
                     = CauchyRationalSequence.sequenceFunction(
                           CauchyRationalSequence.add(
                               CauchyRationalSequence.multiply(rep_x, rep_y),
                               CauchyRationalSequence.multiply(rep_x, rep_z)),
                           n))) } } }

-- Distributivity (right): (x + y) * z = x * z + y * z. Reduces to
-- multiply_commutative + distributivity_left.
theorem Real.distributivity_right
        (x y z : Real)
        : Real.multiply(Real.add(x, y), z)
          = Real.add(Real.multiply(x, z), Real.multiply(y, z)) :=
  calc Real.multiply(Real.add(x, y), z)
     = Real.multiply(z, Real.add(x, y))
     = Real.add(Real.multiply(z, x), Real.multiply(z, y))
     = Real.add(Real.multiply(x, z), Real.multiply(z, y))
     = Real.add(Real.multiply(x, z), Real.multiply(y, z))

-- Negation distributes over subtraction: -(a - b) = b - a. Lives here
-- (not in ring.math) because `ring` needs `Real.multiplication` in
-- scope, which ring.math does not import.
theorem Real.negate_subtract (a b : Real) : -(a - b) = b - a := ring

-- (-x) * y = -(x * y). Lift Rational.multiply_negate_left pointwise.
-- ring would loop here — multiply_negate_left is itself one of the
-- axioms ring's coefficient handling depends on.
theorem Real.multiply_negate_left_at_make
        : (rep_x rep_y : CauchyRationalSequence)
          → Real.multiply(-(Quotient.mk(rep_x) : Real),
                          (Quotient.mk(rep_y) : Real))
            = -Real.multiply((Quotient.mk(rep_x) : Real),
                             (Quotient.mk(rep_y) : Real))
  | CauchyRationalSequence.make(sx, sx_cauchy),
    CauchyRationalSequence.make(sy, sy_cauchy) =>
      Quotient.sound(
          CauchyRationalSequence.multiply(
              CauchyRationalSequence.negate(
                  CauchyRationalSequence.make(sx, sx_cauchy)),
              CauchyRationalSequence.make(sy, sy_cauchy)),
          CauchyRationalSequence.negate(
              CauchyRationalSequence.multiply(
                  CauchyRationalSequence.make(sx, sx_cauchy),
                  CauchyRationalSequence.make(sy, sy_cauchy))),
          CauchyRationalSequence.equivalent_when_sequenceFunction_equal(
              CauchyRationalSequence.multiply(
                  CauchyRationalSequence.negate(
                      CauchyRationalSequence.make(sx, sx_cauchy)),
                  CauchyRationalSequence.make(sy, sy_cauchy)),
              CauchyRationalSequence.negate(
                  CauchyRationalSequence.multiply(
                      CauchyRationalSequence.make(sx, sx_cauchy),
                      CauchyRationalSequence.make(sy, sy_cauchy))),
              function (n : Natural) =>
                Rational.multiply_negate_left(sx(n), sy(n))))

theorem Real.multiply_negate_left (x y : Real)
        : Real.multiply(-x, y) = -Real.multiply(x, y) :=
  Quotient.induct_two(Real.multiply_negate_left_at_make, x, y)

-- x * (-y) = -(x * y). Reduce to multiply_negate_left via commutativity.
theorem Real.multiply_negate_right (x y : Real)
        : Real.multiply(x, -y) = -Real.multiply(x, y) :=
  calc Real.multiply(x, -y)
     = Real.multiply(-y, x)
     = -Real.multiply(x, y)

-- Distribution over subtraction on the right: (a - b) * c = a*c - b*c.
-- Now ring CAN handle it — multiply_negate_left is in its index.
theorem Real.subtract_multiply_distribute (a b c : Real)
        : Real.multiply(a - b, c)
          = Real.multiply(a, c) - Real.multiply(b, c) := ring

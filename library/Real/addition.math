-- Real/addition.math
--
-- Pointwise sum of Cauchy sequences, lifted to a binary operation on
-- Real. The two respect proofs (`add_after_first_respects` and
-- `add_respects`) are honest triangle-inequality + ε/2 split
-- arguments; `Real.add` is the Quotient.lift_two onto Real.

module Real.addition

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.maximum
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.triangle
import Rational.order_arithmetic
import Real.sequence
import Real.basics
import Real.embedding

-- Sequence-arithmetic helper: at any index m, n,
-- (s(m) + t(m)) - (s(n) + t(n)) = (s(m) - s(n)) + (t(m) - t(n)).
-- Pure Rational algebra.
theorem Rational.sequence.add_subtract_regroup
        (a b c d : Rational)
        : (a + b) - (c + d) = (a - c) + (b - d) := ring

-- The pointwise sum of two sequences is Cauchy when both are.
-- Standard ε/2 split through triangle inequality + max of N's.
theorem Rational.sequence.sum_is_cauchy
        (s t : Rational.sequence.Sequence)
        (sIsCauchy : Rational.sequence.IsCauchy(s))
        (tIsCauchy : Rational.sequence.IsCauchy(t))
        : Rational.sequence.IsCauchy(
              function (n : Natural) => s(n) + t(n)) :=
  function (epsilon : Rational)
           (epsilonPositive : Rational.zero < epsilon) => {
    obtain ⟨N_s, sBound⟩
        from sIsCauchy(Rational.halve(epsilon),
                       Rational.halve_positive(epsilon, epsilonPositive));
    obtain ⟨N_t, tBound⟩
        from tIsCauchy(Rational.halve(epsilon),
                       Rational.halve_positive(epsilon, epsilonPositive));
    witness Natural.maximum(N_s, N_t) with
        function (m : Natural)
                 (m_ge_max : Natural.maximum(N_s, N_t) ≤ m)
                 (n : Natural)
                 (n_ge_max : Natural.maximum(N_s, N_t) ≤ n) =>
          Rational.LessThan.transitive_left(
              abs(
                  s(m) + t(m) - (s(n) + t(n))),
              abs(s(m) - s(n))
                  + abs(t(m) - t(n)),
              epsilon,
              -- Step 1: ≤ via triangle + algebra.
              rewrite(
                  congruenceOf(
                      Rational.absolute_value,
                      Equality.symmetry(
                          Rational.sequence.add_subtract_regroup(
                              s(m), t(m), s(n), t(n)))),
                  Rational.triangle_inequality(
                      s(m) - s(n), t(m) - t(n))),
              -- Step 2: < via add_strict_strict + halve_doubled.
              rewrite(
                  Rational.halve_doubled(epsilon),
                  Rational.LessThan.add_strict_strict(
                      abs(s(m) - s(n)),
                      abs(t(m) - t(n)),
                      Rational.halve(epsilon),
                      sBound(m,
                          LessOrEqual.transitive(
                              N_s, Natural.maximum(N_s, N_t), m,
                              m_ge_max,
                              Natural.left_le_max(N_s, N_t)),
                          n,
                          LessOrEqual.transitive(
                              N_s, Natural.maximum(N_s, N_t), n,
                              n_ge_max,
                              Natural.left_le_max(N_s, N_t))),
                      tBound(m,
                          LessOrEqual.transitive(
                              N_t, Natural.maximum(N_s, N_t), m,
                              m_ge_max,
                              Natural.right_le_max(N_s, N_t)),
                          n,
                          LessOrEqual.transitive(
                              N_t, Natural.maximum(N_s, N_t), n,
                              n_ge_max,
                              Natural.right_le_max(N_s, N_t))))))
  }

-- Sum of two packaged Cauchy sequences.
definition CauchyRationalSequence.add
        : CauchyRationalSequence → CauchyRationalSequence
          → CauchyRationalSequence
  | CauchyRationalSequence.make(s, sCauchy),
    CauchyRationalSequence.make(t, tCauchy) =>
      CauchyRationalSequence.make(
          function (n : Natural) => s(n) + t(n),
          Rational.sequence.sum_is_cauchy(s, t, sCauchy, tCauchy))

-- sf(add(rep_x, rep_y), m) = sf(rep_x, m) + sf(rep_y, m).
-- Bridges the abstract sequenceFunction projector through the
-- pattern-match definition of add.
theorem CauchyRationalSequence.sequenceFunction_add
        : (rep_x rep_y : CauchyRationalSequence) → (m : Natural)
          → CauchyRationalSequence.sequenceFunction(
                CauchyRationalSequence.add(rep_x, rep_y), m)
            = CauchyRationalSequence.sequenceFunction(rep_x, m)
              + CauchyRationalSequence.sequenceFunction(rep_y, m)
  | CauchyRationalSequence.make(sa, _),
    CauchyRationalSequence.make(sb, _),
    m =>
      reflexivity(Rational, sa(m) + sb(m))

-- Inner respect: with x fixed, λ y. mk(add(x, y)) respects
-- CauchyEquivalent. The proof uses the SAME ε (no halving) because
-- the shared rep_x cancels: |(x_m + y_m) - (x_m + y'_m)| = |y_m - y'_m|.
-- Bridge each sf(add(rep_x, rep_•), m) to sf(rep_x, m) + sf(rep_•, m)
-- via sequenceFunction_add, then a single ring step does the cancel.
theorem Real.add_after_first_respects
        (rep_x rep_y rep_yPrime : CauchyRationalSequence)
        (yEquiv : CauchyEquivalent(rep_y, rep_yPrime))
        : (Quotient.mk(CauchyRationalSequence.add(rep_x, rep_y)) : Real)
          = Quotient.mk(CauchyRationalSequence.add(rep_x, rep_yPrime)) :=
  Quotient.sound(
      CauchyRationalSequence.add(rep_x, rep_y),
      CauchyRationalSequence.add(rep_x, rep_yPrime),
      function (epsilon : Rational)
               (epsilonPositive : Rational.zero < epsilon) =>
        ({
          obtain ⟨N, yEquiv_at_N⟩ from yEquiv(epsilon, epsilonPositive);
          witness N with
              function (m : Natural) (N_leq_m : N ≤ m) =>
                rewrite(
                    Equality.symmetry(
                        CauchyRationalSequence.sequenceFunction_add(
                            rep_x, rep_yPrime, m)),
                    rewrite(
                        Equality.symmetry(
                            CauchyRationalSequence.sequenceFunction_add(
                                rep_x, rep_y, m)),
                        rewrite(
                            (ring : CauchyRationalSequence.sequenceFunction(
                                        rep_y, m)
                                    - CauchyRationalSequence.sequenceFunction(
                                        rep_yPrime, m)
                                    = (CauchyRationalSequence.sequenceFunction(
                                           rep_x, m)
                                       + CauchyRationalSequence.sequenceFunction(
                                           rep_y, m))
                                      - (CauchyRationalSequence.sequenceFunction(
                                             rep_x, m)
                                         + CauchyRationalSequence.sequenceFunction(
                                             rep_yPrime, m))),
                            yEquiv_at_N(m, N_leq_m))))
        } : ∃ (N : Natural).
              (m : Natural) → N ≤ m →
                abs(
                    CauchyRationalSequence.sequenceFunction(
                        CauchyRationalSequence.add(rep_x, rep_y), m)
                    - CauchyRationalSequence.sequenceFunction(
                        CauchyRationalSequence.add(rep_x, rep_yPrime), m))
                  < epsilon))

-- Outer respect: lift over x. The same cancellation argument with
-- (rep_x + rep_y) vs (rep_x' + rep_y) — here the SECOND component
-- shares, so we use add_subtract_cancel_RIGHT instead.
theorem Real.add_respects
        (rep_x rep_xPrime : CauchyRationalSequence)
        (xEquiv : CauchyEquivalent(rep_x, rep_xPrime))
        (yReal : Real)
        : Quotient.lift(
              function (rep_y : CauchyRationalSequence) =>
                  (Quotient.mk(CauchyRationalSequence.add(rep_x, rep_y)) : Real),
              Real.add_after_first_respects(rep_x),
              yReal)
          = Quotient.lift(
              function (rep_y : CauchyRationalSequence) =>
                  (Quotient.mk(CauchyRationalSequence.add(rep_xPrime, rep_y)) : Real),
              Real.add_after_first_respects(rep_xPrime),
              yReal) :=
  Quotient.induct(
      function (y : Real) =>
          Quotient.lift(
              function (rep_y : CauchyRationalSequence) =>
                  (Quotient.mk(CauchyRationalSequence.add(rep_x, rep_y)) : Real),
              Real.add_after_first_respects(rep_x),
              y)
          = Quotient.lift(
              function (rep_y : CauchyRationalSequence) =>
                  (Quotient.mk(CauchyRationalSequence.add(rep_xPrime, rep_y)) : Real),
              Real.add_after_first_respects(rep_xPrime),
              y),
      function (rep_y : CauchyRationalSequence) =>
        -- Mirror of add_after_first_respects with the SECOND component
        -- shared instead of the first; the same sequenceFunction_add
        -- bridge + ring cancel.
        Quotient.sound(
            CauchyRationalSequence, CauchyEquivalent,
            CauchyRationalSequence.add(rep_x, rep_y),
            CauchyRationalSequence.add(rep_xPrime, rep_y),
            function (epsilon : Rational)
                     (epsilonPositive : Rational.zero < epsilon) =>
              ({
                obtain ⟨N, xEquiv_at_N⟩ from xEquiv(epsilon, epsilonPositive);
                witness N with
                    function (m : Natural) (N_leq_m : N ≤ m) =>
                      rewrite(
                          Equality.symmetry(
                              CauchyRationalSequence.sequenceFunction_add(
                                  rep_xPrime, rep_y, m)),
                          rewrite(
                              Equality.symmetry(
                                  CauchyRationalSequence.sequenceFunction_add(
                                      rep_x, rep_y, m)),
                              rewrite(
                                  (ring : CauchyRationalSequence.sequenceFunction(
                                              rep_x, m)
                                          - CauchyRationalSequence.sequenceFunction(
                                              rep_xPrime, m)
                                          = (CauchyRationalSequence.sequenceFunction(
                                                 rep_x, m)
                                             + CauchyRationalSequence.sequenceFunction(
                                                 rep_y, m))
                                            - (CauchyRationalSequence.sequenceFunction(
                                                   rep_xPrime, m)
                                               + CauchyRationalSequence.sequenceFunction(
                                                   rep_y, m))),
                                  xEquiv_at_N(m, N_leq_m))))
              } : ∃ (N : Natural).
                    (m : Natural) → N ≤ m →
                      abs(
                          CauchyRationalSequence.sequenceFunction(
                              CauchyRationalSequence.add(rep_x, rep_y), m)
                          - CauchyRationalSequence.sequenceFunction(
                              CauchyRationalSequence.add(rep_xPrime, rep_y), m))
                        < epsilon)),
      yReal)

-- Inner "add-with-fixed-first": Real → Real, lifts y over the inner
-- respect.
definition Real.add_after_first
        (rep_x : CauchyRationalSequence) (yReal : Real) : Real :=
  Quotient.lift(
      function (rep_y : CauchyRationalSequence) =>
          (Quotient.mk(CauchyRationalSequence.add(rep_x, rep_y)) : Real),
      Real.add_after_first_respects(rep_x),
      yReal)

-- Real.add itself: lift over x.
definition Real.add (x y : Real) : Real :=
  Quotient.lift(
      function (rep_x : CauchyRationalSequence) =>
          Real.add_after_first(rep_x, y),
      function (rep_x rep_xPrime : CauchyRationalSequence)
               (xEquiv : CauchyEquivalent(rep_x, rep_xPrime)) =>
          Real.add_respects(rep_x, rep_xPrime, xEquiv, y),
      x)

operator (+) on (Real, Real) := Real.add

-- Real/addition.math
--
-- Pointwise sum of Cauchy sequences, lifted to a binary operation on
-- Real. The two respect proofs (`add_after_first_respects` and
-- `add_respects`) are honest triangle-inequality + ε/2 split
-- arguments; `Real.add` is the Quotient.lift_two onto Real.

module Real.addition

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.maximum
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.triangle
import Rational.order_arithmetic
import Real.sequence
import Real.basics
import Real.embedding

-- Sequence-arithmetic helper: at any index m, n,
-- (s(m) + t(m)) - (s(n) + t(n)) = (s(m) - s(n)) + (t(m) - t(n)).
-- Pure Rational algebra.
theorem Rational.sequence.add_subtract_regroup
        (a b c d : Rational)
        : (a + b) - (c + d) = (a - c) + (b - d) := ring

-- The pointwise sum of two sequences is Cauchy when both are.
-- Standard ε/2 split through triangle inequality + max of N's.
theorem Rational.sequence.sum_is_cauchy
        (s t : Rational.sequence.Sequence)
        (sIsCauchy : Rational.sequence.IsCauchy(s))
        (tIsCauchy : Rational.sequence.IsCauchy(t))
        : Rational.sequence.IsCauchy(
              function (n : Natural) => s(n) + t(n)) :=
  function (epsilon : Rational)
           (epsilonPositive : Rational.zero < epsilon) => {
    obtain ⟨N_s, sBound⟩
        from sIsCauchy(Rational.halve(epsilon),
                       Rational.halve_positive(epsilon, epsilonPositive));
    obtain ⟨N_t, tBound⟩
        from tIsCauchy(Rational.halve(epsilon),
                       Rational.halve_positive(epsilon, epsilonPositive));
    witness Natural.maximum(N_s, N_t) with
        function (m : Natural)
                 (m_ge_max : Natural.maximum(N_s, N_t) ≤ m)
                 (n : Natural)
                 (n_ge_max : Natural.maximum(N_s, N_t) ≤ n) => {
          claim sBoundAtMN
                : abs(s(m) - s(n)) < Rational.halve(epsilon)
            by sBound(m,
                      Natural.le_through_max_left(N_s, N_t, m, m_ge_max),
                      n,
                      Natural.le_through_max_left(N_s, N_t, n, n_ge_max));
          claim tBoundAtMN
                : abs(t(m) - t(n)) < Rational.halve(epsilon)
            by tBound(m,
                      Natural.le_through_max_right(N_s, N_t, m, m_ge_max),
                      n,
                      Natural.le_through_max_right(N_s, N_t, n, n_ge_max));
          -- |(s(m)+t(m)) - (s(n)+t(n))|
          --   = |(s(m)-s(n)) + (t(m)-t(n))|      (regroup)
          --   ≤ |s(m)-s(n)| + |t(m)-t(n)|       (triangle)
          --   < ε/2 + ε/2 = ε                    (the two halved Cauchy bounds)
          calc abs(s(m) + t(m) - (s(n) + t(n)))
             = abs((s(m) - s(n)) + (t(m) - t(n)))
             ≤ abs(s(m) - s(n)) + abs(t(m) - t(n))
                 by Rational.triangle_inequality(s(m) - s(n), t(m) - t(n))
             < Rational.halve(epsilon) + Rational.halve(epsilon)
                 by Rational.LessThan.add_strict_strict(
                        abs(s(m) - s(n)),
                        abs(t(m) - t(n)),
                        Rational.halve(epsilon),
                        sBoundAtMN, tBoundAtMN)
             = epsilon
        }
  }

-- Sum of two packaged Cauchy sequences.
definition CauchyRationalSequence.add
        : CauchyRationalSequence → CauchyRationalSequence
          → CauchyRationalSequence
  | CauchyRationalSequence.make(s, sCauchy),
    CauchyRationalSequence.make(t, tCauchy) =>
      CauchyRationalSequence.make(
          function (n : Natural) => s(n) + t(n),
          Rational.sequence.sum_is_cauchy(s, t, sCauchy, tCauchy))

-- sf(add(rep_x, rep_y), m) = sf(rep_x, m) + sf(rep_y, m).
-- Bridges the abstract sequenceFunction projector through the
-- pattern-match definition of add.
theorem CauchyRationalSequence.sequenceFunction_add
        : (rep_x rep_y : CauchyRationalSequence) → (m : Natural)
          → CauchyRationalSequence.sequenceFunction(
                CauchyRationalSequence.add(rep_x, rep_y), m)
            = CauchyRationalSequence.sequenceFunction(rep_x, m)
              + CauchyRationalSequence.sequenceFunction(rep_y, m)
  | CauchyRationalSequence.make(sa, _),
    CauchyRationalSequence.make(sb, _),
    m =>
      reflexivity(Rational, sa(m) + sb(m))

-- Inner respect: with x fixed, λ y. mk(add(x, y)) respects
-- CauchyEquivalent. The proof uses the SAME ε (no halving) because
-- the shared rep_x cancels: |(x_m + y_m) - (x_m + y'_m)| = |y_m - y'_m|.
-- Bridge each sf(add(rep_x, rep_•), m) to sf(rep_x, m) + sf(rep_•, m)
-- via sequenceFunction_add, then a single ring step does the cancel.
theorem Real.add_after_first_respects
        (rep_x rep_y rep_yPrime : CauchyRationalSequence)
        (yEquiv : CauchyEquivalent(rep_y, rep_yPrime))
        : (Quotient.mk(CauchyRationalSequence.add(rep_x, rep_y)) : Real)
          = Quotient.mk(CauchyRationalSequence.add(rep_x, rep_yPrime)) :=
  Quotient.sound(
      CauchyRationalSequence.add(rep_x, rep_y),
      CauchyRationalSequence.add(rep_x, rep_yPrime),
      function (epsilon : Rational)
               (epsilonPositive : Rational.zero < epsilon) => {
          obtain ⟨N, yEquiv_at_N⟩ from yEquiv(epsilon, epsilonPositive);
          witness N with
              function (m : Natural) (N_leq_m : N ≤ m) => {
                let sx : Rational :=
                    CauchyRationalSequence.sequenceFunction(rep_x, m);
                let sy : Rational :=
                    CauchyRationalSequence.sequenceFunction(rep_y, m);
                let syPrime : Rational :=
                    CauchyRationalSequence.sequenceFunction(rep_yPrime, m);
                -- |sf(add(rep_x, rep_y), m) - sf(add(rep_x, rep_yPrime), m)|
                --   = |(sx + sy) - (sx + syPrime)|     (push sf through add, twice)
                --   = |sy - syPrime|                   (ring cancels the shared sx)
                --   < epsilon                          (yEquiv at N)
                calc abs(
                         CauchyRationalSequence.sequenceFunction(
                             CauchyRationalSequence.add(rep_x, rep_y), m)
                         - CauchyRationalSequence.sequenceFunction(
                             CauchyRationalSequence.add(rep_x, rep_yPrime), m))
                   = abs((sx + sy)
                         - CauchyRationalSequence.sequenceFunction(
                               CauchyRationalSequence.add(rep_x, rep_yPrime), m))
                   = abs((sx + sy) - (sx + syPrime))
                   = abs(sy - syPrime)
                   < epsilon
                       by yEquiv_at_N(m, N_leq_m)
              }
        })

-- Outer respect: lift over x. The same cancellation argument with
-- (rep_x + rep_y) vs (rep_x' + rep_y) — here the SECOND component
-- shares, so we use add_subtract_cancel_RIGHT instead.
theorem Real.add_respects
        (rep_x rep_xPrime : CauchyRationalSequence)
        (xEquiv : CauchyEquivalent(rep_x, rep_xPrime))
        (yReal : Real)
        : Quotient.lift(
              function (rep_y : CauchyRationalSequence) =>
                  (Quotient.mk(CauchyRationalSequence.add(rep_x, rep_y)) : Real),
              Real.add_after_first_respects(rep_x),
              yReal)
          = Quotient.lift(
              function (rep_y : CauchyRationalSequence) =>
                  (Quotient.mk(CauchyRationalSequence.add(rep_xPrime, rep_y)) : Real),
              Real.add_after_first_respects(rep_xPrime),
              yReal) :=
  cases yReal {
    | rep_y =>
        -- Mirror of add_after_first_respects with the SECOND component
        -- shared instead of the first; the same sequenceFunction_add
        -- bridge + ring cancel.
        Quotient.sound(
            CauchyRationalSequence.add(rep_x, rep_y),
            CauchyRationalSequence.add(rep_xPrime, rep_y),
            function (epsilon : Rational)
                     (epsilonPositive : Rational.zero < epsilon) => {
                obtain ⟨N, xEquiv_at_N⟩ from xEquiv(epsilon, epsilonPositive);
                witness N with
                    function (m : Natural) (N_leq_m : N ≤ m) => {
                      let sx : Rational :=
                          CauchyRationalSequence.sequenceFunction(rep_x, m);
                      let sxPrime : Rational :=
                          CauchyRationalSequence.sequenceFunction(rep_xPrime, m);
                      let sy : Rational :=
                          CauchyRationalSequence.sequenceFunction(rep_y, m);
                      -- |sf(add(rep_x, rep_y), m) - sf(add(rep_xPrime, rep_y), m)|
                      --   = |(sx + sy) - (sxPrime + sy)|     (push sf through add, twice)
                      --   = |sx - sxPrime|                   (ring cancels the shared sy)
                      --   < epsilon                          (xEquiv at N)
                      calc abs(
                               CauchyRationalSequence.sequenceFunction(
                                   CauchyRationalSequence.add(rep_x, rep_y), m)
                               - CauchyRationalSequence.sequenceFunction(
                                   CauchyRationalSequence.add(rep_xPrime, rep_y), m))
                         = abs((sx + sy)
                               - CauchyRationalSequence.sequenceFunction(
                                     CauchyRationalSequence.add(rep_xPrime, rep_y), m))
                         = abs((sx + sy) - (sxPrime + sy))
                         = abs(sx - sxPrime)
                         < epsilon
                             by xEquiv_at_N(m, N_leq_m)
                    }
              })
  }

-- Inner "add-with-fixed-first": Real → Real, lifts y over the inner
-- respect.
definition Real.add_after_first
        (rep_x : CauchyRationalSequence) (yReal : Real) : Real :=
  Quotient.lift(
      function (rep_y : CauchyRationalSequence) =>
          (Quotient.mk(CauchyRationalSequence.add(rep_x, rep_y)) : Real),
      Real.add_after_first_respects(rep_x),
      yReal)

-- Real.add itself: lift over x.
definition Real.add (x y : Real) : Real :=
  Quotient.lift(
      function (rep_x : CauchyRationalSequence) =>
          Real.add_after_first(rep_x, y),
      function (rep_x rep_xPrime : CauchyRationalSequence)
               (xEquiv : CauchyEquivalent(rep_x, rep_xPrime)) =>
          Real.add_respects(rep_x, rep_xPrime, xEquiv, y),
      x)

operator (+) on (Real, Real) := Real.add

-- ----------------------------------------------------------------------
-- Rational → Real embedding preservation lemmas (zero, one, add).
-- Needed by the `ring` tactic to recognize multi-step-coerced integer
-- literals as scalar coefficients at the Real carrier.

-- Reflexivity: Real.zero is definitionally Rational.to_real(Rational.zero).
theorem Rational.to_real.zero_preserves
        : Rational.to_real(Rational.zero) = Real.zero :=
  reflexivity(Real, Real.zero)

-- Reflexivity: Real.one is definitionally Rational.to_real(Rational.one).
theorem Rational.to_real.one_preserves
        : Rational.to_real(Rational.one) = Real.one :=
  reflexivity(Real, Real.one)

-- Embedding preserves addition. Both sides represent the constant
-- sequence λn. a + b; the LHS via Rational.to_cauchy_constant(a + b),
-- the RHS via CauchyRationalSequence.add of two constant sequences.
-- The Cauchy-witness proofs differ, so we use Quotient.sound with a
-- pointwise-zero equivalence proof — pre-built as a named helper so
-- the lambda body has an unambiguous expected type.
theorem Rational.to_real.add_preserves_equiv (a b : Rational)
        : CauchyEquivalent(
              Rational.to_cauchy_constant(a + b),
              CauchyRationalSequence.add(
                  Rational.to_cauchy_constant(a),
                  Rational.to_cauchy_constant(b))) :=
  function (epsilon : Rational)
           (epsilonPositive : Rational.zero < epsilon) =>
    witness 0 with
        function (m : Natural) (_ : 0 ≤ m) =>
          -- Both sequence projections reduce to `a + b`. The LHS via
          -- δ-unfold of Rational.to_cauchy_constant plus ι/β on the
          -- abstract projector. The RHS additionally walks through
          -- sequenceFunction_add to push the projection inside `add`.
          calc abs(
                   CauchyRationalSequence.sequenceFunction(
                       Rational.to_cauchy_constant(a + b), m)
                   - CauchyRationalSequence.sequenceFunction(
                         CauchyRationalSequence.add(
                             Rational.to_cauchy_constant(a),
                             Rational.to_cauchy_constant(b)),
                         m))
             = abs(
                   (a + b)
                   - CauchyRationalSequence.sequenceFunction(
                         CauchyRationalSequence.add(
                             Rational.to_cauchy_constant(a),
                             Rational.to_cauchy_constant(b)),
                         m))
             = abs(
                   (a + b)
                   - (CauchyRationalSequence.sequenceFunction(
                          Rational.to_cauchy_constant(a), m)
                      + CauchyRationalSequence.sequenceFunction(
                            Rational.to_cauchy_constant(b), m)))
             = abs((a + b) - (a + b))
             = Rational.zero
             < epsilon       by epsilonPositive

theorem Rational.to_real.add_preserves (a b : Rational)
        : Rational.to_real(a + b)
          = Rational.to_real(a) + Rational.to_real(b) :=
  Quotient.sound(
      CauchyRationalSequence,
      CauchyEquivalent,
      Rational.to_cauchy_constant(a + b),
      CauchyRationalSequence.add(
          Rational.to_cauchy_constant(a),
          Rational.to_cauchy_constant(b)),
      Rational.to_real.add_preserves_equiv(a, b))

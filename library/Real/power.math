import Real.density
import Real.convergence

-- ----------------------------------------------------------------------
-- xⁿ, by recursion on the exponent.
definition Real.power (base : Real) : Natural → Real
  | zero => Real.one
  | successor(n) => base * Real.power(base, n)

-- Powers of a nonnegative base are nonnegative.
theorem Real.power_nonneg
        (base : Real) (baseNonneg : Real.zero ≤ base) (n : Natural)
        : Real.zero ≤ Real.power(base, n) :=
  by_induction on n with IH {
    case zero: {
        claim Rational.zero < Rational.one;
        claim Real.zero < (Rational.one : Real)
            since Rational.to_real.positive_preserves;
        claim Real.zero ≤ (Rational.one : Real)
            since Real.LessThan.weaken;
        done
      }
    case successor(predecessor): {
        claim Real.IsNonneg(base)
            since Real.IsNonneg_of_LessOrEqual_zero;
        claim Real.IsNonneg(Real.power(base, predecessor))
            since Real.IsNonneg_of_LessOrEqual_zero;
        claim Real.IsNonneg(base * Real.power(base, predecessor))
            since Real.IsNonneg.multiply;
        claim Real.zero ≤ base * Real.power(base, predecessor)
            since Real.LessOrEqual_zero_of_IsNonneg;
        done
      }
  }

-- |xⁿ| = |x|ⁿ, by induction from |x·y| = |x|·|y|.
theorem Real.absolute_value_power (x : Real) (n : Natural)
        : abs(Real.power(x, n)) = Real.power(abs(x), n) :=
  by_induction on n with IH {
    case zero: {
        claim Rational.zero < Rational.one;
        claim Real.zero < (Rational.one : Real)
            since Rational.to_real.positive_preserves;
        claim Real.zero ≤ Real.one since Real.LessThan.weaken;
        claim Real.IsNonneg(Real.one)
            since Real.IsNonneg_of_LessOrEqual_zero;
        claim abs(Real.one) = Real.one
            since Real.absolute_value_when_nonneg;
        done
      }
    case successor(predecessor):
        calc abs(Real.power(x, successor(predecessor)))
           = abs(x * Real.power(x, predecessor))
           = abs(x) * abs(Real.power(x, predecessor))
                 since Real.absolute_value_multiplicative
           = abs(x) * Real.power(abs(x), predecessor)
                 since IH
  }

-- Powers compare through the embedding: a rational upper bound on the
-- base bounds every power by the cast of the rational power.
theorem Real.power_le_cast_power
        (q : Real) (c : Rational) (n : Natural)
        (qNonneg : Real.zero ≤ q) (qBound : q ≤ (c : Real))
        : Real.power(q, n) ≤ (Rational.power(c, n) : Real) :=
  by_induction on n with IH {
    case zero: {
        claim Real.one ≤ Real.one since Real.LessOrEqual.reflexive;
        done
      }
    case successor(predecessor): {
        claim Real.zero ≤ Real.power(q, predecessor)
            since Real.power_nonneg;
        claim Real.IsNonneg(Real.power(q, predecessor))
            since Real.IsNonneg_of_LessOrEqual_zero;
        calc Real.zero ≤ q ≤ (c : Real);
        claim Real.IsNonneg((c : Real))
            since Real.IsNonneg_of_LessOrEqual_zero;
        calc Real.power(q, successor(predecessor))
           = q * Real.power(q, predecessor)
           ≤ (c : Real) * Real.power(q, predecessor)
                 since Real.LessOrEqual.multiply_by_nonneg_right
           = Real.power(q, predecessor) * (c : Real)
           ≤ (Rational.power(c, predecessor) : Real) * (c : Real)
                 since Real.LessOrEqual.multiply_by_nonneg_right
           = (c : Real) * (Rational.power(c, predecessor) : Real)
           = ((c * Rational.power(c, predecessor) : Rational) : Real)
                 since Rational.to_real.multiply_preserves
      }
  }

-- ----------------------------------------------------------------------
-- The tail estimate: past some index, every power of q sits below any
-- given positive rational tolerance.
theorem Real.power_eventually_below
        (q : Real) (qNonneg : Real.zero ≤ q) (qBelowOne : q < Real.one)
        (epsilon : Rational) (epsilonPositive : Rational.zero < epsilon)
        : ∃ (N : Natural). ∀ (m : Natural). N ≤ m
            → Real.power(q, m) < (epsilon : Real) := {
  -- A rational gap inside (0, 1 − q), giving the bound c := 1 − gap
  -- with q ≤ (c : ℝ) and c < 1.
  claim gapPositive : Real.zero < Real.one - q
      by calc Real.zero
            = q - q
            < Real.one - q      by Real.add_preserves_LessThan;
  obtain ⟨gap, gapData⟩
      from Real.exists_positive_rational_below(Real.one - q, gapPositive);
  let ⟨gapRationalPositive, gapBelow⟩ := gapData;
  -- The cast of 1 − gap is 1 − (gap : ℝ).
  claim castSubtract
        : ((Rational.one - gap) : Real) = Real.one - (gap : Real)
      by calc ((Rational.one - gap) : Real)
            = (Rational.one : Real) + ((-gap : Rational) : Real)
                  by Rational.to_real.add_preserves(Rational.one, -gap)
            = (Rational.one : Real) + -(gap : Real)
                  by Rational.to_real.negate_preserves(gap)
            = Real.one - (gap : Real);
  -- q ≤ 1 − (gap : ℝ) = (c : ℝ).
  claim q + (gap : Real) < Real.one
      by calc q + (gap : Real)
            < q + (Real.one - q)    by Real.add_left_preserves_LessThan
            = Real.one              by ring;
  claim q < Real.one - (gap : Real)
      by calc q
            = (q + (gap : Real)) - (gap : Real)    by ring
            < Real.one - (gap : Real)              by Real.add_preserves_LessThan;
  claim q ≤ Real.one - (gap : Real) since Real.LessThan.weaken;
  claim q ≤ ((Rational.one - gap) : Real)
      by substituting castSubtract;
  -- c < 1 at the Rational level, reflected through the embedding.
  claim Real.one - q ≤ Real.one
      by calc Real.one - q
            = Real.zero + (Real.one - q)    by ring
            ≤ q + (Real.one - q)            by Real.add_preserves_LessOrEqual
            = Real.one                      by ring;
  claim (gap : Real) < (Rational.one : Real)
      by calc (gap : Real)
            < Real.one - q     by gapBelow
            ≤ Real.one;
  claim gap < Rational.one since Rational.to_real.LessThan_reflects;
  claim gap ≤ Rational.one since Rational.LessThan.weaken;
  claim -Rational.one ≤ -gap since Rational.LessOrEqual.negate;
  claim cNonneg : Rational.zero ≤ Rational.one - gap
      by calc Rational.zero
            = -Rational.one + Rational.one     by ring
            ≤ -gap + Rational.one              by Rational.add_preserves_LessOrEqual
            = Rational.one - gap               by ring;
  claim -gap < Rational.zero
      since Rational.negate_LessThan_zero_of_positive;
  claim cBelowOne : Rational.one - gap < Rational.one
      by calc Rational.one - gap
            = -gap + Rational.one             by ring
            < Rational.zero + Rational.one    by Rational.add_preserves_LessThan
            = Rational.one                    by ring;
  claim Rational.one - gap ≤ Rational.one
      since Rational.LessThan.weaken;
  -- Decay at the Rational layer, then transfer the whole tail.
  obtain ⟨N, decayAtN⟩
      from Rational.power_decay_witness(
               Rational.one - gap, epsilon,
               cNonneg, cBelowOne, epsilonPositive);
  witness N with
      (m : Natural) (NLeqM : N ≤ m) ↦ {
        claim Rational.power(Rational.one - gap, m)
                ≤ Rational.power(Rational.one - gap, N)
            since Rational.power_le_at_le;
        calc Real.power(q, m)
           ≤ (Rational.power(Rational.one - gap, m) : Real)
                 since Real.power_le_cast_power
           ≤ (Rational.power(Rational.one - gap, N) : Real)
                 since Rational.to_real.LessOrEqual_preserves
           < (epsilon : Real)
                 since Rational.to_real.LessThan_preserves
      }
}

-- Powers of q with 0 ≤ q < 1 converge to zero.
theorem Real.power_converges_zero
        (q : Real) (qNonneg : Real.zero ≤ q) (qBelowOne : q < Real.one)
        : Real.SequenceConverges((n : Natural) ↦ Real.power(q, n), Real.zero) :=
  (epsilon : Rational) (epsilonPositive : Rational.zero < epsilon) ↦ {
    obtain ⟨N, tailBelow⟩
        from Real.power_eventually_below(
                 q, qNonneg, qBelowOne, epsilon, epsilonPositive);
    witness N with
        (m : Natural) (NLeqM : N ≤ m) ↦ {
          claim Real.power(q, m) < (epsilon : Real) by tailBelow(m, NLeqM);
          claim Real.zero ≤ Real.power(q, m) since Real.power_nonneg;
          claim Real.IsNonneg(Real.power(q, m))
              since Real.IsNonneg_of_LessOrEqual_zero;
          claim absEqual : abs(Real.power(q, m) - Real.zero) = Real.power(q, m)
              by calc abs(Real.power(q, m) - Real.zero)
                    = abs(Real.power(q, m))
                          by substituting
                              (ring : Real.power(q, m) - Real.zero
                                  = Real.power(q, m))
                    = Real.power(q, m)
                          since Real.absolute_value_when_nonneg;
          done by substituting absEqual
        }
  }

-- ----------------------------------------------------------------------
-- The exponent laws and order facts the means inequality runs on.

theorem Real.power_add (x : Real) (exponent1 exponent2 : Natural)
        : Real.power(x, exponent1 + exponent2)
          = Real.power(x, exponent1) * Real.power(x, exponent2) :=
  by_induction on exponent1 with IH {
    case zero:
        calc Real.power(x, 0 + exponent2)
           = Real.power(x, exponent2)
           = Real.power(x, 0) * Real.power(x, exponent2)
    case successor(predecessor):
        calc Real.power(x, successor(predecessor) + exponent2)
           = x * Real.power(x, predecessor + exponent2)
           = x * (Real.power(x, predecessor) * Real.power(x, exponent2))
                 since IH
           = (x * Real.power(x, predecessor)) * Real.power(x, exponent2)
                 by ring
           = Real.power(x, successor(predecessor)) * Real.power(x, exponent2)
  }

theorem Real.power_product (x y : Real) (n : Natural)
        : Real.power(x * y, n) = Real.power(x, n) * Real.power(y, n) :=
  by_induction on n with IH {
    case zero:
        calc Real.power(x * y, 0)
           = Real.one
           = Real.power(x, 0) * Real.power(y, 0)
    case successor(predecessor):
        calc Real.power(x * y, successor(predecessor))
           = (x * y) * Real.power(x * y, predecessor)
           = (x * y) * (Real.power(x, predecessor) * Real.power(y, predecessor))
                 since IH
           = (x * Real.power(x, predecessor)) * (y * Real.power(y, predecessor))
                 by ring
           = Real.power(x, successor(predecessor))
             * Real.power(y, successor(predecessor))
  }

-- Powers preserve the order between nonnegative bases.
theorem Real.power_monotone (u v : Real) (n : Natural)
        (uNonneg : Real.zero ≤ u) (uLeqV : u ≤ v)
        : Real.power(u, n) ≤ Real.power(v, n) :=
  by_induction on n with IH {
    case zero: {
        claim Real.one ≤ Real.one since Real.LessOrEqual.reflexive;
        done
      }
    case successor(predecessor): {
        calc Real.zero ≤ u ≤ v   as vNonneg;
        claim Real.zero ≤ Real.power(u, predecessor)
            since Real.power_nonneg;
        claim Real.IsNonneg(Real.power(u, predecessor))
            since Real.IsNonneg_of_LessOrEqual_zero;
        claim Real.IsNonneg(v) since Real.IsNonneg_of_LessOrEqual_zero;
        calc Real.power(u, successor(predecessor))
           = u * Real.power(u, predecessor)
           ≤ v * Real.power(u, predecessor)
                 since Real.LessOrEqual.multiply_by_nonneg_right
           = Real.power(u, predecessor) * v
                 by ring
           ≤ Real.power(v, predecessor) * v
                 since Real.LessOrEqual.multiply_by_nonneg_right
           = v * Real.power(v, predecessor)
                 by ring
           = Real.power(v, successor(predecessor))
      }
  }

theorem Real.power_positive (x : Real) (n : Natural)
        (xPositive : Real.zero < x)
        : Real.zero < Real.power(x, n) :=
  by_induction on n with IH {
    case zero: {
        claim Rational.zero < Rational.one;
        claim Real.zero < (Rational.one : Real)
            since Rational.to_real.positive_preserves;
        done
      }
    case successor(predecessor): {
        claim Real.zero < x * Real.power(x, predecessor)
            since Real.multiply_positive;
        done
      }
  }

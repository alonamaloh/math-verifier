-- Real/power.math
--
-- Real powers with a natural exponent, and the geometric decay that
-- analysis runs on: powers of a q with 0 ≤ q < 1 converge to zero.
-- The analytic content stays at the Rational layer
-- (Rational.power_decay_witness); here a rational bound c with
-- q ≤ (c : ℝ) < 1 is produced by density, powers are compared through
-- the embedding, and the tail estimate transfers.

module Real.power


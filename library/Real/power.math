-- ----------------------------------------------------------------------
-- xⁿ, by recursion on the exponent.
definition Real.power (base : Real) : Natural → Real
  | zero => Real.one
  | successor(n) => base * Real.power(base, n)

operator (^) on (Real, Natural) := Real.power

-- The recursion characterised in `1 + n` form, so consumers step the
-- exponent without naming the raw constructor (`Natural.add` is opaque,
-- so `1 + n` is not definitionally the constructor form; bridge via `one_add`).
theorem Real.power_add_one (base : Real) (n : Natural)
        : Real.power(base, 1 + n) = base * Real.power(base, n) :=
  done by substituting Natural.one_add

-- Powers of a nonnegative base are nonnegative.
theorem Real.power_nonneg
        (base : Real) (baseNonneg : base ≥ Real.zero) (n : Natural)
        : Real.power(base, n) ≥ Real.zero :=
  by induction on n with IH {
    case base: {
        Rational.one > Rational.zero;
        (Rational.one : Real) > Real.zero;
        (Rational.one : Real) ≥ Real.zero;
        done
      }
    case step(predecessor): {
        Real.IsNonneg(base);
        Real.IsNonneg(Real.power(base, predecessor));
        Real.IsNonneg(base * Real.power(base, predecessor));
        base * Real.power(base, predecessor) ≥ Real.zero;
        done by substituting Real.power_add_one
      }
  }

-- |xⁿ| = |x|ⁿ, by induction from |x·y| = |x|·|y|.
theorem Real.absolute_value_power (x : Real) (n : Natural)
        : abs(Real.power(x, n)) = Real.power(abs(x), n) :=
  by induction on n with IH {
    case base: {
        Rational.one > Rational.zero;
        (Rational.one : Real) > Real.zero;
        Real.one ≥ Real.zero;
        Real.IsNonneg(Real.one);
        abs(Real.one) = Real.one;
        done
      }
    case step(predecessor):
        abs(Real.power(x, 1 + predecessor))
           = abs(x * Real.power(x, predecessor))
           = abs(x) * abs(Real.power(x, predecessor))
                 by Real.absolute_value_multiplicative
           = abs(x) * Real.power(abs(x), predecessor)
                 by IH
           = Real.power(abs(x), 1 + predecessor)
  }

-- Powers compare through the embedding: a rational upper bound on the
-- base bounds every power by the cast of the rational power.
theorem Real.power_le_cast_power
        (q : Real) (c : Rational) (n : Natural)
        (qNonneg : q ≥ Real.zero) (qBound : q ≤ (c : Real))
        : Real.power(q, n) ≤ (Rational.power(c, n) : Real) :=
  by induction on n with IH {
    case base: {
        Real.one ≤ Real.one;
        done
      }
    case step(predecessor): {
        Real.power(q, predecessor) ≥ Real.zero;
        Real.IsNonneg(Real.power(q, predecessor));
        Real.zero ≤ q ≤ (c : Real);
        Real.IsNonneg((c : Real));
        Real.power(q, 1 + predecessor)
           = q * Real.power(q, predecessor)
           ≤ (c : Real) * Real.power(q, predecessor)
                 by Real.LessOrEqual.multiply_by_nonneg_right
           = Real.power(q, predecessor) * (c : Real)
           ≤ (Rational.power(c, predecessor) : Real) * (c : Real)
                 by Real.LessOrEqual.multiply_by_nonneg_right
           = (c : Real) * (Rational.power(c, predecessor) : Real)
           = ((c * Rational.power(c, predecessor) : Rational) : Real)
           = (Rational.power(c, 1 + predecessor) : Real)
      }
  }

-- ----------------------------------------------------------------------
-- xᵃ⁺ᵇ = xᵃ · xᵇ.
theorem Real.power_add (x : Real) (exponent1 exponent2 : Natural)
        : Real.power(x, exponent1 + exponent2)
          = Real.power(x, exponent1) * Real.power(x, exponent2) :=
  by induction on exponent1 with IH {
    case base:
        Real.power(x, 0 + exponent2)
           = Real.power(x, exponent2)
           = Real.power(x, 0) * Real.power(x, exponent2)
    case step(predecessor):
        Real.power(x, (1 + predecessor) + exponent2)
           = Real.power(x, 1 + (predecessor + exponent2))
           = x * Real.power(x, predecessor + exponent2)
           = x * (Real.power(x, predecessor) * Real.power(x, exponent2))
                 by IH
           = (x * Real.power(x, predecessor)) * Real.power(x, exponent2)
           = Real.power(x, 1 + predecessor) * Real.power(x, exponent2)
  }

-- Powers of a base in [0, 1] stay at or below 1.
theorem Real.power_le_one (q : Real) (qNonneg : q ≥ 0) (qLeqOne : q ≤ 1)
        (n : Natural) : Real.power(q, n) ≤ 1 :=
  by induction on n with IH {
    case base:
        Real.power(q, 0)
           = 1
           ≤ 1
    case step(predecessor): {
        Real.power(q, predecessor) ≥ 0;
        Real.power(q, 1 + predecessor)
           = q * Real.power(q, predecessor)   by Real.power_add_one
           ≤ 1 * Real.power(q, predecessor)   by Real.LessOrEqual.multiply_by_nonneg_right
           = Real.power(q, predecessor)
           ≤ 1                                 by IH
      }
  }

-- A base in [0, 1] makes the powers antitone in the exponent.
theorem Real.power_antitone_exponent
        (q : Real) (qNonneg : q ≥ 0) (qLeqOne : q ≤ 1)
        (i j : Natural) (iLeqJ : i ≤ j)
        : Real.power(q, j) ≤ Real.power(q, i) := {
  choose difference such that j = difference + i from Natural.le_to_add;
  Real.power(q, i) ≥ 0;
  Real.power(q, difference) ≤ 1;
  Real.power(q, j)
     = Real.power(q, difference + i)
     = Real.power(q, difference) * Real.power(q, i)   by Real.power_add
     ≤ 1 * Real.power(q, i)
           by Real.LessOrEqual.multiply_by_nonneg_right
     = Real.power(q, i)
}

-- Powers of q with 0 ≤ q < 1 converge to zero. The sequence is decreasing
-- and bounded below by 0, so it converges (monotone convergence); its
-- limit L is pinned by the recursion q^(n+1) = q·q^n to satisfy L = q·L,
-- and 1 − q ≠ 0 forces L = 0.
theorem Real.power_converges_zero
        (q : Real) (qNonneg : q ≥ 0) (qBelowOne : q < 1)
        : Real.SequenceConverges((n : Natural) ↦ Real.power(q, n), 0) := {
  q ≤ 1;
  0
     = q - q
     < 1 - q      by Real.add_preserves_LessThan;
  1 - q ≠ 0 as denominatorNonzero;
  -- −q^n is increasing and bounded above by 0, so it converges.
  ∀ (i : Natural) (j : Natural). i ≤ j
      → -Real.power(q, i) ≤ -Real.power(q, j)
      by (i : Natural) (j : Natural) (iLeqJ : i ≤ j) ↦ {
        Real.power(q, j) ≤ Real.power(q, i)   by Real.power_antitone_exponent;
        done by Real.LessOrEqual.negate
      } as increasing;
  ∀ (n : Natural). -Real.power(q, n) ≤ 0
      by (n : Natural) ↦ {
        Real.power(q, n) ≥ 0;
        -Real.power(q, n)
           ≤ -(0 : Real)     by Real.LessOrEqual.negate
           = 0
      } as boundedAbove;
  choose negativeLimit such that
      Real.SequenceConverges((n : Natural) ↦ -Real.power(q, n), negativeLimit)
      from Real.monotone_bounded_converges(
               s := (n : Natural) ↦ -Real.power(q, n),
               monotone := increasing, bound := 0, bounded := boundedAbove);
  -- Undo the negation: q^n → −negativeLimit.
  Real.SequenceConverges((n : Natural) ↦ -(-Real.power(q, n)), -negativeLimit)
      by Real.SequenceConverges.negate(
             s := (n : Natural) ↦ -Real.power(q, n), sLimit := negativeLimit);
  Real.SequenceConverges((n : Natural) ↦ Real.power(q, n), -negativeLimit)
      by Real.SequenceConverges.of_pointwise(
             s := (n : Natural) ↦ -(-Real.power(q, n)),
             pointwiseEqual := (n : Natural) ↦
                 (ring : -(-Real.power(q, n)) = Real.power(q, n)));
  -- The shifted sequence has the same limit and equals q·q^n, so
  -- −negativeLimit = q·(−negativeLimit).
  Real.SequenceConverges((n : Natural) ↦ Real.power(q, 1 + n), -negativeLimit)
      by Real.SequenceConverges.shift_one(
             s := (n : Natural) ↦ Real.power(q, n), limit := -negativeLimit);
  Real.SequenceConverges((n : Natural) ↦ q * Real.power(q, n), -negativeLimit)
      by Real.SequenceConverges.of_pointwise(
             s := (n : Natural) ↦ Real.power(q, 1 + n),
             pointwiseEqual := (n : Natural) ↦ Real.power_add_one(q, n))
      as shiftedConverges;
  Real.SequenceConverges((n : Natural) ↦ q, q)
      by Real.constant_sequence_converges;
  Real.SequenceConverges((n : Natural) ↦ q * Real.power(q, n), q * -negativeLimit)
      by Real.SequenceConverges.multiply(
             s := (n : Natural) ↦ q, t := (n : Natural) ↦ Real.power(q, n),
             sLimit := q, tLimit := -negativeLimit)
      as productConverges;
  -negativeLimit = q * -negativeLimit
      by Real.SequenceConverges.unique(
             s := (n : Natural) ↦ q * Real.power(q, n),
             convergesToL1 := shiftedConverges, convergesToL2 := productConverges)
      as fixedPoint;
  -- (1 − q)·(−negativeLimit) = 0 with 1 − q ≠ 0 gives −negativeLimit = 0.
  (1 - q) * -negativeLimit
     = -negativeLimit - q * -negativeLimit
     = -negativeLimit - -negativeLimit    by substituting fixedPoint
     = 0
     = (1 - q) * 0
     as cancellable;
  -negativeLimit = 0
      by Real.equal_of_multiply_left(
             a := -negativeLimit, b := 0, c := 1 - q,
             cNonzero := denominatorNonzero, cancellable := cancellable);
  Real.SequenceConverges((n : Natural) ↦ Real.power(q, n), 0)
      by substituting (-negativeLimit = 0);
  done
}

-- ----------------------------------------------------------------------
-- The exponent laws and order facts the means inequality runs on.

theorem Real.power_product (x y : Real) (n : Natural)
        : Real.power(x * y, n) = Real.power(x, n) * Real.power(y, n) :=
  by induction on n with IH {
    case base:
        Real.power(x * y, 0)
           = Real.one
           = Real.power(x, 0) * Real.power(y, 0)
    case step(predecessor):
        Real.power(x * y, 1 + predecessor)
           = (x * y) * Real.power(x * y, predecessor)
           = (x * y) * (Real.power(x, predecessor) * Real.power(y, predecessor))
                 by IH
           = (x * Real.power(x, predecessor)) * (y * Real.power(y, predecessor))
           = Real.power(x, 1 + predecessor) * Real.power(y, 1 + predecessor)
  }

-- Powers preserve the order between nonnegative bases.
theorem Real.power_monotone (u v : Real) (n : Natural)
        (uNonneg : u ≥ Real.zero) (uLeqV : u ≤ v)
        : Real.power(u, n) ≤ Real.power(v, n) :=
  by induction on n with IH {
    case base: {
        Real.one ≤ Real.one;
        done
      }
    case step(predecessor): {
        Real.zero ≤ u ≤ v;
        Real.power(u, predecessor) ≥ Real.zero;
        Real.IsNonneg(Real.power(u, predecessor));
        Real.IsNonneg(v);
        Real.power(u, 1 + predecessor)
           = u * Real.power(u, predecessor)
           ≤ v * Real.power(u, predecessor)
                 by Real.LessOrEqual.multiply_by_nonneg_right
           = Real.power(u, predecessor) * v
           ≤ Real.power(v, predecessor) * v
                 by Real.LessOrEqual.multiply_by_nonneg_right
           = v * Real.power(v, predecessor)
           = Real.power(v, 1 + predecessor)
      }
  }

theorem Real.power_positive (x : Real) (n : Natural)
        (xPositive : x > Real.zero)
        : Real.power(x, n) > Real.zero :=
  by induction on n with IH {
    case base: {
        Rational.one > Rational.zero;
        (Rational.one : Real) > Real.zero;
        done
      }
    case step(predecessor): {
        x * Real.power(x, predecessor) > Real.zero;
        Real.power(x, 1 + predecessor) > Real.zero
            by substituting Real.power_add_one;
        done
      }
  }

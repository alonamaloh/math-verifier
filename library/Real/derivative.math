-- Real/derivative.math
--
-- The derivative, in the division-free linear-approximation form: f has
-- derivative L at x when, within δ of x, the error of the linear
-- approximation f(x) + L·(y − x) is at most ε·|y − x| — for every positive
-- real ε, with a positive real δ. No difference quotient, no punctured
-- neighbourhood (the bound is trivially true at y = x), and the algebra of
-- derivatives is plain ε-bookkeeping.

module Real.derivative

import Logic.basics
import Logic.exists
import Logic.quotient
import Logic.excluded_middle
import Equality.basics
import Natural.basics
import Natural.order
import Integer.basics
import Integer.embedding
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.order
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.positive
import Rational.linearity
import Rational.archimedean
import Set.basics
import Algebra.ring_lemmas
import Real.sequence
import Real.basics
import Real.embedding
import Real.addition
import Real.negation
import Real.multiplication
import Real.ring
import Real.algebra
import Real.instances
import Real.order
import Real.linearity
import Real.embedding_order
import Real.order_multiplication
import Real.apartness
import Real.reciprocal
import Real.field
import Real.order_field
import Real.absolute_value
import Real.absolute_value_order
import Real.density
import Real.convergence
import Real.supremum
import Real.limits
import Real.continuity
import Real.division
import Real.minimum

-- ----------------------------------------------------------------------
-- f has derivative L at x.
definition Real.HasDerivativeAt (f : Real → Real) (x L : Real) : Proposition :=
  ∀ (ε : Real). ε > 0 →
    ∃ (δ : Real).
      δ > 0 ∧ ∀ (y : Real). abs(y - x) < δ
            → abs(f(y) - f(x) - L * (y - x))
              ≤ ε * abs(y - x)

-- ----------------------------------------------------------------------
-- Constants have derivative zero: the approximation error vanishes.
theorem Real.HasDerivativeAt.constant (c x : Real)
        : Real.HasDerivativeAt((y : Real) ↦ c, x, (0 : Real)) :=
  (ε : Real)
  (εPositive : ε > 0) ↦
    witness ε with
        ⟨εPositive,
         (y : Real) (_ : abs(y - x) < ε) ↦ {
           calc abs(c - c - 0 * (y - x))
              = abs(Real.zero)   by (c - c - 0 * (y - x) = 0)
              = 0
              as errorZero;
           claim abs(y - x) ≥ 0 since Real.absolute_value_nonneg;
           claim ε ≥ 0 since Real.LessThan.weaken;
           claim Real.IsNonneg(ε) since Real.IsNonneg_of_LessOrEqual_zero;
           claim Real.IsNonneg(abs(y - x)) since Real.IsNonneg_of_LessOrEqual_zero;
           claim Real.IsNonneg(ε * abs(y - x)) since Real.IsNonneg.multiply;
           claim ε * abs(y - x) ≥ 0 since Real.LessOrEqual_zero_of_IsNonneg;
           calc abs(c - c - 0 * (y - x))
              = 0                    since errorZero
              ≤ ε * abs(y - x)
         }⟩

-- The identity has derivative one.
theorem Real.HasDerivativeAt.identity (x : Real)
        : Real.HasDerivativeAt((y : Real) ↦ y, x, (1 : Real)) :=
  (ε : Real)
  (εPositive : ε > 0) ↦
    witness ε with
        ⟨εPositive,
         (y : Real) (_ : abs(y - x) < ε) ↦ {
           calc abs(y - x - 1 * (y - x))
              = abs(Real.zero)   by (y - x - 1 * (y - x) = 0)
              = 0
              as errorZero;
           claim abs(y - x) ≥ 0 since Real.absolute_value_nonneg;
           claim ε ≥ 0 since Real.LessThan.weaken;
           claim Real.IsNonneg(ε) since Real.IsNonneg_of_LessOrEqual_zero;
           claim Real.IsNonneg(abs(y - x)) since Real.IsNonneg_of_LessOrEqual_zero;
           claim Real.IsNonneg(ε * abs(y - x)) since Real.IsNonneg.multiply;
           claim ε * abs(y - x) ≥ 0 since Real.LessOrEqual_zero_of_IsNonneg;
           calc abs(y - x - 1 * (y - x))
              = 0                    since errorZero
              ≤ ε * abs(y - x)
         }⟩

-- Derivatives add: each summand gets half the tolerance.
theorem Real.HasDerivativeAt.add (f g : Real → Real) (x fSlope gSlope : Real)
        (fDerivative : Real.HasDerivativeAt(f, x, fSlope))
        (gDerivative : Real.HasDerivativeAt(g, x, gSlope))
        : Real.HasDerivativeAt(
              (y : Real) ↦ f(y) + g(y), x, fSlope + gSlope) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    claim (2 : Real) > 0 since Real.two_positive;
    claim (2 : Real) ≠ 0 since Real.two_is_nonzero;
    claim halfPositive : ε / 2 > 0 since Real.divide_positive;
    choose fδ from fDerivative(ε / 2, halfPositive);
    claim fClose : ∀ (y : Real). abs(y - x) < fδ
            → abs(f(y) - f(x) - fSlope * (y - x)) ≤ ε / 2 * abs(y - x);
    choose gδ from gDerivative(ε / 2, halfPositive);
    claim gClose : ∀ (y : Real). abs(y - x) < gδ
            → abs(g(y) - g(x) - gSlope * (y - x)) ≤ ε / 2 * abs(y - x);
    claim minimumPositive : min(fδ, gδ) > 0 since Real.minimum_positive;
    witness min(fδ, gδ) with
        ⟨minimumPositive,
         (y : Real)
         (yClose : abs(y - x) < min(fδ, gδ)) ↦ {
           claim min(fδ, gδ) ≤ fδ since Real.minimum_LessOrEqual_left;
           claim min(fδ, gδ) ≤ gδ since Real.minimum_LessOrEqual_right;
           calc abs(y - x) < min(fδ, gδ) ≤ fδ as yCloseF;
           calc abs(y - x) < min(fδ, gδ) ≤ gδ as yCloseG;
           claim abs(f(y) - f(x) - fSlope * (y - x)) ≤ ε / 2 * abs(y - x)
               by fClose(y, yCloseF);
           claim abs(g(y) - g(x) - gSlope * (y - x)) ≤ ε / 2 * abs(y - x)
               by gClose(y, yCloseG);
           calc abs(f(y) + g(y) - (f(x) + g(x)) - (fSlope + gSlope) * (y - x))
              = abs((f(y) - f(x) - fSlope * (y - x))
                    + (g(y) - g(x) - gSlope * (y - x)))
                    by (f(y) + g(y) - (f(x) + g(x)) - (fSlope + gSlope) * (y - x)
                        = (f(y) - f(x) - fSlope * (y - x))
                          + (g(y) - g(x) - gSlope * (y - x)))
              ≤ abs(f(y) - f(x) - fSlope * (y - x))
                + abs(g(y) - g(x) - gSlope * (y - x))
                    since Real.triangle_inequality
              ≤ ε / 2 * abs(y - x)
                + abs(g(y) - g(x) - gSlope * (y - x))
              ≤ ε / 2 * abs(y - x) + ε / 2 * abs(y - x)
                    since Real.add_preserves_LessOrEqual_left
              = (ε / 2 + ε / 2) * abs(y - x)
              = ε * abs(y - x)
                    since Real.divide_two_doubled
         }⟩
  }

-- Negation flips the derivative: the approximation error is the same
-- up to sign, and |·| forgets the sign.
theorem Real.HasDerivativeAt.negate (f : Real → Real) (x L : Real)
        (fDerivative : Real.HasDerivativeAt(f, x, L))
        : Real.HasDerivativeAt((y : Real) ↦ -f(y), x, -L) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    choose δ from fDerivative(ε, εPositive);
    claim δPositive : δ > 0;
    claim fClose : ∀ (y : Real). abs(y - x) < δ
            → abs(f(y) - f(x) - L * (y - x)) ≤ ε * abs(y - x);
    witness δ with
        ⟨δPositive,
         (y : Real) (yClose : abs(y - x) < δ) ↦ {
           claim fBound : abs(f(y) - f(x) - L * (y - x)) ≤ ε * abs(y - x)
               by fClose(y, yClose);
           calc abs(-f(y) - -f(x) - -L * (y - x))
              = abs(-(f(y) - f(x) - L * (y - x)))
                    by (-f(y) - -f(x) - -L * (y - x) = -(f(y) - f(x) - L * (y - x)))
              = abs(f(y) - f(x) - L * (y - x))
                    since Real.absolute_value_negate
              ≤ ε * abs(y - x)
                    by fBound
         }⟩
  }

-- Differences: f − g = f + (−g), and subtraction on Real is
-- definitionally addition of the negation.
theorem Real.HasDerivativeAt.subtract (f g : Real → Real) (x fSlope gSlope : Real)
        (fDerivative : Real.HasDerivativeAt(f, x, fSlope))
        (gDerivative : Real.HasDerivativeAt(g, x, gSlope))
        : Real.HasDerivativeAt(
              (y : Real) ↦ f(y) - g(y), x, fSlope - gSlope) := {
  claim Real.HasDerivativeAt((y : Real) ↦ -g(y), x, -gSlope)
      since Real.HasDerivativeAt.negate;
  done
}

-- Constant multiples scale the derivative: the error picks up a factor
-- of |c|, so f is run at tolerance ε scaled down by a roof over |c|.
-- The roof is the rational density bound on |c|, cast to Real for the
-- division.
theorem Real.HasDerivativeAt.scale (c : Real) (f : Real → Real) (x L : Real)
        (fDerivative : Real.HasDerivativeAt(f, x, L))
        : Real.HasDerivativeAt((y : Real) ↦ c * f(y), x, c * L) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    choose roof such that Rational.zero < roof ∧ abs(c) ≤ (roof : Real)
        from Real.exists_positive_rational_roof(c);
    claim (roof : Real) > 0
        since Rational.to_real.positive_preserves;
    claim (roof : Real) ≠ 0 since Real.nonzero_of_positive;
    claim tolerancePositive : ε / (roof : Real) > 0
        since Real.divide_positive;
    choose δ such that δ > 0
            ∧ (∀ (y : Real). abs(y - x) < δ
                → abs(f(y) - f(x) - L * (y - x)) ≤ ε / (roof : Real) * abs(y - x))
        as δProperties
        from fDerivative(ε / (roof : Real), tolerancePositive);
    claim δPositive : δ > 0 by And.left(δProperties);
    claim fClose : ∀ (y : Real). abs(y - x) < δ
            → abs(f(y) - f(x) - L * (y - x)) ≤ ε / (roof : Real) * abs(y - x);
    witness δ with
        ⟨δPositive,
         (y : Real) (yClose : abs(y - x) < δ) ↦ {
           claim abs(c) ≥ 0 since Real.absolute_value_nonneg;
           claim abs(f(y) - f(x) - L * (y - x)) ≥ 0
               since Real.absolute_value_nonneg;
           claim abs(f(y) - f(x) - L * (y - x))
                   ≤ ε / (roof : Real) * abs(y - x)
               by fClose(y, yClose);
           claim collapse : (roof : Real) * (ε / (roof : Real)) = ε
               since Real.divide_cancel;
           calc abs(c * f(y) - c * f(x) - c * L * (y - x))
              = abs(c * (f(y) - f(x) - L * (y - x)))
                    by (c * f(y) - c * f(x) - c * L * (y - x)
                        = c * (f(y) - f(x) - L * (y - x)))
              = abs(c) * abs(f(y) - f(x) - L * (y - x))
                    since Real.absolute_value_multiplicative
              ≤ (roof : Real) * (ε / (roof : Real) * abs(y - x))
                    since Real.LessOrEqual.multiply_monotone_nonneg
              = ((roof : Real) * (ε / (roof : Real))) * abs(y - x)
              = ε * abs(y - x)
                    since collapse
         }⟩
  }

-- Differentiability implies continuity: near x the function moves by
-- at most (1 + |L|)·|y − x|, and δ is shrunk until that beats ε. The
-- slope roof is the rational density bound on L, cast to Real.
theorem Real.HasDerivativeAt.continuous (f : Real → Real) (x L : Real)
        (fDerivative : Real.HasDerivativeAt(f, x, L))
        : Real.ContinuousAt(f, x) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    choose slopeRoof from Real.exists_positive_rational_roof(L);
    claim slopeRoofBounds : abs(L) ≤ (slopeRoof : Real);
    claim (1 : Real) > 0 since Real.zero_less_one;
    claim (slopeRoof : Real) > 0
        since Rational.to_real.positive_preserves;
    calc (0 : Real)
       < 1                          by Real.zero_less_one
       < 1 + (slopeRoof : Real)     by Real.less_than_add_of_positive;
    claim 1 + (slopeRoof : Real) ≠ 0 since Real.nonzero_of_positive;
    claim ε / (1 + (slopeRoof : Real)) > 0
        since Real.divide_positive;
    choose nearδ from fDerivative((1 : Real), Real.zero_less_one);
    claim fClose : ∀ (y : Real). abs(y - x) < nearδ
            → abs(f(y) - f(x) - L * (y - x)) ≤ 1 * abs(y - x);
    claim minimumPositive
          : min(nearδ, ε / (1 + (slopeRoof : Real))) > 0
        since Real.minimum_positive;
    witness min(nearδ, ε / (1 + (slopeRoof : Real)))
        with
        ⟨minimumPositive,
         (y : Real)
         (yClose : abs(y - x)
                   < min(nearδ, ε / (1 + (slopeRoof : Real)))) ↦ {
           claim min(nearδ, ε / (1 + (slopeRoof : Real))) ≤ nearδ
               since Real.minimum_LessOrEqual_left;
           claim min(nearδ, ε / (1 + (slopeRoof : Real)))
                   ≤ ε / (1 + (slopeRoof : Real))
               since Real.minimum_LessOrEqual_right;
           calc abs(y - x)
              < min(nearδ, ε / (1 + (slopeRoof : Real)))
              ≤ nearδ
              as yCloseNear;
           calc abs(y - x)
              < min(nearδ, ε / (1 + (slopeRoof : Real)))
              ≤ ε / (1 + (slopeRoof : Real));
           claim abs(f(y) - f(x) - L * (y - x)) ≤ 1 * abs(y - x)
               by fClose(y, yCloseNear);
           claim abs(y - x) ≥ 0 since Real.absolute_value_nonneg;
           claim abs(L) ≤ (slopeRoof : Real) since slopeRoofBounds;
           claim abs(L) * abs(y - x) ≤ (slopeRoof : Real) * abs(y - x)
               since Real.LessOrEqual.multiply_by_nonneg_right;
           claim collapse
                 : (1 + (slopeRoof : Real))
                   * (ε / (1 + (slopeRoof : Real)))
                   = ε
               since Real.divide_cancel;
           calc abs(f(y) - f(x))
              = abs((f(y) - f(x) - L * (y - x)) + L * (y - x))
                    by ((f(y) - f(x) - L * (y - x)) + L * (y - x) = f(y) - f(x))
              ≤ abs(f(y) - f(x) - L * (y - x)) + abs(L * (y - x))
                    by Real.triangle_inequality
              = abs(f(y) - f(x) - L * (y - x)) + abs(L) * abs(y - x)
                    since Real.absolute_value_multiplicative
              ≤ 1 * abs(y - x) + abs(L) * abs(y - x)
                    by Real.add_preserves_LessOrEqual
              ≤ 1 * abs(y - x) + (slopeRoof : Real) * abs(y - x)
                    since Real.add_preserves_LessOrEqual_left
              = (1 + (slopeRoof : Real)) * abs(y - x)
              = abs(y - x) * (1 + (slopeRoof : Real))
              < (ε / (1 + (slopeRoof : Real)))
                * (1 + (slopeRoof : Real))
                    since Real.LessThan.multiply_by_positive_right
              = (1 + (slopeRoof : Real))
                * (ε / (1 + (slopeRoof : Real)))
              = ε
                    since collapse
         }⟩
  }

-- The product rule. The error of f·g against slope f′g(x) + f(x)g′
-- splits into three pieces:
--   (f-error)·g(y)  +  f(x)·(g-error)  +  f′·((y − x)·(g(y) − g(x))),
-- bounded by roofs over |g(y)|, |f(x)| and |fSlope| with tolerances
-- ε/2, ε/4 and ε/4 scaled down by the matching roof.
theorem Real.HasDerivativeAt.multiply (f g : Real → Real) (x fSlope gSlope : Real)
        (fDerivative : Real.HasDerivativeAt(f, x, fSlope))
        (gDerivative : Real.HasDerivativeAt(g, x, gSlope))
        : Real.HasDerivativeAt(
              (y : Real) ↦ f(y) * g(y), x, fSlope * g(x) + f(x) * gSlope) :=
  (ε : Real)
  (εPositive : ε > 0) ↦ {
    claim gContinuous : Real.ContinuousAt(g, x) since Real.HasDerivativeAt.continuous;
    -- Real roofs over the three bystander factors, each with headroom.
    let gHeadroom : Real := abs(g(x)) + 1;
    let fRoof : Real := abs(f(x)) + 1;
    let slopeRoof : Real := abs(fSlope) + 1;
    claim (1 : Real) > 0 since Real.zero_less_one;
    claim (1 : Real) ≥ 0 since Real.LessThan.weaken;
    claim abs(g(x)) ≥ 0 since Real.absolute_value_nonneg;
    claim abs(f(x)) ≥ 0 since Real.absolute_value_nonneg;
    claim abs(fSlope) ≥ 0 since Real.absolute_value_nonneg;
    calc 0
       ≤ abs(g(x))
       < abs(g(x)) + 1            by Real.less_than_add_of_positive;
    calc 0
       ≤ abs(f(x))
       < abs(f(x)) + 1            by Real.less_than_add_of_positive;
    calc 0
       ≤ abs(fSlope)
       < abs(fSlope) + 1          by Real.less_than_add_of_positive;
    calc abs(f(x))
       ≤ abs(f(x)) + 1            by Real.less_or_equal_add_of_nonneg;
    calc abs(fSlope)
       ≤ abs(fSlope) + 1          by Real.less_or_equal_add_of_nonneg;
    claim gHeadroom ≠ 0 since Real.nonzero_of_positive;
    claim fRoof ≠ 0 since Real.nonzero_of_positive;
    claim slopeRoof ≠ 0 since Real.nonzero_of_positive;
    -- The three scaled tolerances, all positive.
    claim (2 : Real) > 0 since Real.two_positive;
    claim (2 : Real) ≠ 0 since Real.two_is_nonzero;
    claim ε / 2 > 0 since Real.divide_positive;
    claim ε / 2 / 2 > 0 since Real.divide_positive;
    claim fTolerancePositive : ε / 2 / gHeadroom > 0
        since Real.divide_positive;
    claim gTolerancePositive : ε / 2 / 2 / fRoof > 0
        since Real.divide_positive;
    claim differenceTolerancePositive : ε / 2 / 2 / slopeRoof > 0
        since Real.divide_positive;
    -- The four δs.
    choose fδ from fDerivative(ε / 2 / gHeadroom, fTolerancePositive);
    claim fClose : ∀ (y : Real). abs(y - x) < fδ
            → abs(f(y) - f(x) - fSlope * (y - x)) ≤ ε / 2 / gHeadroom * abs(y - x);
    choose gδ from gDerivative(ε / 2 / 2 / fRoof, gTolerancePositive);
    claim gClose : ∀ (y : Real). abs(y - x) < gδ
            → abs(g(y) - g(x) - gSlope * (y - x)) ≤ ε / 2 / 2 / fRoof * abs(y - x);
    choose nearδ from gContinuous((1 : Real), Real.zero_less_one);
    claim gNearClose : ∀ (y : Real). abs(y - x) < nearδ → abs(g(y) - g(x)) < 1;
    choose differenceδ
        from gContinuous(ε / 2 / 2 / slopeRoof, differenceTolerancePositive);
    claim gDifferenceClose : ∀ (y : Real). abs(y - x) < differenceδ
            → abs(g(y) - g(x)) < ε / 2 / 2 / slopeRoof;
    claim min(fδ, gδ) > 0 since Real.minimum_positive;
    claim min(nearδ, differenceδ) > 0 since Real.minimum_positive;
    claim minimumPositive
          : min(min(fδ, gδ), min(nearδ, differenceδ)) > 0
        since Real.minimum_positive;
    witness min(min(fδ, gδ), min(nearδ, differenceδ)) with
        ⟨minimumPositive,
         (y : Real)
         (yClose : abs(y - x)
                   < min(min(fδ, gδ), min(nearδ, differenceδ))) ↦ {
           -- The single δ serves all four closeness facts.
           claim min(min(fδ, gδ), min(nearδ, differenceδ))
                   ≤ min(fδ, gδ)
               since Real.minimum_LessOrEqual_left;
           claim min(min(fδ, gδ), min(nearδ, differenceδ))
                   ≤ min(nearδ, differenceδ)
               since Real.minimum_LessOrEqual_right;
           claim min(fδ, gδ) ≤ fδ since Real.minimum_LessOrEqual_left;
           claim min(fδ, gδ) ≤ gδ since Real.minimum_LessOrEqual_right;
           claim min(nearδ, differenceδ) ≤ nearδ
               since Real.minimum_LessOrEqual_left;
           claim min(nearδ, differenceδ) ≤ differenceδ
               since Real.minimum_LessOrEqual_right;
           claim min(min(fδ, gδ), min(nearδ, differenceδ)) ≤ fδ
               since Real.LessOrEqual.transitive;
           claim min(min(fδ, gδ), min(nearδ, differenceδ)) ≤ gδ
               since Real.LessOrEqual.transitive;
           claim min(min(fδ, gδ), min(nearδ, differenceδ)) ≤ nearδ
               since Real.LessOrEqual.transitive;
           claim min(min(fδ, gδ), min(nearδ, differenceδ)) ≤ differenceδ
               since Real.LessOrEqual.transitive;
           calc abs(y - x)
              < min(min(fδ, gδ), min(nearδ, differenceδ))
              ≤ fδ
              as yCloseF;
           calc abs(y - x)
              < min(min(fδ, gδ), min(nearδ, differenceδ))
              ≤ gδ
              as yCloseG;
           calc abs(y - x)
              < min(min(fδ, gδ), min(nearδ, differenceδ))
              ≤ nearδ
              as yCloseNear;
           calc abs(y - x)
              < min(min(fδ, gδ), min(nearδ, differenceδ))
              ≤ differenceδ
              as yCloseDifference;
           -- |g(y)| sits under its headroom roof.
           claim abs(g(y) - g(x)) < 1 by gNearClose(y, yCloseNear);
           claim abs(g(y) - g(x)) ≤ 1 since Real.LessThan.weaken;
           calc abs(g(y))
              = abs(g(x) + (g(y) - g(x)))            by (g(x) + (g(y) - g(x)) = g(y))
              ≤ abs(g(x)) + abs(g(y) - g(x))         since Real.triangle_inequality
              ≤ abs(g(x)) + 1                        by Real.add_preserves_LessOrEqual_left;
           -- The three error bounds delivered by the δs.
           claim abs(f(y) - f(x) - fSlope * (y - x)) ≤ ε / 2 / gHeadroom * abs(y - x)
               by fClose(y, yCloseF);
           claim abs(g(y) - g(x) - gSlope * (y - x)) ≤ ε / 2 / 2 / fRoof * abs(y - x)
               by gClose(y, yCloseG);
           claim abs(g(y) - g(x)) < ε / 2 / 2 / slopeRoof
               by gDifferenceClose(y, yCloseDifference);
           claim abs(g(y) - g(x)) ≤ ε / 2 / 2 / slopeRoof since Real.LessThan.weaken;
           -- Nonnegativity bookkeeping.
           claim abs(y - x) ≥ 0 since Real.absolute_value_nonneg;
           claim abs(g(y)) ≥ 0 since Real.absolute_value_nonneg;
           claim abs(f(x)) ≥ 0 since Real.absolute_value_nonneg;
           claim abs(fSlope) ≥ 0 since Real.absolute_value_nonneg;
           claim abs(f(y) - f(x) - fSlope * (y - x)) ≥ 0 since Real.absolute_value_nonneg;
           claim abs(g(y) - g(x) - gSlope * (y - x)) ≥ 0 since Real.absolute_value_nonneg;
           claim abs(g(y) - g(x)) ≥ 0 since Real.absolute_value_nonneg;
           claim abs(y - x) ≤ abs(y - x) since Real.LessOrEqual.reflexive;
           claim Real.IsNonneg(abs(y - x)) since Real.IsNonneg_of_LessOrEqual_zero;
           claim Real.IsNonneg(abs(g(y) - g(x))) since Real.IsNonneg_of_LessOrEqual_zero;
           claim Real.IsNonneg(abs(y - x) * abs(g(y) - g(x))) since Real.IsNonneg.multiply;
           claim abs(y - x) * abs(g(y) - g(x)) ≥ 0
               since Real.LessOrEqual_zero_of_IsNonneg;
           -- The three tolerance collapses.
           claim collapseFirst : gHeadroom * (ε / 2 / gHeadroom) = ε / 2
               since Real.divide_cancel;
           claim collapseSecond : fRoof * (ε / 2 / 2 / fRoof) = ε / 2 / 2
               since Real.divide_cancel;
           claim collapseThird : slopeRoof * (ε / 2 / 2 / slopeRoof) = ε / 2 / 2
               since Real.divide_cancel;
           -- First piece: (f-error)·g(y) ≤ (ε/2)·|y − x|.
           calc abs((f(y) - f(x) - fSlope * (y - x)) * g(y))
              = abs(f(y) - f(x) - fSlope * (y - x)) * abs(g(y))
                    since Real.absolute_value_multiplicative
              ≤ (ε / 2 / gHeadroom * abs(y - x)) * gHeadroom
                    since Real.LessOrEqual.multiply_monotone_nonneg
              = (gHeadroom * (ε / 2 / gHeadroom)) * abs(y - x)
              = ε / 2 * abs(y - x)
                    since collapseFirst;
           -- Second piece: f(x)·(g-error) ≤ (ε/4)·|y − x|.
           calc abs(f(x) * (g(y) - g(x) - gSlope * (y - x)))
              = abs(f(x)) * abs(g(y) - g(x) - gSlope * (y - x))
                    since Real.absolute_value_multiplicative
              ≤ fRoof * (ε / 2 / 2 / fRoof * abs(y - x))
                    since Real.LessOrEqual.multiply_monotone_nonneg
              = (fRoof * (ε / 2 / 2 / fRoof)) * abs(y - x)
              = ε / 2 / 2 * abs(y - x)
                    since collapseSecond;
           -- Third piece: f′·(y − x)·(g(y) − g(x)) ≤ (ε/4)·|y − x|.
           claim abs(y - x) * abs(g(y) - g(x))
                   ≤ abs(y - x) * (ε / 2 / 2 / slopeRoof)
               since Real.LessOrEqual.multiply_monotone_nonneg;
           calc abs(fSlope * ((y - x) * (g(y) - g(x))))
              = abs(fSlope) * abs((y - x) * (g(y) - g(x)))
                    since Real.absolute_value_multiplicative
              = abs(fSlope) * (abs(y - x) * abs(g(y) - g(x)))
                    since Real.absolute_value_multiplicative
              ≤ slopeRoof * (abs(y - x) * (ε / 2 / 2 / slopeRoof))
                    since Real.LessOrEqual.multiply_monotone_nonneg
              = (slopeRoof * (ε / 2 / 2 / slopeRoof)) * abs(y - x)
              = ε / 2 / 2 * abs(y - x)
                    since collapseThird;
           -- Assemble: triangle inequality twice, then ε/2 + ε/4 + ε/4.
           claim abs(f(x) * (g(y) - g(x) - gSlope * (y - x))
                       + fSlope * ((y - x) * (g(y) - g(x))))
                   ≤ abs(f(x) * (g(y) - g(x) - gSlope * (y - x)))
                     + abs(fSlope * ((y - x) * (g(y) - g(x))))
               by Real.triangle_inequality;
           calc abs(f(x) * (g(y) - g(x) - gSlope * (y - x)))
                + abs(fSlope * ((y - x) * (g(y) - g(x))))
              ≤ ε / 2 / 2 * abs(y - x)
                + abs(fSlope * ((y - x) * (g(y) - g(x))))
                    by Real.add_preserves_LessOrEqual
              ≤ ε / 2 / 2 * abs(y - x) + ε / 2 / 2 * abs(y - x)
                    since Real.add_preserves_LessOrEqual_left;
           calc abs(f(y) * g(y) - f(x) * g(x)
                    - (fSlope * g(x) + f(x) * gSlope) * (y - x))
              = abs((f(y) - f(x) - fSlope * (y - x)) * g(y)
                    + (f(x) * (g(y) - g(x) - gSlope * (y - x))
                       + fSlope * ((y - x) * (g(y) - g(x)))))
                    by ((f(y) - f(x) - fSlope * (y - x)) * g(y)
                        + (f(x) * (g(y) - g(x) - gSlope * (y - x))
                           + fSlope * ((y - x) * (g(y) - g(x))))
                        = f(y) * g(y) - f(x) * g(x)
                          - (fSlope * g(x) + f(x) * gSlope) * (y - x))
              ≤ abs((f(y) - f(x) - fSlope * (y - x)) * g(y))
                + abs(f(x) * (g(y) - g(x) - gSlope * (y - x))
                      + fSlope * ((y - x) * (g(y) - g(x))))
                    by Real.triangle_inequality
              ≤ ε / 2 * abs(y - x)
                + abs(f(x) * (g(y) - g(x) - gSlope * (y - x))
                      + fSlope * ((y - x) * (g(y) - g(x))))
                    by Real.add_preserves_LessOrEqual
              ≤ ε / 2 * abs(y - x)
                + (abs(f(x) * (g(y) - g(x) - gSlope * (y - x)))
                   + abs(fSlope * ((y - x) * (g(y) - g(x)))))
                    since Real.add_preserves_LessOrEqual_left
              ≤ ε / 2 * abs(y - x)
                + (ε / 2 / 2 * abs(y - x) + ε / 2 / 2 * abs(y - x))
                    since Real.add_preserves_LessOrEqual_left
              = (ε / 2 + (ε / 2 / 2 + ε / 2 / 2)) * abs(y - x)
              = (ε / 2 + ε / 2) * abs(y - x)
                    by substituting Real.divide_two_doubled(ε / 2)
              = ε * abs(y - x)
                    by substituting Real.divide_two_doubled(ε)
         }⟩
  }

-- The derivative is unique: two slopes that both approximate f at x to
-- within every ε·|y − x| are equal. Probe both approximations at x + d
-- for a small positive d, cancel d, and squeeze.
theorem Real.HasDerivativeAt.unique (f : Real → Real) (x L1 L2 : Real)
        (firstDerivative : Real.HasDerivativeAt(f, x, L1))
        (secondDerivative : Real.HasDerivativeAt(f, x, L2))
        : L1 = L2 := {
  claim ∀ (ε : Real). ε > 0 → abs(L1 - L2) < ε
      by {
        take ε : Real;
        take εPositive : ε > 0;
        claim (2 : Real) > 0 since Real.two_positive;
        claim (2 : Real) ≠ 0 since Real.two_is_nonzero;
        claim ε / 2 > 0 since Real.divide_positive;
        claim quarterPositive : ε / 2 / 2 > 0 since Real.divide_positive;
        choose δ1 from firstDerivative(ε / 2 / 2, quarterPositive);
        claim firstClose : ∀ (y : Real). abs(y - x) < δ1
                → abs(f(y) - f(x) - L1 * (y - x)) ≤ ε / 2 / 2 * abs(y - x);
        choose δ2 from secondDerivative(ε / 2 / 2, quarterPositive);
        claim secondClose : ∀ (y : Real). abs(y - x) < δ2
                → abs(f(y) - f(x) - L2 * (y - x)) ≤ ε / 2 / 2 * abs(y - x);
        claim min(δ1, δ2) > 0 since Real.minimum_positive;
        -- Probing at any point x + d strictly inside the shared δ bounds
        -- the slope gap by ε/2.
        claim probe : ∀ (d : Real). d > 0 → d < min(δ1, δ2)
                      → abs(L1 - L2) ≤ ε / 2
            by {
              take d : Real;
              take dPositive : d > 0;
              take dSmall : d < min(δ1, δ2);
              claim d ≥ 0 since Real.LessThan.weaken;
              claim Real.IsNonneg(d) since Real.IsNonneg_of_LessOrEqual_zero;
              calc abs(x + d - x)
                 = abs(d)   by (x + d - x = d)
                 = d        by Real.absolute_value_when_nonneg
                 as distanceEquation;
              claim min(δ1, δ2) ≤ δ1 since Real.minimum_LessOrEqual_left;
              claim min(δ1, δ2) ≤ δ2 since Real.minimum_LessOrEqual_right;
              calc abs(x + d - x)
                 = d
                 < min(δ1, δ2)    by dSmall
                 ≤ δ1
                 as probeClose1;
              calc abs(x + d - x)
                 = d
                 < min(δ1, δ2)    by dSmall
                 ≤ δ2
                 as probeClose2;
              claim abs(f(x + d) - f(x) - L1 * (x + d - x))
                      ≤ ε / 2 / 2 * abs(x + d - x)
                  by firstClose(x + d, probeClose1);
              claim abs(f(x + d) - f(x) - L2 * (x + d - x))
                      ≤ ε / 2 / 2 * abs(x + d - x)
                  by secondClose(x + d, probeClose2);
              calc abs(L1 - L2) * d
                 = abs(L1 - L2) * abs(x + d - x)
                       since distanceEquation
                 = abs((L1 - L2) * (x + d - x))
                       since Real.absolute_value_multiplicative
                 = abs((f(x + d) - f(x) - L2 * (x + d - x))
                       - (f(x + d) - f(x) - L1 * (x + d - x)))
                       by ((L1 - L2) * (x + d - x)
                           = (f(x + d) - f(x) - L2 * (x + d - x))
                             - (f(x + d) - f(x) - L1 * (x + d - x)))
                 ≤ abs(f(x + d) - f(x) - L2 * (x + d - x))
                   + abs(-(f(x + d) - f(x) - L1 * (x + d - x)))
                       by Real.triangle_inequality
                 = abs(f(x + d) - f(x) - L2 * (x + d - x))
                   + abs(f(x + d) - f(x) - L1 * (x + d - x))
                       since Real.absolute_value_negate
                 ≤ ε / 2 / 2 * abs(x + d - x)
                   + abs(f(x + d) - f(x) - L1 * (x + d - x))
                       by Real.add_preserves_LessOrEqual
                 ≤ ε / 2 / 2 * abs(x + d - x)
                   + ε / 2 / 2 * abs(x + d - x)
                       since Real.add_preserves_LessOrEqual_left
                 = (ε / 2 / 2 + ε / 2 / 2) * abs(x + d - x)
                 = ε / 2 * abs(x + d - x)
                       by substituting Real.divide_two_doubled(ε / 2)
                 = ε / 2 * d
                       since distanceEquation
                 as productBound;
              calc d * abs(L1 - L2)
                 = abs(L1 - L2) * d
                 ≤ ε / 2 * d         by productBound
                 = d * (ε / 2);
              done by Real.LessOrEqual.multiply_cancel_left_positive
            };
        -- Instantiate the probe at half the shared δ and squeeze.
        claim probeValuePositive : min(δ1, δ2) / 2 > 0
            since Real.divide_positive;
        claim probeValueSmall : min(δ1, δ2) / 2 < min(δ1, δ2)
            since Real.divide_two_less_than_self;
        claim slopeBound : abs(L1 - L2) ≤ ε / 2
            by probe(min(δ1, δ2) / 2, probeValuePositive, probeValueSmall);
        claim εHalfBelow : ε / 2 < ε since Real.divide_two_less_than_self;
        calc abs(L1 - L2)
           ≤ ε / 2   by slopeBound
           < ε       by εHalfBelow
      };
  claim differenceIsZero : L1 - L2 = Real.zero
      since Real.eq_of_absolute_value_less_than_all_positive_real;
  Real.eq_of_sub_eq_zero(L1, L2, differenceIsZero)
}

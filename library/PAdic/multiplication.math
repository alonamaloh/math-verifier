-- PAdic/multiplication.math
--
-- p-adic multiplication via the pointwise product of representative
-- p-adic Cauchy sequences. Mirrors `library/Real/multiplication.math`;
-- the only differences are the absolute value used (padic vs standard)
-- and the boundedness lemma. Reuses the pure-Rational helpers
-- (`Rational.multiply_negate_right`, `Rational.product_difference_decomposition`,
-- `Rational.factor_subtract_distribute`, `Rational.from_natural_le_preserves`)
-- proved in Real.multiplication.

module PAdic.multiplication

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.maximum
import Natural.prime
import Rational.basics
import Rational.embedding
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value
import Rational.halve
import Rational.positive
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.triangle
import Real.multiplication
import PAdic.absolute_value
import PAdic.basics
import PAdic.addition
import PAdic.cauchy_bounded

convention p : Natural with primality : Natural.is_prime(p)

-- ----------------------------------------------------------------------
-- The bound chain extracted as a separate theorem to keep the
-- existential-elimination chain in product_is_padic_cauchy readable. Given
-- all bounds and Cauchy witnesses, conclude the product is bounded by
-- ε at indices m, n ≥ max of all the witness indices.
theorem Rational.sequence.product_is_padic_cauchy_bound
        (s t : Rational.sequence.Sequence) (epsilon : Rational)
        (K_s K_t : Natural)
        (delta_s delta_t : Rational)
        (N_s_bound N_t_bound N_s N_t m n : Natural)
        (m_ge : Natural.maximum(
                    Natural.maximum(N_s_bound, N_t_bound),
                    Natural.maximum(N_s, N_t)) ≤ m)
        (n_ge : Natural.maximum(
                    Natural.maximum(N_s_bound, N_t_bound),
                    Natural.maximum(N_s, N_t)) ≤ n)
        (sBound : (m_arg : Natural) → N_s_bound ≤ m_arg →
                    Rational.padic_absolute_value(p, primality, s(m_arg))
                      ≤ (successor(K_s) : Rational))
        (tBound : (n_arg : Natural) → N_t_bound ≤ n_arg →
                    Rational.padic_absolute_value(p, primality, t(n_arg))
                      ≤ (successor(K_t) : Rational))
        (sCauchyAt : (m_arg : Natural) → N_s ≤ m_arg →
                       (n_arg : Natural) → N_s ≤ n_arg →
                         Rational.padic_absolute_value(p, primality, s(m_arg) - s(n_arg))
                           < delta_s)
        (tCauchyAt : (m_arg : Natural) → N_t ≤ m_arg →
                       (n_arg : Natural) → N_t ≤ n_arg →
                         Rational.padic_absolute_value(p, primality, t(m_arg) - t(n_arg))
                           < delta_t)
        (succ_K_t_delta_s_bound : (successor(K_t) : Rational) * delta_s
                                    ≤ Rational.halve(Rational.halve(epsilon)))
        (succ_K_s_delta_t_bound : (successor(K_s) : Rational) * delta_t
                                    ≤ Rational.halve(Rational.halve(epsilon)))
        (epsilonPositive : Rational.zero < epsilon)
        : Rational.padic_absolute_value(p, primality, s(m) * t(m) - s(n) * t(n)) < epsilon := {
  -- m, n ≥ N_s_bound, N_t_bound, N_s, N_t. Each is one left-then-{left,right}
  -- projection through the nested max, via le_through_max_{left,right}.
  claim m_ge_N_s_bound : N_s_bound ≤ m
    by Natural.le_through_max_left(N_s_bound, N_t_bound, m,
           Natural.le_through_max_left(
               Natural.maximum(N_s_bound, N_t_bound),
               Natural.maximum(N_s, N_t), m, m_ge));
  claim n_ge_N_t_bound : N_t_bound ≤ n
    by Natural.le_through_max_right(N_s_bound, N_t_bound, n,
           Natural.le_through_max_left(
               Natural.maximum(N_s_bound, N_t_bound),
               Natural.maximum(N_s, N_t), n, n_ge));
  claim m_ge_N_s : N_s ≤ m
    by Natural.le_through_max_left(N_s, N_t, m,
           Natural.le_through_max_right(
               Natural.maximum(N_s_bound, N_t_bound),
               Natural.maximum(N_s, N_t), m, m_ge));
  claim n_ge_N_s : N_s ≤ n
    by Natural.le_through_max_left(N_s, N_t, n,
           Natural.le_through_max_right(
               Natural.maximum(N_s_bound, N_t_bound),
               Natural.maximum(N_s, N_t), n, n_ge));
  claim m_ge_N_t : N_t ≤ m
    by Natural.le_through_max_right(N_s, N_t, m,
           Natural.le_through_max_right(
               Natural.maximum(N_s_bound, N_t_bound),
               Natural.maximum(N_s, N_t), m, m_ge));
  claim n_ge_N_t : N_t ≤ n
    by Natural.le_through_max_right(N_s, N_t, n,
           Natural.le_through_max_right(
               Natural.maximum(N_s_bound, N_t_bound),
               Natural.maximum(N_s, N_t), n, n_ge));
  -- Specific bounds at m, n.
  claim s_at_m_bound : Rational.padic_absolute_value(p, primality, s(m)) ≤ (successor(K_s) : Rational)
    by sBound(m, m_ge_N_s_bound);
  claim t_at_n_bound : Rational.padic_absolute_value(p, primality, t(n)) ≤ (successor(K_t) : Rational)
    by tBound(n, n_ge_N_t_bound);
  claim s_diff_bound : Rational.padic_absolute_value(p, primality, s(m) - s(n)) < delta_s
    by sCauchyAt(m, m_ge_N_s, n, n_ge_N_s);
  claim t_diff_bound : Rational.padic_absolute_value(p, primality, t(m) - t(n)) < delta_t
    by tCauchyAt(m, m_ge_N_t, n, n_ge_N_t);
  claim s_diff_weak : Rational.padic_absolute_value(p, primality, s(m) - s(n)) ≤ delta_s
    by Rational.LessThan.weaken(
           Rational.padic_absolute_value(p, primality, s(m) - s(n)), delta_s, s_diff_bound);
  claim t_diff_weak : Rational.padic_absolute_value(p, primality, t(m) - t(n)) ≤ delta_t
    by Rational.LessThan.weaken(
           Rational.padic_absolute_value(p, primality, t(m) - t(n)), delta_t, t_diff_bound);
  claim sum_abs_bound
      : Rational.padic_absolute_value(p, primality,
            s(m) * (t(m) - t(n)) + t(n) * (s(m) - s(n)))
          ≤ Rational.padic_absolute_value(p, primality, s(m) * (t(m) - t(n)))
            + Rational.padic_absolute_value(p, primality, t(n) * (s(m) - s(n)))
    by Rational.padic_absolute_value_triangle(p, primality,
           s(m) * (t(m) - t(n)),
           t(n) * (s(m) - s(n)));
  claim first_factor_bound
      : Rational.padic_absolute_value(p, primality, s(m))
            * Rational.padic_absolute_value(p, primality, t(m) - t(n))
          ≤ (successor(K_s) : Rational)
            * Rational.padic_absolute_value(p, primality, t(m) - t(n))
    by Rational.LessOrEqual.multiply_by_nonneg_right(
           Rational.padic_absolute_value(p, primality, s(m)),
           (successor(K_s) : Rational),
           Rational.padic_absolute_value(p, primality, t(m) - t(n)),
           s_at_m_bound,
           Rational.padic_absolute_value_nonneg(p, primality, t(m) - t(n)));
  claim first_factor_bound_2
      : (successor(K_s) : Rational)
            * Rational.padic_absolute_value(p, primality, t(m) - t(n))
          ≤ (successor(K_s) : Rational) * delta_t
    by Rational.LessOrEqual.multiply_by_nonneg_left(
           Rational.padic_absolute_value(p, primality, t(m) - t(n)),
           delta_t,
           (successor(K_s) : Rational),
           t_diff_weak,
           Rational.LessOrEqual_zero_of_IsNonneg(
               (successor(K_s) : Rational),
               Integer.from_natural_is_nonneg(successor(K_s))));
  claim second_factor_bound
      : Rational.padic_absolute_value(p, primality, t(n))
            * Rational.padic_absolute_value(p, primality, s(m) - s(n))
          ≤ (successor(K_t) : Rational)
            * Rational.padic_absolute_value(p, primality, s(m) - s(n))
    by Rational.LessOrEqual.multiply_by_nonneg_right(
           Rational.padic_absolute_value(p, primality, t(n)),
           (successor(K_t) : Rational),
           Rational.padic_absolute_value(p, primality, s(m) - s(n)),
           t_at_n_bound,
           Rational.padic_absolute_value_nonneg(p, primality, s(m) - s(n)));
  claim second_factor_bound_2
      : (successor(K_t) : Rational)
            * Rational.padic_absolute_value(p, primality, s(m) - s(n))
          ≤ (successor(K_t) : Rational) * delta_s
    by Rational.LessOrEqual.multiply_by_nonneg_left(
           Rational.padic_absolute_value(p, primality, s(m) - s(n)),
           delta_s,
           (successor(K_t) : Rational),
           s_diff_weak,
           Rational.LessOrEqual_zero_of_IsNonneg(
               (successor(K_t) : Rational),
               Integer.from_natural_is_nonneg(successor(K_t))));
  calc Rational.padic_absolute_value(p, primality, s(m) * (t(m) - t(n)))
     = Rational.padic_absolute_value(p, primality, s(m))
         * Rational.padic_absolute_value(p, primality, t(m) - t(n))
     ≤ (successor(K_s) : Rational)
         * Rational.padic_absolute_value(p, primality, t(m) - t(n))
           by first_factor_bound
     ≤ (successor(K_s) : Rational) * delta_t
           by first_factor_bound_2
     ≤ Rational.halve(Rational.halve(epsilon))
           by succ_K_s_delta_t_bound                        as first_total_bound;
  calc Rational.padic_absolute_value(p, primality, t(n) * (s(m) - s(n)))
     = Rational.padic_absolute_value(p, primality, t(n))
         * Rational.padic_absolute_value(p, primality, s(m) - s(n))
     ≤ (successor(K_t) : Rational)
         * Rational.padic_absolute_value(p, primality, s(m) - s(n))
           by second_factor_bound
     ≤ (successor(K_t) : Rational) * delta_s
           by second_factor_bound_2
     ≤ Rational.halve(Rational.halve(epsilon))
           by succ_K_t_delta_s_bound                        as second_total_bound;
  claim sum_total_bound
      : Rational.padic_absolute_value(p, primality, s(m) * (t(m) - t(n)))
            + Rational.padic_absolute_value(p, primality, t(n) * (s(m) - s(n)))
          ≤ Rational.halve(epsilon)
    by rewrite(
           Rational.halve_doubled(Rational.halve(epsilon)),
           Rational.LessOrEqual.sum(
               Rational.padic_absolute_value(p, primality, s(m) * (t(m) - t(n))),
               Rational.halve(Rational.halve(epsilon)),
               Rational.padic_absolute_value(p, primality, t(n) * (s(m) - s(n))),
               Rational.halve(Rational.halve(epsilon)),
               first_total_bound,
               second_total_bound));
  -- Triangle on the regrouped form; ≤ ε/2 by the two halves;
  -- < ε by halve_less_than_self. Single calc chain.
  calc Rational.padic_absolute_value(p, primality, s(m) * t(m) - s(n) * t(n))
     = Rational.padic_absolute_value(p, primality,
           s(m) * (t(m) - t(n)) + t(n) * (s(m) - s(n)))
     ≤ Rational.padic_absolute_value(p, primality, s(m) * (t(m) - t(n)))
           + Rational.padic_absolute_value(p, primality, t(n) * (s(m) - s(n)))
          by sum_abs_bound
     ≤ Rational.halve(epsilon)
          by sum_total_bound
     < epsilon
          by Rational.halve_less_than_self(epsilon, epsilonPositive)
}

-- ----------------------------------------------------------------------
-- product_is_padic_cauchy: the load-bearing analytic proof.

theorem Rational.sequence.product_is_padic_cauchy
        (s t : Rational.sequence.Sequence)
        (sIsCauchy : Rational.sequence.IsPAdicCauchy(p, primality, s))
        (tIsCauchy : Rational.sequence.IsPAdicCauchy(p, primality, t))
        : Rational.sequence.IsPAdicCauchy(p, primality,
              function (n : Natural) => s(n) * t(n)) :=
  function (epsilon : Rational)
           (epsilonPositive : Rational.zero < epsilon) => {
    -- Step 1: bound |s| eventually by (succ K_s : R) starting from N_s_bound.
    obtain ⟨K_s, N_s_bound, sBound⟩
        from Rational.sequence.cauchy_is_padic_naturally_bounded(
                 p, primality, s, sIsCauchy);
    -- Step 2: similar for t.
    obtain ⟨K_t, N_t_bound, tBound⟩
        from Rational.sequence.cauchy_is_padic_naturally_bounded(
                 p, primality, t, tIsCauchy);
    -- Step 3: get δ_s with (succ K_t) · δ_s ≤ ε/4.
    obtain ⟨delta_s, delta_s_pos, delta_s_bound⟩
        from Rational.divide_by_succ_positive(
            Rational.halve(Rational.halve(epsilon)),
            K_t,
            Rational.halve_positive(
                Rational.halve(epsilon),
                Rational.halve_positive(epsilon, epsilonPositive)));
    obtain ⟨delta_t, delta_t_pos, delta_t_bound⟩
        from Rational.divide_by_succ_positive(
            Rational.halve(Rational.halve(epsilon)),
            K_s,
            Rational.halve_positive(
                Rational.halve(epsilon),
                Rational.halve_positive(epsilon, epsilonPositive)));
    -- Step 5: apply sCauchy(δ_s) and tCauchy(δ_t).
    obtain ⟨N_s, sCauchyAt⟩ from sIsCauchy(delta_s, delta_s_pos);
    obtain ⟨N_t, tCauchyAt⟩ from tIsCauchy(delta_t, delta_t_pos);
    -- Final N := max(N_s_bound, N_t_bound, N_s, N_t).
    witness Natural.maximum(
                Natural.maximum(N_s_bound, N_t_bound),
                Natural.maximum(N_s, N_t)) with
        function (m : Natural)
                 (m_ge : Natural.maximum(
                            Natural.maximum(N_s_bound, N_t_bound),
                            Natural.maximum(N_s, N_t)) ≤ m)
                 (n : Natural)
                 (n_ge : Natural.maximum(
                            Natural.maximum(N_s_bound, N_t_bound),
                            Natural.maximum(N_s, N_t)) ≤ n) =>
          -- Bound chain proof comes here.
          Rational.sequence.product_is_padic_cauchy_bound(
              p, primality,
              s, t, epsilon,
              K_s, K_t,
              delta_s, delta_t,
              N_s_bound, N_t_bound, N_s, N_t,
              m, n,
              m_ge, n_ge,
              sBound, tBound,
              sCauchyAt, tCauchyAt,
              delta_s_bound,
              delta_t_bound,
              epsilonPositive)
  }

-- ----------------------------------------------------------------------
-- Restore PAdicCauchySequence.multiply and the PAdic-level lifts.

definition PAdicCauchySequence.multiply
        : PAdicCauchySequence(p, primality)
          → PAdicCauchySequence(p, primality)
          → PAdicCauchySequence(p, primality)
  | PAdicCauchySequence.make(s, sCauchy),
    PAdicCauchySequence.make(t, tCauchy) =>
      PAdicCauchySequence.make(
          function (n : Natural) => s(n) * t(n),
          Rational.sequence.product_is_padic_cauchy(p, primality, s, t, sCauchy, tCauchy))

-- sf(multiply(rep_x, rep_y), m) = sf(rep_x, m) * sf(rep_y, m).
theorem PAdicCauchySequence.sequenceFunction_multiply
        : (rep_x rep_y : PAdicCauchySequence(p, primality)) → (m : Natural)
          → PAdicCauchySequence.sequenceFunction(
                p, primality,
                PAdicCauchySequence.multiply(p, primality, rep_x, rep_y), m)
            = PAdicCauchySequence.sequenceFunction(p, primality, rep_x, m)
              * PAdicCauchySequence.sequenceFunction(p, primality, rep_y, m)
  | PAdicCauchySequence.make(sa, _),
    PAdicCauchySequence.make(sb, _),
    m =>
      reflexivity(Rational, sa(m) * sb(m))

-- The respect-proof inner chain: given the bound |s_x(m)| ≤ (succ K : R)
-- and the difference bound |s_y(m) - s_y'(m)| < δ, conclude
-- |s_x(m)*s_y(m) - s_x(m)*s_y'(m)| < ε via the (succ K)*δ ≤ halve(ε)
-- + halve_less_than_self chain.
theorem PAdic.multiply_respect_bound_chain
        (s_x s_y s_yPrime : Rational.sequence.Sequence)
        (epsilon : Rational) (K : Natural) (delta : Rational)
        (m : Natural)
        (s_x_at_m_bound : Rational.padic_absolute_value(p, primality, s_x(m))
                            ≤ (successor(K) : Rational))
        (s_y_diff_bound : Rational.padic_absolute_value(p, primality, s_y(m) - s_yPrime(m))
                            < delta)
        (delta_bound : Rational.LessOrEqual(
                           (successor(K) : Rational) * delta,
                           Rational.halve(epsilon)))
        (epsilonPositive : Rational.zero < epsilon)
        : Rational.padic_absolute_value(p, primality, s_x(m) * s_y(m) - s_x(m) * s_yPrime(m))
            < epsilon := {
  claim s_y_diff_weak : Rational.padic_absolute_value(p, primality, s_y(m) - s_yPrime(m)) ≤ delta
    by Rational.LessThan.weaken(
           Rational.padic_absolute_value(p, primality, s_y(m) - s_yPrime(m)), delta, s_y_diff_bound);
  claim step1
      : Rational.padic_absolute_value(p, primality, s_x(m))
            * Rational.padic_absolute_value(p, primality, s_y(m) - s_yPrime(m))
          ≤ (successor(K) : Rational)
            * Rational.padic_absolute_value(p, primality, s_y(m) - s_yPrime(m))
    by Rational.LessOrEqual.multiply_by_nonneg_right(
           Rational.padic_absolute_value(p, primality, s_x(m)),
           (successor(K) : Rational),
           Rational.padic_absolute_value(p, primality, s_y(m) - s_yPrime(m)),
           s_x_at_m_bound,
           Rational.padic_absolute_value_nonneg(p, primality, s_y(m) - s_yPrime(m)));
  claim step2
      : (successor(K) : Rational)
            * Rational.padic_absolute_value(p, primality, s_y(m) - s_yPrime(m))
          ≤ (successor(K) : Rational) * delta
    by Rational.LessOrEqual.multiply_by_nonneg_left(
           Rational.padic_absolute_value(p, primality, s_y(m) - s_yPrime(m)),
           delta,
           (successor(K) : Rational),
           s_y_diff_weak,
           Rational.LessOrEqual_zero_of_IsNonneg(
               (successor(K) : Rational),
               Integer.from_natural_is_nonneg(successor(K))));
  -- Factor s_x(m) out; |·| splits multiplicatively; bound |s_x| by
  -- (K+1), then |s_y - s_yPrime| by δ; finally δ·(K+1) ≤ ε/2 < ε.
  calc Rational.padic_absolute_value(p, primality, s_x(m) * s_y(m) - s_x(m) * s_yPrime(m))
     = Rational.padic_absolute_value(p, primality, s_x(m) * (s_y(m) - s_yPrime(m)))
     = Rational.padic_absolute_value(p, primality, s_x(m))
           * Rational.padic_absolute_value(p, primality, s_y(m) - s_yPrime(m))
     ≤ (successor(K) : Rational)
           * Rational.padic_absolute_value(p, primality, s_y(m) - s_yPrime(m))
          by step1
     ≤ (successor(K) : Rational) * delta
          by step2
     ≤ Rational.halve(epsilon)
          by delta_bound
     < epsilon
          by Rational.halve_less_than_self(epsilon, epsilonPositive)
}

-- Helper: produce the PAdicEquivalent proof body for the at-rep
-- multiply respect. Given fixed s_x with a Natural bound, and yEquiv,
-- show the product sequences are PAdicEquivalent.
theorem PAdic.multiply_after_first_respects_at_rep_inner
        (s_x : Rational.sequence.Sequence)
        (sCauchy_x : Rational.sequence.IsPAdicCauchy(p, primality, s_x))
        (s_y s_yPrime : Rational.sequence.Sequence)
        (sCauchy_y : Rational.sequence.IsPAdicCauchy(p, primality, s_y))
        (sCauchy_yPrime : Rational.sequence.IsPAdicCauchy(p, primality, s_yPrime))
        (refinedYEquiv : PAdicEquivalent(p, primality,
                             PAdicCauchySequence.make(s_y, sCauchy_y),
                             PAdicCauchySequence.make(s_yPrime, sCauchy_yPrime)))
        (epsilon : Rational) (epsilonPositive : Rational.zero < epsilon)
        : ∃ (N : Natural).
            (m : Natural) → N ≤ m →
              Rational.padic_absolute_value(p, primality, s_x(m) * s_y(m) - s_x(m) * s_yPrime(m))
                < epsilon := {
    obtain ⟨K, N_x_bound, xBound⟩
        from Rational.sequence.cauchy_is_padic_naturally_bounded(
                 p, primality, s_x, sCauchy_x);
    obtain ⟨delta, delta_pos, delta_bound⟩
        from Rational.divide_by_succ_positive(
            Rational.halve(epsilon), K,
            Rational.halve_positive(epsilon, epsilonPositive));
    obtain ⟨N_y, yEquivAt⟩ from refinedYEquiv(delta, delta_pos);
    witness Natural.maximum(N_x_bound, N_y) with
        function (m : Natural)
                 (m_ge_max : Natural.maximum(N_x_bound, N_y) ≤ m) =>
          PAdic.multiply_respect_bound_chain(
              p, primality,
              s_x, s_y, s_yPrime,
              epsilon, K, delta, m,
              xBound(m,
                  Natural.le_through_max_left(N_x_bound, N_y, m, m_ge_max)),
              yEquivAt(m,
                  Natural.le_through_max_right(N_x_bound, N_y, m, m_ge_max)),
              delta_bound,
              epsilonPositive)
}

-- multiply_after_first_respects: rep_x fixed, y varies.
-- Multi-pattern destructure on all three reps so the bound on s_x is
-- accessible (cauchy_is_padic_naturally_bounded needs the underlying
-- sequence). The inner ε-N bound is supplied by _at_rep_inner.
theorem PAdic.multiply_after_first_respects
        : (rep_x rep_y rep_yPrime : PAdicCauchySequence(p, primality))
          → PAdicEquivalent(p, primality, rep_y, rep_yPrime)
          → (Quotient.mk(PAdicCauchySequence.multiply(p, primality, rep_x, rep_y))
             : PAdic(p, primality))
            = Quotient.mk(PAdicCauchySequence.multiply(p, primality, rep_x, rep_yPrime))
  | PAdicCauchySequence.make(s_x, sCauchy_x),
    PAdicCauchySequence.make(s_y, sCauchy_y),
    PAdicCauchySequence.make(s_yPrime, sCauchy_yPrime),
    refinedYEquiv =>
      Quotient.sound(
          PAdicCauchySequence(p, primality), PAdicEquivalent(p, primality),
          PAdicCauchySequence.multiply(p, primality,
              PAdicCauchySequence.make(s_x, sCauchy_x),
              PAdicCauchySequence.make(s_y, sCauchy_y)),
          PAdicCauchySequence.multiply(p, primality,
              PAdicCauchySequence.make(s_x, sCauchy_x),
              PAdicCauchySequence.make(s_yPrime, sCauchy_yPrime)),
          function (epsilon : Rational)
                   (epsilonPositive : Rational.zero < epsilon) =>
            PAdic.multiply_after_first_respects_at_rep_inner(
                p, primality,
                s_x, sCauchy_x, s_y, s_yPrime,
                sCauchy_y, sCauchy_yPrime,
                refinedYEquiv,
                epsilon, epsilonPositive))

-- Symmetric inner-chain helper for multiply_respects_at_rep_y: y is
-- bounded, x varies via xEquiv.
theorem PAdic.multiply_respects_at_rep_y_inner
        (s_x : Rational.sequence.Sequence)
        (sCauchy_x : Rational.sequence.IsPAdicCauchy(p, primality, s_x))
        (s_xPrime : Rational.sequence.Sequence)
        (sCauchy_xPrime : Rational.sequence.IsPAdicCauchy(p, primality, s_xPrime))
        (s_y : Rational.sequence.Sequence)
        (sCauchy_y : Rational.sequence.IsPAdicCauchy(p, primality, s_y))
        (refinedXEquiv : PAdicEquivalent(p, primality,
                             PAdicCauchySequence.make(s_x, sCauchy_x),
                             PAdicCauchySequence.make(s_xPrime, sCauchy_xPrime)))
        (epsilon : Rational) (epsilonPositive : Rational.zero < epsilon)
        : ∃ (N : Natural).
            (m : Natural) → N ≤ m →
              Rational.padic_absolute_value(p, primality, s_x(m) * s_y(m) - s_xPrime(m) * s_y(m))
                < epsilon :=
  -- Reduce to multiply_after_first_respects_at_rep_inner with s_y as
  -- the "fixed" sequence (bounded) and x varying.
  {
    obtain ⟨N, boundedY⟩
        from PAdic.multiply_after_first_respects_at_rep_inner(
                 p, primality,
                 s_y, sCauchy_y, s_x, s_xPrime, sCauchy_x, sCauchy_xPrime,
                 refinedXEquiv, epsilon, epsilonPositive);
    witness N with
        function (m : Natural) (N_leq_m : N ≤ m) => {
          claim rearrange : s_y(m) * s_x(m) - s_y(m) * s_xPrime(m)
                          = s_x(m) * s_y(m) - s_xPrime(m) * s_y(m)
            by ring;
          rewrite(rearrange, boundedY(m, N_leq_m))
        }
  }

-- Helper for multiply_respects: shows the at-rep-y version of the
-- product equivalence given xEquiv. Argument shape is symmetric to
-- multiply_after_first_respects but with the bound on the y-side.
-- Multi-pattern destructure on all three reps; inner ε-N bound is
-- supplied by _at_rep_y_inner.
theorem PAdic.multiply_respects_at_rep_y
        : (rep_x rep_xPrime rep_y : PAdicCauchySequence(p, primality))
          → PAdicEquivalent(p, primality, rep_x, rep_xPrime)
          → (Quotient.mk(PAdicCauchySequence.multiply(p, primality, rep_x, rep_y))
             : PAdic(p, primality))
            = Quotient.mk(PAdicCauchySequence.multiply(p, primality, rep_xPrime, rep_y))
  | PAdicCauchySequence.make(s_x, sCauchy_x),
    PAdicCauchySequence.make(s_xPrime, sCauchy_xPrime),
    PAdicCauchySequence.make(s_y, sCauchy_y),
    refinedXEquiv =>
      Quotient.sound(
          PAdicCauchySequence(p, primality), PAdicEquivalent(p, primality),
          PAdicCauchySequence.multiply(p, primality,
              PAdicCauchySequence.make(s_x, sCauchy_x),
              PAdicCauchySequence.make(s_y, sCauchy_y)),
          PAdicCauchySequence.multiply(p, primality,
              PAdicCauchySequence.make(s_xPrime, sCauchy_xPrime),
              PAdicCauchySequence.make(s_y, sCauchy_y)),
          function (epsilon : Rational)
                   (epsilonPositive : Rational.zero < epsilon) =>
            PAdic.multiply_respects_at_rep_y_inner(
                p, primality,
                s_x, sCauchy_x, s_xPrime, sCauchy_xPrime,
                s_y, sCauchy_y,
                refinedXEquiv,
                epsilon, epsilonPositive))

-- The full multiply respect proof: lifts over y.
theorem PAdic.multiply_respects
        (rep_x rep_xPrime : PAdicCauchySequence(p, primality))
        (xEquiv : PAdicEquivalent(p, primality, rep_x, rep_xPrime))
        (yPAdic : PAdic(p, primality))
        : Quotient.lift(
              function (rep_y : PAdicCauchySequence(p, primality)) =>
                  Quotient.mk(PAdicCauchySequence(p, primality), PAdicEquivalent(p, primality),
                               PAdicCauchySequence.multiply(p, primality, rep_x, rep_y)),
              PAdic.multiply_after_first_respects(p, primality, rep_x),
              yPAdic)
          = Quotient.lift(
              function (rep_y : PAdicCauchySequence(p, primality)) =>
                  Quotient.mk(PAdicCauchySequence(p, primality), PAdicEquivalent(p, primality),
                               PAdicCauchySequence.multiply(p, primality, rep_xPrime, rep_y)),
              PAdic.multiply_after_first_respects(p, primality, rep_xPrime),
              yPAdic) :=
  cases yPAdic {
    | rep_y =>
        PAdic.multiply_respects_at_rep_y(p, primality, rep_x, rep_xPrime, rep_y, xEquiv)
  }

definition PAdic.multiply_after_first
        (rep_x : PAdicCauchySequence(p, primality))
        (yPAdic : PAdic(p, primality)) : PAdic(p, primality) :=
  Quotient.lift(
      function (rep_y : PAdicCauchySequence(p, primality)) =>
          Quotient.mk(PAdicCauchySequence(p, primality), PAdicEquivalent(p, primality),
                       PAdicCauchySequence.multiply(p, primality, rep_x, rep_y)),
      PAdic.multiply_after_first_respects(p, primality, rep_x),
      yPAdic)

definition PAdic.multiply
        (x y : PAdic(p, primality)) : PAdic(p, primality) :=
  Quotient.lift(
      function (rep_x : PAdicCauchySequence(p, primality)) =>
          PAdic.multiply_after_first(p, primality, rep_x, y),
      function (rep_x rep_xPrime : PAdicCauchySequence(p, primality))
               (xEquiv : PAdicEquivalent(p, primality, rep_x, rep_xPrime)) =>
          PAdic.multiply_respects(p, primality, rep_x, rep_xPrime, xEquiv, y),
      x)

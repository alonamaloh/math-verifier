-- PAdic/instances.math
--
-- Witnesses that PAdic(p, primality) satisfies the standard algebraic
-- abstractions: an abelian group under (+, 0, −) and a commutative
-- ring under (+, ·, 0, 1). Each instance partially applies the
-- already-proved PAdic operations and laws to (p, primality).
--
-- The `convention p : Natural with primality : Natural.is_prime(p)` line below
-- automatically prepends `{p : Natural} {_ : Natural.is_prime(p)}`
-- to every subsequent theorem mentioning `p`. Each theorem body still
-- references `p` and `primality` (the implicit-binder names) freely;
-- the convention simply removes the explicit-binder boilerplate at
-- every theorem signature.

module PAdic.instances

import Logic.basics
import Equality.basics
import Natural.basics
import Natural.prime
import PAdic.basics
import PAdic.embedding
import PAdic.addition
import PAdic.negation
import PAdic.multiplication
import PAdic.ring
import PAdic.algebra
import Algebra.monoid
import Algebra.group
import Algebra.ring

convention p : Natural with primality : Natural.is_prime(p)

-- PAdic is a monoid under (+, 0). `convention` makes p / primality
-- implicit on PAdic.add / PAdic.zero / the axiom lemmas, so they are
-- passed bare — leading-implicit insertion recovers them from the
-- IsMonoid slots' expected types.
theorem PAdic.add_is_monoid
        : IsMonoid(PAdic(p, primality), PAdic.add, PAdic.zero) :=
    ⟨PAdic.add_associative, PAdic.zero_add, PAdic.add_zero⟩

-- PAdic is a commutative monoid under (+, 0).
theorem PAdic.add_is_commutative_monoid
        : IsCommutativeMonoid(PAdic(p, primality), PAdic.add, PAdic.zero) :=
    ⟨PAdic.add_is_monoid, PAdic.add_commutative⟩

-- PAdic is a group under (+, 0, −).
theorem PAdic.add_is_group
        : IsGroup(PAdic(p, primality), PAdic.add, PAdic.zero, PAdic.negate) :=
    ⟨PAdic.add_is_monoid, PAdic.add_negate_left, PAdic.add_negate_right⟩

-- PAdic is an abelian group under (+, 0, −).
theorem PAdic.add_is_abelian_group
        : IsAbelianGroup(PAdic(p, primality), PAdic.add, PAdic.zero,
                          PAdic.negate) :=
    ⟨PAdic.add_is_group, PAdic.add_commutative⟩

-- PAdic is a monoid under (·, 1).
theorem PAdic.multiply_is_monoid
        : IsMonoid(PAdic(p, primality), PAdic.multiply, PAdic.one) :=
    ⟨PAdic.multiply_associative, PAdic.one_multiply, PAdic.multiply_one⟩

-- PAdic is a commutative monoid under (·, 1).
theorem PAdic.multiply_is_commutative_monoid
        : IsCommutativeMonoid(PAdic(p, primality), PAdic.multiply,
                               PAdic.one) :=
    ⟨PAdic.multiply_is_monoid, PAdic.multiply_commutative⟩

-- PAdic is a ring.
theorem PAdic.is_ring
        : IsRing(PAdic(p, primality), PAdic.add, PAdic.zero, PAdic.negate,
                  PAdic.multiply, PAdic.one) :=
    ⟨PAdic.add_is_abelian_group, PAdic.multiply_is_monoid,
     PAdic.distributivity_left, PAdic.distributivity_right⟩

-- PAdic is a commutative ring.
theorem PAdic.is_commutative_ring
        : IsCommutativeRing(PAdic(p, primality), PAdic.add, PAdic.zero,
                             PAdic.negate, PAdic.multiply, PAdic.one) :=
    ⟨PAdic.is_ring, PAdic.multiply_commutative⟩

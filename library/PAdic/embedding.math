-- PAdic/embedding.math
--
-- Embed Rational into PAdic(p) for a fixed prime p, via the constant
-- Cauchy sequence λ _. q. No global coercion registered (the registry
-- doesn't carry a parameter); use Rational.to_padic(p, q) explicitly.

module PAdic.embedding

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.prime
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import PAdic.absolute_value
import PAdic.basics

convention p : Natural with primality : Natural.is_prime(p)

-- The constant Cauchy sequence is p-adic-Cauchy. With the honest
-- `padic_absolute_value`, the bound `|q - q|_p < ε` reduces via
-- `q - q = 0` and `|0|_p = 0` to `0 < ε`, witnessed by the input
-- positivity hypothesis.
theorem Rational.sequence.constant_is_padic_cauchy
        (q : Rational)
        : Rational.sequence.IsPAdicCauchy(p, primality,
              function (_ : Natural) => q) :=
  function (epsilon : Rational)
           (epsilonPositive : Rational.zero < epsilon) =>
    Exists.introduce(
        Natural,
        function (N : Natural) =>
          (m : Natural) → N ≤ m →
            (n : Natural) → N ≤ n →
              Rational.padic_absolute_value(p, primality, q - q) < epsilon,
        zero,
        function (m : Natural) (_ : zero ≤ m)
                 (n : Natural) (_ : zero ≤ n) =>
          -- q - q = Rational.zero. |Rational.zero|_p = Rational.zero
          -- by reflexivity (the lift on mk(make(zero, zero)) reduces
          -- through the inner cases on |0| = 0 to Rational.zero).
          -- So the bound reduces to 0 < epsilon.
          rewrite(
              Equality.symmetry(
                  Equality.transitivity(
                      congruenceOf(
                          function (r : Rational) =>
                              Rational.padic_absolute_value(p, primality, r),
                          Rational.add_negate_right(q)),
                      reflexivity(Rational, Rational.zero))),
              epsilonPositive))

definition Rational.to_padic_constant_sequence
        (q : Rational)
        : PAdicCauchySequence(p, primality) :=
  PAdicCauchySequence.make(
      function (_ : Natural) => q,
      Rational.sequence.constant_is_padic_cauchy(p, primality, q))

definition Rational.to_padic
        (q : Rational) : PAdic(p, primality) :=
  Quotient.mk(Rational.to_padic_constant_sequence(p, primality, q))

-- Canonical constants.
definition PAdic.zero : PAdic(p, primality) :=
  Rational.to_padic(p, primality, Rational.zero)

definition PAdic.one : PAdic(p, primality) :=
  Rational.to_padic(p, primality, Rational.one)

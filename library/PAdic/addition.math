-- PAdic/addition.math
--
-- Pointwise sum of p-adic Cauchy sequences, lifted to a binary
-- operation on PAdic(p, primality). Mirrors the Real addition
-- construction in `library/Real/addition.math`; the only differences
-- are the absolute value used in the Cauchy / equivalence conditions
-- and the triangle inequality invoked in the ε/2 split.

module PAdic.addition

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.maximum
import Natural.prime
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.halve
import Rational.positive
import Rational.order_arithmetic
import Real.addition
import PAdic.absolute_value
import PAdic.basics

convention p : Natural with primality : Natural.is_prime(p)

-- ----------------------------------------------------------------------
-- Cauchy-ness is preserved by pointwise addition.
--
-- Standard ε/2 split: pick N_s and N_t each witnessing the ε/2 bound
-- for s and t; take their max. Triangle on (s(m)+t(m))-(s(n)+t(n)) =
-- (s(m)-s(n)) + (t(m)-t(n)) gives the combined ε bound.
theorem Rational.sequence.sum_is_padic_cauchy
        (s t : Rational.sequence.Sequence)
        (sIsCauchy : Rational.sequence.IsPAdicCauchy(p, primality, s))
        (tIsCauchy : Rational.sequence.IsPAdicCauchy(p, primality, t))
        : Rational.sequence.IsPAdicCauchy(p, primality,
              function (n : Natural) => s(n) + t(n)) :=
  function (epsilon : Rational)
           (epsilonPositive : Rational.zero < epsilon) => {
    obtain ⟨N_s, sBound⟩
        from sIsCauchy(Rational.halve(epsilon),
                       Rational.halve_positive(epsilon, epsilonPositive));
    obtain ⟨N_t, tBound⟩
        from tIsCauchy(Rational.halve(epsilon),
                       Rational.halve_positive(epsilon, epsilonPositive));
    witness Natural.maximum(N_s, N_t) with
        function (m : Natural)
                 (m_ge_max : Natural.maximum(N_s, N_t) ≤ m)
                 (n : Natural)
                 (n_ge_max : Natural.maximum(N_s, N_t) ≤ n) =>
          calc Rational.padic_absolute_value(
                   p, primality,
                   s(m) + t(m) - (s(n) + t(n)))
             = Rational.padic_absolute_value(
                   p, primality,
                   (s(m) - s(n)) + (t(m) - t(n)))
             ≤ Rational.padic_absolute_value(
                   p, primality, s(m) - s(n))
                 + Rational.padic_absolute_value(
                       p, primality, t(m) - t(n))
                   by Rational.padic_absolute_value_triangle(
                          p, primality,
                          s(m) - s(n), t(m) - t(n))
             < Rational.halve(epsilon) + Rational.halve(epsilon)
                   by Rational.LessThan.add_strict_strict(
                          Rational.padic_absolute_value(
                              p, primality, s(m) - s(n)),
                          Rational.padic_absolute_value(
                              p, primality, t(m) - t(n)),
                          Rational.halve(epsilon),
                          sBound(m,
                              LessOrEqual.transitive(
                                  N_s, Natural.maximum(N_s, N_t), m,
                                  m_ge_max,
                                  Natural.left_le_max(N_s, N_t)),
                              n,
                              LessOrEqual.transitive(
                                  N_s, Natural.maximum(N_s, N_t), n,
                                  n_ge_max,
                                  Natural.left_le_max(N_s, N_t))),
                          tBound(m,
                              LessOrEqual.transitive(
                                  N_t, Natural.maximum(N_s, N_t), m,
                                  m_ge_max,
                                  Natural.right_le_max(N_s, N_t)),
                              n,
                              LessOrEqual.transitive(
                                  N_t, Natural.maximum(N_s, N_t), n,
                                  n_ge_max,
                                  Natural.right_le_max(N_s, N_t))))
             = epsilon
  }

-- Sum of two packaged p-adic Cauchy sequences.
definition PAdicCauchySequence.add
        : PAdicCauchySequence(p, primality)
          → PAdicCauchySequence(p, primality)
          → PAdicCauchySequence(p, primality)
  | PAdicCauchySequence.make(s, sCauchy),
    PAdicCauchySequence.make(t, tCauchy) =>
      PAdicCauchySequence.make(
          function (n : Natural) => s(n) + t(n),
          Rational.sequence.sum_is_padic_cauchy(
              p, primality, s, t, sCauchy, tCauchy))

-- sf(add(rep_x, rep_y), m) = sf(rep_x, m) + sf(rep_y, m). Bridges the
-- abstract sequenceFunction projector through the pattern-match
-- definition of add.
theorem PAdicCauchySequence.sequenceFunction_add
        : (rep_x rep_y : PAdicCauchySequence(p, primality))
          → (m : Natural)
          → PAdicCauchySequence.sequenceFunction(
                p, primality,
                PAdicCauchySequence.add(p, primality, rep_x, rep_y), m)
            = PAdicCauchySequence.sequenceFunction(p, primality, rep_x, m)
              + PAdicCauchySequence.sequenceFunction(p, primality, rep_y, m)
  | PAdicCauchySequence.make(sa, _),
    PAdicCauchySequence.make(sb, _),
    m =>
      reflexivity(Rational, sa(m) + sb(m))

-- Inner respect: with x fixed, λ y. mk(add(x, y)) respects
-- PAdicEquivalent. Uses the SAME ε (no halving): |(x_m + y_m) - (x_m + y'_m)|
-- collapses to |y_m - y'_m|. Bridge each sf(add(rep_x, rep_•), m) to
-- sf(rep_x, m) + sf(rep_•, m) via sequenceFunction_add, then ring on
-- the abstract sequenceFunction terms cancels.
theorem PAdic.add_after_first_respects
        (rep_x rep_y rep_yPrime : PAdicCauchySequence(p, primality))
        (yEquiv : PAdicEquivalent(p, primality, rep_y, rep_yPrime))
        : (Quotient.mk(
              PAdicCauchySequence.add(p, primality, rep_x, rep_y))
           : PAdic(p, primality))
          = Quotient.mk(
                PAdicCauchySequence.add(p, primality, rep_x, rep_yPrime)) :=
  Quotient.sound(
      PAdicCauchySequence(p, primality),
      PAdicEquivalent(p, primality),
      PAdicCauchySequence.add(p, primality, rep_x, rep_y),
      PAdicCauchySequence.add(p, primality, rep_x, rep_yPrime),
      function (epsilon : Rational)
               (epsilonPositive : Rational.zero < epsilon) =>
        ({
          obtain ⟨N, yEquiv_at_N⟩ from yEquiv(epsilon, epsilonPositive);
          witness N with
              function (m : Natural) (N_leq_m : N ≤ m) => {
                claim absBridge
                      : Rational.padic_absolute_value(
                            p, primality,
                            PAdicCauchySequence.sequenceFunction(
                                p, primality, rep_y, m)
                            - PAdicCauchySequence.sequenceFunction(
                                  p, primality, rep_yPrime, m))
                        = Rational.padic_absolute_value(
                              p, primality,
                              PAdicCauchySequence.sequenceFunction(
                                  p, primality,
                                  PAdicCauchySequence.add(
                                      p, primality, rep_x, rep_y), m)
                              - PAdicCauchySequence.sequenceFunction(
                                    p, primality,
                                    PAdicCauchySequence.add(
                                        p, primality, rep_x, rep_yPrime), m))
                  by calc Rational.padic_absolute_value(
                              p, primality,
                              PAdicCauchySequence.sequenceFunction(
                                  p, primality, rep_y, m)
                              - PAdicCauchySequence.sequenceFunction(
                                    p, primality, rep_yPrime, m))
                        = Rational.padic_absolute_value(
                              p, primality,
                              (PAdicCauchySequence.sequenceFunction(
                                   p, primality, rep_x, m)
                               + PAdicCauchySequence.sequenceFunction(
                                     p, primality, rep_y, m))
                              - (PAdicCauchySequence.sequenceFunction(
                                     p, primality, rep_x, m)
                                 + PAdicCauchySequence.sequenceFunction(
                                       p, primality, rep_yPrime, m)))
                        = Rational.padic_absolute_value(
                              p, primality,
                              PAdicCauchySequence.sequenceFunction(
                                  p, primality,
                                  PAdicCauchySequence.add(
                                      p, primality, rep_x, rep_y), m)
                              - (PAdicCauchySequence.sequenceFunction(
                                     p, primality, rep_x, m)
                                 + PAdicCauchySequence.sequenceFunction(
                                       p, primality, rep_yPrime, m)))
                        = Rational.padic_absolute_value(
                              p, primality,
                              PAdicCauchySequence.sequenceFunction(
                                  p, primality,
                                  PAdicCauchySequence.add(
                                      p, primality, rep_x, rep_y), m)
                              - PAdicCauchySequence.sequenceFunction(
                                    p, primality,
                                    PAdicCauchySequence.add(
                                        p, primality, rep_x, rep_yPrime), m));
                rewrite(absBridge, yEquiv_at_N(m, N_leq_m))
              }
        } : ∃ (N : Natural).
              (m : Natural) → N ≤ m →
                Rational.padic_absolute_value(
                    p, primality,
                    PAdicCauchySequence.sequenceFunction(
                        p, primality,
                        PAdicCauchySequence.add(
                            p, primality, rep_x, rep_y), m)
                    - PAdicCauchySequence.sequenceFunction(
                          p, primality,
                          PAdicCauchySequence.add(
                              p, primality, rep_x, rep_yPrime), m))
                  < epsilon))

-- Outer respect: lift over x. With y fixed (under the lift), the
-- shared y cancels via add_subtract_cancel_right.
theorem PAdic.add_respects
        (p : Natural) (primality : Natural.is_prime(p))
        (rep_x rep_xPrime : PAdicCauchySequence(p, primality))
        (xEquiv : PAdicEquivalent(p, primality, rep_x, rep_xPrime))
        (yPAdic : PAdic(p, primality))
        : Quotient.lift(
              function (rep_y : PAdicCauchySequence(p, primality)) =>
                  Quotient.mk(
                      PAdicCauchySequence(p, primality),
                      PAdicEquivalent(p, primality),
                      PAdicCauchySequence.add(p, primality, rep_x, rep_y)),
              PAdic.add_after_first_respects(p, primality, rep_x),
              yPAdic)
          = Quotient.lift(
                function (rep_y : PAdicCauchySequence(p, primality)) =>
                    Quotient.mk(
                        PAdicCauchySequence(p, primality),
                        PAdicEquivalent(p, primality),
                        PAdicCauchySequence.add(
                            p, primality, rep_xPrime, rep_y)),
                PAdic.add_after_first_respects(p, primality, rep_xPrime),
                yPAdic) :=
  Quotient.induct(
      function (y : PAdic(p, primality)) =>
          Quotient.lift(
              function (rep_y : PAdicCauchySequence(p, primality)) =>
                  Quotient.mk(
                      PAdicCauchySequence(p, primality),
                      PAdicEquivalent(p, primality),
                      PAdicCauchySequence.add(p, primality, rep_x, rep_y)),
              PAdic.add_after_first_respects(p, primality, rep_x),
              y)
          = Quotient.lift(
                function (rep_y : PAdicCauchySequence(p, primality)) =>
                    Quotient.mk(
                        PAdicCauchySequence(p, primality),
                        PAdicEquivalent(p, primality),
                        PAdicCauchySequence.add(
                            p, primality, rep_xPrime, rep_y)),
                PAdic.add_after_first_respects(p, primality, rep_xPrime),
                y),
      function (rep_y : PAdicCauchySequence(p, primality)) =>
        -- Mirror of add_after_first_respects with the SECOND component
        -- shared instead of the first; the same sequenceFunction_add
        -- bridge + ring cancel.
        Quotient.sound(
            PAdicCauchySequence(p, primality),
            PAdicEquivalent(p, primality),
            PAdicCauchySequence.add(p, primality, rep_x, rep_y),
            PAdicCauchySequence.add(p, primality, rep_xPrime, rep_y),
            function (epsilon : Rational)
                     (epsilonPositive : Rational.zero < epsilon) =>
              ({
                obtain ⟨N, xEquiv_at_N⟩ from xEquiv(epsilon, epsilonPositive);
                witness N with
                    function (m : Natural) (N_leq_m : N ≤ m) => {
                      claim absBridge
                            : Rational.padic_absolute_value(
                                  p, primality,
                                  PAdicCauchySequence.sequenceFunction(
                                      p, primality, rep_x, m)
                                  - PAdicCauchySequence.sequenceFunction(
                                        p, primality, rep_xPrime, m))
                              = Rational.padic_absolute_value(
                                    p, primality,
                                    PAdicCauchySequence.sequenceFunction(
                                        p, primality,
                                        PAdicCauchySequence.add(
                                            p, primality, rep_x, rep_y), m)
                                    - PAdicCauchySequence.sequenceFunction(
                                          p, primality,
                                          PAdicCauchySequence.add(
                                              p, primality, rep_xPrime, rep_y), m))
                        by calc Rational.padic_absolute_value(
                                    p, primality,
                                    PAdicCauchySequence.sequenceFunction(
                                        p, primality, rep_x, m)
                                    - PAdicCauchySequence.sequenceFunction(
                                          p, primality, rep_xPrime, m))
                              = Rational.padic_absolute_value(
                                    p, primality,
                                    (PAdicCauchySequence.sequenceFunction(
                                         p, primality, rep_x, m)
                                     + PAdicCauchySequence.sequenceFunction(
                                           p, primality, rep_y, m))
                                    - (PAdicCauchySequence.sequenceFunction(
                                           p, primality, rep_xPrime, m)
                                       + PAdicCauchySequence.sequenceFunction(
                                             p, primality, rep_y, m)))
                              = Rational.padic_absolute_value(
                                    p, primality,
                                    PAdicCauchySequence.sequenceFunction(
                                        p, primality,
                                        PAdicCauchySequence.add(
                                            p, primality, rep_x, rep_y), m)
                                    - (PAdicCauchySequence.sequenceFunction(
                                           p, primality, rep_xPrime, m)
                                       + PAdicCauchySequence.sequenceFunction(
                                             p, primality, rep_y, m)))
                              = Rational.padic_absolute_value(
                                    p, primality,
                                    PAdicCauchySequence.sequenceFunction(
                                        p, primality,
                                        PAdicCauchySequence.add(
                                            p, primality, rep_x, rep_y), m)
                                    - PAdicCauchySequence.sequenceFunction(
                                          p, primality,
                                          PAdicCauchySequence.add(
                                              p, primality, rep_xPrime, rep_y), m));
                      rewrite(absBridge, xEquiv_at_N(m, N_leq_m))
                    }
              } : ∃ (N : Natural).
                    (m : Natural) → N ≤ m →
                      Rational.padic_absolute_value(
                          p, primality,
                          PAdicCauchySequence.sequenceFunction(
                              p, primality,
                              PAdicCauchySequence.add(
                                  p, primality, rep_x, rep_y), m)
                          - PAdicCauchySequence.sequenceFunction(
                              p, primality,
                              PAdicCauchySequence.add(
                                  p, primality, rep_xPrime, rep_y), m))
                        < epsilon)),
      yPAdic)

-- Inner "add-with-fixed-first": PAdic → PAdic, lifts y over the inner
-- respect.
definition PAdic.add_after_first
        (rep_x : PAdicCauchySequence(p, primality))
        (yPAdic : PAdic(p, primality)) : PAdic(p, primality) :=
  Quotient.lift(
      function (rep_y : PAdicCauchySequence(p, primality)) =>
          Quotient.mk(
              PAdicCauchySequence(p, primality),
              PAdicEquivalent(p, primality),
              PAdicCauchySequence.add(p, primality, rep_x, rep_y)),
      PAdic.add_after_first_respects(p, primality, rep_x),
      yPAdic)

-- PAdic.add itself: lift over x.
definition PAdic.add
        (x y : PAdic(p, primality)) : PAdic(p, primality) :=
  Quotient.lift(
      function (rep_x : PAdicCauchySequence(p, primality)) =>
          PAdic.add_after_first(p, primality, rep_x, y),
      function (rep_x rep_xPrime : PAdicCauchySequence(p, primality))
               (xEquiv : PAdicEquivalent(p, primality, rep_x, rep_xPrime)) =>
          PAdic.add_respects(p, primality, rep_x, rep_xPrime, xEquiv, y),
      x)

-- PAdic/absolute_value.math
--
-- The p-adic absolute value `|x|_p` on Rationals. For a prime p:
--   |0|_p = 0
--   |x|_p = (1/p)^(v_p(x))  for x ≠ 0,
-- where v_p(x) is the p-adic valuation: the exponent of p in the
-- prime factorization of the numerator minus the exponent of p in
-- the denominator.
--
-- The full definition requires a few pieces we don't have yet:
--   - Rational.power : Rational → Integer → Rational
--   - Rational.reciprocal : Rational(nonzero) → Rational
--   - Rational.padic_valuation : Natural(prime) → Rational(nonzero) → Integer
-- We scaffold the API so downstream Cauchy work compiles; the
-- definitions themselves are stubbed with sorry.

module PAdic.absolute_value

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.divisibility
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.ring
import Rational.algebra
import Rational.order
import Rational.absolute_value
import Rational.order_arithmetic

-- p-adic absolute value of a rational.
--
-- The mathematically intended value is `|q|_p = (1/p)^v_p(q)` for
-- q ≠ 0 and 0 otherwise. A full implementation requires
-- `Rational.power`, p-adic valuation, and the prime-factorization
-- machinery. As a placeholder definition that satisfies the property
-- API (non-negativity, triangle, multiplicativity), we use the
-- constant-zero function. This collapses ℚ_p to a single point, but
-- the type signatures and downstream Cauchy plumbing remain valid.
-- Replace with the real definition when `Rational.power` lands.
definition Rational.padic_absolute_value (p : Natural) (q : Rational)
        : Rational := Rational.zero

-- 0 ≤ 0.
theorem Rational.padic_absolute_value_nonneg
        (p : Natural) (q : Rational)
        : Rational.zero ≤ Rational.padic_absolute_value(p, q) :=
  Rational.LessOrEqual.reflexive(Rational.zero)

-- 0 ≤ 0 + 0. Both reduce to 0 by `Rational.add_zero`.
theorem Rational.padic_triangle_inequality
        (p : Natural) (x y : Rational)
        : Rational.padic_absolute_value(p, x + y)
          ≤ Rational.padic_absolute_value(p, x)
            + Rational.padic_absolute_value(p, y) :=
  Equality.transport_proposition(
      Rational,
      function (w : Rational) =>
          Rational.LessOrEqual(Rational.zero, w),
      Rational.zero,
      Rational.zero + Rational.zero,
      Equality.symmetry(Rational.add_zero(Rational.zero)),
      Rational.LessOrEqual.reflexive(Rational.zero))

-- 0 = 0 * 0. At representatives, Rational.zero * Rational.zero reduces
-- to mk(make(Integer.zero * Integer.zero, ...)), and 0 * 0 = 0 (Integer).
-- Use Quotient.sound with the cross-multiplication equation.
theorem Rational.padic_absolute_value_multiplicative
        (p : Natural) (x y : Rational)
        : Rational.padic_absolute_value(p, x * y)
          = Rational.padic_absolute_value(p, x)
            * Rational.padic_absolute_value(p, y) :=
  Quotient.sound(
      RationalRepresentative, RationalEquivalent,
      RationalRepresentative.make(Integer.zero, zero),
      RationalRepresentative.make(
          Integer.zero * Integer.zero,
          zero + zero * successor(zero)),
      -- 0 · succ(0 + 0·s(0)) = (0·0) · succ(0). Both sides = 0.
      calc Integer.zero
             * (successor(zero + zero * successor(zero)) : Integer)
         = Integer.zero
                by Integer.multiply_zero_left(
                       (successor(zero + zero * successor(zero)) : Integer))
         = Integer.zero * Integer.zero
                by Equality.symmetry(
                       Integer.multiply_zero_left(Integer.zero))
         = (Integer.zero * Integer.zero) * (successor(zero) : Integer)
                by Equality.symmetry(
                       Integer.multiply_identity_right(
                           Integer.zero * Integer.zero)))

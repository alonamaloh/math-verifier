-- PAdic/absolute_value.math
--
-- The p-adic absolute value `|x|_p` on Rationals. For a prime p:
--   |0|_p = 0
--   |x|_p = p^(v_p(d) - v_p(n))   for x = n/d ≠ 0,
-- where v_p(_) is the Natural-level p-adic valuation (the exponent
-- of p in a Natural's prime factorization). Represented directly as
-- the Rational `p^v_p(d) / p^v_p(n)`; no real-valued exponent
-- needed, so the definition lives entirely in the Rational world.
--
-- Layout:
--   - `padic_absolute_value_at_representative` defines the value
--     at the (numerator, denominator) representative level.
--   - `padic_absolute_value_respect` shows that representative
--     equivalence is preserved.
--   - `padic_absolute_value` is the Quotient.lift onto Rational.
--   - The rest of the file proves non-negativity,
--     multiplicativity, and the strong triangle inequality, plus a
--     few cross-multiplication and case-analysis helpers used by
--     them.

module PAdic.absolute_value

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.cancellation
import Natural.divisibility
import Natural.monus
import Natural.power
import Natural.prime
import Natural.padic_valuation
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.absolute_value
import Integer.absolute_value_natural
import Integer.absolute_value_multiplicative
import Integer.sign
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.order
import Rational.absolute_value
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.ring
import Rational.algebra
import Rational.instances
import Rational.positive

convention p : Natural with primality : Natural.is_prime(p)

-- Honest representative-level p-adic absolute value. For a
-- Rational representative (n, d) (encoding n / succ(d)):
--   * if the numerator is zero, return Rational.zero.
--   * otherwise (|n| = succ(k)), return the Rational
--         p^v_p(succ(d)) / p^v_p(succ(k)),
--     i.e., mk(make((p^v_p(succ(d)) : Integer),
--                   monus(p^v_p(succ(k)), 1))).
-- The denominator stays positive because p^v_p ≥ 1 for prime p ≥ 1
-- (witness: power_positive). The respect proof (next phase) leverages
-- padic_valuation_multiplicative.
definition Rational.padic_absolute_value_at_representative
        (p : Natural) : RationalRepresentative → Rational
  | RationalRepresentative.make(n, d) =>
      (cases Integer.absolute_value_natural(n) {
         | zero => Rational.zero
         | successor(k) =>
             Rational.fraction((Natural.power(
                          Natural.padic_valuation(p, (1 + d)), p)
                          : Integer),
                     Natural.monus(
                         Natural.power(
                             Natural.padic_valuation(p, (1 + k)), p),
                         1))
       } : Rational)

-- Helper: cross-multiplication transfers from the Integer numerator
-- equation `n1 · succ(d2) = n2 · succ(d1)` to a Natural absolute-value
-- equation. Apply Integer.absolute_value to both sides, multiplicativity
-- distributes it, |succ(d) : Integer| reduces to succ(d), and the
-- absolute_value_natural_is_image bridge plus to_integer.injective
-- drops to Natural.
theorem Rational.padic_cross_mult_natural_absolute_value
        (n1 n2 : Integer) (d1 d2 : Natural)
        (cross : n1 * ((1 + d2) : Integer)
                 = n2 * ((1 + d1) : Integer))
        : Integer.absolute_value_natural(n1) * (1 + d2)
          = Integer.absolute_value_natural(n2) * (1 + d1) :=
  Natural.to_integer.injective(
      Integer.absolute_value_natural(n1) * (1 + d2),
      Integer.absolute_value_natural(n2) * (1 + d1),
      calc (Integer.absolute_value_natural(n1) * (1 + d2) : Integer)
         = (Integer.absolute_value_natural(n1) : Integer)
             * ((1 + d2) : Integer)
         = abs(n1) * ((1 + d2) : Integer)
         = abs(n1 * ((1 + d2) : Integer))
         = abs(n2 * ((1 + d1) : Integer))
         = abs(n2) * ((1 + d1) : Integer)
         = (Integer.absolute_value_natural(n2) : Integer)
             * ((1 + d1) : Integer)
         = (Integer.absolute_value_natural(n2) * (1 + d1) : Integer))

-- Successor-after-monus-one identity: succ(monus(m, 1)) = m for m ≥ 1.
theorem Natural.successor_monus_one_when_positive
        : (m : Natural)
          → 1 ≤ m
          → (1 + Natural.monus(m, 1)) = m
  | zero, mPositive =>
      absurd(mPositive)
  | successor(j), _ =>
      -- monus(succ j, 1) → monus(j, 0) → j, both via the monus
      -- characterising lemmas. `1 + j ≡ succ j` is kernel β.
      calc 1 + Natural.monus(successor(j), 1)
         = 1 + Natural.monus(j, 0)
         = 1 + j
         = successor(j)

-- The Integer equivalence equation that Quotient.sound needs in the
-- "both numerators nonzero" branch of respect, derived from the
-- corresponding cross-multiplication on succ(d_i) and succ(k_i) at
-- Natural level. Uses multiplicativity of padic_valuation (needs prime).
theorem Rational.padic_quotient_cross_equation
        (d1 d2 k1 k2 : Natural)
        (succCross
            : (1 + d1) * (1 + k2) = (1 + d2) * (1 + k1))
        : (Natural.power(Natural.padic_valuation(p, (1 + d1)), p) : Integer)
          * ((1 + Natural.monus(
                 Natural.power(
                     Natural.padic_valuation(p, (1 + k2)), p),
                 1)) : Integer)
          = (Natural.power(Natural.padic_valuation(p, (1 + d2)), p) : Integer)
            * ((1 + Natural.monus(
                   Natural.power(
                       Natural.padic_valuation(p, (1 + k1)), p),
                   1)) : Integer) := {
  claim 1 ≤ p;
  claim 1 ≤ (1 + d1);
  claim 1 ≤ (1 + d2);
  claim 1 ≤ (1 + k1);
  claim 1 ≤ (1 + k2);
  -- Step 1: apply v_p to succCross.
  note Natural.padic_valuation(p, (1 + d1) * (1 + k2))
         = Natural.padic_valuation(p, (1 + d2) * (1 + k1));
  -- Step 2: distribute multiplicativity on both sides.
  calc Natural.padic_valuation(p, (1 + d1))
         + Natural.padic_valuation(p, (1 + k2))
     = Natural.padic_valuation(p, (1 + d1) * (1 + k2))
     = Natural.padic_valuation(p, (1 + d2) * (1 + k1))
     = Natural.padic_valuation(p, (1 + d2))
         + Natural.padic_valuation(p, (1 + k1));
  -- Step 3: exponentiate valuationSum by p^_. Collapse the product into
  -- a single exponent (power_add reversed), swap the exponent, expand.
  calc Natural.power(Natural.padic_valuation(p, (1 + d1)), p)
         * Natural.power(Natural.padic_valuation(p, (1 + k2)), p)
     = Natural.power(
           Natural.padic_valuation(p, (1 + d1))
               + Natural.padic_valuation(p, (1 + k2)),
           p)
     = Natural.power(
           Natural.padic_valuation(p, (1 + d2))
               + Natural.padic_valuation(p, (1 + k1)),
           p)
     = Natural.power(Natural.padic_valuation(p, (1 + d2)), p)
         * Natural.power(Natural.padic_valuation(p, (1 + k1)), p);
  -- Step 4: rewrite p^v_p(succ(k)) as succ(monus(p^v_p(succ(k)), 1)) using
  -- successor_monus_one_when_positive (p^v_p ≥ 1 from power_positive).
  claim 1
            ≤ Natural.power(Natural.padic_valuation(p, (1 + k1)), p);
  claim 1
            ≤ Natural.power(Natural.padic_valuation(p, (1 + k2)), p);
  -- Step 5: cast naturalProduct to Integer and distribute.
  calc (Natural.power(Natural.padic_valuation(p, (1 + d1)), p) : Integer)
       * ((1 + Natural.monus(
              Natural.power(
                  Natural.padic_valuation(p, (1 + k2)), p),
              1)) : Integer)
     = (Natural.power(Natural.padic_valuation(p, (1 + d1)), p) : Integer)
       * (Natural.power(Natural.padic_valuation(p, (1 + k2)), p)
              : Integer)
     = (Natural.power(Natural.padic_valuation(p, (1 + d1)), p)
          * Natural.power(Natural.padic_valuation(p, (1 + k2)), p)
          : Integer)
     = (Natural.power(Natural.padic_valuation(p, (1 + d2)), p)
          * Natural.power(Natural.padic_valuation(p, (1 + k1)), p)
          : Integer)
     = (Natural.power(Natural.padic_valuation(p, (1 + d2)), p) : Integer)
       * (Natural.power(Natural.padic_valuation(p, (1 + k1)), p)
              : Integer)
     = (Natural.power(Natural.padic_valuation(p, (1 + d2)), p) : Integer)
       * ((1 + Natural.monus(
              Natural.power(
                  Natural.padic_valuation(p, (1 + k1)), p),
              1)) : Integer)
}

-- Reduction lemma: when |n| = 0, the at_representative function returns
-- Rational.zero. Transport the inner `cases` motive at zero. (The
-- 2-arg `rewrite` form can't replace this — the cases scrutinee gets
-- ι-reduced before the matcher can locate the rewrite target, so the
-- explicit motive is genuinely needed here.)
theorem Rational.padic_absolute_value_at_zero
        (p : Natural) (n : Integer) (d : Natural)
        (absZero : Integer.absolute_value_natural(n) = 0)
        : Rational.padic_absolute_value_at_representative(
              p, RationalRepresentative.make(n, d))
          = Rational.zero :=
  Equality.transport_proposition(
      (m : Natural) ↦
          (cases m {
             | zero => Rational.zero
             | successor(k) =>
                 Rational.fraction((Natural.power(Natural.padic_valuation(p, (1 + d)), p) : Integer),
                         Natural.monus(Natural.power(Natural.padic_valuation(p, (1 + k)), p), 1))
           } : Rational) = Rational.zero,
      ?, ?, Equality.symmetry(absZero), reflexivity(Rational, Rational.zero))

-- Reduction lemma: when |n| = succ(k), the at_representative function
-- returns the explicit p^v_p / p^v_p Rational form.
theorem Rational.padic_absolute_value_at_succ
        (p : Natural) (n : Integer) (d k : Natural)
        (absSucc : Integer.absolute_value_natural(n) = (1 + k))
        : Rational.padic_absolute_value_at_representative(
              p, RationalRepresentative.make(n, d))
          = Rational.fraction((Natural.power(
                         Natural.padic_valuation(p, (1 + d)), p)
                         : Integer),
                    Natural.monus(
                        Natural.power(
                            Natural.padic_valuation(p, (1 + k)), p),
                        1)) :=
  Equality.transport_proposition(
      (m : Natural) ↦
          (cases m {
             | zero => Rational.zero
             | successor(k') =>
                 Rational.fraction((Natural.power(Natural.padic_valuation(p, (1 + d)), p) : Integer),
                         Natural.monus(Natural.power(Natural.padic_valuation(p, (1 + k')), p), 1))
           } : Rational)
          = Rational.fraction((Natural.power(Natural.padic_valuation(p, (1 + d)), p) : Integer),
                    Natural.monus(Natural.power(Natural.padic_valuation(p, (1 + k)), p), 1)),
      ?, ?, Equality.symmetry(absSucc),
      reflexivity(Rational,
          Rational.fraction((Natural.power(Natural.padic_valuation(p, (1 + d)), p) : Integer),
                  Natural.monus(Natural.power(Natural.padic_valuation(p, (1 + k)), p), 1))))

-- The main respect proof: equivalent Rational representatives map to
-- the same Rational under the p-adic absolute value. Four cases on
-- the (|n1|, |n2|) values of Integer.absolute_value_natural:
--   * both zero: both sides reduce to Rational.zero.
--   * |n1| = 0 and |n2| = succ(k2): naturalCross gives 0 = succ(_),
--     contradiction.
--   * |n1| = succ(k1) and |n2| = 0: symmetric contradiction.
--   * both successors: build the Integer cross-equation for Quotient.sound
--     via the padic_quotient_cross_equation helper.
theorem Rational.padic_absolute_value_respect
        (rep1 rep2 : RationalRepresentative)
        (equivHyp : RationalEquivalent(rep1, rep2))
        : Rational.padic_absolute_value_at_representative(p, rep1)
          = Rational.padic_absolute_value_at_representative(p, rep2) :=
  (cases rep1 {
     | RationalRepresentative.make(n1, d1) =>
         (cases rep2 {
            | RationalRepresentative.make(n2, d2) =>
             (cross : n1 * ((1 + d2) : Integer)
                              = n2 * ((1 + d1) : Integer)) ↦ {
               claim naturalCross
                     : Integer.absolute_value_natural(n1) * (1 + d2)
                       = Integer.absolute_value_natural(n2) * (1 + d1)
                 by Rational.padic_cross_mult_natural_absolute_value(
                        n1, n2, d1, d2, cross);
               -- with-pattern on |n1| and |n2|.
               cases Integer.absolute_value_natural(n1) with eqAbs1 {
                  | zero =>
                      cases Integer.absolute_value_natural(n2) with eqAbs2 {
                         | zero =>
                             calc Rational.padic_absolute_value_at_representative(
                                      p, RationalRepresentative.make(n1, d1))
                                = Rational.zero
                                = Rational.padic_absolute_value_at_representative(
                                      p, RationalRepresentative.make(n2, d2))
                         | successor(k2) => {
                             calc (0 : Natural)
                                = 0 * (1 + d2)
                                = (1 + k2) * (1 + d1)
                                      by rewrite(eqAbs2,
                                                 rewrite(eqAbs1, naturalCross))   as contradEq;
                             -- The above derives:
                             -- zero = succ(k2) * succ(d1), and
                             -- succ(k2) * succ(d1) reduces to
                             -- succ(d1 + k2 * succ(d1)).
                             absurd(contradEq)
                           }
                       }
                  | successor(k1) =>
                      cases Integer.absolute_value_natural(n2) with eqAbs2 {
                         | zero => {
                             calc (1 + k1) * (1 + d2)
                                = 0 * (1 + d1)
                                      by rewrite(eqAbs1,
                                                 rewrite(eqAbs2, naturalCross))
                                = (0 : Natural)                                    as contradEq;
                             absurd(Equality.symmetry(contradEq))
                           }
                         | successor(k2) => {
                             -- Substitute into naturalCross to get
                             --   succ(k1) * succ(d2) = succ(k2) * succ(d1).
                             claim (1 + k1) * (1 + d2)
                                     = (1 + k2) * (1 + d1)
                               by rewrite(eqAbs1,
                                          rewrite(eqAbs2, naturalCross));
                             -- Reorganise via commutativity to
                             --   succ(d1) * succ(k2) = succ(d2) * succ(k1).
                             calc (1 + d1) * (1 + k2)
                                = (1 + k2) * (1 + d1)
                                = (1 + k1) * (1 + d2)
                                = (1 + d2) * (1 + k1)                              as succCross;
                             calc Rational.padic_absolute_value_at_representative(
                                      p, RationalRepresentative.make(n1, d1))
                                = Rational.fraction((Natural.power(
                                               Natural.padic_valuation(
                                                   p, (1 + d1)), p)
                                               : Integer),
                                          Natural.monus(
                                              Natural.power(
                                                  Natural.padic_valuation(
                                                      p, (1 + k1)), p),
                                              1))
                                = Rational.fraction((Natural.power(
                                               Natural.padic_valuation(
                                                   p, (1 + d2)), p)
                                               : Integer),
                                          Natural.monus(
                                              Natural.power(
                                                  Natural.padic_valuation(
                                                      p, (1 + k2)), p),
                                              1))
                                    by Quotient.sound(
                                           RationalRepresentative.make(
                                               (Natural.power(
                                                    Natural.padic_valuation(
                                                        p, (1 + d1)), p)
                                                    : Integer),
                                               Natural.monus(
                                                   Natural.power(
                                                       Natural.padic_valuation(
                                                           p, (1 + k1)), p),
                                                   1)),
                                           RationalRepresentative.make(
                                               (Natural.power(
                                                    Natural.padic_valuation(
                                                        p, (1 + d2)), p)
                                                    : Integer),
                                               Natural.monus(
                                                   Natural.power(
                                                       Natural.padic_valuation(
                                                           p, (1 + k2)), p),
                                                   1)),
                                           Rational.padic_quotient_cross_equation(
                                               p, primality,
                                               d1, d2, k1, k2,
                                               succCross))
                                = Rational.padic_absolute_value_at_representative(
                                      p, RationalRepresentative.make(n2, d2))
                           }
                       }
                }
             }
          } : (refinedEquiv :
                   RationalEquivalent(
                       RationalRepresentative.make(n1, d1), rep2))
              → Rational.padic_absolute_value_at_representative(
                    p, RationalRepresentative.make(n1, d1))
                = Rational.padic_absolute_value_at_representative(
                      p, rep2))
   } : (refinedEquiv : RationalEquivalent(rep1, rep2))
       → Rational.padic_absolute_value_at_representative(p, rep1)
         = Rational.padic_absolute_value_at_representative(p, rep2))(equivHyp)

-- Honest top-level: lift `padic_absolute_value_at_representative`
-- through the Quotient using the respect proof.
definition Rational.padic_absolute_value
        (q : Rational) : Rational :=
  Quotient.lift(
      (rep : RationalRepresentative) ↦
          Rational.padic_absolute_value_at_representative(p, rep),
      (rep1 rep2 : RationalRepresentative)
               (equiv : RationalEquivalent(rep1, rep2)) ↦
          Rational.padic_absolute_value_respect(
              p, primality, rep1, rep2, equiv),
      q)

-- Non-negativity: 0 ≤ |q|_p for any q. Quotient.induct on q. At
-- representative make(n, d), case on the numerator's absolute value:
-- zero gives Rational.zero, and the successor case gives a
-- Rational whose numerator is the image of a Natural (hence IsNonneg).
theorem Rational.padic_absolute_value_nonneg
        (q : Rational)
        : Rational.zero ≤ Rational.padic_absolute_value(p, primality, q) :=
  cases q {
    | RationalRepresentative.make(n, d) =>
        cases Integer.absolute_value_natural(n) with eqAbs {
          | zero =>
              calc Rational.zero
                 ≤ Rational.zero
                 = Rational.padic_absolute_value_at_representative(
                       p,
                       RationalRepresentative.make(n, d))
          | successor(k) =>
              rewrite(
                  Equality.symmetry(
                      Rational.padic_absolute_value_at_succ(
                          p, n, d, k, eqAbs)),
                  Rational.LessOrEqual_zero_of_IsNonneg(
                      Rational.fraction((Natural.power(
                                   Natural.padic_valuation(
                                       p, (1 + d)), p)
                                   : Integer),
                              Natural.monus(
                                  Natural.power(
                                      Natural.padic_valuation(
                                          p, (1 + k)), p),
                                  1)),
                      Integer.from_natural_is_nonneg(
                          Natural.power(
                              Natural.padic_valuation(
                                  p, (1 + d)), p))))
        }
  }

-- ----------------------------------------------------------------------
-- Helpers for the multiplicativity theorem.

-- Integer absolute_value (Natural-valued) is multiplicative. Cast both
-- sides to Integer, apply Integer.absolute_value_multiplicative, then
-- drop back to Natural via injectivity.
theorem Integer.absolute_value_natural_multiplicative (x y : Integer)
        : Integer.absolute_value_natural(x * y)
          = Integer.absolute_value_natural(x)
              * Integer.absolute_value_natural(y) :=
  Natural.to_integer.injective(
      Integer.absolute_value_natural(x * y),
      Integer.absolute_value_natural(x)
          * Integer.absolute_value_natural(y),
      calc (Integer.absolute_value_natural(x * y) : Integer)
         = abs(x * y)
         = abs(x) * abs(y)
         = (Integer.absolute_value_natural(x) : Integer)
             * abs(y)
         = (Integer.absolute_value_natural(x) : Integer)
             * (Integer.absolute_value_natural(y) : Integer)
         = (Integer.absolute_value_natural(x)
              * Integer.absolute_value_natural(y) : Integer))

-- ----------------------------------------------------------------------
-- Multiplicativity of the p-adic absolute value at the representative
-- level. The "both numerators non-zero" case is the meaty one: it
-- builds the Integer cross-equation for Quotient.sound from the
-- multiplicativity of padic_valuation and power_add.

-- Helper: the Quotient.sound input that bridges the LHS and RHS
-- representative forms when both numerators are nonzero.
theorem Rational.padic_multiplicative_cross_equation
        (dx dy kx ky : Natural)
        : (Natural.power(
              Natural.padic_valuation(
                  p, (1 + dy + dx * (1 + dy))), p) : Integer)
          * ((1 + 
                Natural.monus(
                    Natural.power(Natural.padic_valuation(p, (1 + ky)), p),
                    1)
                  + Natural.monus(
                        Natural.power(
                            Natural.padic_valuation(p, (1 + kx)), p),
                        1)
                    * (1 + 
                        Natural.monus(
                            Natural.power(
                                Natural.padic_valuation(
                                    p, (1 + ky)), p),
                            1)))
              : Integer)
          = ((Natural.power(Natural.padic_valuation(p, (1 + dx)), p) : Integer)
             * (Natural.power(Natural.padic_valuation(p, (1 + dy)), p)
                  : Integer))
            * ((1 + 
                  Natural.monus(
                      Natural.power(
                          Natural.padic_valuation(
                              p, (1 + ky + kx * (1 + ky))), p),
                      1))
                : Integer) := {
  claim primePositive   : 1 ≤ p             by Natural.is_prime.positive(p, primality);
  claim succDxPos       : 1 ≤ (1 + dx) by Natural.successor_positive(dx);
  claim succDyPos       : 1 ≤ (1 + dy) by Natural.successor_positive(dy);
  claim succKxPos       : 1 ≤ (1 + kx) by Natural.successor_positive(kx);
  claim succKyPos       : 1 ≤ (1 + ky) by Natural.successor_positive(ky);
  -- succ(dy + dx*succ(dy)) reduces to succ(dx) * succ(dy) by kernel.
  -- So power(v_p(succ(dy + dx*succ(dy))), p) = power(v_p(succ(dx)*succ(dy)), p)
  -- = power(v_p(succ(dx)) + v_p(succ(dy)), p)        [multiplicativity]
  -- = power(v_p(succ(dx)), p) * power(v_p(succ(dy)), p)  [power_add].
  calc Natural.power(
           Natural.padic_valuation(
               p, (1 + dy + dx * (1 + dy))), p)
     = Natural.power(
           Natural.padic_valuation(p, (1 + dx))
               + Natural.padic_valuation(p, (1 + dy)), p)
           by Natural.padic_valuation_multiplicative(
                  p, (1 + dx), (1 + dy),
                  primality, succDxPos, succDyPos)
     = Natural.power(Natural.padic_valuation(p, (1 + dx)), p)
         * Natural.power(Natural.padic_valuation(p, (1 + dy)), p);
  -- Similarly for the denominator (k side).
  calc Natural.power(
           Natural.padic_valuation(
               p, (1 + ky + kx * (1 + ky))), p)
     = Natural.power(
           Natural.padic_valuation(p, (1 + kx))
               + Natural.padic_valuation(p, (1 + ky)), p)
           by Natural.padic_valuation_multiplicative(
                  p, (1 + kx), (1 + ky),
                  primality, succKxPos, succKyPos)
     = Natural.power(Natural.padic_valuation(p, (1 + kx)), p)
         * Natural.power(Natural.padic_valuation(p, (1 + ky)), p);
  claim 1
            ≤ Natural.power(Natural.padic_valuation(p, (1 + kx)), p);
  claim 1
            ≤ Natural.power(Natural.padic_valuation(p, (1 + ky)), p);
  -- Build the Integer equation by computation.
  -- Key: succ(monus(power(v_p(succ(ky)), p), 1) + monus(power(v_p(succ(kx)), p), 1) * succ(monus(power(v_p(succ(ky)), p), 1)))
  --      reduces to succ(monus(power(v_p(succ(kx)), p), 1)) * succ(monus(power(v_p(succ(ky)), p), 1))
  --      = power(v_p(succ(kx)), p) * power(v_p(succ(ky)), p) (via successor_monus_one × 2).
  -- And succ(monus(power(v_p(succ(ky+kx*succ(ky))), p), 1)) = power(v_p(succ(ky+kx*succ(ky))), p) (also via successor_monus_one).
  calc (Natural.power(
            Natural.padic_valuation(
                p, (1 + dy + dx * (1 + dy))), p) : Integer)
       * ((1 + 
              Natural.monus(
                  Natural.power(
                      Natural.padic_valuation(p, (1 + ky)), p),
                  1)
                + Natural.monus(
                      Natural.power(
                          Natural.padic_valuation(p, (1 + kx)), p),
                      1)
                  * (1 + 
                      Natural.monus(
                          Natural.power(
                              Natural.padic_valuation(
                                  p, (1 + ky)), p),
                          1)))
            : Integer)
     = (Natural.power(
            Natural.padic_valuation(
                p, (1 + dy + dx * (1 + dy))), p) : Integer)
       * (Natural.power(Natural.padic_valuation(p, (1 + kx)), p)
            * Natural.power(Natural.padic_valuation(p, (1 + ky)), p)
            : Integer)
            -- succ(monus(B_x, 1) + monus(B_y, 1) * succ(monus(B_y, 1)))
            -- reduces (add on succ first, multiply rearrangement)
            -- to succ(monus(B_x, 1)) * succ(monus(B_y, 1))
            -- = power(v_p(succ(kx)), p) * power(v_p(succ(ky)), p).
            by (calc (1 +
                         Natural.monus(
                             Natural.power(
                                 Natural.padic_valuation(p, (1 + kx)), p),
                             1))
                       * (1 +
                             Natural.monus(
                                 Natural.power(
                                     Natural.padic_valuation(p, (1 + ky)), p),
                                 1))
                   = Natural.power(
                         Natural.padic_valuation(p, (1 + kx)), p)
                       * (1 +
                             Natural.monus(
                                 Natural.power(
                                     Natural.padic_valuation(p, (1 + ky)), p),
                                 1))
                   = Natural.power(
                         Natural.padic_valuation(p, (1 + kx)), p)
                       * Natural.power(
                             Natural.padic_valuation(p, (1 + ky)), p))
     = (Natural.power(
            Natural.padic_valuation(
                p, (1 + dy + dx * (1 + dy))), p)
          * (Natural.power(Natural.padic_valuation(p, (1 + kx)), p)
               * Natural.power(Natural.padic_valuation(p, (1 + ky)), p))
          : Integer)
     = ((Natural.power(Natural.padic_valuation(p, (1 + dx)), p)
           * Natural.power(Natural.padic_valuation(p, (1 + dy)), p))
          * (Natural.power(Natural.padic_valuation(p, (1 + kx)), p)
               * Natural.power(Natural.padic_valuation(p, (1 + ky)), p))
          : Integer)
     = ((Natural.power(Natural.padic_valuation(p, (1 + dx)), p)
           * Natural.power(Natural.padic_valuation(p, (1 + dy)), p))
          : Integer)
       * ((Natural.power(Natural.padic_valuation(p, (1 + kx)), p)
             * Natural.power(Natural.padic_valuation(p, (1 + ky)), p))
            : Integer)
     = ((Natural.power(Natural.padic_valuation(p, (1 + dx)), p) : Integer)
        * (Natural.power(Natural.padic_valuation(p, (1 + dy)), p)
             : Integer))
       * ((Natural.power(Natural.padic_valuation(p, (1 + kx)), p)
             * Natural.power(Natural.padic_valuation(p, (1 + ky)), p))
            : Integer)
     = ((Natural.power(Natural.padic_valuation(p, (1 + dx)), p) : Integer)
        * (Natural.power(Natural.padic_valuation(p, (1 + dy)), p)
             : Integer))
       * (Natural.power(
              Natural.padic_valuation(
                  p, (1 + ky + kx * (1 + ky))), p)
            : Integer)
     = ((Natural.power(Natural.padic_valuation(p, (1 + dx)), p) : Integer)
        * (Natural.power(Natural.padic_valuation(p, (1 + dy)), p)
             : Integer))
       * ((1 + 
              Natural.monus(
                  Natural.power(
                      Natural.padic_valuation(
                          p, (1 + ky + kx * (1 + ky))), p),
                  1))
            : Integer)
            by Equality.symmetry(
                   Natural.successor_monus_one_when_positive(
                       Natural.power(
                           Natural.padic_valuation(
                               p, (1 + ky + kx * (1 + ky))), p),
                       Natural.power_positive(
                           Natural.padic_valuation(
                               p, (1 + ky + kx * (1 + ky))),
                           p, primePositive)))
}

-- Main: multiplicativity at the Rational level.
-- |x · y|_p = |x|_p · |y|_p. Quotient.induct_two on x, y. At
-- representatives, case on |nx| and |ny| to dispatch:
--   * either zero: both sides zero (LHS via |nx·ny|=0 + at_zero;
--     RHS via at_zero on one factor + zero_multiply or multiply_zero).
--   * both successor: both sides are mk's; apply Quotient.sound with
--     padic_multiplicative_cross_equation.
theorem Rational.padic_absolute_value_multiplicative
        (x y : Rational)
        : Rational.padic_absolute_value(p, primality, x * y)
          = Rational.padic_absolute_value(p, primality, x)
              * Rational.padic_absolute_value(p, primality, y) :=
  cases x { | RationalRepresentative.make(nx, dx) =>
    cases y { | RationalRepresentative.make(ny, dy) => {
                      -- Abbreviations for the three padic-av representative
                      -- atoms that show up dozens of times below.
                      let absXAtRep : Rational :=
                          Rational.padic_absolute_value_at_representative(
                              p, RationalRepresentative.make(nx, dx));
                      let absYAtRep : Rational :=
                          Rational.padic_absolute_value_at_representative(
                              p, RationalRepresentative.make(ny, dy));
                      let absXYAtRep : Rational :=
                          Rational.padic_absolute_value_at_representative(
                              p, RationalRepresentative.make(
                                     nx * ny, dy + dx * (1 + dy)));
                      -- With-pattern on |nx| and |ny|.
                      cases Integer.absolute_value_natural(nx) with eqAbsNx {
                         | zero => {
                             -- |nx*ny| = |nx| * |ny| = 0 * |ny| = 0.
                             calc Integer.absolute_value_natural(nx * ny)
                                = Integer.absolute_value_natural(nx)
                                      * Integer.absolute_value_natural(ny)
                                = 0
                                      * Integer.absolute_value_natural(ny)
                                = 0;
                             calc absXYAtRep
                                = Rational.zero
                                = Rational.zero * absYAtRep
                                = absXAtRep * absYAtRep
                           }
                         | successor(kx) =>
                             cases Integer.absolute_value_natural(ny) with eqAbsNy {
                                | zero => {
                                    -- |nx*ny| = |nx| * |ny| = succ(kx) * 0 = 0.
                                    calc Integer.absolute_value_natural(
                                             nx * ny)
                                       = Integer.absolute_value_natural(nx)
                                             * Integer.absolute_value_natural(ny)
                                       = Integer.absolute_value_natural(nx)
                                             * 0
                                       = 0;
                                    calc absXYAtRep
                                       = Rational.zero
                                       = absXAtRep * Rational.zero
                                       = absXAtRep * absYAtRep
                                  }
                                | successor(ky) => {
                                    -- Further abbreviations for the
                                    -- padic-av "successor-form" Quotient.mk
                                    -- atoms that recur through the calc chain.
                                    let padicAvMkY : Rational :=
                                        Rational.fraction((Natural.power(
                                                      Natural.padic_valuation(p, (1 + dy)), p)
                                                      : Integer),
                                                 Natural.monus(
                                                     Natural.power(
                                                         Natural.padic_valuation(p, (1 + ky)), p),
                                                     1));
                                    let padicAvMkXY : Rational :=
                                        Rational.fraction((Natural.power(
                                                      Natural.padic_valuation(
                                                          p, (1 + dy + dx * (1 + dy))), p)
                                                      : Integer),
                                                 Natural.monus(
                                                     Natural.power(
                                                         Natural.padic_valuation(
                                                             p, (1 + ky + kx * (1 + ky))), p),
                                                     1));
                                    -- |nx*ny| = |nx|*|ny| = succ(kx)*succ(ky)
                                    -- = succ(ky + kx*succ(ky)) (by kernel reduction).
                                    calc Integer.absolute_value_natural(
                                             nx * ny)
                                       = Integer.absolute_value_natural(nx)
                                             * Integer.absolute_value_natural(ny)
                                       = (1 + kx)
                                             * Integer.absolute_value_natural(ny)
                                       = (1 + kx) * (1 + ky)
                                       = (1 + ky + kx * (1 + ky))                  as productAbsSucc;
                                    calc absXYAtRep
                                       = padicAvMkXY
                                             by Rational.padic_absolute_value_at_succ(
                                                    p, nx * ny,
                                                    dy + dx * (1 + dy),
                                                    ky + kx * (1 + ky),
                                                    productAbsSucc)
                                       -- padic_multiplicative_cross_equation bridges the
                                       -- single-mk form to the multiplied-reps form.
                                       = Quotient.mk(Rational.multiply_representatives(
                                             RationalRepresentative.make(
                                                 (Natural.power(
                                                      Natural.padic_valuation(p, (1 + dx)), p)
                                                      : Integer),
                                                 Natural.monus(
                                                     Natural.power(
                                                         Natural.padic_valuation(p, (1 + kx)), p),
                                                     1)),
                                             RationalRepresentative.make(
                                                 (Natural.power(
                                                      Natural.padic_valuation(p, (1 + dy)), p)
                                                      : Integer),
                                                 Natural.monus(
                                                     Natural.power(
                                                         Natural.padic_valuation(p, (1 + ky)), p),
                                                     1))))
                                             by Quotient.sound(
                                                    RationalRepresentative.make(
                                                        (Natural.power(
                                                             Natural.padic_valuation(
                                                                 p, (1 + dy + dx * (1 + dy))), p)
                                                             : Integer),
                                                        Natural.monus(
                                                            Natural.power(
                                                                Natural.padic_valuation(
                                                                    p, (1 + ky + kx * (1 + ky))), p),
                                                            1)),
                                                    Rational.multiply_representatives(
                                                        RationalRepresentative.make(
                                                            (Natural.power(
                                                                 Natural.padic_valuation(p, (1 + dx)), p)
                                                                 : Integer),
                                                            Natural.monus(
                                                                Natural.power(
                                                                    Natural.padic_valuation(p, (1 + kx)), p),
                                                                1)),
                                                        RationalRepresentative.make(
                                                            (Natural.power(
                                                                 Natural.padic_valuation(p, (1 + dy)), p)
                                                                 : Integer),
                                                            Natural.monus(
                                                                Natural.power(
                                                                    Natural.padic_valuation(p, (1 + ky)), p),
                                                                1))),
                                                    Rational.padic_multiplicative_cross_equation(
                                                        p, primality,
                                                        dx, dy, kx, ky))
                                       = absXAtRep * padicAvMkY
                                             by congruenceOf(
                                                    (m : Rational) ↦
                                                        m * padicAvMkY,
                                                    Equality.symmetry(
                                                        Rational.padic_absolute_value_at_succ(
                                                            p, nx, dx, kx, eqAbsNx)))
                                       = absXAtRep * absYAtRep
                                  }
                              }
                       }
                    } } }

-- ----------------------------------------------------------------------
-- Triangle inequality. The remaining norm axiom for the p-adic absolute
-- value: |x + y|_p ≤ |x|_p + |y|_p. Goes via the ultrametric
-- |x + y|_p ≤ max(|x|_p, |y|_p), then max ≤ sum (both are nonneg).

-- Helper: x ≤ x + y when 0 ≤ y. Rational addition right-monotone.
theorem Rational.le_add_right_of_nonneg
        (x y : Rational) (yNonneg : Rational.zero ≤ y)
        : x ≤ x + y :=
  rewrite(Rational.add_zero(x),
          Rational.LessOrEqual.sum(Rational.LessOrEqual.reflexive(x),
              yNonneg))

-- And the symmetric: x ≤ y + x when 0 ≤ y.
theorem Rational.le_add_left_of_nonneg
        (x y : Rational) (yNonneg : Rational.zero ≤ y)
        : x ≤ y + x :=
  rewrite(Rational.add_commutative(x, y),
          Rational.le_add_right_of_nonneg(x, y, yNonneg))

-- ----------------------------------------------------------------------
-- Helper A for the p-adic triangle inequality.
--
-- For p ≥ 1 and Naturals α, β, γ, δ with α + δ ≤ β + γ:
--   mk(make((p^α : Int), p^γ - 1))  ≤  mk(make((p^β : Int), p^δ - 1))
--
-- where p^k = Natural.power(k, p) and "p^γ - 1" abbreviates
-- monus(power(γ, p), 1). The two denominators-minus-one are well-formed
-- because p^γ, p^δ ≥ 1 when p ≥ 1.
--
-- Proof sketch: the difference RHS - LHS β-reduces (through Quotient.lift
-- kernel rules on subtract = add + negate) to mk(make(NUM, DEN)) where
--   NUM = (p^β : Int) * succ(p^γ - 1) + (-(p^α : Int)) * succ(p^δ - 1).
-- Rational.IsNonneg β-reduces (through the lift on IsNonneg) to
-- Integer.IsNonneg(NUM). Rewriting succ(monus(_, 1)) to the underlying
-- power and collecting through Natural.to_integer.multiply_preserves
-- yields NUM = (p^β · p^γ : Int) - (p^α · p^δ : Int). Since α + δ ≤ β + γ
-- and power is exponent-monotone, p^α · p^δ ≤ p^β · p^γ, so the Natural
-- subtraction witness s satisfies (s : Int) = NUM; IsNonneg follows from
-- from_natural_is_nonneg.
theorem Rational.padic_av_form_le_when_exponent_le
        (p : Natural) (primePositive : 1 ≤ p)
        (alpha beta gamma delta : Natural)
        (exponentLe : alpha + delta ≤ beta + gamma)
        : Rational.fraction((Natural.power(alpha, p) : Integer),
                  Natural.monus(Natural.power(gamma, p), 1))
          ≤ Rational.fraction((Natural.power(beta, p) : Integer),
                    Natural.monus(Natural.power(delta, p), 1)) := {
  claim 1 ≤ Natural.power(gamma, p);
  claim 1 ≤ Natural.power(delta, p);
  -- p^α · p^δ ≤ p^β · p^γ via power_add + power_monotone.
  claim productLe
        : Natural.power(alpha, p) * Natural.power(delta, p)
            ≤ Natural.power(beta, p) * Natural.power(gamma, p)
    by rewrite(Natural.power_add(alpha, delta, p),
               rewrite(Natural.power_add(beta, gamma, p),
                       Natural.power_monotone(
                           alpha + delta, beta + gamma, p, exponentLe,
                           primePositive)));
  -- Natural subtraction witness.
  let ⟨s, witnessEq⟩ := Natural.subtraction_witness(
      Natural.power(alpha, p) * Natural.power(delta, p),
      Natural.power(beta, p) * Natural.power(gamma, p),
      productLe);
  -- The raw numerator of (RHS - LHS) equals (s : Integer).
  calc (Natural.power(beta, p) : Integer)
          * ((1 +
                Natural.monus(Natural.power(gamma, p), 1))
              : Integer)
        + -(Natural.power(alpha, p) : Integer)
            * ((1 +
                  Natural.monus(Natural.power(delta, p), 1))
                : Integer)
         = (Natural.power(beta, p) : Integer)
             * (Natural.power(gamma, p) : Integer)
           + -(Natural.power(alpha, p) : Integer)
               * ((1 +
                     Natural.monus(Natural.power(delta, p), 1))
                   : Integer)
         = (Natural.power(beta, p) : Integer)
             * (Natural.power(gamma, p) : Integer)
           + -(Natural.power(alpha, p) : Integer)
               * (Natural.power(delta, p) : Integer)
         = (Natural.power(beta, p) * Natural.power(gamma, p) : Integer)
           + -(Natural.power(alpha, p) : Integer)
               * (Natural.power(delta, p) : Integer)
         = (Natural.power(beta, p) * Natural.power(gamma, p) : Integer)
           + -((Natural.power(alpha, p) : Integer)
                 * (Natural.power(delta, p) : Integer))
         = (Natural.power(beta, p) * Natural.power(gamma, p) : Integer)
           + -(Natural.power(alpha, p) * Natural.power(delta, p) : Integer)
         = (Natural.power(alpha, p) * Natural.power(delta, p) + s : Integer)
           + -(Natural.power(alpha, p) * Natural.power(delta, p) : Integer)
         = (Natural.power(alpha, p) * Natural.power(delta, p) : Integer)
             + (s : Integer)
           + -(Natural.power(alpha, p) * Natural.power(delta, p) : Integer)
         -- (A + S) + -A = A + (S + -A) = A + (-A + S) = (A + -A) + S = 0 + S = S
         = (s : Integer)                                             as numerEqInt;
  ⟨s, numerEqInt⟩
}

-- ----------------------------------------------------------------------
-- Bridge: mk(make(Integer.zero, d)) = Rational.zero. The denominator d
-- collapses by Integer.multiply_zero_left after cross-multiplication.
theorem Rational.zero_numerator_is_zero (d : Natural)
        : Rational.fraction(Integer.zero, d)
          = Rational.zero :=
  Quotient.sound(
      RationalRepresentative.make(Integer.zero, d),
      RationalRepresentative.make(Integer.zero, 0),
      calc Integer.zero * ((1 : Natural) : Integer)
         = Integer.zero * ((1 + d : Natural) : Integer))

-- Sub-case of the p-adic triangle inequality: when |nx| = 0.
--
-- nx must be Integer.zero (via absolute_value_natural_zero_implies_zero),
-- so the Rational x = mk(make(nx, dx)) equals Rational.zero. Hence
-- x + y = y. Likewise |x|_p = 0 (by padic_absolute_value_at_zero), so
-- RHS = Rational.zero + |y|_p = |y|_p. Both sides equal |y|_p; ≤ follows
-- by reflexivity.
theorem Rational.padic_absolute_value_triangle_at_reps_when_nx_zero
        (nx ny : Integer) (dx dy : Natural)
        (eqAbsNxZero : Integer.absolute_value_natural(nx) = 0)
        : Rational.padic_absolute_value(
              p, primality,
              Rational.fraction(nx, dx)
              + Rational.fraction(ny, dy))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Rational.fraction(nx, dx))
              + Rational.padic_absolute_value(
                    p, primality,
                    Rational.fraction(ny, dy)) := {
  let x : Rational :=
      Rational.fraction(nx, dx);
  let y : Rational :=
      Rational.fraction(ny, dy);
  let avX : Rational := Rational.padic_absolute_value(p, primality, x);
  let avY : Rational := Rational.padic_absolute_value(p, primality, y);
  -- |nx| = 0 implies nx = 0, so x = 0_Q and |x|_p = 0. Therefore
  -- |x+y|_p = |y|_p = 0 + |y|_p = |x|_p + |y|_p.
  claim avX = Rational.zero
    by Rational.padic_absolute_value_at_zero(p, nx, dx, eqAbsNxZero);
  claim x = Rational.zero
    by calc x
          = Rational.fraction(Integer.zero, dx)
          = Rational.zero;
  calc Rational.padic_absolute_value(p, primality, x + y)
     = Rational.padic_absolute_value(p, primality, Rational.zero + y)
     = avY
         by Rational.zero_add(y)
     ≤ avY
     = Rational.zero + avY
     = avX + avY
}

-- Sub-case: when |ny| = 0. Symmetric to the nx-zero case. Here we
-- conclude y = Rational.zero, x + y = x, |y|_p = 0, RHS = |x|_p; equal.
theorem Rational.padic_absolute_value_triangle_at_reps_when_ny_zero
        (nx ny : Integer) (dx dy : Natural)
        (eqAbsNyZero : Integer.absolute_value_natural(ny) = 0)
        : Rational.padic_absolute_value(
              p, primality,
              Rational.fraction(nx, dx)
              + Rational.fraction(ny, dy))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Rational.fraction(nx, dx))
              + Rational.padic_absolute_value(
                    p, primality,
                    Rational.fraction(ny, dy)) := {
  let x : Rational :=
      Rational.fraction(nx, dx);
  let y : Rational :=
      Rational.fraction(ny, dy);
  let avX : Rational := Rational.padic_absolute_value(p, primality, x);
  let avY : Rational := Rational.padic_absolute_value(p, primality, y);
  -- Symmetric to the nx_zero case: |ny| = 0 collapses y to 0_Q and
  -- |y|_p to 0, so |x+y|_p = |x|_p = |x|_p + 0 = |x|_p + |y|_p.
  claim avY = Rational.zero
    by Rational.padic_absolute_value_at_zero(p, ny, dy, eqAbsNyZero);
  claim y = Rational.zero
    by calc y
          = Rational.fraction(Integer.zero, dy)
          = Rational.zero;
  calc Rational.padic_absolute_value(p, primality, x + y)
     = Rational.padic_absolute_value(p, primality, x + Rational.zero)
     = avX
         by Rational.add_zero(x)
     ≤ avX
     = avX + Rational.zero
     = avX + avY
}

-- Sub-case: when the sum's numerator has absolute value zero.
-- Then padic_av(x+y) = 0 (by padic_absolute_value_at_zero), and RHS is
-- a sum of two nonneg padic_avs (hence nonneg). So 0 ≤ RHS.
theorem Rational.padic_absolute_value_triangle_at_reps_when_sum_zero
        (nx ny : Integer) (dx dy : Natural)
        (eqAbsSumZero
            : Integer.absolute_value_natural(
                  nx * ((1 + dy) : Integer)
                  + ny * ((1 + dx) : Integer)) = 0)
        : Rational.padic_absolute_value(
              p, primality,
              Rational.fraction(nx, dx)
              + Rational.fraction(ny, dy))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Rational.fraction(nx, dx))
              + Rational.padic_absolute_value(
                    p, primality,
                    Rational.fraction(ny, dy)) := {
  let x : Rational :=
      Rational.fraction(nx, dx);
  let y : Rational :=
      Rational.fraction(ny, dy);
  let avX : Rational := Rational.padic_absolute_value(p, primality, x);
  let avY : Rational := Rational.padic_absolute_value(p, primality, y);
  -- |x+y|_p = 0 (sum's numerator has |·| = 0) and avX + avY is nonneg,
  -- so LHS ≤ RHS via 0 ≤ RHS.
  claim lhsIsZero
        : Rational.padic_absolute_value(p, primality, x + y) = Rational.zero
    by Rational.padic_absolute_value_at_zero(
           p,
           nx * ((1 + dy) : Integer) + ny * ((1 + dx) : Integer),
           dy + dx * (1 + dy),
           eqAbsSumZero);
  claim avXNonneg : Rational.IsNonneg(avX)
    by Rational.IsNonneg_of_LessOrEqual_zero(
           avX, Rational.padic_absolute_value_nonneg(p, primality, x));
  claim avYNonneg : Rational.IsNonneg(avY)
    by Rational.IsNonneg_of_LessOrEqual_zero(
           avY, Rational.padic_absolute_value_nonneg(p, primality, y));
  rewrite(
      Equality.symmetry(lhsIsZero),
      Rational.LessOrEqual_zero_of_IsNonneg(
          avX + avY,
          Rational.IsNonneg.add(avX, avY, avXNonneg, avYNonneg)))
}

-- WLOG sub-case for case D: |nx| ≥ 1, |ny| ≥ 1, |sum| ≥ 1, and the
-- p-adic valuations satisfy v_p(|nx·succ(dy)|) ≤ v_p(|ny·succ(dx)|).
-- Applies the Integer ultrametric to (A, B) = (nx·succ(dy), ny·succ(dx))
-- to bound v_p(|sum|) from below, then Helper A turns the exponent
-- inequality into |x+y|_p ≤ |x|_p, and le_add_right_of_nonneg lifts
-- to |x+y|_p ≤ |x|_p + |y|_p.
theorem Rational.padic_absolute_value_triangle_at_reps_wlog_case_a
        (nx ny : Integer) (dx dy : Natural)
        (kx ky kSum : Natural)
        (eqAbsNx : Integer.absolute_value_natural(nx) = (1 + kx))
        (eqAbsNy : Integer.absolute_value_natural(ny) = (1 + ky))
        (eqAbsSum
            : Integer.absolute_value_natural(
                  nx * ((1 + dy) : Integer)
                  + ny * ((1 + dx) : Integer)) = (1 + kSum))
        (vALeqVB
            : Natural.padic_valuation(p, (1 + kx))
                + Natural.padic_valuation(p, (1 + dy))
              ≤ Natural.padic_valuation(p, (1 + ky))
                  + Natural.padic_valuation(p, (1 + dx)))
        : Rational.padic_absolute_value(
              p, primality,
              Rational.fraction(nx, dx)
              + Rational.fraction(ny, dy))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Rational.fraction(nx, dx))
              + Rational.padic_absolute_value(
                    p, primality,
                    Rational.fraction(ny, dy)) := {
  -- Primality and successor-positivity preamble.
  claim primeAtLeastTwo : 2 ≤ p
    by Natural.is_prime.at_least_two(p, primality);
  claim primePositive : 1 ≤ p
    by Natural.is_prime.positive(p, primality);
  claim 1 ≤ (1 + kx);
  claim 1 ≤ (1 + ky);
  claim succDxPos    : 1 ≤ (1 + dx)    by Natural.successor_positive(dx);
  claim succDyPos    : 1 ≤ (1 + dy)    by Natural.successor_positive(dy);
  claim succKSumPos  : 1 ≤ (1 + kSum)  by Natural.successor_positive(kSum);
  -- |nx · (succ(dy):Int)|_Nat = |nx|_Nat · succ(dy) = succ(kx) · succ(dy).
  -- (|(succ(dy):Int)|_Nat = succ(dy) is definitional via distance(succ(dy), 0).)
  calc Integer.absolute_value_natural(
           nx * ((1 + dy) : Integer))
     = Integer.absolute_value_natural(nx) * (1 + dy)
           by Integer.absolute_value_natural_multiplicative
     = (1 + kx) * (1 + dy);
  calc Integer.absolute_value_natural(
           ny * ((1 + dx) : Integer))
     = Integer.absolute_value_natural(ny) * (1 + dx)
           by Integer.absolute_value_natural_multiplicative
     = (1 + ky) * (1 + dx);
  -- |sum|_Nat ≥ 1.
  claim sumAbsPositive
        : 1
            ≤ Integer.absolute_value_natural(
                  nx * ((1 + dy) : Integer)
                  + ny * ((1 + dx) : Integer))
    by rewrite(Equality.symmetry(eqAbsSum), succKSumPos);
  -- v_p(|A|_Nat) = v_p(succ(kx)) + v_p(succ(dy)) (via mult on succ-form).
  calc Natural.padic_valuation(
           p, Integer.absolute_value_natural(
                  nx * ((1 + dy) : Integer)))
     = Natural.padic_valuation(p, (1 + kx) * (1 + dy))
     = Natural.padic_valuation(p, (1 + kx))
         + Natural.padic_valuation(p, (1 + dy));
  -- v_p(|B|_Nat) = v_p(succ(ky)) + v_p(succ(dx)).
  calc Natural.padic_valuation(
           p, Integer.absolute_value_natural(
                  ny * ((1 + dx) : Integer)))
     = Natural.padic_valuation(p, (1 + ky) * (1 + dx))
     = Natural.padic_valuation(p, (1 + ky))
         + Natural.padic_valuation(p, (1 + dx));
  -- v_p(|A|_Nat) ≤ v_p(|B|_Nat), from vALeqVB via the formula bridges.
  claim valuationLe
        : Natural.padic_valuation(
              p, Integer.absolute_value_natural(
                     nx * ((1 + dy) : Integer)))
          ≤ Natural.padic_valuation(
                p, Integer.absolute_value_natural(
                       ny * ((1 + dx) : Integer)))
    by calc Natural.padic_valuation(
                p, Integer.absolute_value_natural(
                       nx * ((1 + dy) : Integer)))
          = Natural.padic_valuation(p, (1 + kx))
              + Natural.padic_valuation(p, (1 + dy))
          ≤ Natural.padic_valuation(p, (1 + ky))
              + Natural.padic_valuation(p, (1 + dx))
          = Natural.padic_valuation(
                p, Integer.absolute_value_natural(
                       ny * ((1 + dx) : Integer)));
  -- Ultrametric: v_p(|A|) ≤ v_p(|A+B|).
  claim ultraIneq
        : Natural.padic_valuation(
              p, Integer.absolute_value_natural(
                     nx * ((1 + dy) : Integer)))
          ≤ Natural.padic_valuation(
                p, Integer.absolute_value_natural(
                       nx * ((1 + dy) : Integer)
                       + ny * ((1 + dx) : Integer)))
    by Integer.padic_valuation_absolute_value_natural_ultrametric_when_le(
           p, primeAtLeastTwo,
           nx * ((1 + dy) : Integer),
           ny * ((1 + dx) : Integer),
           sumAbsPositive, valuationLe);
  -- v_p(|sum|_Nat) = v_p(succ(kSum)) via eqAbsSum + congruenceOf.
  claim Natural.padic_valuation(
            p, Integer.absolute_value_natural(
                   nx * ((1 + dy) : Integer)
                   + ny * ((1 + dx) : Integer)))
        = Natural.padic_valuation(p, (1 + kSum));
  -- Combine: v_p(succ(kx)) + v_p(succ(dy)) ≤ v_p(succ(kSum)).
  claim vASumLeVKSum
        : Natural.padic_valuation(p, (1 + kx))
            + Natural.padic_valuation(p, (1 + dy))
          ≤ Natural.padic_valuation(p, (1 + kSum))
    by calc Natural.padic_valuation(p, (1 + kx))
              + Natural.padic_valuation(p, (1 + dy))
          = Natural.padic_valuation(
                p, Integer.absolute_value_natural(
                       nx * ((1 + dy) : Integer)))
          ≤ Natural.padic_valuation(
                p, Integer.absolute_value_natural(
                       nx * ((1 + dy) : Integer)
                       + ny * ((1 + dx) : Integer)))
          = Natural.padic_valuation(p, (1 + kSum));
  -- v_p(succ(dy + dx · succ(dy))) = v_p(succ(dx)) + v_p(succ(dy)).
  -- This uses padic_valuation_multiplicative on succ(dx) and succ(dy),
  -- whose product is definitionally succ(dy + dx · succ(dy)).
  claim Natural.padic_valuation(p, (1 + dy + dx * (1 + dy)))
          = Natural.padic_valuation(p, (1 + dx))
              + Natural.padic_valuation(p, (1 + dy))
    by Natural.padic_valuation_multiplicative(
           p, (1 + dx), (1 + dy),
           primality, succDxPos, succDyPos);
  -- The Helper A exponent inequality. Substitute vDFormulaMult on the
  -- LHS, then AC-rearrange to align with le_add_preserves_right; the
  -- final ≤ step uses vASumLeVKSum to bound (vp(kx) + vp(dy)) by vp(kSum).
  calc Natural.padic_valuation(p, (1 + dy + dx * (1 + dy)))
         + Natural.padic_valuation(p, (1 + kx))
     = (Natural.padic_valuation(p, (1 + dx))
            + Natural.padic_valuation(p, (1 + dy)))
           + Natural.padic_valuation(p, (1 + kx))
     = Natural.padic_valuation(p, (1 + dx))
           + (Natural.padic_valuation(p, (1 + kx))
              + Natural.padic_valuation(p, (1 + dy)))
     ≤ Natural.padic_valuation(p, (1 + dx))
           + Natural.padic_valuation(p, (1 + kSum))                 as exponentLe;
  -- Apply Helper A.
  claim helperAResult
        : Rational.fraction((Natural.power(
                       Natural.padic_valuation(p, (1 + dy + dx * (1 + dy))), p)
                       : Integer),
                  Natural.monus(
                      Natural.power(
                          Natural.padic_valuation(p, (1 + kSum)), p),
                      1))
          ≤ Rational.fraction((Natural.power(
                         Natural.padic_valuation(p, (1 + dx)), p)
                         : Integer),
                    Natural.monus(
                        Natural.power(
                            Natural.padic_valuation(p, (1 + kx)), p),
                        1))
    by Rational.padic_av_form_le_when_exponent_le(
           p, primePositive,
           Natural.padic_valuation(p, (1 + dy + dx * (1 + dy))),
           Natural.padic_valuation(p, (1 + dx)),
           Natural.padic_valuation(p, (1 + kSum)),
           Natural.padic_valuation(p, (1 + kx)),
           exponentLe);
  -- Bridge LHS: padic_av(x+y) = mk(make((p^... : Int), ...)).
  claim Rational.padic_absolute_value(
            p, primality,
            Rational.fraction(nx, dx)
            + Rational.fraction(ny, dy))
        = Rational.fraction((Natural.power(
                       Natural.padic_valuation(p, (1 + dy + dx * (1 + dy))), p)
                       : Integer),
                  Natural.monus(
                      Natural.power(
                          Natural.padic_valuation(p, (1 + kSum)), p),
                      1))
    by Rational.padic_absolute_value_at_succ(
           p,
           nx * ((1 + dy) : Integer)
             + ny * ((1 + dx) : Integer),
           dy + dx * (1 + dy),
           kSum, eqAbsSum);
  -- Bridge RHS: |x|_p = mk(make((p^... : Int), ...)).
  claim Rational.padic_absolute_value(
            p, primality,
            Rational.fraction(nx, dx))
        = Rational.fraction((Natural.power(
                       Natural.padic_valuation(p, (1 + dx)), p)
                       : Integer),
                  Natural.monus(
                      Natural.power(
                          Natural.padic_valuation(p, (1 + kx)), p),
                      1))
    by Rational.padic_absolute_value_at_succ(p, nx, dx, kx, eqAbsNx);
  -- Transport helperAResult to: padic_av(x+y) ≤ |x|_p.
  claim padicAvSumLeX
        : Rational.padic_absolute_value(
              p, primality,
              Rational.fraction(nx, dx)
              + Rational.fraction(ny, dy))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Rational.fraction(nx, dx))
    by calc Rational.padic_absolute_value(
                p, primality,
                Rational.fraction(nx, dx)
                + Rational.fraction(ny, dy))
          = Rational.fraction((Natural.power(
                         Natural.padic_valuation(p, (1 + dy + dx * (1 + dy))), p)
                         : Integer),
                    Natural.monus(
                        Natural.power(
                            Natural.padic_valuation(p, (1 + kSum)), p),
                        1))
          ≤ Rational.fraction((Natural.power(
                         Natural.padic_valuation(p, (1 + dx)), p)
                         : Integer),
                    Natural.monus(
                        Natural.power(
                            Natural.padic_valuation(p, (1 + kx)), p),
                        1))
          = Rational.padic_absolute_value(
                p, primality,
                Rational.fraction(nx, dx));
  -- |y|_p ≥ 0.
  claim padicAvYNonneg
        : Rational.zero
            ≤ Rational.padic_absolute_value(
                  p, primality,
                  Rational.fraction(ny, dy))
    by Rational.padic_absolute_value_nonneg(
           p, primality,
           Rational.fraction(ny, dy));
  -- |x|_p ≤ |x|_p + |y|_p.
  claim padicAvXLeXPlusY
        : Rational.padic_absolute_value(
              p, primality,
              Rational.fraction(nx, dx))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Rational.fraction(nx, dx))
              + Rational.padic_absolute_value(
                    p, primality,
                    Rational.fraction(ny, dy))
    by Rational.le_add_right_of_nonneg(
           Rational.padic_absolute_value(
               p, primality,
               Rational.fraction(nx, dx)),
           Rational.padic_absolute_value(
               p, primality,
               Rational.fraction(ny, dy)),
           padicAvYNonneg);
  calc Rational.padic_absolute_value(
           p, primality,
           Rational.fraction(nx, dx)
             + Rational.fraction(ny, dy))
     ≤ Rational.padic_absolute_value(
           p, primality,
           Rational.fraction(nx, dx))
     ≤ Rational.padic_absolute_value(
           p, primality,
           Rational.fraction(nx, dx))
         + Rational.padic_absolute_value(
               p, primality,
               Rational.fraction(ny, dy))
}

-- Sub-case D: |nx| ≥ 1, |ny| ≥ 1, |sum| ≥ 1. Dispatch via totality on
-- v_p(succ(kx)) + v_p(succ(dy)) vs v_p(succ(ky)) + v_p(succ(dx)),
-- applying the WLOG helper directly in case A and after swapping x ↔ y
-- (with commutativity bridges) in case B.
theorem Rational.padic_absolute_value_triangle_at_reps_when_all_succ
        (nx ny : Integer) (dx dy : Natural)
        (kx ky kSum : Natural)
        (eqAbsNx : Integer.absolute_value_natural(nx) = (1 + kx))
        (eqAbsNy : Integer.absolute_value_natural(ny) = (1 + ky))
        (eqAbsSum
            : Integer.absolute_value_natural(
                  nx * ((1 + dy) : Integer)
                  + ny * ((1 + dx) : Integer)) = (1 + kSum))
        : Rational.padic_absolute_value(
              p, primality,
              Rational.fraction(nx, dx)
              + Rational.fraction(ny, dy))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Rational.fraction(nx, dx))
              + Rational.padic_absolute_value(
                    p, primality,
                    Rational.fraction(ny, dy)) :=
  claim Natural.padic_valuation(p, (1 + kx))
            + Natural.padic_valuation(p, (1 + dy))
          ≤ Natural.padic_valuation(p, (1 + ky))
              + Natural.padic_valuation(p, (1 + dx))
        ∨ Natural.padic_valuation(p, (1 + ky))
              + Natural.padic_valuation(p, (1 + dx))
          ≤ Natural.padic_valuation(p, (1 + kx))
              + Natural.padic_valuation(p, (1 + dy))
  claim by cases {
    in (Natural.padic_valuation(p, (1 + kx))
            + Natural.padic_valuation(p, (1 + dy))
          ≤ Natural.padic_valuation(p, (1 + ky))
              + Natural.padic_valuation(p, (1 + dx))) as vALevB:
        Rational.padic_absolute_value_triangle_at_reps_wlog_case_a(
            p, primality, nx, ny, dx, dy, kx, ky, kSum,
            eqAbsNx, eqAbsNy, eqAbsSum, vALevB)
    in (Natural.padic_valuation(p, (1 + ky))
            + Natural.padic_valuation(p, (1 + dx))
          ≤ Natural.padic_valuation(p, (1 + kx))
              + Natural.padic_valuation(p, (1 + dy))) as vBLevA: {
      -- eqAbsSum with addends swapped (via Integer.add_commutative).
      calc Integer.absolute_value_natural(
               ny * ((1 + dx) : Integer)
               + nx * ((1 + dy) : Integer))
         = Integer.absolute_value_natural(
               nx * ((1 + dy) : Integer)
               + ny * ((1 + dx) : Integer))
         = (1 + kSum)                                                as eqAbsSumSwapped;
      -- Apply WLOG helper with x, y swapped: get |y+x|_p ≤ |y|_p + |x|_p.
      claim swappedResult
            : Rational.padic_absolute_value(
                  p, primality,
                  Rational.fraction(ny, dy)
                  + Rational.fraction(nx, dx))
              ≤ Rational.padic_absolute_value(
                    p, primality,
                    Rational.fraction(ny, dy))
                  + Rational.padic_absolute_value(
                        p, primality,
                        Rational.fraction(nx, dx))
        by Rational.padic_absolute_value_triangle_at_reps_wlog_case_a(
               p, primality, ny, nx, dy, dx, ky, kx, kSum,
               eqAbsNy, eqAbsNx, eqAbsSumSwapped, vBLevA);
      -- Transport via add_commutative on both sides:
      --   y + x = x + y, |y|_p + |x|_p = |x|_p + |y|_p.
      claim Rational.fraction(ny, dy)
              + Rational.fraction(nx, dx)
            = Rational.fraction(nx, dx)
                + Rational.fraction(ny, dy);
      claim Rational.padic_absolute_value(
                p, primality,
                Rational.fraction(ny, dy))
              + Rational.padic_absolute_value(
                    p, primality,
                    Rational.fraction(nx, dx))
            = Rational.padic_absolute_value(
                  p, primality,
                  Rational.fraction(nx, dx))
                + Rational.padic_absolute_value(
                      p, primality,
                      Rational.fraction(ny, dy));
      calc Rational.padic_absolute_value(
               p, primality,
               Rational.fraction(nx, dx)
               + Rational.fraction(ny, dy))
         = Rational.padic_absolute_value(
               p, primality,
               Rational.fraction(ny, dy)
               + Rational.fraction(nx, dx))
         ≤ Rational.padic_absolute_value(
               p, primality,
               Rational.fraction(ny, dy))
             + Rational.padic_absolute_value(
                   p, primality,
                   Rational.fraction(nx, dx))
         = Rational.padic_absolute_value(
               p, primality,
               Rational.fraction(nx, dx))
             + Rational.padic_absolute_value(
                   p, primality,
                   Rational.fraction(ny, dy))
    }
  }

-- Triangle inequality at the Rational representative level. Dispatches
-- on |nx|, |ny|, and the sum's |·|_Nat via the function-then-cases pattern.
theorem Rational.padic_absolute_value_triangle_at_representatives
        (nx ny : Integer) (dx dy : Natural)
        : Rational.padic_absolute_value(
              p, primality,
              Rational.fraction(nx, dx)
              + Rational.fraction(ny, dy))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Rational.fraction(nx, dx))
              + Rational.padic_absolute_value(
                    p, primality,
                    Rational.fraction(ny, dy)) :=
  cases Integer.absolute_value_natural(nx) with eqAbsNxSucc {
     | zero =>
         Rational.padic_absolute_value_triangle_at_reps_when_nx_zero(
             p, primality, nx, ny, dx, dy, eqAbsNxSucc)
     | successor(kx) =>
         cases Integer.absolute_value_natural(ny) with eqAbsNySucc {
            | zero =>
                Rational.padic_absolute_value_triangle_at_reps_when_ny_zero(
                    p, primality, nx, ny, dx, dy, eqAbsNySucc)
            | successor(ky) =>
                cases Integer.absolute_value_natural(
                          nx * ((1 + dy) : Integer)
                          + ny * ((1 + dx) : Integer)) with eqAbsSumSucc {
                   | zero =>
                       Rational.padic_absolute_value_triangle_at_reps_when_sum_zero(
                           p, primality, nx, ny, dx, dy, eqAbsSumSucc)
                   | successor(kSum) =>
                       Rational.padic_absolute_value_triangle_at_reps_when_all_succ(
                           p, primality, nx, ny, dx, dy,
                           kx, ky, kSum,
                           eqAbsNxSucc, eqAbsNySucc, eqAbsSumSucc)
                 }
          }
   }

-- Top-level: |x+y|_p ≤ |x|_p + |y|_p for all Rationals x, y. Lift via
-- Quotient.induct_two.
theorem Rational.padic_absolute_value_triangle
        (x y : Rational)
        : Rational.padic_absolute_value(p, primality, x + y)
          ≤ Rational.padic_absolute_value(p, primality, x)
              + Rational.padic_absolute_value(p, primality, y) :=
  cases x { | RationalRepresentative.make(nx, dx) =>
    cases y { | RationalRepresentative.make(ny, dy) =>
      Rational.padic_absolute_value_triangle_at_representatives(
          p, primality, nx, ny, dx, dy) } }

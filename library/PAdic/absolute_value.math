-- PAdic/absolute_value.math
--
-- The p-adic absolute value `|x|_p` on Rationals. For a prime p:
--   |0|_p = 0
--   |x|_p = p^(v_p(d) - v_p(n))   for x = n/d ≠ 0,
-- where v_p(_) is the Natural-level p-adic valuation (the exponent
-- of p in a Natural's prime factorization). Represented directly as
-- the Rational `p^v_p(d) / p^v_p(n)`; no real-valued exponent
-- needed, so the definition lives entirely in the Rational world.
--
-- Layout:
--   - `padic_absolute_value_at_representative` defines the value
--     at the (numerator, denominator) representative level.
--   - `padic_absolute_value_respect` shows that representative
--     equivalence is preserved.
--   - `padic_absolute_value` is the Quotient.lift onto Rational.
--   - The rest of the file proves non-negativity,
--     multiplicativity, and the strong triangle inequality, plus a
--     few cross-multiplication and case-analysis helpers used by
--     them.

module PAdic.absolute_value

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.order
import Natural.cancellation
import Natural.divisibility
import Natural.monus
import Natural.power
import Natural.prime
import Natural.padic_valuation
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.absolute_value
import Integer.absolute_value_natural
import Integer.absolute_value_multiplicative
import Integer.sign
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.order
import Rational.absolute_value
import Rational.order_arithmetic
import Rational.order_multiplication
import Rational.ring
import Rational.positive

convention p : Natural with primality : Natural.is_prime(p)

-- Honest representative-level p-adic absolute value. For a
-- Rational representative (n, d) (encoding n / succ(d)):
--   * if the numerator is zero, return Rational.zero.
--   * otherwise (|n| = succ(k)), return the Rational
--         p^v_p(succ(d)) / p^v_p(succ(k)),
--     i.e., mk(make((p^v_p(succ(d)) : Integer),
--                   monus(p^v_p(succ(k)), 1))).
-- The denominator stays positive because p^v_p ≥ 1 for prime p ≥ 1
-- (witness: power_positive). The respect proof (next phase) leverages
-- padic_valuation_multiplicative.
definition Rational.padic_absolute_value_at_representative
        (p : Natural) : RationalRepresentative → Rational
  | RationalRepresentative.make(n, d) =>
      (cases Integer.absolute_value_natural(n) {
         | zero => Rational.zero
         | successor(k) =>
             Quotient.mk(RationalRepresentative.make(
                     (Natural.power(
                          Natural.padic_valuation(p, successor(d)), p)
                          : Integer),
                     Natural.monus(
                         Natural.power(
                             Natural.padic_valuation(p, successor(k)), p),
                         successor(zero))))
       } : Rational)

-- Helper: cross-multiplication transfers from the Integer numerator
-- equation `n1 · succ(d2) = n2 · succ(d1)` to a Natural absolute-value
-- equation. Apply Integer.absolute_value to both sides, multiplicativity
-- distributes it, |succ(d) : Integer| reduces to succ(d), and the
-- absolute_value_natural_is_image bridge plus to_integer.injective
-- drops to Natural.
theorem Rational.padic_cross_mult_natural_absolute_value
        (n1 n2 : Integer) (d1 d2 : Natural)
        (cross : n1 * (successor(d2) : Integer)
                 = n2 * (successor(d1) : Integer))
        : Integer.absolute_value_natural(n1) * successor(d2)
          = Integer.absolute_value_natural(n2) * successor(d1) :=
  Natural.to_integer.injective(
      Integer.absolute_value_natural(n1) * successor(d2),
      Integer.absolute_value_natural(n2) * successor(d1),
      calc (Integer.absolute_value_natural(n1) * successor(d2) : Integer)
         = (Integer.absolute_value_natural(n1) : Integer)
             * (successor(d2) : Integer)
         = Integer.absolute_value(n1) * (successor(d2) : Integer)
         = Integer.absolute_value(n1)
             * Integer.absolute_value((successor(d2) : Integer))
         = Integer.absolute_value(n1 * (successor(d2) : Integer))
         = Integer.absolute_value(n2 * (successor(d1) : Integer))
         = Integer.absolute_value(n2)
             * Integer.absolute_value((successor(d1) : Integer))
         = Integer.absolute_value(n2) * (successor(d1) : Integer)
         = (Integer.absolute_value_natural(n2) : Integer)
             * (successor(d1) : Integer)
         = (Integer.absolute_value_natural(n2) * successor(d1) : Integer))

-- Successor-after-monus-one identity: succ(monus(m, 1)) = m for m ≥ 1.
theorem Natural.successor_monus_one_when_positive
        : (m : Natural)
          → successor(zero) ≤ m
          → successor(Natural.monus(m, successor(zero))) = m
  | zero, mPositive =>
      absurd(mPositive)
  | successor(j), _ =>
      congruenceOf(successor, Natural.monus_zero(j))

-- The Integer equivalence equation that Quotient.sound needs in the
-- "both numerators nonzero" branch of respect, derived from the
-- corresponding cross-multiplication on succ(d_i) and succ(k_i) at
-- Natural level. Uses multiplicativity of padic_valuation (needs prime).
theorem Rational.padic_quotient_cross_equation
        (d1 d2 k1 k2 : Natural)
        (succCross
            : successor(d1) * successor(k2) = successor(d2) * successor(k1))
        : (Natural.power(Natural.padic_valuation(p, successor(d1)), p) : Integer)
          * (successor(Natural.monus(
                 Natural.power(
                     Natural.padic_valuation(p, successor(k2)), p),
                 successor(zero))) : Integer)
          = (Natural.power(Natural.padic_valuation(p, successor(d2)), p) : Integer)
            * (successor(Natural.monus(
                   Natural.power(
                       Natural.padic_valuation(p, successor(k1)), p),
                   successor(zero))) : Integer) := {
  claim primeAtLeastTwo   : 2 ≤ p             by Natural.is_prime.at_least_two(p, primality);
  claim primePositive     : 1 ≤ p             by Natural.is_prime.positive(p, primality);
  claim succD1Positive : 1 ≤ successor(d1)  by Natural.successor_positive(d1);
  claim succD2Positive : 1 ≤ successor(d2)  by Natural.successor_positive(d2);
  claim succK1Positive : 1 ≤ successor(k1)  by Natural.successor_positive(k1);
  claim succK2Positive : 1 ≤ successor(k2)  by Natural.successor_positive(k2);
  -- Step 1: apply v_p to succCross.
  claim valuationCross
        : Natural.padic_valuation(p, successor(d1) * successor(k2))
          = Natural.padic_valuation(p, successor(d2) * successor(k1))
    by congruenceOf(
           function (m : Natural) => Natural.padic_valuation(p, m),
           succCross);
  -- Step 2: distribute multiplicativity on both sides.
  claim valuationSum
        : Natural.padic_valuation(p, successor(d1))
            + Natural.padic_valuation(p, successor(k2))
          = Natural.padic_valuation(p, successor(d2))
              + Natural.padic_valuation(p, successor(k1))
    by Equality.transitivity(
           Equality.symmetry(
               Natural.padic_valuation_multiplicative(
                   p, successor(d1), successor(k2),
                   primality, succD1Positive, succK2Positive)),
           Equality.transitivity(
               valuationCross,
               Natural.padic_valuation_multiplicative(
                   p, successor(d2), successor(k1),
                   primality, succD2Positive, succK1Positive)));
  -- Step 3: apply p^_ to both sides, distribute via power_add.
  claim naturalProduct
        : Natural.power(Natural.padic_valuation(p, successor(d1)), p)
            * Natural.power(Natural.padic_valuation(p, successor(k2)), p)
          = Natural.power(Natural.padic_valuation(p, successor(d2)), p)
              * Natural.power(Natural.padic_valuation(p, successor(k1)), p)
    by Equality.transitivity(
           Equality.symmetry(
               Natural.power_add(
                   Natural.padic_valuation(p, successor(d1)),
                   Natural.padic_valuation(p, successor(k2)), p)),
           Equality.transitivity(
               congruenceOf(
                   function (m : Natural) => Natural.power(m, p),
                   valuationSum),
               Natural.power_add(
                   Natural.padic_valuation(p, successor(d2)),
                   Natural.padic_valuation(p, successor(k1)), p)));
  -- Step 4: rewrite p^v_p(succ(k)) as succ(monus(p^v_p(succ(k)), 1)) using
  -- successor_monus_one_when_positive (p^v_p ≥ 1 from power_positive).
  claim powerSuccK1Positive
        : successor(zero)
            ≤ Natural.power(Natural.padic_valuation(p, successor(k1)), p)
    by Natural.power_positive(
           Natural.padic_valuation(p, successor(k1)), p, primePositive);
  claim powerSuccK2Positive
        : successor(zero)
            ≤ Natural.power(Natural.padic_valuation(p, successor(k2)), p)
    by Natural.power_positive(
           Natural.padic_valuation(p, successor(k2)), p, primePositive);
  -- Step 5: cast naturalProduct to Integer and distribute.
  calc (Natural.power(Natural.padic_valuation(p, successor(d1)), p) : Integer)
       * (successor(Natural.monus(
              Natural.power(
                  Natural.padic_valuation(p, successor(k2)), p),
              successor(zero))) : Integer)
     = (Natural.power(Natural.padic_valuation(p, successor(d1)), p) : Integer)
       * (Natural.power(Natural.padic_valuation(p, successor(k2)), p)
              : Integer)
            by congruenceOf(
                   function (m : Natural) =>
                       (Natural.power(
                            Natural.padic_valuation(p, successor(d1)), p)
                            : Integer)
                       * (m : Integer),
                   Natural.successor_monus_one_when_positive(
                       Natural.power(
                           Natural.padic_valuation(p, successor(k2)), p),
                       powerSuccK2Positive))
     = (Natural.power(Natural.padic_valuation(p, successor(d1)), p)
          * Natural.power(Natural.padic_valuation(p, successor(k2)), p)
          : Integer)
     = (Natural.power(Natural.padic_valuation(p, successor(d2)), p)
          * Natural.power(Natural.padic_valuation(p, successor(k1)), p)
          : Integer)
     = (Natural.power(Natural.padic_valuation(p, successor(d2)), p) : Integer)
       * (Natural.power(Natural.padic_valuation(p, successor(k1)), p)
              : Integer)
     = (Natural.power(Natural.padic_valuation(p, successor(d2)), p) : Integer)
       * (successor(Natural.monus(
              Natural.power(
                  Natural.padic_valuation(p, successor(k1)), p),
              successor(zero))) : Integer)
            by congruenceOf(
                   function (m : Natural) =>
                       (Natural.power(
                            Natural.padic_valuation(p, successor(d2)), p)
                            : Integer)
                       * (m : Integer),
                   Equality.symmetry(
                       Natural.successor_monus_one_when_positive(
                           Natural.power(
                               Natural.padic_valuation(p, successor(k1)), p),
                           powerSuccK1Positive)))
}

-- Reduction lemma: when |n| = 0, the at_representative function returns
-- Rational.zero. Transport the inner `cases` motive at zero. (The
-- 2-arg `rewrite` form can't replace this — the cases scrutinee gets
-- ι-reduced before the matcher can locate the rewrite target, so the
-- explicit motive is genuinely needed here.)
theorem Rational.padic_absolute_value_at_zero
        (p : Natural) (n : Integer) (d : Natural)
        (absZero : Integer.absolute_value_natural(n) = zero)
        : Rational.padic_absolute_value_at_representative(
              p, RationalRepresentative.make(n, d))
          = Rational.zero :=
  Equality.transport_proposition(
      Natural,
      function (m : Natural) =>
          (cases m {
             | zero => Rational.zero
             | successor(k) =>
                 Quotient.mk(RationalRepresentative.make(
                         (Natural.power(
                              Natural.padic_valuation(p, successor(d)), p)
                              : Integer),
                         Natural.monus(
                             Natural.power(
                                 Natural.padic_valuation(p, successor(k)), p),
                             successor(zero))))
           } : Rational) = Rational.zero,
      zero, Integer.absolute_value_natural(n),
      Equality.symmetry(absZero),
      reflexivity(Rational, Rational.zero))

-- Reduction lemma: when |n| = succ(k), the at_representative function
-- returns the explicit p^v_p / p^v_p Rational form.
theorem Rational.padic_absolute_value_at_succ
        (p : Natural) (n : Integer) (d k : Natural)
        (absSucc : Integer.absolute_value_natural(n) = successor(k))
        : Rational.padic_absolute_value_at_representative(
              p, RationalRepresentative.make(n, d))
          = Quotient.mk(RationalRepresentative.make(
                    (Natural.power(
                         Natural.padic_valuation(p, successor(d)), p)
                         : Integer),
                    Natural.monus(
                        Natural.power(
                            Natural.padic_valuation(p, successor(k)), p),
                        successor(zero)))) :=
  Equality.transport_proposition(
      Natural,
      function (m : Natural) =>
          (cases m {
             | zero => Rational.zero
             | successor(k') =>
                 Quotient.mk(RationalRepresentative.make(
                         (Natural.power(
                              Natural.padic_valuation(p, successor(d)), p)
                              : Integer),
                         Natural.monus(
                             Natural.power(
                                 Natural.padic_valuation(p, successor(k')), p),
                             successor(zero))))
           } : Rational)
          = Quotient.mk(RationalRepresentative.make(
                    (Natural.power(
                         Natural.padic_valuation(p, successor(d)), p)
                         : Integer),
                    Natural.monus(
                        Natural.power(
                            Natural.padic_valuation(p, successor(k)), p),
                        successor(zero)))),
      successor(k), Integer.absolute_value_natural(n),
      Equality.symmetry(absSucc),
      reflexivity(Rational,
          Quotient.mk(RationalRepresentative, RationalEquivalent,
                      RationalRepresentative.make(
                  (Natural.power(
                       Natural.padic_valuation(p, successor(d)), p)
                       : Integer),
                  Natural.monus(
                      Natural.power(
                          Natural.padic_valuation(p, successor(k)), p),
                      successor(zero))))))

-- The main respect proof: equivalent Rational representatives map to
-- the same Rational under the p-adic absolute value. Four cases on
-- the (|n1|, |n2|) values of Integer.absolute_value_natural:
--   * both zero: both sides reduce to Rational.zero.
--   * |n1| = 0 and |n2| = succ(k2): naturalCross gives 0 = succ(_),
--     contradiction.
--   * |n1| = succ(k1) and |n2| = 0: symmetric contradiction.
--   * both successors: build the Integer cross-equation for Quotient.sound
--     via the padic_quotient_cross_equation helper.
theorem Rational.padic_absolute_value_respect
        (rep1 rep2 : RationalRepresentative)
        (equivHyp : RationalEquivalent(rep1, rep2))
        : Rational.padic_absolute_value_at_representative(p, rep1)
          = Rational.padic_absolute_value_at_representative(p, rep2) :=
  (cases rep1 {
     | RationalRepresentative.make(n1, d1) =>
         (cases rep2 {
            | RationalRepresentative.make(n2, d2) =>
             function (cross : n1 * (successor(d2) : Integer)
                              = n2 * (successor(d1) : Integer)) => {
               claim naturalCross
                     : Integer.absolute_value_natural(n1) * successor(d2)
                       = Integer.absolute_value_natural(n2) * successor(d1)
                 by Rational.padic_cross_mult_natural_absolute_value(
                        n1, n2, d1, d2, cross);
               -- with-pattern on |n1| and |n2|.
               cases Integer.absolute_value_natural(n1) with eqAbs1 {
                  | zero =>
                      cases Integer.absolute_value_natural(n2) with eqAbs2 {
                         | zero =>
                             Equality.transitivity(
                                 Rational.padic_absolute_value_at_zero(
                                     p, n1, d1, eqAbs1),
                                 Equality.symmetry(
                                     Rational.padic_absolute_value_at_zero(
                                         p, n2, d2, eqAbs2)))
                         | successor(k2) => {
                             claim contradEq
                                   : zero
                                     = successor(k2) * successor(d1)
                               by Equality.transitivity(
                                      Equality.symmetry(
                                          Natural.zero_multiply(
                                              successor(d2))),
                                      rewrite(eqAbs2,
                                              rewrite(eqAbs1, naturalCross)));
                             -- The above derives:
                             -- zero = succ(k2) * succ(d1), and
                             -- succ(k2) * succ(d1) reduces to
                             -- succ(d1 + k2 * succ(d1)).
                             absurd(contradEq)
                           }
                       }
                  | successor(k1) =>
                      cases Integer.absolute_value_natural(n2) with eqAbs2 {
                         | zero => {
                             claim contradEq
                                   : successor(k1) * successor(d2)
                                     = zero
                               by Equality.transitivity(
                                      rewrite(eqAbs1,
                                              rewrite(eqAbs2, naturalCross)),
                                      Natural.zero_multiply(
                                          successor(d1)));
                             absurd(Equality.symmetry(contradEq))
                           }
                         | successor(k2) => {
                             -- Substitute into naturalCross to get
                             --   succ(k1) * succ(d2) = succ(k2) * succ(d1).
                             claim crossSubst
                                   : successor(k1) * successor(d2)
                                     = successor(k2) * successor(d1)
                               by rewrite(eqAbs1,
                                          rewrite(eqAbs2, naturalCross));
                             -- Reorganise via commutativity to
                             --   succ(d1) * succ(k2) = succ(d2) * succ(k1).
                             claim succCross
                                   : successor(d1) * successor(k2)
                                     = successor(d2) * successor(k1)
                               by calc successor(d1) * successor(k2)
                                    = successor(k2) * successor(d1)
                                    = successor(k1) * successor(d2)
                                    = successor(d2) * successor(k1);
                             Equality.transitivity(
                                 Rational.padic_absolute_value_at_succ(
                                     p, n1, d1, k1, eqAbs1),
                                 Equality.transitivity(
                                     Quotient.sound(
                                         RationalRepresentative.make(
                                             (Natural.power(
                                                  Natural.padic_valuation(
                                                      p, successor(d1)), p)
                                                  : Integer),
                                             Natural.monus(
                                                 Natural.power(
                                                     Natural.padic_valuation(
                                                         p, successor(k1)), p),
                                                 successor(zero))),
                                         RationalRepresentative.make(
                                             (Natural.power(
                                                  Natural.padic_valuation(
                                                      p, successor(d2)), p)
                                                  : Integer),
                                             Natural.monus(
                                                 Natural.power(
                                                     Natural.padic_valuation(
                                                         p, successor(k2)), p),
                                                 successor(zero))),
                                         Rational.padic_quotient_cross_equation(
                                             p, primality,
                                             d1, d2, k1, k2,
                                             succCross)),
                                     Equality.symmetry(
                                         Rational.padic_absolute_value_at_succ(
                                             p, n2, d2, k2, eqAbs2))))
                           }
                       }
                }
             }
          } : (refinedEquiv :
                   RationalEquivalent(
                       RationalRepresentative.make(n1, d1), rep2))
              → Rational.padic_absolute_value_at_representative(
                    p, RationalRepresentative.make(n1, d1))
                = Rational.padic_absolute_value_at_representative(
                      p, rep2))
   } : (refinedEquiv : RationalEquivalent(rep1, rep2))
       → Rational.padic_absolute_value_at_representative(p, rep1)
         = Rational.padic_absolute_value_at_representative(p, rep2))(equivHyp)

-- Honest top-level: lift `padic_absolute_value_at_representative`
-- through the Quotient using the respect proof.
definition Rational.padic_absolute_value
        (q : Rational) : Rational :=
  Quotient.lift(
      function (rep : RationalRepresentative) =>
          Rational.padic_absolute_value_at_representative(p, rep),
      function (rep1 rep2 : RationalRepresentative)
               (equiv : RationalEquivalent(rep1, rep2)) =>
          Rational.padic_absolute_value_respect(
              p, primality, rep1, rep2, equiv),
      q)

-- Non-negativity: 0 ≤ |q|_p for any q. Quotient.induct on q. At
-- representative make(n, d), case on the numerator's absolute value:
-- zero gives Rational.zero, and the successor case gives a
-- Rational whose numerator is the image of a Natural (hence IsNonneg).
theorem Rational.padic_absolute_value_nonneg
        (q : Rational)
        : Rational.zero ≤ Rational.padic_absolute_value(p, primality, q) :=
  Quotient.induct(
      function (q' : Rational) =>
          Rational.zero ≤ Rational.padic_absolute_value(p, primality, q'),
      function (rep : RationalRepresentative) =>
          (cases rep {
             | RationalRepresentative.make(n, d) =>
                 cases Integer.absolute_value_natural(n) with eqAbs {
                    | zero =>
                        Equality.transport_proposition(
                            Rational,
                            function (r : Rational) =>
                                Rational.zero ≤ r,
                            Rational.zero,
                            Rational.padic_absolute_value_at_representative(
                                p,
                                RationalRepresentative.make(n, d)),
                            Equality.symmetry(
                                Rational.padic_absolute_value_at_zero(
                                    p, n, d, eqAbs)),
                            Rational.LessOrEqual.reflexive(
                                Rational.zero))
                    | successor(k) =>
                        rewrite(
                            Equality.symmetry(
                                Rational.padic_absolute_value_at_succ(
                                    p, n, d, k, eqAbs)),
                            Rational.LessOrEqual_zero_of_IsNonneg(
                                Quotient.mk(RationalRepresentative.make(
                                        (Natural.power(
                                             Natural.padic_valuation(
                                                 p, successor(d)), p)
                                             : Integer),
                                        Natural.monus(
                                            Natural.power(
                                                Natural.padic_valuation(
                                                    p, successor(k)), p),
                                            successor(zero)))),
                                Integer.from_natural_is_nonneg(
                                    Natural.power(
                                        Natural.padic_valuation(
                                            p, successor(d)), p))))
                 }
           } : Rational.zero
               ≤ Rational.padic_absolute_value_at_representative(p, rep)),
      q)

-- ----------------------------------------------------------------------
-- Helpers for the multiplicativity theorem.

-- Integer absolute_value (Natural-valued) is multiplicative. Cast both
-- sides to Integer, apply Integer.absolute_value_multiplicative, then
-- drop back to Natural via injectivity.
theorem Integer.absolute_value_natural_multiplicative (x y : Integer)
        : Integer.absolute_value_natural(x * y)
          = Integer.absolute_value_natural(x)
              * Integer.absolute_value_natural(y) :=
  Natural.to_integer.injective(
      Integer.absolute_value_natural(x * y),
      Integer.absolute_value_natural(x)
          * Integer.absolute_value_natural(y),
      calc (Integer.absolute_value_natural(x * y) : Integer)
         = Integer.absolute_value(x * y)
         = Integer.absolute_value(x) * Integer.absolute_value(y)
         = (Integer.absolute_value_natural(x) : Integer)
             * Integer.absolute_value(y)
         = (Integer.absolute_value_natural(x) : Integer)
             * (Integer.absolute_value_natural(y) : Integer)
         = (Integer.absolute_value_natural(x)
              * Integer.absolute_value_natural(y) : Integer))

-- Rational.zero is absorbing for multiplication. At representative
-- level: Rational.zero * mk(make(n, d)) reduces (via two Quotient.lift
-- kernel rules) to mk(make(Integer.zero * n, d + zero * succ(d))). The
-- inner zero*succ(d) reduces (Natural.multiply left case) to zero,
-- and Quotient.sound bridges the result to Rational.zero.
theorem Rational.zero_multiply_at_representative
        : (rep : RationalRepresentative)
          → Rational.zero
              * Quotient.mk(RationalRepresentative, RationalEquivalent,
                          rep)
            = Rational.zero
  | RationalRepresentative.make(n, d) =>
      Quotient.sound(
          RationalRepresentative.make(Integer.zero * n, d + zero),
          RationalRepresentative.make(Integer.zero, zero),
          calc (Integer.zero * n) * (successor(zero) : Integer)
             = Integer.zero * (successor(zero) : Integer)
             = Integer.zero
             = Integer.zero * (successor(d + zero) : Integer))

theorem Rational.zero_multiply (r : Rational)
        : Rational.zero * r = Rational.zero :=
  Quotient.induct(
      function (r' : Rational) => Rational.zero * r' = Rational.zero,
      Rational.zero_multiply_at_representative,
      r)

theorem Rational.multiply_zero (r : Rational)
        : r * Rational.zero = Rational.zero :=
  Equality.transitivity(
      Rational.multiply_commutative(r, Rational.zero),
      Rational.zero_multiply(r))

-- ----------------------------------------------------------------------
-- Multiplicativity of the p-adic absolute value at the representative
-- level. The "both numerators non-zero" case is the meaty one: it
-- builds the Integer cross-equation for Quotient.sound from the
-- multiplicativity of padic_valuation and power_add.

-- Helper: the Quotient.sound input that bridges the LHS and RHS
-- representative forms when both numerators are nonzero.
theorem Rational.padic_multiplicative_cross_equation
        (dx dy kx ky : Natural)
        : (Natural.power(
              Natural.padic_valuation(
                  p, successor(dy + dx * successor(dy))), p) : Integer)
          * (successor(
                Natural.monus(
                    Natural.power(Natural.padic_valuation(p, successor(ky)), p),
                    successor(zero))
                  + Natural.monus(
                        Natural.power(
                            Natural.padic_valuation(p, successor(kx)), p),
                        successor(zero))
                    * successor(
                        Natural.monus(
                            Natural.power(
                                Natural.padic_valuation(
                                    p, successor(ky)), p),
                            successor(zero))))
              : Integer)
          = ((Natural.power(Natural.padic_valuation(p, successor(dx)), p) : Integer)
             * (Natural.power(Natural.padic_valuation(p, successor(dy)), p)
                  : Integer))
            * (successor(
                  Natural.monus(
                      Natural.power(
                          Natural.padic_valuation(
                              p, successor(ky + kx * successor(ky))), p),
                      successor(zero)))
                : Integer) := {
  claim primeAtLeastTwo : 2 ≤ p             by Natural.is_prime.at_least_two(p, primality);
  claim primePositive   : 1 ≤ p             by Natural.is_prime.positive(p, primality);
  claim succDxPos       : 1 ≤ successor(dx) by Natural.successor_positive(dx);
  claim succDyPos       : 1 ≤ successor(dy) by Natural.successor_positive(dy);
  claim succKxPos       : 1 ≤ successor(kx) by Natural.successor_positive(kx);
  claim succKyPos       : 1 ≤ successor(ky) by Natural.successor_positive(ky);
  -- succ(dy + dx*succ(dy)) reduces to succ(dx) * succ(dy) by kernel.
  -- So power(v_p(succ(dy + dx*succ(dy))), p) = power(v_p(succ(dx)*succ(dy)), p)
  -- = power(v_p(succ(dx)) + v_p(succ(dy)), p)        [multiplicativity]
  -- = power(v_p(succ(dx)), p) * power(v_p(succ(dy)), p)  [power_add].
  claim numEqual
        : Natural.power(
              Natural.padic_valuation(
                  p, successor(dy + dx * successor(dy))), p)
          = Natural.power(Natural.padic_valuation(p, successor(dx)), p)
              * Natural.power(Natural.padic_valuation(p, successor(dy)), p)
    by Equality.transitivity(
           congruenceOf(
               function (m : Natural) => Natural.power(m, p),
               Natural.padic_valuation_multiplicative(
                   p, successor(dx), successor(dy),
                   primality, succDxPos, succDyPos)),
           Natural.power_add(
               Natural.padic_valuation(p, successor(dx)),
               Natural.padic_valuation(p, successor(dy)), p));
  -- Similarly for the denominator (k side).
  claim denomEqual
        : Natural.power(
              Natural.padic_valuation(
                  p, successor(ky + kx * successor(ky))), p)
          = Natural.power(Natural.padic_valuation(p, successor(kx)), p)
              * Natural.power(Natural.padic_valuation(p, successor(ky)), p)
    by Equality.transitivity(
           congruenceOf(
               function (m : Natural) => Natural.power(m, p),
               Natural.padic_valuation_multiplicative(
                   p, successor(kx), successor(ky),
                   primality, succKxPos, succKyPos)),
           Natural.power_add(
               Natural.padic_valuation(p, successor(kx)),
               Natural.padic_valuation(p, successor(ky)), p));
  claim powerKxPos
        : successor(zero)
            ≤ Natural.power(Natural.padic_valuation(p, successor(kx)), p)
    by Natural.power_positive(
           Natural.padic_valuation(p, successor(kx)), p, primePositive);
  claim powerKyPos
        : successor(zero)
            ≤ Natural.power(Natural.padic_valuation(p, successor(ky)), p)
    by Natural.power_positive(
           Natural.padic_valuation(p, successor(ky)), p, primePositive);
  -- Build the Integer equation by computation.
  -- Key: succ(monus(power(v_p(succ(ky)), p), 1) + monus(power(v_p(succ(kx)), p), 1) * succ(monus(power(v_p(succ(ky)), p), 1)))
  --      reduces to succ(monus(power(v_p(succ(kx)), p), 1)) * succ(monus(power(v_p(succ(ky)), p), 1))
  --      = power(v_p(succ(kx)), p) * power(v_p(succ(ky)), p) (via successor_monus_one × 2).
  -- And succ(monus(power(v_p(succ(ky+kx*succ(ky))), p), 1)) = power(v_p(succ(ky+kx*succ(ky))), p) (also via successor_monus_one).
  calc (Natural.power(
            Natural.padic_valuation(
                p, successor(dy + dx * successor(dy))), p) : Integer)
       * (successor(
              Natural.monus(
                  Natural.power(
                      Natural.padic_valuation(p, successor(ky)), p),
                  successor(zero))
                + Natural.monus(
                      Natural.power(
                          Natural.padic_valuation(p, successor(kx)), p),
                      successor(zero))
                  * successor(
                      Natural.monus(
                          Natural.power(
                              Natural.padic_valuation(
                                  p, successor(ky)), p),
                          successor(zero))))
            : Integer)
     = (Natural.power(
            Natural.padic_valuation(
                p, successor(dy + dx * successor(dy))), p) : Integer)
       * (Natural.power(Natural.padic_valuation(p, successor(kx)), p)
            * Natural.power(Natural.padic_valuation(p, successor(ky)), p)
            : Integer)
            by congruenceOf(
                   function (m : Natural) =>
                       (Natural.power(
                            Natural.padic_valuation(
                                p, successor(dy + dx * successor(dy))), p)
                            : Integer)
                       * (m : Integer),
                   -- succ(monus(B_x, 1) + monus(B_y, 1) * succ(monus(B_y, 1)))
                   -- reduces (add on succ first, multiply rearrangement)
                   -- to succ(monus(B_x, 1)) * succ(monus(B_y, 1))
                   -- = power(v_p(succ(kx)), p) * power(v_p(succ(ky)), p).
                   Equality.transitivity(
                       congruenceOf(
                           function (m : Natural) =>
                               m
                               * successor(
                                   Natural.monus(
                                       Natural.power(
                                           Natural.padic_valuation(
                                               p, successor(ky)), p),
                                       successor(zero))),
                           Natural.successor_monus_one_when_positive(
                               Natural.power(
                                   Natural.padic_valuation(
                                       p, successor(kx)), p),
                               powerKxPos)),
                       congruenceOf(
                           function (m : Natural) =>
                               Natural.power(
                                   Natural.padic_valuation(
                                       p, successor(kx)), p)
                               * m,
                           Natural.successor_monus_one_when_positive(
                               Natural.power(
                                   Natural.padic_valuation(
                                       p, successor(ky)), p),
                               powerKyPos))))
     = (Natural.power(
            Natural.padic_valuation(
                p, successor(dy + dx * successor(dy))), p)
          * (Natural.power(Natural.padic_valuation(p, successor(kx)), p)
               * Natural.power(Natural.padic_valuation(p, successor(ky)), p))
          : Integer)
     = ((Natural.power(Natural.padic_valuation(p, successor(dx)), p)
           * Natural.power(Natural.padic_valuation(p, successor(dy)), p))
          * (Natural.power(Natural.padic_valuation(p, successor(kx)), p)
               * Natural.power(Natural.padic_valuation(p, successor(ky)), p))
          : Integer)
     = ((Natural.power(Natural.padic_valuation(p, successor(dx)), p)
           * Natural.power(Natural.padic_valuation(p, successor(dy)), p))
          : Integer)
       * ((Natural.power(Natural.padic_valuation(p, successor(kx)), p)
             * Natural.power(Natural.padic_valuation(p, successor(ky)), p))
            : Integer)
     = ((Natural.power(Natural.padic_valuation(p, successor(dx)), p) : Integer)
        * (Natural.power(Natural.padic_valuation(p, successor(dy)), p)
             : Integer))
       * ((Natural.power(Natural.padic_valuation(p, successor(kx)), p)
             * Natural.power(Natural.padic_valuation(p, successor(ky)), p))
            : Integer)
     = ((Natural.power(Natural.padic_valuation(p, successor(dx)), p) : Integer)
        * (Natural.power(Natural.padic_valuation(p, successor(dy)), p)
             : Integer))
       * (Natural.power(
              Natural.padic_valuation(
                  p, successor(ky + kx * successor(ky))), p)
            : Integer)
     = ((Natural.power(Natural.padic_valuation(p, successor(dx)), p) : Integer)
        * (Natural.power(Natural.padic_valuation(p, successor(dy)), p)
             : Integer))
       * (successor(
              Natural.monus(
                  Natural.power(
                      Natural.padic_valuation(
                          p, successor(ky + kx * successor(ky))), p),
                  successor(zero)))
            : Integer)
            by congruenceOf(
                   function (m : Natural) =>
                       ((Natural.power(
                              Natural.padic_valuation(p, successor(dx)), p)
                            : Integer)
                         * (Natural.power(
                                Natural.padic_valuation(p, successor(dy)), p)
                              : Integer))
                       * (m : Integer),
                   Equality.symmetry(
                       Natural.successor_monus_one_when_positive(
                           Natural.power(
                               Natural.padic_valuation(
                                   p, successor(ky + kx * successor(ky))), p),
                           Natural.power_positive(
                               Natural.padic_valuation(
                                   p, successor(ky + kx * successor(ky))),
                               p, primePositive))))
}

-- Main: multiplicativity at the Rational level.
-- |x · y|_p = |x|_p · |y|_p. Quotient.induct_two on x, y. At
-- representatives, case on |nx| and |ny| to dispatch:
--   * either zero: both sides zero (LHS via |nx·ny|=0 + at_zero;
--     RHS via at_zero on one factor + zero_multiply or multiply_zero).
--   * both successor: both sides are mk's; apply Quotient.sound with
--     padic_multiplicative_cross_equation.
theorem Rational.padic_absolute_value_multiplicative
        (x y : Rational)
        : Rational.padic_absolute_value(p, primality, x * y)
          = Rational.padic_absolute_value(p, primality, x)
              * Rational.padic_absolute_value(p, primality, y) :=
  Quotient.induct_two(
      function (x' y' : Rational) =>
          Rational.padic_absolute_value(p, primality, x' * y')
            = Rational.padic_absolute_value(p, primality, x')
                * Rational.padic_absolute_value(p, primality, y'),
      function (rep_x rep_y : RationalRepresentative) =>
        (cases rep_x {
           | RationalRepresentative.make(nx, dx) =>
               (cases rep_y {
                  | RationalRepresentative.make(ny, dy) => {
                      -- With-pattern on |nx| and |ny|.
                      cases Integer.absolute_value_natural(nx) with eqAbsNx {
                         | zero => {
                             -- |nx*ny| = |nx| * |ny| = 0 * |ny| = 0.
                             claim productAbsZero
                                   : Integer.absolute_value_natural(nx * ny)
                                     = zero
                               by Equality.transitivity(
                                      Integer.absolute_value_natural_multiplicative(
                                          nx, ny),
                                      Equality.transitivity(
                                          congruenceOf(
                                              function (m : Natural) =>
                                                  m
                                                  * Integer.absolute_value_natural(
                                                        ny),
                                              eqAbsNx),
                                          Natural.zero_multiply(
                                              Integer.absolute_value_natural(ny))));
                             calc Rational.padic_absolute_value_at_representative(
                                      p,
                                      RationalRepresentative.make(
                                          nx * ny,
                                          dy + dx * successor(dy)))
                                = Rational.zero
                                       by Rational.padic_absolute_value_at_zero(
                                              p, nx * ny,
                                              dy + dx * successor(dy),
                                              productAbsZero)
                                = Rational.zero
                                  * Rational.padic_absolute_value_at_representative(
                                        p,
                                        RationalRepresentative.make(ny, dy))
                                = Rational.padic_absolute_value_at_representative(
                                      p,
                                      RationalRepresentative.make(nx, dx))
                                  * Rational.padic_absolute_value_at_representative(
                                        p,
                                        RationalRepresentative.make(ny, dy))
                                       by congruenceOf(
                                              function (m : Rational) =>
                                                  m
                                                  * Rational.padic_absolute_value_at_representative(
                                                        p,
                                                        RationalRepresentative.make(
                                                            ny, dy)),
                                              Equality.symmetry(
                                                  Rational.padic_absolute_value_at_zero(
                                                      p, nx, dx, eqAbsNx)))
                           }
                         | successor(kx) =>
                             cases Integer.absolute_value_natural(ny) with eqAbsNy {
                                | zero => {
                                    -- |nx*ny| = |nx| * |ny| = succ(kx) * 0 = 0.
                                    claim productAbsZero
                                          : Integer.absolute_value_natural(
                                                nx * ny)
                                            = zero
                                      by Equality.transitivity(
                                             Integer.absolute_value_natural_multiplicative(
                                                 nx, ny),
                                             Equality.transitivity(
                                                 congruenceOf(
                                                     function (m : Natural) =>
                                                         Integer.absolute_value_natural(
                                                             nx)
                                                         * m,
                                                     eqAbsNy),
                                                 Natural.multiply_zero(
                                                     Integer.absolute_value_natural(
                                                         nx))));
                                    calc Rational.padic_absolute_value_at_representative(
                                             p,
                                             RationalRepresentative.make(
                                                 nx * ny,
                                                 dy + dx * successor(dy)))
                                       = Rational.zero
                                              by Rational.padic_absolute_value_at_zero(
                                                     p, nx * ny,
                                                     dy + dx * successor(dy),
                                                     productAbsZero)
                                       = Rational.padic_absolute_value_at_representative(
                                             p,
                                             RationalRepresentative.make(nx, dx))
                                         * Rational.zero
                                       = Rational.padic_absolute_value_at_representative(
                                             p,
                                             RationalRepresentative.make(nx, dx))
                                         * Rational.padic_absolute_value_at_representative(
                                               p,
                                               RationalRepresentative.make(
                                                   ny, dy))
                                              by congruenceOf(
                                                     function (m : Rational) =>
                                                         Rational.padic_absolute_value_at_representative(
                                                             p,
                                                             RationalRepresentative.make(
                                                                 nx, dx))
                                                         * m,
                                                     Equality.symmetry(
                                                         Rational.padic_absolute_value_at_zero(
                                                             p, ny, dy, eqAbsNy)))
                                  }
                                | successor(ky) => {
                                    -- |nx*ny| = |nx|*|ny| = succ(kx)*succ(ky)
                                    -- = succ(ky + kx*succ(ky)) (by kernel reduction).
                                    claim productAbsSucc
                                          : Integer.absolute_value_natural(
                                                nx * ny)
                                            = successor(ky + kx * successor(ky))
                                      by Equality.transitivity(
                                             Integer.absolute_value_natural_multiplicative(
                                                 nx, ny),
                                             Equality.transitivity(
                                                 congruenceOf(
                                                     function (m : Natural) =>
                                                         m
                                                         * Integer.absolute_value_natural(
                                                               ny),
                                                     eqAbsNx),
                                                 congruenceOf(
                                                     function (m : Natural) =>
                                                         successor(kx) * m,
                                                     eqAbsNy)));
                                              calc Rational.padic_absolute_value_at_representative(
                                                       p,
                                                       RationalRepresentative.make(
                                                           nx * ny,
                                                           dy + dx * successor(dy)))
                                                 = Quotient.mk(RationalRepresentative.make(
                                                           (Natural.power(
                                                                Natural.padic_valuation(
                                                                    p,
                                                                    successor(
                                                                        dy + dx * successor(dy))), p)
                                                                : Integer),
                                                           Natural.monus(
                                                               Natural.power(
                                                                   Natural.padic_valuation(
                                                                       p,
                                                                       successor(
                                                                           ky + kx * successor(ky))), p),
                                                               successor(zero))))
                                                        by Rational.padic_absolute_value_at_succ(
                                                               p, nx * ny,
                                                               dy + dx * successor(dy),
                                                               ky + kx * successor(ky),
                                                               productAbsSucc)
                                                 = Quotient.mk(Rational.multiply_representatives(
                                                           RationalRepresentative.make(
                                                               (Natural.power(
                                                                    Natural.padic_valuation(
                                                                        p, successor(dx)), p)
                                                                    : Integer),
                                                               Natural.monus(
                                                                   Natural.power(
                                                                       Natural.padic_valuation(
                                                                           p, successor(kx)), p),
                                                                   successor(zero))),
                                                           RationalRepresentative.make(
                                                               (Natural.power(
                                                                    Natural.padic_valuation(
                                                                        p, successor(dy)), p)
                                                                    : Integer),
                                                               Natural.monus(
                                                                   Natural.power(
                                                                       Natural.padic_valuation(
                                                                           p, successor(ky)), p),
                                                                   successor(zero)))))
                                                        by Quotient.sound(
                                                               RationalRepresentative.make(
                                                                   (Natural.power(
                                                                        Natural.padic_valuation(
                                                                            p,
                                                                            successor(
                                                                                dy + dx * successor(dy))), p)
                                                                        : Integer),
                                                                   Natural.monus(
                                                                       Natural.power(
                                                                           Natural.padic_valuation(
                                                                               p,
                                                                               successor(
                                                                                   ky + kx * successor(ky))), p),
                                                                       successor(zero))),
                                                               Rational.multiply_representatives(
                                                                   RationalRepresentative.make(
                                                                       (Natural.power(
                                                                            Natural.padic_valuation(
                                                                                p, successor(dx)), p)
                                                                            : Integer),
                                                                       Natural.monus(
                                                                           Natural.power(
                                                                               Natural.padic_valuation(
                                                                                   p, successor(kx)), p),
                                                                           successor(zero))),
                                                                   RationalRepresentative.make(
                                                                       (Natural.power(
                                                                            Natural.padic_valuation(
                                                                                p, successor(dy)), p)
                                                                            : Integer),
                                                                       Natural.monus(
                                                                           Natural.power(
                                                                               Natural.padic_valuation(
                                                                                   p, successor(ky)), p),
                                                                           successor(zero)))),
                                                               Rational.padic_multiplicative_cross_equation(
                                                                   p, primality,
                                                                   dx, dy, kx, ky))
                                                 = Rational.padic_absolute_value_at_representative(
                                                       p,
                                                       RationalRepresentative.make(nx, dx))
                                                   * Rational.padic_absolute_value_at_representative(
                                                         p,
                                                         RationalRepresentative.make(
                                                             ny, dy))
                                                        by Equality.transitivity(
                                                               congruenceOf(
                                                                   function (m : Rational) =>
                                                                       m
                                                                       * Quotient.mk(RationalRepresentative, RationalEquivalent,
                                                                                   RationalRepresentative.make(
                                                                                 (Natural.power(
                                                                                      Natural.padic_valuation(
                                                                                          p, successor(dy)), p)
                                                                                      : Integer),
                                                                                 Natural.monus(
                                                                                     Natural.power(
                                                                                         Natural.padic_valuation(
                                                                                             p, successor(ky)), p),
                                                                                     successor(zero)))),
                                                                   Equality.symmetry(
                                                                       Rational.padic_absolute_value_at_succ(
                                                                           p, nx, dx, kx,
                                                                           eqAbsNx))),
                                                               congruenceOf(
                                                                   function (m : Rational) =>
                                                                       Rational.padic_absolute_value_at_representative(
                                                                           p,
                                                                           RationalRepresentative.make(
                                                                               nx, dx))
                                                                       * m,
                                                                   Equality.symmetry(
                                                                       Rational.padic_absolute_value_at_succ(
                                                                           p, ny, dy, ky,
                                                                           eqAbsNy))))
                                  }
                              }
                       }
                    }
                } : Rational.padic_absolute_value_at_representative(
                        p,
                        Rational.multiply_representatives(
                            RationalRepresentative.make(nx, dx), rep_y))
                    = Rational.padic_absolute_value_at_representative(
                          p, RationalRepresentative.make(nx, dx))
                      * Rational.padic_absolute_value_at_representative(
                            p, rep_y))
         } : Rational.padic_absolute_value_at_representative(
                 p,
                 Rational.multiply_representatives(rep_x, rep_y))
             = Rational.padic_absolute_value_at_representative(p, rep_x)
               * Rational.padic_absolute_value_at_representative(p, rep_y)),
      x, y)

-- ----------------------------------------------------------------------
-- Triangle inequality. The remaining norm axiom for the p-adic absolute
-- value: |x + y|_p ≤ |x|_p + |y|_p. Goes via the ultrametric
-- |x + y|_p ≤ max(|x|_p, |y|_p), then max ≤ sum (both are nonneg).

-- Helper: x ≤ x + y when 0 ≤ y. Rational addition right-monotone.
theorem Rational.le_add_right_of_nonneg
        (x y : Rational) (yNonneg : Rational.zero ≤ y)
        : x ≤ x + y :=
  rewrite(Rational.add_zero(x),
          Rational.LessOrEqual.sum(
              x, x, Rational.zero, y,
              Rational.LessOrEqual.reflexive(x),
              yNonneg))

-- And the symmetric: x ≤ y + x when 0 ≤ y.
theorem Rational.le_add_left_of_nonneg
        (x y : Rational) (yNonneg : Rational.zero ≤ y)
        : x ≤ y + x :=
  rewrite(Rational.add_commutative(x, y),
          Rational.le_add_right_of_nonneg(x, y, yNonneg))

-- ----------------------------------------------------------------------
-- Helper A for the p-adic triangle inequality.
--
-- For p ≥ 1 and Naturals α, β, γ, δ with α + δ ≤ β + γ:
--   mk(make((p^α : Int), p^γ - 1))  ≤  mk(make((p^β : Int), p^δ - 1))
--
-- where p^k = Natural.power(k, p) and "p^γ - 1" abbreviates
-- monus(power(γ, p), 1). The two denominators-minus-one are well-formed
-- because p^γ, p^δ ≥ 1 when p ≥ 1.
--
-- Proof sketch: the difference RHS - LHS β-reduces (through Quotient.lift
-- kernel rules on subtract = add + negate) to mk(make(NUM, DEN)) where
--   NUM = (p^β : Int) * succ(p^γ - 1) + (-(p^α : Int)) * succ(p^δ - 1).
-- Rational.IsNonneg β-reduces (through the lift on IsNonneg) to
-- Integer.IsNonneg(NUM). Rewriting succ(monus(_, 1)) to the underlying
-- power and collecting through Natural.to_integer.multiply_preserves
-- yields NUM = (p^β · p^γ : Int) - (p^α · p^δ : Int). Since α + δ ≤ β + γ
-- and power is exponent-monotone, p^α · p^δ ≤ p^β · p^γ, so the Natural
-- subtraction witness s satisfies (s : Int) = NUM; IsNonneg follows from
-- from_natural_is_nonneg.
theorem Rational.padic_av_form_le_when_exponent_le
        (p : Natural) (primePositive : successor(zero) ≤ p)
        (alpha beta gamma delta : Natural)
        (exponentLe : alpha + delta ≤ beta + gamma)
        : Quotient.mk(RationalRepresentative, RationalEquivalent,
                    RationalRepresentative.make(
                  (Natural.power(alpha, p) : Integer),
                  Natural.monus(Natural.power(gamma, p), successor(zero))))
          ≤ Quotient.mk(RationalRepresentative, RationalEquivalent,
                      RationalRepresentative.make(
                    (Natural.power(beta, p) : Integer),
                    Natural.monus(Natural.power(delta, p), successor(zero)))) := {
  claim powerGammaPos : successor(zero) ≤ Natural.power(gamma, p)
    by Natural.power_positive(gamma, p, primePositive);
  claim powerDeltaPos : successor(zero) ≤ Natural.power(delta, p)
    by Natural.power_positive(delta, p, primePositive);
  -- p^α · p^δ ≤ p^β · p^γ via power_add + power_monotone.
  claim productLe
        : Natural.power(alpha, p) * Natural.power(delta, p)
            ≤ Natural.power(beta, p) * Natural.power(gamma, p)
    by rewrite(Natural.power_add(alpha, delta, p),
               rewrite(Natural.power_add(beta, gamma, p),
                       Natural.power_monotone(
                           alpha + delta, beta + gamma, p, exponentLe,
                           primePositive)));
  -- Natural subtraction witness.
  let ⟨s, witnessEq⟩ := Natural.subtraction_witness(
      Natural.power(alpha, p) * Natural.power(delta, p),
      Natural.power(beta, p) * Natural.power(gamma, p),
      productLe);
  -- The raw numerator of (RHS - LHS) equals (s : Integer).
  claim numerEqInt
        : (Natural.power(beta, p) : Integer)
            * (successor(
                  Natural.monus(Natural.power(gamma, p), successor(zero)))
                : Integer)
          + -(Natural.power(alpha, p) : Integer)
              * (successor(
                    Natural.monus(Natural.power(delta, p), successor(zero)))
                  : Integer)
          = (s : Integer)
    by calc (Natural.power(beta, p) : Integer)
              * (successor(
                    Natural.monus(Natural.power(gamma, p), successor(zero)))
                  : Integer)
            + -(Natural.power(alpha, p) : Integer)
                * (successor(
                      Natural.monus(Natural.power(delta, p), successor(zero)))
                    : Integer)
         = (Natural.power(beta, p) : Integer)
             * (Natural.power(gamma, p) : Integer)
           + -(Natural.power(alpha, p) : Integer)
               * (successor(
                     Natural.monus(Natural.power(delta, p), successor(zero)))
                   : Integer)
                by congruenceOf(
                       function (m : Natural) =>
                           (Natural.power(beta, p) : Integer) * (m : Integer)
                           + -(Natural.power(alpha, p) : Integer)
                               * (successor(
                                     Natural.monus(
                                         Natural.power(delta, p),
                                         successor(zero)))
                                   : Integer),
                       Natural.successor_monus_one_when_positive(
                           Natural.power(gamma, p), powerGammaPos))
         = (Natural.power(beta, p) : Integer)
             * (Natural.power(gamma, p) : Integer)
           + -(Natural.power(alpha, p) : Integer)
               * (Natural.power(delta, p) : Integer)
                by congruenceOf(
                       function (m : Natural) =>
                           (Natural.power(beta, p) : Integer)
                             * (Natural.power(gamma, p) : Integer)
                           + -(Natural.power(alpha, p) : Integer)
                               * (m : Integer),
                       Natural.successor_monus_one_when_positive(
                           Natural.power(delta, p), powerDeltaPos))
         = (Natural.power(beta, p) * Natural.power(gamma, p) : Integer)
           + -(Natural.power(alpha, p) : Integer)
               * (Natural.power(delta, p) : Integer)
         = (Natural.power(beta, p) * Natural.power(gamma, p) : Integer)
           + -((Natural.power(alpha, p) : Integer)
                 * (Natural.power(delta, p) : Integer))
         = (Natural.power(beta, p) * Natural.power(gamma, p) : Integer)
           + -(Natural.power(alpha, p) * Natural.power(delta, p) : Integer)
         = (Natural.power(alpha, p) * Natural.power(delta, p) + s : Integer)
           + -(Natural.power(alpha, p) * Natural.power(delta, p) : Integer)
         = (Natural.power(alpha, p) * Natural.power(delta, p) : Integer)
             + (s : Integer)
           + -(Natural.power(alpha, p) * Natural.power(delta, p) : Integer)
         -- (A + S) + -A = A + (S + -A)
         = (Natural.power(alpha, p) * Natural.power(delta, p) : Integer)
             + ((s : Integer)
                + -(Natural.power(alpha, p)
                        * Natural.power(delta, p) : Integer))
         -- A + (S + -A) = A + (-A + S)
         = (Natural.power(alpha, p) * Natural.power(delta, p) : Integer)
             + (-(Natural.power(alpha, p)
                      * Natural.power(delta, p) : Integer)
                + (s : Integer))
         -- A + (-A + S) = (A + -A) + S
         = ((Natural.power(alpha, p) * Natural.power(delta, p) : Integer)
              + -(Natural.power(alpha, p)
                      * Natural.power(delta, p) : Integer))
             + (s : Integer)
         -- (A + -A) + S = 0 + S
         = Integer.zero + (s : Integer)
         -- 0 + S = S
         = (s : Integer);
  Exists.introduce(
      Natural,
      function (k : Natural) =>
          (Natural.power(beta, p) : Integer)
            * (successor(
                  Natural.monus(Natural.power(gamma, p), successor(zero)))
                : Integer)
          + -(Natural.power(alpha, p) : Integer)
              * (successor(
                    Natural.monus(Natural.power(delta, p), successor(zero)))
                  : Integer)
          = (k : Integer),
      s,
      numerEqInt)
}

-- ----------------------------------------------------------------------
-- Bridge: mk(make(Integer.zero, d)) = Rational.zero. The denominator d
-- collapses by Integer.multiply_zero_left after cross-multiplication.
theorem Rational.zero_numerator_is_zero (d : Natural)
        : Quotient.mk(RationalRepresentative, RationalEquivalent,
                    RationalRepresentative.make(Integer.zero, d))
          = Rational.zero :=
  Quotient.sound(
      RationalRepresentative.make(Integer.zero, d),
      RationalRepresentative.make(Integer.zero, zero),
      Equality.transitivity(
          Integer.multiply_zero_left((successor(zero) : Integer)),
          Equality.symmetry(
              Integer.multiply_zero_left((successor(d) : Integer)))))

-- Sub-case of the p-adic triangle inequality: when |nx| = 0.
--
-- nx must be Integer.zero (via absolute_value_natural_zero_implies_zero),
-- so the Rational x = mk(make(nx, dx)) equals Rational.zero. Hence
-- x + y = y. Likewise |x|_p = 0 (by padic_absolute_value_at_zero), so
-- RHS = Rational.zero + |y|_p = |y|_p. Both sides equal |y|_p; ≤ follows
-- by reflexivity.
theorem Rational.padic_absolute_value_triangle_at_reps_when_nx_zero
        (nx ny : Integer) (dx dy : Natural)
        (eqAbsNxZero : Integer.absolute_value_natural(nx) = zero)
        : Rational.padic_absolute_value(
              p, primality,
              (Quotient.mk(RationalRepresentative.make(nx, dx)) : Rational)
              + (Quotient.mk(RationalRepresentative.make(ny, dy)) : Rational))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Quotient.mk(RationalRepresentative.make(nx, dx)))
              + Rational.padic_absolute_value(
                    p, primality,
                    Quotient.mk(RationalRepresentative.make(ny, dy))) := {
  claim nxZero : nx = Integer.zero
    by Integer.absolute_value_natural_zero_implies_zero(nx, eqAbsNxZero);
  -- mk(make(nx, dx)) = mk(make(Integer.zero, dx)) = Rational.zero.
  claim xRationalZero
        : Quotient.mk(RationalRepresentative, RationalEquivalent,
                    RationalRepresentative.make(nx, dx))
          = Rational.zero
    by Equality.transitivity(
           congruenceOf(
               function (m : Integer) =>
                   Quotient.mk(RationalRepresentative, RationalEquivalent,
                               RationalRepresentative.make(m, dx)),
               nxZero),
           Rational.zero_numerator_is_zero(dx));
  -- x + y = Rational.zero + y = y.
  claim sumEqY
        : Quotient.mk(RationalRepresentative, RationalEquivalent,
                    RationalRepresentative.make(nx, dx))
          + Quotient.mk(RationalRepresentative, RationalEquivalent,
                      RationalRepresentative.make(ny, dy))
          = Quotient.mk(RationalRepresentative.make(ny, dy))
    by Equality.transitivity(
           congruenceOf(
               function (m : Rational) =>
                   m
                   + Quotient.mk(RationalRepresentative, RationalEquivalent,
                               RationalRepresentative.make(ny, dy)),
               xRationalZero),
           Rational.zero_add(
               Quotient.mk(RationalRepresentative.make(ny, dy))));
  -- |x|_p = padic_av_at_rep(make(nx, dx)) = Rational.zero (since |nx|=0).
  -- The lifted form reduces (Quotient.lift β) to padic_av_at_rep.
  claim padicAvXEqZero
        : Rational.padic_absolute_value(
              p, primality,
              Quotient.mk(RationalRepresentative.make(nx, dx)))
          = Rational.zero
    by Rational.padic_absolute_value_at_zero(p, nx, dx, eqAbsNxZero);
  -- |x+y|_p = |y|_p (by congruenceOf on sumEqY).
  claim padicAvSumEqY
        : Rational.padic_absolute_value(
              p, primality,
              (Quotient.mk(RationalRepresentative.make(nx, dx)) : Rational)
              + (Quotient.mk(RationalRepresentative.make(ny, dy)) : Rational))
          = Rational.padic_absolute_value(
                p, primality,
                Quotient.mk(RationalRepresentative.make(ny, dy)))
    by congruenceOf(
           function (m : Rational) =>
               Rational.padic_absolute_value(p, primality, m),
           sumEqY);
  -- RHS = Rational.zero + |y|_p = |y|_p.
  claim rhsEqY
        : Rational.padic_absolute_value(
              p, primality,
              Quotient.mk(RationalRepresentative.make(nx, dx)))
            + Rational.padic_absolute_value(
                  p, primality,
                  Quotient.mk(RationalRepresentative.make(ny, dy)))
          = Rational.padic_absolute_value(
                p, primality,
                Quotient.mk(RationalRepresentative.make(ny, dy)))
    by Equality.transitivity(
           congruenceOf(
               function (m : Rational) =>
                   m
                   + Rational.padic_absolute_value(
                         p, primality,
                         Quotient.mk(RationalRepresentative.make(ny, dy))),
               padicAvXEqZero),
           Rational.zero_add(
               Rational.padic_absolute_value(
                   p, primality,
                   Quotient.mk(RationalRepresentative.make(ny, dy)))));
  -- LHS = RHS, hence LHS ≤ RHS by reflexivity.
  rewrite(
      Equality.symmetry(rhsEqY),
      Equality.transport_proposition(
          Rational,
          function (m : Rational) =>
              m
                ≤ Rational.padic_absolute_value(
                      p, primality,
                      Quotient.mk(RationalRepresentative.make(ny, dy))),
          Rational.padic_absolute_value(
              p, primality,
              Quotient.mk(RationalRepresentative.make(ny, dy))),
          Rational.padic_absolute_value(
              p, primality,
              (Quotient.mk(RationalRepresentative.make(nx, dx)) : Rational)
              + (Quotient.mk(RationalRepresentative.make(ny, dy)) : Rational)),
          Equality.symmetry(padicAvSumEqY),
          Rational.LessOrEqual.reflexive(
              Rational.padic_absolute_value(
                  p, primality,
                  Quotient.mk(RationalRepresentative.make(ny, dy))))))
}

-- Sub-case: when |ny| = 0. Symmetric to the nx-zero case. Here we
-- conclude y = Rational.zero, x + y = x, |y|_p = 0, RHS = |x|_p; equal.
theorem Rational.padic_absolute_value_triangle_at_reps_when_ny_zero
        (nx ny : Integer) (dx dy : Natural)
        (eqAbsNyZero : Integer.absolute_value_natural(ny) = zero)
        : Rational.padic_absolute_value(
              p, primality,
              (Quotient.mk(RationalRepresentative.make(nx, dx)) : Rational)
              + (Quotient.mk(RationalRepresentative.make(ny, dy)) : Rational))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Quotient.mk(RationalRepresentative.make(nx, dx)))
              + Rational.padic_absolute_value(
                    p, primality,
                    Quotient.mk(RationalRepresentative.make(ny, dy))) := {
  claim nyZero : ny = Integer.zero
    by Integer.absolute_value_natural_zero_implies_zero(ny, eqAbsNyZero);
  claim yRationalZero
        : Quotient.mk(RationalRepresentative, RationalEquivalent,
                    RationalRepresentative.make(ny, dy))
          = Rational.zero
    by Equality.transitivity(
           congruenceOf(
               function (m : Integer) =>
                   Quotient.mk(RationalRepresentative, RationalEquivalent,
                               RationalRepresentative.make(m, dy)),
               nyZero),
           Rational.zero_numerator_is_zero(dy));
  -- x + y = x + Rational.zero = x.
  claim sumEqX
        : Quotient.mk(RationalRepresentative, RationalEquivalent,
                    RationalRepresentative.make(nx, dx))
          + Quotient.mk(RationalRepresentative, RationalEquivalent,
                      RationalRepresentative.make(ny, dy))
          = Quotient.mk(RationalRepresentative.make(nx, dx))
    by Equality.transitivity(
           congruenceOf(
               function (m : Rational) =>
                   Quotient.mk(RationalRepresentative, RationalEquivalent,
                               RationalRepresentative.make(nx, dx))
                   + m,
               yRationalZero),
           Rational.add_zero(
               Quotient.mk(RationalRepresentative.make(nx, dx))));
  claim padicAvYEqZero
        : Rational.padic_absolute_value(
              p, primality,
              Quotient.mk(RationalRepresentative.make(ny, dy)))
          = Rational.zero
    by Rational.padic_absolute_value_at_zero(p, ny, dy, eqAbsNyZero);
  claim padicAvSumEqX
        : Rational.padic_absolute_value(
              p, primality,
              (Quotient.mk(RationalRepresentative.make(nx, dx)) : Rational)
              + (Quotient.mk(RationalRepresentative.make(ny, dy)) : Rational))
          = Rational.padic_absolute_value(
                p, primality,
                Quotient.mk(RationalRepresentative.make(nx, dx)))
    by congruenceOf(
           function (m : Rational) =>
               Rational.padic_absolute_value(p, primality, m),
           sumEqX);
  claim rhsEqX
        : Rational.padic_absolute_value(
              p, primality,
              Quotient.mk(RationalRepresentative.make(nx, dx)))
            + Rational.padic_absolute_value(
                  p, primality,
                  Quotient.mk(RationalRepresentative.make(ny, dy)))
          = Rational.padic_absolute_value(
                p, primality,
                Quotient.mk(RationalRepresentative.make(nx, dx)))
    by Equality.transitivity(
           congruenceOf(
               function (m : Rational) =>
                   Rational.padic_absolute_value(
                       p, primality,
                       Quotient.mk(RationalRepresentative.make(nx, dx)))
                   + m,
               padicAvYEqZero),
           Rational.add_zero(
               Rational.padic_absolute_value(
                   p, primality,
                   Quotient.mk(RationalRepresentative.make(nx, dx)))));
  rewrite(
      Equality.symmetry(rhsEqX),
      Equality.transport_proposition(
          Rational,
          function (m : Rational) =>
              m
                ≤ Rational.padic_absolute_value(
                      p, primality,
                      Quotient.mk(RationalRepresentative.make(nx, dx))),
          Rational.padic_absolute_value(
              p, primality,
              Quotient.mk(RationalRepresentative.make(nx, dx))),
          Rational.padic_absolute_value(
              p, primality,
              (Quotient.mk(RationalRepresentative.make(nx, dx)) : Rational)
              + (Quotient.mk(RationalRepresentative.make(ny, dy)) : Rational)),
          Equality.symmetry(padicAvSumEqX),
          Rational.LessOrEqual.reflexive(
              Rational.padic_absolute_value(
                  p, primality,
                  Quotient.mk(RationalRepresentative.make(nx, dx))))))
}

-- Sub-case: when the sum's numerator has absolute value zero.
-- Then padic_av(x+y) = 0 (by padic_absolute_value_at_zero), and RHS is
-- a sum of two nonneg padic_avs (hence nonneg). So 0 ≤ RHS.
theorem Rational.padic_absolute_value_triangle_at_reps_when_sum_zero
        (nx ny : Integer) (dx dy : Natural)
        (eqAbsSumZero
            : Integer.absolute_value_natural(
                  nx * (successor(dy) : Integer)
                  + ny * (successor(dx) : Integer)) = zero)
        : Rational.padic_absolute_value(
              p, primality,
              (Quotient.mk(RationalRepresentative.make(nx, dx)) : Rational)
              + (Quotient.mk(RationalRepresentative.make(ny, dy)) : Rational))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Quotient.mk(RationalRepresentative.make(nx, dx)))
              + Rational.padic_absolute_value(
                    p, primality,
                    Quotient.mk(RationalRepresentative.make(ny, dy))) := {
  claim lhsIsZero
        : Rational.padic_absolute_value(
              p, primality,
              (Quotient.mk(RationalRepresentative.make(nx, dx)) : Rational)
              + (Quotient.mk(RationalRepresentative.make(ny, dy)) : Rational))
          = Rational.zero
    by Rational.padic_absolute_value_at_zero(
           p,
           nx * (successor(dy) : Integer)
             + ny * (successor(dx) : Integer),
           dy + dx * successor(dy),
           eqAbsSumZero);
  rewrite(
      Equality.symmetry(lhsIsZero),
      Rational.LessOrEqual_zero_of_IsNonneg(
          Rational.padic_absolute_value(
              p, primality,
              Quotient.mk(RationalRepresentative.make(nx, dx)))
          + Rational.padic_absolute_value(
                p, primality,
                Quotient.mk(RationalRepresentative.make(ny, dy))),
          Rational.IsNonneg.add(
              Rational.padic_absolute_value(
                  p, primality,
                  Quotient.mk(RationalRepresentative.make(nx, dx))),
              Rational.padic_absolute_value(
                  p, primality,
                  Quotient.mk(RationalRepresentative.make(ny, dy))),
              Rational.IsNonneg_of_LessOrEqual_zero(
                  Rational.padic_absolute_value(
                      p, primality,
                      Quotient.mk(RationalRepresentative.make(nx, dx))),
                  Rational.padic_absolute_value_nonneg(
                      p, primality,
                      Quotient.mk(RationalRepresentative.make(nx, dx)))),
              Rational.IsNonneg_of_LessOrEqual_zero(
                  Rational.padic_absolute_value(
                      p, primality,
                      Quotient.mk(RationalRepresentative.make(ny, dy))),
                  Rational.padic_absolute_value_nonneg(
                      p, primality,
                      Quotient.mk(RationalRepresentative.make(ny, dy)))))))
}

-- WLOG sub-case for case D: |nx| ≥ 1, |ny| ≥ 1, |sum| ≥ 1, and the
-- p-adic valuations satisfy v_p(|nx·succ(dy)|) ≤ v_p(|ny·succ(dx)|).
-- Applies the Integer ultrametric to (A, B) = (nx·succ(dy), ny·succ(dx))
-- to bound v_p(|sum|) from below, then Helper A turns the exponent
-- inequality into |x+y|_p ≤ |x|_p, and le_add_right_of_nonneg lifts
-- to |x+y|_p ≤ |x|_p + |y|_p.
theorem Rational.padic_absolute_value_triangle_at_reps_wlog_case_a
        (nx ny : Integer) (dx dy : Natural)
        (kx ky kSum : Natural)
        (eqAbsNx : Integer.absolute_value_natural(nx) = successor(kx))
        (eqAbsNy : Integer.absolute_value_natural(ny) = successor(ky))
        (eqAbsSum
            : Integer.absolute_value_natural(
                  nx * (successor(dy) : Integer)
                  + ny * (successor(dx) : Integer)) = successor(kSum))
        (vALeqVB
            : Natural.padic_valuation(p, successor(kx))
                + Natural.padic_valuation(p, successor(dy))
              ≤ Natural.padic_valuation(p, successor(ky))
                  + Natural.padic_valuation(p, successor(dx)))
        : Rational.padic_absolute_value(
              p, primality,
              (Quotient.mk(RationalRepresentative.make(nx, dx)) : Rational)
              + (Quotient.mk(RationalRepresentative.make(ny, dy)) : Rational))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Quotient.mk(RationalRepresentative.make(nx, dx)))
              + Rational.padic_absolute_value(
                    p, primality,
                    Quotient.mk(RationalRepresentative.make(ny, dy))) := {
  -- Primality and successor-positivity preamble.
  claim primeAtLeastTwo : 2 ≤ p
    by Natural.is_prime.at_least_two(p, primality);
  claim primePositive : 1 ≤ p
    by Natural.is_prime.positive(p, primality);
  claim succKxPos    : 1 ≤ successor(kx)    by Natural.successor_positive(kx);
  claim succKyPos    : 1 ≤ successor(ky)    by Natural.successor_positive(ky);
  claim succDxPos    : 1 ≤ successor(dx)    by Natural.successor_positive(dx);
  claim succDyPos    : 1 ≤ successor(dy)    by Natural.successor_positive(dy);
  claim succKSumPos  : 1 ≤ successor(kSum)  by Natural.successor_positive(kSum);
  -- |nx · (succ(dy):Int)|_Nat = |nx|_Nat · succ(dy) = succ(kx) · succ(dy).
  -- (|(succ(dy):Int)|_Nat = succ(dy) is definitional via distance(succ(dy), 0).)
  claim absAEq
        : Integer.absolute_value_natural(
              nx * (successor(dy) : Integer))
          = successor(kx) * successor(dy)
    by calc Integer.absolute_value_natural(
                nx * (successor(dy) : Integer))
          = Integer.absolute_value_natural(nx) * successor(dy)
                by Integer.absolute_value_natural_multiplicative(
                       nx, (successor(dy) : Integer))
          = successor(kx) * successor(dy)
                by congruenceOf(
                       function (m : Natural) => m * successor(dy),
                       eqAbsNx);
  claim absBEq
        : Integer.absolute_value_natural(
              ny * (successor(dx) : Integer))
          = successor(ky) * successor(dx)
    by calc Integer.absolute_value_natural(
                ny * (successor(dx) : Integer))
          = Integer.absolute_value_natural(ny) * successor(dx)
                by Integer.absolute_value_natural_multiplicative(
                       ny, (successor(dx) : Integer))
          = successor(ky) * successor(dx)
                by congruenceOf(
                       function (m : Natural) => m * successor(dx),
                       eqAbsNy);
  -- |sum|_Nat ≥ 1.
  claim sumAbsPositive
        : successor(zero)
            ≤ Integer.absolute_value_natural(
                  nx * (successor(dy) : Integer)
                  + ny * (successor(dx) : Integer))
    by rewrite(Equality.symmetry(eqAbsSum), succKSumPos);
  -- v_p(|A|_Nat) = v_p(succ(kx)) + v_p(succ(dy)) (via mult on succ-form).
  claim vAFormulaSucc
        : Natural.padic_valuation(
              p, Integer.absolute_value_natural(
                     nx * (successor(dy) : Integer)))
          = Natural.padic_valuation(p, successor(kx))
              + Natural.padic_valuation(p, successor(dy))
    by Equality.transitivity(
           congruenceOf(
               function (m : Natural) => Natural.padic_valuation(p, m),
               absAEq),
           Natural.padic_valuation_multiplicative(
               p, successor(kx), successor(dy),
               primality, succKxPos, succDyPos));
  -- v_p(|B|_Nat) = v_p(succ(ky)) + v_p(succ(dx)).
  claim vBFormulaSucc
        : Natural.padic_valuation(
              p, Integer.absolute_value_natural(
                     ny * (successor(dx) : Integer)))
          = Natural.padic_valuation(p, successor(ky))
              + Natural.padic_valuation(p, successor(dx))
    by Equality.transitivity(
           congruenceOf(
               function (m : Natural) => Natural.padic_valuation(p, m),
               absBEq),
           Natural.padic_valuation_multiplicative(
               p, successor(ky), successor(dx),
               primality, succKyPos, succDxPos));
  -- v_p(|A|_Nat) ≤ v_p(|B|_Nat), from vALeqVB via the formula bridges.
  claim valuationLe
        : Natural.padic_valuation(
              p, Integer.absolute_value_natural(
                     nx * (successor(dy) : Integer)))
          ≤ Natural.padic_valuation(
                p, Integer.absolute_value_natural(
                       ny * (successor(dx) : Integer)))
    by rewrite(Equality.symmetry(vBFormulaSucc),
               rewrite(Equality.symmetry(vAFormulaSucc), vALeqVB));
  -- Ultrametric: v_p(|A|) ≤ v_p(|A+B|).
  claim ultraIneq
        : Natural.padic_valuation(
              p, Integer.absolute_value_natural(
                     nx * (successor(dy) : Integer)))
          ≤ Natural.padic_valuation(
                p, Integer.absolute_value_natural(
                       nx * (successor(dy) : Integer)
                       + ny * (successor(dx) : Integer)))
    by Integer.padic_valuation_absolute_value_natural_ultrametric_when_le(
           p, primeAtLeastTwo,
           nx * (successor(dy) : Integer),
           ny * (successor(dx) : Integer),
           sumAbsPositive, valuationLe);
  -- v_p(|sum|_Nat) = v_p(succ(kSum)) via eqAbsSum + congruenceOf.
  claim vSumIsVKSum
        : Natural.padic_valuation(
              p, Integer.absolute_value_natural(
                     nx * (successor(dy) : Integer)
                     + ny * (successor(dx) : Integer)))
          = Natural.padic_valuation(p, successor(kSum))
    by congruenceOf(
           function (m : Natural) => Natural.padic_valuation(p, m),
           eqAbsSum);
  -- Combine: v_p(succ(kx)) + v_p(succ(dy)) ≤ v_p(succ(kSum)).
  claim vASumLeVKSum
        : Natural.padic_valuation(p, successor(kx))
            + Natural.padic_valuation(p, successor(dy))
          ≤ Natural.padic_valuation(p, successor(kSum))
    by rewrite(vSumIsVKSum, rewrite(vAFormulaSucc, ultraIneq));
  -- v_p(succ(dy + dx · succ(dy))) = v_p(succ(dx)) + v_p(succ(dy)).
  -- This uses padic_valuation_multiplicative on succ(dx) and succ(dy),
  -- whose product is definitionally succ(dy + dx · succ(dy)).
  claim vDFormulaMult
        : Natural.padic_valuation(p, successor(dy + dx * successor(dy)))
          = Natural.padic_valuation(p, successor(dx))
              + Natural.padic_valuation(p, successor(dy))
    by Natural.padic_valuation_multiplicative(
           p, successor(dx), successor(dy),
           primality, succDxPos, succDyPos);
  -- The Helper A exponent inequality. Substitute vDFormulaMult on the
  -- LHS, then AC-rearrange to align with le_add_preserves_right; the
  -- final ≤ step uses vASumLeVKSum to bound (vp(kx) + vp(dy)) by vp(kSum).
  claim exponentLe
        : Natural.padic_valuation(p, successor(dy + dx * successor(dy)))
            + Natural.padic_valuation(p, successor(kx))
          ≤ Natural.padic_valuation(p, successor(dx))
              + Natural.padic_valuation(p, successor(kSum))
    by calc Natural.padic_valuation(p, successor(dy + dx * successor(dy)))
                + Natural.padic_valuation(p, successor(kx))
          = (Natural.padic_valuation(p, successor(dx))
                 + Natural.padic_valuation(p, successor(dy)))
                + Natural.padic_valuation(p, successor(kx))
                by rewrite(vDFormulaMult)
          = Natural.padic_valuation(p, successor(dx))
                + (Natural.padic_valuation(p, successor(kx))
                   + Natural.padic_valuation(p, successor(dy)))
          ≤ Natural.padic_valuation(p, successor(dx))
                + Natural.padic_valuation(p, successor(kSum))
                by Natural.le_add_preserves_right(
                       Natural.padic_valuation(p, successor(dx)),
                       Natural.padic_valuation(p, successor(kx))
                           + Natural.padic_valuation(p, successor(dy)),
                       Natural.padic_valuation(p, successor(kSum)),
                       vASumLeVKSum);
  -- Apply Helper A.
  claim helperAResult
        : (Quotient.mk(RationalRepresentative.make(
                  (Natural.power(
                       Natural.padic_valuation(p, successor(dy + dx * successor(dy))), p)
                       : Integer),
                  Natural.monus(
                      Natural.power(
                          Natural.padic_valuation(p, successor(kSum)), p),
                      successor(zero)))) : Rational)
          ≤ (Quotient.mk(RationalRepresentative.make(
                    (Natural.power(
                         Natural.padic_valuation(p, successor(dx)), p)
                         : Integer),
                    Natural.monus(
                        Natural.power(
                            Natural.padic_valuation(p, successor(kx)), p),
                        successor(zero)))) : Rational)
    by Rational.padic_av_form_le_when_exponent_le(
           p, primePositive,
           Natural.padic_valuation(p, successor(dy + dx * successor(dy))),
           Natural.padic_valuation(p, successor(dx)),
           Natural.padic_valuation(p, successor(kSum)),
           Natural.padic_valuation(p, successor(kx)),
           exponentLe);
  -- Bridge LHS: padic_av(x+y) = mk(make((p^... : Int), ...)).
  claim lhsForm
        : Rational.padic_absolute_value(
              p, primality,
              (Quotient.mk(RationalRepresentative.make(nx, dx)) : Rational)
              + (Quotient.mk(RationalRepresentative.make(ny, dy)) : Rational))
          = Quotient.mk(RationalRepresentative.make(
                    (Natural.power(
                         Natural.padic_valuation(p, successor(dy + dx * successor(dy))), p)
                         : Integer),
                    Natural.monus(
                        Natural.power(
                            Natural.padic_valuation(p, successor(kSum)), p),
                        successor(zero))))
    by Rational.padic_absolute_value_at_succ(
           p,
           nx * (successor(dy) : Integer)
             + ny * (successor(dx) : Integer),
           dy + dx * successor(dy),
           kSum, eqAbsSum);
  -- Bridge RHS: |x|_p = mk(make((p^... : Int), ...)).
  claim rhsXForm
        : Rational.padic_absolute_value(
              p, primality,
              Quotient.mk(RationalRepresentative.make(nx, dx)))
          = Quotient.mk(RationalRepresentative.make(
                    (Natural.power(
                         Natural.padic_valuation(p, successor(dx)), p)
                         : Integer),
                    Natural.monus(
                        Natural.power(
                            Natural.padic_valuation(p, successor(kx)), p),
                        successor(zero))))
    by Rational.padic_absolute_value_at_succ(p, nx, dx, kx, eqAbsNx);
  -- Transport helperAResult to: padic_av(x+y) ≤ |x|_p.
  claim padicAvSumLeX
        : Rational.padic_absolute_value(
              p, primality,
              (Quotient.mk(RationalRepresentative.make(nx, dx)) : Rational)
              + (Quotient.mk(RationalRepresentative.make(ny, dy)) : Rational))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Quotient.mk(RationalRepresentative.make(nx, dx)))
    by rewrite(Equality.symmetry(lhsForm),
           rewrite(Equality.symmetry(rhsXForm), helperAResult));
  -- |y|_p ≥ 0.
  claim padicAvYNonneg
        : Rational.zero
            ≤ Rational.padic_absolute_value(
                  p, primality,
                  Quotient.mk(RationalRepresentative.make(ny, dy)))
    by Rational.padic_absolute_value_nonneg(
           p, primality,
           Quotient.mk(RationalRepresentative.make(ny, dy)));
  -- |x|_p ≤ |x|_p + |y|_p.
  claim padicAvXLeXPlusY
        : Rational.padic_absolute_value(
              p, primality,
              Quotient.mk(RationalRepresentative.make(nx, dx)))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Quotient.mk(RationalRepresentative.make(nx, dx)))
              + Rational.padic_absolute_value(
                    p, primality,
                    Quotient.mk(RationalRepresentative.make(ny, dy)))
    by Rational.le_add_right_of_nonneg(
           Rational.padic_absolute_value(
               p, primality,
               Quotient.mk(RationalRepresentative.make(nx, dx))),
           Rational.padic_absolute_value(
               p, primality,
               Quotient.mk(RationalRepresentative.make(ny, dy))),
           padicAvYNonneg);
  calc Rational.padic_absolute_value(
           p, primality,
           (Quotient.mk(RationalRepresentative.make(nx, dx)) : Rational)
             + (Quotient.mk(RationalRepresentative.make(ny, dy)) : Rational))
     ≤ Rational.padic_absolute_value(
           p, primality,
           Quotient.mk(RationalRepresentative.make(nx, dx)))
              by padicAvSumLeX
     ≤ Rational.padic_absolute_value(
           p, primality,
           Quotient.mk(RationalRepresentative.make(nx, dx)))
         + Rational.padic_absolute_value(
               p, primality,
               Quotient.mk(RationalRepresentative.make(ny, dy)))
              by padicAvXLeXPlusY
}

-- Sub-case D: |nx| ≥ 1, |ny| ≥ 1, |sum| ≥ 1. Dispatch via totality on
-- v_p(succ(kx)) + v_p(succ(dy)) vs v_p(succ(ky)) + v_p(succ(dx)),
-- applying the WLOG helper directly in case A and after swapping x ↔ y
-- (with commutativity bridges) in case B.
theorem Rational.padic_absolute_value_triangle_at_reps_when_all_succ
        (nx ny : Integer) (dx dy : Natural)
        (kx ky kSum : Natural)
        (eqAbsNx : Integer.absolute_value_natural(nx) = successor(kx))
        (eqAbsNy : Integer.absolute_value_natural(ny) = successor(ky))
        (eqAbsSum
            : Integer.absolute_value_natural(
                  nx * (successor(dy) : Integer)
                  + ny * (successor(dx) : Integer)) = successor(kSum))
        : Rational.padic_absolute_value(
              p, primality,
              (Quotient.mk(RationalRepresentative.make(nx, dx)) : Rational)
              + (Quotient.mk(RationalRepresentative.make(ny, dy)) : Rational))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Quotient.mk(RationalRepresentative.make(nx, dx)))
              + Rational.padic_absolute_value(
                    p, primality,
                    Quotient.mk(RationalRepresentative.make(ny, dy))) :=
  claim Natural.padic_valuation(p, successor(kx))
            + Natural.padic_valuation(p, successor(dy))
          ≤ Natural.padic_valuation(p, successor(ky))
              + Natural.padic_valuation(p, successor(dx))
        ∨ Natural.padic_valuation(p, successor(ky))
              + Natural.padic_valuation(p, successor(dx))
          ≤ Natural.padic_valuation(p, successor(kx))
              + Natural.padic_valuation(p, successor(dy))
  claim by cases {
    in (Natural.padic_valuation(p, successor(kx))
            + Natural.padic_valuation(p, successor(dy))
          ≤ Natural.padic_valuation(p, successor(ky))
              + Natural.padic_valuation(p, successor(dx))) as vALevB:
        Rational.padic_absolute_value_triangle_at_reps_wlog_case_a(
            p, primality, nx, ny, dx, dy, kx, ky, kSum,
            eqAbsNx, eqAbsNy, eqAbsSum, vALevB)
    in (Natural.padic_valuation(p, successor(ky))
            + Natural.padic_valuation(p, successor(dx))
          ≤ Natural.padic_valuation(p, successor(kx))
              + Natural.padic_valuation(p, successor(dy))) as vBLevA: {
      -- eqAbsSum with addends swapped (via Integer.add_commutative).
      claim eqAbsSumSwapped
            : Integer.absolute_value_natural(
                  ny * (successor(dx) : Integer)
                  + nx * (successor(dy) : Integer))
              = successor(kSum)
        by Equality.transitivity(
               congruenceOf(
                   Integer.absolute_value_natural,
                   Integer.add_commutative(
                       ny * (successor(dx) : Integer),
                       nx * (successor(dy) : Integer))),
               eqAbsSum);
      -- Apply WLOG helper with x, y swapped: get |y+x|_p ≤ |y|_p + |x|_p.
      claim swappedResult
            : Rational.padic_absolute_value(
                  p, primality,
                  Quotient.mk(RationalRepresentative, RationalEquivalent,
                              RationalRepresentative.make(ny, dy))
                  + Quotient.mk(RationalRepresentative, RationalEquivalent,
                              RationalRepresentative.make(nx, dx)))
              ≤ Rational.padic_absolute_value(
                    p, primality,
                    Quotient.mk(RationalRepresentative.make(ny, dy)))
                  + Rational.padic_absolute_value(
                        p, primality,
                        Quotient.mk(RationalRepresentative.make(nx, dx)))
        by Rational.padic_absolute_value_triangle_at_reps_wlog_case_a(
               p, primality, ny, nx, dy, dx, ky, kx, kSum,
               eqAbsNy, eqAbsNx, eqAbsSumSwapped, vBLevA);
      -- Transport via add_commutative on both sides:
      --   y + x = x + y, |y|_p + |x|_p = |x|_p + |y|_p.
      claim sumSwap
            : Quotient.mk(RationalRepresentative, RationalEquivalent,
                        RationalRepresentative.make(ny, dy))
                + Quotient.mk(RationalRepresentative, RationalEquivalent,
                            RationalRepresentative.make(nx, dx))
              = Quotient.mk(RationalRepresentative, RationalEquivalent,
                          RationalRepresentative.make(nx, dx))
                  + Quotient.mk(RationalRepresentative, RationalEquivalent,
                              RationalRepresentative.make(ny, dy))
        by Rational.add_commutative(
               Quotient.mk(RationalRepresentative.make(ny, dy)),
               Quotient.mk(RationalRepresentative.make(nx, dx)));
      claim rhsSwap
            : Rational.padic_absolute_value(
                  p, primality,
                  Quotient.mk(RationalRepresentative.make(ny, dy)))
                + Rational.padic_absolute_value(
                      p, primality,
                      Quotient.mk(RationalRepresentative.make(nx, dx)))
              = Rational.padic_absolute_value(
                    p, primality,
                    Quotient.mk(RationalRepresentative.make(nx, dx)))
                  + Rational.padic_absolute_value(
                        p, primality,
                        Quotient.mk(RationalRepresentative.make(ny, dy)))
        by Rational.add_commutative(
               Rational.padic_absolute_value(
                   p, primality,
                   Quotient.mk(RationalRepresentative.make(ny, dy))),
               Rational.padic_absolute_value(
                   p, primality,
                   Quotient.mk(RationalRepresentative.make(nx, dx))));
      rewrite(
          congruenceOf(
              function (m : Rational) =>
                  Rational.padic_absolute_value(p, primality, m),
              sumSwap),
          rewrite(rhsSwap, swappedResult))
    }
  }

-- Triangle inequality at the Rational representative level. Dispatches
-- on |nx|, |ny|, and the sum's |·|_Nat via the function-then-cases pattern.
theorem Rational.padic_absolute_value_triangle_at_representatives
        (nx ny : Integer) (dx dy : Natural)
        : Rational.padic_absolute_value(
              p, primality,
              (Quotient.mk(RationalRepresentative.make(nx, dx)) : Rational)
              + (Quotient.mk(RationalRepresentative.make(ny, dy)) : Rational))
          ≤ Rational.padic_absolute_value(
                p, primality,
                Quotient.mk(RationalRepresentative.make(nx, dx)))
              + Rational.padic_absolute_value(
                    p, primality,
                    Quotient.mk(RationalRepresentative.make(ny, dy))) :=
  cases Integer.absolute_value_natural(nx) with eqAbsNxSucc {
     | zero =>
         Rational.padic_absolute_value_triangle_at_reps_when_nx_zero(
             p, primality, nx, ny, dx, dy, eqAbsNxSucc)
     | successor(kx) =>
         cases Integer.absolute_value_natural(ny) with eqAbsNySucc {
            | zero =>
                Rational.padic_absolute_value_triangle_at_reps_when_ny_zero(
                    p, primality, nx, ny, dx, dy, eqAbsNySucc)
            | successor(ky) =>
                cases Integer.absolute_value_natural(
                          nx * (successor(dy) : Integer)
                          + ny * (successor(dx) : Integer)) with eqAbsSumSucc {
                   | zero =>
                       Rational.padic_absolute_value_triangle_at_reps_when_sum_zero(
                           p, primality, nx, ny, dx, dy, eqAbsSumSucc)
                   | successor(kSum) =>
                       Rational.padic_absolute_value_triangle_at_reps_when_all_succ(
                           p, primality, nx, ny, dx, dy,
                           kx, ky, kSum,
                           eqAbsNxSucc, eqAbsNySucc, eqAbsSumSucc)
                 }
          }
   }

-- Top-level: |x+y|_p ≤ |x|_p + |y|_p for all Rationals x, y. Lift via
-- Quotient.induct_two.
theorem Rational.padic_absolute_value_triangle
        (x y : Rational)
        : Rational.padic_absolute_value(p, primality, x + y)
          ≤ Rational.padic_absolute_value(p, primality, x)
              + Rational.padic_absolute_value(p, primality, y) :=
  Quotient.induct_two(
      function (xArg yArg : Rational) =>
          Rational.padic_absolute_value(p, primality, xArg + yArg)
            ≤ Rational.padic_absolute_value(p, primality, xArg)
                + Rational.padic_absolute_value(p, primality, yArg),
      function (rep_x rep_y : RationalRepresentative) =>
          (cases rep_x {
             | RationalRepresentative.make(nx, dx) =>
                 (cases rep_y {
                    | RationalRepresentative.make(ny, dy) =>
                        Rational.padic_absolute_value_triangle_at_representatives(
                            p, primality, nx, ny, dx, dy)
                  } : Rational.padic_absolute_value(
                          p, primality,
                          Quotient.mk(RationalRepresentative, RationalEquivalent,
                                      RationalRepresentative.make(nx, dx))
                          + Quotient.mk(RationalRepresentative, RationalEquivalent,
                                      rep_y))
                      ≤ Rational.padic_absolute_value(
                            p, primality,
                            Quotient.mk(RationalRepresentative.make(nx, dx)))
                          + Rational.padic_absolute_value(
                                p, primality,
                                Quotient.mk(rep_y)))
           } : Rational.padic_absolute_value(
                   p, primality,
                   Quotient.mk(RationalRepresentative, RationalEquivalent,
                               rep_x)
                   + Quotient.mk(RationalRepresentative, RationalEquivalent,
                               rep_y))
               ≤ Rational.padic_absolute_value(
                     p, primality,
                     Quotient.mk(rep_x))
                 + Rational.padic_absolute_value(
                       p, primality,
                       Quotient.mk(rep_y))),
      x, y)

-- PAdic/negation.math
--
-- Pointwise negation of p-adic Cauchy sequences. Negation preserves
-- the p-adic-Cauchy property because |−s(m) − −s(n)|_p = |s(m) − s(n)|_p
-- (negation invariance of the p-adic absolute value).
--
-- Subtraction is the usual derived x − y := x + (−y).

module PAdic.negation

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.peano
import Natural.arithmetic
import Natural.distance
import Natural.prime
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.embedding
import Integer.negation
import Integer.absolute_value
import Integer.absolute_value_natural
import Rational.basics
import Rational.addition
import Rational.multiplication
import Rational.negation
import Rational.order
import Rational.absolute_value
import PAdic.absolute_value
import PAdic.basics
import PAdic.addition

convention p : Natural with primality : Natural.is_prime(p)

-- ----------------------------------------------------------------------
-- Helper: Integer absolute_value_natural is invariant under negation.
-- At rep make(a, b), negate swaps the components to make(b, a), and
-- distance is symmetric.
theorem Integer.absolute_value_natural_negate (x : Integer)
        : Integer.absolute_value_natural(-x)
          = Integer.absolute_value_natural(x) :=
  Quotient.induct(
      function (y : Integer) =>
          Integer.absolute_value_natural(-y)
            = Integer.absolute_value_natural(y),
      function (rep : IntegerRepresentative) =>
          (cases rep {
             | IntegerRepresentative.make(a, b) =>
                 Natural.distance_symmetric(b, a)
           } : Integer.absolute_value_natural(
                   -Quotient.mk(IntegerRepresentative, IntegerEquivalent, rep))
               = Integer.absolute_value_natural(Quotient.mk(rep))),
      x)

-- ----------------------------------------------------------------------
-- p-adic absolute value is invariant under negation at the
-- representative level. The padic_av_at_rep function depends on the
-- numerator only via Integer.absolute_value_natural, which the helper
-- above shows is invariant under -.
theorem Rational.padic_absolute_value_negate_at_representative (p : Natural)
        : (rep : RationalRepresentative)
          → Rational.padic_absolute_value_at_representative(
                p, Rational.negate_representatives(rep))
            = Rational.padic_absolute_value_at_representative(p, rep)
  | RationalRepresentative.make(n, d) =>
      cases Integer.absolute_value_natural(n) with eqAbsN {
        | zero =>
            Equality.transitivity(
                Rational,
                Rational.padic_absolute_value_at_representative(
                    p, RationalRepresentative.make(-n, d)),
                Rational.zero,
                Rational.padic_absolute_value_at_representative(
                    p, RationalRepresentative.make(n, d)),
                Rational.padic_absolute_value_at_zero(
                    p, -n, d,
                    Equality.transitivity(
                        Natural,
                        Integer.absolute_value_natural(-n),
                        Integer.absolute_value_natural(n),
                        zero,
                        Integer.absolute_value_natural_negate(n),
                        eqAbsN)),
                Equality.symmetry(
                    Rational.padic_absolute_value_at_zero(
                        p, n, d, eqAbsN)))
        | successor(k) =>
            Equality.transitivity(
                Rational,
                Rational.padic_absolute_value_at_representative(
                    p, RationalRepresentative.make(-n, d)),
                Quotient.mk(
                    RationalRepresentative, RationalEquivalent,
                    RationalRepresentative.make(
                        (Natural.power(
                             Natural.padic_valuation(p, successor(d)), p)
                             : Integer),
                        Natural.monus(
                            Natural.power(
                                Natural.padic_valuation(p, successor(k)), p),
                            successor(zero)))),
                Rational.padic_absolute_value_at_representative(
                    p, RationalRepresentative.make(n, d)),
                Rational.padic_absolute_value_at_succ(
                    p, -n, d, k,
                    Equality.transitivity(
                        Natural,
                        Integer.absolute_value_natural(-n),
                        Integer.absolute_value_natural(n),
                        successor(k),
                        Integer.absolute_value_natural_negate(n),
                        eqAbsN)),
                Equality.symmetry(
                    Rational.padic_absolute_value_at_succ(
                        p, n, d, k, eqAbsN)))
      }

-- |−x|_p = |x|_p at the Rational level. Lift via Quotient.induct.
theorem Rational.padic_absolute_value_negate
        (x : Rational)
        : Rational.padic_absolute_value(p, primality, -x)
          = Rational.padic_absolute_value(p, primality, x) :=
  Quotient.induct(
      function (y : Rational) =>
          Rational.padic_absolute_value(p, primality, -y)
            = Rational.padic_absolute_value(p, primality, y),
      function (rep : RationalRepresentative) =>
          Rational.padic_absolute_value_negate_at_representative(p, rep),
      x)

-- |−x − −y|_p = |x − y|_p. Goes via subtract_of_negates (pure Rational
-- algebra) and padic_absolute_value_negate.
theorem Rational.padic_absolute_value_of_subtract_of_negates
        (x y : Rational)
        : Rational.padic_absolute_value(p, primality, -x - -y)
          = Rational.padic_absolute_value(p, primality, x - y) :=
  calc Rational.padic_absolute_value(p, primality, -x - -y)
     = Rational.padic_absolute_value(p, primality, -(x - y))
     = Rational.padic_absolute_value(p, primality, x - y)

-- ----------------------------------------------------------------------
-- Pointwise negation of a p-adic Cauchy sequence is p-adic Cauchy.
-- Same N witness; transport via the negation-invariance of |·|_p.
theorem Rational.sequence.negate_is_padic_cauchy
        (s : Rational.sequence.Sequence)
        (sIsCauchy : Rational.sequence.IsPAdicCauchy(p, primality, s))
        : Rational.sequence.IsPAdicCauchy(p, primality,
              function (n : Natural) => -s(n)) :=
  function (epsilon : Rational)
           (epsilonPositive : Rational.zero < epsilon) => {
    obtain ⟨N, sCauchy_at_N⟩ from sIsCauchy(epsilon, epsilonPositive);
    witness N with
        function (m : Natural) (N_leq_m : N ≤ m)
                 (n : Natural) (N_leq_n : N ≤ n) =>
          rewrite(
              Equality.symmetry(
                  Rational.padic_absolute_value_of_subtract_of_negates(
                      p, primality, s(m), s(n))),
              sCauchy_at_N(m, N_leq_m, n, N_leq_n))
  }

-- ----------------------------------------------------------------------
-- Pointwise negation of a packaged p-adic Cauchy sequence.
definition PAdicCauchySequence.negate
        : PAdicCauchySequence(p, primality)
          → PAdicCauchySequence(p, primality)
  | PAdicCauchySequence.make(s, sCauchy) =>
      PAdicCauchySequence.make(
          function (n : Natural) => -s(n),
          Rational.sequence.negate_is_padic_cauchy(
              p, primality, s, sCauchy))

theorem PAdicCauchySequence.sequenceFunction_negate
        : (rep : PAdicCauchySequence(p, primality)) → (m : Natural)
          → PAdicCauchySequence.sequenceFunction(
                p, primality,
                PAdicCauchySequence.negate(p, primality, rep), m)
            = -PAdicCauchySequence.sequenceFunction(p, primality, rep, m)
  | PAdicCauchySequence.make(s, _), m =>
      reflexivity(Rational, -s(m))

-- Bridge each sequenceFunction(negate(rep), m) to -sequenceFunction(rep, m)
-- via sequenceFunction_negate, then one application of
-- padic_absolute_value_of_subtract_of_negates collapses the bound.
theorem PAdic.negate_respects
        (rep1 rep1Prime : PAdicCauchySequence(p, primality))
        (equivalenceHypothesis
            : PAdicEquivalent(p, primality, rep1, rep1Prime))
        : Quotient.mk(
              PAdicCauchySequence(p, primality),
              PAdicEquivalent(p, primality),
              PAdicCauchySequence.negate(p, primality, rep1))
          = Quotient.mk(
                PAdicCauchySequence(p, primality),
                PAdicEquivalent(p, primality),
                PAdicCauchySequence.negate(p, primality, rep1Prime)) :=
  Quotient.sound(
      PAdicCauchySequence(p, primality),
      PAdicEquivalent(p, primality),
      PAdicCauchySequence.negate(p, primality, rep1),
      PAdicCauchySequence.negate(p, primality, rep1Prime),
      function (epsilon : Rational)
               (epsilonPositive : Rational.zero < epsilon) =>
        ({
          obtain ⟨N, origAtN⟩
              from equivalenceHypothesis(epsilon, epsilonPositive);
          witness N with
              function (m : Natural) (N_leq_m : N ≤ m) =>
                rewrite(
                    Equality.symmetry(
                        PAdicCauchySequence.sequenceFunction_negate(
                            p, primality, rep1Prime, m)),
                    rewrite(
                        Equality.symmetry(
                            PAdicCauchySequence.sequenceFunction_negate(
                                p, primality, rep1, m)),
                        rewrite(
                            Equality.symmetry(
                                Rational.padic_absolute_value_of_subtract_of_negates(
                                    p, primality,
                                    PAdicCauchySequence.sequenceFunction(
                                        p, primality, rep1, m),
                                    PAdicCauchySequence.sequenceFunction(
                                        p, primality, rep1Prime, m))),
                            origAtN(m, N_leq_m))))
        } : ∃ (N : Natural).
              (m : Natural) → N ≤ m →
                Rational.padic_absolute_value(p, primality,
                    PAdicCauchySequence.sequenceFunction(
                        p, primality,
                        PAdicCauchySequence.negate(p, primality, rep1), m)
                    - PAdicCauchySequence.sequenceFunction(
                        p, primality,
                        PAdicCauchySequence.negate(p, primality, rep1Prime), m))
                  < epsilon))

definition PAdic.negate
        (x : PAdic(p, primality)) : PAdic(p, primality) :=
  Quotient.lift(
      function (rep : PAdicCauchySequence(p, primality)) =>
          Quotient.mk(
              PAdicCauchySequence(p, primality),
              PAdicEquivalent(p, primality),
              PAdicCauchySequence.negate(p, primality, rep)),
      PAdic.negate_respects(p, primality),
      x)

-- Subtraction.
definition PAdic.subtract
        (x y : PAdic(p, primality)) : PAdic(p, primality) :=
  PAdic.add(p, primality, x, PAdic.negate(p, primality, y))

-- IntegerMod/basics.math
--
-- The integers modulo a natural number `modulus`:
--   IntegerMod(modulus) := Quotient(Integer, CongruentModulo(modulus))
-- where two integers are congruent modulo `modulus` exactly when their
-- difference is divisible by `modulus`. This is the standard
-- construction of Z/(n); when `modulus` is prime it is the finite
-- field F_p (see IntegerMod/field.math).
--
-- Because the representatives are Integers (themselves a ring), the
-- equivalence proofs reduce to the Integer divisibility closure lemmas
-- from Integer/divisibility.math plus a `ring` rearrangement of the
-- differences.

module IntegerMod.basics

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import Integer.instances
import Integer.divisibility
import Algebra.ring_lemmas

-- x is congruent to y modulo `modulus` when `modulus` divides x − y.
definition Integer.CongruentModulo (modulus : ℕ) (x y : ℤ)
        : Proposition :=
  Integer.divides((modulus : ℤ), x - y)

-- The integers modulo `modulus`: equivalence classes of Integer under
-- congruence.
definition IntegerMod (modulus : ℕ) : Type(0) :=
  Quotient(ℤ, Integer.CongruentModulo(modulus))

-- ----------------------------------------------------------------------
-- Congruence is an equivalence relation. Each property is one Integer
-- divisibility lemma plus a `ring` identity describing how the
-- difference rearranges.

-- Reflexive: x − x = 0 and every integer divides 0.
theorem Integer.CongruentModulo.reflexive (modulus : ℕ) (x : ℤ)
        : Integer.CongruentModulo(modulus, x, x) := {
  Integer.divides((modulus : ℤ), Integer.zero) by Integer.divides_zero((modulus : ℤ));
  Integer.zero = x - x;
  Integer.divides((modulus : ℤ), x - x)
}

-- Symmetric: y − x = −(x − y), and divisibility is closed under
-- negation.
theorem Integer.CongruentModulo.symmetric (modulus : ℕ) (x y : ℤ)
        (congruent : Integer.CongruentModulo(modulus, x, y))
        : Integer.CongruentModulo(modulus, y, x) := {
  Integer.divides((modulus : ℤ), -(x - y)) by Integer.divides_negate((modulus : ℤ), x - y, congruent);
  -(x - y) = y - x;
  Integer.divides((modulus : ℤ), y - x)
}

-- Transitive: x − z = (x − y) + (y − z), and divisibility is closed
-- under addition.
theorem Integer.CongruentModulo.transitive (modulus : ℕ)
        (x y z : ℤ)
        (congruentXY : Integer.CongruentModulo(modulus, x, y))
        (congruentYZ : Integer.CongruentModulo(modulus, y, z))
        : Integer.CongruentModulo(modulus, x, z) := {
  Integer.divides((modulus : ℤ), (x - y) + (y - z))
      by Integer.divides_add((modulus : ℤ), x - y, y - z, congruentXY, congruentYZ);
  (x - y) + (y - z) = x - z;
  Integer.divides((modulus : ℤ), x - z)
}

-- The congruence bundled as an `IsEquivalenceRelation`, registered as
-- the canonical instance for IntegerMod's quotient. Parameterized by the
-- modulus (which lives in the RELATION, not the carrier Integer), so
-- `Quotient.equal_implies_equivalent(x, y, mkEquality)` recovers the laws with the modulus
-- threaded automatically.
definition IntegerMod.equivalence (modulus : ℕ)
        : IsEquivalenceRelation(ℤ,
                                 Integer.CongruentModulo(modulus)) :=
  ⟨Integer.CongruentModulo.reflexive(modulus),
   Integer.CongruentModulo.symmetric(modulus),
   Integer.CongruentModulo.transitive(modulus)⟩

instance IntegerMod.equivalence

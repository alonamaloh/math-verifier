-- IntegerMod/ring.math
--
-- The commutative-ring laws for IntegerMod(modulus). Every law lifts
-- the corresponding Integer law through the quotient: on
-- representatives `a, b, …`, both sides reduce (by the Quotient.lift
-- compute rule) to `IntegerMod.make(modulus, <Integer expression>)`,
-- so the law is exactly `congruenceOf(make, <Integer law>)`.
--
-- Every law uses the short `Quotient.induct` / `induct_two` /
-- `induct_three` forms: their motive inference handles the
-- parameterized quotient IntegerMod (the single `Quotient.induct`
-- motive recovery for parameterized aliases works — the earlier
-- explicit-motive workaround is no longer needed). The constants are
-- spelled `IntegerMod.zero(modulus)` / `IntegerMod.one(modulus)` since
-- a bare nullary constant has no operand to drive modulus inference;
-- negation is the implicit-modulus `IntegerMod.negate(x)`.

module IntegerMod.ring

import Logic.basics
import Logic.quotient
import Equality.basics
import Natural.basics
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.ring
import IntegerMod.basics
import IntegerMod.operations

-- ----------------------------------------------------------------------
-- Additive abelian group.

theorem IntegerMod.add_associative (modulus : Natural)
        (x y z : IntegerMod(modulus))
        : (x + y) + z = x + (y + z) :=
  by_representatives x as a, y as b, z as c =>
    claim IntegerMod.make(modulus, a + b + c)
        = IntegerMod.make(modulus, a + (b + c))
      by substituting Integer.add_associative(a, b, c)

theorem IntegerMod.add_identity_left (modulus : Natural)
        (x : IntegerMod(modulus))
        : IntegerMod.zero(modulus) + x = x :=
  by_representatives x as a =>
    claim IntegerMod.make(modulus, Integer.zero + a)
        = IntegerMod.make(modulus, a)
      by substituting Integer.add_identity_left(a)

theorem IntegerMod.add_identity_right (modulus : Natural)
        (x : IntegerMod(modulus))
        : x + IntegerMod.zero(modulus) = x :=
  by_representatives x as a =>
    claim IntegerMod.make(modulus, a + Integer.zero)
        = IntegerMod.make(modulus, a)
      by substituting Integer.add_identity_right(a)

theorem IntegerMod.add_commutative (modulus : Natural)
        (x y : IntegerMod(modulus))
        : x + y = y + x :=
  by_representatives x as a, y as b =>
    claim IntegerMod.make(modulus, a + b)
        = IntegerMod.make(modulus, b + a)
      by substituting Integer.add_commutative(a, b)

theorem IntegerMod.add_negate_left (modulus : Natural)
        (x : IntegerMod(modulus))
        : IntegerMod.negate(x) + x = IntegerMod.zero(modulus) :=
  by_representatives x as a =>
    claim IntegerMod.make(modulus, -a + a)
        = IntegerMod.make(modulus, Integer.zero)
      by substituting Integer.add_negate_left(a)

theorem IntegerMod.add_negate_right (modulus : Natural)
        (x : IntegerMod(modulus))
        : x + IntegerMod.negate(x) = IntegerMod.zero(modulus) :=
  by_representatives x as a =>
    claim IntegerMod.make(modulus, a + -a)
        = IntegerMod.make(modulus, Integer.zero)
      by substituting Integer.add_negate_right(a)

-- ----------------------------------------------------------------------
-- Multiplicative monoid.

theorem IntegerMod.multiply_associative (modulus : Natural)
        (x y z : IntegerMod(modulus))
        : (x * y) * z = x * (y * z) :=
  by_representatives x as a, y as b, z as c =>
    claim IntegerMod.make(modulus, a * b * c)
        = IntegerMod.make(modulus, a * (b * c))
      by substituting Integer.multiply_associative(a, b, c)

theorem IntegerMod.multiply_identity_left (modulus : Natural)
        (x : IntegerMod(modulus))
        : IntegerMod.one(modulus) * x = x :=
  by_representatives x as a =>
    claim IntegerMod.make(modulus, Integer.one * a)
        = IntegerMod.make(modulus, a)
      by substituting Integer.multiply_identity_left(a)

theorem IntegerMod.multiply_identity_right (modulus : Natural)
        (x : IntegerMod(modulus))
        : x * IntegerMod.one(modulus) = x :=
  by_representatives x as a =>
    claim IntegerMod.make(modulus, a * Integer.one)
        = IntegerMod.make(modulus, a)
      by substituting Integer.multiply_identity_right(a)

theorem IntegerMod.multiply_commutative (modulus : Natural)
        (x y : IntegerMod(modulus))
        : x * y = y * x :=
  by_representatives x as a, y as b =>
    claim IntegerMod.make(modulus, a * b)
        = IntegerMod.make(modulus, b * a)
      by substituting Integer.multiply_commutative(a, b)

-- ----------------------------------------------------------------------
-- Distributivity.

theorem IntegerMod.distributivity_left (modulus : Natural)
        (x y z : IntegerMod(modulus))
        : x * (y + z) = x * y + x * z :=
  by_representatives x as a, y as b, z as c =>
    claim IntegerMod.make(modulus, a * (b + c))
        = IntegerMod.make(modulus, a * b + a * c)
      by substituting Integer.distributivity_left(a, b, c)

theorem IntegerMod.distributivity_right (modulus : Natural)
        (x y z : IntegerMod(modulus))
        : (x + y) * z = x * z + y * z :=
  by_representatives x as a, y as b, z as c =>
    claim IntegerMod.make(modulus, (a + b) * c)
        = IntegerMod.make(modulus, a * c + b * c)
      by substituting Integer.distributivity_right(a, b, c)

-- ----------------------------------------------------------------------
-- Negation facts, read off the integer representatives like the laws
-- above: negation is an involution, and pulls out of a product.

theorem IntegerMod.negate_negate (modulus : Natural) (x : IntegerMod(modulus))
        : IntegerMod.negate(IntegerMod.negate(x)) = x :=
  by_representatives x as a =>
    claim IntegerMod.make(modulus, -(-a)) = IntegerMod.make(modulus, a)
      by substituting (ring : -(-a) = a)

theorem IntegerMod.negate_multiply_left (modulus : Natural)
        (x y : IntegerMod(modulus))
        : IntegerMod.negate(x) * y = IntegerMod.negate(x * y) :=
  by_representatives x as a, y as b =>
    claim IntegerMod.make(modulus, -a * b) = IntegerMod.make(modulus, -(a * b))
      by substituting (ring : -a * b = -(a * b))

-- The four-factor exchange (a·b)·(c·d) = (a·c)·(b·d) — the rearrangement
-- behind "scale every factor of a product".
theorem IntegerMod.multiply_exchange (modulus : Natural)
        (a b c d : IntegerMod(modulus))
        : (a * b) * (c * d) = (a * c) * (b * d) :=
  by_representatives a as w, b as x, c as y, d as z =>
    claim IntegerMod.make(modulus, w * x * (y * z))
        = IntegerMod.make(modulus, w * y * (x * z))
      by substituting (ring : w * x * (y * z) = w * y * (x * z))

-- IntegerMod/wilson.math
--
-- Wilson's theorem: for an odd prime p (written p = 1 + n), the product
-- of all nonzero classes of F_p is −1, hence n! ≡ −1 (mod p), hence
-- p ∣ n! + 1. The field facts that drive it:
--
--   * IntegerMod.multiply_zero        — x · 0 = 0 (the right zero law)
--   * IntegerMod.no_zero_divisors     — a field has no zero divisors
--   * IntegerMod.square_one_iff       — x² = 1 ⟹ x = 1 ∨ x = −1
--
-- The self-inverse fact is the geometric heart of Wilson: in F_p the
-- inversion involution fixes only ±1, so pulling 1 and −1 aside, the
-- remaining classes pair off with their (distinct) inverses and the
-- pairs collapse (List.product_one_of_paired_inverses), leaving
-- 1 · (−1) = −1.

module IntegerMod.wilson

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Natural.factorial
import Natural.prime
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.embedding
import Integer.ring
import Algebra.ring_lemmas
import Lists.list
import Lists.length
import Lists.map
import Lists.range
import Lists.permutation
import Lists.distinct
import Lists.pairing
import IntegerMod.basics
import IntegerMod.operations
import IntegerMod.ring
import IntegerMod.instances
import IntegerMod.field
import IntegerMod.representative
import IntegerMod.residues

-- ----------------------------------------------------------------------
-- The right zero law: x · 0 = 0. (There is no `ring` instance on
-- IntegerMod, so we read it off the Integer representative.)
theorem IntegerMod.multiply_zero (modulus : Natural) (x : IntegerMod(modulus))
        : x * IntegerMod.zero(modulus) = IntegerMod.zero(modulus) :=
  by_representatives x as a => {
      IntegerMod.make(modulus, a * Integer.zero)
          = IntegerMod.make(modulus, Integer.zero)
        by substituting (ring : a * Integer.zero = Integer.zero)
    }

-- ----------------------------------------------------------------------
-- Small additive-cancellation rearrangements, read off the integer
-- representative (where `ring` applies). `subtract_add_cancel`:
-- (x − c) + c = x; `add_subtract_cancel`: (x + c) − c = x.
theorem IntegerMod.subtract_add_cancel (modulus : Natural)
        (x c : IntegerMod(modulus))
        : (x - c) + c = x :=
  by_representatives x as a, c as b => {
      IntegerMod.make(modulus, a + -b + b) = IntegerMod.make(modulus, a)
        by substituting (ring : a + -b + b = a)
    }

theorem IntegerMod.add_subtract_cancel (modulus : Natural)
        (x c : IntegerMod(modulus))
        : (x + c) - c = x :=
  by_representatives x as a, c as b => {
      IntegerMod.make(modulus, a + b + -b) = IntegerMod.make(modulus, a)
        by substituting (ring : a + b + -b = a)
    }

-- 0 − c = −c.
theorem IntegerMod.zero_subtract (modulus : Natural) (c : IntegerMod(modulus))
        : IntegerMod.zero(modulus) - c = IntegerMod.negate(c) :=
  by_representatives c as b => {
      IntegerMod.make(modulus, Integer.zero + -b) = IntegerMod.make(modulus, -b)
        by substituting (ring : Integer.zero + -b = -b)
    }

-- ----------------------------------------------------------------------
-- A field has no zero divisors: if x ≠ 0 and x·y = 0 then y = 0.
-- Multiply the equation by an inverse of x:
--   y = 1·y = (x⁻¹·x)·y = x⁻¹·(x·y) = x⁻¹·0 = 0.
theorem IntegerMod.no_zero_divisors (p : Natural) (primality : Natural.is_prime(p))
        (x y : IntegerMod(p))
        (xNonzero : ¬(x = IntegerMod.zero(p)))
        (productZero : x * y = IntegerMod.zero(p))
        : y = IntegerMod.zero(p) := {
  ∃ (inverse : IntegerMod(p)). x * inverse = IntegerMod.one(p)
      by IntegerMod.nonzero_invertible;
  choose inverse such that x * inverse = IntegerMod.one(p);
  inverse * x
     = x * inverse
     = IntegerMod.one(p)                   as inverseLeft;
  y
     = IntegerMod.one(p) * y
     = (inverse * x) * y                   by substituting inverseLeft
     = inverse * (x * y)
     = inverse * IntegerMod.zero(p)        by substituting productZero
     = IntegerMod.zero(p)
}

-- ----------------------------------------------------------------------
-- Ring identity (true at the integer-representative level):
--   (x − 1)·(x + 1) = x·x − 1.
theorem IntegerMod.difference_of_squares (modulus : Natural) (x : IntegerMod(modulus))
        : (x - IntegerMod.one(modulus)) * (x + IntegerMod.one(modulus))
          = x * x - IntegerMod.one(modulus) :=
  by_representatives x as a => {
      IntegerMod.make(modulus, (a + -Integer.one) * (a + Integer.one))
          = IntegerMod.make(modulus, a * a + -Integer.one)
        by substituting
            (ring : (a + -Integer.one) * (a + Integer.one)
                = a * a + -Integer.one)
    }

-- x² = 1 ⟹ x = 1 ∨ x = −1 in F_p. Factor:
--   (x − 1)·(x + 1) = x² − 1 = 0,
-- so one of the factors is zero (no zero divisors), giving x = ±1.
theorem IntegerMod.square_one_iff (p : Natural) (primality : Natural.is_prime(p))
        (x : IntegerMod(p))
        (squareIsOne : x * x = IntegerMod.one(p))
        : x = IntegerMod.one(p) ∨ x = IntegerMod.negate(IntegerMod.one(p)) := {
  (x - IntegerMod.one(p)) * (x + IntegerMod.one(p))
     = x * x - IntegerMod.one(p)
     = IntegerMod.one(p) - IntegerMod.one(p)     by substituting squareIsOne
     = IntegerMod.zero(p)                        by IntegerMod.add_negate_right;
  done by cases {
    case x - IntegerMod.one(p) = IntegerMod.zero(p) as leftZero:
        x
           = (x - IntegerMod.one(p)) + IntegerMod.one(p)
           = IntegerMod.zero(p) + IntegerMod.one(p)    by substituting leftZero
           = IntegerMod.one(p)
    case x - IntegerMod.one(p) ≠ IntegerMod.zero(p) as leftNonzero: {
        x + IntegerMod.one(p) = IntegerMod.zero(p)
            by IntegerMod.no_zero_divisors as rightZero;
        x
           = (x + IntegerMod.one(p)) - IntegerMod.one(p)
           = IntegerMod.zero(p) - IntegerMod.one(p)    by substituting rightZero
           = IntegerMod.negate(IntegerMod.one(p))
    }
  }
}

-- ----------------------------------------------------------------------
-- (−1)·(−1) = 1, read off the integer representatives.
theorem IntegerMod.negate_one_multiply_negate_one (modulus : Natural)
        : IntegerMod.negate(IntegerMod.one(modulus))
              * IntegerMod.negate(IntegerMod.one(modulus))
          = IntegerMod.one(modulus) := {
  IntegerMod.make(modulus, -Integer.one * -Integer.one)
      = IntegerMod.make(modulus, Integer.one)
    by substituting (ring : -Integer.one * -Integer.one = Integer.one);
  done
}

-- ----------------------------------------------------------------------
-- The product of all the nonzero classes [n], …, [1] of F_p (p = 1 + top).
definition IntegerMod.residues_product (p top : Natural) : IntegerMod(p) :=
  List.product(IntegerMod(p), IntegerMod.multiply, IntegerMod.one(p),
      IntegerMod.residues_up_to(p, top))

-- The recursion in `1 + n` form: the top residue times the rest.
theorem IntegerMod.residues_product_one_plus (p n : Natural)
        : IntegerMod.residues_product(p, 1 + n)
          = IntegerMod.residue(p, 1 + n) * IntegerMod.residues_product(p, n) :=
  IntegerMod.residues_product(p, 1 + n)
     = List.product(IntegerMod(p), IntegerMod.multiply, IntegerMod.one(p),
           List.prepend(IntegerMod(p), IntegerMod.residue(p, 1 + n),
               IntegerMod.residues_up_to(p, n)))
           by substituting IntegerMod.residues_up_to_one_plus
     = IntegerMod.residue(p, 1 + n) * IntegerMod.residues_product(p, n)

-- ----------------------------------------------------------------------
-- The pairing behind Wilson: once the residue list is rearranged into
-- 1 :: −1 :: rest, every class z in `rest` keeps a partner inside `rest`:
-- its field inverse w. Indeed w ≠ 1 and w ≠ −1 (those invert 1 and −1,
-- which are not in `rest`), and w ≠ z (a self-inverse z would be ±1 by
-- square_one_iff — also not in `rest`).
theorem IntegerMod.wilson_pairing (p n : Natural)
        (primality : Natural.is_prime(p))
        (pEquation : p = 1 + n)
        (rest : List(IntegerMod(p)))
        (fullPermutation
            : List.Permutation(IntegerMod(p), IntegerMod.residues_up_to(p, n),
                  List.prepend(IntegerMod(p), IntegerMod.one(p),
                      List.prepend(IntegerMod(p),
                          IntegerMod.negate(IntegerMod.one(p)), rest))))
        (oneNotInRest : ¬(List.member(IntegerMod(p), IntegerMod.one(p), rest)))
        (negateOneNotInRest
            : ¬(List.member(IntegerMod(p),
                   IntegerMod.negate(IntegerMod.one(p)), rest)))
        : ∀ (z : IntegerMod(p)). List.member(IntegerMod(p), z, rest)
          → List.has_distinct_inverse_in(IntegerMod(p), IntegerMod.multiply,
                IntegerMod.one(p), rest, z) :=
  {
    take z : IntegerMod(p);
    suppose List.member(IntegerMod(p), z, rest) as zMemberRest;
    let minusOne : IntegerMod(p) := IntegerMod.negate(IntegerMod.one(p));
    List.member(IntegerMod(p), z,
              List.prepend(IntegerMod(p), IntegerMod.one(p),
                  List.prepend(IntegerMod(p), minusOne, rest)))
        by List.member.there(IntegerMod(p), z, IntegerMod.one(p),
               List.prepend(IntegerMod(p), minusOne, rest),
               List.member.there(IntegerMod(p), z, minusOne, rest, zMemberRest));
    List.Permutation(IntegerMod(p),
              List.prepend(IntegerMod(p), IntegerMod.one(p),
                  List.prepend(IntegerMod(p), minusOne, rest)),
              IntegerMod.residues_up_to(p, n))
        by List.Permutation.symmetric;
    List.member(IntegerMod(p), z, IntegerMod.residues_up_to(p, n))
        by List.Permutation.member_forward;
    z ≠ IntegerMod.zero(p)
        by IntegerMod.residues_member_nonzero;
    ∃ (w : IntegerMod(p)). z * w = IntegerMod.one(p)
        by IntegerMod.nonzero_invertible;
    choose w such that z * w = IntegerMod.one(p);
    w ≠ IntegerMod.zero(p)
        by {
            suppose w = IntegerMod.zero(p) as wZero;
            IntegerMod.zero(p)
               = z * IntegerMod.zero(p)
               = z * w                   by substituting wZero
               = IntegerMod.one(p);
            done by IntegerMod.zero_not_one
          };
    List.member(IntegerMod(p), w, IntegerMod.residues_up_to(p, n))
        by IntegerMod.residues_complete;
    List.member(IntegerMod(p), w,
              List.prepend(IntegerMod(p), IntegerMod.one(p),
                  List.prepend(IntegerMod(p), minusOne, rest)))
        by List.Permutation.member_forward;
    w ≠ IntegerMod.one(p)
        by {
            suppose w = IntegerMod.one(p) as wIsOne;
            z * IntegerMod.one(p) = IntegerMod.one(p)
                by substituting wIsOne as zTimesOneIsOne;
            z
               = z * IntegerMod.one(p)
               = IntegerMod.one(p)       by zTimesOneIsOne
               as zIsOne;
            List.member(IntegerMod(p), IntegerMod.one(p), rest)
                by substituting zIsOne;
            done
          };
    w ≠ minusOne
        by {
            suppose w = minusOne as wIsMinusOne;
            z * minusOne = IntegerMod.one(p)
                by substituting wIsMinusOne as zTimesMinusOne;
            minusOne * minusOne = IntegerMod.one(p) as minusOneSquare;
            z
               = z * IntegerMod.one(p)
               = z * (minusOne * minusOne)    by substituting minusOneSquare
               = (z * minusOne) * minusOne
               = IntegerMod.one(p) * minusOne by substituting zTimesMinusOne
               = minusOne
               as zIsMinusOne;
            List.member(IntegerMod(p), minusOne, rest)
                by substituting zIsMinusOne;
            done
          };
    w ≠ z
        by {
            suppose w = z as wIsZ;
            z * z
               = z * w
               = IntegerMod.one(p);
            z = IntegerMod.one(p) ∨ z = IntegerMod.negate(IntegerMod.one(p))
                by IntegerMod.square_one_iff;
            done by cases {
              case z = IntegerMod.one(p) as zIsOne: {
                  List.member(IntegerMod(p), IntegerMod.one(p), rest)
                      by substituting zIsOne;
                  done
                }
              case z = IntegerMod.negate(IntegerMod.one(p)) as zIsMinusOne: {
                  List.member(IntegerMod(p), minusOne, rest)
                      by substituting zIsMinusOne;
                  done
                }
            }
          };
    List.member(IntegerMod(p), w,
              List.prepend(IntegerMod(p), minusOne, rest))
        by List.member_of_prepend_not_head;
    List.member(IntegerMod(p), w, rest)
        by List.member_of_prepend_not_head;
    witness w with done
  }

-- ----------------------------------------------------------------------
-- Wilson's theorem in F_p: the product of all nonzero classes is −1.
theorem IntegerMod.wilson_product (p n : Natural)
        (primality : Natural.is_prime(p))
        (pEquation : p = 1 + n)
        (nAtLeastTwo : 2 ≤ n)
        : IntegerMod.residues_product(p, n)
          = IntegerMod.negate(IntegerMod.one(p)) := {
  let minusOne : IntegerMod(p) := IntegerMod.negate(IntegerMod.one(p));
  1 ≤ n by Natural.less_or_equal_predecessor_less_or_equal;
  List.member(IntegerMod(p), IntegerMod.one(p),
            IntegerMod.residues_up_to(p, n))
      by IntegerMod.one_member_residues;
  ∃ (afterOne : List(IntegerMod(p))).
            List.Permutation(IntegerMod(p), IntegerMod.residues_up_to(p, n),
                List.prepend(IntegerMod(p), IntegerMod.one(p), afterOne))
      by List.Permutation.extract;
  choose afterOne such that
      List.Permutation(IntegerMod(p), IntegerMod.residues_up_to(p, n),
          List.prepend(IntegerMod(p), IntegerMod.one(p), afterOne));
  List.member(IntegerMod(p), minusOne, IntegerMod.residues_up_to(p, n))
      by IntegerMod.negate_one_member_residues;
  List.member(IntegerMod(p), minusOne,
            List.prepend(IntegerMod(p), IntegerMod.one(p), afterOne))
      by List.Permutation.member_forward;
  minusOne ≠ IntegerMod.one(p)
      by {
          suppose minusOne = IntegerMod.one(p) as minusOneIsOne;
          IntegerMod.one(p)
             = IntegerMod.negate(IntegerMod.one(p)) by minusOneIsOne;
          done by IntegerMod.one_not_negate_one
        };
  List.member(IntegerMod(p), minusOne, afterOne)
      by List.member_of_prepend_not_head;
  ∃ (rest : List(IntegerMod(p))).
            List.Permutation(IntegerMod(p), afterOne,
                List.prepend(IntegerMod(p), minusOne, rest))
      by List.Permutation.extract;
  choose rest such that
      List.Permutation(IntegerMod(p), afterOne,
          List.prepend(IntegerMod(p), minusOne, rest));
  List.Permutation(IntegerMod(p),
            List.prepend(IntegerMod(p), IntegerMod.one(p), afterOne),
            List.prepend(IntegerMod(p), IntegerMod.one(p),
                List.prepend(IntegerMod(p), minusOne, rest)));
  List.Permutation(IntegerMod(p), IntegerMod.residues_up_to(p, n),
            List.prepend(IntegerMod(p), IntegerMod.one(p),
                List.prepend(IntegerMod(p), minusOne, rest)));
  List.Distinct(IntegerMod(p), IntegerMod.residues_up_to(p, n))
      by IntegerMod.residues_distinct;
  List.Distinct(IntegerMod(p),
            List.prepend(IntegerMod(p), IntegerMod.one(p),
                List.prepend(IntegerMod(p), minusOne, rest)))
      by List.Permutation.distinct_invariant;
  ¬(List.member(IntegerMod(p), IntegerMod.one(p),
             List.prepend(IntegerMod(p), minusOne, rest)))
      by List.Distinct.head_not_member;
  List.Distinct(IntegerMod(p), List.prepend(IntegerMod(p), minusOne, rest))
      by List.Distinct.tail_distinct;
  ¬(List.member(IntegerMod(p), minusOne, rest))
      by List.Distinct.head_not_member;
  List.Distinct(IntegerMod(p), rest)
      by List.Distinct.tail_distinct;
  ¬(List.member(IntegerMod(p), IntegerMod.one(p), rest))
      by {
          suppose List.member(IntegerMod(p), IntegerMod.one(p), rest) as oneInRest;
          List.member(IntegerMod(p), IntegerMod.one(p),
                    List.prepend(IntegerMod(p), minusOne, rest));
          done
        };
  (z : IntegerMod(p)) → List.member(IntegerMod(p), z, rest)
        → List.has_distinct_inverse_in(IntegerMod(p), IntegerMod.multiply,
              IntegerMod.one(p), rest, z)
      by IntegerMod.wilson_pairing;
  ∀ (a b c : IntegerMod(p)). (a * b) * c = a * (b * c)
      by IntegerMod.multiply_associative;
  ∀ (a b : IntegerMod(p)). a * b = b * a
      by IntegerMod.multiply_commutative;
  ∀ (a : IntegerMod(p)). IntegerMod.one(p) * a = a
      by IntegerMod.multiply_identity_left;
  List.product(IntegerMod(p), IntegerMod.multiply, IntegerMod.one(p), rest)
        = IntegerMod.one(p)
      by List.product_one_of_paired_inverses as restProductOne;
  IntegerMod.residues_product(p, n)
        = List.product(IntegerMod(p), IntegerMod.multiply, IntegerMod.one(p),
              List.prepend(IntegerMod(p), IntegerMod.one(p),
                  List.prepend(IntegerMod(p), minusOne, rest)))
      by List.Permutation.product_invariant as productPermutation;
  IntegerMod.residues_product(p, n)
     = List.product(IntegerMod(p), IntegerMod.multiply, IntegerMod.one(p),
           List.prepend(IntegerMod(p), IntegerMod.one(p),
               List.prepend(IntegerMod(p), minusOne, rest)))
           by productPermutation
     = IntegerMod.one(p) * (minusOne
           * List.product(IntegerMod(p), IntegerMod.multiply,
                 IntegerMod.one(p), rest))
     = IntegerMod.one(p) * (minusOne * IntegerMod.one(p))
           by substituting restProductOne
     = minusOne * IntegerMod.one(p)
     = minusOne
}

-- ----------------------------------------------------------------------
-- The residue product is the class of the factorial: [n]·[n−1]⋯[1] = [n!].
theorem IntegerMod.residues_product_is_factorial (p top : Natural)
        : IntegerMod.residues_product(p, top)
          = IntegerMod.make(p, (top! : Integer)) :=
  by induction on top with IH {
    case top = 0:
        IntegerMod.residues_product(p, 0)
           = IntegerMod.make(p, (0! : Integer))
    case top = 1 + predecessor for some predecessor: {
        (((1 + predecessor) * predecessor! : Natural) : Integer)
              = ((1 + predecessor) : Integer) * (predecessor! : Integer) as castProduct;
        IntegerMod.residues_product(p, 1 + predecessor)
           = IntegerMod.residue(p, 1 + predecessor)
                 * IntegerMod.residues_product(p, predecessor)
                 by IntegerMod.residues_product_one_plus
           = IntegerMod.residue(p, 1 + predecessor)
                 * IntegerMod.make(p, (predecessor! : Integer))
                 by substituting IH
           = IntegerMod.make(p, (1 + predecessor : Integer)
                 * (predecessor! : Integer))
           = IntegerMod.make(p,
                 (((1 + predecessor) * predecessor!
                     : Natural) : Integer))
                 by substituting castProduct
           = IntegerMod.make(p, ((1 + predecessor)! : Integer))
                 by substituting Natural.factorial_add_one
      }
  }

-- ----------------------------------------------------------------------
-- Wilson's theorem: for a prime p = 1 + n with n ≥ 2, n! ≡ −1 (mod p).
theorem IntegerMod.wilson (p n : Natural)
        (primality : Natural.is_prime(p))
        (pEquation : p = 1 + n)
        (nAtLeastTwo : 2 ≤ n)
        : IntegerMod.make(p, (n! : Integer))
          = IntegerMod.negate(IntegerMod.one(p)) := {
  IntegerMod.residues_product(p, n)
        = IntegerMod.make(p, (n! : Integer));
  IntegerMod.residues_product(p, n) = IntegerMod.negate(IntegerMod.one(p));
  IntegerMod.make(p, (n! : Integer))
     = IntegerMod.residues_product(p, n)
     = IntegerMod.negate(IntegerMod.one(p))
}

-- The same statement as an Integer divisibility: p ∣ n! + 1.
theorem Natural.wilson_divides (p n : Natural)
        (primality : Natural.is_prime(p))
        (pEquation : p = 1 + n)
        (nAtLeastTwo : 2 ≤ n)
        : Integer.divides((p : Integer),
              (n! : Integer) + Integer.one) := {
  IntegerMod.make(p, (n! : Integer))
     = IntegerMod.negate(IntegerMod.one(p))
     = IntegerMod.make(p, -Integer.one);
  Integer.CongruentModulo(p, (n! : Integer), -Integer.one) as congruent;
  choose quotient such that
      (n! : Integer) - (-Integer.one) = (p : Integer) * quotient
      as differenceEquation from congruent;
  witness quotient with
      (n! : Integer) + Integer.one
         = (n! : Integer) - (-Integer.one)
         = (p : Integer) * quotient                            by differenceEquation
}

-- Wilson's theorem for every prime (Freek #51, forward direction):
-- p ∣ (p−1)! + 1. The pairing argument above needs p ≥ 3; the one
-- remaining prime is p = 2, where 1! + 1 = 2 = p directly.
theorem Natural.wilson (p n : Natural)
        (primality : Natural.is_prime(p))
        (pEquation : p = 1 + n)
        : Integer.divides((p : Integer),
              (n! : Integer) + Integer.one) :=
  done by cases {
    case n = 0: {
        -- n = 0 would make p = 1, which is not prime.
        2 ≤ p;
        2 ≤ 1 + 0 by substituting pEquation;
        2 ≤ 1 by substituting (1 + 0 = 1);
        False as impossible;
        absurd(impossible)
      }
    case n = 1 + m for some m:
        done by cases {
          case m = 0: {
              -- p = 2: 1! + 1 = 2 divides itself.
              ((1 + 1 : Natural) : Integer)
                    = ((1 : Natural) : Integer) + ((1 : Natural) : Integer);
              (p : Integer)
                 = ((1 + 1 : Natural) : Integer)
                 = ((1 : Natural) : Integer) + ((1 : Natural) : Integer)
                 = Integer.one + Integer.one
                 as castP;
              witness Integer.one with
                  (1! : Integer) + Integer.one
                     = ((1 : Natural) : Integer) + Integer.one
                     = (Integer.one + Integer.one) * Integer.one        by ring
                     = (p : Integer) * Integer.one                      by substituting castP
            }
          case m = 1 + k for some k: {
              -- n = 2 + k ≥ 2: the pairing argument applies.
              1 ≤ 1 + k;
              2 ≤ 1 + (1 + k);
              done by Natural.wilson_divides
            }
        }
  }

-- The divisor analysis behind the converse of Wilson's theorem: when
-- p = 1 + n divides n! + 1, a divisor of p other than p itself is at most
-- n, hence divides both n! and (through p) n! + 1, forcing it to be 1.
theorem Natural.divisor_one_or_self_of_divides_factorial_plus_one
        (p n : Natural)
        (pEquation : p = 1 + n)
        (pAtLeastTwo : 2 ≤ p)
        (wilsonDivides : Natural.divides(p, n! + 1))
        (divisor : Natural) (dividesP : divisor ∣ p)
        : divisor = 1 ∨ divisor = p := {
  divisor = p ∨ ¬(divisor = p);
  done by cases {
    case divisor = p as isP: done
    case divisor ≠ p as notP: {
        p = 0 ∨ divisor ≤ p;
        done by cases {
          case p = 0 as pZero: {
              2 ≤ 0 by substituting pZero;
              False as impossible;
              absurd(impossible)
            }
          case divisor ≤ p as divisorAtMostP: {
              divisor
                 ≤ p             by divisorAtMostP
                 = 1 + n;
              divisor ≠ 1 + n
                  by {
                      suppose divisor = 1 + n as isTop;
                      divisor
                         = 1 + n
                         = p;
                      done
                    };
              divisor ≤ n
                  by Natural.le_of_le_one_plus_of_ne;
              divisor ≠ 0
                  by {
                      suppose divisor = 0 as isZero;
                      choose quotient such that p = divisor * quotient from dividesP;
                      p
                         = divisor * quotient
                         = 0 * quotient   by substituting isZero
                         = 0
                         as pZero;
                      2 ≤ 0 by substituting pZero;
                      done
                    };
              1 ≤ divisor;
              divisor ∣ n! + 1;
              divisor = 1
                  by Natural.small_divisor_of_factorial_plus_one_is_one;
              done
            }
        }
      }
  }
}

-- The converse of Wilson's theorem: if p = 1 + n (n ≥ 1) divides n! + 1,
-- then p is prime. Together with `Natural.wilson` this characterises the
-- primes ≥ 2 by the Wilson congruence, completing Freek #51.
theorem Natural.prime_of_divides_factorial_plus_one (p n : Natural)
        (pEquation : p = 1 + n) (nPositive : 1 ≤ n)
        (wilsonDivides : Natural.divides(p, n! + 1))
        : Natural.is_prime(p) := {
  1 + 1 ≤ 1 + n as oneAddOne;
  (2 : Natural)
     = 1 + 1
     ≤ 1 + n   by oneAddOne
     = p;
  ∀ (divisor : Natural). divisor ∣ p → divisor = 1 ∨ divisor = p
      by {
          take divisor : Natural;
          suppose divisor ∣ p as dividesP;
          done
        };
  done
}

-- ----------------------------------------------------------------------
-- Two more field facts, both inverses of `no_zero_divisors` in spirit:
-- a product of nonzero classes is nonzero, and a nonzero class cancels
-- from both sides of an equation.

theorem IntegerMod.multiply_nonzero (p : Natural)
        (primality : Natural.is_prime(p))
        (x y : IntegerMod(p))
        (xNonzero : ¬(x = IntegerMod.zero(p)))
        (yNonzero : ¬(y = IntegerMod.zero(p)))
        : x * y ≠ IntegerMod.zero(p) := {
  suppose x * y = IntegerMod.zero(p) as productZero;
  y = IntegerMod.zero(p);
  done
}

-- Cancel a nonzero factor: c·u = c·v implies u = v (multiply by c⁻¹).
theorem IntegerMod.multiply_cancel_left (p : Natural)
        (primality : Natural.is_prime(p))
        (c u v : IntegerMod(p))
        (cNonzero : ¬(c = IntegerMod.zero(p)))
        (equation : c * u = c * v)
        : u = v := {
  ∃ (inverse : IntegerMod(p)). c * inverse = IntegerMod.one(p)
      by IntegerMod.nonzero_invertible;
  choose inverse such that c * inverse = IntegerMod.one(p);
  inverse * c
     = c * inverse
     = IntegerMod.one(p)        as inverseLeft;
  u
     = IntegerMod.one(p) * u
     = (inverse * c) * u        by substituting inverseLeft
     = inverse * (c * u)
     = inverse * (c * v)        by substituting equation
     = (inverse * c) * v
     = IntegerMod.one(p) * v    by substituting inverseLeft
     = v
}

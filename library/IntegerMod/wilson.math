-- IntegerMod/wilson.math
--
-- Wilson's theorem: for an odd prime p (written p = 1 + n), the product
-- of all nonzero classes of F_p is −1, hence n! ≡ −1 (mod p), hence
-- p ∣ n! + 1. The field facts that drive it:
--
--   * IntegerMod.multiply_zero        — x · 0 = 0 (the right zero law)
--   * IntegerMod.no_zero_divisors     — a field has no zero divisors
--   * IntegerMod.square_one_iff       — x² = 1 ⟹ x = 1 ∨ x = −1
--
-- The self-inverse fact is the geometric heart of Wilson: in F_p the
-- inversion involution fixes only ±1, so pulling 1 and −1 aside, the
-- remaining classes pair off with their (distinct) inverses and the
-- pairs collapse (List.product_one_of_paired_inverses), leaving
-- 1 · (−1) = −1.

module IntegerMod.wilson

import Logic.basics
import Logic.exists
import Logic.quotient
import Equality.basics
import Natural.basics
import Natural.arithmetic
import Natural.order
import Natural.add_order
import Natural.factorial
import Natural.prime
import Integer.basics
import Integer.addition
import Integer.multiplication
import Integer.negation
import Integer.embedding
import Integer.ring
import Algebra.ring_lemmas
import Lists.list
import Lists.length
import Lists.map
import Lists.range
import Lists.permutation
import Lists.distinct
import Lists.pairing
import IntegerMod.basics
import IntegerMod.operations
import IntegerMod.ring
import IntegerMod.instances
import IntegerMod.field
import IntegerMod.representative
import IntegerMod.residues

-- ----------------------------------------------------------------------
-- The right zero law: x · 0 = 0. (There is no `ring` instance on
-- IntegerMod, so we read it off the Integer representative.)
theorem IntegerMod.multiply_zero (modulus : Natural) (x : IntegerMod(modulus))
        : x * IntegerMod.zero(modulus) = IntegerMod.zero(modulus) :=
  by_representatives x as a =>
    claim IntegerMod.make(modulus, a * Integer.zero)
        = IntegerMod.make(modulus, Integer.zero)
      by substituting (ring : a * Integer.zero = Integer.zero)

-- ----------------------------------------------------------------------
-- Small additive-cancellation rearrangements, read off the integer
-- representative (where `ring` applies). `subtract_add_cancel`:
-- (x − c) + c = x; `add_subtract_cancel`: (x + c) − c = x.
theorem IntegerMod.subtract_add_cancel (modulus : Natural)
        (x c : IntegerMod(modulus))
        : (x - c) + c = x :=
  by_representatives x as a, c as b =>
    claim IntegerMod.make(modulus, a + -b + b) = IntegerMod.make(modulus, a)
      by substituting (ring : a + -b + b = a)

theorem IntegerMod.add_subtract_cancel (modulus : Natural)
        (x c : IntegerMod(modulus))
        : (x + c) - c = x :=
  by_representatives x as a, c as b =>
    claim IntegerMod.make(modulus, a + b + -b) = IntegerMod.make(modulus, a)
      by substituting (ring : a + b + -b = a)

-- 0 − c = −c.
theorem IntegerMod.zero_subtract (modulus : Natural) (c : IntegerMod(modulus))
        : IntegerMod.zero(modulus) - c = IntegerMod.negate(c) :=
  by_representatives c as b =>
    claim IntegerMod.make(modulus, Integer.zero + -b) = IntegerMod.make(modulus, -b)
      by substituting (ring : Integer.zero + -b = -b)

-- ----------------------------------------------------------------------
-- A field has no zero divisors: if x ≠ 0 and x·y = 0 then y = 0.
-- Multiply the equation by an inverse of x:
--   y = 1·y = (x⁻¹·x)·y = x⁻¹·(x·y) = x⁻¹·0 = 0.
theorem IntegerMod.no_zero_divisors (p : Natural) (primality : Natural.is_prime(p))
        (x y : IntegerMod(p))
        (xNonzero : ¬(x = IntegerMod.zero(p)))
        (productZero : x * y = IntegerMod.zero(p))
        : y = IntegerMod.zero(p) := {
  obtain ⟨inverse, inverseEquation⟩
      from IntegerMod.nonzero_invertible(p, primality, x, xNonzero);
  -- inverseEquation : x · inverse = one. Commute to inverse · x = one.
  claim inverseLeft : inverse * x = IntegerMod.one(p)
      by calc inverse * x
            = x * inverse           by IntegerMod.multiply_commutative
            = IntegerMod.one(p);
  calc y
     = IntegerMod.one(p) * y               by IntegerMod.multiply_identity_left
     = (inverse * x) * y                   by substituting inverseLeft
     = inverse * (x * y)                   by IntegerMod.multiply_associative
     = inverse * IntegerMod.zero(p)        by substituting productZero
     = IntegerMod.zero(p)                  by IntegerMod.multiply_zero
}

-- ----------------------------------------------------------------------
-- Ring identity (true at the integer-representative level):
--   (x − 1)·(x + 1) = x·x − 1.
theorem IntegerMod.difference_of_squares (modulus : Natural) (x : IntegerMod(modulus))
        : (x - IntegerMod.one(modulus)) * (x + IntegerMod.one(modulus))
          = x * x - IntegerMod.one(modulus) :=
  by_representatives x as a =>
    claim IntegerMod.make(modulus, (a + -Integer.one) * (a + Integer.one))
        = IntegerMod.make(modulus, a * a + -Integer.one)
      by substituting
          (ring : (a + -Integer.one) * (a + Integer.one)
              = a * a + -Integer.one)

-- x² = 1 ⟹ x = 1 ∨ x = −1 in F_p. Factor:
--   (x − 1)·(x + 1) = x² − 1 = 0,
-- so one of the factors is zero (no zero divisors), giving x = ±1.
theorem IntegerMod.square_one_iff (p : Natural) (primality : Natural.is_prime(p))
        (x : IntegerMod(p))
        (squareIsOne : x * x = IntegerMod.one(p))
        : x = IntegerMod.one(p) ∨ x = IntegerMod.negate(IntegerMod.one(p)) := {
  -- Using x·x = 1, the difference of squares is 1 − 1 = 0.
  claim factorsZero
      : (x - IntegerMod.one(p)) * (x + IntegerMod.one(p)) = IntegerMod.zero(p)
      by calc (x - IntegerMod.one(p)) * (x + IntegerMod.one(p))
            = x * x - IntegerMod.one(p)                 by IntegerMod.difference_of_squares
            = IntegerMod.one(p) - IntegerMod.one(p)     by substituting squareIsOne
            = IntegerMod.zero(p)                        by IntegerMod.add_negate_right;
  -- A product is zero, so one factor is zero. Case-split classically on
  -- whether the left factor x − 1 vanishes.
  claim by cases {
    in (x - IntegerMod.one(p) = IntegerMod.zero(p)) as leftZero:
        -- x − 1 = 0 ⟹ x = 1 (add 1 back).
        Or.introduceLeft(
            calc x
               = (x - IntegerMod.one(p)) + IntegerMod.one(p)
                     by IntegerMod.subtract_add_cancel
               = IntegerMod.zero(p) + IntegerMod.one(p)
                     by substituting leftZero
               = IntegerMod.one(p)
                     by IntegerMod.add_identity_left)
    in (Not(x - IntegerMod.one(p) = IntegerMod.zero(p))) as leftNonzero: {
        -- x − 1 ≠ 0, so the other factor x + 1 must vanish (no zero
        -- divisors), giving x = −1.
        claim rightZero : x + IntegerMod.one(p) = IntegerMod.zero(p)
            by IntegerMod.no_zero_divisors(p, primality,
                   x - IntegerMod.one(p), x + IntegerMod.one(p),
                   leftNonzero, factorsZero);
        Or.introduceRight(
            calc x
               = (x + IntegerMod.one(p)) - IntegerMod.one(p)
                     by IntegerMod.add_subtract_cancel
               = IntegerMod.zero(p) - IntegerMod.one(p)
                     by substituting rightZero
               = IntegerMod.negate(IntegerMod.one(p))
                     by IntegerMod.zero_subtract)
    }
  }
}

-- ----------------------------------------------------------------------
-- (−1)·(−1) = 1, read off the integer representatives.
theorem IntegerMod.negate_one_multiply_negate_one (modulus : Natural)
        : IntegerMod.negate(IntegerMod.one(modulus))
              * IntegerMod.negate(IntegerMod.one(modulus))
          = IntegerMod.one(modulus) := {
  claim IntegerMod.make(modulus, -Integer.one * -Integer.one)
      = IntegerMod.make(modulus, Integer.one)
    by substituting (ring : -Integer.one * -Integer.one = Integer.one);
  done
}

-- ----------------------------------------------------------------------
-- The product of all the nonzero classes [n], …, [1] of F_p (p = 1 + top).
definition IntegerMod.residues_product (p top : Natural) : IntegerMod(p) :=
  List.product(IntegerMod(p), IntegerMod.multiply, IntegerMod.one(p),
      IntegerMod.residues_up_to(p, top))

-- ----------------------------------------------------------------------
-- The pairing behind Wilson: once the residue list is rearranged into
-- 1 :: −1 :: rest, every class z in `rest` keeps a partner inside `rest`:
-- its field inverse w. Indeed w ≠ 1 and w ≠ −1 (those invert 1 and −1,
-- which are not in `rest`), and w ≠ z (a self-inverse z would be ±1 by
-- square_one_iff — also not in `rest`).
theorem IntegerMod.wilson_pairing (p n : Natural)
        (primality : Natural.is_prime(p))
        (pEquation : p = 1 + n)
        (rest : List(IntegerMod(p)))
        (fullPermutation
            : List.Permutation(IntegerMod(p), IntegerMod.residues_up_to(p, n),
                  List.prepend(IntegerMod(p), IntegerMod.one(p),
                      List.prepend(IntegerMod(p),
                          IntegerMod.negate(IntegerMod.one(p)), rest))))
        (oneNotInRest : ¬(List.member(IntegerMod(p), IntegerMod.one(p), rest)))
        (negateOneNotInRest
            : ¬(List.member(IntegerMod(p),
                   IntegerMod.negate(IntegerMod.one(p)), rest)))
        : (z : IntegerMod(p)) → List.member(IntegerMod(p), z, rest)
          → List.has_distinct_inverse_in(IntegerMod(p), IntegerMod.multiply,
                IntegerMod.one(p), rest, z) :=
  (z : IntegerMod(p)) (zMemberRest : List.member(IntegerMod(p), z, rest)) ↦ {
    let minusOne : IntegerMod(p) := IntegerMod.negate(IntegerMod.one(p));
    -- z is a nonzero class, so it has a field inverse w, also nonzero.
    claim List.member(IntegerMod(p), z,
              List.prepend(IntegerMod(p), IntegerMod.one(p),
                  List.prepend(IntegerMod(p), minusOne, rest)))
        by List.member.there(IntegerMod(p), z, IntegerMod.one(p),
               List.prepend(IntegerMod(p), minusOne, rest),
               List.member.there(IntegerMod(p), z, minusOne, rest, zMemberRest));
    claim List.Permutation(IntegerMod(p),
              List.prepend(IntegerMod(p), IntegerMod.one(p),
                  List.prepend(IntegerMod(p), minusOne, rest)),
              IntegerMod.residues_up_to(p, n))
        by List.Permutation.symmetric;
    claim List.member(IntegerMod(p), z, IntegerMod.residues_up_to(p, n))
        by List.Permutation.member_forward;
    claim ¬(z = IntegerMod.zero(p))
        by IntegerMod.residues_member_nonzero;
    obtain ⟨w, zTimesWIsOne⟩ by IntegerMod.nonzero_invertible;
    claim ¬(w = IntegerMod.zero(p))
        by (wZero : w = IntegerMod.zero(p)) ↦ {
            claim IntegerMod.one(p) = IntegerMod.zero(p)
                by calc IntegerMod.one(p)
                      = z * w                   by zTimesWIsOne
                      = z * IntegerMod.zero(p)  by substituting wZero
                      = IntegerMod.zero(p)      by IntegerMod.multiply_zero(p, z);
            claim IntegerMod.zero(p) = IntegerMod.one(p)
                by calc IntegerMod.zero(p) = IntegerMod.one(p)
                      by (IntegerMod.one(p) = IntegerMod.zero(p));
            claim False by IntegerMod.zero_not_one;
            done
          };
    -- So w is itself on the residue list, hence in 1 :: −1 :: rest.
    claim List.member(IntegerMod(p), w, IntegerMod.residues_up_to(p, n))
        by IntegerMod.residues_complete;
    claim List.member(IntegerMod(p), w,
              List.prepend(IntegerMod(p), IntegerMod.one(p),
                  List.prepend(IntegerMod(p), minusOne, rest)))
        by List.Permutation.member_forward;
    -- w ≠ 1: otherwise z = z·1 = 1, but 1 ∉ rest.
    claim ¬(w = IntegerMod.one(p))
        by (wIsOne : w = IntegerMod.one(p)) ↦ {
            claim zTimesOneIsOne : z * IntegerMod.one(p) = IntegerMod.one(p)
                by substituting wIsOne;
            claim zIsOne : z = IntegerMod.one(p)
                by calc z
                      = z * IntegerMod.one(p)   by IntegerMod.multiply_identity_right(p, z)
                      = IntegerMod.one(p)       by zTimesOneIsOne;
            claim oneMemberRest
                : List.member(IntegerMod(p), IntegerMod.one(p), rest)
                by substituting zIsOne;
            oneNotInRest(oneMemberRest)
          };
    -- w ≠ −1: otherwise z = z·(−1)·(−1) = 1·(−1) = −1, but −1 ∉ rest.
    claim ¬(w = minusOne)
        by (wIsMinusOne : w = minusOne) ↦ {
            claim zTimesMinusOne : z * minusOne = IntegerMod.one(p)
                by substituting wIsMinusOne;
            claim minusOneSquare : minusOne * minusOne = IntegerMod.one(p)
                by IntegerMod.negate_one_multiply_negate_one;
            claim zIsMinusOne : z = minusOne
                by calc z
                      = z * IntegerMod.one(p)
                            by IntegerMod.multiply_identity_right(p, z)
                      = z * (minusOne * minusOne)
                            by substituting minusOneSquare
                      = (z * minusOne) * minusOne
                            by IntegerMod.multiply_associative(p, z, minusOne, minusOne)
                      = IntegerMod.one(p) * minusOne
                            by substituting zTimesMinusOne
                      = minusOne
                            by IntegerMod.multiply_identity_left(p, minusOne);
            claim minusOneMemberRest : List.member(IntegerMod(p), minusOne, rest)
                by substituting zIsMinusOne;
            negateOneNotInRest(minusOneMemberRest)
          };
    -- w ≠ z: a self-paired z would satisfy z² = 1, i.e. z = ±1 — not in rest.
    claim wNotZ : ¬(w = z)
        by (wIsZ : w = z) ↦ {
            claim z * z = IntegerMod.one(p) by rewrite(wIsZ, zTimesWIsOne);
            claim zSelfInverse
                : z = IntegerMod.one(p) ∨ z = IntegerMod.negate(IntegerMod.one(p))
                by IntegerMod.square_one_iff;
            cases zSelfInverse {
              | Or.introduceLeft(zIsOne) => {
                  claim oneMemberRest
                      : List.member(IntegerMod(p), IntegerMod.one(p), rest)
                      by substituting zIsOne;
                  oneNotInRest(oneMemberRest)
                }
              | Or.introduceRight(zIsMinusOne) => {
                  claim minusOneMemberRest
                      : List.member(IntegerMod(p), minusOne, rest)
                      by substituting zIsMinusOne;
                  negateOneNotInRest(minusOneMemberRest)
                }
            }
          };
    -- So w sits in rest, and is the required distinct inverse of z.
    claim List.member(IntegerMod(p), w,
              List.prepend(IntegerMod(p), minusOne, rest))
        by List.member_of_prepend_not_head;
    claim wMemberRest : List.member(IntegerMod(p), w, rest)
        by List.member_of_prepend_not_head;
    witness w with
        And.introduction(wMemberRest, And.introduction(zTimesWIsOne, wNotZ))
  }

-- ----------------------------------------------------------------------
-- Wilson's theorem in F_p: the product of all nonzero classes is −1.
theorem IntegerMod.wilson_product (p n : Natural)
        (primality : Natural.is_prime(p))
        (pEquation : p = 1 + n)
        (nAtLeastTwo : 2 ≤ n)
        : IntegerMod.residues_product(p, n)
          = IntegerMod.negate(IntegerMod.one(p)) := {
  let minusOne : IntegerMod(p) := IntegerMod.negate(IntegerMod.one(p));
  claim 1 ≤ n by Natural.less_or_equal_predecessor_less_or_equal;
  -- Pull the class 1 to the front of the residue list…
  claim oneMember
      : List.member(IntegerMod(p), IntegerMod.one(p),
            IntegerMod.residues_up_to(p, n))
      by IntegerMod.one_member_residues;
  obtain ⟨afterOne, oneExtracted⟩
      from List.Permutation.extract(IntegerMod(p), IntegerMod.one(p),
               IntegerMod.residues_up_to(p, n), oneMember);
  -- …then −1 (a different class, since p ≥ 3) to the front of the rest.
  claim List.member(IntegerMod(p), minusOne, IntegerMod.residues_up_to(p, n))
      by IntegerMod.negate_one_member_residues;
  claim List.member(IntegerMod(p), minusOne,
            List.prepend(IntegerMod(p), IntegerMod.one(p), afterOne))
      by List.Permutation.member_forward;
  claim ¬(minusOne = IntegerMod.one(p))
      by (minusOneIsOne : minusOne = IntegerMod.one(p)) ↦ {
          claim IntegerMod.one(p) = IntegerMod.negate(IntegerMod.one(p))
              by calc IntegerMod.one(p)
                    = IntegerMod.negate(IntegerMod.one(p)) by minusOneIsOne;
          claim False by IntegerMod.one_not_negate_one;
          done
        };
  claim minusOneInAfterOne : List.member(IntegerMod(p), minusOne, afterOne)
      by List.member_of_prepend_not_head;
  obtain ⟨rest, minusOneExtracted⟩
      from List.Permutation.extract(IntegerMod(p), minusOne, afterOne,
               minusOneInAfterOne);
  -- Together: the residues permute to 1 :: −1 :: rest.
  claim List.Permutation(IntegerMod(p), IntegerMod.residues_up_to(p, n),
            List.prepend(IntegerMod(p), IntegerMod.one(p),
                List.prepend(IntegerMod(p), minusOne, rest)))
      by List.Permutation.transitive(IntegerMod(p),
             IntegerMod.residues_up_to(p, n),
             List.prepend(IntegerMod(p), IntegerMod.one(p), afterOne),
             List.prepend(IntegerMod(p), IntegerMod.one(p),
                 List.prepend(IntegerMod(p), minusOne, rest)),
             oneExtracted,
             List.Permutation.skip(IntegerMod(p), IntegerMod.one(p), afterOne,
                 List.prepend(IntegerMod(p), minusOne, rest),
                 minusOneExtracted));
  -- Distinctness travels along the permutation, so 1 and −1 do not recur.
  claim List.Distinct(IntegerMod(p), IntegerMod.residues_up_to(p, n))
      by IntegerMod.residues_distinct;
  claim List.Distinct(IntegerMod(p),
            List.prepend(IntegerMod(p), IntegerMod.one(p),
                List.prepend(IntegerMod(p), minusOne, rest)))
      by List.Permutation.distinct_invariant;
  claim oneNotInMinusOneRest
      : ¬(List.member(IntegerMod(p), IntegerMod.one(p),
             List.prepend(IntegerMod(p), minusOne, rest)))
      by List.Distinct.head_not_member;
  claim List.Distinct(IntegerMod(p), List.prepend(IntegerMod(p), minusOne, rest))
      by List.Distinct.tail_distinct;
  claim ¬(List.member(IntegerMod(p), minusOne, rest))
      by List.Distinct.head_not_member;
  claim List.Distinct(IntegerMod(p), rest)
      by List.Distinct.tail_distinct;
  claim ¬(List.member(IntegerMod(p), IntegerMod.one(p), rest))
      by (oneInRest : List.member(IntegerMod(p), IntegerMod.one(p), rest)) ↦
          oneNotInMinusOneRest(
              List.member.there(IntegerMod(p), IntegerMod.one(p), minusOne,
                  rest, oneInRest));
  -- The remaining classes pair off with their inverses and collapse to 1.
  claim (z : IntegerMod(p)) → List.member(IntegerMod(p), z, rest)
        → List.has_distinct_inverse_in(IntegerMod(p), IntegerMod.multiply,
              IntegerMod.one(p), rest, z)
      by (z : IntegerMod(p))
         (zMemberRest : List.member(IntegerMod(p), z, rest)) ↦ {
           done by IntegerMod.wilson_pairing
         };
  claim restProductOne
      : List.product(IntegerMod(p), IntegerMod.multiply, IntegerMod.one(p), rest)
        = IntegerMod.one(p)
      by List.product_one_of_paired_inverses
         recalling IntegerMod.multiply_associative(p),
             IntegerMod.multiply_commutative(p),
             IntegerMod.multiply_identity_left(p);
  -- Multiply everything back together: 1 · (−1) · 1 = −1.
  claim productPermutation
      : IntegerMod.residues_product(p, n)
        = List.product(IntegerMod(p), IntegerMod.multiply, IntegerMod.one(p),
              List.prepend(IntegerMod(p), IntegerMod.one(p),
                  List.prepend(IntegerMod(p), minusOne, rest)))
      by List.Permutation.product_invariant
         recalling IntegerMod.multiply_associative(p),
             IntegerMod.multiply_commutative(p);
  calc IntegerMod.residues_product(p, n)
     = List.product(IntegerMod(p), IntegerMod.multiply, IntegerMod.one(p),
           List.prepend(IntegerMod(p), IntegerMod.one(p),
               List.prepend(IntegerMod(p), minusOne, rest)))
           by productPermutation
     = IntegerMod.one(p) * (minusOne
           * List.product(IntegerMod(p), IntegerMod.multiply,
                 IntegerMod.one(p), rest))
     = IntegerMod.one(p) * (minusOne * IntegerMod.one(p))
           by substituting restProductOne
     = minusOne * IntegerMod.one(p)
           by IntegerMod.multiply_identity_left(p, minusOne * IntegerMod.one(p))
     = minusOne
           by IntegerMod.multiply_identity_right(p, minusOne)
}

-- ----------------------------------------------------------------------
-- The residue product is the class of the factorial: [n]·[n−1]⋯[1] = [n!].
theorem IntegerMod.residues_product_is_factorial (p top : Natural)
        : IntegerMod.residues_product(p, top)
          = IntegerMod.make(p, (Natural.factorial(top) : Integer)) :=
  by_induction on top with IH {
    case zero:
        -- Both sides are the class of 1.
        calc IntegerMod.residues_product(p, 0)
           = IntegerMod.make(p, (Natural.factorial(0) : Integer))
    case successor(predecessor):
        calc IntegerMod.residues_product(p, successor(predecessor))
           = IntegerMod.residue(p, successor(predecessor))
                 * IntegerMod.residues_product(p, predecessor)
           = IntegerMod.residue(p, successor(predecessor))
                 * IntegerMod.make(p, (Natural.factorial(predecessor) : Integer))
                 by substituting IH
           = IntegerMod.make(p, (successor(predecessor) : Integer)
                 * (Natural.factorial(predecessor) : Integer))
           = IntegerMod.make(p,
                 ((successor(predecessor) * Natural.factorial(predecessor)
                     : Natural) : Integer))
                 by Natural.to_integer.multiply_preserves(successor(predecessor),
                        Natural.factorial(predecessor))
           = IntegerMod.make(p, (Natural.factorial(successor(predecessor)) : Integer))
  }

-- ----------------------------------------------------------------------
-- Wilson's theorem: for a prime p = 1 + n with n ≥ 2, n! ≡ −1 (mod p).
theorem IntegerMod.wilson (p n : Natural)
        (primality : Natural.is_prime(p))
        (pEquation : p = 1 + n)
        (nAtLeastTwo : 2 ≤ n)
        : IntegerMod.make(p, (Natural.factorial(n) : Integer))
          = IntegerMod.negate(IntegerMod.one(p)) :=
  calc IntegerMod.make(p, (Natural.factorial(n) : Integer))
     = IntegerMod.residues_product(p, n)
           by IntegerMod.residues_product_is_factorial(p, n)
     = IntegerMod.negate(IntegerMod.one(p))
           by IntegerMod.wilson_product(p, n, primality, pEquation, nAtLeastTwo)

-- The same statement as an Integer divisibility: p ∣ n! + 1.
theorem Natural.wilson_divides (p n : Natural)
        (primality : Natural.is_prime(p))
        (pEquation : p = 1 + n)
        (nAtLeastTwo : 2 ≤ n)
        : Integer.divides((p : Integer),
              (Natural.factorial(n) : Integer) + Integer.one) := {
  claim IntegerMod.make(p, (Natural.factorial(n) : Integer))
      = IntegerMod.make(p, -Integer.one)
      by calc IntegerMod.make(p, (Natural.factorial(n) : Integer))
            = IntegerMod.negate(IntegerMod.one(p))   by IntegerMod.wilson
            = IntegerMod.make(p, -Integer.one);
  claim congruent
      : Integer.CongruentModulo(p, (Natural.factorial(n) : Integer), -Integer.one)
      by IntegerMod.congruent_of_make_equal;
  -- p ∣ n! − (−1), and n! − (−1) = n! + 1.
  obtain ⟨quotient, differenceEquation⟩ from congruent;
  witness quotient with
      calc (Natural.factorial(n) : Integer) + Integer.one
         = (Natural.factorial(n) : Integer) - (-Integer.one)   by ring
         = (p : Integer) * quotient                            by differenceEquation
}
